  title: 'Former French PM Lionel Jospin Dead at 88',
  description: 'Lionel Jospin, the Socialist prime minister who gave France its 35-hour work week and oversaw the introduction of civil partnerships, has died at 88.',
  category: 'politics',
  published: '2026-03-24',
};

const schema = {
  "@context": "https://schema.org",
