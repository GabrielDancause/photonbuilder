---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best Free-to-Play Games",
  "description": "Curated list of the top free-to-play games including Valorant, Fortnite, Apex Legends, League of Legends, Genshin Impact, and Path of Exile.",
  "author": {
    "@type": "Organization",
    "name": "Leeroy Jenkins"
  },
  "publisher": {
    "@type": "Organization",
    "name": "GAB Ventures"
  },
  "url": "https://leeroyjenkins.quest/list-free-games"
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Best Free-to-Play Games | Leeroy Jenkins"
  description="Curated list of the top free-to-play games including Valorant, Fortnite, Apex Legends, League of Legends, Genshin Impact, and Path of Exile. Compare genres, platforms, and monetization."
  canonical="https://leeroyjenkins.quest/list-free-games" schema={schema}
>
  <style>
:root {
      --bg: #08060e;
      --card-bg: #100e18;
      --border: #221e30;
      --accent: #9333EA;
      --accent-hover: #7e22ce;
      --text-primary: #d8d0e8;
      --text-secondary: #888;
      --font-ui: 'Inter', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --score-high: #10b981;
      --score-mid: #f59e0b;
      --score-low: #ef4444;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-ui);
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 60px 24px;
    }

    header {
      text-align: center;
      margin-bottom: 40px;
    }

    h1 {
      font-weight: 900;
      letter-spacing: -1px;
      margin-bottom: 12px;
      font-size: 2rem;
      background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    @media (min-width: 768px) {
      h1 { font-size: 2.5rem; }
    }

    header p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .filter-section {
      margin-bottom: 40px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .search-bar {
      position: relative;
    }

    .search-bar input {
      width: 100%;
      background: var(--card-bg);
      border: 2px solid var(--border);
      color: var(--text-primary);
      padding: 16px 24px;
      border-radius: 12px;
      font-family: var(--font-ui);
      font-size: 1.1rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .search-bar input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px rgba(147, 51, 234, 0.1);
    }

    .filter-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .filter-btn {
      background: var(--card-bg);
      border: 1px solid var(--border);
      color: var(--text-secondary);
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      font-family: var(--font-ui);
      transition: all 0.2s;
    }

    .filter-btn:hover {
      border-color: var(--accent);
      color: var(--text-primary);
    }

    .filter-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
    }

    @media (min-width: 768px) {
      .grid-2 {
        grid-template-columns: 1fr 1fr;
      }
    }

    .card {
      background: var(--card-bg);
      border: 2px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s, border-color 0.2s;
    }

    .card:hover {
      border-color: var(--accent);
      transform: translateY(-4px);
    }

    .card-header {
      padding: 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      background: rgba(255, 255, 255, 0.02);
    }

    .card-title-group h3 {
      font-size: 1.5rem;
      color: #fff;
      font-weight: 800;
      margin-bottom: 4px;
    }

    .card-subtitle {
      color: var(--text-secondary);
      font-size: 0.9rem;
      font-weight: 500;
    }

    .score-badge {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: 12px;
      font-family: var(--font-mono);
      font-weight: 700;
      font-size: 1.1rem;
      background: var(--bg);
      border: 2px solid;
    }

    .score-high { border-color: var(--score-high); color: var(--score-high); }
    .score-mid { border-color: var(--score-mid); color: var(--score-mid); }

    .card-body {
      padding: 24px;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
      gap: 20px;
    }

    .card-description {
      color: var(--text-primary);
      font-size: 0.95rem;
    }

    .metric-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      background: var(--bg);
      padding: 16px;
      border-radius: 12px;
      border: 1px solid var(--border);
    }

    .metric {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .metric-label {
      color: var(--text-secondary);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 700;
    }

    .metric-value {
      color: #fff;
      font-size: 0.95rem;
      font-weight: 500;
    }

    .pros-cons {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .list-title {
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-secondary);
      margin-bottom: 4px;
    }

    .pros-list, .cons-list {
      list-style: none;
      font-size: 0.9rem;
    }

    .pros-list li, .cons-list li {
      position: relative;
      padding-left: 20px;
      margin-bottom: 6px;
      color: var(--text-primary);
    }

    .pros-list li::before {
      content: '+';
      position: absolute;
      left: 0;
      color: var(--score-high);
      font-weight: 800;
    }

    .cons-list li::before {
      content: '-';
      position: absolute;
      left: 0;
      color: var(--score-low);
      font-weight: 800;
    }

    .seo-content {
      margin-top: 80px;
      padding-top: 40px;
      border-top: 1px solid var(--border);
    }

    .seo-content h2 {
      font-size: 1.5rem;
      color: #fff;
      margin-bottom: 16px;
      margin-top: 40px;
    }

    .seo-content h2:first-child {
      margin-top: 0;
    }

    .seo-content p {
      color: var(--text-secondary);
      margin-bottom: 16px;
    }

    .seo-content ul {
      color: var(--text-secondary);
      margin-left: 24px;
      margin-bottom: 16px;
    }

    .seo-content li {
      margin-bottom: 8px;
    }

    footer {
      text-align: center;
      padding: 40px 24px;
      margin-top: 60px;
      font-size: 0.85rem;
      color: var(--text-secondary);
      border-top: 1px solid var(--border);
    }

    footer a {
      color: var(--accent);
      text-decoration: none;
    }

    .hidden {
      display: none !important;
    }

    .no-results {
      grid-column: 1 / -1;
      text-align: center;
      padding: 40px;
      background: var(--card-bg);
      border: 1px dashed var(--border);
      border-radius: 12px;
      color: var(--text-secondary);
    }
  </style>

<div class="container">
    

