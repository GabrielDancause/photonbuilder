              <span class="metric-label">Monetization</span>
              <span class="metric-value">Cosmetics only</span>
            </div>
            <div class="metric">
              <span class="metric-label">Playerbase</span>
              <span class="metric-value">Massive / Active</span>
            </div>
          </div>
