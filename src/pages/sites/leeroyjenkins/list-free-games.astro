            <div class="metric">
              <span class="metric-label">Genre</span>
              <span class="metric-value">Tactical FPS</span>
            </div>
            <div class="metric">
              <span class="metric-label">Platforms</span>
              <span class="metric-value">PC, PS5, Xbox Series X/S</span>
            </div>
