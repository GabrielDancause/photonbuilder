                <td>{m.panelType}</td>
                <td>{m.responseTime}</td>
                <td>{m.hdr}</td>
                <td data-value={m.size}>{m.size}"</td>
                <td data-value={m.price}>${m.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Detailed Reviews</h2>

      {monitors.map((m, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{m.name}</h3>
              {m.badge && <span class="badge">{m.badge}</span>}
            </div>
            <span class="review-price">${m.price}</span>
          </div>

          <p class="review-summary">{m.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Resolution</span><span class="spec-value">{m.resolution}</span></div>
            <div class="spec"><span class="spec-label">Refresh Rate</span><span class="spec-value">{m.refreshRate}Hz</span></div>
            <div class="spec"><span class="spec-label">Panel Type</span><span class="spec-value">{m.panelType}</span></div>
            <div class="spec"><span class="spec-label">Response Time</span><span class="spec-value">{m.responseTime}</span></div>
            <div class="spec"><span class="spec-label">HDR</span><span class="spec-value">{m.hdr}</span></div>
            <div class="spec"><span class="spec-label">Size</span><span class="spec-value">{m.size}"</span></div>
            <div class="spec"><span class="spec-label">Adaptive Sync</span><span class="spec-value">{m.adaptiveSync}</span></div>
          </div>

