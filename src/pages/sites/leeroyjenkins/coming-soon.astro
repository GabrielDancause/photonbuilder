    ]
  },
  {
    icon: '🏆',
    title: 'Tier Lists',
    description: 'Character, weapon, and meta tier lists',
    total: 15,
    items: [
      { name: 'Genshin Tier List', searches: '27,000', status: 'building', href: '' },
      { name: 'Genshin Impact Tier List', searches: '12,000', status: 'building', href: '' },
      { name: 'League Of Legends Tier List', searches: '8,800', status: 'building', href: '' },
      { name: 'Overwatch Tier List', searches: '7,300', status: 'building', href: '' },
      { name: 'Elden Ring Weapon Tier List', searches: '6,200', status: 'building', href: '' },
      { name: 'Diablo 4 Tier List', searches: '5,900', status: 'building', href: '' },
      { name: 'Valorant Tier List', searches: '5,900', status: 'building', href: '' },
      { name: 'Genshin Character Tier List', searches: '4,800', status: 'building', href: '' }
    ]
  },
  {
    icon: '🎮',
    title: 'Game Calculators',
    description: 'Breeding calculators, damage calculators, and build tools',
    total: 27,
    items: [
      { name: 'How Long Will Mail Take From Zip Code To Zip Code Calculator', searches: '16,000', status: 'building', href: '' },
      { name: 'Elden Ring Build Calculator', searches: '6,000', status: 'building', href: '' },
      { name: 'Diablo 4 Build Planner', searches: '5,600', status: 'building', href: '' },
      { name: 'Forge Calculator Roblox', searches: '5,100', status: 'building', href: '' },
      { name: 'Elden Ring Build Planner', searches: '5,000', status: 'building', href: '' },
      { name: 'Elden Ring Level Calculator', searches: '2,700', status: 'building', href: '' },
      { name: 'Cs2 Trade Up Calculator', searches: '2,400', status: 'building', href: '' },
      { name: 'Elden Ring Calculator', searches: '2,300', status: 'building', href: '' }
    ]
  },
  {
    icon: '📖',
    title: 'Game Guides',
    description: 'Walkthroughs, tips, and strategy guides',
    total: 20,
    items: [
      { name: 'Network Optimization Guide', searches: '—', status: 'published', href: '/leeroyjenkins/network-optimization-guide' },
      { name: 'Router Settings Guide', searches: '—', status: 'published', href: '/leeroyjenkins/router-settings-guide' },
      { name: 'Gaming Mouse Sensor Guide', searches: '—', status: 'published', href: '/leeroyjenkins/gaming-mouse-sensor-guide' },
      { name: 'Mouse Weight Mod Guide', searches: '—', status: 'published', href: '/leeroyjenkins/mouse-weight-mod-guide' },
      { name: 'Mouse Switch Guide', searches: '—', status: 'published', href: '/leeroyjenkins/mouse-switch-guide' },
      { name: 'Vpn Gaming Guide', searches: '—', status: 'published', href: '/leeroyjenkins/vpn-gaming-guide' },
      { name: 'Guide Gaming Gear Complete', searches: '—', status: 'published', href: '/leeroyjenkins/guide-gaming-gear-complete' },
      { name: 'Guide Mechanical Keyboards', searches: '—', status: 'published', href: '/leeroyjenkins/guide-mechanical-keyboards' }
    ]
  },
  {
    icon: '🔧',
    title: 'Game Tools',
    description: 'General gaming utilities and tools',
    total: 133,
    items: [
      { name: 'Qr Code Generator', searches: '682,000', status: 'building', href: '' },
      { name: 'Morse Code Translator', searches: '269,000', status: 'building', href: '' },
      { name: 'Barcode Generator', searches: '229,000', status: 'building', href: '' },
      { name: 'Qr Code Scanner', searches: '147,000', status: 'building', href: '' },
