    total: 29,
    items: [
      { name: 'R6 Tracker', searches: '796,000', status: 'published', href: '/leeroyjenkins/r6-tracker' },
      { name: 'Fortnite Tracker', searches: '463,000', status: 'published', href: '/leeroyjenkins/fortnite-tracker' },
      { name: 'Valorant Tracker', searches: '195,000', status: 'published', href: '/leeroyjenkins/valorant-tracker' },
      { name: 'R6 Stat Tracker', searches: '56,000', status: 'published', href: '/leeroyjenkins/r6-stat-tracker' },
      { name: 'Apex Legends Tracker', searches: '13,000', status: 'building', href: '' },
      { name: 'Warzone Tracker', searches: '13,000', status: 'published', href: '/leeroyjenkins/warzone-tracker' },
