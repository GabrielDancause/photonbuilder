      gap: 24px;
      margin-bottom: 60px;
    }

    .engine-card {
      background: var(--card-bg);
      border: 2px solid var(--border-color);
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s, border-color 0.2s;
    }

    .engine-card:hover {
      transform: translateY(-4px);
      border-color: var(--accent-color);
    }

    .card-header {
      padding: 24px 24px 16px;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .engine-icon {
      width: 48px;
      height: 48px;
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent-color);
    }

    .engine-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
    }

    .engine-subtitle {
      font-size: 0.9rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .card-body {
      padding: 24px;
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .metric {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 12px;
    }

    .metric-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .metric-value {
      font-family: var(--font-mono);
      font-weight: 600;
      color: #fff;
      font-size: 0.95rem;
    }

    .metric-full {
      grid-column: 1 / -1;
    }

    .score-container {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-top: 4px;
    }

    .score-bar {
      flex-grow: 1;
      height: 6px;
      background: var(--border-color);
      border-radius: 3px;
      overflow: hidden;
    }

    .score-fill {
      height: 100%;
      background: var(--accent-color);
      border-radius: 3px;
    }

    .score-text {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--accent-color);
      min-width: 30px;
      text-align: right;
    }

    .pros-cons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: auto;
    }

    .pc-list {
      list-style: none;
    }

    .pc-title {
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .pros .pc-title { color: #10b981; }
    .cons .pc-title { color: #ef4444; }

    .pc-list li {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-bottom: 6px;
      padding-left: 16px;
      position: relative;
    }

    .pc-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 8px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
    }

    .pros .pc-list li::before { background: #10b981; }
    .cons .pc-list li::before { background: #ef4444; }

    .seo-content {
