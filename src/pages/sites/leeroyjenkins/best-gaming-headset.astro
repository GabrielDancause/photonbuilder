---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const headsets = [
  {
    name: "Audeze Maxwell",
    badge: "Best Overall",
    price: 299,
    audioQuality: 10,
    micQuality: 9,
    comfort: 8,
    connectivity: "Wireless (2.4GHz + Bluetooth 5.3) / Wired",
    driver: "90mm Planar Magnetic",
    frequencyResponse: "10Hz - 50kHz",
    weight: "490g",
    batteryLife: "80+ hours",
    pros: ["Audiophile-grade planar magnetic sound", "Massive 80-hour battery life", "Incredible AI noise-canceling mic", "Simultaneous Bluetooth and 2.4GHz"],
    cons: ["Very heavy at 490g", "Expensive", "Requires proper seal for best bass"],
    summary: "The Audeze Maxwell sets a new standard for gaming headset audio. The 90mm planar magnetic drivers deliver detail and soundstage that dynamic drivers simply can't touch. While it's undeniably heavy, the suspension strap distributes the weight well enough for long sessions. The AI noise-filtering microphone is also best-in-class, completely blocking out keyboard clicks and background noise."
  },
  {
    name: "Razer BlackShark V2 Pro (2023)",
    badge: "Best for Esports",
    price: 199,
    audioQuality: 8.5,
    micQuality: 9.5,
    comfort: 9.5,
    connectivity: "Wireless (2.4GHz + Bluetooth 5.2)",
    driver: "50mm TriForce Titanium",
    frequencyResponse: "12Hz - 28kHz",
    weight: "320g",
    batteryLife: "70 hours",
    pros: ["Extremely comfortable and lightweight", "Broadcast-quality super wideband mic", "Excellent positional audio for FPS", "Great battery life"],
    cons: ["Slightly gamery aesthetic", "No wired audio option", "Micro-USB to USB-C transition feels slightly dated in some aspects"],
    summary: "Razer's 2023 refresh of the BlackShark V2 Pro fixed its biggest flaw by adding an unbelievable super wideband microphone. It sounds closer to a standalone USB mic than a headset boom. Combined with its extreme comfort, 70-hour battery, and punchy, precise audio tuned for competitive shooters, this is the ultimate esports headset."
  },
  {
    name: "HyperX Cloud III Wireless",
    badge: "Most Comfortable",
    price: 169,
    audioQuality: 8,
    micQuality: 8,
    comfort: 10,
    connectivity: "Wireless (2.4GHz)",
    driver: "53mm Angled",
    frequencyResponse: "10Hz - 21kHz",
    weight: "340g",
    batteryLife: "120 hours",
    pros: ["Legendary comfort that disappears on your head", "Unbelievable 120-hour battery life", "Durable aluminum frame", "Clear, natural sounding mic"],
    cons: ["No Bluetooth connectivity", "Audio is good but lacks deep sub-bass punch", "Software is still clunky"],
    summary: "If comfort is your absolute highest priority, the Cloud III Wireless is the undisputed king. The memory foam is incredibly plush, and the clamping force is perfectly calibrated. Add in a staggering 120-hour battery life (you'll charge it maybe once a month), and it's a headset you can truly wear all day and forget about."
  },
  {
    name: "SteelSeries Arctis Nova Pro Wireless",
    badge: "Best Premium",
    price: 349,
    audioQuality: 9,
    micQuality: 8,
    comfort: 8.5,
    connectivity: "Wireless (2.4GHz + Bluetooth 5.0) / Wired",
    driver: "40mm Neodymium",
    frequencyResponse: "10Hz - 22kHz",
    weight: "338g",
    batteryLife: "Infinite (hot-swappable batteries)",
    pros: ["Hot-swappable batteries mean it never dies", "Active Noise Cancellation (ANC)", "Simultaneous audio mixing via base station", "Sleek, mature design"],
    cons: ["Very expensive", "ANC nub inside ear cup can bother some users", "Mic is just okay for the price"],
    summary: "The Arctis Nova Pro Wireless is the ultimate quality-of-life headset. The included base station charges a spare battery, meaning you can hot-swap in seconds and literally never plug the headset in. It also features Active Noise Cancellation to block out fan noise or roommates, and the simultaneous Bluetooth/2.4GHz mixing is flawless."
  },
  {
    name: "Corsair HS80 RGB Wireless",
    badge: "Best Mid-Range",
    price: 149,
    audioQuality: 8.5,
    micQuality: 9,
    comfort: 8.5,
    connectivity: "Wireless (2.4GHz) / Wired USB",
    driver: "50mm Neodymium",
    frequencyResponse: "20Hz - 40kHz",
    weight: "367g",
    batteryLife: "20 hours",
    pros: ["Fantastic broadcast-quality microphone", "Dolby Atmos support included", "Very comfortable suspension band", "Sturdy aluminum build"],
    cons: ["Battery life is mediocre compared to rivals", "Fabric ear pads trap some heat", "Range isn't as long as others"],
    summary: "The HS80 is a sleeper hit. It boasts one of the best microphones on any wireless headset, period. The audio quality is rich and detailed, further enhanced by the included Dolby Atmos license. The floating suspension headband is very comfortable, though the 20-hour battery life feels quite low in 2026."
  },
  {
    name: "Logitech G Pro X 2 Lightspeed",
    price: 249,
    audioQuality: 9,
    micQuality: 7.5,
    comfort: 9,
    connectivity: "Wireless (2.4GHz + Bluetooth) / Wired 3.5mm",
    driver: "50mm Graphene",
    frequencyResponse: "20Hz - 20kHz",
    weight: "345g",
    batteryLife: "50 hours",
    pros: ["Graphene drivers deliver incredibly fast, distortion-free sound", "Very comfortable for long sessions", "Durable, professional build", "Good battery life"],
    cons: ["Microphone sounds compressed", "Expensive", "Bluetooth implementation is basic (no simultaneous mixing)"],
    summary: "Logitech introduced graphene drivers with the Pro X 2, and the result is impressively crisp, accurate audio with zero distortion even at high volumes. It's built like a tank and extremely comfortable. However, the microphone is a noticeable step down from competitors like Razer and Corsair, sounding overly compressed."
  },
  {
    name: "Drop + EPOS PC38X",
    badge: "Best Open-Back",
    price: 169,
    audioQuality: 9.5,
    micQuality: 8.5,
    comfort: 8.5,
    connectivity: "Wired (3.5mm)",
    driver: "Dynamic (Sennheiser drivers)",
    frequencyResponse: "10Hz - 30kHz",
    weight: "253g",
    batteryLife: "N/A",
    pros: ["Unmatched soundstage and imaging for FPS games", "Audiophile-level sound quality", "Very lightweight", "No charging required"],
    cons: ["Wired only", "Open-back design leaks sound and lets noise in", "Yellow accents aren't for everyone"],
    summary: "If you play in a quiet room and don't mind a cable, the PC38X offers the best directional audio for gaming, period. The open-back design creates a massive soundstage, making it incredibly easy to pinpoint footsteps. The Sennheiser drivers deliver beautiful, natural sound that easily doubles for critical music listening."
  },
  {
    name: "Razer Kraken V3 X",
    badge: "Best Budget",
    price: 49,
    audioQuality: 7,
    micQuality: 7,
    comfort: 8,
    connectivity: "Wired USB",
    driver: "40mm TriForce",
    frequencyResponse: "12Hz - 28kHz",
    weight: "285g",
    batteryLife: "N/A",
    pros: ["Incredibly cheap", "Very lightweight at 285g", "Decent sound for the price", "Comfortable memory foam pads"],
    cons: ["Wired only", "Build feels plasticky", "Mic picks up some background noise", "No inline controls on the cable"],
    summary: "At $49, the Kraken V3 X is the best entry-level headset available. It's incredibly light, making it comfortable for hours, and the 40mm TriForce drivers deliver surprisingly punchy bass and clear mids. It's entirely plastic and basic, but it gets the fundamentals right for gamers on a strict budget."
  },
  {
    name: "Sennheiser HD 560S + Antlion ModMic",
    badge: "Best Custom Setup",
    price: 280,
    audioQuality: 10,
    micQuality: 9,
    comfort: 9,
    connectivity: "Wired",
    driver: "Dynamic Open-Back",
    frequencyResponse: "6Hz - 38kHz",
    weight: "240g",
    batteryLife: "N/A",
    pros: ["Reference-grade audio quality", "Incredible comfort and breathability", "ModMic offers stellar voice clarity", "Modular (can replace mic easily)"],
    cons: ["Requires two cables (headphone + mic)", "Open-back leaks sound", "Not a plug-and-play 'headset'"],
    summary: "For the purists. By pairing a phenomenal audiophile headphone (the HD 560S) with an attachable boom mic (Antlion ModMic), you get audio quality that destroys 99% of gaming headsets. The imaging is razor-sharp. It's slightly less convenient due to the double cables, but the sonic reward is immense."
  },
  {
    name: "Turtle Beach Stealth Pro",
    price: 329,
    audioQuality: 9,
    micQuality: 8.5,
    comfort: 7.5,
    connectivity: "Wireless (2.4GHz + Bluetooth 5.1)",
    driver: "50mm Nanoclear",
    frequencyResponse: "10Hz - 22kHz",
    weight: "400g",
    batteryLife: "12 hours per battery (swappable)",
    pros: ["Excellent ANC (Active Noise Cancellation)", "Hot-swappable battery system", "Powerful, bass-rich sound signature", "Simultaneous Bluetooth"],
    cons: ["Heavy and clamps tightly", "Battery life per pack is short", "Expensive"],
    summary: "The Stealth Pro is a direct competitor to the Nova Pro Wireless. It features similar hot-swappable batteries and simultaneous Bluetooth, but edges out the SteelSeries with superior Active Noise Cancellation and a punchier, more aggressive sound profile. However, it's quite heavy and the clamping force is strong, making it less comfortable for larger heads."
  }
];

const categoryWinners = [
  { category: "Best Overall", pick: "Audeze Maxwell", reason: "Planar magnetic drivers deliver unmatched audio quality with 80-hour battery life." },
  { category: "Best for Esports", pick: "Razer BlackShark V2 Pro", reason: "Super wideband mic, extreme comfort, and precise FPS audio tuning." },
  { category: "Best Budget", pick: "Razer Kraken V3 X", reason: "Incredible value, very lightweight, and solid sound for under $50." },
  { category: "Most Comfortable", pick: "HyperX Cloud III Wireless", reason: "Plush memory foam and a staggering 120-hour battery life." },
  { category: "Best Premium", pick: "SteelSeries Arctis Nova Pro", reason: "Hot-swappable batteries, ANC, and simultaneous audio mixing." },
  { category: "Best Open-Back", pick: "Drop + EPOS PC38X", reason: "Massive soundstage and flawless directional imaging for competitive play." }
];

const faqs = [
  {
    q: "Wireless vs. Wired gaming headsets: Which is better?",
    a: "Wireless technology in 2026 has virtually zero latency when using a 2.4GHz USB dongle, making it just as responsive as wired. Wireless offers freedom of movement and cleaner setups, but requires charging and costs more. Wired headsets (like the PC38X) still offer the absolute best audio fidelity per dollar and never run out of battery. For most gamers, the convenience of wireless wins out."
  },
  {
    q: "What is an open-back vs. closed-back headset?",
    a: "Closed-back headsets have sealed ear cups. They block outside noise and prevent your game audio from leaking into your mic, making them best for loud environments or playing with others in the room. Open-back headsets have perforated ear cups that let air and sound pass through. This creates a wider, more natural 'soundstage' (great for pinpointing footsteps) and keeps your ears cooler, but they let all outside noise in."
  },
  {
    q: "Do I need 7.1 Surround Sound for gaming?",
    a: "No. 'True' 7.1 surround sound in headsets is a marketing gimmick. Good stereo audio is actually better for competitive gaming because game engines already calculate 3D spatial audio (like footsteps) perfectly for two ears. Features like Dolby Atmos or Windows Sonic can add nice immersion for single-player games, but pure stereo is preferred by esports pros."
  },
  {
    q: "Why does my wireless headset mic sound bad?",
    a: "Bluetooth and 2.4GHz connections have limited bandwidth. To send high-quality game audio to your ears without lag, the headset has to compress the audio coming from your microphone. Wired headsets don't have this bandwidth limit. However, newer wireless headsets like the Razer BlackShark V2 Pro use 'super wideband' technology to dedicate more bandwidth to the mic, sounding much better."
  },
  {
    q: "What are Planar Magnetic drivers?",
    a: "Most headsets use dynamic drivers (a cone pushed by a magnet). Planar magnetic drivers (used in the Audeze Maxwell) use a thin, flat diaphragm suspended between magnets. They move much faster and more uniformly, resulting in incredibly low distortion, tighter bass, and far more detail. The tradeoff is they are heavier and more expensive to manufacture."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Gaming Headsets 2026",
    "description": "Compare the best gaming headsets of 2026. Wireless, wired, budget and premium options with specs, pros/cons, and verdicts.",
    "author": {
      "@type": "Organization",
      "name": "Leeroy Jenkins"
    },
    "datePublished": "2026-05-15",
    "dateModified": "2026-05-15"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Best Gaming Headsets 2026 — Top Picks Ranked",
  description: "Compare the best gaming headsets of 2026. Wireless, wired, budget and premium options with specs, pros/cons, and verdicts.",
  category: "list",
  published: "2026-05-15",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Best Gaming Headsets 2026 — Top Picks Ranked"
  description="Compare the best gaming headsets of 2026. Wireless, wired, budget and premium options with specs, pros/cons, and verdicts."
  canonical="https://leeroyjenkins.quest/best-gaming-headset"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Best Gaming Headsets (2026)</h1>
      <p>We tested and ranked the top 10 gaming headsets of the year. From $49 budget wired options to audiophile-grade planar magnetic wireless powerhouses, find your perfect audio upgrade.</p>
    </div>

    <section class="content-section">
      <p>Audio is half the experience. A great gaming headset doesn't just immerse you in the world; it gives you a tactical advantage. Hearing the exact direction of footsteps before you see the enemy is the difference between winning and losing.</p>
      <p>We evaluated dozens of headsets based on audio fidelity, microphone clarity, long-term comfort, battery life, and overall value. Below are the definitive best options for every type of gamer and budget in 2026.</p>

      <h2>Quick Verdict: Category Winners</h2>
      <div class="winners-grid">
        {categoryWinners.map(w => (
          <div class="winner-card">
            <span class="winner-label">{w.category}</span>
            <strong>{w.pick}</strong>
            <span class="winner-reason">{w.reason}</span>
          </div>
        ))}
      </div>

      <h2>Comparison Table</h2>
      <p>Click any column header to sort. All prices are MSRP in USD.</p>
      <div class="table-wrapper">
        <table id="comparison-table">
          <thead>
            <tr>
              <th data-sort="string">Headset</th>
              <th data-sort="number">Price</th>
              <th data-sort="number">Audio</th>
              <th data-sort="number">Mic</th>
              <th data-sort="number">Comfort</th>
              <th data-sort="string">Connectivity</th>
              <th data-sort="string">Battery</th>
            </tr>
          </thead>
          <tbody>
            {headsets.map(h => (
              <tr>
                <td><strong>{h.name}</strong></td>
                <td data-value={h.price}>${h.price}</td>
                <td data-value={h.audioQuality}>{h.audioQuality}/10</td>
                <td data-value={h.micQuality}>{h.micQuality}/10</td>
                <td data-value={h.comfort}>{h.comfort}/10</td>
                <td>{h.connectivity}</td>
                <td data-value={parseInt(h.batteryLife) || 0}>{h.batteryLife}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Detailed Reviews</h2>

      {headsets.map((h, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{h.name}</h3>
              {h.badge && <span class="badge">{h.badge}</span>}
            </div>
            <span class="review-price">${h.price}</span>
          </div>

          <p class="review-summary">{h.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Connectivity</span><span class="spec-value">{h.connectivity}</span></div>
            <div class="spec"><span class="spec-label">Driver</span><span class="spec-value">{h.driver}</span></div>
            <div class="spec"><span class="spec-label">Freq Response</span><span class="spec-value">{h.frequencyResponse}</span></div>
            <div class="spec"><span class="spec-label">Weight</span><span class="spec-value">{h.weight}</span></div>
            <div class="spec"><span class="spec-label">Battery Life</span><span class="spec-value">{h.batteryLife}</span></div>
            <div class="spec"><span class="spec-label">Audio Quality</span><span class="spec-value">{h.audioQuality}/10</span></div>
            <div class="spec"><span class="spec-label">Mic Quality</span><span class="spec-value">{h.micQuality}/10</span></div>
            <div class="spec"><span class="spec-label">Comfort</span><span class="spec-value">{h.comfort}/10</span></div>
          </div>

          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{h.pros.map(p => <li>{p}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{h.cons.map(con => <li>{con}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Gaming Headset Buying Guide</h2>

      <h3>Wireless vs. Wired</h3>
      <p>Modern 2.4GHz wireless headsets have imperceptible latency, making them perfectly viable for competitive gaming. The main tradeoffs are price and the need to recharge. Wired headsets (like the Drop + EPOS PC38X) still offer the best raw audio quality for the money, never run out of battery, and don't suffer from microphone compression issues.</p>

      <h3>Open-Back vs. Closed-Back</h3>
      <p>Closed-back headsets seal around your ears, isolating you from background noise. This is ideal for loud environments or LAN parties. Open-back headsets have perforated cups that let sound pass through. They sound more natural and offer a wider soundstage (crucial for FPS games), but they leak audio into your room and let outside noise in.</p>

      <h3>Microphone Quality Matters</h3>
      <p>If you play multiplayer games, your microphone quality is arguably as important as your audio quality. Headsets like the Razer BlackShark V2 Pro and Corsair HS80 feature super wideband or broadcast-quality mics that sound fantastic. If mic quality is paramount, consider a dedicated USB microphone or a custom setup like the ModMic.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

    </section>
  </div>

  <script is:inline>
    (function() {
      const table = document.getElementById('comparison-table');
      if (!table) return;
      const headers = table.querySelectorAll('th');
      let currentSort = { col: -1, asc: true };

      headers.forEach((th, index) => {
        th.style.cursor = 'pointer';
        th.addEventListener('click', () => {
          const sortType = th.dataset.sort;
          const asc = currentSort.col === index ? !currentSort.asc : true;
          currentSort = { col: index, asc };

          headers.forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
          th.classList.add(asc ? 'sort-asc' : 'sort-desc');

          const tbody = table.querySelector('tbody');
          const rows = Array.from(tbody.querySelectorAll('tr'));

          rows.sort((a, b) => {
            const cellA = a.children[index];
            const cellB = b.children[index];
            let valA, valB;

            if (sortType === 'number') {
              valA = parseFloat(cellA.dataset.value || cellA.textContent.replace(/[^0-9.\-]/g, ''));
              valB = parseFloat(cellB.dataset.value || cellB.textContent.replace(/[^0-9.\-]/g, ''));
              return asc ? valA - valB : valB - valA;
            } else {
              valA = cellA.textContent.trim().toLowerCase();
              valB = cellB.textContent.trim().toLowerCase();
              return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
            }
          });

          rows.forEach(row => tbody.appendChild(row));
        });
      });
    })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }

    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Winners Grid */
    .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
    .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
    .winner-card strong { font-size: 1.05rem; }
    .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

    /* Comparison Table */
    .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; min-width: 800px; }
    th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; user-select: none; position: relative; }
    th::after { content: '⇅'; margin-left: 0.3rem; opacity: 0.3; font-size: 0.75rem; }
    th.sort-asc::after { content: '↑'; opacity: 0.8; }
    th.sort-desc::after { content: '↓'; opacity: 0.8; }
    td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* Review Cards */
    .review-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .review-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
    .review-header > div { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .review-rank { font-size: 1.1rem; font-weight: 800; color: var(--accent-color); }
    .review-header h3 { margin: 0; font-size: 1.25rem; color: var(--text-primary); }
    .badge { background: var(--accent-color); color: #fff; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 20px; white-space: nowrap; }
    .review-price { font-size: 1.4rem; font-weight: 800; color: var(--text-primary); }
    .review-summary { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

    .specs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-bottom: 1rem; }
    .spec { display: flex; flex-direction: column; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border-color); }
    .spec-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); font-weight: 600; }
    .spec-value { font-size: 0.95rem; color: var(--text-primary); font-weight: 600; }

    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .pros h4, .cons h4 { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .pros h4 { color: #22c55e; }
    .cons h4 { color: #ef4444; }
    .pros ul, .cons ul { margin: 0; padding-left: 1.2rem; font-size: 0.9rem; }
    .pros li, .cons li { margin-bottom: 0.3rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .pros-cons { grid-template-columns: 1fr; }
      .specs-grid { grid-template-columns: 1fr 1fr; }
      .review-header { flex-direction: column; }
      .winners-grid { grid-template-columns: 1fr; }
