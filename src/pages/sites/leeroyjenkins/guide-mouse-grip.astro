    }

    .seo-content h2 {
      font-size: 1.5rem;
      color: #fff;
      margin-bottom: 16px;
      margin-top: 40px;
    }

    .seo-content h2:first-child {
      margin-top: 0;
    }

    .seo-content p {
      color: var(--text-secondary);
      margin-bottom: 16px;
