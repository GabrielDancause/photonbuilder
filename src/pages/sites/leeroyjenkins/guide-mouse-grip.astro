    }

    .section-title {
      font-size: 1.8rem;
      font-weight: 800;
      margin-bottom: 24px;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 32px;
      transition: transform 0.2s, border-color 0.2s;
    }

    .card:hover {
      border-color: var(--accent-color);
      transform: translateY(-2px);
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 16px;
    }

    .card-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
    }

    .badge {
      background: rgba(147, 51, 234, 0.1);
      color: var(--accent-color);
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 600;
      font-family: var(--font-mono);
      border: 1px solid rgba(147, 51, 234, 0.3);
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    .pros-cons h4 {
      color: #fff;
      margin-bottom: 12px;
      font-size: 1.1rem;
    }

    .pros-list, .cons-list {
      list-style: none;
    }

    .pros-list li, .cons-list li {
      position: relative;
      padding-left: 24px;
      margin-bottom: 8px;
      color: var(--text-secondary);
    }

    .pros-list li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: #10b981;
      font-weight: bold;
    }

    .cons-list li::before {
      content: '×';
      position: absolute;
