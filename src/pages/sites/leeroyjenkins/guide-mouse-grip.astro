      color: #fff;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      flex-shrink: 0;
    }

    .step-content h4 {
      color: #fff;
      margin-bottom: 4px;
    }

    .step-content p {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    .table-container {
      overflow-x: auto;
      margin-top: 24px;
    }

