    }

    .recommendations {
      margin-top: 24px;
      padding-top: 24px;
      border-top: 1px solid var(--border-color);
    }

    .recommendations h4 {
      color: #fff;
      margin-bottom: 12px;
    }

    .mouse-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .mouse-tag {
      background: var(--bg-color);
