      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    header p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .search-container {
      margin-bottom: 40px;
      position: relative;
    }

    .search-input {
      width: 100%;
      background: var(--card-bg);
      border: 2px solid var(--border-color);
