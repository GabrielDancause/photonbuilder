    }
  }
};

export const meta = {
  title: "Mouse Grip Styles Guide | Leeroy Jenkins",
  description: "A comprehensive guide to mouse grip styles (Palm, Claw, Fingertip), hand size measurement, and the best mouse shapes for each grip.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Mouse Grip Styles Guide | Leeroy Jenkins"
  description="A comprehensive guide to mouse grip styles (Palm, Claw, Fingertip), hand size measurement, and the best mouse shapes for each grip."
  canonical="https://leeroyjenkins.quest/guide-mouse-grip" schema={schema}
>
  <style>

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-ui);
      background: var(--bg-color);
      color: var(--text-primary);
