---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Interactive Gaming PC Build Calculator | $500 to $3000 Builds',
  description: 'Interactive calculator showing exactly what to buy for your gaming PC. Compare FPS for Valorant, CS2, Fortnite, find bottlenecks, and compare pre-built vs custom.',
  category: 'tool',
  keywords: ['gaming pc calculator', 'pc build planner', 'fps estimator', 'bottleneck calculator', 'custom vs pre-built pc', 'power supply calculator']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" },
    "publisher": { "@type": "Organization", "name": "Leeroy Jenkins" },
    "datePublished": "2026-03-22",
    "dateModified": "2026-03-22"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much should I spend on a gaming PC?",
        "acceptedAnswer": { "@type": "Answer", "text": "A budget of $800 to $1200 is the sweet spot for 1080p and 1440p gaming. At this price range, a custom PC outperforms consoles in every way while offering upgradeability." }
      },
      {
        "@type": "Question",
        "name": "Is it better to build or buy a pre-built gaming PC?",
        "acceptedAnswer": { "@type": "Answer", "text": "Building your own PC usually saves you 15-30% compared to a pre-built with the same specs. It also ensures you get high-quality components for the power supply and motherboard, which pre-builts often compromise on." }
      },
      {
        "@type": "Question",
        "name": "What is a CPU bottleneck?",
        "acceptedAnswer": { "@type": "Answer", "text": "A bottleneck occurs when one component limits the performance of another. A CPU bottleneck happens when your processor isn't fast enough to keep up with your graphics card, resulting in lower FPS and stuttering in games." }
      },
      {
        "@type": "Question",
        "name": "How much RAM do I need for gaming?",
        "acceptedAnswer": { "@type": "Answer", "text": "16GB is the current standard for gaming, but 32GB is highly recommended for newer titles and multitasking. If you stream or have many browser tabs open while gaming, 32GB will prevent stuttering." }
      },
      {
        "@type": "Question",
        "name": "How much wattage should my power supply have?",
        "acceptedAnswer": { "@type": "Answer", "text": "Take your estimated system wattage and add at least 20-30% overhead for safety and future upgrades. For most mid-range builds, a high-quality 650W to 750W power supply is ideal." }
      }
    ]
  }
]);
---

<SiteLayout site="leeroyjenkins" title={meta.title} description={meta.description} canonical="https://leeroyjenkins.quest/gaming-pc-builder">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <div style="max-width:900px;margin:0 auto;padding:16px 20px 0;">
    <div style="background:rgba(147,51,234,0.08);border:1px solid rgba(147,51,234,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;">
      🖥️ <strong style="color:#9333EA;">PS5 just jumped to $650.</strong> For that price, you can build a PC that outperforms it at 1080p and 1440p — and plays thousands more games. Configure your build below. <a href="https://gab.ae/news/ps5-price-hike-pc-gaming-bottleneck-2026" style="color:var(--accent-color);">Why consoles cost more →</a>
    </div>
  </div>
  <div style="background:rgba(147,51,234,0.08);border:1px solid rgba(147,51,234,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
    🖥️ <strong style="color:#9333EA;">Building your own PC saves 30-40% vs prebuilt — and a $1,200 custom build outperforms a $2,000 prebuilt.</strong> With the PS5 price hike to $500, PC gaming is more cost-effective than ever at the mid-range. Pick your budget tier and get exact parts. <a href="https://gab.ae/news/ps5-price-hike-pc-gaming-bottleneck-2026" style="color:#9333EA;">Why gamers are switching to PC →</a>
  </div>
  <section class="mill-hero">
    <div class="mill-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>The Ultimate Gaming PC <em>Build Calculator</em></h1>
    <p class="mill-hero-hook">An <strong>$800 PC beats a $650 console in every way.</strong> <br/>See exactly what you need for maximum FPS.</p>
    <div class="mill-hero-stats">
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-fastest">144+ FPS</span>
        <span class="mill-stat-label">Esports Standard</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-slowest">0%</span>
        <span class="mill-stat-label">Bottleneck Target</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num">15-30%</span>
        <span class="mill-stat-label">Custom Build Savings</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="mill-section">
    <h2 class="mill-section-title">Design Your Perfect Build</h2>
    <p class="mill-section-sub">Set your budget to automatically generate a perfectly balanced part list.</p>

    <div class="mill-calc-container">
      <div class="mill-calc-inputs">
        <div class="mill-input-group">
          <label for="budget-slider">Total Budget: <strong id="budget-display">$1500</strong></label>
          <input type="range" id="budget-slider" min="500" max="3000" step="50" value="1500" />
          <div class="mill-slider-labels"><span>$500</span><span>$1500</span><span>$3000</span></div>
        </div>

        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="gpu-select">Graphics Card (GPU)</label>
            <select id="gpu-select">
              <option value="rx6600">AMD RX 6600 (~$200)</option>
              <option value="rtx4060">NVIDIA RTX 4060 (~$300)</option>
              <option value="rx7800xt" selected>AMD RX 7800 XT (~$500)</option>
              <option value="rtx4070s">NVIDIA RTX 4070 Super (~$600)</option>
              <option value="rtx4080s">NVIDIA RTX 4080 Super (~$1000)</option>
              <option value="rtx4090">NVIDIA RTX 4090 (~$1800)</option>
            </select>
          </div>
          <div class="mill-input-group">
            <label for="cpu-select">Processor (CPU)</label>
            <select id="cpu-select">
              <option value="i3">Intel i3-12100F / Ryzen 5 5500 (~$100)</option>
              <option value="i5">Intel i5-12400F / Ryzen 5 5600 (~$150)</option>
              <option value="ryzen7" selected>Ryzen 5 7600X / i5-13600K (~$250)</option>
              <option value="ryzenx3d">Ryzen 7 7800X3D (~$400)</option>
              <option value="i9">Intel i9-14900K / Ryzen 9 7950X3D (~$600)</option>
            </select>
          </div>
          <div class="mill-input-group">
            <label for="ram-select">Memory (RAM)</label>
            <select id="ram-select">
              <option value="16">16GB DDR4 (~$40)</option>
              <option value="32d4">32GB DDR4 (~$70)</option>
              <option value="32d5" selected>32GB DDR5 (~$100)</option>
              <option value="64">64GB DDR5 (~$200)</option>
            </select>
          </div>
        </div>

        <button id="calc-btn" class="mill-btn">Calculate Build Performance</button>
      </div>

      <!-- RESULTS -->
      <div class="mill-calc-results" id="results-panel" style="display:none;">
        <div class="mill-result-header">
          <div class="mill-result-title">Performance Estimate</div>
          <div class="mill-result-age" id="result-bottleneck"><strong>0%</strong> Bottleneck</div>
          <div class="mill-result-years"><span id="result-psu">750W</span> Recommended Power Supply</div>
        </div>

        <!-- MILESTONES / FPS -->
        <div class="mill-milestones" id="milestones-container">
          <div class="mill-milestone reached show">
            <div class="mill-milestone-icon">🔫</div>
            <div class="mill-milestone-amt" id="fps-valorant">300+ FPS</div>
            <div class="mill-milestone-age">Valorant (1080p Comp)</div>
          </div>
          <div class="mill-milestone reached show">
            <div class="mill-milestone-icon">💣</div>
            <div class="mill-milestone-amt" id="fps-cs2">250+ FPS</div>
            <div class="mill-milestone-age">CS2 (1080p Low)</div>
          </div>
          <div class="mill-milestone reached show">
            <div class="mill-milestone-icon">🪂</div>
            <div class="mill-milestone-amt" id="fps-fortnite">200+ FPS</div>
            <div class="mill-milestone-age">Fortnite (1080p Comp)</div>
          </div>
          <div class="mill-milestone reached show">
            <div class="mill-milestone-icon">🌆</div>
            <div class="mill-milestone-amt" id="fps-cyberpunk">80 FPS</div>
            <div class="mill-milestone-age">Cyberpunk (1440p High)</div>
          </div>
        </div>

        <!-- ANIMATED BAR CHART (Price to Performance) -->
        <div class="mill-chart-wrap">
          <div class="mill-chart-title">Component Budget Allocation</div>
          <div class="mill-chart" id="wealth-chart">
            <div class="mill-chart-bar-group" style="flex: 0.45">
              <div class="mill-chart-tooltip">GPU: 45%</div>
              <div class="mill-chart-bar" style="height: 100%;"><div class="contrib-part" style="height: 100%; background: var(--accent-color);"></div></div>
              <div class="mill-chart-bar-label">GPU</div>
            </div>
            <div class="mill-chart-bar-group" style="flex: 0.25">
              <div class="mill-chart-tooltip">CPU: 25%</div>
              <div class="mill-chart-bar" style="height: 60%;"><div class="contrib-part" style="height: 100%; background: #3b82f6;"></div></div>
              <div class="mill-chart-bar-label">CPU</div>
            </div>
            <div class="mill-chart-bar-group" style="flex: 0.15">
              <div class="mill-chart-tooltip">Mobo/RAM: 15%</div>
              <div class="mill-chart-bar" style="height: 35%;"><div class="contrib-part" style="height: 100%; background: #10b981;"></div></div>
              <div class="mill-chart-bar-label">Base</div>
            </div>
            <div class="mill-chart-bar-group" style="flex: 0.15">
              <div class="mill-chart-tooltip">PSU/Case: 15%</div>
              <div class="mill-chart-bar" style="height: 35%;"><div class="contrib-part" style="height: 100%; background: #8b5cf6;"></div></div>
              <div class="mill-chart-bar-label">Misc</div>
            </div>
          </div>
          <div class="mill-chart-legend">
            <span><i class="mill-legend-dot contributions"></i> Optimal GPU Heavy Balance</span>
          </div>
        </div>

        <div class="mill-insight" id="result-insight"><strong>Perfect Balance.</strong> Your CPU and GPU are perfectly matched for high-refresh rate 1440p gaming.</div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="mill-section">
    <h2 class="mill-section-title">Custom Build vs Pre-built</h2>
    <p class="mill-section-sub">See how much you save by building it yourself.</p>

    <div class="mill-compare-controls">
      <div class="mill-input-group" style="max-width: 100%;">
        <label for="compare-budget">Target Specs Budget</label>
        <select id="compare-budget">
          <option value="800">Entry Level ($800 Custom)</option>
          <option value="1500" selected>Mid-Range ($1500 Custom)</option>
          <option value="2500">High-End ($2500 Custom)</option>
        </select>
      </div>
      <button id="compare-btn" class="mill-btn" style="max-width: 200px; align-self: center; margin-top: 1rem;">Compare Value</button>
    </div>

    <div class="mill-compare-results" id="compare-results" style="display:none;">
      <div class="mill-compare-cards">
        <div class="mill-compare-card" id="compare-card-a"></div>
        <div class="mill-compare-card" id="compare-card-b"></div>
      </div>
      <div class="mill-compare-race" id="compare-race"></div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mill-section">
    <h2 class="mill-section-title">Frequently Asked Questions</h2>
    <div class="mill-faq">
      <details class="mill-faq-item">
        <summary>How much should I spend on a gaming PC?</summary>
        <p>A budget of $800 to $1200 is the sweet spot for 1080p and 1440p gaming. At this price range, a custom PC outperforms consoles in every way while offering upgradeability.</p>
      </details>
      <details class="mill-faq-item">
        <summary>Is it better to build or buy a pre-built gaming PC?</summary>
        <p>Building your own PC usually saves you 15-30% compared to a pre-built with the same specs. It also ensures you get high-quality components for the power supply and motherboard, which pre-builts often compromise on.</p>
      </details>
      <details class="mill-faq-item">
        <summary>What is a CPU bottleneck?</summary>
        <p>A bottleneck occurs when one component limits the performance of another. A CPU bottleneck happens when your processor isn't fast enough to keep up with your graphics card, resulting in lower FPS and stuttering in games.</p>
      </details>
      <details class="mill-faq-item">
        <summary>How much RAM do I need for gaming?</summary>
        <p>16GB is the current standard for gaming, but 32GB is highly recommended for newer titles and multitasking. If you stream or have many browser tabs open while gaming, 32GB will prevent stuttering.</p>
      </details>
      <details class="mill-faq-item">
        <summary>How much wattage should my power supply have?</summary>
        <p>Take your estimated system wattage and add at least 20-30% overhead for safety and future upgrades. For most mid-range builds, a high-quality 650W to 750W power supply is ideal.</p>
      </details>
    </div>
  </section>


  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="https://westmountfundamentals.com/debt-payoff-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Debt Payoff Calculator: See Exactly When You</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Find out how much time and money you can save. Use our interactive debt payoff calculator to compare snowball, avalanche...</p>
      </a>
      <a href="https://pleasestartplease.photonbuilder.com/car-cost-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">The Real Cost of Owning a Car</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Interactive calculator showing the true 5-year cost of owning different vehicles. Compare MSRP, depreciation, insurance,...</p>
      </a>
      <a href="/guide-gaming-pc-complete" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">The Complete Guide to Building a Gaming PC (2026)</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Everything about building a gaming PC: component selection, GPU benchmarks, bottleneck analysis, budget tiers, and step-...</p>
      </a>
    </div>
  </div>
</SiteLayout>

<style is:global>
  /* ===== MILLIONAIRE CALCULATOR PATTERN ===== */
  .mill-page { max-width: 1100px; margin: 0 auto; }
  .mill-hero {
    text-align: center;
    padding: 2.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(147,51,234,0.12) 0%, rgba(147,51,234,0.02) 60%, rgba(147,51,234,0.08) 100%);
    border-bottom: 1px solid var(--border-color, #152040);
    position: relative;
    overflow: hidden;
  }
  .mill-hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(147,51,234,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(147,51,234,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    padding: 0.35rem 1rem;
    border: 1px solid var(--accent-color, #9333EA);
    border-radius: 100px;
    color: var(--accent-color, #9333EA);
    margin-bottom: 1.5rem;
    font-weight: 600;
    animation: mill-fadeUp 0.6s ease both;
  }
  .mill-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    margin: 0 auto 1rem;
    max-width: 700px;
    color: var(--text-primary, #c8d0de);
    animation: mill-fadeUp 0.6s 0.1s ease both;
  }
  .mill-hero h1 em {
    color: var(--accent-color, #9333EA);
    font-style: italic;
  }
  .mill-hero-hook {
    font-size: 1.15rem;
    color: var(--text-secondary, #94a3b8);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    animation: mill-fadeUp 0.6s 0.2s ease both;
  }
  .mill-hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    animation: mill-fadeUp 0.6s 0.3s ease both;
  }
  .mill-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .mill-stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent-color, #9333EA);
    white-space: nowrap;
  }
  .mill-stat-label {
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* SECTIONS */
  .mill-section {
    padding: 2.5rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .mill-section-title {
    font-size: 1.6rem;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .mill-section-sub {
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  /* CALCULATOR */
  .mill-calc-container {
    display: grid;
    gap: 2rem;
  }
  .mill-calc-inputs {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 2rem;
  }
  .mill-input-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .mill-input-row { grid-template-columns: 1fr; }
  }
  .mill-input-group {
    margin-bottom: 1.25rem;
  }
  .mill-input-group label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.4rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .mill-input-group select,
  .mill-input-group input[type="number"] {
    width: 100%;
    padding: 0.65rem 0.75rem;
    background: var(--bg-color, #060a12);
    border: 1px solid var(--border-color, #152040);
    border-radius: 8px;
    color: var(--text-primary, #c8d0de);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .mill-input-group select:focus,
  .mill-input-group input:focus {
    outline: none;
    border-color: var(--accent-color, #9333EA);
    box-shadow: 0 0 0 3px rgba(147,51,234,0.1);
  }

  /* SLIDER */
  .mill-input-group input[type="range"] {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    background: linear-gradient(90deg, var(--accent-color, #9333EA) 0%, var(--border-color, #152040) 0%);
    border-radius: 3px;
    outline: none;
    margin-top: 0.5rem;
  }
  .mill-input-group input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent-color, #9333EA);
    cursor: pointer;
    box-shadow: 0 0 12px rgba(147,51,234,0.4);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .mill-input-group input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.2);
    box-shadow: 0 0 18px rgba(147,51,234,0.5);
  }
  .mill-input-group input[type="range"]::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent-color, #9333EA);
    cursor: pointer;
    border: none;
    box-shadow: 0 0 12px rgba(147,51,234,0.4);
  }
  .mill-slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    margin-top: 0.3rem;
  }

  /* BUTTON */
  .mill-btn {
    width: 100%;
    padding: 0.85rem;
    border: none;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--accent-color, #9333EA), #7e22ce);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    margin-top: 0.5rem;
    position: relative;
    overflow: hidden;
  }
  .mill-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.1) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: transform 0.5s;
  }
  .mill-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(147,51,234,0.35);
  }
  .mill-btn:hover::after {
    transform: translateX(100%);
  }
  .mill-btn:active {
    transform: translateY(0);
  }

  /* RESULTS */
  .mill-calc-results {
    animation: mill-fadeUp 0.5s ease;
  }
  @keyframes mill-fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .mill-result-header {
    text-align: center;
