    letter-spacing: 0.05em;
  }
  .mill-race-track {
    height: 36px;
    background: rgba(255,255,255,0.03);
    border-radius: 18px;
    position: relative;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .mill-race-bar {
    height: 100%;
    border-radius: 18px;
    display: flex;
    align-items: center;
    padding: 0 0.85rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
    white-space: nowrap;
    min-width: fit-content;
  }
  .mill-race-bar.bar-a {
    background: linear-gradient(90deg, var(--accent-color, #9333EA), #7e22ce);
  }
  .mill-race-bar.bar-b {
    background: linear-gradient(90deg, #ef4444, #b91c1c);
  }

  /* FAQ */
  .mill-faq {
    max-width: 700px;
    margin: 0 auto;
  }
  .mill-faq-item {
    border: 1px solid var(--border-color, #152040);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .mill-faq-item[open] {
    border-color: rgba(147,51,234,0.3);
  }
  .mill-faq-item summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
    font-size: 0.95rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.2s;
    user-select: none;
  }
  .mill-faq-item summary:hover {
    background: rgba(147,51,234,0.04);
  }
  .mill-faq-item summary::-webkit-details-marker { display: none; }
  .mill-faq-item summary::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--accent-color, #9333EA);
    font-weight: 300;
    transition: transform 0.25s;
    flex-shrink: 0;
    margin-left: 1rem;
  }
  .mill-faq-item[open] summary::after {
    transform: rotate(45deg);
  }
  .mill-faq-item p {
    padding: 0 1.25rem 1.1rem;
    color: var(--text-secondary, #94a3b8);
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
  }
</style>

<script is:inline>
(function() {
  'use strict';

  const GPU_DATA = {
    rx6600: { name: 'RX 6600', score: 35, price: 200 },
    rtx4060: { name: 'RTX 4060', score: 45, price: 300 },
    rx7800xt: { name: 'RX 7800 XT', score: 75, price: 500 },
    rtx4070s: { name: 'RTX 4070 Super', score: 85, price: 600 },
    rtx4080s: { name: 'RTX 4080 Super', score: 120, price: 1000 },
    rtx4090: { name: 'RTX 4090', score: 180, price: 1800 }
  };

  const CPU_DATA = {
    i3: { name: 'i3-12100F / R5 5500', score: 40, price: 100 },
    i5: { name: 'i5-12400F / R5 5600', score: 60, price: 150 },
    ryzen7: { name: 'R5 7600X / i5-13600K', score: 90, price: 250 },
    ryzenx3d: { name: 'R7 7800X3D', score: 130, price: 400 },
    i9: { name: 'i9-14900K / 7950X3D', score: 140, price: 600 }
  };

  const PREBUILT_DATA = {
    800: {
      custom: { price: 800, name: 'Custom $800 Build', gpu: 'RX 6600', cpu: 'Ryzen 5 5600', ram: '16GB', storage: '1TB NVMe', psu: '650W Bronze' },
      prebuilt: { price: 800, name: 'Pre-built $800 PC', gpu: 'GTX 1650', cpu: 'i5-11400F', ram: '8GB', storage: '512GB SSD', psu: '500W Unknown' }
    },
    1500: {
      custom: { price: 1500, name: 'Custom $1500 Build', gpu: 'RX 7800 XT', cpu: 'Ryzen 5 7600X', ram: '32GB DDR5', storage: '2TB Gen4 NVMe', psu: '750W Gold' },
      prebuilt: { price: 1500, name: 'Pre-built $1500 PC', gpu: 'RTX 4060', cpu: 'i7-13700F', ram: '16GB DDR4', storage: '1TB NVMe', psu: '600W Bronze' }
    },
    2500: {
      custom: { price: 2500, name: 'Custom $2500 Build', gpu: 'RTX 4080 Super', cpu: 'Ryzen 7 7800X3D', ram: '32GB DDR5 6000', storage: '4TB Gen4 NVMe', psu: '850W Gold ATX 3.0' },
      prebuilt: { price: 2500, name: 'Pre-built $2500 PC', gpu: 'RTX 4070 Ti', cpu: 'i9-14900KF', ram: '32GB DDR5 5200', storage: '2TB NVMe', psu: '750W Gold' }
    }
  };

  // Slider setup
  const budgetSlider = document.getElementById('budget-slider');
  const budgetDisplay = document.getElementById('budget-display');

  function updateSlider() {
    const pct = ((budgetSlider.value - budgetSlider.min) / (budgetSlider.max - budgetSlider.min)) * 100;
    budgetSlider.style.background = 'linear-gradient(90deg, var(--accent-color, #9333EA) ' + pct + '%, var(--border-color, #152040) ' + pct + '%)';
    budgetDisplay.textContent = '$' + budgetSlider.value;

    // Auto-select dropdowns based on budget
    const budget = parseInt(budgetSlider.value);

    let gpuSelect = document.getElementById('gpu-select');
    if (budget < 800) gpuSelect.value = 'rx6600';
    else if (budget < 1200) gpuSelect.value = 'rtx4060';
    else if (budget < 1800) gpuSelect.value = 'rx7800xt';
    else if (budget < 2200) gpuSelect.value = 'rtx4070s';
    else if (budget < 2800) gpuSelect.value = 'rtx4080s';
    else gpuSelect.value = 'rtx4090';

    let cpuSelect = document.getElementById('cpu-select');
    if (budget < 900) cpuSelect.value = 'i5';
    else if (budget < 1500) cpuSelect.value = 'ryzen7';
    else if (budget < 2500) cpuSelect.value = 'ryzenx3d';
    else cpuSelect.value = 'i9';
  }

  budgetSlider.addEventListener('input', updateSlider);
  updateSlider();

  // Calculate Build Performance
  document.getElementById('calc-btn').addEventListener('click', function() {
    const gpuId = document.getElementById('gpu-select').value;
    const cpuId = document.getElementById('cpu-select').value;

    const gpu = GPU_DATA[gpuId];
    const cpu = CPU_DATA[cpuId];

    const panel = document.getElementById('results-panel');
    panel.style.display = 'block';

    setTimeout(function() {
      panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 50);

    // Calculate Bottleneck
    // Ideal ratio: CPU score should be roughly 0.8x to 1.2x of GPU score
    // Lower score means it's the bottleneck
    let bottleneckPct = 0;
    let bottleneckMsg = "Perfectly balanced.";
    let bottleneckElement = "None";

    const ratio = cpu.score / gpu.score;

    if (ratio < 0.6) {
      bottleneckPct = Math.round((1 - (ratio / 0.6)) * 100);
      bottleneckMsg = "Your CPU is significantly weaker than your GPU. You will experience stuttering in games and lower FPS at 1080p.";
      bottleneckElement = "CPU";
    } else if (ratio > 1.8) {
      bottleneckPct = Math.round(((ratio - 1.8) / ratio) * 100);
      bottleneckMsg = "Your GPU is the weak link. You're spending too much on the processor relative to graphics. Upgrade your GPU for more FPS.";
      bottleneckElement = "GPU";
    } else {
      bottleneckPct = Math.round(Math.abs(1 - ratio) * 15); // Just a little noise for "balance"
    }

    if (bottleneckPct > 50) bottleneckPct = 50; // Cap it

    const bnDisplay = document.getElementById('result-bottleneck');
    if (bottleneckPct <= 10) {
      bnDisplay.innerHTML = `<strong>${bottleneckPct}%</strong> Bottleneck`;
      bnDisplay.style.color = "var(--text-primary)";
    } else {
      bnDisplay.innerHTML = `<strong>${bottleneckPct}%</strong> ${bottleneckElement} Bottleneck`;
      bnDisplay.style.color = "#ef4444";
    }

    document.getElementById('result-insight').innerHTML = `<strong>${bottleneckPct <= 10 ? 'Perfect Balance.' : 'Bottleneck Detected.'}</strong> ${bottleneckMsg}`;

    // Calculate PSU
    let psuWattage = 650;
    if (gpu.price >= 600) psuWattage = 750;
    if (gpu.price >= 1000) psuWattage = 850;
    if (gpu.price >= 1800) psuWattage = 1000;
    document.getElementById('result-psu').textContent = psuWattage + "W";

    // Calculate FPS (Base = GPU, modifier = CPU bottleneck)
    const baseMult = (1 - (bottleneckElement === "CPU" ? (bottleneckPct / 100) * 0.5 : 0));

    const valFps = Math.min(Math.round((200 + (gpu.score * 3.5)) * baseMult), 800);
    const cs2Fps = Math.min(Math.round((150 + (gpu.score * 3.0)) * baseMult), 600);
    const fnFps = Math.min(Math.round((120 + (gpu.score * 2.5)) * baseMult), 400);
    const cpFps = Math.min(Math.round((40 + (gpu.score * 0.8)) * baseMult), 160);

    document.getElementById('fps-valorant').textContent = valFps + "+ FPS";
    document.getElementById('fps-cs2').textContent = cs2Fps + "+ FPS";
    document.getElementById('fps-fortnite').textContent = fnFps + "+ FPS";
    document.getElementById('fps-cyberpunk').textContent = cpFps + " FPS";

    // Update Chart
    const totalBudget = parseInt(budgetSlider.value);
    const gpuPct = Math.min(Math.max((gpu.price / totalBudget), 0.2), 0.6);
    const cpuPct = Math.min(Math.max((cpu.price / totalBudget), 0.1), 0.4);
    const remainingPct = 1 - gpuPct - cpuPct;

    const bars = document.querySelectorAll('.mill-chart-bar-group');
    if (bars.length >= 4) {
      bars[0].style.flex = gpuPct;
      bars[0].querySelector('.mill-chart-tooltip').textContent = `GPU: ${Math.round(gpuPct * 100)}%`;

      bars[1].style.flex = cpuPct;
      bars[1].querySelector('.mill-chart-tooltip').textContent = `CPU: ${Math.round(cpuPct * 100)}%`;

      bars[2].style.flex = remainingPct / 2;
      bars[2].querySelector('.mill-chart-tooltip').textContent = `Mobo/RAM: ${Math.round((remainingPct / 2) * 100)}%`;

      bars[3].style.flex = remainingPct / 2;
      bars[3].querySelector('.mill-chart-tooltip').textContent = `PSU/Case: ${Math.round((remainingPct / 2) * 100)}%`;
    }
  });

  // COMPARISON
  document.getElementById('compare-btn').addEventListener('click', function() {
    const budget = document.getElementById('compare-budget').value;
    const data = PREBUILT_DATA[budget];

    const results = document.getElementById('compare-results');
    results.style.display = 'block';

    function renderCard(id, pc, isWinner) {
      const card = document.getElementById(id);
      card.innerHTML =
        '<h3>' + pc.name + '</h3>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">GPU</span><span class="mill-compare-stat-val">' + pc.gpu + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">CPU</span><span class="mill-compare-stat-val">' + pc.cpu + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">RAM</span><span class="mill-compare-stat-val">' + pc.ram + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Storage</span><span class="mill-compare-stat-val">' + pc.storage + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Power Supply</span><span class="mill-compare-stat-val">' + pc.psu + '</span></div>' +
        '<div class="mill-compare-winner ' + (isWinner ? 'is-winner' : 'is-loser') + '">' +
        (isWinner ? 'Better Components / Faster' : 'Overpriced / Bottlenecked') + '</div>';
    }

    renderCard('compare-card-a', data.custom, true);
    renderCard('compare-card-b', data.prebuilt, false);

    // Race bars
    const race = document.getElementById('compare-race');
    race.innerHTML =
      '<div class="mill-race-label">Gaming Performance (FPS) @ $'+budget+'</div>' +
      '<div class="mill-race-track"><div class="mill-race-bar bar-a" style="width: 0%">Custom PC — ~100% Perf</div></div>' +
      '<div class="mill-race-track"><div class="mill-race-bar bar-b" style="width: 0%">Pre-built — ~65% Perf</div></div>';

    setTimeout(function() {
      race.querySelector('.bar-a').style.width = '100%';
      race.querySelector('.bar-b').style.width = '65%';
    }, 100);
  });

  // Initial calculation trigger
  setTimeout(function() {
    document.getElementById('calc-btn').click();
    document.getElementById('compare-btn').click();
  }, 500);

})();
</script>
