  }
  .mill-insight strong {
    color: var(--text-primary, #c8d0de);
  }

  /* COMPARISON */
  .mill-compare-controls {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .mill-compare-controls .mill-input-group {
    flex: 1;
    min-width: 180px;
    max-width: 280px;
    margin-bottom: 0;
  }
  .mill-vs {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--accent-color, #9333EA);
    padding-bottom: 0.65rem;
    text-shadow: 0 0 20px rgba(147,51,234,0.3);
  }
  .mill-compare-controls .mill-btn {
    width: auto;
    padding: 0.65rem 2rem;
    margin-top: 0;
    align-self: flex-end;
    margin-bottom: 0;
  }
  .mill-compare-results {
    animation: mill-fadeUp 0.5s ease;
  }
  .mill-compare-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 600px) {
    .mill-compare-cards { grid-template-columns: 1fr; }
  }
  .mill-compare-card {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.3s;
  }
  .mill-compare-card:hover {
    border-color: rgba(147,51,234,0.2);
  }
  .mill-compare-card h3 {
    color: var(--accent-color, #9333EA);
    margin: 0 0 0.75rem;
    font-size: 1.1rem;
  }
  .mill-compare-card .mill-compare-stat {
    display: flex;
    justify-content: space-between;
    padding: 0.45rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.85rem;
  }
  .mill-compare-card .mill-compare-stat-label {
    color: var(--text-secondary, #94a3b8);
  }
  .mill-compare-card .mill-compare-stat-val {
    color: var(--text-primary, #c8d0de);
    font-weight: 600;
  }
  .mill-compare-card .mill-compare-winner {
    margin-top: 0.75rem;
    padding: 0.55rem;
