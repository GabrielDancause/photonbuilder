  }
  .mill-legend-dot.contributions {
    background: var(--accent-color, #9333EA);
  }

  /* INSIGHT */
  .mill-insight {
    background: linear-gradient(135deg, rgba(147,51,234,0.08), rgba(147,51,234,0.02));
    border-left: 3px solid var(--accent-color, #9333EA);
