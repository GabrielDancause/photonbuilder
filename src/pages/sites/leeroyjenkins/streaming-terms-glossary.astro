---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Streaming Terms Glossary",
    "description": "Streaming terms: bitrate, OBS, VOD, sub, raid, emotes, alerts."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Bitrate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The amount of data processed per second during a live stream, measured in kilobits per second (kbps). A higher bitrate results in a sharper, clearer video, but requires a faster, more stable internet upload speed from the streamer."
        }
      },
      {
        "@type": "Question",
        "name": "What is OBS (Open Broadcaster Software)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The industry-standard, free, and open-source software used by the vast majority of streamers to capture gameplay, configure audio sources, manage visual overlays, and encode the video for broadcast to platforms like Twitch or YouTube."
        }
      },
      {
        "@type": "Question",
        "name": "What is VOD (Video On Demand)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A recorded, archived version of a past live stream that viewers can watch at their own convenience. VODs are crucial for building an audience who cannot always tune in live."
        }
      }
    ]
  }
];

export const meta = {
  title: "Streaming Terms Glossary",
  description: "Streaming terms: bitrate, OBS, VOD, sub, raid, emotes, alerts.",
  category: "list",
  published: "2026-03-15",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Streaming Terms Glossary"
  description="Streaming terms: bitrate, OBS, VOD, sub, raid, emotes, alerts."
  canonical="https://leeroyjenkins.quest/streaming-terms-glossary"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Streaming Terms Glossary</h1>
      <p>Streaming terms: bitrate, OBS, VOD, sub, raid, emotes, alerts.</p>
    </div>


    <div class="card">
        <h3>Bitrate</h3>
        <p>The amount of data processed per second during a live stream, measured in kilobits per second (kbps). A higher bitrate results in a sharper, clearer video, but requires a faster, more stable internet upload speed from the streamer.</p>
    </div>
    <div class="card">
        <h3>OBS (Open Broadcaster Software)</h3>
        <p>The industry-standard, free, and open-source software used by the vast majority of streamers to capture gameplay, configure audio sources, manage visual overlays, and encode the video for broadcast to platforms like Twitch or YouTube.</p>
    </div>
    <div class="card">
        <h3>VOD (Video On Demand)</h3>
        <p>A recorded, archived version of a past live stream that viewers can watch at their own convenience. VODs are crucial for building an audience who cannot always tune in live.</p>
    </div>
    <div class="card">
        <h3>Sub (Subscriber)</h3>
        <p>A viewer who pays a recurring monthly fee (or uses a free Prime subscription) to financially support a streamer. In return, they typically receive ad-free viewing, custom emotes, and a special badge next to their name in chat.</p>
    </div>
    <div class="card">
        <h3>Raid</h3>
        <p>A feature where a streamer, upon ending their broadcast, automatically redirects all of their current viewers to another streamer's channel. It is a powerful way to network, show support, and help smaller creators grow.</p>
    </div>
    <div class="card">
        <h3>Emotes</h3>
        <p>Custom, channel-specific emojis used extensively in Twitch and YouTube chat to react to the stream. Emotes like 'Kappa', 'PogChamp', and 'LUL' form the core vocabulary of streaming culture.</p>
    </div>
    <div class="card">
        <h3>Alerts</h3>
        <p>On-screen graphics and sound effects that trigger automatically during a stream to acknowledge viewer actions, such as someone following the channel, subscribing, or making a financial donation.</p>
    </div>
    <div class="card">
        <h3>Stream sniping</h3>
        <p>The highly toxic and often bannable practice of a viewer maliciously watching a streamer's live broadcast to discover their in-game location and queue into their match with the sole intent of killing them or ruining their game.</p>
    </div>
    <div class="card">
        <h3>Chat</h3>
        <p>The live text communication window alongside the video player. Managing, interacting with, and moderating chat is one of the most critical and challenging aspects of being a successful live streamer.</p>
    </div>
    <div class="card">
        <h3>Donation</h3>
        <p>A direct, one-time financial tip given by a viewer to a streamer, often accompanied by a text-to-speech message that is read aloud on the broadcast.</p>
    </div>
    <div class="card">
        <h3>Overlay</h3>
        <p>The customized graphical elements placed on top of the raw gameplay video, including webcam borders, social media handles, recent subscriber lists, and sponsor logos, designed to give the stream a professional look.</p>
    </div>
    <div class="card">
        <h3>VTuber</h3>
        <p>A Virtual YouTuber or streamer who uses a highly animated, motion-captured 2D or 3D digital avatar instead of a traditional facecam to represent themselves on stream.</p>
    </div>
    <div class="card">
        <h3>Capture card</h3>
        <p>A physical hardware device used to capture the audio and video signal from a gaming console (like a PS5 or Switch) or a dual-PC setup, sending it to the streaming computer for broadcast via OBS.</p>
    </div>
    <div class="card">
        <h3>Bit</h3>
        <p>A virtual good or currency purchased by viewers on Twitch and used to 'Cheer' in a streamer's chat. Streamers receive a portion of the revenue for every Bit cheered in their channel.</p>
    </div>
    <div class="card">
        <h3>Mod (Moderator)</h3>
        <p>Trusted members of the community appointed by the streamer to police the chat. Mods have the power to delete inappropriate messages, issue temporary timeouts, and permanently ban toxic users.</p>
    </div>
    <div class="card">
        <h3>Timeout</h3>
        <p>A temporary restriction placed on a viewer by a moderator, preventing them from sending messages in chat for a set duration, usually as a warning for breaking channel rules.</p>
    </div>
    <div class="card">
        <h3>Ban</h3>
        <p>A permanent restriction that entirely blocks a user from participating in a channel's chat, reserved for severe or repeated violations of the community guidelines.</p>
    </div>
    <div class="card">
        <h3>Stream deck</h3>
        <p>A popular physical macro pad with customizable LCD keys, allowing streamers to easily switch scenes, trigger sound effects, or mute their microphone with a single button press without minimizing their game.</p>
    </div>
    <div class="card">
        <h3>Just Chatting</h3>
        <p>A massively popular category on Twitch where streamers interact directly with their audience, watch videos, or tell stories, focusing entirely on personality and conversation rather than gameplay.</p>
    </div>
    <div class="card">
        <h3>F (Press F to Pay Respects)</h3>
        <p>A widespread internet meme originating from Call of Duty: Advanced Warfare. Viewers flood the chat with the letter 'F' to jokingly express condolences when the streamer fails, dies in-game, or encounters bad luck.</p>
    </div>
    <div class="card">
        <h3>Poggers</h3>
        <p>A highly popular emote and slang term used to express extreme excitement, hype, or genuine amazement at a highly skilled play or a surprising, positive event on stream.</p>
    </div>
    <div class="card">
        <h3>Lurker</h3>
        <p>A viewer who actively watches the stream but rarely, if ever, types or participates in the chat. Lurkers represent the vast majority of a streamer's total viewership and are highly valued.</p>
    </div>
    <div class="card">
        <h3>Backseating</h3>
        <p>When a viewer unsolicitedly tells the streamer exactly what to do, solves puzzles for them, or constantly offers strategic advice, which is generally considered annoying and is banned in many channels.</p>
    </div>
    <div class="card">
        <h3>DMCA (Digital Millennium Copyright Act)</h3>
        <p>Copyright law that affects streamers. Playing copyrighted music or showing copyrighted video without permission can result in the stream being muted, the VOD being deleted, or the channel being permanently banned.</p>
    </div>
    <div class="card">
        <h3>Host</h3>
        <p>Similar to a raid, but instead of moving viewers to a new channel, the streamer embeds another creator's live video directly on their own channel page while they are offline.</p>
    </div>
    <div class="links-section">
      <h3>Related Guides</h3>
      <ul>
        <li><a href="/gaming-jargon-dictionary">Gaming Jargon Dictionary</a></li>
        <li><a href="/pc-hardware-terms">Pc Hardware Terms</a></li>
        <li><a href="/network-gaming-terms">Network Gaming Terms</a></li>
      </ul>
    </div>


  </div>

  <script is:inline>
    // Page specific JS
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .card h3 { color: var(--text-primary); font-size: 1.5rem; margin-bottom: 0.5rem; }
    .card p { color: var(--text-secondary); font-size: 1.05rem; line-height: 1.6; margin-bottom: 1rem; }
    .links-section { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color); }
    .links-section h3 { margin-bottom: 1rem; color: var(--text-primary); }
    .links-section ul { list-style: none; padding: 0; }
    .links-section li { margin-bottom: 0.5rem; }
    .links-section a { color: var(--accent-color); text-decoration: none; font-weight: bold; }
    .links-section a:hover { text-decoration: underline; }
  </style>
</SiteLayout>
