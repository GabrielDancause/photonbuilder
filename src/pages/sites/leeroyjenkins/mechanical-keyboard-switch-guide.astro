---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const switches = [
  { name: "Cherry MX Red", type: "Linear", force: 45, travel: 4.0, actuation: 2.0, noise: "Low", price: "$$", brand: "Cherry", desc: "The original gaming linear. Smooth, light, and widely available — the default switch in most prebuilt gaming keyboards." },
  { name: "Cherry MX Blue", type: "Clicky", force: 60, travel: 4.0, actuation: 2.2, noise: "High", price: "$$", brand: "Cherry", desc: "The classic clicky switch. Satisfying tactile bump with a loud click on every keystroke. Iconic sound, but not office-friendly." },
  { name: "Cherry MX Brown", type: "Tactile", force: 55, travel: 4.0, actuation: 2.0, noise: "Medium", price: "$$", brand: "Cherry", desc: "The most popular switch ever made. Light tactile bump without the click — a compromise between gaming and typing that millions swear by." },
  { name: "Cherry MX Black", type: "Linear", force: 60, travel: 4.0, actuation: 2.0, noise: "Low", price: "$$", brand: "Cherry", desc: "A heavier linear for people who bottom out on Reds. The extra weight prevents accidental presses and gives a more deliberate feel." },
  { name: "Cherry MX Speed Silver", type: "Linear", force: 45, travel: 3.4, actuation: 1.2, noise: "Low", price: "$$", brand: "Cherry", desc: "Cherry's fastest switch with a 1.2mm actuation point. Designed for competitive gaming where every millisecond matters." },
  { name: "Cherry MX Silent Red", type: "Linear", force: 45, travel: 3.7, actuation: 1.9, noise: "Very Low", price: "$$$", brand: "Cherry", desc: "A dampened version of the MX Red with rubber pads that absorb impact on both the downstroke and upstroke. Ideal for shared spaces." },
  { name: "Gateron Yellow", type: "Linear", force: 50, travel: 4.0, actuation: 2.0, noise: "Low", price: "$", brand: "Gateron", desc: "The budget king of linears. Smoother than Cherry MX Red out of the box, with a slightly heavier spring that many prefer. A community favourite." },
  { name: "Gateron Red", type: "Linear", force: 45, travel: 4.0, actuation: 2.0, noise: "Low", price: "$", brand: "Gateron", desc: "Gateron's take on the light linear. Smoother than Cherry's equivalent at a lower price, making it an easy recommendation for beginners." },
  { name: "Gateron Brown", type: "Tactile", force: 55, travel: 4.0, actuation: 2.0, noise: "Medium", price: "$", brand: "Gateron", desc: "A smoother, slightly less scratchy version of Cherry MX Brown. The tactile bump is subtle — some people love the gentleness, others want more." },
  { name: "Gateron Black", type: "Linear", force: 60, travel: 4.0, actuation: 2.0, noise: "Low", price: "$", brand: "Gateron", desc: "Heavier linear for typists who want resistance. Smooth Gateron housing with a 60g spring that prevents bottoming out on every keystroke." },
  { name: "Gateron Milky Yellow", type: "Linear", force: 50, travel: 4.0, actuation: 2.0, noise: "Low", price: "$", brand: "Gateron", desc: "The milky housing version produces a deeper, thockier sound. One of the best value switches in the hobby — sounds premium after a simple lube job." },
  { name: "Kailh Box White", type: "Clicky", force: 50, travel: 3.6, actuation: 1.8, noise: "High", price: "$", brand: "Kailh", desc: "A click bar mechanism instead of a click jacket — produces a sharper, crisper click than Cherry Blue. Also IP56 dust and moisture resistant." },
  { name: "Kailh Box Jade", type: "Clicky", force: 50, travel: 3.6, actuation: 1.8, noise: "Very High", price: "$", brand: "Kailh", desc: "The thickest click bar Kailh makes. Extremely tactile with a loud, crisp click that's almost aggressive. The ultimate clicky switch for enthusiasts." },
  { name: "Kailh Speed Copper", type: "Tactile", force: 50, travel: 3.5, actuation: 1.1, noise: "Medium", price: "$", brand: "Kailh", desc: "A speed tactile with a 1.1mm actuation point. The bump comes right at the top of the stroke, giving instant feedback for gaming." },
  { name: "Akko CS Cream Yellow", type: "Linear", force: 50, travel: 4.0, actuation: 2.0, noise: "Low", price: "$", brand: "Akko", desc: "Akko's flagship budget linear. Pre-lubed from the factory with a 50g spring — smooth, consistent, and a fraction of the price of Cherry." },
  { name: "Akko Jelly Black", type: "Linear", force: 50, travel: 4.0, actuation: 2.0, noise: "Low", price: "$", brand: "Akko", desc: "A medium-weight linear with Akko's signature smooth feel. The full nylon housing gives it a slightly deeper sound profile than the Cream Yellow." },
  { name: "Razer Green", type: "Clicky", force: 50, travel: 4.0, actuation: 1.9, noise: "High", price: "$$", brand: "Razer", desc: "Razer's clicky switch with a crisp tactile bump and audible click. Found in BlackWidow keyboards — loud, satisfying, and divisive." },
  { name: "Razer Yellow", type: "Linear", force: 45, travel: 3.5, actuation: 1.2, noise: "Low", price: "$$", brand: "Razer", desc: "Razer's speed linear with a 1.2mm actuation point. Quiet and fast, designed for competitive gaming. Smooth after Razer's Gen-3 housing update." },
  { name: "Razer Purple", type: "Tactile", force: 50, travel: 4.0, actuation: 1.9, noise: "Medium", price: "$$", brand: "Razer", desc: "Razer's optical tactile with a noticeable bump at the actuation point. A good middle ground in the Razer lineup between Green's click and Yellow's silence." },
  { name: "Holy Panda", type: "Tactile", force: 67, travel: 4.0, actuation: 2.0, noise: "Medium", price: "$$$$", brand: "Drop", desc: "The legendary tactile. A pronounced, round bump with a snappy return — the gold standard for tactile feel. Originally a Frankenswitch, now mass-produced by Drop." },
  { name: "Boba U4T", type: "Tactile", force: 62, travel: 4.0, actuation: 2.0, noise: "Medium", price: "$$$", brand: "Gazzew", desc: "A strong tactile with a sharp, crisp bump and a satisfying thock. Many enthusiasts prefer it over Holy Panda for its tighter tactility and lower price." },
  { name: "Zealios V2", type: "Tactile", force: 62, travel: 4.0, actuation: 2.0, noise: "Medium", price: "$$$$", brand: "ZealPC", desc: "A refined, smooth tactile with a large rounded bump. Premium feel and tight housing tolerances, but the high price has lost ground to cheaper alternatives." },
  { name: "Durock L7", type: "Linear", force: 62, travel: 4.0, actuation: 2.0, noise: "Low", price: "$$$", brand: "Durock", desc: "A premium linear with tight tolerances, minimal wobble, and buttery smoothness. The 62g spring gives it a satisfying heft that's great for both typing and gaming." },
  { name: "NK Cream", type: "Linear", force: 55, travel: 4.0, actuation: 2.0, noise: "Low", price: "$$$", brand: "NovelKeys", desc: "Famous for their deep, thocky sound profile. The full POM housing gives them a unique acoustic signature — they sound better the more you break them in." },
  { name: "Glorious Panda", type: "Tactile", force: 67, travel: 4.0, actuation: 2.0, noise: "Medium", price: "$$", brand: "Glorious", desc: "A Holy Panda clone at half the price. The tactile bump is nearly identical, and after lubing, most people can't tell them apart in a blind test." },
];

const finderQuestions = [
  {
    id: "use",
    question: "What will you primarily use the keyboard for?",
    options: [
      { label: "Competitive gaming (FPS, MOBA)", value: "gaming" },
      { label: "Typing / programming", value: "typing" },
      { label: "Both equally", value: "both" },
    ],
  },
  {
    id: "noise",
    question: "How important is noise level?",
    options: [
      { label: "I want it as quiet as possible", value: "quiet" },
      { label: "Normal volume is fine", value: "normal" },
      { label: "I love loud, clicky sounds", value: "loud" },
    ],
  },
  {
    id: "budget",
    question: "What's your budget per switch?",
    options: [
      { label: "Budget-friendly (under $0.30/switch)", value: "budget" },
      { label: "Mid-range ($0.30–$0.60/switch)", value: "mid" },
      { label: "No limit — I want the best", value: "premium" },
    ],
  },
];

const faqs = [
  {
    q: "What are the main types of mechanical keyboard switches?",
    a: "There are three main types: linear (smooth keystroke with no bump or click — best for gaming), tactile (a small bump at the actuation point gives feedback without noise — good for typing and gaming), and clicky (a bump plus an audible click sound — satisfying but loud). Within each type, switches vary by actuation force, travel distance, and housing material.",
  },
  {
    q: "Which mechanical keyboard switch is best for gaming?",
    a: "For competitive gaming, light linear switches like Cherry MX Speed Silver (1.2mm actuation) or Razer Yellow are the fastest. For general gaming, Cherry MX Red and Gateron Yellow are the most popular — they're smooth, light, and won't slow you down. Avoid clicky switches for gaming if you use voice chat, as your teammates will hear every keystroke.",
  },
  {
    q: "Are Cherry MX switches still the best?",
    a: "Cherry MX switches are reliable and widely available, but they're no longer the best in most categories. Gateron Yellow is smoother and cheaper than Cherry MX Red. Boba U4T and Holy Panda outclass Cherry MX Brown for tactile feel. Cherry's advantage is brand trust, availability, and long-term consistency — but the competition has caught up and often surpassed them.",
  },
  {
    q: "What does actuation force mean for keyboard switches?",
    a: "Actuation force is the amount of pressure (measured in grams) needed to register a keypress. Light switches (35–45g) like Cherry MX Red are easier to press and better for rapid key presses in gaming. Heavy switches (60–67g) like Holy Panda require more deliberate presses, reducing accidental keystrokes during typing. Most people prefer 45–55g for a balance of speed and control.",
  },
  {
    q: "What is the difference between Cherry MX Red and Gateron Yellow?",
    a: "Both are popular linear switches, but they differ in weight and smoothness. Cherry MX Red has a 45g actuation force and a slightly scratchy feel out of the box. Gateron Yellow has a 50g force with a noticeably smoother keystroke. Gateron Yellow is also significantly cheaper. Most enthusiasts recommend Gateron Yellow over Cherry MX Red for both gaming and typing.",
  },
  {
    q: "Do I need to lube my keyboard switches?",
    a: "Lubing is optional but makes a significant difference in sound and smoothness. Unlubed switches can feel scratchy and produce a higher-pitched, rattly sound. Lubed switches feel silky smooth and sound deeper and more consistent. Popular lubes include Krytox 205g0 for linears and Tribosys 3203 for tactiles. Budget switches like Gateron Yellow benefit the most from lubing.",
  },
  {
    q: "What does hot-swappable mean for mechanical switches?",
    a: "Hot-swappable keyboards let you pull switches out and push new ones in without soldering. This is important because switch preference is personal — you might buy Cherry MX Browns, realize you prefer linears, and swap to Gateron Yellows in 10 minutes. If your keyboard isn't hot-swappable, changing switches requires desoldering every single switch, which is time-consuming and risks damaging the PCB.",
  },
  {
    q: "How long do mechanical keyboard switches last?",
    a: "Most mechanical switches are rated for 50–100 million keystrokes. Cherry MX switches are rated for 100 million, Gateron for 80 million, and Kailh Box switches for 80 million. In practice, this means 10–20+ years of daily use. Hall Effect (magnetic) switches have theoretically infinite lifespan since there are no physical contacts to wear out.",
  },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "Mechanical Keyboard Switch Guide 2026 — 25 Switches Compared",
    description: "Complete guide to mechanical keyboard switches. Compare 25 switches from Cherry MX, Gateron, Kailh, Akko, Razer, and more by type, force, travel, noise, and price.",
    author: { "@type": "Organization", name: "Leeroy Jenkins" },
    datePublished: "2026-03-21",
    dateModified: "2026-03-21",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];

export const meta = {
  title: "Mechanical Keyboard Switch Guide 2026 — 25 Switches Compared",
  description: "Complete guide to mechanical keyboard switches. Compare 25 switches from Cherry MX, Gateron, Kailh, Akko, and more — sortable by type, force, travel, noise, and price.",
  category: "guide",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Mechanical Keyboard Switch Guide 2026 — 25 Switches Compared"
  description="Complete guide to mechanical keyboard switches. Compare 25 switches from Cherry MX, Gateron, Kailh, Akko, and more — sortable by type, force, travel, noise, and price."
  canonical="https://leeroyjenkins.quest/mechanical-keyboard-switch-guide"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Mechanical Keyboard Switch Guide (2026)</h1>
      <p>25 switches compared side by side. Filter by type, sort by specs, and find the perfect switch for your keyboard.</p>
    </div>

    <section class="content-section">
      <p>Choosing a keyboard switch is the single most important decision in a mechanical keyboard build. The switch determines how your keyboard feels, sounds, and performs — far more than the case, keycaps, or PCB. But with hundreds of switches on the market, the options are overwhelming.</p>
      <p>We've tested and compared 25 of the most popular switches from Cherry MX, Gateron, Kailh, Akko, Razer, and the enthusiast market. Use the comparison table below to sort by any spec, filter by switch type, or take our 3-question switch finder to get a personalized recommendation.</p>

      <h2>Switch Type Overview</h2>
      <div class="type-cards">
        <div class="type-card">
          <h3>Linear</h3>
          <span class="type-tag linear">Smooth &amp; Quiet</span>
          <p>No bump, no click — just a smooth, consistent press from top to bottom. The most popular type for gaming because there's nothing interrupting your keystroke speed.</p>
          <p><strong>Best for:</strong> Gaming, fast typists, quiet environments</p>
        </div>
        <div class="type-card">
          <h3>Tactile</h3>
          <span class="type-tag tactile">Bump Feedback</span>
          <p>A noticeable bump partway through the keystroke tells your finger the key has registered. You don't need to bottom out, which reduces fatigue over long typing sessions.</p>
          <p><strong>Best for:</strong> Typing, programming, mixed use</p>
        </div>
        <div class="type-card">
          <h3>Clicky</h3>
          <span class="type-tag clicky">Loud &amp; Satisfying</span>
          <p>Combines a tactile bump with an audible click on every keypress. The most satisfying switch type — and the most annoying for everyone around you.</p>
          <p><strong>Best for:</strong> Solo environments, people who love the sound</p>
        </div>
      </div>

      <h2>Switch Comparison Table</h2>
      <p>Click any column header to sort. Use the filter buttons to narrow by switch type.</p>

      <div class="filter-bar" id="filter-bar">
        <button class="filter-btn active" data-filter="all">All Switches</button>
        <button class="filter-btn" data-filter="Linear">Linear</button>
        <button class="filter-btn" data-filter="Tactile">Tactile</button>
        <button class="filter-btn" data-filter="Clicky">Clicky</button>
      </div>

      <div class="table-wrapper">
        <table id="switch-table">
          <thead>
            <tr>
              <th data-sort="string">Switch</th>
              <th data-sort="string">Type</th>
              <th data-sort="number">Force (g)</th>
              <th data-sort="number">Travel (mm)</th>
              <th data-sort="number">Actuation (mm)</th>
              <th data-sort="string">Noise</th>
              <th data-sort="string">Price</th>
              <th data-sort="string">Brand</th>
            </tr>
          </thead>
          <tbody>
            {switches.map((s) => (
              <tr data-type={s.type}>
                <td><strong>{s.name}</strong></td>
                <td><span class={`type-badge ${s.type.toLowerCase()}`}>{s.type}</span></td>
                <td data-value={s.force}>{s.force}g</td>
                <td data-value={s.travel}>{s.travel}mm</td>
                <td data-value={s.actuation}>{s.actuation}mm</td>
                <td data-value={s.noise === "Very Low" ? 1 : s.noise === "Low" ? 2 : s.noise === "Medium" ? 3 : s.noise === "High" ? 4 : 5}>{s.noise}</td>
                <td data-value={s.price.length}>{s.price}</td>
                <td>{s.brand}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Detailed Switch Reviews</h2>
      {switches.map((s) => (
        <div class="switch-card" data-switch-type={s.type}>
          <div class="switch-header">
            <div>
              <h3>{s.name}</h3>
              <span class={`type-badge ${s.type.toLowerCase()}`}>{s.type}</span>
            </div>
            <span class="switch-price">{s.price}</span>
          </div>
          <p class="switch-desc">{s.desc}</p>
          <div class="switch-specs">
            <div class="switch-spec"><span class="spec-label">Force</span><span class="spec-value">{s.force}g</span></div>
            <div class="switch-spec"><span class="spec-label">Travel</span><span class="spec-value">{s.travel}mm</span></div>
            <div class="switch-spec"><span class="spec-label">Actuation</span><span class="spec-value">{s.actuation}mm</span></div>
            <div class="switch-spec"><span class="spec-label">Noise</span><span class="spec-value">{s.noise}</span></div>
            <div class="switch-spec"><span class="spec-label">Brand</span><span class="spec-value">{s.brand}</span></div>
          </div>
        </div>
      ))}

      <h2>Switch Finder</h2>
      <p>Answer 3 quick questions and we'll recommend the best switch for you.</p>

      <div id="switch-finder" class="finder-container">
        {finderQuestions.map((q, i) => (
          <div class="finder-step" data-step={i} style={i > 0 ? "display:none" : ""}>
            <span class="finder-step-label">Question {i + 1} of {finderQuestions.length}</span>
            <h3>{q.question}</h3>
            <div class="finder-options">
              {q.options.map((o) => (
                <button class="finder-option" data-question={q.id} data-value={o.value}>{o.label}</button>
              ))}
            </div>
          </div>
        ))}
        <div class="finder-result" id="finder-result" style="display:none">
          <h3>Your Recommended Switch</h3>
          <div id="finder-recommendation"></div>
          <button class="finder-reset" id="finder-reset">Start Over</button>
        </div>
      </div>

      <h2>Cherry MX Comparison</h2>
      <p>Cherry MX is the brand most people encounter first. Here's how their main switches stack up against each other and the competition.</p>

      <h3>Cherry MX Red vs Gateron Yellow</h3>
      <p>Both are popular linears, but Gateron Yellow wins on smoothness and value. Cherry MX Red (45g) is lighter and more widely available in prebuilt boards. Gateron Yellow (50g) is smoother out of the box, has a slightly heavier spring that many gamers prefer, and costs significantly less. For most people, Gateron Yellow is the better buy.</p>

      <h3>Cherry MX Brown vs Holy Panda</h3>
      <p>Cherry MX Brown has a subtle tactile bump that some find too weak — it often gets described as a "scratchy linear." Holy Panda has a large, round, pronounced bump that leaves no doubt you've hit the actuation point. If you want genuine tactile feedback, Holy Panda (or the more affordable Boba U4T) is a massive upgrade over Cherry MX Brown.</p>

      <h3>Cherry MX Blue vs Kailh Box Jade</h3>
      <p>Both are clicky, but they use different mechanisms. Cherry MX Blue uses a click jacket that produces a softer, more muted click. Kailh Box Jade uses a thick click bar that creates a much sharper, louder, crisper click. Box Jade is also dust and moisture resistant thanks to Kailh's box housing design. If you want the clickiest switch possible, Box Jade wins decisively.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map((f) => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/best-gaming-keyboard" class="related-link">
          <strong>Best Gaming Keyboards 2026</strong>
          <span>12 keyboards compared — mechanical and Hall Effect</span>
        </a>
        <a href="/best-gaming-chair" class="related-link">
          <strong>Best Gaming Chairs 2026</strong>
          <span>Top picks for ergonomics, comfort, and value</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      // Table sorting
      const table = document.getElementById("switch-table");
      if (!table) return;
      const headers = table.querySelectorAll("th");
      let currentSort = { col: -1, asc: true };

      headers.forEach((th, index) => {
        th.style.cursor = "pointer";
        th.addEventListener("click", () => {
          const sortType = th.dataset.sort;
          const asc = currentSort.col === index ? !currentSort.asc : true;
          currentSort = { col: index, asc };
          headers.forEach((h) => h.classList.remove("sort-asc", "sort-desc"));
          th.classList.add(asc ? "sort-asc" : "sort-desc");
          const tbody = table.querySelector("tbody");
          const rows = Array.from(tbody.querySelectorAll("tr"));
          rows.sort((a, b) => {
            const cellA = a.children[index];
            const cellB = b.children[index];
            if (sortType === "number") {
              const valA = parseFloat(cellA.dataset.value || cellA.textContent.replace(/[^0-9.\-]/g, ""));
              const valB = parseFloat(cellB.dataset.value || cellB.textContent.replace(/[^0-9.\-]/g, ""));
              return asc ? valA - valB : valB - valA;
            } else {
              const valA = (cellA.dataset.value || cellA.textContent).trim().toLowerCase();
              const valB = (cellB.dataset.value || cellB.textContent).trim().toLowerCase();
              return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
            }
          });
          rows.forEach((row) => tbody.appendChild(row));
        });
      });

      // Filter by type
      const filterBar = document.getElementById("filter-bar");
      if (filterBar) {
        filterBar.addEventListener("click", (e) => {
          const btn = e.target.closest(".filter-btn");
          if (!btn) return;
          const filter = btn.dataset.filter;
          filterBar.querySelectorAll(".filter-btn").forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const rows = table.querySelectorAll("tbody tr");
          rows.forEach((row) => {
            row.style.display = filter === "all" || row.dataset.type === filter ? "" : "none";
          });
        });
      }

      // Switch finder
      const finder = document.getElementById("switch-finder");
      if (!finder) return;
      const answers = {};
      const steps = finder.querySelectorAll(".finder-step");
      const resultEl = document.getElementById("finder-result");
      const recEl = document.getElementById("finder-recommendation");
      const resetBtn = document.getElementById("finder-reset");

      finder.addEventListener("click", (e) => {
        const option = e.target.closest(".finder-option");
        if (!option) return;
        answers[option.dataset.question] = option.dataset.value;
        const currentStep = option.closest(".finder-step");
        const nextIndex = parseInt(currentStep.dataset.step) + 1;
        currentStep.style.display = "none";
        if (nextIndex < steps.length) {
          steps[nextIndex].style.display = "";
        } else {
          showResult();
        }
      });

      if (resetBtn) {
        resetBtn.addEventListener("click", () => {
          Object.keys(answers).forEach((k) => delete answers[k]);
          resultEl.style.display = "none";
          steps[0].style.display = "";
        });
      }

      function showResult() {
        const rec = getRecommendation(answers);
        recEl.innerHTML =
          '<div class="rec-card">' +
          '<strong class="rec-name">' + rec.name + "</strong>" +
          '<span class="rec-type type-badge ' + rec.type.toLowerCase() + '">' + rec.type + "</span>" +
          '<p class="rec-reason">' + rec.reason + "</p>" +
          "</div>";
        resultEl.style.display = "";
      }

      function getRecommendation(a) {
        if (a.noise === "loud") {
          if (a.budget === "budget") return { name: "Kailh Box White", type: "Clicky", reason: "Crisp click bar mechanism, dust resistant, and very affordable. The best budget clicky switch." };
          return { name: "Kailh Box Jade", type: "Clicky", reason: "The thickest click bar available — an extremely satisfying, sharp click that clicky fans love." };
        }
        if (a.noise === "quiet") {
          if (a.use === "typing") {
            if (a.budget === "premium") return { name: "Boba U4T", type: "Tactile", reason: "Sharp tactile bump with a deep, muted thock. Premium tactile feel without the price tag of Zealios." };
            return { name: "Cherry MX Silent Red", type: "Linear", reason: "Dampened on both the down and upstroke for minimal noise. The quietest switch on this list." };
          }
          if (a.budget === "budget") return { name: "Gateron Yellow", type: "Linear", reason: "Incredibly smooth, quiet linear at a budget price. Lube it and it rivals switches 3x its cost." };
          return { name: "Cherry MX Silent Red", type: "Linear", reason: "Purpose-built for silence. Rubber dampeners eliminate impact noise on both strokes." };
        }
        // Normal noise
        if (a.use === "gaming") {
          if (a.budget === "budget") return { name: "Gateron Yellow", type: "Linear", reason: "The community's go-to budget linear. Smooth, consistent, and perfect for gaming at an unbeatable price." };
          if (a.budget === "premium") return { name: "Durock L7", type: "Linear", reason: "Tight tolerances, minimal wobble, buttery smooth. A premium linear that excels for gaming and typing." };
          return { name: "Cherry MX Speed Silver", type: "Linear", reason: "1.2mm actuation point — the fastest Cherry switch. Designed for competitive gaming where speed is everything." };
        }
        if (a.use === "typing") {
