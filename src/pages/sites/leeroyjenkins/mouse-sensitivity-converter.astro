---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How does mouse sensitivity conversion work between games?",
    a: "Every FPS game uses a different internal sensitivity scale. A sensitivity of '2' in CS2 moves your crosshair a completely different amount than '2' in Valorant or Overwatch 2. Conversion works by calculating the universal measurement — cm/360 (centimeters of mouse movement needed for a full 360-degree turn). Once you know your cm/360 in one game, a converter can reverse-engineer the exact sensitivity value in any other game that produces the same physical mouse movement. The formula uses each game's unique 'yaw per count' value — the degrees of rotation per mouse count at sensitivity 1."
  },
  {
    q: "What is eDPI and why does it matter?",
    a: "eDPI (effective Dots Per Inch) is your mouse DPI multiplied by your in-game sensitivity. It gives you a single number to compare sensitivity across different DPI settings. For example, 800 DPI × 1.0 sens = 800 eDPI, and 400 DPI × 2.0 sens = 800 eDPI — both feel identical in-game. eDPI is useful for sharing settings with other players because it normalizes the DPI variable. However, eDPI only works for comparison within the same game since each game has a different sensitivity scale."
  },
  {
    q: "What is cm/360 and what's a good value for FPS games?",
    a: "cm/360 is the number of centimeters you need to move your mouse to do a complete 360-degree turn in-game. It's the universal sensitivity measurement that works across all games. Most FPS pros use between 25-55 cm/360. Low sensitivity (40-55 cm/360) is popular in tactical shooters like CS2 and Valorant where precise micro-adjustments matter. Medium sensitivity (28-40 cm/360) suits fast-paced games like Apex Legends and Overwatch 2. Very low sensitivity (55+ cm/360) requires a large mousepad but gives maximum precision for AWP/Operator players."
  },
  {
    q: "Should I use 400, 800, or 1600 DPI?",
    a: "800 DPI is the sweet spot for most competitive FPS players. At 400 DPI, your cursor feels sluggish on the desktop and some games have pixel-skipping issues at very low sensitivities. At 1600+ DPI, your in-game sensitivity number becomes very small and harder to fine-tune. 800 DPI gives a good balance: smooth desktop usage, plenty of granularity for in-game sensitivity, and no pixel-skipping. That said, the actual in-game feel is identical as long as your eDPI matches — 400 DPI × 2.0 sens feels the same as 800 DPI × 1.0 sens."
  },
  {
    q: "Why do pros use low sensitivity in FPS games?",
    a: "Low sensitivity gives you finer control over small crosshair movements, which is critical for headshots and tracking at range. At higher sensitivities, tiny hand tremors translate into large crosshair movements, making it harder to hold precise angles. Low sensitivity also reduces the impact of flicking too far — overshooting a target at low sens is a few extra centimeters of mouse movement, while at high sens it's millimeters that are hard to control. The trade-off is that low sensitivity requires more desk space and a larger mousepad, plus you need to develop arm-aiming technique rather than wrist-aiming."
  },
  {
    q: "How do I find my perfect sensitivity?",
    a: "Start with a common pro average for your main game (around 30-45 cm/360 for tactical shooters, 25-35 cm/360 for arena/BR games). Play for a few days without changing it. If you consistently overshoot targets when flicking, lower your sensitivity. If you can't turn fast enough in close-range fights, raise it. Make small adjustments (5-10% at a time) and give each change at least a few hours of play. Many pros also use the 'tracking test' — try to smoothly follow a moving target. If your crosshair is jerky, sensitivity may be too high. If it lags behind, it may be too low."
  },
  {
    q: "Does converting sensitivity between games give an exact 1:1 feel?",
    a: "The conversion gives you the same physical mouse distance for the same rotation, which is the most accurate match possible. However, games can still 'feel' slightly different due to factors like FOV (field of view), mouse smoothing, acceleration, input lag, frame rate, and engine-specific quirks. Hipfire and ADS (aim-down-sights) sensitivities are also handled differently per game. The converted sensitivity is the correct mathematical starting point, but you may want to fine-tune it by ±5% based on how the game feels to you."
  },
  {
    q: "Should I use the same sensitivity across all games?",
    a: "Using the same cm/360 across all games builds consistent muscle memory, which is the biggest advantage for competitive play. Your brain learns 'move my hand this far to turn 90 degrees' and that transfers across every game. Most pro players who compete in multiple titles keep their cm/360 constant. The main exception is game-specific roles — you might want slightly higher sensitivity for a fast-paced game like Overwatch 2 where 180-degree turns are frequent, and lower sensitivity for a tactical shooter like CS2 where precision outweighs speed."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Mouse Sensitivity Converter — CS2, Valorant & More",
    "description": "Free mouse sensitivity converter for CS2, Valorant, Overwatch 2, Fortnite, Apex Legends, and more. Convert sensitivity between games, calculate eDPI and cm/360.",
    "applicationCategory": "Utility",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Mouse Sensitivity Converter — CS2, Valorant & More",
  description: "Free mouse sensitivity converter and eDPI calculator. Convert your sensitivity between CS2, Valorant, Overwatch 2, Fortnite, Apex Legends, R6 Siege, and more. See cm/360 and eDPI instantly.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Mouse Sensitivity Converter — CS2, Valorant & More"
  description="Free mouse sensitivity converter and eDPI calculator. Convert your sensitivity between CS2, Valorant, Overwatch 2, Fortnite, Apex Legends, R6 Siege, and more. See cm/360 and eDPI instantly."
  canonical="https://leeroyjenkins.quest/mouse-sensitivity-converter"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Mouse Sensitivity Converter</h1>
      <p>Convert your mouse sensitivity between FPS games instantly. Enter your current sensitivity and DPI, pick a target game, and get the exact converted value with eDPI and cm/360.</p>
    </div>

    <section class="content-section">
      <!-- Step 1: Source Game -->
      <div class="converter-card">
        <div class="step-header"><span class="step-num">1</span> Source Game &amp; Sensitivity</div>
        <div class="form-row">
          <div class="form-group">
            <label for="source-game">Game</label>
            <select id="source-game" class="form-select">
              <option value="cs2">CS2</option>
              <option value="valorant" selected>Valorant</option>
              <option value="overwatch2">Overwatch 2</option>
              <option value="fortnite">Fortnite</option>
              <option value="apex">Apex Legends</option>
              <option value="r6siege">R6 Siege</option>
              <option value="pubg">PUBG</option>
              <option value="warzone">CoD Warzone</option>
              <option value="tarkov">Escape from Tarkov</option>
              <option value="quake">Quake / QC</option>
              <option value="minecraft">Minecraft</option>
            </select>
          </div>
          <div class="form-group">
            <label for="source-sens">In-Game Sensitivity</label>
            <input type="number" id="source-sens" class="form-input" value="0.3" step="any" min="0" />
          </div>
          <div class="form-group">
            <label for="dpi-input">Mouse DPI</label>
            <input type="number" id="dpi-input" class="form-input" value="800" step="any" min="1" />
          </div>
        </div>
        <div class="dpi-presets">
          <span class="preset-label">Quick DPI:</span>
          <button class="dpi-btn" data-dpi="400">400</button>
          <button class="dpi-btn active" data-dpi="800">800</button>
          <button class="dpi-btn" data-dpi="1600">1600</button>
          <button class="dpi-btn" data-dpi="3200">3200</button>
        </div>
      </div>

      <!-- Step 2: Target Game -->
      <div class="converter-card">
        <div class="step-header"><span class="step-num">2</span> Target Game</div>
        <div class="game-grid" id="target-game-grid">
          <button class="game-btn active" data-game="cs2"><span class="game-icon">💥</span>CS2</button>
          <button class="game-btn" data-game="valorant"><span class="game-icon">🎯</span>Valorant</button>
          <button class="game-btn" data-game="overwatch2"><span class="game-icon">🛡️</span>Overwatch 2</button>
          <button class="game-btn" data-game="fortnite"><span class="game-icon">🏗️</span>Fortnite</button>
          <button class="game-btn" data-game="apex"><span class="game-icon">⚡</span>Apex Legends</button>
          <button class="game-btn" data-game="r6siege"><span class="game-icon">🔫</span>R6 Siege</button>
          <button class="game-btn" data-game="pubg"><span class="game-icon">🪂</span>PUBG</button>
          <button class="game-btn" data-game="warzone"><span class="game-icon">🪖</span>CoD Warzone</button>
          <button class="game-btn" data-game="tarkov"><span class="game-icon">🎒</span>Tarkov</button>
          <button class="game-btn" data-game="quake"><span class="game-icon">🚀</span>Quake</button>
          <button class="game-btn" data-game="minecraft"><span class="game-icon">⛏️</span>Minecraft</button>
        </div>
      </div>

      <!-- Convert Button -->
      <button class="btn btn-primary btn-convert" id="convert-btn">Convert Sensitivity</button>

      <!-- Results -->
      <div class="results-container" id="results-container" style="display:none;">
        <h2>Converted Sensitivity</h2>

        <div class="result-cards">
          <div class="result-card result-main">
            <div class="result-label" id="target-game-label">CS2 Sensitivity</div>
            <div class="result-value" id="target-sens-value">---</div>
            <button class="copy-inline" id="copy-sens" title="Copy value">Copy</button>
          </div>
        </div>

        <div class="metrics-grid">
          <div class="metric-card">
            <div class="metric-label">Source eDPI</div>
            <div class="metric-value" id="source-edpi">---</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Target eDPI</div>
            <div class="metric-value" id="target-edpi">---</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">cm / 360°</div>
            <div class="metric-value" id="cm360-value">---</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">in / 360°</div>
            <div class="metric-value" id="in360-value">---</div>
          </div>
        </div>

        <!-- All Games Table -->
        <div class="all-games-card">
          <h3>Your Sensitivity in Every Game</h3>
          <div class="table-wrapper">
            <table id="all-games-table">
              <thead>
                <tr>
                  <th>Game</th>
                  <th>Sensitivity</th>
                  <th>eDPI</th>
                </tr>
              </thead>
              <tbody id="all-games-body"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Pro Sensitivity Reference -->
      <h2>Pro Player Sensitivity Reference</h2>
      <p>Average cm/360 used by professional players in each game. Use these as a starting point if you're unsure what sensitivity to use.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Game</th>
              <th>Avg cm/360</th>
              <th>Typical Range</th>
              <th>Style</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>CS2</strong></td><td>44 cm</td><td>35–55 cm</td><td>Low — precision aiming</td></tr>
            <tr><td><strong>Valorant</strong></td><td>40 cm</td><td>30–55 cm</td><td>Low — crosshair placement</td></tr>
            <tr><td><strong>Overwatch 2</strong></td><td>30 cm</td><td>20–45 cm</td><td>Medium — hero dependent</td></tr>
            <tr><td><strong>Fortnite</strong></td><td>33 cm</td><td>25–45 cm</td><td>Medium — building + aiming</td></tr>
            <tr><td><strong>Apex Legends</strong></td><td>32 cm</td><td>22–45 cm</td><td>Medium — tracking focused</td></tr>
            <tr><td><strong>R6 Siege</strong></td><td>36 cm</td><td>25–50 cm</td><td>Low-medium — angle holding</td></tr>
            <tr><td><strong>PUBG</strong></td><td>38 cm</td><td>28–50 cm</td><td>Low-medium — long range</td></tr>
            <tr><td><strong>CoD Warzone</strong></td><td>30 cm</td><td>20–42 cm</td><td>Medium — fast CQB</td></tr>
            <tr><td><strong>Escape from Tarkov</strong></td><td>35 cm</td><td>25–50 cm</td><td>Low-medium — survival</td></tr>
            <tr><td><strong>Quake / QC</strong></td><td>28 cm</td><td>18–38 cm</td><td>Medium-high — arena speed</td></tr>
            <tr><td><strong>Minecraft</strong></td><td>24 cm</td><td>15–35 cm</td><td>Medium-high — PvP combat</td></tr>
          </tbody>
        </table>
      </div>

      <!-- DPI Guide -->
      <h2>DPI Guide: Why 800 or 1600 DPI is Optimal</h2>
      <p>Your mouse DPI (dots per inch) determines how far the cursor moves per physical inch of mouse movement. Higher DPI means more cursor movement per inch. Here's why most competitive players stick to 800 or 1600 DPI:</p>

      <h3>800 DPI — The Pro Standard</h3>
      <p>The most popular DPI among FPS professionals. At 800 DPI, in-game sensitivity values sit in a comfortable range (0.2–3.0 for most games), giving you fine control over adjustments. Desktop navigation is smooth without being too fast. Nearly all modern sensors track perfectly at 800 DPI with zero smoothing or interpolation. If you're unsure, start here.</p>

      <h3>1600 DPI — The Modern Choice</h3>
      <p>Increasingly popular as monitors get larger and higher-resolution. 1600 DPI makes desktop and menu navigation snappier, especially at 1440p or 4K. Your in-game sensitivity numbers will be half what they'd be at 800 DPI (same physical feel). Some argue that higher DPI gives a marginal smoothness advantage due to more data points per inch, though this is debatable in practice. Good for players who alt-tab frequently or use multiple monitors.</p>

      <h3>400 DPI — Legacy Standard</h3>
      <p>Popular in the CS 1.6 and CS:GO era, 400 DPI is still used by some veteran players. The downside is sluggish desktop navigation and potential pixel-skipping in games with very low sensitivity values. If you're used to 400 DPI, there's no urgent reason to switch, but new players should start at 800 DPI instead.</p>

      <h3>Why Higher ≠ Better</h3>
      <p>Going above 1600 DPI for gaming has no meaningful advantage. Extremely high DPI (3200+) forces your in-game sensitivity into tiny fractions that are hard to fine-tune. Some mice also introduce smoothing or interpolation at their highest DPI steps, which adds a subtle delay. The key insight: your in-game feel is determined by eDPI (DPI × sensitivity), not DPI alone. 800 DPI × 1.0 sens and 1600 DPI × 0.5 sens feel identical in-game.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Tools</h2>
      <div class="related-grid">
        <a href="/aim-trainer" class="related-link">
          <strong>Aim Trainer</strong>
          <span>Free online FPS aim practice — 4 modes, reaction time tracking</span>
        </a>
        <a href="/fps-settings-optimizer" class="related-link">
          <strong>FPS Settings Optimizer</strong>
          <span>Get optimized settings for max FPS in any competitive game</span>
        </a>
        <a href="/reaction-time-test" class="related-link">
          <strong>Reaction Time Test</strong>
          <span>Measure your reaction speed — see how you compare to pro players</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ── Game sensitivity data ──
       yaw: degrees per count at sensitivity 1 and 1 DPI
       (counts * dpi * sens * yaw = degrees per physical inch)
       We store the "yaw" such that:
         degrees_per_count = sens * yaw
         cm/360 = (360 / (dpi * sens * yaw)) * 2.54
    */
    var GAMES = {
      cs2:        { name: 'CS2',                yaw: 0.022,   defaultSens: 1.0  },
      valorant:   { name: 'Valorant',           yaw: 0.07,    defaultSens: 0.3  },
      overwatch2: { name: 'Overwatch 2',        yaw: 0.0066,  defaultSens: 5.0  },
      fortnite:   { name: 'Fortnite',           yaw: 0.5555,  defaultSens: 0.06 },
      apex:       { name: 'Apex Legends',       yaw: 0.022,   defaultSens: 1.5  },
      r6siege:    { name: 'R6 Siege',           yaw: 0.00572, defaultSens: 10   },
      pubg:       { name: 'PUBG',               yaw: 0.002222,defaultSens: 25   },
      warzone:    { name: 'CoD Warzone',        yaw: 0.0066,  defaultSens: 5.0  },
      tarkov:     { name: 'Escape from Tarkov', yaw: 0.022,   defaultSens: 0.5  },
      quake:      { name: 'Quake / QC',         yaw: 0.022,   defaultSens: 2.0  },
      minecraft:  { name: 'Minecraft',          yaw: 0.1,     defaultSens: 0.5  }
    };

    var sourceGameEl = document.getElementById('source-game');
    var sourceSensEl = document.getElementById('source-sens');
    var dpiInputEl   = document.getElementById('dpi-input');
    var targetGrid   = document.getElementById('target-game-grid');
    var convertBtn   = document.getElementById('convert-btn');
    var resultsEl    = document.getElementById('results-container');

    var selectedTarget = 'cs2';

    /* ── DPI Presets ── */
    document.querySelectorAll('.dpi-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.dpi-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        dpiInputEl.value = btn.dataset.dpi;
      });
    });

    /* Keep DPI buttons in sync with manual input */
    dpiInputEl.addEventListener('input', function() {
      document.querySelectorAll('.dpi-btn').forEach(function(b) {
        b.classList.toggle('active', b.dataset.dpi === dpiInputEl.value);
      });
    });

    /* ── Target Game Selection ── */
    targetGrid.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-game]');
      if (!btn) return;
      targetGrid.querySelectorAll('.game-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedTarget = btn.dataset.game;
    });

    /* ── Update default sens when source game changes ── */
    sourceGameEl.addEventListener('change', function() {
      var game = GAMES[sourceGameEl.value];
      if (game) sourceSensEl.value = game.defaultSens;
    });

    /* ── Conversion ── */
    convertBtn.addEventListener('click', convert);

    function calcCm360(dpi, sens, yaw) {
      var degreesPerCount = sens * yaw;
      var countsFor360 = 360 / degreesPerCount;
      return (countsFor360 / dpi) * 2.54;
    }

    function sensFromCm360(dpi, cm360, yaw) {
      var countsFor360 = (cm360 / 2.54) * dpi;
      var degreesPerCount = 360 / countsFor360;
      return degreesPerCount / yaw;
    }

    function formatSens(val) {
      if (val >= 100) return val.toFixed(1);
      if (val >= 10) return val.toFixed(2);
      if (val >= 1) return val.toFixed(3);
      return val.toFixed(4);
    }

    function convert() {
      var sourceKey = sourceGameEl.value;
      var sourceSens = parseFloat(sourceSensEl.value);
      var dpi = parseFloat(dpiInputEl.value);

      if (!sourceSens || !dpi || !GAMES[sourceKey]) return;

      var sourceGame = GAMES[sourceKey];
      var targetGame = GAMES[selectedTarget];

      // Calculate cm/360
      var cm360 = calcCm360(dpi, sourceSens, sourceGame.yaw);
      var in360 = cm360 / 2.54;

      // Convert to target
      var targetSens = sensFromCm360(dpi, cm360, targetGame.yaw);

      // eDPI values
      var sourceEdpi = (dpi * sourceSens).toFixed(1);
      var targetEdpi = (dpi * targetSens).toFixed(1);

      // Update results
      document.getElementById('target-game-label').textContent = targetGame.name + ' Sensitivity';
      document.getElementById('target-sens-value').textContent = formatSens(targetSens);
      document.getElementById('source-edpi').textContent = sourceEdpi;
      document.getElementById('target-edpi').textContent = targetEdpi;
      document.getElementById('cm360-value').textContent = cm360.toFixed(2) + ' cm';
      document.getElementById('in360-value').textContent = in360.toFixed(2) + ' in';

      // All games table
      var tbody = document.getElementById('all-games-body');
      var rows = '';
      var keys = Object.keys(GAMES);
      for (var i = 0; i < keys.length; i++) {
        var key = keys[i];
        var game = GAMES[key];
        var gameSens = sensFromCm360(dpi, cm360, game.yaw);
        var gameEdpi = (dpi * gameSens).toFixed(1);
        var isSource = key === sourceKey;
        var isTarget = key === selectedTarget;
        var rowClass = isTarget ? ' class="row-highlight"' : isSource ? ' class="row-source"' : '';
        rows += '<tr' + rowClass + '><td><strong>' + game.name + '</strong>' +
          (isSource ? ' <span class="badge-source">source</span>' : '') +
          (isTarget ? ' <span class="badge-target">target</span>' : '') +
          '</td><td>' + formatSens(gameSens) + '</td><td>' + gameEdpi + '</td></tr>';
      }
      tbody.innerHTML = rows;

      resultsEl.style.display = 'block';
      resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    /* ── Copy sensitivity value ── */
    document.getElementById('copy-sens').addEventListener('click', function() {
      var val = document.getElementById('target-sens-value').textContent;
      if (val === '---') return;
      navigator.clipboard.writeText(val).then(function() {
        var btn = document.getElementById('copy-sens');
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
      });
    });

    /* ── Auto-convert on load ── */
    convert();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Converter Cards */
    .converter-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.4rem 1.5rem; margin-bottom: 1rem; }
    .step-header { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.6rem; }
    .step-num { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: var(--accent-color); color: #fff; border-radius: 50%; font-size: 0.85rem; font-weight: 800; flex-shrink: 0; }

    /* Form */
    .form-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.8rem; margin-bottom: 0.8rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.3rem; }
    .form-group label { font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em; }
    .form-select, .form-input { width: 100%; padding: 0.6rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-primary); font-size: 0.95rem; font-weight: 500; box-sizing: border-box; }
    .form-select:focus, .form-input:focus { outline: 2px solid var(--accent-color); outline-offset: 1px; }
    .form-input { font-variant-numeric: tabular-nums; }

    /* DPI Presets */
    .dpi-presets { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
