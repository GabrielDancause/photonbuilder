const resolutionComparison = [
  { resolution: "720p (1280x720)", pixels: "0.92M", fpsMultiplier: "1.8–2.2x vs 1080p", useCase: "Older GPUs, esports on low-end hardware", quality: "Noticeably blurry on modern displays" },
  { resolution: "1080p (1920x1080)", pixels: "2.07M", fpsMultiplier: "Baseline", useCase: "Competitive gaming, budget builds", quality: "Sharp on 24\", slightly soft on 27\"" },
  { resolution: "1440p (2560x1440)", pixels: "3.69M", fpsMultiplier: "0.55–0.70x vs 1080p", useCase: "Sweet spot for most gamers", quality: "Sharp on 27\", ideal pixel density" },
  { resolution: "4K (3840x2160)", pixels: "8.29M", fpsMultiplier: "0.30–0.45x vs 1080p", useCase: "High-end single-player, productivity", quality: "Razor-sharp, requires powerful GPU" },
];

const nvidiaSettings = [
  { setting: "Power Management Mode", recommended: "Prefer Maximum Performance", reason: "Prevents GPU from downclocking during gameplay" },
  { setting: "Texture Filtering Quality", recommended: "High Performance", reason: "Marginal FPS gain with no visible quality loss" },
  { setting: "Low Latency Mode", recommended: "On (or Ultra with DLSS)", reason: "Reduces input lag by limiting pre-rendered frames" },
