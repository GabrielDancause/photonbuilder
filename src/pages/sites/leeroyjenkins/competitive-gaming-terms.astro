const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Competitive Gaming Terms",
    "description": "Competitive terms: ELO, MMR, smurfing, meta, tier list, scrim."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is ELO?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A rating system originally invented for chess by Arpad Elo, used to calculate the relative skill levels of players in competitive games. Beating a higher-rated player yields more points than beating a lower-rated one."
        }
      },
      {
        "@type": "Question",
        "name": "What is MMR (Matchmaking Rating)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A hidden numerical value used by a game's matchmaking algorithm to pair players of roughly equal skill against each other to ensure fair and competitive matches. It is often separate from a player's visible rank."
        }
      },
      {
        "@type": "Question",
        "name": "What is Smurfing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The highly frowned-upon practice of an experienced, high-ranked player creating a brand new or artificially low-ranked account specifically to play against and easily dominate less skilled opponents."
        }
      }
    ]
  }
];

export const meta = {
  title: "Competitive Gaming Terms",
  description: "Competitive terms: ELO, MMR, smurfing, meta, tier list, scrim.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Competitive Gaming Terms"
  description="Competitive terms: ELO, MMR, smurfing, meta, tier list, scrim."
  canonical="https://leeroyjenkins.quest/competitive-gaming-terms"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Competitive Gaming Terms</h1>
      <p>Competitive terms: ELO, MMR, smurfing, meta, tier list, scrim.</p>
    </div>


    <div class="card">
        <h3>ELO</h3>
        <p>A rating system originally invented for chess by Arpad Elo, used to calculate the relative skill levels of players in competitive games. Beating a higher-rated player yields more points than beating a lower-rated one.</p>
    </div>
    <div class="card">
        <h3>MMR (Matchmaking Rating)</h3>
        <p>A hidden numerical value used by a game's matchmaking algorithm to pair players of roughly equal skill against each other to ensure fair and competitive matches. It is often separate from a player's visible rank.</p>
    </div>
    <div class="card">
        <h3>Smurfing</h3>
        <p>The highly frowned-upon practice of an experienced, high-ranked player creating a brand new or artificially low-ranked account specifically to play against and easily dominate less skilled opponents.</p>
    </div>
    <div class="card">
        <h3>Meta (Most Effective Tactic Available)</h3>
        <p>The currently dominant and widely accepted optimal strategies, character picks, or item builds in a game. The meta is constantly shifting due to developer balance updates and player discoveries.</p>
    </div>
    <div class="card">
        <h3>Tier list</h3>
        <p>A subjective but widely referenced ranking system that categorizes characters, weapons, or strategies from best (S-Tier) to worst (F-Tier) based on their current viability in the competitive meta.</p>
    </div>
    <div class="card">
        <h3>Scrim</h3>
        <p>An abbreviation for scrimmage. A highly organized, private practice match played between two competitive or professional teams to test strategies and improve coordination without the pressure of an official tournament.</p>
    </div>
    <div class="card">
        <h3>Ranked</h3>
        <p>A competitive game mode where players are matched based on skill and gain or lose rating points based on the outcome of the match, progressing through distinct tiers (e.g., Bronze, Silver, Gold, Platinum, Diamond).</p>
    </div>
    <div class="card">
        <h3>Ladder</h3>
        <p>The overall ranking system or leaderboard in a competitive game. Players 'climb the ladder' by winning matches and increasing their MMR or ranked points to reach the top positions.</p>
    </div>
    <div class="card">
        <h3>Tilt</h3>
        <p>A state of deep emotional frustration, anger, or loss of focus caused by consecutive losses, mistakes, or toxic behavior, which severely and negatively impacts a player's decision-making and gameplay performance.</p>
    </div>
    <div class="card">
        <h3>Cheese strategy</h3>
        <p>An highly unconventional, unpredictable, and often risky strategy that relies entirely on catching the opponent completely off guard. If scouted or expected, a cheese strategy usually fails spectacularly.</p>
    </div>
    <div class="card">
        <h3>Tryhard</h3>
        <p>A somewhat derogatory term used by casual players to describe someone who is putting an excessive, almost desperate amount of effort into winning, often prioritizing victory over having fun.</p>
    </div>
    <div class="card">
        <h3>Carry</h3>
        <p>A player or specific character role whose performance is the primary reason their team wins the match. Carrying usually implies dealing the vast majority of the team's damage or making game-winning plays.</p>
    </div>
    <div class="card">
        <h3>Throwing</h3>
        <p>Intentionally or accidentally making a series of catastrophic mistakes that costs your team a match they were otherwise heavily favored to win, squandering a significant lead.</p>
    </div>
    <div class="card">
        <h3>Toxic</h3>
        <p>Behavior that ruins the experience for others, including verbal abuse, griefing, intentionally feeding, or generally creating a hostile and negative environment within the game.</p>
    </div>
    <div class="card">
        <h3>Griefing</h3>
        <p>The act of intentionally and maliciously sabotaging your own teammates and the game itself, such as destroying friendly structures, stealing resources, or purposefully feeding the enemy team.</p>
    </div>
    <div class="card">
        <h3>Mechanics</h3>
        <p>The raw, physical skill required to execute actions in a game. Good mechanics encompass precise aiming, rapid and accurate clicking, and flawless execution of complex button combinations or ability combos.</p>
    </div>
    <div class="card">
        <h3>Game sense</h3>
        <p>A player's overarching, intuitive understanding of the game's flow. It involves anticipating enemy movements, predicting plays, understanding timings, and knowing when to take risks or play defensively.</p>
    </div>
    <div class="card">
        <h3>Min-maxing</h3>
        <p>The intense process of mathematically analyzing a game's systems to completely minimize a character's weaknesses and absolutely maximize their strengths, often resulting in highly specialized and uncompromising builds.</p>
    </div>
    <div class="card">
        <h3>Nerf</h3>
        <p>A balance change implemented by the developers in a patch that reduces the power, effectiveness, or stats of a specific character, item, or strategy that was deemed too strong for the health of the game.</p>
    </div>
    <div class="card">
        <h3>Buff</h3>
        <p>A balance change implemented by the developers in a patch that increases the power, stats, or utility of a character, item, or strategy that was previously underperforming or considered too weak.</p>
    </div>
    <div class="card">
        <h3>OP (Overpowered)</h3>
        <p>A character, weapon, or strategy that is currently far too strong compared to everything else in the game, completely dominating the meta and heavily skewing the balance of matches.</p>
    </div>
    <div class="card">
        <h3>RNG (Random Number Generation)</h3>
        <p>The underlying algorithms used by games to determine unpredictable events, such as critical hit chances, loot drops, or spawn locations. High RNG can reduce the impact of pure skill in competitive scenarios.</p>
    </div>
    <div class="card">
        <h3>VOD review</h3>
        <p>The practice of watching recorded videos (VODs) of your own past matches, or those of professional players, to deeply analyze mistakes, study enemy tendencies, and identify areas for improvement.</p>
    </div>
    <div class="card">
        <h3>Shotcaller</h3>
        <p>The designated player on a team responsible for making the final macro decisions, dictating rotations, calling out targets in team fights, and managing the team's overall strategy during a match.</p>
    </div>
    <div class="card">
        <h3>Hardstuck</h3>
        <p>A player who has played a massive number of ranked matches but remains entirely unable to progress past their current rank, implying they have reached their absolute skill ceiling.</p>
    </div>
    <div class="links-section">
      <h3>Related Guides</h3>
      <ul>
        <li><a href="/gaming-jargon-dictionary">Gaming Jargon Dictionary</a></li>
        <li><a href="/fps-terms-glossary">Fps Terms Glossary</a></li>
        <li><a href="/moba-terms-glossary">Moba Terms Glossary</a></li>
      </ul>
    </div>


  </div>

  <script is:inline>
    // Page specific JS
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
