    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    label { font-weight: 600; color: var(--text-primary); font-size: 0.95rem; }

    select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; cursor: pointer; }
    select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .error-msg { color: #ef4444; font-size: 0.9rem; margin-top: 0.25rem; }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 2rem; margin: 2rem 0 0 0; text-align: center; transition: opacity 0.3s; }
    .result-label { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); line-height: 1.2; margin-top: 0.5rem; }
    .mt-3 { margin-top: 1.5rem; }

    .explainer { line-height: 1.7; color: var(--text-primary); margin-top: 3rem; }
    .explainer h2, .explainer h3, .explainer h4 { color: var(--text-primary); margin-top: 2rem; margin-bottom: 1rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer ul, .explainer ol { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer code { background: var(--card-bg); padding: 0.2rem 0.4rem; border-radius: 4px; font-family: monospace; border: 1px solid var(--border-color); }
    .explainer a { color: var(--accent-color); text-decoration: none; font-weight: 500; }
    .explainer a:hover { text-decoration: underline; }

    .faq-section { margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 2rem; }
    .faq-section h2 { margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); }
    .faq-section p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }

    @media (max-width: 600px) {
      .input-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>
