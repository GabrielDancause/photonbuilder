    /* GPU Dropdown */
    .gpu-dropdown { width: 100%; padding: 0.7rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-primary); font-size: 0.95rem; font-weight: 500; cursor: pointer; appearance: auto; }
    .gpu-dropdown:focus { outline: 2px solid var(--accent-color); outline-offset: 1px; }
    .gpu-dropdown optgroup { font-weight: 700; color: var(--text-primary); }
    .gpu-dropdown option { font-weight: 400; padding: 0.3rem; }

    /* Buttons */
    .btn-group { display: flex; gap: 0.3rem; }
    .btn { padding: 0.45rem 0.9rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn.active { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }
    .btn-primary { background: var(--accent-color); color: #fff; border-color: var(--accent-color); padding: 0.7rem 1.8rem; font-size: 1rem; font-weight: 700; }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { border-color: var(--border-color); color: var(--text-secondary); padding: 0.5rem 1.2rem; }
    .btn-secondary:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn-generate { width: 100%; margin-bottom: 1rem; }
    .target-desc { color: var(--text-secondary); font-size: 0.85rem; font-style: italic; margin-top: 0.6rem; margin-bottom: 0; }

    /* FPS Estimate */
    .fps-estimate { text-align: center; background: var(--card-bg); border: 2px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .fps-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; color: var(--text-secondary); margin-bottom: 0.3rem; }
    .fps-value { font-size: 2.2rem; font-weight: 900; color: var(--accent-color); }
    .fps-note { font-size: 0.78rem; color: var(--text-secondary); margin-top: 0.4rem; }

    /* Settings Table */
    .table-wrapper { overflow-x: auto; border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 1rem; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.65rem 0.8rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.55rem 0.8rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* Impact Badges */
    .impact-badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; }
    .impact-high { background: rgba(255,107,107,0.15); color: #ff6b6b; }
    .impact-med { background: rgba(255,193,7,0.15); color: #ffc107; }
    .impact-low { background: rgba(81,207,102,0.15); color: #51cf66; }
    .impact-none { background: rgba(150,150,150,0.1); color: var(--text-secondary); }

    /* Game Tips */
    .game-tips { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; margin-top: 1rem; }
    .game-tips h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.8rem; }
    .game-tips ul { margin-bottom: 0; }
    .game-tips li { margin-bottom: 0.4rem; }

    /* Copy Feedback */
    .copy-feedback { margin-left: 0.8rem; font-size: 0.85rem; color: var(--accent-color); font-weight: 600; opacity: 0; transition: opacity 0.3s; }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    /* Related */
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .related-link { display: flex; flex-direction: column; gap: 0.3rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem; text-decoration: none; transition: border-color 0.2s; }
    .related-link:hover { border-color: var(--accent-color); text-decoration: none; }
    .related-link strong { color: var(--text-primary); font-size: 1rem; }
    .related-link span { color: var(--text-secondary); font-size: 0.85rem; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .game-grid { grid-template-columns: repeat(2, 1fr); }
      .btn-group { flex-wrap: wrap; }
      .fps-value { font-size: 1.6rem; }
    }
