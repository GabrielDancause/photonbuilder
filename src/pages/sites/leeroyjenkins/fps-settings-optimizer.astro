---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "Do FPS settings really make a difference in competitive games?",
    a: "Yes — dramatically. Lowering settings like shadows, effects, and anti-aliasing can boost your FPS by 30-80%, reducing input lag and making enemy movement smoother. Pro players in Valorant, CS2, and Fortnite almost universally play on low settings regardless of their hardware. Higher FPS means lower frame times, which translates directly to faster visual feedback and more responsive controls. On a 144Hz monitor, going from 90 FPS to 200+ FPS is a night-and-day difference in how the game feels."
  },
  {
    q: "Should I always turn everything to low for max FPS?",
    a: "Not necessarily. Some settings have almost zero FPS cost but improve visibility. Texture quality, for example, uses VRAM rather than GPU processing power — if your card has enough VRAM, medium or high textures are free. View distance is critical in battle royale games like Fortnite and PUBG where spotting enemies at range matters. The sweet spot is turning off expensive effects (shadows, anti-aliasing, ambient occlusion, motion blur) while keeping textures and view distance at medium or above."
  },
  {
    q: "What's the ideal FPS target for competitive gaming?",
    a: "Match your monitor's refresh rate as a minimum, then aim higher. For a 144Hz monitor, target at least 200+ FPS so frame times stay consistently below your refresh window even during hectic moments. For 240Hz, target 300+. The reason to aim above your refresh rate is consistency — FPS dips during explosions or smoke grenades feel worse than low but stable FPS. If you can't hit your monitor's refresh rate consistently, lower settings until you can. Stable 144 FPS beats fluctuating 100-200 FPS."
  },
  {
    q: "Does V-Sync help or hurt in competitive games?",
    a: "V-Sync hurts competitive performance and should always be off. It caps your frame rate to your monitor's refresh rate and adds 1-3 frames of input lag (7-20ms at 144Hz). In fast-paced FPS games, that extra latency makes your aim feel sluggish and delayed. Instead, use your GPU's low-latency mode: NVIDIA Reflex (built into most competitive games), NVIDIA Ultra Low Latency Mode in the control panel, or AMD Anti-Lag. These reduce input lag without the tearing that V-Sync prevents."
  },
  {
    q: "What's the difference between render scale and resolution?",
    a: "Resolution is the output size (1920x1080, 2560x1440, etc.) and render scale is a percentage of that resolution the game actually renders at before upscaling. Setting render scale to 80% at 1080p means the game renders at 864p and stretches it to 1080p. This gives a significant FPS boost (20-40%) with a mild blur. Some pros use lower render scales intentionally — it makes character models slightly blurry but can make them easier to spot against backgrounds. FSR and DLSS are smarter versions of render scaling that use algorithms to reconstruct detail."
  },
  {
    q: "Should I use DLSS, FSR, or XeSS for competitive gaming?",
    a: "It depends on the game and your GPU. NVIDIA DLSS (RTX cards only) offers the best quality-to-performance ratio and is generally safe to use on Quality or Balanced mode. AMD FSR works on all GPUs and is a good option when available, though quality is slightly lower than DLSS. Intel XeSS is newer and works best on Arc GPUs. For competitive games, use Quality mode — Performance and Ultra Performance modes introduce too much blur and ghosting that can obscure enemy outlines. If your GPU can hit your target FPS without upscaling, native resolution is still king."
  },
  {
    q: "How do NVIDIA Control Panel settings affect game performance?",
    a: "The NVIDIA Control Panel has several settings that impact FPS and input lag. Set Power Management Mode to 'Prefer Maximum Performance' to prevent GPU clock throttling. Set Texture Filtering Quality to 'High Performance.' Turn off Vertical Sync globally (override per-game in the game itself). Set Low Latency Mode to 'Ultra' for games that don't support NVIDIA Reflex. Set your preferred refresh rate to the highest your monitor supports. These control panel changes typically add 3-8% more FPS and noticeably reduce input lag."
  },
  {
    q: "Does Windows Game Mode actually help?",
    a: "Windows Game Mode has improved significantly since its rough launch. In Windows 10/11, it prevents Windows Update from installing drivers and sending restart notifications during gameplay, and it allocates more CPU and GPU resources to your game. For most modern systems, it provides a small but measurable benefit — 1-3% more stable FPS and fewer frame time spikes. Keep it on unless you're streaming, as it can occasionally conflict with capture software. Also disable Hardware-Accelerated GPU Scheduling if you experience stuttering."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "FPS Settings Optimizer — Get Best Settings for Any Game",
    "description": "Free FPS settings optimizer for Valorant, CS2, Fortnite, Apex Legends, and more. Select your game and GPU to get recommended settings for maximum FPS and lowest input lag.",
    "applicationCategory": "Utility",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "FPS Settings Optimizer — Best Settings for Valorant, CS2, Fortnite & More",
