    /* ── GPU Performance Tiers (relative multiplier) ── */
    const GPU_TIERS = {
      rtx4090: 2.5, rtx4080: 2.1, rtx4070ti: 1.8, rtx4070: 1.5,
      rtx4060ti: 1.3, rtx4060: 1.0,
      rtx3090: 2.0, rtx3080: 1.7, rtx3070: 1.35, rtx3060: 0.9,
      rtx2070: 1.0, rtx2060: 0.8,
      gtx1660: 0.6, gtx1650: 0.4,
      rx7900xtx: 2.2, rx7800xt: 1.5, rx7600: 0.95,
      rx6800xt: 1.6, rx6700xt: 1.1, rx6600: 0.75
    };

    /* ── Target multipliers ── */
    const TARGET_MULT = { maxfps: 1.3, balanced: 1.0, quality: 0.65 };

    /* ── State ── */
    let selectedGame = 'valorant';
    let selectedGpu = 'rtx4060';
    let selectedTarget = 'maxfps';

    const targetDescs = {
      maxfps: 'Lowest possible settings for maximum frame rate and minimum input lag. Recommended for competitive play.',
      balanced: 'Good mix of visual quality and performance. Keeps FPS above your monitor\'s refresh rate on most hardware.',
      quality: 'Best visuals your GPU can handle while maintaining smooth gameplay. V-Sync stays off for low latency.'
    };

    /* ── DOM ── */
    const gameSelect = document.getElementById('game-select');
    const gpuSelect = document.getElementById('gpu-select');
    const targetSelect = document.getElementById('target-select');
    const targetDesc = document.getElementById('target-desc');
    const generateBtn = document.getElementById('generate-btn');
    const resultsContainer = document.getElementById('results-container');
    const settingsBody = document.getElementById('settings-body');
    const gameTipsList = document.getElementById('game-tips-list');
    const gameTipsTitle = document.getElementById('game-tips-title');
    const fpsValue = document.getElementById('fps-value');
    const fpsNote = document.getElementById('fps-note');
    const resultsTitle = document.getElementById('results-title');
    const copyBtn = document.getElementById('copy-btn');
    const copyFeedback = document.getElementById('copy-feedback');

    /* ── Game Selection ── */
    gameSelect.addEventListener('click', function(e) {
      const btn = e.target.closest('[data-game]');
      if (!btn) return;
      this.querySelectorAll('.game-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedGame = btn.dataset.game;
    });

    /* ── GPU Selection ── */
    gpuSelect.addEventListener('change', function() {
      selectedGpu = this.value;
    });

    /* ── Target Selection ── */
    targetSelect.addEventListener('click', function(e) {
      const btn = e.target.closest('[data-target]');
      if (!btn) return;
      this.querySelectorAll('.btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedTarget = btn.dataset.target;
      targetDesc.textContent = targetDescs[selectedTarget];
    });

    /* ── Generate Results ── */
    generateBtn.addEventListener('click', generateSettings);

    function generateSettings() {
      const game = GAMES[selectedGame];
      if (!game) return;

      const settings = game.settings[selectedTarget];
      const gpuMult = GPU_TIERS[selectedGpu] || 1.0;
      const targetMult = TARGET_MULT[selectedTarget];
      const baseFps = game.baseFps['1080p'];
      const estimatedFps = Math.round(baseFps * gpuMult * targetMult);
      const fpsLow = Math.round(estimatedFps * 0.75);
      const fpsHigh = Math.round(estimatedFps * 1.15);

      resultsTitle.textContent = game.name + ' — Optimized Settings';
      fpsValue.textContent = fpsLow + ' – ' + fpsHigh + ' FPS';
      fpsNote.textContent = 'at 1080p with ' + gpuSelect.options[gpuSelect.selectedIndex].text + ' — actual FPS varies by CPU, RAM, and scene complexity';

      /* Render settings table */
      settingsBody.innerHTML = settings.map(function(s) {
        const impactClass = s[2] === 'High' ? 'impact-high' : s[2] === 'Medium' ? 'impact-med' : s[2] === 'None' ? 'impact-none' : 'impact-low';
        return '<tr><td><strong>' + s[0] + '</strong></td><td>' + s[1] + '</td><td><span class="impact-badge ' + impactClass + '">' + s[2] + '</span></td></tr>';
      }).join('');

      /* Render game tips */
      gameTipsTitle.textContent = game.name + ' — Specific Tips';
      gameTipsList.innerHTML = game.tips.map(function(t) {
        return '<li>' + t + '</li>';
      }).join('');

      resultsContainer.style.display = 'block';
      resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    /* ── Copy Settings ── */
    copyBtn.addEventListener('click', function() {
      const game = GAMES[selectedGame];
      if (!game) return;
      const settings = game.settings[selectedTarget];
      const gpuName = gpuSelect.options[gpuSelect.selectedIndex].text;
      const targetLabel = selectedTarget === 'maxfps' ? 'Max FPS' : selectedTarget === 'balanced' ? 'Balanced' : 'Max Quality';

      let text = game.name + ' Settings (' + targetLabel + ' — ' + gpuName + ')\n';
      text += '═'.repeat(50) + '\n';
      settings.forEach(function(s) {
        text += s[0] + ': ' + s[1] + '\n';
      });
      text += '\nGame-Specific Tips:\n';
      game.tips.forEach(function(t, i) {
        text += (i + 1) + '. ' + t + '\n';
      });
      text += '\nGenerated by leeroyjenkins.quest/fps-settings-optimizer';

      navigator.clipboard.writeText(text).then(function() {
        copyFeedback.textContent = 'Copied!';
        copyFeedback.style.opacity = '1';
        setTimeout(function() { copyFeedback.style.opacity = '0'; }, 2000);
      }).catch(function() {
        copyFeedback.textContent = 'Copy failed — try selecting text manually';
        copyFeedback.style.opacity = '1';
        setTimeout(function() { copyFeedback.style.opacity = '0'; }, 3000);
      });
    });

    /* ── Auto-generate on load ── */
    generateSettings();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
