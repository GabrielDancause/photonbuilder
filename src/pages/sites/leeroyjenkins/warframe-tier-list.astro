    .filter-btn.active { background: var(--accent-color) !important; color: white !important; border-color: var(--accent-color) !important; }
    .frame-badge { transition: opacity 0.3s, transform 0.3s; }
    .frame-badge.hidden { opacity: 0.15; transform: scale(0.9); }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const buttons = document.querySelectorAll('.filter-btn');
      const badges = document.querySelectorAll('.frame-badge');

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          buttons.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');

          var filter = btn.getAttribute('data-filter');

          badges.forEach(function(badge) {
            if (filter === 'all' || badge.getAttribute('data-role') === filter) {
              badge.classList.remove('hidden');
            } else {
              badge.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>
</SiteLayout>
