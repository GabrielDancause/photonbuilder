    const tbody = document.getElementById('card-tbody');
    const searchInput = document.getElementById('card-search');
    const resultsCount = document.getElementById('results-count');
    let activeType = 'all';
    let activeRarity = 'all';
    let sortCol = 'number';
    let sortAsc = true;

    function renderTable() {
      const query = searchInput.value.toLowerCase().trim();
      let filtered = CARDS.filter(c => {
        if (activeType !== 'all' && c[2] !== activeType) return false;
        if (activeRarity !== 'all' && c[3] !== activeRarity) return false;
        if (query && !c[1].toLowerCase().includes(query) && !String(c[0]).includes(query)) return false;
        return true;
      });

      const si = { number: 0, name: 1, type: 2, rarity: 3, hp: 4 }[sortCol] || 0;
      filtered.sort((a, b) => {
        let va = a[si], vb = b[si];
        if (typeof va === 'string') { va = va.toLowerCase(); vb = vb.toLowerCase(); }
        if (va < vb) return sortAsc ? -1 : 1;
        if (va > vb) return sortAsc ? 1 : -1;
        return a[0] - b[0];
      });

      resultsCount.textContent = 'Showing ' + filtered.length + ' of ' + CARDS.length + ' cards';

      const html = filtered.map(c => {
        const tc = TYPE_COLORS[c[2]] || '#888';
        const rc = RARITY_COLORS[c[3]] || '#888';
        const rarityTextColor = (c[3] === 'Rare' || c[3] === 'Secret') ? '#000' : '#fff';
        return '<tr>' +
          '<td>' + c[0] + '</td>' +
          '<td><strong>' + c[1] + '</strong></td>' +
          '<td><span class="type-badge" style="background:' + tc + '">' + c[2] + '</span></td>' +
          '<td><span class="rarity-badge" style="background:' + rc + ';color:' + rarityTextColor + '">' + c[3] + '</span></td>' +
          '<td>' + (c[4] ? c[4] : '—') + '</td>' +
          '</tr>';
      }).join('');
      tbody.innerHTML = html;
    }

    // Type filters
    document.getElementById('type-filters').addEventListener('click', function(e) {
      const btn = e.target.closest('.type-btn');
      if (!btn) return;
      this.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeType = btn.dataset.type;
      renderTable();
    });

    // Rarity filters
    document.getElementById('rarity-filters').addEventListener('click', function(e) {
      const btn = e.target.closest('.rarity-btn');
      if (!btn) return;
      this.querySelectorAll('.rarity-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeRarity = btn.dataset.rarity;
      renderTable();
    });

    // Search
    searchInput.addEventListener('input', renderTable);

    // Sort
    document.querySelectorAll('th.sortable').forEach(th => {
      th.addEventListener('click', function() {
        const col = this.dataset.sort;
        if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
        document.querySelectorAll('.sort-arrow').forEach(a => a.textContent = '');
        this.querySelector('.sort-arrow').textContent = sortAsc ? ' ▲' : ' ▼';
        renderTable();
      });
    });

    renderTable();
  })();
  </script>
