---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How many cards are in the Pokémon TCG Destined Rivals set?",
    a: "The Destined Rivals expansion contains 184 cards in the main set, plus additional secret rares bringing the total to over 200 collectible cards. The set features rival-themed Pokémon pairs and includes regular cards, EX cards, full art cards, special art rares, and secret rares. The exact count of secret rares can vary as some are revealed post-launch."
  },
  {
    q: "When was Destined Rivals released?",
    a: "Destined Rivals was released on February 7, 2025, as part of the Pokémon TCG Scarlet & Violet era. It was available in booster packs, Elite Trainer Boxes, booster bundles, and special collections. The Japanese equivalent cards were part of earlier Japanese sets before being localized for the international release."
  },
  {
    q: "What are the pull rates for Destined Rivals booster packs?",
    a: "In a standard Destined Rivals booster pack (10 cards), you're guaranteed at least one reverse holo or higher rarity card. On average, you'll pull a holo rare in about 1 in 3 packs, an EX card in roughly 1 in 8-10 packs, a full art in about 1 in 18-24 packs, a special art rare in roughly 1 in 40-50 packs, and a hyper/secret rare in approximately 1 in 60-80 packs. These are approximate community-gathered rates and can vary."
  },
  {
    q: "What are the most valuable cards in Destined Rivals?",
    a: "The most valuable Destined Rivals cards are typically the special art rares and secret rares. Cards featuring popular Pokémon like Charizard, Mewtwo, and Pikachu in their full art or special art rare versions tend to command the highest prices, often ranging from $20-100+. The specific chase cards and their values fluctuate based on market demand, competitive playability, and collector interest."
  },
  {
    q: "Is Destined Rivals good for competitive play?",
    a: "Destined Rivals introduced several competitively relevant cards to the Pokémon TCG Standard format. The set features powerful EX Pokémon and useful Trainer cards that have seen play in tournament decks. Whether specific cards are meta-defining depends on the current format and rotation schedule. Check recent tournament results for the most up-to-date competitive analysis of Destined Rivals cards."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pokémon TCG Destined Rivals Card List",
    "description": "Complete Destined Rivals card list with type and rarity filters, search, price estimates, and pull rates for the Pokémon TCG expansion set.",
    "applicationCategory": "Reference",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Pokémon TCG Destined Rivals Card List: Complete Set Guide",
  description: "Complete Destined Rivals card list with every card, type filters, rarity filters, search, price estimates, and pull rates. Browse the full Pokémon TCG expansion set.",
  category: "tool",
  published: "2026-03-29",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Pokémon TCG Destined Rivals Card List: Complete Set Guide"
  description="Complete Destined Rivals card list with every card, type filters, rarity filters, search, price estimates, and pull rates. Browse the full Pokémon TCG expansion set."
  canonical="https://leeroyjenkins.quest/destined-rivals-card-list"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Pokémon TCG Destined Rivals Card List</h1>
      <p>Complete set guide — browse, search, and filter every card in the Destined Rivals expansion. Released February 2025.</p>
    </div>

    <!-- Set Overview -->
    <section class="content-section">
      <h2>Set Overview</h2>
      <div class="overview-grid">
        <div class="overview-card">
          <span class="overview-label">Total Cards</span>
          <span class="overview-value">184+</span>
          <span class="overview-sub">Main set + Secret Rares</span>
        </div>
        <div class="overview-card">
          <span class="overview-label">Release Date</span>
          <span class="overview-value">Feb 7, 2025</span>
          <span class="overview-sub">Scarlet &amp; Violet Era</span>
        </div>
        <div class="overview-card">
          <span class="overview-label">EX Cards</span>
          <span class="overview-value">16</span>
          <span class="overview-sub">Powerful Pokémon EX</span>
        </div>
        <div class="overview-card">
          <span class="overview-label">Full Art / SAR</span>
          <span class="overview-value">20+</span>
          <span class="overview-sub">Full Arts &amp; Special Art Rares</span>
        </div>
      </div>
    </section>

    <!-- Search & Filters -->
    <section class="content-section">
      <h2>Card Database</h2>
      <div class="search-bar">
        <input type="text" id="card-search" placeholder="Search by card name or number..." autocomplete="off" />
      </div>

      <div class="filter-group">
        <h3>Filter by Type</h3>
        <div class="type-filters" id="type-filters">
          <button class="type-btn active" data-type="all">All</button>
          <button class="type-btn" data-type="Fire" style="--tc:#EE8130">Fire</button>
          <button class="type-btn" data-type="Water" style="--tc:#6390F0">Water</button>
          <button class="type-btn" data-type="Grass" style="--tc:#7AC74C">Grass</button>
          <button class="type-btn" data-type="Electric" style="--tc:#F7D02C">Electric</button>
          <button class="type-btn" data-type="Psychic" style="--tc:#F95587">Psychic</button>
          <button class="type-btn" data-type="Fighting" style="--tc:#C22E28">Fighting</button>
          <button class="type-btn" data-type="Dark" style="--tc:#705746">Dark</button>
          <button class="type-btn" data-type="Steel" style="--tc:#B7B7CE">Steel</button>
          <button class="type-btn" data-type="Dragon" style="--tc:#6F35FC">Dragon</button>
          <button class="type-btn" data-type="Colorless" style="--tc:#A8A77A">Colorless</button>
          <button class="type-btn" data-type="Trainer" style="--tc:#E08030">Trainer</button>
          <button class="type-btn" data-type="Energy" style="--tc:#AAA">Energy</button>
        </div>
      </div>

      <div class="filter-group">
        <h3>Filter by Rarity</h3>
        <div class="rarity-filters" id="rarity-filters">
          <button class="rarity-btn active" data-rarity="all">All</button>
          <button class="rarity-btn" data-rarity="Common" style="--rc:#9CA3AF">Common</button>
          <button class="rarity-btn" data-rarity="Uncommon" style="--rc:#60A5FA">Uncommon</button>
          <button class="rarity-btn" data-rarity="Rare" style="--rc:#FBBF24">Rare</button>
          <button class="rarity-btn" data-rarity="Holo" style="--rc:#A78BFA">Holo Rare</button>
          <button class="rarity-btn" data-rarity="EX" style="--rc:#F472B6">EX</button>
          <button class="rarity-btn" data-rarity="Full Art" style="--rc:#FB923C">Full Art</button>
          <button class="rarity-btn" data-rarity="Special Art" style="--rc:#EC4899">Special Art</button>
          <button class="rarity-btn" data-rarity="Secret" style="--rc:#F59E0B">Secret Rare</button>
        </div>
      </div>

      <div class="results-count" id="results-count">Showing all cards</div>

      <!-- Card Table -->
      <div class="table-wrap">
        <table id="card-table">
          <thead>
            <tr>
              <th class="sortable" data-sort="number"># <span class="sort-arrow"></span></th>
              <th class="sortable" data-sort="name">Name <span class="sort-arrow"></span></th>
              <th class="sortable" data-sort="type">Type <span class="sort-arrow"></span></th>
              <th class="sortable" data-sort="rarity">Rarity <span class="sort-arrow"></span></th>
              <th class="sortable" data-sort="hp">HP <span class="sort-arrow"></span></th>
            </tr>
          </thead>
          <tbody id="card-tbody"></tbody>
        </table>
      </div>
    </section>

    <!-- Price Tracker -->
    <section class="content-section">
      <h2>Price Estimates by Rarity</h2>
      <p class="section-note">Prices vary by condition, seller, and market demand. These are approximate ranges for near-mint singles as of early 2025.</p>
      <div class="price-grid">
        <div class="price-card">
          <span class="price-rarity" style="background:#9CA3AF">Common</span>
          <span class="price-range">$0.10 – $0.50</span>
        </div>
        <div class="price-card">
          <span class="price-rarity" style="background:#60A5FA">Uncommon</span>
          <span class="price-range">$0.25 – $1.00</span>
        </div>
        <div class="price-card">
          <span class="price-rarity" style="background:#FBBF24;color:#000">Rare</span>
          <span class="price-range">$1.00 – $5.00</span>
        </div>
        <div class="price-card">
          <span class="price-rarity" style="background:#A78BFA">Holo Rare</span>
          <span class="price-range">$1.50 – $8.00</span>
        </div>
        <div class="price-card">
          <span class="price-rarity" style="background:#F472B6">EX</span>
          <span class="price-range">$3.00 – $15.00</span>
        </div>
        <div class="price-card">
          <span class="price-rarity" style="background:#FB923C">Full Art</span>
          <span class="price-range">$10.00 – $40.00</span>
        </div>
        <div class="price-card">
          <span class="price-rarity" style="background:#EC4899">Special Art Rare</span>
          <span class="price-range">$20.00 – $80.00</span>
        </div>
        <div class="price-card">
          <span class="price-rarity" style="background:#F59E0B;color:#000">Secret Rare</span>
          <span class="price-range">$20.00 – $100+</span>
        </div>
      </div>
    </section>

    <!-- Pull Rates -->
    <section class="content-section">
      <h2>Approximate Pull Rates</h2>
      <p class="section-note">Estimated pull rates per standard 10-card booster pack, based on community data. Individual results will vary.</p>
      <div class="pull-rates-grid">
        <div class="pull-card">
          <span class="pull-rarity">Reverse Holo</span>
          <span class="pull-rate">1 per pack</span>
          <span class="pull-detail">Guaranteed in every pack</span>
        </div>
        <div class="pull-card">
          <span class="pull-rarity">Holo Rare</span>
          <span class="pull-rate">~1 in 3 packs</span>
          <span class="pull-detail">≈ 33% chance</span>
        </div>
        <div class="pull-card">
          <span class="pull-rarity">Pokémon EX</span>
          <span class="pull-rate">~1 in 8 packs</span>
          <span class="pull-detail">≈ 12% chance</span>
        </div>
        <div class="pull-card">
          <span class="pull-rarity">Full Art</span>
          <span class="pull-rate">~1 in 18 packs</span>
          <span class="pull-detail">≈ 5.5% chance</span>
        </div>
        <div class="pull-card">
          <span class="pull-rarity">Special Art Rare</span>
          <span class="pull-rate">~1 in 40 packs</span>
          <span class="pull-detail">≈ 2.5% chance</span>
        </div>
        <div class="pull-card">
          <span class="pull-rarity">Secret / Hyper Rare</span>
          <span class="pull-rate">~1 in 60 packs</span>
          <span class="pull-detail">≈ 1.7% chance</span>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </div>

  <style is:inline>
    :root {
      --bg-primary: #0f1419;
      --bg-secondary: #1a1f2e;
      --bg-tertiary: #242b3d;
      --text-primary: #e4e6eb;
      --text-secondary: #a0a8b8;
      --accent: #F7D02C;
      --border: #2d3548;
    }
    .page-content { max-width: 1100px; margin: 0 auto; padding: 1rem; }
    .hero { text-align: center; padding: 2rem 0 1.5rem; }
    .hero h1 { font-size: 2rem; margin: 0 0 .5rem; color: var(--accent); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }
    .content-section { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .content-section h2 { font-size: 1.4rem; margin: 0 0 1rem; color: var(--text-primary); }
    .section-note { color: var(--text-secondary); font-size: .9rem; margin: -.5rem 0 1rem; }

    /* Overview Grid */
    .overview-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
    .overview-card { background: var(--bg-tertiary); border-radius: 10px; padding: 1.25rem; text-align: center; display: flex; flex-direction: column; gap: .25rem; }
    .overview-label { font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; color: var(--text-secondary); }
    .overview-value { font-size: 1.8rem; font-weight: 700; color: var(--accent); }
    .overview-sub { font-size: .8rem; color: var(--text-secondary); }

    /* Search */
    .search-bar { margin-bottom: 1rem; }
    .search-bar input { width: 100%; padding: .75rem 1rem; background: var(--bg-tertiary); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); font-size: 1rem; outline: none; box-sizing: border-box; }
    .search-bar input:focus { border-color: var(--accent); }
    .search-bar input::placeholder { color: var(--text-secondary); }

    /* Filter Groups */
    .filter-group { margin-bottom: 1rem; }
    .filter-group h3 { font-size: .9rem; margin: 0 0 .5rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: .04em; }
    .type-filters, .rarity-filters { display: flex; flex-wrap: wrap; gap: .4rem; }
    .type-btn, .rarity-btn { padding: .4rem .75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg-tertiary); color: var(--text-secondary); font-size: .85rem; cursor: pointer; transition: all .15s; }
    .type-btn:hover, .rarity-btn:hover { border-color: var(--text-secondary); color: var(--text-primary); }
    .type-btn.active { background: var(--tc, var(--accent)); color: #000; border-color: transparent; font-weight: 600; }
    .rarity-btn.active { background: var(--rc, var(--accent)); color: #000; border-color: transparent; font-weight: 600; }
    .results-count { color: var(--text-secondary); font-size: .85rem; margin-bottom: .75rem; }

    /* Table */
    .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    table { width: 100%; border-collapse: collapse; font-size: .9rem; }
    thead { position: sticky; top: 0; z-index: 2; }
    th { background: var(--bg-tertiary); color: var(--text-secondary); text-align: left; padding: .6rem .75rem; font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; border-bottom: 2px solid var(--border); white-space: nowrap; user-select: none; }
    th.sortable { cursor: pointer; }
    th.sortable:hover { color: var(--accent); }
    .sort-arrow { font-size: .7rem; }
    td { padding: .55rem .75rem; border-bottom: 1px solid var(--border); color: var(--text-primary); }
    tr:hover td { background: rgba(247,208,44,.04); }
    .type-badge { display: inline-block; padding: .15rem .5rem; border-radius: 4px; font-size: .78rem; font-weight: 600; color: #fff; white-space: nowrap; }
    .rarity-badge { display: inline-block; padding: .15rem .5rem; border-radius: 4px; font-size: .78rem; font-weight: 600; white-space: nowrap; }

    /* Price Grid */
    .price-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: .75rem; }
    .price-card { background: var(--bg-tertiary); border-radius: 8px; padding: 1rem; display: flex; flex-direction: column; gap: .4rem; align-items: center; text-align: center; }
    .price-rarity { padding: .25rem .75rem; border-radius: 5px; font-size: .85rem; font-weight: 600; color: #fff; }
    .price-range { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); }

    /* Pull Rates */
    .pull-rates-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: .75rem; }
    .pull-card { background: var(--bg-tertiary); border-radius: 8px; padding: 1rem; text-align: center; display: flex; flex-direction: column; gap: .25rem; }
    .pull-rarity { font-weight: 600; color: var(--accent); font-size: .95rem; }
    .pull-rate { font-size: 1.3rem; font-weight: 700; color: var(--text-primary); }
    .pull-detail { font-size: .8rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; gap: .5rem; }
    .faq-item { background: var(--bg-tertiary); border-radius: 8px; border: 1px solid var(--border); }
    .faq-item summary { padding: 1rem; cursor: pointer; font-weight: 600; color: var(--text-primary); list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .faq-item summary::after { content: '+'; font-size: 1.3rem; color: var(--accent); flex-shrink: 0; margin-left: .5rem; }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p { padding: 0 1rem 1rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }

    @media (max-width: 640px) {
      .hero h1 { font-size: 1.4rem; }
      .hero p { font-size: .95rem; }
      .content-section { padding: 1rem; }
      .overview-grid { grid-template-columns: repeat(2, 1fr); }
      .overview-value { font-size: 1.4rem; }
      th, td { padding: .45rem .5rem; font-size: .8rem; }
      .type-btn, .rarity-btn { padding: .3rem .55rem; font-size: .78rem; }
      .price-grid, .pull-rates-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

