---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Reaction Time Test",
  "description": "Test your reaction time with visual and audio stimuli. Track your average over multiple attempts and compare your speed to competitive gaming benchmarks.",
  "url": "https://leeroyjenkins.quest/reaction-time",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Reaction Time Test | Leeroy Jenkins"
  description="Test your reaction time with visual and audio stimuli. Track your average over multiple attempts and compare your speed to competitive gaming benchmarks."
  canonical="" schema={schema}
>
  <style>
:root {
      --bg: #08060e;
      --card-bg: #100e18;
      --border: #221e30;
      --accent: #9333EA;
      --accent-hover: #7e22ce;
      --text-primary: #d8d0e8;
      --text-secondary: #888;
      --font-ui: 'Inter', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;

      --test-wait: #EF4444; /* Red */
      --test-ready: #10B981; /* Green */
      --test-early: #3B82F6; /* Blue */
      --test-idle: #221e30; /* Gray */
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-ui);
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 60px 24px;
    }

    header {
      text-align: center;
      margin-bottom: 40px;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 900;
      letter-spacing: -1px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    header p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .tool-card {
      background: var(--card-bg);
      border: 2px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 40px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .settings-bar {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .radio-group {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    input[type="radio"] {
      accent-color: var(--accent);
      width: 16px;
      height: 16px;
      cursor: pointer;
    }

    label {
      font-weight: 500;
      font-size: 0.95rem;
      color: var(--text-primary);
      cursor: pointer;
    }

    .test-area {
      background: var(--test-idle);
      border-radius: 12px;
      height: 300px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      user-select: none;
      transition: background-color 0.1s;
      position: relative;
      overflow: hidden;
      margin-bottom: 24px;
      border: 2px solid transparent;
    }

    .test-area:active {
      transform: scale(0.99);
    }

    .test-area.focus-ring:focus {
        outline: none;
        border-color: var(--text-primary);
    }

    .test-icon {
      font-size: 3rem;
      margin-bottom: 16px;
    }

    .test-message {
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
      text-align: center;
      padding: 0 20px;
    }

    .test-submessage {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.7);
      margin-top: 8px;
    }

    .state-idle { background: var(--test-idle); }
    .state-waiting { background: var(--test-wait); }
    .state-ready { background: var(--test-ready); }
    .state-early { background: var(--test-early); }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .stat-box {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      text-align: center;
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .stat-value {
      font-family: var(--font-mono);
      font-size: 1.5rem;
      font-weight: 700;
      color: #fff;
    }

    .stat-value.highlight {
      color: var(--accent);
    }

    .benchmark-container {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      text-align: center;
      margin-bottom: 24px;
    }

    .benchmark-title {
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 8px;
    }

    .benchmark-rating {
      font-size: 1.2rem;
      font-weight: 700;
      color: #fff;
    }

    .controls {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .btn {
      background: var(--border);
      color: var(--text-primary);
      border: none;
      border-radius: 6px;
      padding: 10px 20px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      font-family: var(--font-ui);
      transition: all 0.2s;
    }

    .btn:hover {
      background: #332d46;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
    }

    .btn-primary:hover {
      background: var(--accent-hover);
    }

    .seo-content {
      margin-top: 60px;
    }

    .seo-content h2 {
      font-size: 1.5rem;
      color: #fff;
      margin-bottom: 16px;
      margin-top: 40px;
    }

    .seo-content p {
      color: var(--text-secondary);
      margin-bottom: 16px;
    }

    .seo-content ul {
      color: var(--text-secondary);
      margin-left: 24px;
      margin-bottom: 16px;
    }

    .seo-content li {
      margin-bottom: 8px;
    }

    footer {
      text-align: center;
      padding: 40px 24px;
      margin-top: 60px;
      font-size: 0.85rem;
      color: var(--text-secondary);
      border-top: 1px solid var(--border);
    }

    footer a {
      color: var(--accent);
      text-decoration: none;
    }

    @media (max-width: 600px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }
      h1 { font-size: 2rem; }
      .tool-card { padding: 24px; }
      .test-area { height: 250px; }
      .controls { flex-direction: column; gap: 12px; }
      .btn { width: 100%; }
    }
  </style>

<div class="container">
    

    <div class="tool-card">
      <div class="settings-bar">
        <div class="radio-group">
          <input type="radio" id="mode-visual" name="stimulus-mode" value="visual" checked>
          <label for="mode-visual">Visual Only</label>
        </div>
        <div class="radio-group">
          <input type="radio" id="mode-audio" name="stimulus-mode" value="audio">
          <label for="mode-audio">Audio Only</label>
        </div>
        <div class="radio-group">
          <input type="radio" id="mode-both" name="stimulus-mode" value="both">
          <label for="mode-both">Visual + Audio</label>
        </div>
      </div>

      <div class="test-area state-idle focus-ring" id="testArea" tabindex="0">
        <div class="test-icon" id="testIcon">⚡</div>
        <div class="test-message" id="testMessage">Click to Start</div>
        <div class="test-submessage" id="testSubmessage">When the red box turns green, click as quickly as you can.</div>
      </div>

      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-label">Attempt</div>
          <div class="stat-value" id="attemptCount">0 / 5</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Last Score</div>
          <div class="stat-value" id="lastScore">- ms</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Average</div>
          <div class="stat-value highlight" id="avgScore">- ms</div>
        </div>
      </div>

      <div class="benchmark-container">
        <div class="benchmark-title">Competitive Benchmark Rating</div>
        <div class="benchmark-rating" id="benchmarkRating">Complete 5 attempts to get rated.</div>
      </div>

      <div class="controls">
        <button class="btn" id="resetBtn">Reset Test</button>
        <button class="btn btn-primary" id="copyBtn" disabled>Copy Results</button>
      </div>
    </div>

    <div class="seo-content">
      <h2>Why Reaction Time Matters in Gaming</h2>
      <p>In competitive esports titles like Valorant, CS2, or Apex Legends, a few milliseconds can be the difference between winning a duel and losing a round. Human reaction time is composed of sensory processing (seeing or hearing the stimulus) and motor response (clicking your mouse). Top professional gamers typically have visual reaction times between 150ms and 180ms, while the average person hovers around 250ms.</p>

      <h2>Visual vs. Audio Stimuli</h2>
      <p>You might notice different results when switching between Visual and Audio modes. This is biologically normal!</p>
      <ul>
        <li><strong>Audio Reaction Time</strong> is typically faster than visual reaction time. It takes about 8-10 milliseconds for an auditory stimulus to reach the brain, compared to 20-40 milliseconds for a visual stimulus. This is why reacting to footsteps or gunshot audio cues can often feel more instantaneous than reacting to a visual peek.</li>
        <li><strong>Visual Reaction Time</strong> is highly dependent on your monitor's refresh rate and your system's total input lag. High refresh rate monitors (144Hz, 240Hz, 360Hz) display the visual cue sooner than a standard 60Hz display, effectively reducing your measured reaction time.</li>
      </ul>

      <h2>How to Improve Your Score</h2>
      <p>While genetics play a role in your raw biological reaction time, your total setup latency heavily influences your score on tests like this. To get your absolute best time, ensure you are using a wired mouse with a high polling rate (1000Hz+), playing on a high refresh rate monitor, and minimizing background processes that might introduce input lag. Getting enough sleep, staying hydrated, and warming up before gaming are also crucial for peak cognitive performance.</p>
    </div>

    
  </div>
  <script is:inline>
const testArea = document.getElementById('testArea');
    const testIcon = document.getElementById('testIcon');
    const testMessage = document.getElementById('testMessage');
    const testSubmessage = document.getElementById('testSubmessage');

    const attemptCountOut = document.getElementById('attemptCount');
    const lastScoreOut = document.getElementById('lastScore');
    const avgScoreOut = document.getElementById('avgScore');
    const benchmarkRatingOut = document.getElementById('benchmarkRating');

    const resetBtn = document.getElementById('resetBtn');
    const copyBtn = document.getElementById('copyBtn');
    const modeRadios = document.getElementsByName('stimulus-mode');

    // States: 'idle', 'waiting', 'ready', 'finished'
    let currentState = 'idle';
    let timeoutId = null;
    let startTime = 0;

    const MAX_ATTEMPTS = 5;
    let attempts = 0;
    let scores = [];

    // Audio Context
    let audioCtx = null;

    function initAudio() {
        if (!audioCtx) {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        if (audioCtx.state === 'suspended') {
            audioCtx.resume();
        }
    }

    function playBeep() {
        if (!audioCtx) return;
        const oscillator = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();

        oscillator.type = 'sine';
        oscillator.frequency.setValueAtTime(800, audioCtx.currentTime); // 800Hz beep

        gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);

        oscillator.connect(gainNode);
        gainNode.connect(audioCtx.destination);

        oscillator.start();
        oscillator.stop(audioCtx.currentTime + 0.1);
    }

    function getSelectedMode() {
        let mode = 'visual';
        for (const radio of modeRadios) {
            if (radio.checked) {
                mode = radio.value;
                break;
            }
        }
        return mode;
    }

    function setState(state) {
        currentState = state;
        const mode = getSelectedMode();
        testArea.className = `test-area state-${state} focus-ring`;

        if (state === 'idle') {
            testIcon.textContent = '⚡';
            testMessage.textContent = 'Click to Start';
            if (mode === 'audio') {
                testSubmessage.textContent = 'When ready, click to begin the audio test.';
            } else {
                testSubmessage.textContent = 'When the box turns green, click as quickly as you can.';
            }
        } else if (state === 'waiting') {
            testIcon.textContent = '⏳';
            if (mode === 'audio') {
                 testMessage.textContent = 'Wait for the beep...';
                 testSubmessage.textContent = 'Do not click until you hear the sound.';
            } else {
                 testMessage.textContent = 'Wait for green...';
                 testSubmessage.textContent = 'Do not click yet.';
            }
        } else if (state === 'ready') {
            testIcon.textContent = '🟢';
            testMessage.textContent = 'CLICK NOW!';
            testSubmessage.textContent = '';

            if (mode === 'audio' || mode === 'both') {
                 playBeep();
            }

            startTime = performance.now();
        } else if (state === 'early') {
            testIcon.textContent = '❌';
            testMessage.textContent = 'Too soon!';
            testSubmessage.textContent = 'Click to try again.';
            clearTimeout(timeoutId);
        }
    }

    function calculateAverage() {
        if (scores.length === 0) return 0;
        const sum = scores.reduce((a, b) => a + b, 0);
        return Math.round(sum / scores.length);
    }

    function getBenchmark(avg) {
        if (avg < 150) return { text: "Alien / God-tier 👽", color: "#9333EA" }; // Purple
        if (avg < 170) return { text: "Professional Esports Player 🏆", color: "#F59E0B" }; // Gold
        if (avg < 200) return { text: "Highly Competitive Tier ⚔️", color: "#3B82F6" }; // Blue
        if (avg < 230) return { text: "Above Average Gamer 🎮", color: "#10B981" }; // Green
        if (avg < 270) return { text: "Average Human 🚶", color: "#d8d0e8" }; // Default text
        return { text: "Sluggish / High Latency Setup 🐢", color: "#888" }; // Gray
    }

    function updateStats() {
        attemptCountOut.textContent = `${attempts} / ${MAX_ATTEMPTS}`;

        if (scores.length > 0) {
            lastScoreOut.textContent = `${scores[scores.length - 1]} ms`;
            const avg = calculateAverage();
            avgScoreOut.textContent = `${avg} ms`;

            if (attempts >= MAX_ATTEMPTS) {
                const benchmark = getBenchmark(avg);
                benchmarkRatingOut.textContent = benchmark.text;
                benchmarkRatingOut.style.color = benchmark.color;
                copyBtn.disabled = false;
            } else {
                benchmarkRatingOut.textContent = `Complete ${MAX_ATTEMPTS - attempts} more attempt(s) to get rated.`;
                benchmarkRatingOut.style.color = 'var(--text-primary)';
            }
        } else {
            lastScoreOut.textContent = '- ms';
            avgScoreOut.textContent = '- ms';
            benchmarkRatingOut.textContent = 'Complete 5 attempts to get rated.';
            benchmarkRatingOut.style.color = 'var(--text-primary)';
            copyBtn.disabled = true;
        }
    }

    function handleInteraction(e) {
        // Prevent default behavior to avoid double firing on touch/click
        if(e) e.preventDefault();

        initAudio();

        if (currentState === 'idle') {
            if (attempts >= MAX_ATTEMPTS) {
                // If max attempts reached, reset entirely to start over
                resetTest();
            }
            startWait();
        } else if (currentState === 'waiting') {
            setState('early');
        } else if (currentState === 'ready') {
            const endTime = performance.now();
            const reactionTime = Math.round(endTime - startTime);

            scores.push(reactionTime);
            attempts++;

            updateStats();

            if (attempts >= MAX_ATTEMPTS) {
                 testArea.className = 'test-area state-idle focus-ring';
                 testIcon.textContent = '🏁';
                 testMessage.textContent = 'Test Complete';
                 testSubmessage.textContent = 'Click "Reset Test" or the box to try again.';
                 currentState = 'idle'; // Let them click again to restart
            } else {
                 // Briefly show result before letting them go to next wait state
                 testArea.className = 'test-area state-idle focus-ring';
                 testIcon.textContent = '⏱️';
                 testMessage.textContent = `${reactionTime} ms`;
                 testSubmessage.textContent = 'Click to continue...';
                 currentState = 'idle';
            }
        } else if (currentState === 'early') {
            startWait();
        }
    }

    function startWait() {
        setState('waiting');
        // Random wait between 2 and 5 seconds
        const waitTime = Math.random() * 3000 + 2000;
        timeoutId = setTimeout(() => {
            setState('ready');
        }, waitTime);
    }

    function resetTest() {
        clearTimeout(timeoutId);
        attempts = 0;
        scores = [];
        updateStats();
        setState('idle');
    }

    function copyResults() {
        if (attempts < MAX_ATTEMPTS) return;
        const avg = calculateAverage();
        const mode = getSelectedMode();
        const modeText = mode.charAt(0).toUpperCase() + mode.slice(1);
        const benchmark = getBenchmark(avg).text;

        const textToCopy = `Reaction Time Test (${modeText} Mode): ${avg}ms Average\nRating: ${benchmark}\nTest yours at: https://leeroyjenkins.quest/reaction-time`;

        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = copyBtn.textContent;
            copyBtn.textContent = 'Copied!';
            setTimeout(() => {
                copyBtn.textContent = originalText;
            }, 2000);
        });
    }

    // Event Listeners
    testArea.addEventListener('mousedown', handleInteraction);
    testArea.addEventListener('touchstart', handleInteraction, {passive: false});

    // Keyboard support
    testArea.addEventListener('keydown', (e) => {
        if (e.code === 'Space' || e.code === 'Enter') {
            e.preventDefault();
            handleInteraction(e);
        }
    });

    resetBtn.addEventListener('click', resetTest);
    copyBtn.addEventListener('click', copyResults);

    // Reset if mode changes mid-test
    modeRadios.forEach(radio => {
        radio.addEventListener('change', () => {
            if (attempts > 0 || currentState !== 'idle') {
                resetTest();
            } else {
                setState('idle'); // update the submessage text
            }
        });
    });
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-competitive-gaming-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Optimize Your Aim & Performance</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
