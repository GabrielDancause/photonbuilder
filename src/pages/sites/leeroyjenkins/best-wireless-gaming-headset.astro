  { category: "Best Premium", pick: "SteelSeries Arctis Nova Pro Wireless", reason: "ANC, hot-swap batteries, hi-res audio, simultaneous connections" },
  { category: "Best for PS5", pick: "Corsair HS80 MAX Wireless", reason: "Seamless PS5 pairing, Dolby Atmos on PC, SoundID personalization" },
  { category: "Best for PC", pick: "Razer BlackShark V2 Pro", reason: "Best mic, THX Spatial Audio, TriForce drivers" },
  { category: "Best Battery Life", pick: "HyperX Cloud III Wireless", reason: "120 hours — charge it once a month" }
