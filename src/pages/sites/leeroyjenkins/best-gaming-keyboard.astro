const categoryWinners = [
  { category: "Best Overall", pick: "Wooting 60HE+", reason: "Unmatched Rapid Trigger and analog input — the competitive standard" },
  { category: "Best Budget", pick: "Royal Kludge RK84", reason: "Wireless, hot-swap, 75% layout at just $65" },
  { category: "Best Premium", pick: "Razer Huntsman V3 Pro", reason: "4000Hz polling, Rapid Trigger, premium build and wrist rest" },
  { category: "Best TKL", pick: "SteelSeries Apex Pro TKL", reason: "Per-key actuation, Rapid Trigger, OLED display, aluminum frame" },
  { category: "Best 60%", pick: "Wooting 60HE+", reason: "Compact form factor with the best Hall Effect implementation" },
  { category: "Best Full-Size", pick: "Corsair K70 MAX", reason: "8000Hz polling, hot-swap, media controls, full numpad" },
