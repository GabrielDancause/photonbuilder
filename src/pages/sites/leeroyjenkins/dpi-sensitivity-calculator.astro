---
import SiteLayout from "../../../layouts/SiteLayout.astro";
const schema = [
  {
    "@type": "Article",
    "headline": "Interactive DPI & Sensitivity Calculator",
    "description": "Input game, resolution, desired cm/360, get optimal DPI + in-game sens.",
    "@context": "https://schema.org"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is cm/360?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": null
        }
      },
      {
        "@type": "Question",
        "name": "Does changing resolution affect sensitivity?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": null
        }
      },
      {
        "@type": "Question",
        "name": "How does DPI interact with in-game sensitivity?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": null
        }
      }
    ]
  }
];
---
<SiteLayout site="leeroyjenkins" title="Interactive DPI & Sensitivity Calculator" description="Input game, resolution, desired cm/360, get optimal DPI + in-game sens." canonical="https://leeroyjenkins.quest/dpi-sensitivity-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero"><h1>Interactive DPI & Sensitivity Calculator</h1><p>Input game, resolution, desired cm/360, get optimal DPI + in-game sens.</p></div>

    <div class="card">
      <h2>Calculate Optimal Sensitivity</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem; max-width: 400px; margin: 0 auto;">
        <div>
          <label>Game:</label>
          <select id="gameSelect" style="width: 100%; padding: 0.5rem; background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color);">
            <option value="0.022">CS2 / Apex Legends (Yaw 0.022)</option>
            <option value="0.07">Valorant (Yaw 0.07)</option>
            <option value="0.0066">Overwatch 2 (Yaw 0.0066)</option>
            <option value="0.00573">Rainbow Six Siege (Yaw 0.00573)</option>
          </select>
        </div>
        <div>
          <label>Monitor Resolution:</label>
          <select id="resSelect" style="width: 100%; padding: 0.5rem; background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color);">
            <option value="800">1080p (Full HD)</option>
            <option value="1600">1440p (QHD)</option>
            <option value="3200">2160p (4K)</option>
          </select>
        </div>
        <div>
          <label>Desired cm/360:</label>
          <input type="number" id="cm360Input" value="34.6" step="0.1" style="width: 100%; padding: 0.5rem; background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color);">
        </div>
        <button id="calcBtn" style="padding: 0.75rem; background: var(--accent-color); color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">Calculate</button>
      </div>

      <div id="resultBox" style="margin-top: 2rem; padding: 1rem; border: 1px solid var(--border-color); border-radius: 8px; display: none;">
        <h3>Results</h3>
        <p><strong>Optimal DPI:</strong> <span id="outDpi"></span> (Based on resolution to prevent pixel skipping)</p>
        <p><strong>In-Game Sensitivity:</strong> <span id="outSens"></span></p>
      </div>
    </div>

    <div class="card">
      <h2>How it Works</h2>
      <p>{null}</p>
    </div>
    <div class="card">
      <h2>FAQ</h2>
      <dl>
        <dt>What is cm/360?</dt><dd>{null}</dd>
        <dt>Does changing resolution affect sensitivity?</dt><dd>{null}</dd>
        <dt>How does DPI interact with in-game sensitivity?</dt><dd>{null}</dd>
      </dl>
    </div>
    <div class="card">
      <h2>Related</h2>
      <ul>
        <li><a href="/best-gaming-mice-2026">Best Gaming Mice 2026</a></li>
        <li><a href="/gaming-mouse-sensor-guide">Mouse Sensor Guide</a></li>
        <li><a href="/best-fps-mouse">Best FPS Mouse</a></li>
      </ul>
    </div>

  </div>
  <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('calcBtn');
        if(!btn) return;

        btn.addEventListener('click', () => {
          const yaw = parseFloat(document.getElementById('gameSelect').value);
          const optimalDpi = parseInt(document.getElementById('resSelect').value, 10);
          const cm360 = parseFloat(document.getElementById('cm360Input').value);

          if(!yaw || !optimalDpi || !cm360 || cm360 <= 0) return;

          // Formula: 360 * 2.54 / (yaw * cm360 * optimal_dpi)
          const sens = (360 * 2.54) / (yaw * cm360 * optimalDpi);

          document.getElementById('outDpi').innerText = optimalDpi;
          document.getElementById('outSens').innerText = sens.toFixed(4);
          document.getElementById('resultBox').style.display = 'block';
        });
      });
</script>
  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    th, td { padding: 0.5rem; border-bottom: 1px solid var(--border-color); text-align: left; }
    table { width: 100%; border-collapse: collapse; }
    ul { padding-left: 1.5rem; margin-top: 1rem; }
    li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    dl { margin-top: 1rem; }
    dt { font-weight: bold; margin-top: 1rem; color: var(--text-primary); }
    dd { margin-left: 1.5rem; margin-top: 0.5rem; color: var(--text-secondary); }
  </style>
</SiteLayout>
