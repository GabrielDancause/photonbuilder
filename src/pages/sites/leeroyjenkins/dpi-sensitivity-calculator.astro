---
import SiteLayout from "../../../layouts/SiteLayout.astro";
const schema = [
  {
    "@type": "Article",
    "headline": "DPI & Sensitivity Calculator",
    "description": "Convert your mouse sensitivity between games. Input your game, DPI, and resolution to find your optimal settings.",
    "@context": "https://schema.org"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is eDPI?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "eDPI stands for 'Effective DPI'. It is calculated by multiplying your mouse DPI by your in-game sensitivity. It provides a standard metric to compare true sensitivity regardless of hardware DPI."
        }
      },
      {
        "@type": "Question",
        "name": "How do I find my perfect sensitivity?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Start with an average eDPI for your game (e.g., 800 eDPI for CS:GO or 280 for Valorant). Adjust slightly up or down until you can track targets smoothly without over-flicking or feeling sluggish."
        }
      },
      {
        "@type": "Question",
        "name": "Does monitor resolution affect mouse sensitivity?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In 3D games (FPS engines), resolution does not affect turn rate. However, on your 2D desktop, a higher resolution means more pixels to cross, making the cursor feel slower at the same DPI."
        }
      }
    ]
  }
];

export const meta = {
  title: "DPI & Sensitivity Calculator",
  description: "Convert your mouse sensitivity between games. Input your game, DPI, and resolution to find your optimal settings.",
  category: "tool",
  published: "2026-03-15",
};
---
<SiteLayout site="leeroyjenkins" title="DPI & Sensitivity Calculator" description="Convert your mouse sensitivity between games. Input your game, DPI, and resolution to find your optimal settings." canonical="https://leeroyjenkins.quest/dpi-sensitivity-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero"><h1>DPI & Sensitivity Calculator</h1><p>Convert your mouse sensitivity between games. Input your game, DPI, and resolution to find your optimal settings.</p></div>

    <div class="card">
      <h2>Sensitivity Converter & eDPI Calculator</h2>
      <p>Use this tool to convert your sensitivity from one game to another, keeping your muscle memory intact across different engines.</p>

      <div class="calculator">
        <div class="input-group">
          <label for="current-game">Current Game</label>
          <select id="current-game">
            <option value="csgo">CS:GO / CS2</option>
            <option value="valorant">Valorant</option>
            <option value="apex">Apex Legends</option>
            <option value="overwatch">Overwatch 2</option>
            <option value="r6">Rainbow Six Siege</option>
          </select>
        </div>
        <div class="input-group">
          <label for="current-sens">Current In-Game Sensitivity</label>
          <input type="number" id="current-sens" value="1.0" step="0.01">
        </div>
        <div class="input-group">
          <label for="current-dpi">Mouse DPI</label>
          <input type="number" id="current-dpi" value="800" step="50">
        </div>
        <div class="input-group">
          <label for="target-game">Target Game</label>
          <select id="target-game">
            <option value="valorant">Valorant</option>
            <option value="csgo">CS:GO / CS2</option>
            <option value="apex">Apex Legends</option>
            <option value="overwatch">Overwatch 2</option>
            <option value="r6">Rainbow Six Siege</option>
          </select>
        </div>

        <div class="result-box">
          <h3>Your eDPI</h3>
          <div class="result-value" id="edpi-result">800</div>
          <h3 style="margin-top: 1rem;">Converted Target Sensitivity</h3>
          <div class="result-value" id="target-result">0.315</div>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Understanding eDPI and Conversions</h2>
      <h3>What is eDPI?</h3>
      <p>eDPI (Effective Dots Per Inch) is simply your mouse DPI multiplied by your in-game sensitivity. If Player A uses 400 DPI and 2.0 sensitivity, their eDPI is 800. If Player B uses 800 DPI and 1.0 sensitivity, their eDPI is also 800. They have the exact same true sensitivity in-game.</p>

      <h3>Why Convert Sensitivities?</h3>
      <p>Different game engines (Source, Unreal Engine, Riot's custom engine) handle sensitivity numbers differently. A '1.0' in CS:GO is vastly different from a '1.0' in Valorant. Converting ensures your physical muscle memory is retained across all games.</p>
    </div>

    <div class="card">
      <h2>FAQ</h2>
      <dl>
        <dt>What is eDPI?</dt>
        <dd>eDPI stands for 'Effective DPI'. It is calculated by multiplying your mouse DPI by your in-game sensitivity. It provides a standard metric to compare true sensitivity regardless of hardware DPI.</dd>

        <dt>How do I find my perfect sensitivity?</dt>
        <dd>Start with an average eDPI for your game (e.g., 800 eDPI for CS:GO or 280 for Valorant). Adjust slightly up or down until you can track targets smoothly without over-flicking or feeling sluggish.</dd>

        <dt>Does monitor resolution affect mouse sensitivity?</dt>
        <dd>In 3D games (FPS engines), resolution does not affect turn rate. However, on your 2D desktop, a higher resolution means more pixels to cross, making the cursor feel slower at the same DPI.</dd>
      </dl>
    </div>

    <div class="card">
      <h2>Related Guides</h2>
      <div class="cluster-links">
        <div class="cluster-link-card"><a href="/best-gaming-mice-2026">Best Gaming Mice 2026</a> (Pillar)</div>
        <div class="cluster-link-card"><a href="/gaming-mouse-sensor-guide">Sensor Guide</a></div>
        <div class="cluster-link-card"><a href="/best-fps-mouse">Best FPS Mice</a></div>
      </div>
    </div>

  </div>
  <script is:inline>

    // Simple mock conversion logic for the calculator
    const multipliers = {
      csgo: 1,
      apex: 1,
      valorant: 3.181818, // CSGO to Valorant ratio
      overwatch: 0.3,     // CSGO to OW ratio (approx)
      r6: 0.26           // CSGO to R6 ratio (approx based on default multiplier)
    };

    function calculate() {
      const currentGame = document.getElementById('current-game').value;
      const targetGame = document.getElementById('target-game').value;
      const currentSens = parseFloat(document.getElementById('current-sens').value) || 0;
      const currentDpi = parseFloat(document.getElementById('current-dpi').value) || 0;

      const edpi = currentSens * currentDpi;
      document.getElementById('edpi-result').innerText = edpi.toFixed(0);

      // Convert current sens to a "base" (CSGO scale)
      const baseSens = currentSens * multipliers[currentGame];

      // Convert "base" to target
      const targetSens = baseSens / multipliers[targetGame];

      document.getElementById('target-result').innerText = targetSens.toFixed(3);
    }

    document.getElementById('current-game').addEventListener('change', calculate);
    document.getElementById('target-game').addEventListener('change', calculate);
    document.getElementById('current-sens').addEventListener('input', calculate);
    document.getElementById('current-dpi').addEventListener('input', calculate);

    // Initial calc
    calculate();

  </script>
  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .card h2 { margin-top: 0; color: var(--text-primary); }
    .card h3 { color: var(--text-primary); }
    th, td { padding: 0.5rem; border-bottom: 1px solid var(--border-color); text-align: left; }
    table { width: 100%; border-collapse: collapse; }
    ul, ol { padding-left: 1.5rem; margin-top: 1rem; color: var(--text-secondary); }
    li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; font-weight: bold; }
    a:hover { text-decoration: underline; }
    dl { margin-top: 1rem; }
    dt { font-weight: bold; margin-top: 1rem; color: var(--text-primary); }
    dd { margin-left: 1.5rem; margin-top: 0.5rem; color: var(--text-secondary); }
    .cluster-links { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin-top: 1rem; }
    .cluster-link-card { background: var(--bg-color); border: 1px solid var(--border-color); padding: 1rem; border-radius: 8px; text-align: center; }

    /* Calculator styles */
    .calculator { display: grid; gap: 1rem; }
    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group label { font-weight: bold; color: var(--text-primary); }
    .input-group select, .input-group input { padding: 0.5rem; border-radius: 4px; border: 1px solid var(--border-color); background: var(--bg-color); color: var(--text-primary); }
    .result-box { background: var(--bg-color); padding: 1.5rem; border-radius: 8px; text-align: center; margin-top: 1rem; border: 1px solid var(--accent-color); }
    .result-box h3 { margin: 0 0 0.5rem 0; color: var(--accent-color); }
    .result-value { font-size: 2rem; font-weight: bold; color: var(--text-primary); }
  </style>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/mouse-sensitivity-converter" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Mouse Sensitivity Converter</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Free mouse sensitivity converter and eDPI calculator. Convert your sensitivity between CS2, Valorant, Overwatch 2, Fortn...</p>
      </a>
    </div>
  </div>
</SiteLayout>
