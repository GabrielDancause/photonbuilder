    .quiz-result h3 { color: #fff; margin-top: 0; margin-bottom: 1rem; font-size: 1.5rem; }
    .highlight-text { color: var(--accent-color); }
    .quiz-result p { color: #e2e8f0; line-height: 1.6; margin-bottom: 2rem; font-size: 1.1rem; }

