---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "What's the difference between screen resolution and viewport size?",
    a: "Screen resolution is the total number of physical pixels your monitor has (e.g., 1920×1080), while viewport size is the area your browser uses to display content. The viewport is always smaller than screen resolution because it excludes the browser's address bar, tabs, taskbar, and other UI chrome. On high-DPI displays (Retina, 4K), the viewport can also differ because the operating system scales content — a 3840×2160 screen at 200% scaling has an effective viewport of 1920×1080 CSS pixels. For gaming, screen resolution matters most. For web development, viewport size is what determines layout behavior."
  },
  {
    q: "What is device pixel ratio (DPR) and why does it matter for gaming?",
    a: "Device pixel ratio is the number of physical pixels per CSS pixel. A DPR of 1 means one physical pixel equals one CSS pixel (standard 1080p/1440p monitors). A DPR of 2 means each CSS pixel is rendered with 4 physical pixels (2×2), which is common on Retina displays and 4K monitors at 200% scaling. For gaming, a higher DPR means your GPU has to render significantly more pixels — 4K at DPR 2 would be rendering at an effective 7680×4320, which is absurd. Most games bypass DPR entirely and render at native resolution. For streaming and content creation, understanding your DPR helps you capture screenshots and record video at the correct resolution."
  },
  {
    q: "How do I check if my monitor has dead pixels?",
    a: "Use a dead pixel test by displaying solid colors across your entire screen — white, black, red, green, and blue. Dead pixels appear as tiny dots that don't change color. A stuck pixel shows as a bright dot on a black screen (it's permanently on), while a dead pixel appears as a dark dot on a white screen (it's permanently off). Stuck pixels can sometimes be fixed by rapidly cycling colors or applying gentle pressure with a soft cloth, but dead pixels are usually permanent. Most manufacturers allow 1-5 dead pixels before honoring a warranty replacement, though premium brands like Dell and ASUS have zero-dead-pixel policies on their gaming monitor lines."
  },
  {
    q: "What resolution should I use for competitive gaming — 1080p, 1440p, or 4K?",
    a: "For competitive FPS games, 1080p at 240Hz+ is still the gold standard among pros. The reason is simple: lower resolution means higher frame rates and lower input lag. At 1080p, even mid-range GPUs can push 300+ FPS in games like Valorant and CS2, keeping frame times consistently below 4ms. 1440p at 165-240Hz is an excellent middle ground if you play a mix of competitive and AAA games — you get noticeably sharper text and details with only a 15-25% FPS drop versus 1080p. 4K gaming at 120Hz+ requires a top-tier GPU (RTX 4080/4090) and is best for single-player or story-driven games where visual quality matters more than raw FPS."
  },
  {
    q: "What aspect ratio is best for gaming — 16:9, 21:9, or 32:9?",
    a: "16:9 is the standard and safest choice — all competitive games support it, and it offers the best performance since you're rendering fewer pixels than wider formats. 21:9 ultrawide (2560×1080 or 3440×1440) gives you more peripheral vision in supported games, which is a legitimate advantage in titles like Escape from Tarkov, Apex Legends, and flight sims. However, some competitive games like Valorant and Overwatch 2 don't support 21:9 and will add black bars. 32:9 super ultrawide (5120×1440) is immersive for sim racing and flight sims but is banned or unsupported in most competitive titles. Stick with 16:9 if you primarily play ranked FPS games."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Screen Resolution Tester — Display & Pixel Check",
    "description": "Free screen resolution tester. Detect your resolution, viewport, pixel ratio, refresh rate, and color depth. Test for dead pixels with full-screen colors. Compare gaming monitor resolutions and PPI.",
    "applicationCategory": "Utility",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Screen Resolution Tester — Display & Pixel Check",
  description: "Free screen resolution tester. Detect resolution, viewport, pixel ratio, refresh rate, and color depth. Dead pixel tester, gaming monitor PPI comparison, and responsive viewport checker.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Screen Resolution Tester — Display & Pixel Check"
  description="Free screen resolution tester. Detect resolution, viewport, pixel ratio, refresh rate, and color depth. Dead pixel tester, gaming monitor PPI comparison, and responsive viewport checker."
  canonical="https://leeroyjenkins.quest/screen-resolution-tester"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Screen Resolution Tester</h1>
      <p>Detect your screen resolution, viewport size, pixel ratio, refresh rate, and color depth. Test for dead pixels and compare gaming monitor specs — all in your browser.</p>
    </div>

    <section class="content-section">
      <!-- Your Screen Info -->
      <div class="optimizer-card">
        <div class="step-header"><span class="step-num">1</span> Your Screen Info</div>
        <div class="info-grid" id="screen-info">
          <div class="info-tile">
            <div class="info-label">Screen Resolution</div>
            <div class="info-value" id="val-resolution">Detecting...</div>
          </div>
          <div class="info-tile">
            <div class="info-label">Viewport Size</div>
            <div class="info-value" id="val-viewport">Detecting...</div>
          </div>
          <div class="info-tile">
            <div class="info-label">Device Pixel Ratio</div>
            <div class="info-value" id="val-dpr">Detecting...</div>
          </div>
          <div class="info-tile">
            <div class="info-label">Aspect Ratio</div>
            <div class="info-value" id="val-aspect">Detecting...</div>
          </div>
          <div class="info-tile">
            <div class="info-label">Color Depth</div>
            <div class="info-value" id="val-color">Detecting...</div>
          </div>
          <div class="info-tile">
            <div class="info-label">Estimated Refresh Rate</div>
            <div class="info-value" id="val-refresh">Measuring...</div>
          </div>
        </div>
      </div>

      <!-- Resolution Comparison -->
      <div class="optimizer-card">
        <div class="step-header"><span class="step-num">2</span> Resolution Comparison</div>
        <p class="card-desc">How your screen compares to standard resolutions.</p>
        <div class="res-bars" id="res-bars"></div>
      </div>

      <!-- Dead Pixel Tester -->
      <div class="optimizer-card">
        <div class="step-header"><span class="step-num">3</span> Dead Pixel Tester</div>
        <p class="card-desc">Click a color to fill your entire screen. Press <kbd>Esc</kbd> or click anywhere to exit. Look for dots that don't match the displayed color.</p>
        <div class="color-row" id="color-row">
          <button class="color-swatch" data-color="#ffffff" style="background:#ffffff;" title="White"></button>
          <button class="color-swatch" data-color="#000000" style="background:#000000;" title="Black"></button>
          <button class="color-swatch" data-color="#ff0000" style="background:#ff0000;" title="Red"></button>
          <button class="color-swatch" data-color="#00ff00" style="background:#00ff00;" title="Green"></button>
          <button class="color-swatch" data-color="#0000ff" style="background:#0000ff;" title="Blue"></button>
          <button class="color-swatch" data-color="#808080" style="background:#808080;" title="Gray"></button>
        </div>
      </div>

      <!-- Gaming Monitor PPI Comparison -->
      <div class="optimizer-card">
        <div class="step-header"><span class="step-num">4</span> Gaming Monitor PPI Comparison</div>
        <p class="card-desc">Pixels per inch (PPI) at different screen sizes. Higher PPI = sharper image.</p>
        <div class="table-wrapper">
          <table id="ppi-table">
            <thead>
              <tr>
                <th>Resolution</th>
                <th>Name</th>
                <th>24"</th>
                <th>27"</th>
                <th>32"</th>
                <th>Best For</th>
              </tr>
            </thead>
            <tbody id="ppi-body"></tbody>
          </table>
        </div>
      </div>

      <!-- Responsive Viewport Comparison -->
      <div class="optimizer-card">
        <div class="step-header"><span class="step-num">5</span> Responsive Viewport Comparison</div>
        <p class="card-desc">See how your viewport compares to common devices. Green = your viewport is wider than that device.</p>
        <div class="device-list" id="device-list"></div>
      </div>

      <h2>Understanding Your Screen Specs</h2>

      <h3>Resolution vs. Effective Resolution</h3>
      <p>Your screen resolution is the raw pixel count of your display. However, most modern operating systems use display scaling (100%, 125%, 150%, 200%) to make text and UI elements readable at high DPI. A 4K monitor (3840×2160) at 200% scaling behaves like a 1920×1080 display for layout purposes but renders text and images at 4× the detail. The "viewport" you see reported above reflects this scaled resolution.</p>

      <h3>Why Pixel Density Matters</h3>
      <p>Pixels per inch (PPI) determines how sharp your display looks. At normal desk viewing distances (2-3 feet), most people can't distinguish individual pixels above ~110 PPI. A 24" 1080p monitor has 92 PPI — you can see pixels if you look closely. A 27" 1440p monitor hits 109 PPI — the sweet spot for gaming. A 27" 4K monitor at 163 PPI is razor-sharp but requires a powerful GPU. For competitive gaming, 24-27" at 1080p or 1440p is ideal because you can maintain high frame rates without sacrificing too much sharpness.</p>

      <h3>Refresh Rate Detection</h3>
      <p>The refresh rate shown above is estimated using requestAnimationFrame timing. It may not be perfectly accurate — your actual monitor refresh rate is set in your OS display settings. Common gaming refresh rates are 60Hz (budget), 144Hz (competitive standard), 165Hz (common 1440p), 240Hz (high-end competitive), and 360Hz (pro esports). Make sure your Windows display settings are set to the maximum refresh rate your monitor supports — many monitors default to 60Hz even when they support 144Hz+.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/fps-settings-optimizer" class="related-link">
          <strong>FPS Settings Optimizer</strong>
          <span>Get optimized settings for Valorant, CS2, Fortnite & more</span>
        </a>
        <a href="/best-gaming-monitor" class="related-link">
          <strong>Best Gaming Monitors</strong>
          <span>144Hz, 240Hz, 360Hz — high-refresh displays compared</span>
        </a>
      </div>
    </section>
  </div>

  <!-- Dead pixel fullscreen overlay -->
  <div id="dp-overlay" class="dp-overlay" style="display:none;"></div>

  <script is:inline>
  (function() {
    /* ── Helper: GCD for aspect ratio ── */
    function gcd(a, b) { return b === 0 ? a : gcd(b, a % b); }

    function getAspectRatio(w, h) {
      var d = gcd(w, h);
      var rw = w / d, rh = h / d;
      /* Normalize common ratios */
      var known = { '8:5': '16:10', '16:10': '16:10', '16:9': '16:9', '21:9': '21:9', '32:9': '32:9', '64:27': '21:9' };
      var key = rw + ':' + rh;
      return known[key] || key;
    }

    /* ── Detect screen info ── */
    var sw = screen.width, sh = screen.height;
    var dpr = window.devicePixelRatio || 1;
    var physW = Math.round(sw * dpr), physH = Math.round(sh * dpr);

    document.getElementById('val-resolution').textContent = physW + ' × ' + physH + ' px';
    document.getElementById('val-viewport').textContent = window.innerWidth + ' × ' + window.innerHeight + ' px';
    document.getElementById('val-dpr').textContent = dpr + 'x' + (dpr > 1 ? ' (HiDPI / Retina)' : '');
    document.getElementById('val-aspect').textContent = getAspectRatio(physW, physH);
    document.getElementById('val-color').textContent = screen.colorDepth + '-bit';

    /* Update viewport on resize */
    window.addEventListener('resize', function() {
      document.getElementById('val-viewport').textContent = window.innerWidth + ' × ' + window.innerHeight + ' px';
    });

    /* ── Estimate refresh rate ── */
    var frameTimes = [];
    var lastTime = 0;
    var frameCount = 0;

    function measureFrame(ts) {
      if (lastTime > 0) {
        frameTimes.push(ts - lastTime);
      }
      lastTime = ts;
      frameCount++;
      if (frameCount < 62) {
        requestAnimationFrame(measureFrame);
      } else {
        /* Discard first few samples, compute median */
        frameTimes.sort(function(a, b) { return a - b; });
        var mid = Math.floor(frameTimes.length / 2);
        var median = frameTimes[mid];
        var hz = Math.round(1000 / median);
        /* Snap to common rates */
        var common = [60, 75, 90, 120, 144, 165, 180, 200, 240, 300, 360];
        var snapped = hz;
        for (var i = 0; i < common.length; i++) {
          if (Math.abs(hz - common[i]) <= 3) { snapped = common[i]; break; }
        }
        document.getElementById('val-refresh').textContent = snapped + ' Hz' + (snapped !== hz ? ' (detected ~' + hz + ')' : '');
      }
    }
    requestAnimationFrame(measureFrame);

    /* ── Resolution comparison bars ── */
    var RESOLUTIONS = [
      { name: '720p (HD)', w: 1280, h: 720 },
      { name: '1080p (Full HD)', w: 1920, h: 1080 },
      { name: '1440p (QHD)', w: 2560, h: 1440 },
      { name: '1080p UW', w: 2560, h: 1080 },
      { name: '1440p UW', w: 3440, h: 1440 },
      { name: '4K (UHD)', w: 3840, h: 2160 },
      { name: '5K', w: 5120, h: 2880 },
      { name: 'Super UW', w: 5120, h: 1440 }
    ];

    var maxPixels = Math.max(physW * physH, RESOLUTIONS[RESOLUTIONS.length - 1].w * RESOLUTIONS[RESOLUTIONS.length - 1].h);
    var barsHtml = '';

    /* Add user's resolution */
    var userPx = physW * physH;
    barsHtml += '<div class="res-row">' +
      '<div class="res-label"><strong>Your Screen</strong><span class="res-dim">' + physW + '×' + physH + '</span></div>' +
      '<div class="res-track"><div class="res-fill res-fill-user" style="width:' + ((userPx / maxPixels) * 100).toFixed(1) + '%;"></div></div>' +
      '<div class="res-pixels">' + (userPx / 1000000).toFixed(1) + ' MP</div></div>';

    for (var i = 0; i < RESOLUTIONS.length; i++) {
      var r = RESOLUTIONS[i];
      var px = r.w * r.h;
      var pct = (px / maxPixels) * 100;
      var isMatch = (r.w === physW && r.h === physH);
      barsHtml += '<div class="res-row">' +
        '<div class="res-label">' + r.name + '<span class="res-dim">' + r.w + '×' + r.h + '</span></div>' +
        '<div class="res-track"><div class="res-fill' + (isMatch ? ' res-fill-match' : '') + '" style="width:' + pct.toFixed(1) + '%;"></div></div>' +
        '<div class="res-pixels">' + (px / 1000000).toFixed(1) + ' MP</div></div>';
    }

    document.getElementById('res-bars').innerHTML = barsHtml;

    /* ── PPI Table ── */
    var PPI_DATA = [
      { res: '1920×1080', name: '1080p (Full HD)', bestFor: 'Competitive FPS' },
      { res: '2560×1080', name: '1080p Ultrawide', bestFor: 'Immersive gaming' },
      { res: '2560×1440', name: '1440p (QHD)', bestFor: 'All-around gaming' },
      { res: '3440×1440', name: '1440p Ultrawide', bestFor: 'Sim racing, RPGs' },
      { res: '3840×2160', name: '4K (UHD)', bestFor: 'Single-player, content' },
      { res: '5120×1440', name: 'Super Ultrawide', bestFor: 'Sim racing, productivity' }
    ];

    function calcPPI(w, h, diag) {
      return Math.round(Math.sqrt(w * w + h * h) / diag);
    }

    var ppiHtml = '';
    for (var i = 0; i < PPI_DATA.length; i++) {
      var d = PPI_DATA[i];
      var parts = d.res.split('×');
      var w = parseInt(parts[0]), h = parseInt(parts[1]);
      var ppi24 = calcPPI(w, h, 24);
      var ppi27 = calcPPI(w, h, 27);
      var ppi32 = calcPPI(w, h, 32);
      ppiHtml += '<tr><td><strong>' + d.res + '</strong></td><td>' + d.name + '</td>' +
        '<td>' + ppi24 + '</td><td>' + ppi27 + '</td><td>' + ppi32 + '</td>' +
        '<td><span class="best-for-badge">' + d.bestFor + '</span></td></tr>';
    }
    document.getElementById('ppi-body').innerHTML = ppiHtml;

    /* ── Responsive Device Comparison ── */
    var DEVICES = [
      { name: 'iPhone SE', w: 375 },
      { name: 'iPhone 14/15', w: 390 },
      { name: 'iPhone 14/15 Pro Max', w: 430 },
      { name: 'iPad Mini', w: 768 },
      { name: 'iPad Air/Pro', w: 1024 },
      { name: 'Small Laptop (13")', w: 1280 },
      { name: 'Laptop (15")', w: 1440 },
      { name: 'Desktop 1080p', w: 1920 },
      { name: 'Desktop 1440p', w: 2560 },
      { name: 'Desktop 4K', w: 3840 }
    ];

    var viewW = window.innerWidth;
    var maxDevW = 3840;
    var devHtml = '';
    for (var i = 0; i < DEVICES.length; i++) {
      var dev = DEVICES[i];
      var wider = viewW >= dev.w;
      devHtml += '<div class="device-row">' +
        '<div class="device-name">' + dev.name + '<span class="device-px">' + dev.w + 'px</span></div>' +
        '<div class="device-track"><div class="device-fill' + (wider ? ' device-wider' : '') + '" style="width:' + ((dev.w / maxDevW) * 100).toFixed(1) + '%;"></div>' +
        '<div class="device-marker" style="left:' + ((viewW / maxDevW) * 100).toFixed(1) + '%;"></div></div>' +
        '<div class="device-status">' + (wider ? '✓' : '—') + '</div></div>';
    }
    document.getElementById('device-list').innerHTML = devHtml;

    /* ── Dead Pixel Tester ── */
    var overlay = document.getElementById('dp-overlay');

    document.getElementById('color-row').addEventListener('click', function(e) {
      var swatch = e.target.closest('[data-color]');
      if (!swatch) return;
      overlay.style.background = swatch.dataset.color;
      overlay.style.display = 'block';
      if (document.documentElement.requestFullscreen) {
        document.documentElement.requestFullscreen().catch(function() {});
      }
    });

    overlay.addEventListener('click', function() {
      overlay.style.display = 'none';
      if (document.fullscreenElement) {
        document.exitFullscreen().catch(function() {});
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && overlay.style.display === 'block') {
        overlay.style.display = 'none';
      }
    });

    document.addEventListener('fullscreenchange', function() {
      if (!document.fullscreenElement && overlay.style.display === 'block') {
        overlay.style.display = 'none';
      }
    });
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Cards */
    .optimizer-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.4rem 1.5rem; margin-bottom: 1rem; }
    .step-header { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.6rem; }
    .step-num { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: var(--accent-color); color: #fff; border-radius: 50%; font-size: 0.85rem; font-weight: 800; flex-shrink: 0; }
    .card-desc { color: var(--text-secondary); font-size: 0.9rem; margin-top: -0.3rem; margin-bottom: 1rem; }
    .card-desc kbd { background: var(--border-color); padding: 0.1rem 0.4rem; border-radius: 4px; font-size: 0.8rem; font-family: inherit; }

    /* Screen Info Grid */
    .info-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
    .info-tile { background: rgba(0,0,0,0.15); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem; text-align: center; }
    .info-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700; color: var(--text-secondary); margin-bottom: 0.4rem; }
    .info-value { font-size: 1.15rem; font-weight: 800; color: var(--accent-color); word-break: break-word; }

    /* Resolution Bars */
    .res-bars { display: flex; flex-direction: column; gap: 0.5rem; }
    .res-row { display: grid; grid-template-columns: 140px 1fr 60px; gap: 0.6rem; align-items: center; }
    .res-label { font-size: 0.8rem; font-weight: 600; color: var(--text-primary); line-height: 1.2; }
    .res-dim { display: block; font-size: 0.7rem; font-weight: 400; color: var(--text-secondary); }
    .res-track { height: 20px; background: rgba(0,0,0,0.15); border-radius: 6px; overflow: hidden; position: relative; }
    .res-fill { height: 100%; background: var(--border-color); border-radius: 6px; transition: width 0.4s ease; min-width: 4px; }
    .res-fill-user { background: var(--accent-color); }
    .res-fill-match { background: var(--accent-color); opacity: 0.6; }
    .res-pixels { font-size: 0.75rem; color: var(--text-secondary); text-align: right; font-weight: 600; }

    /* Dead Pixel Color Swatches */
    .color-row { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .color-swatch { width: 52px; height: 52px; border-radius: 10px; border: 3px solid var(--border-color); cursor: pointer; transition: transform 0.15s, border-color 0.15s; }
    .color-swatch:hover { transform: scale(1.1); border-color: var(--accent-color); }

    /* Dead Pixel Overlay */
    .dp-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 99999; cursor: pointer; }

    /* PPI Table */
    .table-wrapper { overflow-x: auto; border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 1rem; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.65rem 0.8rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.55rem 0.8rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }
    .best-for-badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 700; background: rgba(81,207,102,0.15); color: #51cf66; white-space: nowrap; }

    /* Device Comparison */
    .device-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .device-row { display: grid; grid-template-columns: 160px 1fr 30px; gap: 0.6rem; align-items: center; }
    .device-name { font-size: 0.8rem; font-weight: 600; color: var(--text-primary); line-height: 1.2; }
    .device-px { display: block; font-size: 0.7rem; font-weight: 400; color: var(--text-secondary); }
    .device-track { height: 18px; background: rgba(0,0,0,0.15); border-radius: 6px; overflow: hidden; position: relative; }
    .device-fill { height: 100%; background: var(--border-color); border-radius: 6px; min-width: 4px; }
