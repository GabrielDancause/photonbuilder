    .device-marker { position: absolute; top: 0; height: 100%; width: 2px; background: var(--accent-color); transform: translateX(-1px); }
    .device-status { font-size: 0.85rem; text-align: center; font-weight: 700; color: var(--text-secondary); }
    .device-fill.device-wider + .device-marker ~ .device-status,
    .device-row:has(.device-wider) .device-status { color: #51cf66; }

    /* FAQ */
