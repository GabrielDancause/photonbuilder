export const meta = {
  title: 'Pokémon Go Evolution Calculator | Leeroyjenkins',
  description: 'Calculate your Pokémon Go evolution CP with our accurate, interactive calculator. Estimate Combat Power, candy costs, and evolution chains instantly.',
  category: 'tool',
  keywords: ['pokemon go evolution calculator', 'pokemon cp calculator', 'pokemon go evolve cp', 'pokemon evolution cp', 'pokemon go calculator']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "leeroyjenkins.quest" },
    "publisher": { "@type": "Organization", "name": "leeroyjenkins.quest" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does the Pokémon Go Evolution Calculator work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The calculator uses known multipliers for each Pokémon species to estimate the Combat Power (CP) of the evolved form. By inputting your Pokémon's current CP, the tool multiplies it by the species-specific range (minimum and maximum multipliers) to provide an accurate estimated CP range after evolution."
        }
      },
      {
        "@type": "Question",
        "name": "Is the evolved CP exact or an estimate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The evolved CP is an estimate, provided as a range. The exact CP depends on the hidden Individual Values (IVs) of your specific Pokémon (Attack, Defense, and Stamina) and its exact half-level. Our calculator provides a highly accurate minimum and maximum bound based on community-sourced data."
        }
      },
      {
        "@type": "Question",
        "name": "Does evolving a Pokémon change its IVs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, a Pokémon's Individual Values (IVs) remain completely unchanged when it evolves. If you evolve a 100% IV (perfect) Pokémon, the evolved form will also be 100% IV. Only the base stats of the species change, which combined with the static IVs, results in the new, higher CP."
        }
      },
      {
        "@type": "Question",
        "name": "Should I power up my Pokémon before or after evolving?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Mathematically, it costs exactly the same amount of Stardust and Candy to power up a Pokémon before or after evolving. However, it is highly recommended to evolve first to check the Pokémon's new moveset before investing valuable Stardust, as you might prefer different attacks."
        }
      },
      {
        "@type": "Question",
        "name": "Why do some Pokémon have a huge CP jump while others don't?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The CP jump depends on the difference between the base stats of the unevolved and evolved species. For example, Magikarp has incredibly low base stats but Gyarados has very high ones, leading to a massive 10x multiplier. Others, like Metapod to Butterfree, have a much smaller base stat increase."
        }
      }
    ]
  }
]);

