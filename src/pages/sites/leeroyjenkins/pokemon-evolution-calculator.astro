---

<SiteLayout site="leeroyjenkins" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <style is:inline>
    .page-wrapper {
      font-family: var(--font-body, system-ui, sans-serif);
      color: var(--text-primary);
      background-color: var(--bg-primary);
    }
    .hero {
      text-align: center;
      padding: 4rem 1rem;
      background: linear-gradient(to bottom, rgba(234, 179, 8, 0.1), transparent);
      border-bottom: 1px solid var(--border-color);
      margin-bottom: 3rem;
    }
    .hero h1 {
      font-size: 2.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }
    .hero p {
      font-size: 1.2rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }
    .calculator-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .input-group {
      margin-bottom: 1.5rem;
    }
    .input-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: var(--text-primary);
    }
    .input-group select, .input-group input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      background: var(--bg-primary);
      color: var(--text-primary);
      font-size: 1rem;
    }
    .input-group select:focus, .input-group input:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 2px rgba(234, 179, 8, 0.2);
    }
    .btn-primary {
      display: inline-block;
      width: 100%;
      padding: 1rem;
      background: var(--accent-color);
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
      margin-top: 1rem;
    }
    .btn-primary:hover {
      opacity: 0.9;
    }
    .error-message {
      color: #ef4444;
      font-size: 0.9rem;
      margin-top: 0.5rem;
      display: none;
    }
    .result-section {
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
      display: none;
    }
    .result-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }
    .result-card {
      background: var(--bg-primary);
      padding: 1.5rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
      text-align: center;
    }
    .result-card h3 {
      font-size: 1rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }
    .result-value {
      font-size: 2rem;
      font-weight: bold;
      color: var(--accent-color);
    }
    .evolution-chain {
      margin-top: 2rem;
      padding: 1.5rem;
      background: rgba(234, 179, 8, 0.05);
      border-radius: 8px;
      text-align: center;
    }
    .chain-flow {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }
    .chain-item {
      font-weight: bold;
      color: var(--text-primary);
    }
    .chain-arrow {
      color: var(--text-secondary);
    }
    .candy-cost {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-top: 0.5rem;
    }
    .chart-wrapper {
      margin-top: 2rem;
      padding: 1.5rem;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
    }
    .chart-title {
      font-size: 1.1rem;
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 1rem;
      text-align: center;
    }
    .chart-container {
      position: relative;
      height: 40px;
      background: #e2e8f0;
      border-radius: 20px;
      overflow: hidden;
    }
    .chart-bar-min {
      position: absolute;
      height: 100%;
      background: #94a3b8;
      border-radius: 20px 0 0 20px;
    }
    .chart-bar-range {
      position: absolute;
      height: 100%;
      background: var(--accent-color);
    }
    .chart-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 0.5rem;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }
    .educational-section {
      max-width: 800px;
      margin: 4rem auto;
      padding: 0 1rem;
    }
    .educational-section h2 {
      font-size: 1.8rem;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      text-align: center;
    }
    .grid-3 {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .card {
      background: var(--card-bg);
      padding: 1.5rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }
    .card h3 {
      color: var(--accent-color);
      margin-bottom: 1rem;
    }
    .card p {
      color: var(--text-secondary);
      line-height: 1.6;
    }
    .faq-section {
      max-width: 800px;
      margin: 4rem auto;
      padding: 0 1rem;
    }
    .faq-section h2 {
      font-size: 1.8rem;
      color: var(--text-primary);
      margin-bottom: 2rem;
      text-align: center;
    }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      margin-bottom: 1rem;
      padding: 1.5rem;
    }
    .faq-item h3 {
      font-size: 1.1rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }
    .faq-item p {
      color: var(--text-secondary);
      line-height: 1.6;
    }
    .related-tools {
      max-width: 800px;
      margin: 4rem auto;
      padding: 0 1rem;
      text-align: center;
    }
    .related-tools h2 {
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }
    .related-links {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .related-link {
      padding: 0.75rem 1.5rem;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 999px;
      color: var(--text-primary);
      text-decoration: none;
      transition: all 0.2s;
    }
    .related-link:hover {
      background: var(--accent-color);
      color: white;
      border-color: var(--accent-color);
    }
    .table-container {
      overflow-x: auto;
      margin-top: 2rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--card-bg);
    }
    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }
    th {
      background: rgba(234, 179, 8, 0.1);
      font-weight: bold;
    }
    tr:last-child td {
      border-bottom: none;
    }
    @media (max-width: 600px) {
      .hero h1 { font-size: 2rem; }
      .calculator-container { padding: 1.5rem; }
    }
  </style>

  <div class="page-wrapper">
    <section class="hero">
      <h1>Pokémon Go Evolution Calculator</h1>
      <p>Instantly estimate the Combat Power (CP) of your Pokémon after evolution. Plan your team, manage your candy, and dominate raids.</p>
    </section>

    <main class="calculator-container">
      <div class="input-group">
        <label for="pokemon-select">Select Pokémon to Evolve</label>
        <select id="pokemon-select">
          <option value="">-- Choose a Pokémon --</option>
        </select>
        <div id="pokemon-error" class="error-message">Please select a Pokémon.</div>
      </div>

      <div class="input-group">
        <label for="cp-input">Current CP</label>
        <input type="number" id="cp-input" min="10" max="5000" placeholder="e.g. 450" />
        <div id="cp-error" class="error-message">Please enter a valid CP (10-5000).</div>
      </div>

      <button id="calculate-btn" class="btn-primary">Calculate Evolution CP</button>

      <div id="result-section" class="result-section">
        <h2 style="text-align: center; margin-bottom: 1rem; color: var(--text-primary);">Evolution Results</h2>
        <div class="result-cards">
          <div class="result-card">
            <h3>Minimum CP</h3>
            <div id="min-cp-result" class="result-value">--</div>
          </div>
          <div class="result-card">
            <h3>Maximum CP</h3>
            <div id="max-cp-result" class="result-value">--</div>
          </div>
        </div>

        <div class="evolution-chain">
          <h3 style="margin-bottom: 0.5rem;">Evolution Path</h3>
          <div class="chain-flow">
            <span id="chain-start" class="chain-item">--</span>
            <span class="chain-arrow">➔</span>
            <span id="chain-end" class="chain-item">--</span>
          </div>
          <div class="candy-cost">Cost: <strong id="candy-cost-val">--</strong> Candy</div>
        </div>

        <div class="chart-wrapper">
          <div class="chart-title">Estimated CP Range</div>
          <div class="chart-container">
            <div id="chart-bar-min" class="chart-bar-min" style="width: 0%"></div>
            <div id="chart-bar-range" class="chart-bar-range" style="left: 0%; width: 0%"></div>
          </div>
          <div class="chart-labels">
            <span>0</span>
            <span id="chart-max-label">4000</span>
          </div>
        </div>
      </div>
    </main>

    <section class="educational-section">
      <h2>Understanding Pokémon Evolution CP</h2>
      <div class="grid-3">
        <div class="card">
          <h3>The Multiplier Effect</h3>
          <p>Every Pokémon species has a specific evolution multiplier range. When you evolve a Pokémon, its current CP is multiplied by this hidden value to determine its new Combat Power. Species with higher base stat increases have larger multipliers.</p>
        </div>
        <div class="card">
          <h3>The Role of IVs</h3>
          <p>Individual Values (IVs) for Attack, Defense, and Stamina stay exactly the same through evolution. The exact multiplier you get within the possible range depends entirely on your Pokémon's unique combination of IVs and its exact hidden half-level.</p>
        </div>
        <div class="card">
          <h3>Evolution Costs</h3>
          <p>Evolving requires species-specific Candy. First-stage evolutions usually cost 25 or 50 candy, while second-stage evolutions often cost 100. Some unique species require items, walking distances, or massive 400 candy investments (like Magikarp).</p>
        </div>
      </div>
    </section>

    <section class="educational-section">
      <h2>What Makes a Strong Evolution?</h2>
      <div class="grid-3">
        <div class="card">
          <h3>Base Stat Jumps</h3>
          <p>The core of any evolution's CP increase is the base stat jump. When a Pokémon evolves, its base Attack, Defense, and Stamina permanently increase according to its species definition. For instance, Weedle has incredibly low base stats, while Beedrill has moderately higher ones.</p>
        </div>
        <div class="card">
          <h3>Level Caps</h3>
          <p>A Pokémon's level remains constant during evolution. A level 20 Charmander will become a level 20 Charmeleon. The maximum level is 50, requiring vast amounts of Candy XL and Stardust to reach.</p>
        </div>
        <div class="card">
          <h3>Moveset Rerolls</h3>
          <p>Upon evolution, your Pokémon will learn a completely new Fast and Charged Attack from the evolved form's possible movepool. It is usually best to evolve before using Stardust to power up, ensuring you get a desirable moveset.</p>
        </div>
      </div>
    </section>

    <section class="educational-section">
      <h2>Advanced Mechanics: Level and CP Formula</h2>
      <div class="card" style="margin-top: 2rem;">
        <h3>How CP is Calculated</h3>
        <p>The true CP formula in Pokémon Go is a complex calculation: <code>CP = (Attack * Defense^0.5 * Stamina^0.5 * CPMultiplier^2) / 10</code>. This is why Attack has such a massive influence on the final CP value compared to Defense and Stamina. The CPMultiplier is a hidden value that corresponds to the Pokémon's exact level, increasing every half-level. Understanding this formula is crucial for optimizing Pokémon for PVP leagues like the Great League, where low Attack IVs often allow a Pokémon to reach a higher level and better overall bulk under the 1500 CP cap.</p>
      </div>
    </section>

    <section class="educational-section">
      <h2>Popular Evolution Multipliers</h2>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Pokémon</th>
              <th>Evolves To</th>
              <th>Min Multiplier</th>
              <th>Max Multiplier</th>
              <th>Candy Cost</th>
            </tr>
          </thead>
          <tbody id="multiplier-table-body">
          </tbody>
        </table>
      </div>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list" id="faq-list-container">
      </div>
    </section>

    <section class="related-tools">
      <h2>More Pokémon Go Tools</h2>
      <div class="related-links">
        <a href="/pokemon-type-calculator" class="related-link">Type Matchup Calculator</a>
        <a href="/pokemon-go-cp-calculator" class="related-link">Max CP Calculator</a>
        <a href="/damage-calculator" class="related-link">Damage Calculator</a>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ pokemonDataStr: JSON.stringify(pokemonData), faqDataStr: JSON.stringify(faqData) }}>
    const pData = JSON.parse(pokemonDataStr);
    const fData = JSON.parse(faqDataStr);

    document.addEventListener('DOMContentLoaded', () => {
      const calcBtn = document.getElementById('calculate-btn');
      const pokemonSelect = document.getElementById('pokemon-select');
      const cpInput = document.getElementById('cp-input');
      const resultSection = document.getElementById('result-section');

      const pkmError = document.getElementById('pokemon-error');
      const cpError = document.getElementById('cp-error');

      const tableBody = document.getElementById('multiplier-table-body');
      const faqContainer = document.getElementById('faq-list-container');

      // Populate Select
      pData.forEach(p => {
        const option = document.createElement('option');
        option.value = p.name;
        option.textContent = p.name + ' (to ' + p.evolves_to + ')';
        pokemonSelect.appendChild(option);
      });

      // Populate Table
      pData.slice(0, 50).forEach(p => {
        const tr = document.createElement('tr');

        const tdName = document.createElement('td');
        tdName.textContent = p.name;
        tr.appendChild(tdName);

        const tdEvolves = document.createElement('td');
        tdEvolves.textContent = p.evolves_to;
        tr.appendChild(tdEvolves);

        const tdMin = document.createElement('td');
        tdMin.textContent = p.cp_min + 'x';
        tr.appendChild(tdMin);

        const tdMax = document.createElement('td');
        tdMax.textContent = p.cp_max + 'x';
        tr.appendChild(tdMax);

        const tdCost = document.createElement('td');
        tdCost.textContent = p.cost;
        tr.appendChild(tdCost);

        tableBody.appendChild(tr);
      });

      // Populate FAQ
      fData.forEach(faq => {
        const div = document.createElement('div');
        div.className = 'faq-item';

        const h3 = document.createElement('h3');
        h3.textContent = faq.name;
        div.appendChild(h3);

        const p = document.createElement('p');
        p.textContent = faq.acceptedAnswer.text;
        div.appendChild(p);

        faqContainer.appendChild(div);
      });

      calcBtn.addEventListener('click', () => {
        // Reset errors
        pkmError.style.display = 'none';
        cpError.style.display = 'none';

        const selectedName = pokemonSelect.value;
        const cp = parseInt(cpInput.value, 10);

        let hasError = false;
        if (!selectedName) {
          pkmError.style.display = 'block';
          hasError = true;
        }
        if (isNaN(cp) || cp < 10 || cp > 5000) {
          cpError.style.display = 'block';
          hasError = true;
        }

        if (hasError) return;

        const pokemon = pData.find(p => p.name === selectedName);
        if (!pokemon) return;

        const minCp = Math.floor(cp * pokemon.cp_min);
        const maxCp = Math.floor(cp * pokemon.cp_max);

        // Update DOM
        document.getElementById('min-cp-result').textContent = minCp;
        document.getElementById('max-cp-result').textContent = maxCp;

        document.getElementById('chain-start').textContent = pokemon.name;
        document.getElementById('chain-end').textContent = pokemon.evolves_to;
        document.getElementById('candy-cost-val').textContent = pokemon.cost;

        // Update Chart
        const chartMax = Math.max(4000, maxCp + 500); // Dynamic scale
        document.getElementById('chart-max-label').textContent = chartMax;

        const minPercent = (minCp / chartMax) * 100;
        const rangePercent = ((maxCp - minCp) / chartMax) * 100;

        document.getElementById('chart-bar-min').style.width = `${minPercent}%`;
        document.getElementById('chart-bar-range').style.left = `${minPercent}%`;
        document.getElementById('chart-bar-range').style.width = `${rangePercent}%`;

        resultSection.style.display = 'block';

        // Smooth scroll to results
        resultSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });
  </script>
</SiteLayout>
