---
import SiteLayout from "../../../layouts/SiteLayout.astro";
---

<SiteLayout
  site="leeroyjenkins"
  title="Esports Prize Pool Rankings 2026"
  description="Track the biggest esports prize pools, top tournaments, and highest earning players across different games."
  canonical=""
>
  <style>
:root {
            --bg-color: #0a0b10;
            --card-bg: #111318;
            --border-color: #1e2030;
            --accent-color: #9333EA;
            --text-primary: #f3f4f6;
            --text-secondary: #9ca3af;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        /* Hero Section */
        header {
            padding: 4rem 0 3rem;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 3rem;
        }

        h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            background: linear-gradient(to right, #fff, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-desc {
            color: var(--text-secondary);
            font-size: 1.125rem;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .stat-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 0.75rem;
            padding: 1.5rem;
            text-align: center;
        }

        .stat-value {
            font-family: var(--font-mono);
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--accent-color);
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
        }

        /* Data Controls */
        .controls {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.5rem;
            justify-content: space-between;
            align-items: center;
        }

        .search-input {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            font-family: var(--font-ui);
            width: 100%;
            max-width: 300px;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .filter-select {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            font-family: var(--font-ui);
        }

        .filter-select:focus {
             outline: none;
             border-color: var(--accent-color);
        }

        /* Table Styles */
        .table-container {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 0.75rem;
            overflow-x: auto;
            margin-bottom: 4rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th, td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            white-space: nowrap;
        }

        th {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            cursor: pointer;
            user-select: none;
        }

        th:hover {
            color: var(--text-primary);
        }

        .sort-icon {
            display: inline-block;
            margin-left: 0.25rem;
            font-size: 0.75rem;
        }

        td {
            font-family: var(--font-mono);
            font-size: 0.875rem;
        }

        .col-game {
            font-family: var(--font-ui);
            font-weight: 600;
            color: var(--text-primary);
        }

        .col-genre {
            font-family: var(--font-ui);
            color: var(--text-secondary);
        }

        tbody tr:hover {
            background-color: rgba(255,255,255,0.02);
        }

        .col-money {
            color: #10b981; /* emerald-500 */
        }

        .empty-cell {
            color: var(--text-secondary);
            font-style: italic;
        }

        /* FAQ Section */
        .faq-section {
            margin-bottom: 4rem;
        }

        .section-title {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 2rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.75rem;
        }

        .faq-item {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            margin-bottom: 1rem;
            overflow: hidden;
        }

        .faq-question {
            padding: 1.25rem 1.5rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .faq-question:hover {
            background-color: rgba(255,255,255,0.02);
        }

        .faq-answer {
            padding: 0 1.5rem 1.25rem;
            color: var(--text-secondary);
            display: none;
            line-height: 1.6;
        }

        .faq-item.active .faq-answer {
            display: block;
        }

        .faq-icon {
            transition: transform 0.2s;
        }

        .faq-item.active .faq-icon {
            transform: rotate(45deg);
        }

        /* Methodology */
        .methodology {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 0.75rem;
            padding: 2rem;
            margin-bottom: 4rem;
        }

        .methodology h2 {
            margin-bottom: 1rem;
        }

        .methodology p, .methodology ul {
            color: var(--text-secondary);
            margin-bottom: 1rem;
        }

        .methodology ul {
            padding-left: 1.5rem;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        footer a {
            color: var(--accent-color);
            text-decoration: none;
        }

        footer a:hover {
            text-decoration: underline;
        }

        @media (max-width: 768px) {
            .controls {
                flex-direction: column;
                align-items: stretch;
            }
            .search-input {
                max-width: none;
            }
        }
  </style>

<div class="container">
        

        <div class="stats-grid" id="stats-container">
            <!-- Stats will be inserted here via JS -->
        </div>

        <div class="controls">
            <input type="text" id="searchInput" class="search-input" placeholder="Search games...">
            <select id="genreFilter" class="filter-select">
                <option value="All">All Genres</option>
                <!-- Options will be populated via JS -->
            </select>
        </div>

        <div class="table-container">
            <table id="dataTable">
                <thead>
                    <tr>
                        <th data-sort="game">Game <span class="sort-icon">↕</span></th>
                        <th data-sort="genre">Genre <span class="sort-icon">↕</span></th>
                        <th data-sort="totalPrizeUSD">Total Prize Pool <span class="sort-icon">↓</span></th>
                        <th data-sort="tournamentsCount">Tournaments <span class="sort-icon">↕</span></th>
                        <th data-sort="topPrizeUSD">Top Tournament Prize <span class="sort-icon">↕</span></th>
                        <th data-sort="topEarningsUSD">Top Player Earnings <span class="sort-icon">↕</span></th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- Data will be inserted here via JS -->
                </tbody>
            </table>
        </div>

        <section class="faq-section">
            <h2 class="section-title">Frequently Asked Questions</h2>
            <div id="faq-container">
                <!-- FAQs inserted via JS -->
            </div>
        </section>

        <section class="methodology">
            <h2 class="section-title">Methodology</h2>
            <p>This study analyzes the esports landscape by collecting public data on tournament prize pools. Our process involves:</p>
            <ul>
                <li>Aggregating data from reputable sources including Esports Earnings, Liquipedia, and official game tournament announcements.</li>
                <li>Normalizing currency to USD based on historical exchange rates at the time of the tournament.</li>
                <li>Categorizing games into standardized genres for comparative analysis.</li>
                <li>Identifying the single largest tournament prize pool and highest earning individual player for the top titles.</li>
            </ul>
            <p>Note: Data is subject to availability and public reporting. Top player earnings refer strictly to tournament prize winnings and do not include salaries, sponsorships, or streaming revenue.</p>
        </section>

        
    </div>

    <!-- Inline JSON Data -->
    

