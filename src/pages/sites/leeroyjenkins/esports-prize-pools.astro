  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
            // Load data
            const rawData = document.getElementById('esports-data').textContent;
            let esportsData = [];
            try {
                esportsData = JSON.parse(rawData);
            } catch (e) {
                console.error("Failed to parse data:", e);
                return;
            }

            // State
            let currentData = [...esportsData];
            let sortColumn = 'totalPrizeUSD';
            let sortDirection = 'desc';

            // DOM Elements
            const tableBody = document.getElementById('tableBody');
            const searchInput = document.getElementById('searchInput');
            const genreFilter = document.getElementById('genreFilter');
            const headers = document.querySelectorAll('th[data-sort]');

            // Formatting utilities
            const formatMoney = (amount) => {
                if (amount === null || amount === undefined) return '<span class="empty-cell">Data unavailable</span>';
                return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(amount);
            };

            const formatNumber = (num) => {
                if (num === null || num === undefined) return '<span class="empty-cell">N/A</span>';
                return new Intl.NumberFormat('en-US').format(num);
            };

            // Initialize Stats
            const initStats = () => {
                const totalPrizeMoney = esportsData.reduce((sum, game) => sum + (game.totalPrizeUSD || 0), 0);
                const totalTournaments = esportsData.reduce((sum, game) => sum + (game.tournamentsCount || 0), 0);

                // Find game with biggest single tournament
                let maxTournamentPrize = 0;
                let topTournamentGame = '';
                esportsData.forEach(game => {
                    if (game.topPrizeUSD && game.topPrizeUSD > maxTournamentPrize) {
                        maxTournamentPrize = game.topPrizeUSD;
                        topTournamentGame = game.game;
                    }
                });

                const statsHtml = `
                    <div class="stat-card">
                        <div class="stat-value">${formatMoney(totalPrizeMoney)}</div>
                        <div class="stat-label">Total Prize Money Tracked</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${formatNumber(esportsData.length)}</div>
                        <div class="stat-label">Games Analyzed</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${formatNumber(totalTournaments)}</div>
                        <div class="stat-label">Tournaments Recorded</div>
                    </div>
                `;
                document.getElementById('stats-container').innerHTML = statsHtml;
            };

            // Initialize Filters
            const initFilters = () => {
                const genres = new Set();
                esportsData.forEach(game => {
                    if (game.genre) genres.add(game.genre);
                });

                const sortedGenres = Array.from(genres).sort();
                sortedGenres.forEach(genre => {
                    const option = document.createElement('option');
                    option.value = genre;
                    option.textContent = genre;
                    genreFilter.appendChild(option);
                });
            };

            // Render Table
            const renderTable = () => {
                tableBody.innerHTML = '';

                if (currentData.length === 0) {
                    tableBody.innerHTML = `<tr><td colspan="6" style="text-align: center; padding: 2rem;">No games found matching criteria.</td></tr>`;
                    return;
                }

                currentData.forEach(game => {
                    const tr = document.createElement('tr');

                    let topPrizeCell = formatMoney(game.topPrizeUSD);
                    if (game.topTournament) topPrizeCell += ` <br><span style="font-size: 0.75rem; color: var(--text-secondary); font-family: var(--font-ui);">${game.topTournament}</span>`;

                    let topPlayerCell = formatMoney(game.topEarningsUSD);
                    if (game.topPlayer) topPlayerCell += ` <br><span style="font-size: 0.75rem; color: var(--text-secondary); font-family: var(--font-ui);">${game.topPlayer}</span>`;

                    tr.innerHTML = `
                        <td class="col-game">${game.game}</td>
                        <td class="col-genre">${game.genre || 'Various'}</td>
                        <td class="col-money">${formatMoney(game.totalPrizeUSD)}</td>
                        <td>${formatNumber(game.tournamentsCount)}</td>
                        <td>${topPrizeCell}</td>
                        <td>${topPlayerCell}</td>
                    `;
                    tableBody.appendChild(tr);
                });
            };

            // Sort logic
            const sortData = (column) => {
                if (sortColumn === column) {
                    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
                } else {
                    sortColumn = column;
                    sortDirection = 'desc'; // Default to desc for new column
                }

                // Update icons
                headers.forEach(th => {
                    const icon = th.querySelector('.sort-icon');
                    if (th.dataset.sort === sortColumn) {
                        icon.textContent = sortDirection === 'asc' ? '↑' : '↓';
                        th.style.color = 'var(--text-primary)';
                    } else {
                        icon.textContent = '↕';
                        th.style.color = '';
                    }
                });

                currentData.sort((a, b) => {
                    let valA = a[sortColumn];
                    let valB = b[sortColumn];

                    // Handle nulls
                    if (valA === null) valA = sortDirection === 'asc' ? Infinity : -Infinity;
                    if (valB === null) valB = sortDirection === 'asc' ? Infinity : -Infinity;

                    if (typeof valA === 'string') {
                        return sortDirection === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
                    } else {
                        return sortDirection === 'asc' ? valA - valB : valB - valA;
                    }
                });

                renderTable();
            };

            // Filter logic
            const applyFilters = () => {
                const searchTerm = searchInput.value.toLowerCase();
                const selectedGenre = genreFilter.value;

                currentData = esportsData.filter(game => {
                    const matchesSearch = game.game.toLowerCase().includes(searchTerm);
                    const matchesGenre = selectedGenre === 'All' || game.genre === selectedGenre;
                    return matchesSearch && matchesGenre;
                });

                // Re-sort after filtering
                const tempSort = sortColumn;
                const tempDir = sortDirection;
                sortColumn = ''; // Force sort to run
                sortDirection = tempDir === 'asc' ? 'desc' : 'asc'; // invert so it sets back
                sortData(tempSort);
            };

            // Event Listeners
            headers.forEach(th => {
                th.addEventListener('click', () => sortData(th.dataset.sort));
            });

            searchInput.addEventListener('input', applyFilters);
            genreFilter.addEventListener('change', applyFilters);

            // FAQ Logic
            const faqs = [
                {
                    q: "Which esports game has the highest total prize pool?",
                    a: `Based on our current data, the game with the highest total historical prize pool is typically a major title in the MOBA or Battle Royale genre. You can see the exact top game by sorting the table above by "Total Prize Pool".`
                },
                {
                    q: "What is the biggest single esports tournament prize pool ever?",
                    a: "Dota 2's 'The International 2021' currently holds the record for the largest single tournament prize pool in esports history, surpassing $40 million."
                },
                {
                    q: "Do players keep all their prize money?",
                    a: "No. While the figures shown represent the total winnings attributed to players or teams, in professional esports, organizations usually take a percentage cut of tournament winnings (often between 10-20%, though it varies by contract). Additionally, taxes apply."
                },
                {
                    q: "Which esports genre is the most lucrative?",
                    a: "MOBAs (Multiplayer Online Battle Arenas) and Battle Royales consistently feature the largest overall prize pools, driven by massive player bases and developer-funded tournament circuits."
                },
                {
                    q: "How often is this data updated?",
                    a: "This is a static research study representing a snapshot of the esports landscape for 2026. The data is based on historical tournament payouts up to the time of data collection."
                }
            ];

            const renderFaqs = () => {
                const faqContainer = document.getElementById('faq-container');
                faqs.forEach((faq, index) => {
                    const item = document.createElement('div');
                    item.className = 'faq-item';
                    item.innerHTML = `
                        <div class="faq-question">
                            <span>${faq.q}</span>
                            <span class="faq-icon">+</span>
                        </div>
                        <div class="faq-answer">${faq.a}</div>
                    `;

                    item.querySelector('.faq-question').addEventListener('click', () => {
                        const isActive = item.classList.contains('active');
                        // Close all
                        document.querySelectorAll('.faq-item').forEach(el => {
                            el.classList.remove('active');
                            el.querySelector('.faq-icon').textContent = '+';
                        });
                        // Open clicked if it wasn't active
                        if (!isActive) {
                            item.classList.add('active');
                            item.querySelector('.faq-icon').textContent = '×';
                        }
                    });

                    faqContainer.appendChild(item);
                });
            };

            // Setup JSON-LD
            const setupJsonLd = () => {
                const schema = {
                    "@context": "https://schema.org",
                    "@graph": [
                        {
                            "@type": "Article",
                            "headline": "Esports Prize Pool Rankings 2026",
                            "description": "An in-depth analysis of the highest-paying esports games.",
                            "author": {
                                "@type": "Organization",
                                "name": "leeroyjenkins.quest"
                            },
                            "publisher": {
                                "@type": "Organization",
                                "name": "GAB Ventures"
                            }
                        },
                        {
                            "@type": "FAQPage",
                            "mainEntity": faqs.map(f => ({
                                "@type": "Question",
                                "name": f.q,
                                "acceptedAnswer": {
                                    "@type": "Answer",
                                    "text": f.a
                                }
                            }))
                        }
                    ]
                };

                const script = document.createElement('script');
                script.type = 'application/ld+json';
                script.textContent = JSON.stringify(schema);
                document.head.appendChild(script);
            };

            // Initialize
            initStats();
            initFilters();
            sortData('totalPrizeUSD'); // Initial sort and render
            renderFaqs();
            setupJsonLd();
        });
  </script>
</SiteLayout>
