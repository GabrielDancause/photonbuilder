---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "What is a keyboard tester and why should I use one?",
    a: "A keyboard tester is an online tool that detects and displays every key press on a visual keyboard layout. It helps you verify that all keys on your keyboard are working correctly, which is especially useful when buying a used keyboard, troubleshooting unresponsive keys, or testing a new mechanical keyboard. This tool shows the keycode, key name, and location for each press, plus tracks your typing heatmap and tests N-key rollover."
  },
  {
    q: "What is N-key rollover (NKRO) and why does it matter?",
    a: "N-key rollover (NKRO) refers to how many keys your keyboard can register simultaneously. A keyboard with full NKRO can detect every key pressed at the same time, no matter how many that is. This matters for gaming, where you might press W + A + Shift + Space + Ctrl simultaneously. Cheaper membrane keyboards often only support 2-3 key rollover (called 2KRO or 3KRO), meaning extra simultaneous presses get dropped — this is called 'ghosting'. Most mechanical keyboards support 6KRO over USB or full NKRO."
  },
  {
    q: "Why are some of my keys not registering?",
    a: "If keys aren't registering in this tester, there are several possible causes: 1) Your keyboard has limited rollover — try pressing fewer keys simultaneously. 2) The key switch is physically broken or has debris underneath — try removing the keycap and cleaning it. 3) Your keyboard's USB connection is intermittent — try a different port or cable. 4) Software conflicts — some keyboards have Fn-lock modes or driver issues. 5) Browser limitations — certain key combinations (like Ctrl+W) are intercepted by the browser before they reach the page."
  },
  {
    q: "What are keycodes and why do different keyboards show different values?",
    a: "Keycodes are numeric identifiers the browser assigns to each key press. The 'key' property gives the readable character (like 'a' or 'Enter'), while 'keyCode' gives the legacy numeric code (like 65 for 'A'). The 'code' property identifies the physical key location (like 'KeyA') regardless of keyboard layout. Different keyboards may show different values because of layout differences (QWERTY vs AZERTY vs Dvorak), regional variations, or custom firmware that remaps keys."
  },
  {
    q: "How does the typing heatmap work?",
    a: "The typing heatmap color-codes each key based on how many times you've pressed it during your current session. Keys you haven't pressed stay their default color. As you press keys more frequently, they shift from blue (cool, few presses) through yellow to red (hot, many presses). This visualization helps you understand your typing patterns, identify which keys you use most, and can be useful for optimizing custom keybind layouts in games."
  },
  {
    q: "Can this tool detect if a key is stuck?",
    a: "Yes. This keyboard tester includes a stuck key detector that monitors how long each key is held down. If a key appears to be held for more than 3 seconds without being released, a warning will appear. Stuck keys can be caused by physical debris under the switch, a broken spring in a mechanical switch, liquid damage, or software-level key repeat issues. If you see a stuck key warning, try pressing the key firmly to unstick it, or remove the keycap to inspect the switch."
  },
  {
    q: "Does this keyboard tester work with any keyboard layout?",
    a: "This tool works with any keyboard that connects to your computer, including QWERTY, AZERTY, Dvorak, and other layouts. The visual keyboard shows a standard US QWERTY layout for reference, but key detection works regardless of your physical layout. The 'code' value shown for each press identifies the physical key position, while the 'key' value shows the character your OS maps to that position. This means the highlighted key on the visual layout always matches the physical position you pressed."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Keyboard Tester — Free Online Key Test & Checker",
    "description": "Free online keyboard tester. Press any key to test it. Visual keyboard layout, key event details, N-key rollover test, typing heatmap, and stuck key detection.",
    "applicationCategory": "Utility",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Keyboard Tester — Free Online Key Test & Checker",
  description: "Test every key on your keyboard online. Visual layout, keycodes, N-key rollover test, typing heatmap, and stuck key detection. Free, no download.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Keyboard Tester — Free Online Key Test & Checker"
  description="Test every key on your keyboard online. Visual layout, keycodes, N-key rollover test, typing heatmap, and stuck key detection. Free, no download."
  canonical="https://leeroyjenkins.quest/keyboard-tester"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(147,51,234,0.08);border:1px solid rgba(147,51,234,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      ⌨️ <strong style="color:#9333EA;">6-key rollover (6KRO) keyboards ghost inputs when you press 7+ keys — fatal in games like Starcraft or MMOs.</strong> N-key rollover (NKRO) registers every key simultaneously. Test your keyboard's actual rollover, detect stuck keys, and see your typing heatmap. <a href="https://gab.ae/news/ps5-price-hike-pc-gaming-bottleneck-2026" style="color:#9333EA;">Why hardware testing matters →</a>
    </div>
    <div class="hero">
      <h1>Keyboard Tester</h1>
      <p>Press any key to test it. Every key lights up on the visual keyboard. Check keycodes, test N-key rollover, see your typing heatmap, and detect stuck keys.</p>
    </div>

    <section class="content-section">
      <!-- Info Panel -->
      <div class="info-panel" id="info-panel">
        <div class="info-prompt" id="info-prompt">Press any key to begin...</div>
        <div class="info-grid" id="info-grid" style="display:none;">
          <div class="info-item"><span class="info-label">Key</span><span class="info-value" id="info-key">—</span></div>
          <div class="info-item"><span class="info-label">Code</span><span class="info-value" id="info-code">—</span></div>
          <div class="info-item"><span class="info-label">keyCode</span><span class="info-value" id="info-keycode">—</span></div>
          <div class="info-item"><span class="info-label">Location</span><span class="info-value" id="info-location">—</span></div>
        </div>
      </div>

      <!-- Stuck Key Warning -->
      <div class="stuck-warning" id="stuck-warning" style="display:none;">
        <span class="stuck-icon">⚠</span>
        <span>Stuck key detected: <strong id="stuck-key-name"></strong> — held for over 3 seconds</span>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-card">
          <span class="stat-value" id="stat-total">0</span>
          <span class="stat-label">Total Pressed</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-unique">0</span>
          <span class="stat-label">Unique Keys</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-held">0</span>
          <span class="stat-label">Held Now</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-max-rollover">0</span>
          <span class="stat-label">Max Rollover</span>
        </div>
      </div>

      <!-- Visual Keyboard -->
      <div class="keyboard-wrapper" id="keyboard"></div>

      <!-- Heatmap Legend + Controls -->
      <div class="controls-row">
        <div class="heatmap-legend">
          <span class="legend-label">Heatmap:</span>
          <span class="legend-cold">Cold</span>
          <div class="legend-gradient"></div>
          <span class="legend-hot">Hot</span>
        </div>
        <button class="btn btn-primary" id="reset-btn">Reset All</button>
      </div>

      <!-- N-Key Rollover Test -->
      <h2>N-Key Rollover Test</h2>
      <p>Press and hold multiple keys simultaneously. All detected keys appear below. If a key you're pressing doesn't show up, your keyboard is ghosting that combination.</p>
      <div class="ghost-panel" id="ghost-panel">
        <div class="ghost-prompt" id="ghost-prompt">Hold multiple keys to test...</div>
        <div class="ghost-keys" id="ghost-keys"></div>
        <div class="ghost-count" id="ghost-count"></div>
      </div>

      <!-- Key History -->
      <h2>Key History</h2>
      <p>Last 20 key presses with timestamps, most recent first.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Key</th>
              <th>Code</th>
              <th>keyCode</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody id="history-body">
            <tr><td colspan="5" style="text-align:center;color:var(--text-secondary);padding:1rem;">No keys pressed yet</td></tr>
          </tbody>
        </table>
      </div>

      <!-- How to Use -->
      <h2>How to Use This Keyboard Tester</h2>
      <ul>
        <li><strong>Test individual keys:</strong> Press any key and watch it light up on the visual keyboard. The info panel shows the key name, code, keyCode, and physical location (left, right, numpad, or standard).</li>
        <li><strong>Check for broken keys:</strong> Press every key one by one. The "Unique Keys" counter tracks how many distinct keys you've tested. Aim to match your keyboard's total key count.</li>
        <li><strong>Test N-key rollover:</strong> Hold multiple keys at once (try WASD + Shift + Space). The rollover panel shows every key the computer detects simultaneously. Missing keys mean ghosting.</li>
        <li><strong>Read the heatmap:</strong> As you type, keys shift from blue (few presses) through yellow to red (many presses), showing your most-used keys at a glance.</li>
        <li><strong>Detect stuck keys:</strong> If any key stays held for over 3 seconds, a warning banner appears. This helps identify physically stuck switches or software-level repeat issues.</li>
      </ul>

      <!-- Rollover Reference -->
      <h2>Keyboard Rollover Benchmarks</h2>
      <p>How many simultaneous key presses does your keyboard support? Here's what to expect from different keyboard types.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Keyboard Type</th>
              <th>Typical Rollover</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Budget Membrane</strong></td><td>2-3 KRO</td><td>Most basic keyboards. May ghost with 3+ keys held. Fine for typing, problematic for gaming.</td></tr>
            <tr><td><strong>Laptop Built-in</strong></td><td>3-4 KRO</td><td>Varies widely by model. Gaming laptops often support 5-6 KRO on WASD clusters.</td></tr>
            <tr><td><strong>Gaming Membrane</strong></td><td>6 KRO (anti-ghosting zones)</td><td>Enhanced matrix in WASD/gaming zones. Full rollover in other areas may be limited.</td></tr>
            <tr><td><strong>Mechanical (USB)</strong></td><td>6 KRO / Full NKRO</td><td>USB protocol defaults to 6KRO. Most support full NKRO mode via firmware toggle.</td></tr>
            <tr><td><strong>Mechanical (PS/2)</strong></td><td>Full NKRO</td><td>PS/2 protocol natively supports unlimited simultaneous keys. Rare on modern boards.</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Key Code Reference -->
      <h2>Common Key Codes Reference</h2>
      <p>Quick reference for commonly used JavaScript key codes and their corresponding values.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Key</th>
              <th>keyCode</th>
              <th>code</th>
              <th>key value</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Enter</strong></td><td>13</td><td>Enter</td><td>Enter</td></tr>
            <tr><td><strong>Space</strong></td><td>32</td><td>Space</td><td>" " (space)</td></tr>
            <tr><td><strong>Escape</strong></td><td>27</td><td>Escape</td><td>Escape</td></tr>
            <tr><td><strong>Tab</strong></td><td>9</td><td>Tab</td><td>Tab</td></tr>
            <tr><td><strong>Shift (Left)</strong></td><td>16</td><td>ShiftLeft</td><td>Shift</td></tr>
            <tr><td><strong>Ctrl (Left)</strong></td><td>17</td><td>ControlLeft</td><td>Control</td></tr>
            <tr><td><strong>Alt (Left)</strong></td><td>18</td><td>AltLeft</td><td>Alt</td></tr>
            <tr><td><strong>Arrow Up</strong></td><td>38</td><td>ArrowUp</td><td>ArrowUp</td></tr>
            <tr><td><strong>Arrow Down</strong></td><td>40</td><td>ArrowDown</td><td>ArrowDown</td></tr>
            <tr><td><strong>A</strong></td><td>65</td><td>KeyA</td><td>a</td></tr>
            <tr><td><strong>0</strong></td><td>48</td><td>Digit0</td><td>0</td></tr>
            <tr><td><strong>F1</strong></td><td>112</td><td>F1</td><td>F1</td></tr>
          </tbody>
        </table>
      </div>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/aim-trainer" class="related-link">
          <strong>Aim Trainer</strong>
          <span>Practice your FPS aim with multiple game modes and accuracy tracking</span>
        </a>
        <a href="/best-gaming-keyboard" class="related-link">
          <strong>Best Gaming Keyboard 2026</strong>
          <span>Top mechanical keyboards ranked by switches, build quality, and features</span>
        </a>
        <a href="/reaction-time-test" class="related-link">
          <strong>Reaction Time Test</strong>
          <span>Measure your reaction speed in milliseconds and compare to pro gamers</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ── Keyboard Layout Definition ── */
    var ROWS = [
      [
        {c:'Escape',l:'Esc',w:1},{c:'',w:0.5},
        {c:'F1',l:'F1',w:1},{c:'F2',l:'F2',w:1},{c:'F3',l:'F3',w:1},{c:'F4',l:'F4',w:1},{c:'',w:0.25},
        {c:'F5',l:'F5',w:1},{c:'F6',l:'F6',w:1},{c:'F7',l:'F7',w:1},{c:'F8',l:'F8',w:1},{c:'',w:0.25},
        {c:'F9',l:'F9',w:1},{c:'F10',l:'F10',w:1},{c:'F11',l:'F11',w:1},{c:'F12',l:'F12',w:1},{c:'',w:0.25},
        {c:'PrintScreen',l:'PrtSc',w:1},{c:'ScrollLock',l:'ScrLk',w:1},{c:'Pause',l:'Pause',w:1}
      ],
      [
        {c:'Backquote',l:'`',w:1},{c:'Digit1',l:'1',w:1},{c:'Digit2',l:'2',w:1},{c:'Digit3',l:'3',w:1},
        {c:'Digit4',l:'4',w:1},{c:'Digit5',l:'5',w:1},{c:'Digit6',l:'6',w:1},{c:'Digit7',l:'7',w:1},
        {c:'Digit8',l:'8',w:1},{c:'Digit9',l:'9',w:1},{c:'Digit0',l:'0',w:1},
        {c:'Minus',l:'-',w:1},{c:'Equal',l:'=',w:1},{c:'Backspace',l:'Bksp',w:2},{c:'',w:0.25},
        {c:'Insert',l:'Ins',w:1},{c:'Home',l:'Home',w:1},{c:'PageUp',l:'PgUp',w:1},{c:'',w:0.25},
        {c:'NumLock',l:'Num',w:1},{c:'NumpadDivide',l:'/',w:1},{c:'NumpadMultiply',l:'*',w:1},{c:'NumpadSubtract',l:'-',w:1}
      ],
      [
        {c:'Tab',l:'Tab',w:1.5},{c:'KeyQ',l:'Q',w:1},{c:'KeyW',l:'W',w:1},{c:'KeyE',l:'E',w:1},
        {c:'KeyR',l:'R',w:1},{c:'KeyT',l:'T',w:1},{c:'KeyY',l:'Y',w:1},{c:'KeyU',l:'U',w:1},
        {c:'KeyI',l:'I',w:1},{c:'KeyO',l:'O',w:1},{c:'KeyP',l:'P',w:1},
        {c:'BracketLeft',l:'[',w:1},{c:'BracketRight',l:']',w:1},{c:'Backslash',l:'\\',w:1.5},{c:'',w:0.25},
        {c:'Delete',l:'Del',w:1},{c:'End',l:'End',w:1},{c:'PageDown',l:'PgDn',w:1},{c:'',w:0.25},
        {c:'Numpad7',l:'7',w:1},{c:'Numpad8',l:'8',w:1},{c:'Numpad9',l:'9',w:1},{c:'NumpadAdd',l:'+',w:1,h:2}
      ],
      [
        {c:'CapsLock',l:'Caps',w:1.75},{c:'KeyA',l:'A',w:1},{c:'KeyS',l:'S',w:1},{c:'KeyD',l:'D',w:1},
        {c:'KeyF',l:'F',w:1},{c:'KeyG',l:'G',w:1},{c:'KeyH',l:'H',w:1},{c:'KeyJ',l:'J',w:1},
        {c:'KeyK',l:'K',w:1},{c:'KeyL',l:'L',w:1},{c:'Semicolon',l:';',w:1},
        {c:'Quote',l:"'",w:1},{c:'Enter',l:'Enter',w:2.25},{c:'',w:3.5},
        {c:'Numpad4',l:'4',w:1},{c:'Numpad5',l:'5',w:1},{c:'Numpad6',l:'6',w:1}
      ],
      [
        {c:'ShiftLeft',l:'Shift',w:2.25},{c:'KeyZ',l:'Z',w:1},{c:'KeyX',l:'X',w:1},{c:'KeyC',l:'C',w:1},
        {c:'KeyV',l:'V',w:1},{c:'KeyB',l:'B',w:1},{c:'KeyN',l:'N',w:1},{c:'KeyM',l:'M',w:1},
        {c:'Comma',l:',',w:1},{c:'Period',l:'.',w:1},{c:'Slash',l:'/',w:1},
        {c:'ShiftRight',l:'Shift',w:2.75},{c:'',w:1.25},
        {c:'ArrowUp',l:'\u2191',w:1},{c:'',w:1.25},
        {c:'Numpad1',l:'1',w:1},{c:'Numpad2',l:'2',w:1},{c:'Numpad3',l:'3',w:1},{c:'NumpadEnter',l:'Ent',w:1,h:2}
      ],
      [
        {c:'ControlLeft',l:'Ctrl',w:1.25},{c:'MetaLeft',l:'Win',w:1.25},{c:'AltLeft',l:'Alt',w:1.25},
        {c:'Space',l:'Space',w:6.25},
        {c:'AltRight',l:'Alt',w:1.25},{c:'MetaRight',l:'Win',w:1.25},{c:'ContextMenu',l:'Menu',w:1.25},{c:'ControlRight',l:'Ctrl',w:1.25},{c:'',w:0.25},
        {c:'ArrowLeft',l:'\u2190',w:1},{c:'ArrowDown',l:'\u2193',w:1},{c:'ArrowRight',l:'\u2192',w:1},{c:'',w:0.25},
        {c:'Numpad0',l:'0',w:2},{c:'NumpadDecimal',l:'.',w:1}
      ]
    ];

    /* ── State ── */
    var hitCounts = {};
    var heldNow = {};
    var totalPresses = 0;
    var maxRollover = 0;
    var history = [];
    var keyElements = {};
    var stuckTimers = {};
    var stuckKeys = {};

    /* ── Build Keyboard ── */
    var kb = document.getElementById('keyboard');
    var UNIT = 48;
    var GAP = 3;

    ROWS.forEach(function(row) {
      var rowDiv = document.createElement('div');
      rowDiv.className = 'kb-row';
      row.forEach(function(k) {
        if (!k.c) {
          var spacer = document.createElement('div');
          spacer.className = 'kb-spacer';
          spacer.style.width = (k.w * UNIT + (k.w > 0.5 ? GAP * (k.w - 1) : 0)) + 'px';
          rowDiv.appendChild(spacer);
          return;
        }
        var key = document.createElement('div');
        key.className = 'kb-key';
        key.setAttribute('data-code', k.c);
        key.style.width = (k.w * UNIT + GAP * (k.w - 1)) + 'px';
        if (k.h === 2) {
          key.style.height = (2 * UNIT + GAP) + 'px';
          key.classList.add('kb-key-tall');
        }
        key.innerHTML = '<span>' + k.l + '</span>';
        rowDiv.appendChild(key);
        keyElements[k.c] = key;
      });
      kb.appendChild(rowDiv);
    });

    /* ── DOM Refs ── */
    var infoPrompt = document.getElementById('info-prompt');
    var infoGrid = document.getElementById('info-grid');
    var infoKey = document.getElementById('info-key');
    var infoCode = document.getElementById('info-code');
    var infoKeycode = document.getElementById('info-keycode');
    var infoLocation = document.getElementById('info-location');
    var statTotal = document.getElementById('stat-total');
    var statUnique = document.getElementById('stat-unique');
    var statHeld = document.getElementById('stat-held');
    var statMaxRollover = document.getElementById('stat-max-rollover');
    var ghostPrompt = document.getElementById('ghost-prompt');
    var ghostKeys = document.getElementById('ghost-keys');
    var ghostCount = document.getElementById('ghost-count');
    var historyBody = document.getElementById('history-body');
    var stuckWarning = document.getElementById('stuck-warning');
    var stuckKeyNameEl = document.getElementById('stuck-key-name');

    var LOC_NAMES = { 0: 'Standard', 1: 'Left', 2: 'Right', 3: 'Numpad' };

    /* ── Heatmap ── */
    function getHeatColor(count) {
      if (count <= 0) return '';
      var vals = Object.values(hitCounts);
      var maxH = Math.max.apply(null, vals.length ? vals : [1]);
      if (maxH <= 0) return '';
      var t = Math.min(count / maxH, 1);
      var r, g, b;
      if (t < 0.5) {
        var s = t * 2;
        r = Math.round(60 + 195 * s);
        g = Math.round(120 + 135 * s);
        b = Math.round(220 - 180 * s);
      } else {
        var s2 = (t - 0.5) * 2;
        r = 255;
        g = Math.round(255 - 200 * s2);
        b = Math.round(40 - 40 * s2);
      }
      return 'rgb(' + r + ',' + g + ',' + b + ')';
    }

    function applyHeatmap() {
      Object.keys(keyElements).forEach(function(code) {
        var el = keyElements[code];
        if (el.classList.contains('kb-active')) return;
        var count = hitCounts[code] || 0;
        if (count > 0) {
          el.style.backgroundColor = getHeatColor(count);
          el.style.color = '#fff';
          el.style.borderColor = 'rgba(255,255,255,0.15)';
        }
      });
    }

    function updateStats() {
      statTotal.textContent = totalPresses;
      statUnique.textContent = Object.keys(hitCounts).length;
      var heldCount = Object.keys(heldNow).length;
      statHeld.textContent = heldCount;
      statMaxRollover.textContent = maxRollover;
    }

    function updateGhost() {
      var keys = Object.keys(heldNow);
      if (keys.length === 0) {
        ghostKeys.innerHTML = '';
        ghostCount.textContent = '';
        ghostPrompt.style.display = '';
        return;
      }
      ghostPrompt.style.display = 'none';
      ghostKeys.innerHTML = keys.map(function(c) {
        return '<span class="ghost-tag">' + escHtml(c) + '</span>';
      }).join('');
      ghostCount.textContent = keys.length + ' key' + (keys.length !== 1 ? 's' : '') + ' detected simultaneously';
    }

    function addHistory(e) {
      var now = new Date();
      var ts = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' }) + '.' + String(now.getMilliseconds()).padStart(3, '0');
      history.unshift({ key: e.key, code: e.code, keyCode: e.keyCode, time: ts });
      if (history.length > 20) history.length = 20;
      historyBody.innerHTML = history.map(function(h, i) {
        var dk = h.key === ' ' ? 'Space' : h.key;
        return '<tr><td>' + (i + 1) + '</td><td><strong>' + escHtml(dk) + '</strong></td><td>' + escHtml(h.code) + '</td><td>' + h.keyCode + '</td><td>' + h.time + '</td></tr>';
      }).join('');
    }

    function escHtml(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    /* ── Key Events ── */
    document.addEventListener('keydown', function(e) {
      e.preventDefault();
      var code = e.code;

      /* Info panel */
      infoPrompt.style.display = 'none';
      infoGrid.style.display = '';
      infoKey.textContent = e.key === ' ' ? 'Space' : e.key;
      infoCode.textContent = code;
      infoKeycode.textContent = e.keyCode;
      infoLocation.textContent = LOC_NAMES[e.location] || e.location;

      /* Highlight */
      if (keyElements[code]) {
        keyElements[code].classList.add('kb-active');
        keyElements[code].classList.add('kb-pressed');
        keyElements[code].style.backgroundColor = '';
        keyElements[code].style.color = '';
        keyElements[code].style.borderColor = '';
      }

      /* Track */
      if (!heldNow[code]) {
        heldNow[code] = Date.now();
        totalPresses++;
        hitCounts[code] = (hitCounts[code] || 0) + 1;
        addHistory(e);

        /* Stuck key timer */
        if (stuckTimers[code]) clearTimeout(stuckTimers[code]);
        stuckTimers[code] = setTimeout(function() {
          stuckKeys[code] = true;
          stuckKeyNameEl.textContent = code;
          stuckWarning.style.display = 'flex';
        }, 3000);
      }

      /* Rollover */
      var heldCount = Object.keys(heldNow).length;
      if (heldCount > maxRollover) maxRollover = heldCount;

      updateStats();
      updateGhost();
    });

    document.addEventListener('keyup', function(e) {
      e.preventDefault();
      var code = e.code;

      if (keyElements[code]) {
        keyElements[code].classList.remove('kb-active');
      }

      delete heldNow[code];

      /* Clear stuck timer */
      if (stuckTimers[code]) {
        clearTimeout(stuckTimers[code]);
        delete stuckTimers[code];
      }
      delete stuckKeys[code];
      if (Object.keys(stuckKeys).length === 0) {
        stuckWarning.style.display = 'none';
      }

      updateStats();
      updateGhost();
      applyHeatmap();
    });

    /* Handle window blur — clear held state */
    window.addEventListener('blur', function() {
      Object.keys(heldNow).forEach(function(code) {
        if (keyElements[code]) keyElements[code].classList.remove('kb-active');
        if (stuckTimers[code]) clearTimeout(stuckTimers[code]);
      });
      heldNow = {};
      stuckTimers = {};
      stuckKeys = {};
      stuckWarning.style.display = 'none';
      updateStats();
      updateGhost();
      applyHeatmap();
    });

    /* ── Reset ── */
    document.getElementById('reset-btn').addEventListener('click', function() {
      hitCounts = {};
      heldNow = {};
      totalPresses = 0;
      maxRollover = 0;
      history = [];
      stuckKeys = {};
      Object.keys(stuckTimers).forEach(function(k) { clearTimeout(stuckTimers[k]); });
      stuckTimers = {};

      Object.values(keyElements).forEach(function(el) {
        el.classList.remove('kb-active', 'kb-pressed');
        el.style.backgroundColor = '';
        el.style.color = '';
        el.style.borderColor = '';
      });

      infoPrompt.style.display = '';
      infoGrid.style.display = 'none';
      stuckWarning.style.display = 'none';
      historyBody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text-secondary);padding:1rem;">No keys pressed yet</td></tr>';
      updateStats();
      updateGhost();
    });

    updateStats();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }
    code { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.15rem 0.4rem; font-size: 0.85em; color: var(--accent-color); }

    /* Info Panel */
    .info-panel { background: var(--card-bg); border: 2px solid var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; margin-bottom: 1rem; min-height: 80px; display: flex; align-items: center; justify-content: center; transition: border-color 0.2s; }
    .info-prompt { color: var(--text-secondary); font-size: 1.1rem; }
    .info-grid { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
    .info-item { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
    .info-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary); font-weight: 600; }
    .info-value { font-size: 1.2rem; font-weight: 800; color: var(--text-primary); font-family: monospace; background: var(--border-color); padding: 0.2rem 0.6rem; border-radius: 6px; min-width: 60px; text-align: center; }

    /* Stuck Warning */
    .stuck-warning { display: flex; align-items: center; gap: 0.5rem; background: #b71c1c; color: #fff; padding: 0.6rem 1rem; border-radius: 8px; font-size: 0.9rem; font-weight: 600; margin-bottom: 1rem; animation: pulse-warn 1s infinite; }
    .stuck-icon { font-size: 1.2rem; }
    @keyframes pulse-warn { 0%,100% { opacity: 1; } 50% { opacity: 0.75; } }

    /* Stats */
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-bottom: 1rem; }
    .stat-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem; text-align: center; display: flex; flex-direction: column; gap: 0.2rem; }
    .stat-value { font-size: 1.8rem; font-weight: 900; color: var(--text-primary); line-height: 1.1; }
    .stat-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; }

    /* Keyboard */
    .keyboard-wrapper { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 12px; overflow-x: auto; margin-bottom: 1rem; }
    .kb-row { display: flex; gap: 3px; margin-bottom: 3px; align-items: flex-start; }
    .kb-row:last-child { margin-bottom: 0; }
    .kb-key { height: 48px; background: var(--border-color); border: 1px solid rgba(255,255,255,0.06); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 700; color: var(--text-secondary); user-select: none; -webkit-user-select: none; transition: background 0.1s, transform 0.08s, box-shadow 0.1s; flex-shrink: 0; position: relative; cursor: default; }
    .kb-key span { pointer-events: none; text-align: center; line-height: 1.2; }
    .kb-key-tall { position: relative; }
    .kb-spacer { flex-shrink: 0; }

    .kb-key.kb-active { background: var(--accent-color) !important; color: #fff !important; transform: scale(0.95); box-shadow: 0 0 12px color-mix(in srgb, var(--accent-color) 50%, transparent); border-color: var(--accent-color) !important; }
    .kb-key.kb-pressed { border-color: rgba(255,255,255,0.15); }

    /* Controls Row */
    .controls-row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1rem; }
    .heatmap-legend { display: flex; align-items: center; gap: 0.4rem; }
    .legend-label { font-size: 0.8rem; color: var(--text-secondary); font-weight: 700; }
    .legend-cold, .legend-hot { font-size: 0.7rem; color: var(--text-secondary); font-weight: 600; }
    .legend-gradient { width: 120px; height: 12px; border-radius: 3px; background: linear-gradient(90deg, #3c78dc, #ffdb4a, #ff3300); }

    /* Anti-ghosting / Rollover */
    .ghost-panel { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; min-height: 80px; }
    .ghost-prompt { color: var(--text-secondary); font-size: 0.95rem; }
    .ghost-keys { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 0.5rem; }
    .ghost-tag { background: var(--accent-color); color: #fff; padding: 0.3rem 0.7rem; border-radius: 6px; font-size: 0.8rem; font-weight: 700; font-family: monospace; }
    .ghost-count { font-size: 0.85rem; color: var(--text-secondary); font-weight: 600; }

    /* Buttons */
    .btn { padding: 0.45rem 0.9rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn-primary { background: var(--accent-color); color: #fff; border-color: var(--accent-color); padding: 0.6rem 1.6rem; font-size: 1rem; }
    .btn-primary:hover { opacity: 0.9; }

    /* Table */
    .table-wrapper { overflow-x: auto; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.65rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.55rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    /* Related */
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .related-link { display: flex; flex-direction: column; gap: 0.3rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem; text-decoration: none; transition: border-color 0.2s; }
    .related-link:hover { border-color: var(--accent-color); text-decoration: none; }
    .related-link strong { color: var(--text-primary); font-size: 1rem; }
    .related-link span { color: var(--text-secondary); font-size: 0.85rem; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .stats-row { grid-template-columns: repeat(2, 1fr); }
      .info-grid { gap: 0.8rem; }
      .info-value { font-size: 1rem; min-width: 50px; }
      .kb-key { height: 36px; font-size: 0.5rem; }
      .keyboard-wrapper { padding: 6px; }
      .controls-row { flex-direction: column; align-items: stretch; }
    }
  </style>
</SiteLayout>
