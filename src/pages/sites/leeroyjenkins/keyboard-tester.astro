---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "What is keyboard ghosting?",
    a: "Keyboard ghosting occurs when you press multiple keys simultaneously but some key presses aren't registered by the computer. This happens because most budget keyboards use a matrix circuit design where certain key combinations share electrical pathways. When too many keys on the same circuit are pressed at once, the keyboard can't distinguish which keys are actually being pressed. This is a hardware limitation — no software can fix it. Gaming keyboards with N-key rollover (NKRO) eliminate ghosting entirely by giving each key its own independent circuit."
  },
  {
    q: "What is N-key rollover (NKRO)?",
    a: "N-key rollover means the keyboard can correctly detect any number of simultaneously pressed keys. The 'N' stands for any number. A keyboard with 6-key rollover (6KRO) can handle up to 6 simultaneous key presses — which is the USB standard minimum. Full NKRO keyboards, typically mechanical ones, can register all 104+ keys pressed at the same time. For gaming, 6KRO is usually sufficient since you rarely press more than 6 keys at once. But for anti-ghosting peace of mind, NKRO is the gold standard."
  },
  {
    q: "What's the difference between keyCode, key, and code?",
    a: "These are three different JavaScript properties for identifying key presses. 'key' returns the character or action produced (like 'a', 'Enter', 'Shift') and changes based on your keyboard layout and modifier keys. 'code' returns the physical key location on the keyboard (like 'KeyA', 'Enter', 'ShiftLeft') and stays the same regardless of layout — so a QWERTY 'A' and AZERTY 'Q' both return 'KeyA'. 'keyCode' is a legacy numeric code (deprecated but still widely used) where each key has a number like 65 for 'A'. Modern web apps should use 'key' or 'code' instead of 'keyCode'."
  },
  {
    q: "Why do some keys not register in the browser?",
    a: "Certain keys are intercepted by the operating system or browser before they reach the web page. Common examples include: F11 (fullscreen toggle), Alt+F4 (close window), Ctrl+W (close tab), Print Screen (screenshot), and the Windows/Command key (opens start menu). Some browsers also block F1 (help), Ctrl+N (new window), and media keys. Additionally, Fn keys on laptops are handled at the hardware level and never generate a JavaScript key event at all. This keyboard tester will show you exactly which keys your browser can detect."
  },
  {
    q: "How do I test if my keyboard has anti-ghosting?",
    a: "Use the anti-ghosting section of this tool: press and hold multiple keys at the same time and check if all of them appear as detected. Start with common gaming combinations like WASD + Shift + Space. If all keys show up, your keyboard handles that combination. Try increasingly unusual combinations — budget keyboards typically ghost at 3-4 simultaneous keys on certain rows, while gaming keyboards with NKRO will register every key. The key is to test combinations you actually use in games, not just random keys."
  },
  {
    q: "Can I use this to test a new or replacement keyboard?",
    a: "Yes — that's one of the best use cases for this tool. After buying a new keyboard or replacing one, use this tester to verify every single key works. Press each key one by one and watch the visual keyboard light up. The 'keys remaining' counter tells you how many keys you haven't pressed yet. If a key doesn't register, it could indicate a defective switch, a wiring issue, or a driver problem. This is especially useful for testing refurbished keyboards, custom builds, or keyboards bought secondhand."
  },
  {
    q: "Does this keyboard tester work with any keyboard layout?",
    a: "This tester displays a standard US QWERTY 104-key layout, but it detects key presses from any keyboard layout (AZERTY, QWERTZ, Dvorak, Colemak, etc.). The 'code' value shown in the info panel always refers to the physical key position, so pressing the physical 'A' key will highlight the 'A' position on the visual keyboard regardless of your layout. The 'key' value will show the actual character your layout produces. So yes — it works with any layout for testing purposes, though the visual display shows QWERTY positions."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Keyboard Tester — Free Online Key Test & Checker",
    "description": "Free online keyboard tester. Press any key to test it. Visual keyboard layout, key event details, anti-ghosting test, and full 104-key support.",
    "applicationCategory": "Utility",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Keyboard Tester — Free Online Key Test & Checker",
  description: "Test every key on your keyboard. Visual QWERTY layout with 104 keys, key event details, anti-ghosting test, and key history log. Free, no download.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Keyboard Tester — Free Online Key Test & Checker"
  description="Test every key on your keyboard. Visual QWERTY layout with 104 keys, key event details, anti-ghosting test, and key history log. Free, no download."
  canonical="https://leeroyjenkins.quest/keyboard-tester"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Keyboard Tester</h1>
      <p>Press any key to test it. Every key lights up on the visual keyboard. Check key events, test anti-ghosting, and verify all 104 keys work.</p>
    </div>

    <section class="content-section">
      <!-- Info Panel -->
      <div class="info-panel" id="info-panel">
        <div class="info-prompt" id="info-prompt">Press any key to begin...</div>
        <div class="info-grid" id="info-grid" style="display:none;">
          <div class="info-item"><span class="info-label">Key</span><span class="info-value" id="info-key">—</span></div>
          <div class="info-item"><span class="info-label">Code</span><span class="info-value" id="info-code">—</span></div>
          <div class="info-item"><span class="info-label">keyCode</span><span class="info-value" id="info-keycode">—</span></div>
          <div class="info-item"><span class="info-label">which</span><span class="info-value" id="info-which">—</span></div>
          <div class="info-item"><span class="info-label">Location</span><span class="info-value" id="info-location">—</span></div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-card">
          <span class="stat-value" id="stat-total">0</span>
          <span class="stat-label">Total Pressed</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-unique">0</span>
          <span class="stat-label">Unique Keys</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-remaining">104</span>
          <span class="stat-label">Remaining</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-held">0</span>
          <span class="stat-label">Held Now</span>
        </div>
      </div>

      <!-- Visual Keyboard -->
      <div class="keyboard-wrapper" id="keyboard"></div>

      <!-- Controls -->
      <div class="controls-row">
        <button class="btn btn-primary" id="reset-btn">Reset All</button>
      </div>

      <!-- Anti-Ghosting -->
      <h2>Anti-Ghosting Test</h2>
      <p>Press and hold multiple keys simultaneously. All detected keys appear below. If a key you're pressing doesn't show up, your keyboard is ghosting that combination.</p>
      <div class="ghost-panel" id="ghost-panel">
        <div class="ghost-prompt">Hold multiple keys to test...</div>
        <div class="ghost-keys" id="ghost-keys"></div>
        <div class="ghost-count" id="ghost-count"></div>
      </div>

      <!-- Key History -->
      <h2>Key History</h2>
      <p>Last 20 key presses, most recent first.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Key</th>
              <th>Code</th>
              <th>keyCode</th>
              <th>Type</th>
            </tr>
          </thead>
          <tbody id="history-body">
            <tr><td colspan="5" style="text-align:center;color:var(--text-secondary);padding:1rem;">No keys pressed yet</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Reference Table -->
      <h2>Common Key Codes Reference</h2>
      <p>Quick reference for commonly used JavaScript key codes and their corresponding <code>key</code> and <code>code</code> values.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Key</th>
              <th>keyCode</th>
              <th>code</th>
              <th>key value</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Enter</strong></td><td>13</td><td>Enter</td><td>Enter</td></tr>
            <tr><td><strong>Space</strong></td><td>32</td><td>Space</td><td>" " (space)</td></tr>
            <tr><td><strong>Escape</strong></td><td>27</td><td>Escape</td><td>Escape</td></tr>
            <tr><td><strong>Tab</strong></td><td>9</td><td>Tab</td><td>Tab</td></tr>
            <tr><td><strong>Shift (Left)</strong></td><td>16</td><td>ShiftLeft</td><td>Shift</td></tr>
            <tr><td><strong>Ctrl (Left)</strong></td><td>17</td><td>ControlLeft</td><td>Control</td></tr>
            <tr><td><strong>Alt (Left)</strong></td><td>18</td><td>AltLeft</td><td>Alt</td></tr>
            <tr><td><strong>Arrow Up</strong></td><td>38</td><td>ArrowUp</td><td>ArrowUp</td></tr>
            <tr><td><strong>Arrow Down</strong></td><td>40</td><td>ArrowDown</td><td>ArrowDown</td></tr>
            <tr><td><strong>A</strong></td><td>65</td><td>KeyA</td><td>a</td></tr>
            <tr><td><strong>0</strong></td><td>48</td><td>Digit0</td><td>0</td></tr>
            <tr><td><strong>F1</strong></td><td>112</td><td>F1</td><td>F1</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Tips -->
      <h2>How to Use This Keyboard Tester</h2>
      <ul>
        <li><strong>Test individual keys:</strong> Press any key and watch it light up on the visual keyboard. The info panel shows the key name, JavaScript event codes, and physical location.</li>
        <li><strong>Check for broken keys:</strong> Press every key one by one. The "Remaining" counter tracks how many keys you haven't tested yet. Aim for 0 to verify your entire keyboard works.</li>
        <li><strong>Test anti-ghosting:</strong> Hold multiple keys at once (try WASD + Shift + Space). The anti-ghosting panel shows every key the computer detects simultaneously. Missing keys = ghosting.</li>
        <li><strong>Verify key events for development:</strong> If you're building a web app that uses keyboard shortcuts, use the info panel to check exact <code>key</code>, <code>code</code>, and <code>keyCode</code> values for any key.</li>
        <li><strong>Test after cleaning or modding:</strong> If you've cleaned your keyboard, replaced switches, or done any hardware modification, run through all keys to confirm everything reconnected properly.</li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/typing-speed-test" class="related-link">
          <strong>Typing Speed Test</strong>
          <span>Test your typing speed in WPM with real words and accuracy tracking</span>
        </a>
        <a href="/best-gaming-keyboard" class="related-link">
          <strong>Best Gaming Keyboard 2026</strong>
          <span>Top mechanical keyboards ranked by switches, build quality, and features</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ── Keyboard Layout Definition ── */
    var ROWS = [
      [
        {c:'Escape',l:'Esc',w:1}, {c:'',l:'',w:0.5},
        {c:'F1',l:'F1',w:1},{c:'F2',l:'F2',w:1},{c:'F3',l:'F3',w:1},{c:'F4',l:'F4',w:1},{c:'',l:'',w:0.25},
        {c:'F5',l:'F5',w:1},{c:'F6',l:'F6',w:1},{c:'F7',l:'F7',w:1},{c:'F8',l:'F8',w:1},{c:'',l:'',w:0.25},
        {c:'F9',l:'F9',w:1},{c:'F10',l:'F10',w:1},{c:'F11',l:'F11',w:1},{c:'F12',l:'F12',w:1},{c:'',l:'',w:0.25},
        {c:'PrintScreen',l:'PrtSc',w:1},{c:'ScrollLock',l:'ScrLk',w:1},{c:'Pause',l:'Pause',w:1}
      ],
      [
        {c:'Backquote',l:'`',w:1},{c:'Digit1',l:'1',w:1},{c:'Digit2',l:'2',w:1},{c:'Digit3',l:'3',w:1},
        {c:'Digit4',l:'4',w:1},{c:'Digit5',l:'5',w:1},{c:'Digit6',l:'6',w:1},{c:'Digit7',l:'7',w:1},
        {c:'Digit8',l:'8',w:1},{c:'Digit9',l:'9',w:1},{c:'Digit0',l:'0',w:1},
        {c:'Minus',l:'-',w:1},{c:'Equal',l:'=',w:1},{c:'Backspace',l:'Bksp',w:2},{c:'',l:'',w:0.25},
        {c:'Insert',l:'Ins',w:1},{c:'Home',l:'Home',w:1},{c:'PageUp',l:'PgUp',w:1},{c:'',l:'',w:0.25},
        {c:'NumLock',l:'Num',w:1},{c:'NumpadDivide',l:'/',w:1},{c:'NumpadMultiply',l:'*',w:1},{c:'NumpadSubtract',l:'-',w:1}
      ],
      [
        {c:'Tab',l:'Tab',w:1.5},{c:'KeyQ',l:'Q',w:1},{c:'KeyW',l:'W',w:1},{c:'KeyE',l:'E',w:1},
        {c:'KeyR',l:'R',w:1},{c:'KeyT',l:'T',w:1},{c:'KeyY',l:'Y',w:1},{c:'KeyU',l:'U',w:1},
        {c:'KeyI',l:'I',w:1},{c:'KeyO',l:'O',w:1},{c:'KeyP',l:'P',w:1},
        {c:'BracketLeft',l:'[',w:1},{c:'BracketRight',l:']',w:1},{c:'Backslash',l:'\\',w:1.5},{c:'',l:'',w:0.25},
        {c:'Delete',l:'Del',w:1},{c:'End',l:'End',w:1},{c:'PageDown',l:'PgDn',w:1},{c:'',l:'',w:0.25},
        {c:'Numpad7',l:'7',w:1},{c:'Numpad8',l:'8',w:1},{c:'Numpad9',l:'9',w:1},{c:'NumpadAdd',l:'+',w:1,h:2}
      ],
      [
        {c:'CapsLock',l:'Caps',w:1.75},{c:'KeyA',l:'A',w:1},{c:'KeyS',l:'S',w:1},{c:'KeyD',l:'D',w:1},
        {c:'KeyF',l:'F',w:1},{c:'KeyG',l:'G',w:1},{c:'KeyH',l:'H',w:1},{c:'KeyJ',l:'J',w:1},
        {c:'KeyK',l:'K',w:1},{c:'KeyL',l:'L',w:1},{c:'Semicolon',l:';',w:1},
        {c:'Quote',l:"'",w:1},{c:'Enter',l:'Enter',w:2.25},{c:'',l:'',w:3.5},
        {c:'Numpad4',l:'4',w:1},{c:'Numpad5',l:'5',w:1},{c:'Numpad6',l:'6',w:1}
      ],
      [
        {c:'ShiftLeft',l:'Shift',w:2.25},{c:'KeyZ',l:'Z',w:1},{c:'KeyX',l:'X',w:1},{c:'KeyC',l:'C',w:1},
        {c:'KeyV',l:'V',w:1},{c:'KeyB',l:'B',w:1},{c:'KeyN',l:'N',w:1},{c:'KeyM',l:'M',w:1},
        {c:'Comma',l:',',w:1},{c:'Period',l:'.',w:1},{c:'Slash',l:'/',w:1},
        {c:'ShiftRight',l:'Shift',w:2.75},{c:'',l:'',w:1.25},
        {c:'ArrowUp',l:'\u2191',w:1},{c:'',l:'',w:1.25},
        {c:'Numpad1',l:'1',w:1},{c:'Numpad2',l:'2',w:1},{c:'Numpad3',l:'3',w:1},{c:'NumpadEnter',l:'Ent',w:1,h:2}
      ],
      [
        {c:'ControlLeft',l:'Ctrl',w:1.25},{c:'MetaLeft',l:'Win',w:1.25},{c:'AltLeft',l:'Alt',w:1.25},
        {c:'Space',l:'Space',w:6.25},
        {c:'AltRight',l:'Alt',w:1.25},{c:'MetaRight',l:'Win',w:1.25},{c:'ContextMenu',l:'Menu',w:1.25},{c:'ControlRight',l:'Ctrl',w:1.25},{c:'',l:'',w:0.25},
        {c:'ArrowLeft',l:'\u2190',w:1},{c:'ArrowDown',l:'\u2193',w:1},{c:'ArrowRight',l:'\u2192',w:1},{c:'',l:'',w:0.25},
        {c:'Numpad0',l:'0',w:2},{c:'NumpadDecimal',l:'.',w:1}
      ]
    ];

    var TOTAL_KEYS = 0;
    ROWS.forEach(function(row) {
      row.forEach(function(k) { if (k.c) TOTAL_KEYS++; });
    });

    /* ── State ── */
    var pressedEver = {};
    var heldNow = {};
    var totalPresses = 0;
    var history = [];
    var keyElements = {};

    /* ── Build Keyboard ── */
    var kb = document.getElementById('keyboard');
    var UNIT = 48;
    var GAP = 3;

    ROWS.forEach(function(row, ri) {
      var rowDiv = document.createElement('div');
      rowDiv.className = 'kb-row';
      row.forEach(function(k) {
        if (!k.c) {
          var spacer = document.createElement('div');
          spacer.className = 'kb-spacer';
          spacer.style.width = (k.w * UNIT + (k.w > 0.5 ? GAP * (k.w - 1) : 0)) + 'px';
          rowDiv.appendChild(spacer);
          return;
        }
        var key = document.createElement('div');
        key.className = 'kb-key';
        key.setAttribute('data-code', k.c);
        key.style.width = (k.w * UNIT + GAP * (k.w - 1)) + 'px';
        if (k.h === 2) {
          key.style.height = (2 * UNIT + GAP) + 'px';
          key.classList.add('kb-key-tall');
        }
        key.innerHTML = '<span>' + k.l + '</span>';
        rowDiv.appendChild(key);
        keyElements[k.c] = key;
      });
      kb.appendChild(rowDiv);
    });

    /* ── DOM Refs ── */
    var infoPrompt = document.getElementById('info-prompt');
    var infoGrid = document.getElementById('info-grid');
    var infoKey = document.getElementById('info-key');
    var infoCode = document.getElementById('info-code');
    var infoKeycode = document.getElementById('info-keycode');
    var infoWhich = document.getElementById('info-which');
    var infoLocation = document.getElementById('info-location');
    var statTotal = document.getElementById('stat-total');
    var statUnique = document.getElementById('stat-unique');
    var statRemaining = document.getElementById('stat-remaining');
    var statHeld = document.getElementById('stat-held');
    var ghostKeys = document.getElementById('ghost-keys');
    var ghostCount = document.getElementById('ghost-count');
    var ghostPanel = document.getElementById('ghost-panel');
    var historyBody = document.getElementById('history-body');

    var LOC_NAMES = { 0: 'Standard', 1: 'Left', 2: 'Right', 3: 'Numpad' };

    function updateStats() {
      var unique = Object.keys(pressedEver).length;
      statTotal.textContent = totalPresses;
      statUnique.textContent = unique;
      statRemaining.textContent = Math.max(0, TOTAL_KEYS - unique);
      statHeld.textContent = Object.keys(heldNow).length;
    }

    function updateGhost() {
      var keys = Object.keys(heldNow);
      if (keys.length === 0) {
        ghostKeys.innerHTML = '';
        ghostCount.textContent = '';
        ghostPanel.querySelector('.ghost-prompt').style.display = '';
        return;
      }
      ghostPanel.querySelector('.ghost-prompt').style.display = 'none';
      ghostKeys.innerHTML = keys.map(function(c) {
        return '<span class="ghost-tag">' + c + '</span>';
      }).join('');
      ghostCount.textContent = keys.length + ' key' + (keys.length !== 1 ? 's' : '') + ' detected simultaneously';
    }

    function addHistory(e) {
      history.unshift({ key: e.key, code: e.code, keyCode: e.keyCode, type: e.type });
      if (history.length > 20) history.length = 20;
      historyBody.innerHTML = history.map(function(h, i) {
        var displayKey = h.key === ' ' ? 'Space' : h.key;
        return '<tr><td>' + (i + 1) + '</td><td><strong>' + escHtml(displayKey) + '</strong></td><td>' + escHtml(h.code) + '</td><td>' + h.keyCode + '</td><td>' + h.type + '</td></tr>';
      }).join('');
    }

    function escHtml(s) {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ── Key Events ── */
    document.addEventListener('keydown', function(e) {
      e.preventDefault();
      var code = e.code;

      infoPrompt.style.display = 'none';
      infoGrid.style.display = '';
      var displayKey = e.key === ' ' ? 'Space' : e.key;
      infoKey.textContent = displayKey;
      infoCode.textContent = e.code;
      infoKeycode.textContent = e.keyCode;
      infoWhich.textContent = e.which;
      infoLocation.textContent = LOC_NAMES[e.location] || e.location;

      if (keyElements[code]) {
        keyElements[code].classList.add('kb-active');
        keyElements[code].classList.add('kb-pressed');
      }

      if (!heldNow[code]) {
        heldNow[code] = true;
        totalPresses++;
        pressedEver[code] = true;
        addHistory(e);
      }

      updateStats();
      updateGhost();
    });

    document.addEventListener('keyup', function(e) {
      e.preventDefault();
      var code = e.code;
      if (keyElements[code]) {
        keyElements[code].classList.remove('kb-active');
      }
      delete heldNow[code];
      updateStats();
      updateGhost();
    });

    window.addEventListener('blur', function() {
      Object.keys(heldNow).forEach(function(code) {
        if (keyElements[code]) keyElements[code].classList.remove('kb-active');
      });
      heldNow = {};
      updateStats();
      updateGhost();
    });

    /* ── Reset ── */
    document.getElementById('reset-btn').addEventListener('click', function() {
      pressedEver = {};
      heldNow = {};
      totalPresses = 0;
      history = [];
      Object.values(keyElements).forEach(function(el) {
        el.classList.remove('kb-active', 'kb-pressed');
      });
      infoPrompt.style.display = '';
      infoGrid.style.display = 'none';
      historyBody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text-secondary);padding:1rem;">No keys pressed yet</td></tr>';
      updateStats();
      updateGhost();
    });

    updateStats();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }
    code { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.15rem 0.4rem; font-size: 0.85em; color: var(--accent-color); }

    /* Info Panel */
    .info-panel { background: var(--card-bg); border: 2px solid var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; margin-bottom: 1.5rem; min-height: 80px; display: flex; align-items: center; justify-content: center; transition: border-color 0.2s; }
    .info-prompt { color: var(--text-secondary); font-size: 1.1rem; }
