      { category: "Accessories", pick: "Boom arm, green screen, panels", price: 250 }
    ],
    note: "The Elgato ecosystem shines at this tier. The Facecam, Wave:3, Key Light, and Stream Deck all integrate through Elgato software, giving you unified control. This is where your stream starts looking and sounding professional. Add a second Key Light when budget allows."
  },
  {
    tier: "Pro",
    budget: "$1,500+",
    total: "~$2,800",
    items: [
      { category: "Camera", pick: "Sony A6400 + Sigma 16mm f/1.4", price: 1250 },
      { category: "Microphone", pick: "Shure SM7B + Focusrite 2i2 + Cloudlifter", price: 650 },
      { category: "Lighting", pick: "Elgato Key Light (x2)", price: 400 },
      { category: "Capture Card", pick: "Elgato HD60 X (for camera input)", price: 200 },
      { category: "Stream Deck", pick: "Elgato Stream Deck MK.2", price: 150 },
      { category: "Accessories", pick: "Boom arm, green screen, acoustic treatment", price: 300 }
    ],
    note: "This is the setup you see on streams with 10K+ viewers. The mirrorless camera with a fast lens gives cinematic depth of field. The SM7B makes your voice sound like broadcast radio. Two Key Lights provide professional, shadow-free lighting. At this tier, your production quality matches full-time content creators."
  }
];

const obsSettings = [
  { setting: "Output Resolution", starter: "1280x720", mid: "1920x1080", pro: "1920x1080" },
  { setting: "FPS", starter: "30", mid: "60", pro: "60" },
  { setting: "Encoder", starter: "x264 (CPU)", mid: "NVENC / AMF (GPU)", pro: "NVENC / AMF (GPU)" },
  { setting: "Rate Control", starter: "CBR", mid: "CBR", pro: "CBR" },
  { setting: "Bitrate (Twitch)", starter: "3,000 kbps", mid: "6,000 kbps", pro: "6,000 kbps" },
  { setting: "Bitrate (YouTube)", starter: "4,000 kbps", mid: "8,000 kbps", pro: "10,000+ kbps" },
  { setting: "Keyframe Interval", starter: "2 seconds", mid: "2 seconds", pro: "2 seconds" },
  { setting: "CPU Preset (x264)", starter: "veryfast", mid: "N/A (use GPU)", pro: "N/A (use GPU)" },
  { setting: "Audio Bitrate", starter: "128 kbps", mid: "160 kbps", pro: "320 kbps" }
];

const internetSpeeds = [
  { quality: "720p30", bitrate: "3,000 kbps", minUpload: "5 Mbps", recommended: "10 Mbps" },
  { quality: "1080p30", bitrate: "4,500 kbps", minUpload: "7 Mbps", recommended: "15 Mbps" },
  { quality: "1080p60", bitrate: "6,000 kbps", minUpload: "10 Mbps", recommended: "20 Mbps" },
  { quality: "4K30 (YouTube)", bitrate: "13,000 kbps", minUpload: "20 Mbps", recommended: "35 Mbps" }
];

const faqs = [
  {
    q: "What is the minimum PC spec to stream on Twitch?",
    a: "For a single-PC setup at 1080p60, you need at minimum an NVIDIA RTX 3060 or AMD RX 6700 XT (for hardware encoding), a 6-core CPU (Ryzen 5 5600 or Intel i5-12400), and 16GB RAM. The GPU encoder (NVENC/AMF) handles the streaming workload with minimal FPS impact. Older GPUs without hardware encoders will force you to use CPU encoding (x264), which requires a much stronger processor."
  },
  {
    q: "Should I use one PC or a dual-PC streaming setup?",
    a: "One PC is fine for the vast majority of streamers. Modern GPU encoders (NVENC on NVIDIA, AMF on AMD) produce excellent quality with less than 5% performance impact. A dual-PC setup only makes sense if you're playing extremely CPU-intensive games at competitive framerates (240fps+) and streaming at the highest quality simultaneously. For 99% of streamers, invest the second PC's budget into better gear instead."
  },
  {
    q: "Do I need a capture card if I stream from a PC?",
    a: "No — if you game and stream from the same PC, OBS captures your game directly. You only need a capture card for: (1) streaming console gameplay (PS5, Xbox, Switch), (2) using a mirrorless camera as a webcam, or (3) a dual-PC setup where one PC captures the other's output."
  },
  {
    q: "What is the best free streaming software?",
    a: "OBS Studio is the industry standard and it's completely free and open source. It handles everything — scene management, audio mixing, encoding, and streaming to Twitch/YouTube/Kick simultaneously. Streamlabs adds a user-friendly UI on top of OBS, but uses more resources. For most streamers, plain OBS Studio with a few plugins is the best choice."
  },
  {
    q: "How much does internet speed matter for streaming?",
    a: "Upload speed is critical. For 1080p60 streaming at 6,000 kbps, you need at least 10 Mbps upload with 20 Mbps recommended to handle concurrent gaming traffic. Download speed matters for the games you play but not for streaming itself. Wired ethernet is strongly recommended over Wi-Fi — packet loss causes stream stuttering even with fast speeds."
  },
  {
    q: "Is it worth upgrading from a webcam to a mirrorless camera?",
    a: "A mirrorless camera like the Sony A6400 with a fast lens (f/1.4-f/1.8) gives you shallow depth of field (blurry background) that no webcam can replicate. It's the single biggest visual upgrade you can make. However, it adds complexity — you need a capture card, dummy battery, and proper mounting. If you're serious about streaming long-term and want that 'professional' look, it's worth the investment."
  },
  {
    q: "What lighting setup do most big streamers use?",
    a: "Most professional streamers use two key lights at 45-degree angles (one on each side of the monitor). The Elgato Key Light is the most popular because it desk-mounts and integrates with Stream Deck. Some add a third light behind them for separation from the background. Good lighting matters more than camera quality — a $60 webcam with proper lighting looks better than a $900 camera in a dark room."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Streaming Setup Guide 2026",
    "description": "Complete streaming setup guide with gear recommendations at 3 budget tiers. Camera, microphone, lighting, capture card, and OBS settings for Twitch and YouTube.",
    "author": {
      "@type": "Organization",
      "name": "Leeroy Jenkins"
    },
    "datePublished": "2026-03-21",
    "dateModified": "2026-03-21"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Best Streaming Setup Guide 2026 — Gear at Every Budget",
  description: "Complete streaming setup guide with gear recommendations at 3 budget tiers. Camera, mic, lighting, capture card, and OBS settings for Twitch and YouTube.",
  category: "guide",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Best Streaming Setup Guide 2026 — Gear at Every Budget"
  description="Complete streaming setup guide with gear recommendations at 3 budget tiers. Camera, mic, lighting, capture card, and OBS settings for Twitch and YouTube."
  canonical="https://leeroyjenkins.quest/best-streaming-setup"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Best Streaming Setup Guide (2026)</h1>
      <p>Everything you need to start streaming on Twitch or YouTube — from $400 starter setups to $2,800 pro rigs. We break down every piece of gear, explain what actually matters, and give you the exact OBS settings to use.</p>
    </div>

    <section class="content-section">
      <p>Your streaming setup determines your production quality, and production quality determines whether new viewers stick around. Studies show viewers decide within 10 seconds whether to stay on a stream — and that decision is heavily influenced by audio and video quality, not just gameplay.</p>
      <p>We've built streaming setups at three price points and tested every component. Here's exactly what to buy, why, and how to configure it.</p>

      <h2>Budget Tier Overview</h2>
      <p>Pick the tier that fits your budget. Every tier produces a stream good enough for its audience — don't overspend if you're just starting out.</p>

      {budgetTiers.map(t => (
        <div class="tier-card">
          <div class="tier-header">
            <div>
              <span class="tier-label">{t.tier}</span>
              <strong class="tier-budget">{t.budget}</strong>
            </div>
            <span class="tier-total">Total: {t.total}</span>
          </div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Category</th>
                  <th>Pick</th>
                  <th>Price</th>
                </tr>
              </thead>
              <tbody>
                {t.items.map(item => (
                  <tr>
                    <td><strong>{item.category}</strong></td>
                    <td>{item.pick}</td>
                    <td>{item.price === 0 ? "Free" : `$${item.price}`}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="tier-note">{t.note}</p>
        </div>
      ))}

      <h2>Cameras</h2>
      <p>Click any column header to sort. Your camera is the most visible part of your setup — but good lighting matters more than an expensive camera.</p>
      <div class="table-wrapper">
        <table class="sortable-table">
          <thead>
            <tr>
              <th data-sort="string">Camera</th>
              <th data-sort="number">Price</th>
              <th data-sort="string">Resolution</th>
              <th data-sort="string">Autofocus</th>
              <th data-sort="string">FOV</th>
              <th data-sort="number">Quality</th>
              <th data-sort="string">Tier</th>
            </tr>
          </thead>
          <tbody>
            {cameras.map(c => (
              <tr>
                <td><strong>{c.name}</strong></td>
                <td data-value={c.price}>${c.price}</td>
                <td>{c.resolution}</td>
                <td>{c.autofocus}</td>
                <td>{c.fov}</td>
                <td data-value={c.quality}>{c.quality}/10</td>
                <td>{c.tier}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {cameras.map((c, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{c.name}</h3>
              {c.badge && <span class="badge">{c.badge}</span>}
            </div>
            <span class="review-price">${c.price}</span>
          </div>
          <p class="review-summary">{c.summary}</p>
          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Resolution</span><span class="spec-value">{c.resolution}</span></div>
            <div class="spec"><span class="spec-label">Autofocus</span><span class="spec-value">{c.autofocus}</span></div>
            <div class="spec"><span class="spec-label">FOV</span><span class="spec-value">{c.fov}</span></div>
            <div class="spec"><span class="spec-label">Mount</span><span class="spec-value">{c.mount}</span></div>
            <div class="spec"><span class="spec-label">Quality</span><span class="spec-value">{c.quality}/10</span></div>
            <div class="spec"><span class="spec-label">Tier</span><span class="spec-value">{c.tier}</span></div>
          </div>
          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{c.pros.map(p => <li>{p}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{c.cons.map(con => <li>{con}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Microphones</h2>
      <p>Audio quality is arguably more important than video. Viewers tolerate a 720p stream with great audio far longer than a 4K stream with bad audio.</p>
      <div class="table-wrapper">
        <table class="sortable-table">
          <thead>
            <tr>
              <th data-sort="string">Microphone</th>
              <th data-sort="number">Price</th>
              <th data-sort="string">Type</th>
              <th data-sort="string">Pattern</th>
              <th data-sort="string">Sample Rate</th>
              <th data-sort="number">Quality</th>
              <th data-sort="string">Tier</th>
            </tr>
          </thead>
          <tbody>
            {microphones.map(m => (
              <tr>
                <td><strong>{m.name}</strong></td>
                <td data-value={m.price}>${m.price}</td>
                <td>{m.type}</td>
                <td>{m.pattern}</td>
                <td>{m.sampleRate}</td>
                <td data-value={m.quality}>{m.quality}/10</td>
                <td>{m.tier}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {microphones.map((m, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{m.name}</h3>
              {m.badge && <span class="badge">{m.badge}</span>}
            </div>
            <span class="review-price">${m.price}</span>
          </div>
          <p class="review-summary">{m.summary}</p>
          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Type</span><span class="spec-value">{m.type}</span></div>
            <div class="spec"><span class="spec-label">Pattern</span><span class="spec-value">{m.pattern}</span></div>
            <div class="spec"><span class="spec-label">Sample Rate</span><span class="spec-value">{m.sampleRate}</span></div>
            <div class="spec"><span class="spec-label">Quality</span><span class="spec-value">{m.quality}/10</span></div>
            <div class="spec"><span class="spec-label">Tier</span><span class="spec-value">{m.tier}</span></div>
          </div>
          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{m.pros.map(p => <li>{p}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{m.cons.map(con => <li>{con}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Capture Cards</h2>
      <p>Only needed for console streaming or using a mirrorless camera. If you game and stream from the same PC, OBS captures your game directly.</p>
      <div class="table-wrapper">
        <table class="sortable-table">
          <thead>
            <tr>
              <th data-sort="string">Capture Card</th>
              <th data-sort="number">Price</th>
              <th data-sort="string">Passthrough</th>
              <th data-sort="string">Capture</th>
              <th data-sort="string">Connection</th>
              <th data-sort="number">Quality</th>
            </tr>
          </thead>
          <tbody>
            {captureCards.map(cc => (
              <tr>
                <td><strong>{cc.name}</strong></td>
                <td data-value={cc.price}>${cc.price}</td>
                <td>{cc.passthrough}</td>
                <td>{cc.capture}</td>
                <td>{cc.connection}</td>
                <td data-value={cc.quality}>{cc.quality}/10</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {captureCards.map((cc, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{cc.name}</h3>
              {cc.badge && <span class="badge">{cc.badge}</span>}
            </div>
            <span class="review-price">${cc.price}</span>
          </div>
          <p class="review-summary">{cc.summary}</p>
