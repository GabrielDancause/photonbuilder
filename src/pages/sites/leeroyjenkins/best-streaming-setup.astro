const captureCards = [
  {
    name: "Elgato HD60 X",
    badge: "Best Overall",
    price: 200,
    passthrough: "4K60 HDR",
    capture: "1080p60 / 4K30",
    connection: "USB 3.0",
    compatibility: "PC, Mac, PS5, Xbox, Switch",
