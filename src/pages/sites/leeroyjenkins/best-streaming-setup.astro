  { name: "Boom Arm (Rode PSA1 II)", price: 100, category: "Mic Mount", description: "The most popular mic boom arm for a reason — smooth movement, strong springs, and internal cable routing. Essential for getting your mic off the desk and reducing vibration." },
  { name: "Acoustic Panels (12-pack)", price: 30, category: "Sound Treatment", description: "Foam panels reduce echo and room reverb. Place behind and to the sides of your mic. This is the cheapest way to make your mic sound significantly better." }
];

