        <select id="case-select" class="component-dropdown">
          <option value="case-mini">Mini-ITX Compact — $69</option>
          <option value="case-micro">Micro-ATX Mid Tower — $79</option>
          <option value="case-mid" selected>ATX Mid Tower — $89</option>
