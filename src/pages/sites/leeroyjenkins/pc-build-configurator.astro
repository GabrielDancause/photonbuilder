---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How much should I spend on a gaming PC in 2026?",
    a: "A solid 1080p gaming PC starts around $600-700, delivering 60+ FPS in most games. For 1440p at 100+ FPS, budget $1,000-1,300. High-end 4K gaming rigs run $1,800-2,500+. The sweet spot for most gamers is the $1,000-1,500 range — you get excellent 1440p performance with room for future upgrades. Don't forget to budget $150-300 for a monitor, keyboard, and mouse if you're starting from scratch. Building your own PC saves 15-30% compared to prebuilts with the same specs."
  },
  {
    q: "What's a CPU bottleneck vs GPU bottleneck and how do I avoid it?",
    a: "A bottleneck occurs when one component limits another's performance. A CPU bottleneck means your processor can't feed frames to the GPU fast enough — common when pairing a budget CPU with a high-end GPU, especially at 1080p. A GPU bottleneck means the graphics card is the limiting factor — this is actually ideal because it means you're using your GPU fully. To avoid CPU bottlenecks, follow the ~40-50% GPU / ~20-25% CPU budget ratio. For example, don't pair an RTX 4090 with an i3 or Ryzen 3. A Ryzen 5 7600X or i5-14600K handles up to an RTX 4070 Ti Super without issues."
  },
  {
    q: "How much RAM do I actually need for gaming?",
    a: "16GB DDR5 is the sweet spot for gaming in 2026. It handles every current game comfortably while leaving headroom for Discord, a browser, and streaming software. 32GB is worth it if you multitask heavily, stream, or play memory-hungry games like modded Minecraft, Star Citizen, or Cities: Skylines 2. 8GB is too little for modern gaming — you'll experience stuttering in open-world games. 64GB is overkill for pure gaming but makes sense for content creators who also game. Always run RAM in dual-channel (two sticks) for a 15-20% performance boost over a single stick."
  },
  {
    q: "Do I need an NVMe SSD or is a SATA SSD fine for gaming?",
    a: "For gaming, a SATA SSD is perfectly fine — game load times are nearly identical between SATA and NVMe SSDs because games are limited by decompression speed, not raw read speed. Where NVMe shines is file transfers, video editing, and DirectStorage-enabled games (still rare). A 1TB SATA SSD costs $50-70 vs $60-90 for NVMe, so the price gap is small enough that NVMe is the default recommendation. Get at least 1TB — modern games are 50-150GB each, and a 500GB drive fills up fast. A 2TB drive gives comfortable breathing room."
  },
  {
    q: "How do I know if my PSU is big enough for my build?",
    a: "Add up your CPU TDP and GPU TDP, then add 100-150W for other components and overhead. Multiply the total by 1.25 for 80% load headroom — running a PSU near max capacity increases noise, heat, and reduces lifespan. For example: a Ryzen 5 7600X (65W) + RTX 4070 Super (220W) = 285W + 125W overhead = 410W, times 1.25 = ~512W, so a 550W PSU works but 650W gives better headroom. Modern GPUs have transient power spikes that can trip low-wattage PSUs — NVIDIA recommends 700W for the RTX 4080 and 850W for the 4090. Always buy 80+ Bronze certified or better for efficiency and reliability."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Gaming PC Build Configurator — Plan Your Perfect Build",
    "description": "Free gaming PC build planner. Select components, auto-calculate total cost, estimated FPS at 1080p/1440p/4K, bottleneck warnings, and PSU adequacy. Includes budget, mid-range, and high-end presets.",
    "applicationCategory": "Utility",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Gaming PC Build Configurator — Plan Your Build",
  description: "Free gaming PC build planner. Pick CPU, GPU, RAM, storage, PSU, and case — get total cost, estimated FPS for popular games, bottleneck warnings, and compatibility checks. 3 preset builds included.",
  category: "tool",
  published: "2026-03-21",
};
---

