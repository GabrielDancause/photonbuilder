            <option value="i5-14600k">Core i5-14600K — $269 — 14C/20T</option>
            <option value="i5-14400f">Core i5-14400F — $189 — 10C/16T</option>
            <option value="i3-14100f">Core i3-14100F — $109 — 4C/8T</option>
