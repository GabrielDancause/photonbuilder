      </div>

      <!-- GPU Selection -->
      <div class="optimizer-card">
        <div class="step-header"><span class="step-num">2</span> GPU (Graphics Card)</div>
        <select id="gpu-select" class="component-dropdown">
          <optgroup label="NVIDIA — Current Gen">
            <option value="rtx4090">RTX 4090 — $1,599 — 24GB VRAM</option>
            <option value="rtx4080s">RTX 4080 Super — $999 — 16GB VRAM</option>
            <option value="rtx4070tis">RTX 4070 Ti Super — $799 — 16GB VRAM</option>
