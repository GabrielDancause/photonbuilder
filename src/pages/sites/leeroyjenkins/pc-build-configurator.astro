            <option value="rtx4060ti" selected>RTX 4060 Ti — $399 — 8GB VRAM</option>
            <option value="rtx4060">RTX 4060 — $299 — 8GB VRAM</option>
          </optgroup>
          <optgroup label="AMD — Current Gen">
