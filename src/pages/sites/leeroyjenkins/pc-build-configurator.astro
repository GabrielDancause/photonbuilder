        <!-- Game FPS Table -->
        <div class="table-wrapper">
          <table id="game-fps-table">
            <thead>
              <tr>
                <th>Game</th>
                <th>1080p</th>
                <th>1440p</th>
                <th>4K</th>
              </tr>
            </thead>
            <tbody id="game-fps-body"></tbody>
          </table>
        </div>

        <!-- Warnings -->
        <div class="warnings-container" id="warnings-container" style="display:none;">
          <h3>Warnings &amp; Notes</h3>
          <ul id="warnings-list"></ul>
        </div>

        <!-- Component Summary -->
        <div class="build-summary" id="build-summary">
          <h3>Build Summary</h3>
          <div id="summary-body"></div>
        </div>

        <!-- Copy Build -->
        <button class="btn btn-secondary" id="copy-btn" style="margin-top:1rem;">Copy Build to Clipboard</button>
        <span class="copy-feedback" id="copy-feedback"></span>
      </div>

      <!-- Building Guide -->
      <h2>PC Building Tips</h2>

      <h3>Before You Buy</h3>
      <ul>
        <li><strong>Set a realistic budget:</strong> Decide your total budget including peripherals (monitor, keyboard, mouse). Allocate roughly 35-40% to GPU, 15-20% to CPU, and the rest to other components.</li>
        <li><strong>Check compatibility:</strong> Make sure your motherboard socket matches your CPU (AM5 for Ryzen 7000, LGA 1700 for Intel 14th gen). DDR4 and DDR5 motherboards are not interchangeable.</li>
        <li><strong>Don't overspend on the CPU:</strong> For pure gaming, a Ryzen 5 7600X or i5-14600K handles even an RTX 4080 without bottlenecking at 1440p. Save money for a better GPU instead.</li>
        <li><strong>Watch for sales:</strong> GPU and SSD prices fluctuate significantly. Check prices on PCPartPicker and set alerts for your target components.</li>
      </ul>

      <h3>During the Build</h3>
      <ul>
        <li><strong>Install the CPU cooler before mounting the motherboard</strong> in the case — it's much easier with full access to the back of the board.</li>
        <li><strong>Don't forget the I/O shield:</strong> Install it before the motherboard goes in. It's almost impossible to add afterward without removing everything.</li>
        <li><strong>Connect front panel headers last:</strong> These tiny connectors are the most fiddly part. Use your motherboard manual for the correct pinout.</li>
        <li><strong>Route cables behind the motherboard tray:</strong> Good cable management improves airflow and makes future upgrades easier.</li>
        <li><strong>Test outside the case first:</strong> Connect CPU, RAM, GPU, and PSU on the motherboard box and boot to BIOS before installing everything in the case. This saves hours of troubleshooting if something is DOA.</li>
      </ul>

      <h3>After Building</h3>
      <ul>
        <li><strong>Update BIOS and drivers:</strong> Flash the latest BIOS from your motherboard manufacturer, then install GPU drivers from NVIDIA or AMD's website (not Windows Update).</li>
        <li><strong>Enable XMP/EXPO in BIOS:</strong> Your RAM runs at base speed (4800MHz for DDR5) until you enable the XMP (Intel) or EXPO (AMD) profile to reach its rated speed.</li>
        <li><strong>Set up proper fan curves:</strong> Default fan curves are often too conservative. Use your BIOS or fan control software to create curves that ramp up at 70°C+ for a quieter, cooler system.</li>
        <li><strong>Monitor temperatures:</strong> Use HWMonitor or HWiNFO64 during gaming. CPU under 85°C and GPU under 83°C is healthy. Higher temps mean you need better airflow or cooler mounting.</li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/fps-settings-optimizer" class="related-link">
          <strong>FPS Settings Optimizer</strong>
          <span>Get optimized in-game settings for Valorant, CS2, Fortnite, and more</span>
        </a>
        <a href="/best-gaming-monitor" class="related-link">
          <strong>Best Gaming Monitors</strong>
          <span>144Hz, 240Hz, 360Hz monitors for competitive gaming</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ── Component Database ── */
    const CPUS = {
      'r9-7950x':  { name: 'Ryzen 9 7950X', price: 549, score: 98, tdp: 170, tier: 5 },
      'r7-7800x3d':{ name: 'Ryzen 7 7800X3D', price: 399, score: 100, tdp: 120, tier: 5 },
      'r7-7700x':  { name: 'Ryzen 7 7700X', price: 299, score: 85, tdp: 105, tier: 4 },
      'r5-7600x':  { name: 'Ryzen 5 7600X', price: 199, score: 75, tdp: 105, tier: 3 },
      'r5-7600':   { name: 'Ryzen 5 7600', price: 179, score: 72, tdp: 65, tier: 3 },
      'i9-14900k': { name: 'Core i9-14900K', price: 549, score: 97, tdp: 253, tier: 5 },
      'i7-14700k': { name: 'Core i7-14700K', price: 379, score: 90, tdp: 253, tier: 4 },
      'i5-14600k': { name: 'Core i5-14600K', price: 269, score: 80, tdp: 181, tier: 3 },
      'i5-14400f': { name: 'Core i5-14400F', price: 189, score: 65, tdp: 148, tier: 2 },
      'i3-14100f': { name: 'Core i3-14100F', price: 109, score: 45, tdp: 110, tier: 1 }
    };

    const GPUS = {
      'rtx4090':   { name: 'RTX 4090', price: 1599, score: 100, tdp: 450, tier: 5, vram: 24 },
      'rtx4080s':  { name: 'RTX 4080 Super', price: 999, score: 82, tdp: 320, tier: 5, vram: 16 },
      'rtx4070tis': { name: 'RTX 4070 Ti Super', price: 799, score: 72, tdp: 285, tier: 4, vram: 16 },
      'rtx4070s':  { name: 'RTX 4070 Super', price: 599, score: 62, tdp: 220, tier: 3, vram: 12 },
      'rtx4060ti':  { name: 'RTX 4060 Ti', price: 399, score: 48, tdp: 160, tier: 3, vram: 8 },
      'rtx4060':   { name: 'RTX 4060', price: 299, score: 38, tdp: 115, tier: 2, vram: 8 },
      'rx7900xtx': { name: 'RX 7900 XTX', price: 899, score: 85, tdp: 355, tier: 5, vram: 24 },
      'rx7800xt':  { name: 'RX 7800 XT', price: 479, score: 58, tdp: 263, tier: 3, vram: 16 },
      'rx7600':    { name: 'RX 7600', price: 249, score: 35, tdp: 165, tier: 2, vram: 8 },
      'rx6600':    { name: 'RX 6600', price: 179, score: 25, tdp: 132, tier: 1, vram: 8 }
    };

    const RAM_OPTIONS = {
      'ddr5-8':  { name: '8GB DDR5-5600 (1x8GB)', price: 25, gb: 8, channels: 1 },
      'ddr5-16': { name: '16GB DDR5-5600 (2x8GB)', price: 49, gb: 16, channels: 2 },
      'ddr5-32': { name: '32GB DDR5-5600 (2x16GB)', price: 89, gb: 32, channels: 2 },
      'ddr5-64': { name: '64GB DDR5-5600 (2x32GB)', price: 179, gb: 64, channels: 2 }
    };

    const STORAGE_OPTIONS = {
      'ssd-500':  { name: '500GB NVMe SSD', price: 45, gb: 500 },
      'ssd-1000': { name: '1TB NVMe SSD', price: 75, gb: 1000 },
      'ssd-2000': { name: '2TB NVMe SSD', price: 139, gb: 2000 },
      'ssd-4000': { name: '4TB NVMe SSD', price: 279, gb: 4000 }
    };

    const PSU_OPTIONS = {
      'psu-450':  { name: '450W 80+ Bronze', price: 39, wattage: 450 },
      'psu-550':  { name: '550W 80+ Bronze', price: 54, wattage: 550 },
      'psu-650':  { name: '650W 80+ Gold', price: 79, wattage: 650 },
      'psu-750':  { name: '750W 80+ Gold', price: 99, wattage: 750 },
      'psu-850':  { name: '850W 80+ Gold', price: 119, wattage: 850 },
      'psu-1000': { name: '1000W 80+ Gold', price: 149, wattage: 1000 }
    };

    const CASE_OPTIONS = {
      'case-mini': { name: 'Mini-ITX Compact', price: 69, size: 'mini-itx' },
      'case-micro': { name: 'Micro-ATX Mid Tower', price: 79, size: 'micro-atx' },
      'case-mid':  { name: 'ATX Mid Tower', price: 89, size: 'atx' },
      'case-full': { name: 'ATX Full Tower', price: 149, size: 'full-atx' }
    };

    /* ── Game FPS Database (base FPS at 1080p for score=50 GPU) ── */
    const GAMES = {
      'Valorant':       { base1080: 220, cpuWeight: 0.6 },
      'CS2':            { base1080: 180, cpuWeight: 0.55 },
      'Fortnite':       { base1080: 140, cpuWeight: 0.4 },
      'Apex Legends':   { base1080: 130, cpuWeight: 0.35 },
      'Overwatch 2':    { base1080: 160, cpuWeight: 0.4 },
      'CoD Warzone':    { base1080: 100, cpuWeight: 0.3 },
      'Cyberpunk 2077': { base1080: 60,  cpuWeight: 0.2 },
      'Elden Ring':     { base1080: 55,  cpuWeight: 0.25 }
    };

    /* ── Preset Builds ── */
    const PRESETS = {
      budget: { cpu: 'r5-7600', gpu: 'rtx4060', ram: 'ddr5-16', storage: 'ssd-1000', psu: 'psu-550', case: 'case-micro' },
      midrange: { cpu: 'r5-7600x', gpu: 'rtx4070s', ram: 'ddr5-16', storage: 'ssd-2000', psu: 'psu-650', case: 'case-mid' },
      highend: { cpu: 'r7-7800x3d', gpu: 'rtx4080s', ram: 'ddr5-32', storage: 'ssd-2000', psu: 'psu-850', case: 'case-full' }
    };

    /* ── DOM Refs ── */
    var cpuSel = document.getElementById('cpu-select');
    var gpuSel = document.getElementById('gpu-select');
    var ramSel = document.getElementById('ram-select');
    var storageSel = document.getElementById('storage-select');
    var psuSel = document.getElementById('psu-select');
    var caseSel = document.getElementById('case-select');
    var presetSelect = document.getElementById('preset-select');
    var analyzeBtn = document.getElementById('analyze-btn');
    var resultsContainer = document.getElementById('results-container');
    var totalCostEl = document.getElementById('total-cost');
    var fps1080El = document.getElementById('fps-1080');
    var fps1440El = document.getElementById('fps-1440');
    var fps4kEl = document.getElementById('fps-4k');
    var gameFpsBody = document.getElementById('game-fps-body');
    var warningsContainer = document.getElementById('warnings-container');
    var warningsList = document.getElementById('warnings-list');
    var summaryBody = document.getElementById('summary-body');
    var copyBtn = document.getElementById('copy-btn');
    var copyFeedback = document.getElementById('copy-feedback');

    /* ── Preset Selection ── */
    presetSelect.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-preset]');
      if (!btn) return;
      var preset = PRESETS[btn.dataset.preset];
      if (!preset) return;
      cpuSel.value = preset.cpu;
      gpuSel.value = preset.gpu;
      ramSel.value = preset.ram;
      storageSel.value = preset.storage;
      psuSel.value = preset.psu;
      caseSel.value = preset.case;
      analyzeBuild();
    });

    /* ── Analyze ── */
    analyzeBtn.addEventListener('click', analyzeBuild);

    function estimateFps(gpuScore, cpuScore, game, resolution) {
      var resMult = resolution === '1080p' ? 1.0 : resolution === '1440p' ? 0.68 : 0.38;
      var gpuFactor = gpuScore / 50;
      var cpuFactor = cpuScore / 75;
      var combined = (game.cpuWeight * cpuFactor) + ((1 - game.cpuWeight) * gpuFactor);
      return Math.round(game.base1080 * combined * resMult);
    }

    function analyzeBuild() {
      var cpu = CPUS[cpuSel.value];
      var gpu = GPUS[gpuSel.value];
      var ram = RAM_OPTIONS[ramSel.value];
      var storage = STORAGE_OPTIONS[storageSel.value];
      var psu = PSU_OPTIONS[psuSel.value];
      var pcCase = CASE_OPTIONS[caseSel.value];

      if (!cpu || !gpu || !ram || !storage || !psu || !pcCase) return;

      /* ── Total Cost ── */
      var totalCost = cpu.price + gpu.price + ram.price + storage.price + psu.price + pcCase.price;
      totalCostEl.textContent = '$' + totalCost.toLocaleString();

      /* ── FPS Estimates ── */
      var avgFps1080 = 0, avgFps1440 = 0, avgFps4k = 0, gameCount = 0;
      var gameRows = '';

      var gameNames = Object.keys(GAMES);
      for (var i = 0; i < gameNames.length; i++) {
        var gameName = gameNames[i];
        var game = GAMES[gameName];
        var f1080 = estimateFps(gpu.score, cpu.score, game, '1080p');
        var f1440 = estimateFps(gpu.score, cpu.score, game, '1440p');
        var f4k = estimateFps(gpu.score, cpu.score, game, '4k');

        avgFps1080 += f1080;
        avgFps1440 += f1440;
        avgFps4k += f4k;
        gameCount++;

        gameRows += '<tr><td><strong>' + gameName + '</strong></td>';
        gameRows += '<td class="' + fpsClass(f1080) + '">' + f1080 + ' FPS</td>';
        gameRows += '<td class="' + fpsClass(f1440) + '">' + f1440 + ' FPS</td>';
        gameRows += '<td class="' + fpsClass(f4k) + '">' + f4k + ' FPS</td></tr>';
      }

      fps1080El.textContent = Math.round(avgFps1080 / gameCount);
      fps1440El.textContent = Math.round(avgFps1440 / gameCount);
      fps4kEl.textContent = Math.round(avgFps4k / gameCount);

      gameFpsBody.innerHTML = gameRows;

      /* ── Warnings ── */
      var warnings = [];

      // Bottleneck check
      var tierDiff = gpu.tier - cpu.tier;
      if (tierDiff >= 2) {
        warnings.push({ type: 'warning', text: '<strong>CPU Bottleneck:</strong> Your ' + cpu.name + ' will bottleneck the ' + gpu.name + ', especially at 1080p. Consider upgrading your CPU for balanced performance.' });
      } else if (tierDiff <= -2) {
        warnings.push({ type: 'info', text: '<strong>GPU Bottleneck:</strong> Your ' + gpu.name + ' is underpowered relative to your ' + cpu.name + '. You could get a faster GPU to match your CPU\'s potential.' });
      }

      // PSU check
      var totalTdp = cpu.tdp + gpu.tdp + 100; // 100W for other components
      var recommendedPsu = Math.ceil(totalTdp * 1.25 / 50) * 50;
      if (psu.wattage < totalTdp) {
        warnings.push({ type: 'danger', text: '<strong>PSU Too Small:</strong> Your build draws ~' + totalTdp + 'W but your PSU only provides ' + psu.wattage + 'W. This will cause crashes and shutdowns. Minimum recommended: ' + recommendedPsu + 'W.' });
      } else if (psu.wattage < recommendedPsu) {
        warnings.push({ type: 'warning', text: '<strong>PSU Tight:</strong> Your build draws ~' + totalTdp + 'W with a ' + psu.wattage + 'W PSU. It\'ll work but runs the PSU at high load. Recommended: ' + recommendedPsu + 'W for headroom and quieter operation.' });
      } else {
        warnings.push({ type: 'good', text: '<strong>PSU Adequate:</strong> ' + psu.wattage + 'W provides good headroom over the estimated ~' + totalTdp + 'W draw. You\'re set.' });
      }

      // RAM check
      if (ram.gb < 16) {
        warnings.push({ type: 'warning', text: '<strong>Low RAM:</strong> 8GB is below the recommended minimum for modern gaming. You\'ll experience stuttering in open-world games. Upgrade to 16GB.' });
      }
      if (ram.channels === 1) {
        warnings.push({ type: 'warning', text: '<strong>Single-Channel RAM:</strong> Running one stick loses 15-20% memory bandwidth. Use two sticks for dual-channel mode.' });
      }

      // Storage check
      if (storage.gb < 1000) {
        warnings.push({ type: 'info', text: '<strong>Limited Storage:</strong> 500GB fills up fast with modern games (50-150GB each). Consider 1TB or adding a second drive later.' });
      }

      // Case compatibility
      if (pcCase.size === 'mini-itx' && (gpu.tdp > 300 || cpu.tdp > 170)) {
        warnings.push({ type: 'warning', text: '<strong>Case Clearance:</strong> High-power components in a Mini-ITX case may have cooling and GPU length constraints. Verify physical dimensions before buying.' });
      }

      if (warnings.length > 0) {
        warningsList.innerHTML = warnings.map(function(w) {
          return '<li class="warn-' + w.type + '">' + w.text + '</li>';
        }).join('');
        warningsContainer.style.display = 'block';
      } else {
        warningsContainer.style.display = 'none';
      }

      /* ── Build Summary ── */
      var summaryHtml = '<table class="summary-table">';
      summaryHtml += summaryRow('CPU', cpu.name, cpu.price);
      summaryHtml += summaryRow('GPU', gpu.name, gpu.price);
      summaryHtml += summaryRow('RAM', ram.name, ram.price);
      summaryHtml += summaryRow('Storage', storage.name, storage.price);
      summaryHtml += summaryRow('PSU', psu.name, psu.price);
      summaryHtml += summaryRow('Case', pcCase.name, pcCase.price);
      summaryHtml += '<tr class="summary-total"><td><strong>Total</strong></td><td></td><td><strong>$' + totalCost.toLocaleString() + '</strong></td></tr>';
      summaryHtml += '</table>';
      summaryBody.innerHTML = summaryHtml;

      resultsContainer.style.display = 'block';
      resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function summaryRow(label, name, price) {
      return '<tr><td>' + label + '</td><td>' + name + '</td><td>$' + price + '</td></tr>';
    }

    function fpsClass(fps) {
      if (fps >= 144) return 'fps-great';
      if (fps >= 60) return 'fps-good';
      if (fps >= 30) return 'fps-ok';
      return 'fps-bad';
    }

    /* ── Copy Build ── */
    copyBtn.addEventListener('click', function() {
      var cpu = CPUS[cpuSel.value];
      var gpu = GPUS[gpuSel.value];
      var ram = RAM_OPTIONS[ramSel.value];
      var storage = STORAGE_OPTIONS[storageSel.value];
      var psu = PSU_OPTIONS[psuSel.value];
      var pcCase = CASE_OPTIONS[caseSel.value];
      if (!cpu || !gpu) return;

      var total = cpu.price + gpu.price + ram.price + storage.price + psu.price + pcCase.price;

      var text = 'Gaming PC Build — $' + total.toLocaleString() + '\n';
      text += '═'.repeat(45) + '\n';
      text += 'CPU: ' + cpu.name + ' ($' + cpu.price + ')\n';
      text += 'GPU: ' + gpu.name + ' ($' + gpu.price + ')\n';
      text += 'RAM: ' + ram.name + ' ($' + ram.price + ')\n';
      text += 'Storage: ' + storage.name + ' ($' + storage.price + ')\n';
      text += 'PSU: ' + psu.name + ' ($' + psu.price + ')\n';
      text += 'Case: ' + pcCase.name + ' ($' + pcCase.price + ')\n';
      text += '═'.repeat(45) + '\n';
      text += 'Estimated Avg FPS (1080p): ' + fps1080El.textContent + '\n';
      text += 'Estimated Avg FPS (1440p): ' + fps1440El.textContent + '\n';
      text += 'Estimated Avg FPS (4K): ' + fps4kEl.textContent + '\n';
      text += '\nGenerated by leeroyjenkins.quest/pc-build-configurator';

      navigator.clipboard.writeText(text).then(function() {
        copyFeedback.textContent = 'Copied!';
        copyFeedback.style.opacity = '1';
        setTimeout(function() { copyFeedback.style.opacity = '0'; }, 2000);
      }).catch(function() {
        copyFeedback.textContent = 'Copy failed — try selecting text manually';
        copyFeedback.style.opacity = '1';
        setTimeout(function() { copyFeedback.style.opacity = '0'; }, 3000);
      });
    });

    /* ── Auto-analyze on load ── */
    analyzeBuild();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Optimizer Cards */
    .optimizer-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.4rem 1.5rem; margin-bottom: 1rem; }
    .step-header { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.6rem; }
    .step-num { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: var(--accent-color); color: #fff; border-radius: 50%; font-size: 0.85rem; font-weight: 800; flex-shrink: 0; }

    /* Preset Grid */
    .preset-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.7rem; }
    .preset-btn { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; padding: 1rem 0.8rem; border-radius: 10px; border: 2px solid var(--border-color); background: transparent; color: var(--text-secondary); cursor: pointer; transition: all 0.15s; text-align: center; }
    .preset-btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .preset-tier { font-size: 0.85rem; font-weight: 700; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.04em; }
    .preset-price { font-size: 1.5rem; font-weight: 900; color: var(--accent-color); }
    .preset-desc { font-size: 0.75rem; color: var(--text-secondary); line-height: 1.3; }

    /* Component Dropdown */
    .component-dropdown { width: 100%; padding: 0.7rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-primary); font-size: 0.95rem; font-weight: 500; cursor: pointer; appearance: auto; }
    .component-dropdown:focus { outline: 2px solid var(--accent-color); outline-offset: 1px; }
    .component-dropdown optgroup { font-weight: 700; color: var(--text-primary); }
    .component-dropdown option { font-weight: 400; padding: 0.3rem; }

    /* Buttons */
    .btn { padding: 0.45rem 0.9rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn-primary { background: var(--accent-color); color: #fff; border-color: var(--accent-color); padding: 0.7rem 1.8rem; font-size: 1rem; font-weight: 700; }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { border-color: var(--border-color); color: var(--text-secondary); padding: 0.5rem 1.2rem; }
    .btn-secondary:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn-generate { width: 100%; margin-bottom: 1rem; }

    /* Cost Display */
    .cost-display { text-align: center; background: var(--card-bg); border: 2px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .cost-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; color: var(--text-secondary); margin-bottom: 0.3rem; }
    .cost-value { font-size: 2.5rem; font-weight: 900; color: var(--accent-color); }

    /* FPS Grid */
    .fps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; margin-bottom: 1.5rem; }
    .fps-card { text-align: center; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem; }
    .fps-res { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700; color: var(--text-secondary); margin-bottom: 0.2rem; }
    .fps-val { font-size: 1.8rem; font-weight: 900; color: var(--text-primary); }
    .fps-sub { font-size: 0.7rem; color: var(--text-secondary); }

    /* Game FPS Table */
    .table-wrapper { overflow-x: auto; border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 1rem; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.65rem 0.8rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.55rem 0.8rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* FPS Color Classes */
    .fps-great { color: #51cf66; font-weight: 700; }
    .fps-good { color: #ffc107; font-weight: 700; }
    .fps-ok { color: #ff922b; font-weight: 700; }
    .fps-bad { color: #ff6b6b; font-weight: 700; }

    /* Warnings */
    .warnings-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; margin-bottom: 1rem; }
    .warnings-container h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.8rem; }
    .warnings-container ul { list-style: none; padding-left: 0; margin-bottom: 0; }
    .warnings-container li { padding: 0.6rem 0.8rem; border-radius: 8px; margin-bottom: 0.5rem; font-size: 0.9rem; line-height: 1.5; }
    .warnings-container li:last-child { margin-bottom: 0; }
    .warn-danger { background: rgba(255,107,107,0.1); border-left: 3px solid #ff6b6b; }
    .warn-warning { background: rgba(255,193,7,0.1); border-left: 3px solid #ffc107; }
    .warn-info { background: rgba(100,149,237,0.1); border-left: 3px solid #6495ed; }
    .warn-good { background: rgba(81,207,102,0.1); border-left: 3px solid #51cf66; }

    /* Build Summary */
    .build-summary { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; margin-top: 1rem; }
    .build-summary h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.8rem; }
    .summary-table { font-size: 0.9rem; }
    .summary-table td:last-child { text-align: right; font-weight: 600; white-space: nowrap; }
    .summary-total td { border-top: 2px solid var(--border-color); padding-top: 0.7rem; }

    /* Copy Feedback */
    .copy-feedback { margin-left: 0.8rem; font-size: 0.85rem; color: var(--accent-color); font-weight: 600; opacity: 0; transition: opacity 0.3s; }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    /* Related */
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .related-link { display: flex; flex-direction: column; gap: 0.3rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem; text-decoration: none; transition: border-color 0.2s; }
    .related-link:hover { border-color: var(--accent-color); text-decoration: none; }
    .related-link strong { color: var(--text-primary); font-size: 1rem; }
    .related-link span { color: var(--text-secondary); font-size: 0.85rem; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .preset-grid { grid-template-columns: 1fr; }
      .fps-grid { grid-template-columns: 1fr; }
      .fps-val { font-size: 1.4rem; }
      .cost-value { font-size: 1.8rem; }
    }
  </style>
</SiteLayout>
