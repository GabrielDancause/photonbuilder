---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How much filler does One Piece have?",
    a: "One Piece has roughly 99 filler episodes out of 1,122 total — about 9% filler. This is remarkably low compared to other long-running shonen anime like Naruto (41% filler) and Bleach (45% filler). Most One Piece filler is concentrated in short 2-10 episode arcs inserted between major canon storylines, making it easy to skip without losing track of the plot."
  },
  {
    q: "Can I skip all One Piece filler episodes?",
    a: "Yes, you can safely skip every filler episode without missing any plot points from the manga. Filler arcs are standalone stories that don't affect the main storyline. However, some filler arcs like G-8 (episodes 196-206) are widely considered excellent and worth watching. The Ice Hunter Arc and some standalone filler episodes also have entertaining character moments. Our recommendation: skip filler on your first watch to maintain story momentum, then go back for the well-rated filler arcs."
  },
  {
    q: "What is the best One Piece filler arc?",
    a: "The G-8 Arc (episodes 196-206) is almost universally considered the best One Piece filler arc. It follows the Straw Hats after they fall from Skypiea into a Marine fortress, featuring clever comedy, great character writing, and the memorable antagonist Jonathan. Many fans consider it better than some canon arcs. Other well-regarded filler includes the Ice Hunter Arc (326-335) and some of the standalone filler episodes that expand on crew dynamics."
  },
  {
    q: "What are mixed episodes in One Piece?",
    a: "Mixed episodes contain both canon material from the manga and anime-original (filler) content. This typically happens when the anime catches up to the manga and needs to pad episodes with extra scenes, extended flashbacks, or added subplot material. Mixed episodes usually contain important canon scenes you shouldn't skip, but they may feel slower-paced than pure canon episodes. We mark these as 'mixed' so you know to expect some padding."
  },
  {
    q: "How long would it take to watch One Piece skipping filler?",
    a: "With 1,122 episodes and roughly 99 being filler, you'd watch about 1,023 canon/mixed episodes. At approximately 24 minutes per episode (skipping opening/ending), that's about 409 hours or 17 days of continuous watching. At a pace of 5 episodes per day, it would take roughly 205 days. Skipping filler saves you about 40 hours of watch time compared to watching everything."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "One Piece Filler List — Complete Episode Guide",
    "description": "Complete One Piece filler episode guide covering all 1,122 episodes. Filter canon, filler, and mixed episodes. Track your progress with built-in watchlist.",
    "applicationCategory": "Entertainment",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "One Piece Filler List: Every Episode Guide (Canon vs Filler)",
  description: "Complete One Piece filler guide for all 1,122 episodes. See which episodes are canon, filler, or mixed. Track your progress, skip filler, and save 40+ hours.",
  category: "tool",
  published: "2026-03-29",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="One Piece Filler List: Every Episode Guide (Canon vs Filler)"
  description="Complete One Piece filler guide for all 1,122 episodes. See which episodes are canon, filler, or mixed. Track your progress, skip filler, and save 40+ hours."
  canonical="https://leeroyjenkins.quest/one-piece-filler-list"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>One Piece Filler List</h1>
      <p>Complete episode guide for all 1,122 episodes. Every episode classified as canon, filler, or mixed — with progress tracking.</p>
    </div>

    <section class="content-section">
      <!-- Stats Dashboard -->
      <div class="stats-dashboard" id="stats-dashboard">
        <div class="stat-card">
          <span class="stat-number" id="stat-total">1,122</span>
          <span class="stat-label">Total Episodes</span>
        </div>
        <div class="stat-card canon">
          <span class="stat-number" id="stat-canon">0</span>
          <span class="stat-label">Canon</span>
        </div>
        <div class="stat-card filler">
          <span class="stat-number" id="stat-filler">0</span>
          <span class="stat-label">Filler</span>
        </div>
        <div class="stat-card mixed">
          <span class="stat-number" id="stat-mixed">0</span>
          <span class="stat-label">Mixed</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-pct">0%</span>
          <span class="stat-label">Filler %</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-saved">0h</span>
          <span class="stat-label">Time Saved Skipping Filler</span>
        </div>
      </div>

      <!-- Progress Bar -->
      <div class="progress-section">
        <div class="progress-header">
          <h2>Your Watch Progress</h2>
          <span class="progress-text" id="progress-text">0 / 1,122 watched (0%)</span>
        </div>
        <div class="progress-bar-track">
          <div class="progress-bar-fill" id="progress-fill" style="width:0%"></div>
        </div>
        <div class="progress-actions">
          <button class="btn btn-sm" id="mark-canon-btn">Mark All Canon Watched</button>
          <button class="btn btn-sm" id="clear-progress-btn">Clear Progress</button>
        </div>
      </div>

      <!-- Filters -->
      <div class="filter-bar">
        <div class="filter-group">
          <label>Filter</label>
          <div class="btn-group" id="type-filter">
            <button class="btn active" data-filter="all">All</button>
            <button class="btn canon-btn" data-filter="canon">Canon</button>
            <button class="btn filler-btn" data-filter="filler">Filler</button>
            <button class="btn mixed-btn" data-filter="mixed">Mixed</button>
          </div>
        </div>
        <div class="filter-group search-group">
          <label>Search</label>
          <input type="text" id="search-input" placeholder="Episode # or arc name..." class="search-input" />
        </div>
        <div class="filter-group">
          <label>View</label>
          <div class="btn-group" id="view-toggle">
            <button class="btn active" data-view="arc">Arc View</button>
            <button class="btn" data-view="table">Table View</button>
          </div>
        </div>
      </div>

      <!-- Quick Skip Guide -->
      <div class="skip-guide" id="skip-guide">
        <h2>Quick Skip Guide</h2>
        <p>In a hurry? Here's exactly what to skip and what to watch. All filler arcs listed below can be skipped without missing any story from the manga.</p>
        <div class="skip-columns">
          <div class="skip-col skip-list">
            <h3>Skip These (Filler)</h3>
            <ul id="skip-list"></ul>
          </div>
          <div class="skip-col watch-list">
            <h3>Worth Watching (Filler)</h3>
            <ul>
              <li><strong>G-8 Arc (196-206)</strong> — Best filler in the series. The crew infiltrates a Marine base after Skypiea. Funny, clever, and has a great original antagonist.</li>
              <li><strong>Ice Hunter Arc (326-335)</strong> — Fun adventure with the crew fighting bounty hunters. Good character dynamics.</li>
              <li><strong>Little East Blue Arc (426-429)</strong> — Movie tie-in filler but features nice callbacks to East Blue.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Arc View -->
      <div id="arc-view">
        <h2>Episode Guide by Arc</h2>
        <div id="arc-container"></div>
      </div>

      <!-- Table View -->
      <div id="table-view" style="display:none">
        <h2>Episode Table</h2>
        <div class="table-wrapper">
          <table id="episode-table">
            <thead>
              <tr>
                <th class="th-check"><input type="checkbox" id="check-all" title="Toggle all visible" /></th>
                <th class="th-ep sortable" data-sort="ep">Ep #</th>
                <th class="th-arc">Arc</th>
                <th class="th-type sortable" data-sort="type">Type</th>
              </tr>
            </thead>
            <tbody id="episode-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- Content -->
      <h2>About One Piece Filler Episodes</h2>
      <p>One Piece is one of the longest-running anime series in history, with over 1,100 episodes since its debut in 1999. Unlike many long-running shonen series, One Piece has a remarkably low filler percentage — roughly 9% compared to Naruto's 41% and Bleach's 45%. This is largely because the One Piece anime has historically used slower pacing and extended scenes rather than full filler arcs to avoid catching up to the manga.</p>

      <p>That said, the series does contain several filler arcs and standalone filler episodes. These are anime-original stories not based on Eiichiro Oda's manga. While none are required for understanding the main plot, some filler arcs — particularly the G-8 Arc — are beloved by fans and considered worth watching.</p>

      <h3>How We Classify Episodes</h3>
      <p><strong>Canon</strong> episodes adapt material directly from the One Piece manga. These are essential to the story and should never be skipped.</p>
      <p><strong>Filler</strong> episodes are entirely anime-original content not found in the manga. They can be safely skipped without missing any plot points.</p>
      <p><strong>Mixed</strong> episodes contain both canon manga material and anime-original additions. These usually have important canon scenes padded with extra filler content. We recommend watching mixed episodes since they contain canon material.</p>

      <h3>Filler by Saga</h3>
      <p><strong>East Blue Saga (1-61):</strong> Only one filler arc — Warship Island (54-61). A short detour before the Grand Line with an original dragon storyline.</p>
      <p><strong>Alabasta Saga (62-135):</strong> A few standalone filler episodes (98-99, 102) plus the Post-Alabasta Arc (131-135) with character-focused side stories.</p>
      <p><strong>Sky Island Saga (136-206):</strong> Goat Island (136-138), Ruluka Island (139-143), and the fan-favorite G-8 Arc (196-206).</p>
      <p><strong>Water 7 Saga (207-325):</strong> Extra Davy Back rounds (213-216), Ocean's Dream (220-224), Foxy's Return (225-226), plus several standalone episodes within Enies Lobby.</p>
      <p><strong>Thriller Bark Saga (326-384):</strong> Ice Hunter Arc (326-335) and Spa Island (382-384).</p>
      <p><strong>Summit War Saga (385-516):</strong> Standalone filler (406-407), Little East Blue (426-429), and a couple of extra episodes (457-458).</p>
      <p><strong>Fishman Island & Punk Hazard (517-628):</strong> Z's Ambition (575-578), an episode 590 filler, and Caesar Retrieval (626-628).</p>
      <p><strong>Dressrosa & Beyond (629-896):</strong> Silver Mine (747-750), Marine Rookie (780-782), and Cidre Guild (895-896).</p>
      <p><strong>Wano & Egghead (897-1122):</strong> No filler arcs. Wano is entirely canon material adapted from the manga.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/xp-calculator" class="related-link">
          <strong>XP Calculator</strong>
          <span>Calculate experience points and leveling for popular games</span>
        </a>
        <a href="/best-streaming-setup" class="related-link">
          <strong>Best Streaming Setup 2026</strong>
          <span>Everything you need to start streaming anime watch-alongs</span>
        </a>
        <a href="/bandwidth-calculator" class="related-link">
          <strong>Bandwidth Calculator</strong>
          <span>Check if your internet can handle streaming anime in HD</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ─── Episode Data ─── */
    /* Each arc: { name, saga, ranges: [[start, end, type], ...], desc } */
    /* type: 'c' = canon, 'f' = filler, 'm' = mixed */
    const ARCS = [
      { name: 'Romance Dawn', saga: 'East Blue', ranges: [[1,3,'c']], desc: 'Luffy sets out from Foosha Village to become King of the Pirates, meeting Coby and defeating Alvida.' },
      { name: 'Orange Town', saga: 'East Blue', ranges: [[4,8,'c']], desc: 'Luffy and Zoro arrive at Orange Town and battle Buggy the Clown. Nami joins the crew.' },
      { name: 'Syrup Village', saga: 'East Blue', ranges: [[9,18,'c']], desc: 'The crew meets Usopp and defends his village from Captain Kuro. They acquire the Going Merry.' },
      { name: 'Baratie', saga: 'East Blue', ranges: [[19,30,'c']], desc: 'Luffy works at the floating restaurant Baratie and recruits Sanji. Don Krieg attacks.' },
      { name: 'Arlong Park', saga: 'East Blue', ranges: [[31,44,'c']], desc: 'The crew travels to Nami\'s home island to free it from the tyrannical Fish-Man Arlong.' },
      { name: 'Loguetown', saga: 'East Blue', ranges: [[45,53,'c']], desc: 'The crew visits the town where Gold Roger was executed. Smoker and Dragon appear.' },
      { name: 'Warship Island', saga: 'East Blue', ranges: [[54,61,'f']], desc: 'Filler arc. The crew helps a girl named Apis return a dragon to its homeland.' },
      { name: 'Reverse Mountain', saga: 'Alabasta', ranges: [[62,63,'c']], desc: 'The crew enters the Grand Line through Reverse Mountain and meets Laboon the whale.' },
      { name: 'Whisky Peak', saga: 'Alabasta', ranges: [[64,67,'c']], desc: 'A town of bounty hunters welcomes the Straw Hats. Zoro fights the agents of Baroque Works.' },
      { name: 'Little Garden', saga: 'Alabasta', ranges: [[68,77,'c']], desc: 'The crew lands on a prehistoric island where two giants have been dueling for 100 years.' },
      { name: 'Drum Island', saga: 'Alabasta', ranges: [[78,91,'c']], desc: 'Nami falls ill, leading the crew to Drum Island where they meet Tony Tony Chopper.' },
      { name: 'Alabasta', saga: 'Alabasta', ranges: [[92,97,'c'],[98,99,'f'],[100,101,'c'],[102,102,'f'],[103,130,'c']], desc: 'The crew arrives in Alabasta to help Vivi stop Crocodile and Baroque Works from destroying the kingdom.' },
      { name: 'Post-Alabasta', saga: 'Alabasta', ranges: [[131,135,'f']], desc: 'Filler arc. Standalone episodes focusing on individual crew members after leaving Alabasta.' },
      { name: 'Goat Island', saga: 'Sky Island', ranges: [[136,138,'f']], desc: 'Filler arc. The crew encounters an old man living alone on an island with goats.' },
      { name: 'Ruluka Island', saga: 'Sky Island', ranges: [[139,143,'f']], desc: 'Filler arc. The crew gets caught in a time-loop phenomenon called the Rainbow Mist.' },
      { name: 'Jaya', saga: 'Sky Island', ranges: [[144,152,'c']], desc: 'The crew learns about Sky Island from Mont Blanc Cricket and clashes with Bellamy.' },
      { name: 'Skypiea', saga: 'Sky Island', ranges: [[153,195,'c']], desc: 'The Straw Hats reach the sky island of Skypiea and battle the self-proclaimed god Enel.' },
      { name: 'G-8', saga: 'Sky Island', ranges: [[196,206,'f']], desc: 'Filler arc. After falling from Skypiea, the crew lands in a Marine fortress and must escape. Widely considered the best filler in the series.' },
      { name: 'Long Ring Long Land', saga: 'Water 7', ranges: [[207,212,'c'],[213,216,'f'],[217,219,'c']], desc: 'The crew participates in the Davy Back Fight against the Foxy Pirates. Episodes 213-216 are anime-original extra rounds.' },
      { name: "Ocean's Dream", saga: 'Water 7', ranges: [[220,224,'f']], desc: 'Filler arc. The crew loses their memories and must figure out who they are and why they\'re together.' },
      { name: "Foxy's Return", saga: 'Water 7', ranges: [[225,226,'f']], desc: 'Filler arc. Foxy challenges the Straw Hats to another Davy Back Fight.' },
      { name: 'Water 7', saga: 'Water 7', ranges: [[227,263,'c']], desc: 'The crew arrives at Water 7 seeking ship repairs. Robin disappears and the crew faces CP9.' },
      { name: 'Enies Lobby', saga: 'Water 7', ranges: [[264,278,'c'],[279,283,'f'],[284,290,'c'],[291,292,'f'],[293,302,'c'],[303,303,'f'],[304,312,'c']], desc: 'The Straw Hats storm the judicial island to rescue Robin from the World Government.' },
      { name: 'Post-Enies Lobby', saga: 'Water 7', ranges: [[313,316,'c'],[317,319,'f'],[320,325,'c']], desc: 'The crew recovers after Enies Lobby. Franky officially joins and the Thousand Sunny is built.' },
      { name: 'Ice Hunter', saga: 'Thriller Bark', ranges: [[326,335,'f']], desc: 'Filler arc. The crew encounters the Accino Family, a group of bounty hunters in an icy region.' },
      { name: 'Thriller Bark', saga: 'Thriller Bark', ranges: [[336,381,'c']], desc: 'The crew enters the Florian Triangle and battles Gecko Moria on his zombie-filled ship. Brook joins the crew.' },
      { name: 'Spa Island', saga: 'Thriller Bark', ranges: [[382,384,'f']], desc: 'Filler arc. The crew visits a resort island that hides a sinister secret.' },
      { name: 'Sabaody Archipelago', saga: 'Summit War', ranges: [[385,405,'c']], desc: 'The crew reaches Sabaody near the Red Line. They meet the Supernovas and face a Pacifista.' },
      { name: 'Sabaody Filler', saga: 'Summit War', ranges: [[406,407,'f']], desc: 'Standalone filler episodes set around Sabaody Archipelago.' },
      { name: 'Amazon Lily', saga: 'Summit War', ranges: [[408,421,'c']], desc: 'Luffy lands on the island of women warriors and meets Boa Hancock.' },
      { name: 'Impel Down (Part 1)', saga: 'Summit War', ranges: [[422,425,'c']], desc: 'Luffy breaks into the underwater prison Impel Down to save Ace.' },
      { name: 'Little East Blue', saga: 'Summit War', ranges: [[426,429,'f']], desc: 'Filler arc. Movie tie-in featuring an island that recreates East Blue.' },
      { name: 'Impel Down (Part 2)', saga: 'Summit War', ranges: [[430,456,'c']], desc: 'Luffy descends through the levels of Impel Down, allying with former enemies to rescue Ace.' },
      { name: 'Impel Down Filler', saga: 'Summit War', ranges: [[457,458,'f']], desc: 'Standalone filler episodes during the Impel Down saga.' },
      { name: 'Marineford', saga: 'Summit War', ranges: [[459,489,'c']], desc: 'The war between the Whitebeard Pirates and the Marines at Marineford. One of the most pivotal arcs in the series.' },
      { name: 'Post-War', saga: 'Summit War', ranges: [[490,491,'c'],[492,492,'f'],[493,516,'c']], desc: 'Luffy recovers from the war. The crew trains for two years across the world.' },
      { name: 'Return to Sabaody', saga: 'Fish-Man Island', ranges: [[517,522,'c']], desc: 'The Straw Hats reunite after the two-year timeskip and depart for the New World.' },
      { name: 'Fish-Man Island', saga: 'Fish-Man Island', ranges: [[523,574,'c']], desc: 'The crew journeys to Fish-Man Island and battles Hody Jones to protect the undersea kingdom.' },
      { name: "Z's Ambition", saga: 'Fish-Man Island', ranges: [[575,578,'f']], desc: 'Filler arc. Movie tie-in featuring former Marine admiral Z.' },
      { name: 'Punk Hazard', saga: 'Dressrosa', ranges: [[579,589,'c'],[590,590,'f'],[591,625,'c']], desc: 'The crew investigates a devastated island and clashes with Caesar Clown. The alliance with Law begins.' },
      { name: 'Caesar Retrieval', saga: 'Dressrosa', ranges: [[626,628,'f']], desc: 'Filler arc. The crew chases down Caesar after he escapes custody.' },
      { name: 'Dressrosa', saga: 'Dressrosa', ranges: [[629,746,'c']], desc: 'Luffy and Law challenge Doflamingo in the kingdom of Dressrosa. The Straw Hat Grand Fleet is formed.' },
      { name: 'Silver Mine', saga: 'Dressrosa', ranges: [[747,750,'f']], desc: 'Filler arc. Movie tie-in. Luffy and Bartolomeo are captured by the Silver Pirate Alliance.' },
      { name: 'Zou', saga: 'Four Emperors', ranges: [[751,779,'c']], desc: 'The crew reaches Zou, a civilization on the back of a giant elephant, and learns about the Road Poneglyphs.' },
      { name: 'Marine Rookie', saga: 'Four Emperors', ranges: [[780,782,'f']], desc: 'Filler arc. The crew encounters ambitious Marine rookies at a military base.' },
      { name: 'Whole Cake Island', saga: 'Four Emperors', ranges: [[783,877,'c']], desc: 'Luffy infiltrates Big Mom\'s territory to rescue Sanji from a political marriage.' },
      { name: 'Reverie', saga: 'Four Emperors', ranges: [[878,889,'c']], desc: 'World leaders gather at Mary Geoise. Major political developments unfold.' },
      { name: 'Wano (Act 1)', saga: 'Four Emperors', ranges: [[890,894,'c']], desc: 'The crew arrives in Wano Country, a land isolated from the world and ruled by Kaido.' },
      { name: 'Cidre Guild', saga: 'Four Emperors', ranges: [[895,896,'f']], desc: 'Filler arc. Movie tie-in. Luffy encounters the Cidre Guild, a group of carbonated water pirates.' },
      { name: 'Wano (Acts 2-4)', saga: 'Four Emperors', ranges: [[897,1085,'c']], desc: 'The Straw Hat alliance wages war against Kaido and Big Mom in the raid on Onigashima. One of the longest continuous canon stretches in the series.' },
      { name: 'Egghead', saga: 'Final', ranges: [[1086,1122,'c']], desc: 'The crew arrives at the futuristic island Egghead, home of Dr. Vegapunk. Major world-shaking revelations unfold.' }
    ];

    /* ─── Derived data ─── */
    const TOTAL_EPS = 1122;
    const EP_MINUTES = 24;
    let episodeMap = {}; /* ep# -> { ep, arc, saga, type } */
    let arcList = [];

    function initData() {
      ARCS.forEach(function(arc) {
        var arcEps = [];
        arc.ranges.forEach(function(r) {
          for (var i = r[0]; i <= r[1]; i++) {
            var type = r[2] === 'c' ? 'canon' : r[2] === 'f' ? 'filler' : 'mixed';
            var entry = { ep: i, arc: arc.name, saga: arc.saga, type: type };
            episodeMap[i] = entry;
            arcEps.push(entry);
          }
        });
        arcList.push({ name: arc.name, saga: arc.saga, desc: arc.desc, episodes: arcEps, startEp: arcEps[0].ep, endEp: arcEps[arcEps.length - 1].ep });
      });
    }
    initData();

    /* Count types */
    var counts = { canon: 0, filler: 0, mixed: 0 };
    for (var k in episodeMap) counts[episodeMap[k].type]++;

    document.getElementById('stat-total').textContent = TOTAL_EPS.toLocaleString();
    document.getElementById('stat-canon').textContent = counts.canon.toLocaleString();
    document.getElementById('stat-filler').textContent = counts.filler.toLocaleString();
    document.getElementById('stat-mixed').textContent = counts.mixed.toLocaleString();
    document.getElementById('stat-pct').textContent = Math.round((counts.filler / TOTAL_EPS) * 100) + '%';
    document.getElementById('stat-saved').textContent = Math.round((counts.filler * EP_MINUTES) / 60) + 'h';

    /* ─── Skip Guide ─── */
    var fillerArcs = arcList.filter(function(a) {
      return a.episodes.every(function(e) { return e.type === 'filler'; });
    });
    var skipUl = document.getElementById('skip-list');
    fillerArcs.forEach(function(a) {
      var li = document.createElement('li');
      li.innerHTML = '<strong>' + a.name + ' (' + a.startEp + '-' + a.endEp + ')</strong> — ' + a.episodes.length + ' episodes';
      skipUl.appendChild(li);
    });

    /* ─── localStorage progress ─── */
    var STORAGE_KEY = 'opFillerWatched';
    function getWatched() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch(e) { return {}; }
    }
    function setWatched(obj) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(obj));
    }
    function toggleWatched(ep) {
      var w = getWatched();
      if (w[ep]) delete w[ep]; else w[ep] = 1;
      setWatched(w);
      updateProgress();
    }
    function isWatched(ep) {
      return !!getWatched()[ep];
    }
    function updateProgress() {
      var w = getWatched();
      var count = Object.keys(w).length;
      var pct = Math.round((count / TOTAL_EPS) * 100);
      document.getElementById('progress-text').textContent = count.toLocaleString() + ' / ' + TOTAL_EPS.toLocaleString() + ' watched (' + pct + '%)';
      document.getElementById('progress-fill').style.width = pct + '%';
      /* Update visible checkboxes */
      document.querySelectorAll('.ep-check').forEach(function(cb) {
        cb.checked = !!w[cb.dataset.ep];
      });
    }

    document.getElementById('mark-canon-btn').addEventListener('click', function() {
      if (!confirm('Mark all canon episodes as watched?')) return;
      var w = getWatched();
      for (var k in episodeMap) {
        if (episodeMap[k].type === 'canon') w[k] = 1;
      }
      setWatched(w);
      updateProgress();
    });
    document.getElementById('clear-progress-btn').addEventListener('click', function() {
      if (!confirm('Clear all watch progress?')) return;
      localStorage.removeItem(STORAGE_KEY);
      updateProgress();
    });

    /* ─── Filter state ─── */
    var currentFilter = 'all';
    var currentSearch = '';
    var currentView = 'arc';

    document.getElementById('type-filter').addEventListener('click', function(e) {
      var btn = e.target.closest('[data-filter]');
      if (!btn) return;
      this.querySelectorAll('.btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      render();
    });

    document.getElementById('search-input').addEventListener('input', function() {
      currentSearch = this.value.toLowerCase().trim();
      render();
    });

    document.getElementById('view-toggle').addEventListener('click', function(e) {
      var btn = e.target.closest('[data-view]');
      if (!btn) return;
      this.querySelectorAll('.btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentView = btn.dataset.view;
      render();
    });

    /* ─── Rendering ─── */
    function matchesFilter(entry) {
      if (currentFilter !== 'all' && entry.type !== currentFilter) return false;
      if (currentSearch) {
        var s = currentSearch;
        if (/^\d+$/.test(s)) {
          return entry.ep === parseInt(s);
        }
        if (/^\d+\s*-\s*\d+$/.test(s)) {
          var parts = s.split('-').map(function(x) { return parseInt(x.trim()); });
          return entry.ep >= parts[0] && entry.ep <= parts[1];
        }
        return entry.arc.toLowerCase().indexOf(s) !== -1 || entry.saga.toLowerCase().indexOf(s) !== -1;
      }
      return true;
    }

    function arcMatchesFilter(arc) {
      return arc.episodes.some(matchesFilter);
    }

    function typeBadge(type) {
      return '<span class="type-badge type-' + type + '">' + type.charAt(0).toUpperCase() + type.slice(1) + '</span>';
    }

    function epCheckbox(ep) {
      return '<input type="checkbox" class="ep-check" data-ep="' + ep + '"' + (isWatched(ep) ? ' checked' : '') + ' />';
    }

    function renderArcView() {
      var container = document.getElementById('arc-container');
      var html = '';
      arcList.forEach(function(arc) {
        if (!arcMatchesFilter(arc)) return;
        var visibleEps = arc.episodes.filter(matchesFilter);
        if (visibleEps.length === 0) return;
        var types = {};
        arc.episodes.forEach(function(e) { types[e.type] = true; });
        var arcType = Object.keys(types).length === 1 ? Object.keys(types)[0] : 'mixed';
        var watchedCount = arc.episodes.filter(function(e) { return isWatched(e.ep); }).length;
        var arcPct = Math.round((watchedCount / arc.episodes.length) * 100);

        html += '<details class="arc-card" open>';
        html += '<summary class="arc-header">';
        html += '<div class="arc-header-left">';
        html += '<span class="arc-name">' + arc.name + '</span>';
        html += '<span class="arc-range">Ep ' + arc.startEp + '-' + arc.endEp + ' · ' + arc.episodes.length + ' eps · ' + arc.saga + '</span>';
        html += '</div>';
        html += '<div class="arc-header-right">';
        html += typeBadge(arcType);
        html += '<span class="arc-progress">' + arcPct + '%</span>';
        html += '</div>';
        html += '</summary>';
        html += '<div class="arc-body">';
        html += '<p class="arc-desc">' + arc.desc + '</p>';
        html += '<div class="arc-episodes">';

        /* Group consecutive episodes of same type for compact display */
        var groups = [];
        var current = null;
        visibleEps.forEach(function(e) {
          if (current && current.type === e.type && e.ep === current.endEp + 1) {
            current.endEp = e.ep;
            current.eps.push(e);
          } else {
            current = { type: e.type, startEp: e.ep, endEp: e.ep, eps: [e] };
            groups.push(current);
          }
        });

        groups.forEach(function(g) {
          var rangeStr = g.startEp === g.endEp ? 'Ep ' + g.startEp : 'Ep ' + g.startEp + '-' + g.endEp;
          html += '<div class="ep-group ep-group-' + g.type + '">';
          html += '<div class="ep-group-header">';
          html += '<span>' + rangeStr + '</span>';
          html += typeBadge(g.type);
          html += '</div>';
          html += '<div class="ep-group-checks">';
          g.eps.forEach(function(e) {
            html += '<label class="ep-label" title="Episode ' + e.ep + '">' + epCheckbox(e.ep) + '<span>' + e.ep + '</span></label>';
          });
          html += '</div>';
          html += '</div>';
        });

        html += '</div></div></details>';
      });
      container.innerHTML = html || '<p style="color:var(--text-secondary);text-align:center;padding:2rem;">No episodes match your filters.</p>';
    }

    function renderTableView() {
      var tbody = document.getElementById('episode-tbody');
      var html = '';
      var allEps = [];
      for (var i = 1; i <= TOTAL_EPS; i++) {
        if (episodeMap[i] && matchesFilter(episodeMap[i])) {
          allEps.push(episodeMap[i]);
        }
      }
      allEps.forEach(function(e) {
        html += '<tr class="row-' + e.type + '">';
        html += '<td>' + epCheckbox(e.ep) + '</td>';
        html += '<td>' + e.ep + '</td>';
        html += '<td>' + e.arc + '</td>';
        html += '<td>' + typeBadge(e.type) + '</td>';
        html += '</tr>';
      });
      tbody.innerHTML = html || '<tr><td colspan="4" style="text-align:center;color:var(--text-secondary);padding:2rem;">No episodes match your filters.</td></tr>';
    }

    function render() {
      document.getElementById('arc-view').style.display = currentView === 'arc' ? '' : 'none';
      document.getElementById('table-view').style.display = currentView === 'table' ? '' : 'none';
      if (currentView === 'arc') renderArcView();
      else renderTableView();
    }

    /* Delegated click handler for checkboxes */
    document.addEventListener('change', function(e) {
      if (e.target.classList.contains('ep-check')) {
        toggleWatched(e.target.dataset.ep);
      }
    });

    document.getElementById('check-all').addEventListener('change', function() {
      var checked = this.checked;
      document.querySelectorAll('.ep-check').forEach(function(cb) {
        var ep = cb.dataset.ep;
        var w = getWatched();
        if (checked) w[ep] = 1; else delete w[ep];
        setWatched(w);
        cb.checked = checked;
      });
      updateProgress();
    });

    /* Initial render */
    render();
    updateProgress();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Stats Dashboard */
    .stats-dashboard { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
    .stat-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 0.75rem; text-align: center; display: flex; flex-direction: column; gap: 0.2rem; }
    .stat-number { font-size: 1.6rem; font-weight: 800; color: var(--text-primary); }
    .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); font-weight: 600; }
    .stat-card.canon { border-color: #2b8a3e; }
    .stat-card.canon .stat-number { color: #51cf66; }
    .stat-card.filler { border-color: #c92a2a; }
    .stat-card.filler .stat-number { color: #ff6b6b; }
    .stat-card.mixed { border-color: #e67700; }
    .stat-card.mixed .stat-number { color: #ffd43b; }

    /* Progress */
    .progress-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; margin-bottom: 1.5rem; }
    .progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem; }
    .progress-header h2 { font-size: 1.1rem; margin: 0; color: var(--text-primary); }
    .progress-text { font-size: 0.9rem; color: var(--text-secondary); font-weight: 600; }
    .progress-bar-track { height: 10px; background: var(--border-color); border-radius: 5px; overflow: hidden; }
    .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #51cf66, #37b24d); border-radius: 5px; transition: width 0.3s; }
    .progress-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }

    /* Filters */
    .filter-bar { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end; margin-bottom: 1.5rem; }
    .filter-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .filter-group label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); }
    .search-group { flex: 1; min-width: 180px; }
    .search-input { width: 100%; padding: 0.45rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-primary); font-size: 0.9rem; outline: none; }
    .search-input:focus { border-color: var(--accent-color); }
    .search-input::placeholder { color: var(--text-secondary); opacity: 0.6; }
    .btn-group { display: flex; gap: 0.3rem; }
    .btn { padding: 0.45rem 0.9rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn.active { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }
    .btn-sm { padding: 0.3rem 0.7rem; font-size: 0.8rem; }
    .canon-btn.active { background: #2b8a3e; border-color: #2b8a3e; }
    .filler-btn.active { background: #c92a2a; border-color: #c92a2a; }
    .mixed-btn.active { background: #e67700; border-color: #e67700; }

    /* Type Badges */
    .type-badge { display: inline-block; padding: 0.15rem 0.55rem; border-radius: 4px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; }
    .type-canon { background: rgba(43,138,62,0.2); color: #51cf66; }
    .type-filler { background: rgba(201,42,42,0.2); color: #ff6b6b; }
    .type-mixed { background: rgba(230,119,0,0.2); color: #ffd43b; }

    /* Skip Guide */
    .skip-guide { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .skip-guide h2 { margin-top: 0; font-size: 1.4rem; color: var(--text-primary); }
    .skip-guide h3 { font-size: 1.1rem; margin-top: 0; margin-bottom: 0.5rem; }
    .skip-guide p { color: var(--text-secondary); margin-bottom: 1rem; }
    .skip-columns { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .skip-col { padding: 1rem; border-radius: 8px; }
    .skip-list { background: rgba(201,42,42,0.08); border: 1px solid rgba(201,42,42,0.2); }
    .skip-list h3 { color: #ff6b6b; }
    .watch-list { background: rgba(43,138,62,0.08); border: 1px solid rgba(43,138,62,0.2); }
    .watch-list h3 { color: #51cf66; }
    .skip-col ul { padding-left: 1.2rem; margin: 0; }
    .skip-col li { margin-bottom: 0.4rem; color: var(--text-secondary); font-size: 0.9rem; }

    /* Arc View */
    .arc-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
    .arc-header { display: flex; justify-content: space-between; align-items: center; padding: 0.9rem 1.2rem; cursor: pointer; list-style: none; }
    .arc-header::-webkit-details-marker { display: none; }
    .arc-header::marker { display: none; content: ''; }
    .arc-header-left { display: flex; flex-direction: column; gap: 0.15rem; }
    .arc-name { font-weight: 700; font-size: 1rem; color: var(--text-primary); }
    .arc-range { font-size: 0.8rem; color: var(--text-secondary); }
    .arc-header-right { display: flex; align-items: center; gap: 0.75rem; }
    .arc-progress { font-size: 0.8rem; font-weight: 700; color: var(--text-secondary); min-width: 35px; text-align: right; }
    .arc-body { padding: 0 1.2rem 1rem; }
    .arc-desc { font-size: 0.88rem; color: var(--text-secondary); margin-bottom: 0.75rem; line-height: 1.5; }
    .arc-episodes { display: flex; flex-direction: column; gap: 0.4rem; }
    .ep-group { border-radius: 6px; padding: 0.5rem 0.75rem; }
    .ep-group-canon { background: rgba(43,138,62,0.06); border: 1px solid rgba(43,138,62,0.15); }
    .ep-group-filler { background: rgba(201,42,42,0.06); border: 1px solid rgba(201,42,42,0.15); }
    .ep-group-mixed { background: rgba(230,119,0,0.06); border: 1px solid rgba(230,119,0,0.15); }
    .ep-group-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.35rem; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); }
    .ep-group-checks { display: flex; flex-wrap: wrap; gap: 0.1rem; }
    .ep-label { display: inline-flex; align-items: center; gap: 0.2rem; padding: 0.15rem 0.35rem; border-radius: 4px; font-size: 0.75rem; color: var(--text-secondary); cursor: pointer; transition: background 0.15s; }
    .ep-label:hover { background: rgba(255,255,255,0.06); }
    .ep-check { width: 14px; height: 14px; accent-color: #51cf66; cursor: pointer; }

    /* Table View */
    .table-wrapper { overflow-x: auto; border: 1px solid var(--border-color); border-radius: 12px; max-height: 600px; overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    thead { position: sticky; top: 0; z-index: 2; }
    th { background: var(--card-bg); padding: 0.65rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.45rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    .row-canon:hover td { background: rgba(43,138,62,0.05); }
    .row-filler:hover td { background: rgba(201,42,42,0.05); }
    .row-mixed:hover td { background: rgba(230,119,0,0.05); }
    .th-check { width: 30px; }
    .th-ep { width: 60px; }
    .th-type { width: 80px; }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
