      .filter-bar { flex-direction: column; align-items: stretch; }
      .btn-group { flex-wrap: wrap; }
      .arc-header { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
      .arc-header-right { align-self: flex-end; }
    }
  </style>
</SiteLayout>
