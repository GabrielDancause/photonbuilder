---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "What is a good reaction time?",
    a: "The average human visual reaction time is about 250ms. Anything under 200ms is considered fast, and under 150ms is exceptional — typically only seen in competitive gamers and trained athletes. Most people fall between 200-300ms. Age, sleep, caffeine, and practice all affect your results. Don't worry if your first few attempts are slow — reaction time improves significantly with practice and warming up."
  },
  {
    q: "How accurate is this reaction time test?",
    a: "This test measures the time between the screen turning green and your mouse click, using the browser's high-resolution performance.now() timer (accurate to fractions of a millisecond). Your actual result includes input lag from your monitor (typically 5-15ms), mouse (1-8ms depending on polling rate), and browser rendering. For consistent comparisons, always test on the same setup. The 5-attempt average smooths out outliers for a more reliable score."
  },
  {
    q: "Why is my reaction time different on different devices?",
    a: "Display latency is the biggest factor. A 60Hz monitor adds ~16ms of frame delay compared to ~4ms on a 240Hz display. Wireless mice add 1-4ms versus wired. Bluetooth can add 10-30ms. Even your browser matters — Chrome and Edge tend to have slightly lower input lag than Firefox. For the most accurate measurement, use a wired mouse on a high-refresh-rate monitor with hardware acceleration enabled in your browser."
  },
  {
    q: "Can I improve my reaction time?",
    a: "Yes, but within biological limits. Most people can improve by 20-40ms through regular practice. Sleep is the single biggest factor — reaction time degrades by 20-30% when sleep-deprived. Caffeine can improve reaction time by 10-20ms for most people. Regular cardiovascular exercise has been shown to improve reaction time long-term. Playing fast-paced video games also trains your visual processing speed. However, your baseline is partly genetic — some people are naturally faster reactors."
  },
  {
    q: "What's the fastest human reaction time ever recorded?",
    a: "In controlled laboratory settings, the fastest simple visual reaction times are around 120ms. In sprinting, the IAAF considers any reaction time under 100ms to be a false start, as it's believed to be physiologically impossible to genuinely react that fast to a gunshot. In gaming, some professional players have recorded consistent averages around 140-150ms on click-based tests, though in-game reaction times are slower due to decision-making overhead."
  },
  {
    q: "Does age affect reaction time?",
    a: "Yes. Reaction time peaks in your mid-20s and gradually slows after that. A typical 20-year-old averages around 230ms, while a 60-year-old averages around 330ms. However, this is a general trend — an active, well-rested 50-year-old can outperform a sleep-deprived 20-year-old. Regular practice, exercise, and good sleep habits can offset much of the age-related decline. Professional athletes in their 30s often maintain excellent reaction times through training."
  },
  {
    q: "What's the difference between reaction time and reflex?",
    a: "A reflex is an involuntary, automatic response (like pulling your hand from a hot stove) that bypasses the brain via the spinal cord — these are around 50-80ms. Reaction time is a voluntary, conscious response to a stimulus (like clicking when the screen turns green) that requires brain processing — typically 150-300ms. This test measures voluntary reaction time. Reflexes can't really be trained, but voluntary reaction time can be improved with practice."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Reaction Time Test — Free Online Human Benchmark",
    "description": "Free reaction time test. Measure your reaction speed in milliseconds with 5 attempts. Compare your results to pro gamers and the average human.",
    "applicationCategory": "Game",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Reaction Time Test — Free Online Speed Test & Human Benchmark",
  description: "Test your reaction time in milliseconds. Click when the screen turns green. 5 attempts, average score, and comparison to pro gamers. Free, no download.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Reaction Time Test — Free Online Speed Test & Human Benchmark"
  description="Test your reaction time in milliseconds. Click when the screen turns green. 5 attempts, average score, and comparison to pro gamers. Free, no download."
  canonical="https://leeroyjenkins.quest/reaction-time-test"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Reaction Time Test</h1>
      <p>Measure your reaction speed in milliseconds. Wait for green, click as fast as you can. 5 attempts, averaged for accuracy.</p>
    </div>

    <section class="content-section">
      <!-- Test Area -->
      <div class="test-area" id="test-area">
        <div class="test-inner" id="test-inner">
          <div class="test-icon" id="test-icon">🖱️</div>
          <div class="test-msg" id="test-msg">Click anywhere to start</div>
          <div class="test-sub" id="test-sub">5 attempts — we'll average your results</div>
        </div>
      </div>

      <!-- Attempt Indicators -->
      <div class="attempt-dots" id="attempt-dots">
        <div class="dot" data-i="0"></div>
        <div class="dot" data-i="1"></div>
        <div class="dot" data-i="2"></div>
        <div class="dot" data-i="3"></div>
        <div class="dot" data-i="4"></div>
      </div>

      <!-- Results Panel (shown after 5 attempts) -->
      <div class="results-panel" id="results-panel" style="display:none;">
        <h2>Your Results</h2>
        <div class="avg-result">
          <span class="avg-label">Average Reaction Time</span>
          <span class="avg-value" id="avg-value">—</span>
          <span class="avg-rating" id="avg-rating"></span>
        </div>

        <!-- Bar Chart -->
        <div class="chart-section">
          <h3>Attempts Breakdown</h3>
          <div class="bar-chart" id="bar-chart"></div>
        </div>

        <!-- Comparison Table -->
        <div class="comparison-section">
          <h3>How You Compare</h3>
          <div class="comparison-table">
            <div class="comp-row">
              <span class="comp-label">Pro Gamer</span>
              <div class="comp-bar-track"><div class="comp-bar" style="width:42.8%" data-ms="~150ms"></div></div>
            </div>
            <div class="comp-row">
              <span class="comp-label">Fast (top 15%)</span>
              <div class="comp-bar-track"><div class="comp-bar" style="width:57.1%" data-ms="~200ms"></div></div>
            </div>
            <div class="comp-row">
              <span class="comp-label">Average Human</span>
              <div class="comp-bar-track"><div class="comp-bar" style="width:71.4%" data-ms="~250ms"></div></div>
            </div>
            <div class="comp-row" id="comp-you">
              <span class="comp-label"><strong>You</strong></span>
              <div class="comp-bar-track"><div class="comp-bar comp-bar-you" id="comp-you-bar" style="width:0%" data-ms="—"></div></div>
            </div>
            <div class="comp-row">
              <span class="comp-label">Elderly (65+)</span>
              <div class="comp-bar-track"><div class="comp-bar" style="width:100%" data-ms="~350ms"></div></div>
            </div>
          </div>
        </div>

        <button class="btn btn-primary" id="try-again-btn">Try Again</button>
      </div>

      <!-- History -->
      <h2>Session History</h2>
      <div class="table-wrapper">
        <table id="history-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Average</th>
              <th>Best</th>
              <th>Worst</th>
              <th>Rating</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody id="history-body"></tbody>
        </table>
      </div>
      <button class="btn btn-sm" id="clear-history-btn" style="margin-top:0.5rem;">Clear History</button>

      <!-- Comparison Reference Table -->
      <h2>Reaction Time Benchmarks</h2>
      <p>Where does your reaction time rank? Here's how different groups typically perform on visual reaction time tests.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Category</th>
              <th>Reaction Time</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Elite / Pro Gamer</strong></td><td>&lt; 150ms</td><td>Top-tier competitive players, trained athletes. Exceptional reflexes honed through thousands of hours of practice.</td></tr>
            <tr><td><strong>Fast</strong></td><td>150 – 200ms</td><td>Experienced gamers, young adults in peak condition. Noticeably faster than the general population.</td></tr>
            <tr><td><strong>Average</strong></td><td>200 – 250ms</td><td>Most healthy adults aged 18-40. This is the normal range for untrained individuals.</td></tr>
            <tr><td><strong>Below Average</strong></td><td>250 – 350ms</td><td>Common for older adults, fatigue, or first-time testers who haven't warmed up.</td></tr>
            <tr><td><strong>Slow</strong></td><td>&gt; 350ms</td><td>Significant fatigue, distraction, or age-related decline. Can improve with practice and rest.</td></tr>
          </tbody>
        </table>
      </div>

      <!-- Tips -->
      <h2>Tips to Improve Your Reaction Time</h2>
      <ul>
        <li><strong>Get enough sleep.</strong> Sleep deprivation is the #1 reaction time killer. Even one night of poor sleep can add 30-50ms to your reaction time. Aim for 7-9 hours consistently.</li>
        <li><strong>Warm up first.</strong> Your first few attempts are always slower. Do 2-3 practice rounds before measuring your true baseline. Cold muscles and an unfocused mind add latency.</li>
        <li><strong>Use caffeine strategically.</strong> 100-200mg of caffeine (1-2 cups of coffee) can improve reaction time by 10-20ms. But too much causes jitteriness that hurts accuracy.</li>
        <li><strong>Practice regularly.</strong> Like any skill, reaction time improves with consistent training. Even 5 minutes per day of reaction time practice can yield measurable improvement within 2 weeks.</li>
        <li><strong>Reduce input lag.</strong> Use a wired mouse (not Bluetooth), enable hardware acceleration in your browser, and if possible, use a high-refresh-rate monitor (144Hz+).</li>
        <li><strong>Stay physically active.</strong> Regular cardio exercise improves blood flow to the brain and has been shown to improve cognitive processing speed, including reaction time.</li>
        <li><strong>Focus on the stimulus, not the click.</strong> Anticipating the green screen causes early clicks. Instead, relax your hand and let the green color trigger your click naturally.</li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/aim-trainer" class="related-link">
          <strong>Aim Trainer</strong>
          <span>Practice your FPS aim with 4 game modes — track accuracy and reaction time</span>
        </a>
        <a href="/best-gaming-mouse" class="related-link">
          <strong>Best Gaming Mouse 2026</strong>
          <span>Low-latency mice that minimize input lag for faster reaction times</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ── State ── */
    const TOTAL_ATTEMPTS = 5;
    let state = 'idle';
    let attempt = 0;
    let results = [];
    let greenTimeout = null;
    let greenTime = 0;

    /* ── DOM ── */
    const testArea = document.getElementById('test-area');
    const testIcon = document.getElementById('test-icon');
    const testMsg = document.getElementById('test-msg');
    const testSub = document.getElementById('test-sub');
    const dots = document.querySelectorAll('.dot');
    const resultsPanel = document.getElementById('results-panel');
    const tryAgainBtn = document.getElementById('try-again-btn');
    const clearHistBtn = document.getElementById('clear-history-btn');

    /* ── Audio ── */
    let audioCtx = null;
    function getAudioCtx() {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      return audioCtx;
    }
    function playGo() {
      try {
        const ctx = getAudioCtx();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.setValueAtTime(1200, ctx.currentTime);
        gain.gain.setValueAtTime(0.12, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.08);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.08);
      } catch(e) {}
    }
    function playClick() {
      try {
        const ctx = getAudioCtx();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.setValueAtTime(880, ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(1760, ctx.currentTime + 0.04);
        gain.gain.setValueAtTime(0.15, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.08);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.08);
      } catch(e) {}
    }
    function playEarly() {
      try {
        const ctx = getAudioCtx();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(200, ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(80, ctx.currentTime + 0.2);
        gain.gain.setValueAtTime(0.12, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + 0.2);
      } catch(e) {}
    }

    /* ── Rating ── */
    function getRating(ms) {
      if (ms < 150) return { text: 'Incredible', cls: 'rating-incredible' };
      if (ms < 200) return { text: 'Fast', cls: 'rating-fast' };
      if (ms < 250) return { text: 'Average', cls: 'rating-average' };
      if (ms < 350) return { text: 'Below Average', cls: 'rating-below' };
      return { text: 'Slow', cls: 'rating-slow' };
    }

    /* ── Test Area Click Handler ── */
    testArea.addEventListener('click', function() {
      switch (state) {
        case 'idle':
        case 'result':
          startWaiting();
          break;
        case 'waiting':
          tooEarly();
          break;
        case 'ready':
          recordClick();
          break;
        case 'early':
          startWaiting();
          break;
        case 'done':
          showResults();
          break;
      }
    });

    function startWaiting() {
      state = 'waiting';
      testArea.className = 'test-area state-waiting';
      testIcon.textContent = '⏳';
      testMsg.textContent = 'Wait for green...';
      testSub.textContent = 'Attempt ' + (attempt + 1) + ' of ' + TOTAL_ATTEMPTS;

      const delay = 2000 + Math.random() * 3000;
      greenTimeout = setTimeout(function() {
        showGreen();
      }, delay);
    }

    function showGreen() {
      state = 'ready';
      testArea.className = 'test-area state-ready';
      testIcon.textContent = '⚡';
      testMsg.textContent = 'CLICK NOW!';
      testSub.textContent = '';
      greenTime = performance.now();
      playGo();
    }

    function tooEarly() {
      state = 'early';
      clearTimeout(greenTimeout);
      testArea.className = 'test-area state-early';
      testIcon.textContent = '❌';
      testMsg.textContent = 'Too early!';
      testSub.textContent = 'Click to try again';
      playEarly();
    }

    function recordClick() {
      const rt = Math.round(performance.now() - greenTime);
      results.push(rt);
      playClick();

      const rating = getRating(rt);
      state = 'result';
      testArea.className = 'test-area state-result';
      testIcon.textContent = '🎯';
      testMsg.innerHTML = '<span class="rt-display">' + rt + '<small>ms</small></span>';
      testSub.innerHTML = '<span class="rt-rating ' + rating.cls + '">' + rating.text + '</span>';

      var dot = dots[attempt];
      dot.classList.add('done');
      dot.textContent = rt + 'ms';
      dot.className = 'dot done ' + rating.cls;

      attempt++;

      if (attempt >= TOTAL_ATTEMPTS) {
        testSub.innerHTML += '<br><span style="font-size:0.9rem;opacity:0.8;">Click to see results</span>';
        state = 'done';
      } else {
        testSub.innerHTML += '<br><span style="font-size:0.9rem;opacity:0.8;">Click to continue</span>';
      }
    }

    function showResults() {
      state = 'idle';
      var avg = Math.round(results.reduce(function(a, b) { return a + b; }, 0) / results.length);
      var best = Math.min.apply(null, results);
      var worst = Math.max.apply(null, results);
      var rating = getRating(avg);

      testArea.className = 'test-area state-idle';
      testIcon.textContent = '✅';
      testMsg.textContent = 'Done!';
      testSub.textContent = 'See your results below';

      document.getElementById('avg-value').textContent = avg + 'ms';
      var avgRatingEl = document.getElementById('avg-rating');
      avgRatingEl.textContent = rating.text;
      avgRatingEl.className = 'avg-rating ' + rating.cls;

      var chart = document.getElementById('bar-chart');
      var maxMs = Math.max.apply(null, results.concat([350]));
      chart.innerHTML = results.map(function(rt, i) {
        var pct = (rt / maxMs) * 100;
        var r = getRating(rt);
        return '<div class="bar-row">' +
          '<span class="bar-label">#' + (i + 1) + '</span>' +
          '<div class="bar-track"><div class="bar-fill ' + r.cls + '" style="width:' + pct + '%"></div></div>' +
          '<span class="bar-value">' + rt + 'ms</span>' +
        '</div>';
      }).join('');

      var youBar = document.getElementById('comp-you-bar');
      var youPct = Math.min((avg / 350) * 100, 100);
      youBar.style.width = youPct + '%';
      youBar.setAttribute('data-ms', avg + 'ms');

      resultsPanel.style.display = 'block';
      resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });

      saveHistory(avg, best, worst, rating.text);
      renderHistory();
    }

    /* ── Try Again ── */
    tryAgainBtn.addEventListener('click', function() {
      attempt = 0;
      results = [];
      resultsPanel.style.display = 'none';
      dots.forEach(function(d) { d.className = 'dot'; d.textContent = ''; });
      state = 'idle';
      testArea.className = 'test-area state-idle';
      testIcon.textContent = '🖱️';
      testMsg.textContent = 'Click anywhere to start';
      testSub.textContent = '5 attempts — we\'ll average your results';
      testArea.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    /* ── History (localStorage) ── */
    function getHistory() {
      try { return JSON.parse(localStorage.getItem('reactionTimeHistory') || '[]'); } catch(e) { return []; }
    }
    function saveHistory(avg, best, worst, rating) {
      var h = getHistory();
      h.unshift({ avg: avg, best: best, worst: worst, rating: rating, date: new Date().toLocaleDateString() });
      if (h.length > 20) h.length = 20;
      localStorage.setItem('reactionTimeHistory', JSON.stringify(h));
    }
    function renderHistory() {
      var h = getHistory();
      var tbody = document.getElementById('history-body');
      if (h.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--text-secondary);padding:1rem;">No history yet — complete a test!</td></tr>';
        return;
      }
      tbody.innerHTML = h.map(function(e, i) {
        return '<tr><td>' + (i + 1) + '</td><td><strong>' + e.avg + 'ms</strong></td><td>' + e.best + 'ms</td><td>' + e.worst + 'ms</td><td>' + e.rating + '</td><td>' + e.date + '</td></tr>';
      }).join('');
    }

    clearHistBtn.addEventListener('click', function() {
      if (confirm('Clear all reaction time history?')) {
        localStorage.removeItem('reactionTimeHistory');
        renderHistory();
      }
    });

    renderHistory();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Test Area */
    .test-area { border-radius: 16px; min-height: 340px; display: flex; align-items: center; justify-content: center; cursor: pointer; user-select: none; -webkit-user-select: none; transition: background 0.2s; margin-bottom: 1rem; }
    .test-inner { text-align: center; padding: 2rem; }
    .test-icon { font-size: 3.5rem; margin-bottom: 1rem; line-height: 1; }
    .test-msg { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem; }
    .test-sub { font-size: 1rem; opacity: 0.85; }

    .state-idle { background: var(--card-bg); border: 2px solid var(--border-color); }
    .state-idle .test-msg { color: var(--text-primary); }
    .state-idle .test-sub { color: var(--text-secondary); }

    .state-waiting { background: #b71c1c; border: 2px solid #d32f2f; }
    .state-waiting .test-msg, .state-waiting .test-sub { color: #fff; }

    .state-ready { background: #2e7d32; border: 2px solid #43a047; animation: pulse-green 0.3s; }
    .state-ready .test-msg, .state-ready .test-sub { color: #fff; }
    @keyframes pulse-green { 0% { transform: scale(1); } 50% { transform: scale(1.01); } 100% { transform: scale(1); } }

    .state-early { background: #e65100; border: 2px solid #ef6c00; }
    .state-early .test-msg, .state-early .test-sub { color: #fff; }

    .state-result { background: var(--card-bg); border: 2px solid var(--accent-color); }
    .state-result .test-msg { color: var(--text-primary); }
    .state-result .test-sub { color: var(--text-secondary); }

    .rt-display { font-size: 3.5rem; font-weight: 900; color: var(--text-primary); line-height: 1.1; }
    .rt-display small { font-size: 1.2rem; font-weight: 700; opacity: 0.6; margin-left: 2px; }

    .rt-rating { display: inline-block; padding: 0.3rem 1rem; border-radius: 20px; font-weight: 700; font-size: 0.95rem; }

    /* Rating Colors */
    .rating-incredible { background: #1b5e20; color: #a5d6a7; }
    .rating-fast { background: #0d47a1; color: #90caf9; }
    .rating-average { background: #f57f17; color: #fff9c4; }
    .rating-below { background: #e65100; color: #ffcc80; }
    .rating-slow { background: #b71c1c; color: #ef9a9a; }

    /* Attempt Dots */
    .attempt-dots { display: flex; gap: 0.5rem; justify-content: center; margin-bottom: 1.5rem; }
    .dot { width: 60px; height: 32px; border-radius: 8px; border: 2px solid var(--border-color); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: var(--text-secondary); background: var(--card-bg); transition: all 0.2s; }
    .dot.done { border-color: transparent; color: #fff; font-size: 0.65rem; }
    .dot.done.rating-incredible { background: #1b5e20; }
    .dot.done.rating-fast { background: #0d47a1; }
    .dot.done.rating-average { background: #f57f17; }
    .dot.done.rating-below { background: #e65100; }
    .dot.done.rating-slow { background: #b71c1c; }

    /* Results Panel */
    .results-panel { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; margin-bottom: 1.5rem; }
    .results-panel h2 { margin-top: 0; font-size: 1.5rem; color: var(--text-primary); }
    .avg-result { margin: 1.5rem 0; }
