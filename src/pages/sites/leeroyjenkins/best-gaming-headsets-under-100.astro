    platform: "PC, PS4, PS5, Xbox, Switch",
    price: 99
  },
  {
    name: "SteelSeries Arctis Nova 1",
    sound: "Custom High Fidelity",
    mic: "ClearCast Gen 2",
    comfort: "AirWeave Memory Foam",
    wireless: "Wired",
    weight: "236g",
    platform: "PC, Mac, PlayStation, Xbox, Switch",
    price: 59
  },
  {
    name: "Razer Barracuda X",
    sound: "Triforce 40mm",
    mic: "Detachable HyperClear Cardioid",
    comfort: "FlowKnit Memory Foam",
    wireless: "Wireless (2.4GHz + BT)",
