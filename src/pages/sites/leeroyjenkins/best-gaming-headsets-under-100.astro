    platform: "PC, PlayStation, Switch, Android",
    price: 99
  },
  {
    name: "Corsair HS65",
    sound: "Custom 50mm Neodymium",
    mic: "Omni-directional flip-to-mute",
    comfort: "Memory Foam & Leatherette",
    wireless: "Wired",
    weight: "282g",
    platform: "PC, Mac, PlayStation, Xbox, Switch",
    price: 79
  },
  {
    name: "JBL Quantum 100",
    sound: "QuantumSOUND Signature",
    mic: "Detachable Voice Focus",
    comfort: "Memory Foam Polyurethane",
    wireless: "Wired",
    weight: "220g",
    platform: "PC, Mac, PlayStation, Xbox, Switch, VR",
    price: 39
  },
  {
    name: "Logitech G435",
    sound: "40mm Audio Drivers",
    mic: "Dual Beamforming",
    comfort: "Breathable Fabric",
    wireless: "Wireless (Lightspeed + BT)",
    weight: "165g",
    platform: "PC, Mac, PlayStation",
    price: 79
  },
  {
    name: "Turtle Beach Stealth 600",
    sound: "50mm Speakers",
    mic: "Gen 2 Flip-to-mute",
    comfort: "ProSpecs Glasses Friendly",
    wireless: "Wireless",
    weight: "290g",
    platform: "PlayStation or Xbox (Specific models)",
    price: 99
  }
];

const faqs = [
  {
    q: "Are wireless gaming headsets under $100 worth it?",
    a: "Yes, many modern wireless headsets under $100 offer excellent low-latency connections (like 2.4GHz) and solid battery life. However, you might sacrifice a bit of premium build quality or advanced features compared to more expensive models."
  },
  {
    q: "Is a wired connection better for competitive gaming?",
    a: "Wired headsets guarantee zero latency and no battery anxiety, which is crucial for competitive play. However, top-tier wireless technology has closed the latency gap significantly."
  },
  {
    q: "Do I need 7.1 surround sound?",
    a: "Virtual 7.1 surround sound can help with spatial awareness in games (like hearing footsteps), but a high-quality stereo headset often provides better overall audio clarity and is perfectly fine for most gamers."
  },
  {
    q: "How important is mic quality on a budget headset?",
    a: "If you frequently play multiplayer games with friends, a decent microphone is essential for clear communication. Look for noise-cancelling features to block out background noise."
  },
  {
    q: "What makes a headset comfortable for long sessions?",
    a: "Key factors include the clamping force, the ear cup material (memory foam, breathable fabric vs. leatherette), and the overall weight of the headset. Lighter headsets are generally better for marathon gaming."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Gaming Headsets Under 100",
    "description": "Discover the top budget gaming headsets. We compare HyperX, SteelSeries, Razer, and more.",
    "author": {
      "@type": "Organization",
      "name": "Leeroy Jenkins"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];
---

<SiteLayout
  site="leeroyjenkins"
  canonical="https://leeroyjenkins.quest/best-gaming-headsets-under-100"
  schema={schema}
  title={meta.title}
  description={meta.description}>
  <div class="page-content">
    <div class="hero">
      <h1>Best Gaming Headsets Under $100</h1>
      <p>Great audio doesn't have to break the bank. We compare the best budget gaming headsets for your setup.</p>
    </div>

    <section class="content-section">
      <h2>Headset Buying Guide: Competitive vs Casual</h2>
      <p>When choosing a budget gaming headset, consider your primary gaming style:</p>
      <ul>
        <li><strong>Competitive Gamers:</strong> Prioritize clear microphones, precise audio positioning (to hear footsteps), and lightweight comfort for long sessions. A wired connection is often preferred for zero latency, but modern 2.4GHz wireless is also excellent.</li>
        <li><strong>Casual Gamers:</strong> Focus on overall sound quality for immersion, deeper bass for cinematic games, and features like Bluetooth for connecting to multiple devices. Comfort remains crucial for long, relaxed sessions.</li>
      </ul>

      <h2>Top Picks Comparison</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Headset</th>
              <th>Price</th>
              <th>Sound Quality</th>
              <th>Mic Quality</th>
              <th>Comfort</th>
              <th>Connection</th>
              <th>Weight</th>
              <th>Platform</th>
            </tr>
          </thead>
          <tbody>
            {headsets.map(h => (
              <tr>
                <td><strong>{h.name}</strong></td>
                <td>${h.price}</td>
                <td>{h.sound}</td>
                <td>{h.mic}</td>
                <td>{h.comfort}</td>
                <td>{h.wireless}</td>
                <td>{h.weight}</td>
                <td>{h.platform}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faqs">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <style>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }

    strong { color: var(--text-primary); }

    .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; min-width: 800px; }
    th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }
  </style>
</SiteLayout>
