    .skip-badge.canon { background: var(--green); color: #000; }
    .skip-badge.filler { background: var(--red); color: #fff; }
    .skip-badge.mixed { background: var(--yellow); color: #000; }
    .skip-range { font-weight: 600; min-width: 80px; }
    .skip-name { flex: 1; }

    /* Filter bar */
