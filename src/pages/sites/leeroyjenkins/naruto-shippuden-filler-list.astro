---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How much of Naruto Shippuden is filler?",
    a: "Approximately 205 out of 500 episodes (41%) are filler — the highest filler percentage of the Big Three anime (Naruto, Bleach, One Piece). If you skip all filler, you cut the watch time from roughly 192 hours down to about 113 hours, saving nearly 79 hours."
  },
  {
    q: "Which Naruto Shippuden filler arcs are actually worth watching?",
    a: "Most fans recommend Kakashi's Anbu Arc (episodes 349-361) as the best filler arc — it explores Kakashi's dark past and feels canon-quality. The Power Arc (290-295) has movie-level animation. Itachi's Story (451-458) is partially adapted from canon novels and is widely considered essential. The rest can be safely skipped without losing story context."
  },
  {
    q: "What is Naruto Kai and should I watch it instead?",
    a: "Naruto Kai is a fan-edited version of both Naruto and Naruto Shippuden that removes all filler, recaps, and unnecessary flashbacks. It compresses the series into roughly 72 movie-length episodes that follow the manga closely. It's a great option if you want a tighter, manga-faithful experience, but it's not officially licensed."
  },
  {
    q: "Can I skip straight from episode 1 to the War Arc?",
    a: "Not recommended. While the Fourth Shinobi World War arc is the climax, it relies heavily on character development and plot points from the Kazekage Rescue, Akatsuki Suppression, Itachi Pursuit, Pain's Assault, and Five Kage Summit arcs. Skipping these will leave you confused about key relationships, abilities, and motivations. Use this filler guide to skip only the filler episodes."
  },
  {
    q: "Do any filler episodes contain important canon information?",
    a: "A few 'mixed' episodes blend filler content with brief canon scenes — particularly at the start or end of filler arcs where they transition back to the main story. Episodes 451-458 (Itachi's Story) adapt canon light novels. Episodes 484-500 adapt Konoha Hiden novels and include Naruto and Hinata's wedding. This guide marks those as 'mixed' so you don't accidentally skip canon content."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Naruto Shippuden Filler List: All 500 Episodes Guide",
    "description": "Complete Naruto Shippuden filler episode guide with all 500 episodes classified as canon, filler, or mixed. Track your progress, filter by arc, and save 79+ hours.",
    "applicationCategory": "Entertainment",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Naruto Shippuden Filler List: All 500 Episodes Guide",
  description: "Complete Naruto Shippuden filler guide — all 500 episodes classified as canon, filler, or mixed. Interactive tracker, arc guide, and skip list. Save 79+ hours.",
  category: "tool",
  published: "2026-03-29",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Naruto Shippuden Filler List: All 500 Episodes Guide"
  description="Complete Naruto Shippuden filler guide — all 500 episodes classified as canon, filler, or mixed. Interactive tracker, arc guide, and skip list. Save 79+ hours."
  canonical="https://leeroyjenkins.quest/naruto-shippuden-filler-list"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Naruto Shippuden Filler List</h1>
      <p>All 500 episodes classified — canon, filler, or mixed. Track your progress, filter by type or arc, and skip the filler to save <strong>79+ hours</strong>.</p>
    </div>

    <!-- Stats Dashboard -->
    <section class="content-section">
      <h2>Stats Dashboard</h2>
      <div id="stats-dashboard" class="stats-grid">
        <div class="stat-card">
          <div class="stat-number">500</div>
          <div class="stat-label">Total Episodes</div>
        </div>
        <div class="stat-card canon-card">
          <div class="stat-number" id="canon-count">—</div>
          <div class="stat-label">Canon</div>
        </div>
        <div class="stat-card filler-card">
          <div class="stat-number" id="filler-count">—</div>
          <div class="stat-label">Filler</div>
        </div>
        <div class="stat-card mixed-card">
          <div class="stat-number" id="mixed-count">—</div>
          <div class="stat-label">Mixed</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" id="filler-pct">—</div>
          <div class="stat-label">Filler %</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" id="time-saved">—</div>
          <div class="stat-label">Hours Saved Skipping Filler</div>
        </div>
      </div>

      <h3>Your Progress</h3>
      <div class="progress-bar-wrap">
        <div class="progress-bar" id="progress-bar"><span id="progress-text">0 / 500 watched</span></div>
      </div>
      <div class="progress-actions">
        <button class="btn btn-sm" id="btn-mark-canon">Mark All Canon Watched</button>
        <button class="btn btn-sm btn-outline" id="btn-clear-progress">Clear Progress</button>
      </div>
    </section>

    <!-- Quick Skip Guide -->
    <section class="content-section">
      <h2>Quick Skip Guide</h2>
      <p>Short on time? Here's the essentials — <strong class="text-green">watch</strong> the canon arcs and <strong class="text-red">skip</strong> the filler. Mixed episodes are marked so you can decide.</p>
      <div class="skip-guide" id="skip-guide"></div>
    </section>

    <!-- Filter / Search -->
    <section class="content-section">
      <h2>Full Episode List</h2>
      <div class="filter-bar">
        <input type="text" id="search-input" placeholder="Search episode # or title..." class="search-input" />
        <div class="filter-buttons">
          <button class="filter-btn active" data-filter="all">All</button>
          <button class="filter-btn" data-filter="canon">Canon</button>
          <button class="filter-btn" data-filter="filler">Filler</button>
          <button class="filter-btn" data-filter="mixed">Mixed</button>
        </div>
        <select id="arc-select" class="arc-select">
          <option value="all">All Arcs</option>
        </select>
      </div>

      <!-- Arc View -->
      <div id="arc-view"></div>
    </section>

    <!-- Naruto Kai Section -->
    <section class="content-section">
      <h2>Naruto Kai — The Filler-Free Fan Edit</h2>
      <p><strong>Naruto Kai</strong> is a fan-made re-edit of the entire Naruto and Naruto Shippuden anime that removes every filler episode, recap, and unnecessary flashback. It follows the manga panel-by-panel and condenses the series into roughly <strong>72 movie-length episodes</strong> (~1.5 hours each).</p>
      <div class="kai-info">
        <h3>Why Watch Naruto Kai?</h3>
        <ul>
          <li><strong>Zero filler</strong> — every scene matches the manga</li>
          <li><strong>No recaps or repeated flashbacks</strong> — the infamous Swing flashback is gone</li>
          <li><strong>Tighter pacing</strong> — fights that dragged for 10 episodes feel cinematic</li>
          <li><strong>~108 hours total</strong> vs the original ~440 hours for both series</li>
        </ul>
        <h3>Caveats</h3>
        <ul>
          <li>Not officially licensed — it's a fan project distributed informally</li>
          <li>Audio/video quality varies between episodes</li>
          <li>Some fans prefer the anime's original pacing and added scenes</li>
          <li>You miss out on well-regarded filler like Kakashi's Anbu Arc</li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Methodology -->
    <section class="content-section">
      <h2>How We Classified Each Episode</h2>
      <p><strong>Canon</strong> episodes adapt content directly from Masashi Kishimoto's manga. <strong>Filler</strong> episodes are anime-original with no manga source material. <strong>Mixed</strong> episodes contain both — typically canon scenes bookended by filler, or content adapted from official Naruto light novels (like Itachi Shinden, Konoha Hiden, and Shikamaru Hiden). We cross-referenced with the manga chapter list and official novel publications to ensure accuracy.</p>
    </section>
  </div>

  <style is:inline>
