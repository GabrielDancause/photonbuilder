    .ep-table tr.mixed-row { background: var(--yellow-bg); }
    .ep-table tr:hover { filter: brightness(1.2); }
    .type-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-right: 4px;
      vertical-align: middle;
    }
    .type-dot.canon { background: var(--green); }
    .type-dot.filler { background: var(--red); }
    .type-dot.mixed { background: var(--yellow); }
    .watch-checkbox { cursor: pointer; width: 16px; height: 16px; accent-color: var(--green); }
    .ep-num { font-weight: 700; white-space: nowrap; }

    /* Responsive table wrapper */
    .table-wrap { overflow-x: auto; }

    /* Kai section */
    .kai-info {
      background: var(--surface);
      border: 1px solid var(--yellow-border);
      border-radius: 8px;
      padding: 1.25rem;
    }
    .kai-info ul { padding-left: 1.25rem; margin: .5rem 0; }
    .kai-info li { margin-bottom: .35rem; color: var(--text-secondary); }
    .kai-info li strong { color: var(--text-primary); }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; gap: .5rem; }
    .faq-item {
      background: var(--surface);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      overflow: hidden;
    }
    .faq-item summary {
      padding: .75rem 1rem;
      cursor: pointer;
      font-weight: 600;
      font-size: .95rem;
      list-style: none;
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .faq-item summary::before { content: '+'; font-weight: 700; font-size: 1.1rem; color: var(--green); min-width: 18px; }
    .faq-item[open] summary::before { content: '−'; }
    .faq-item p { padding: 0 1rem 1rem; color: var(--text-secondary); line-height: 1.6; font-size: .9rem; margin: 0; }

    @media (max-width: 640px) {
      .hero h1 { font-size: 1.5rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .filter-bar { flex-direction: column; }
      .search-input { min-width: unset; width: 100%; }
      .filter-buttons { width: 100%; justify-content: stretch; }
      .filter-btn { flex: 1; text-align: center; }
      .arc-select { width: 100%; }
      .ep-table { font-size: .78rem; }
      .ep-table td, .ep-table th { padding: .35rem .4rem; }
    }
  </style>

  <script>
    // ── EPISODE DATA ──
