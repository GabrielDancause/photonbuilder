    // Build per-episode data
    function buildEpisodes() {
      const episodes = [];
      for (let i = 1; i <= 500; i++) {
        let type = "canon";
        let arcName = "Unknown";
        for (const arc of ARCS) {
          if (i >= arc.eps[0] && i <= arc.eps[1]) {
            arcName = arc.name;
            if (arc.overrides && arc.overrides[i]) {
              type = arc.overrides[i];
            } else {
              type = arc.type;
            }
            break;
          }
        }
        episodes.push({
          num: i,
          title: EP_TITLES[i] || `Episode ${i}`,
          type,
          arc: arcName
        });
      }
      return episodes;
    }

    const ALL_EPISODES = buildEpisodes();

    // ── STORAGE ──
    const STORAGE_KEY = "shippuden-watched";
    function getWatched() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]"); } catch { return []; }
    }
    function setWatched(arr) { localStorage.setItem(STORAGE_KEY, JSON.stringify(arr)); }
    function toggleWatched(ep) {
      const w = getWatched();
      const idx = w.indexOf(ep);
      if (idx > -1) w.splice(idx, 1); else w.push(ep);
      setWatched(w);
      return w;
    }

    // ── STATS ──
    function updateStats() {
      const canon = ALL_EPISODES.filter(e => e.type === "canon").length;
      const filler = ALL_EPISODES.filter(e => e.type === "filler").length;
      const mixed = ALL_EPISODES.filter(e => e.type === "mixed").length;
      document.getElementById("canon-count").textContent = canon;
      document.getElementById("filler-count").textContent = filler;
      document.getElementById("mixed-count").textContent = mixed;
      document.getElementById("filler-pct").textContent = ((filler / 500) * 100).toFixed(1) + "%";
      document.getElementById("time-saved").textContent = Math.round((filler * 23) / 60);
      updateProgress();
    }

    function updateProgress() {
      const watched = getWatched();
      const pct = ((watched.length / 500) * 100);
      const bar = document.getElementById("progress-bar");
      bar.style.width = Math.max(pct, 0.5) + "%";
      document.getElementById("progress-text").textContent = `${watched.length} / 500 watched`;
    }

    // ── SKIP GUIDE ──
    function renderSkipGuide() {
      const guide = document.getElementById("skip-guide");
      const entries = ARCS.map(a => {
        const range = a.eps[0] === a.eps[1] ? `Ep ${a.eps[0]}` : `Ep ${a.eps[0]}–${a.eps[1]}`;
        const count = a.eps[1] - a.eps[0] + 1;
        let mainType = a.type;
        if (a.overrides) {
          const types = {};
          for (let i = a.eps[0]; i <= a.eps[1]; i++) {
            const t = a.overrides[i] || a.type;
            types[t] = (types[t] || 0) + 1;
          }
          const max = Object.entries(types).sort((a,b) => b[1] - a[1])[0][0];
          mainType = max;
          if (Object.keys(types).length > 1) mainType = "mixed";
        }
        const label = mainType === "canon" ? "WATCH" : mainType === "filler" ? "SKIP" : "PARTIAL";
        return `<div class="skip-guide-item ${mainType}">
          <span class="skip-badge ${mainType}">${label}</span>
          <span class="skip-range">${range}</span>
          <span class="skip-name">${a.name} <span style="color:var(--text-secondary);font-size:.8rem">(${count} ep)</span></span>
        </div>`;
      });
      guide.innerHTML = entries.join("");
    }

    // ── ARC VIEW ──
    let currentFilter = "all";
    let currentArc = "all";
    let searchQuery = "";
    let sortCol = "num";
    let sortDir = 1;

    function getFilteredEpisodes() {
      return ALL_EPISODES.filter(ep => {
        if (currentFilter !== "all" && ep.type !== currentFilter) return false;
        if (currentArc !== "all" && ep.arc !== currentArc) return false;
        if (searchQuery) {
          const q = searchQuery.toLowerCase();
          if (!ep.title.toLowerCase().includes(q) && !String(ep.num).includes(q) && !ep.arc.toLowerCase().includes(q)) return false;
        }
        return true;
      });
    }

    function sortEpisodes(eps) {
      return [...eps].sort((a, b) => {
        if (sortCol === "num") return (a.num - b.num) * sortDir;
        if (sortCol === "title") return a.title.localeCompare(b.title) * sortDir;
        if (sortCol === "type") return a.type.localeCompare(b.type) * sortDir;
        if (sortCol === "arc") return a.arc.localeCompare(b.arc) * sortDir;
        return 0;
      });
    }

    function renderArcView() {
      const container = document.getElementById("arc-view");
      const filtered = getFilteredEpisodes();

      // Group by arc
      const arcMap = new Map();
      for (const ep of filtered) {
        if (!arcMap.has(ep.arc)) arcMap.set(ep.arc, []);
        arcMap.get(ep.arc).push(ep);
      }

      const watched = getWatched();
      let html = "";

      for (const [arcName, eps] of arcMap) {
        const sorted = sortEpisodes(eps);
        const types = { canon: 0, filler: 0, mixed: 0 };
        eps.forEach(e => types[e.type]++);
        const mainType = Object.entries(types).sort((a,b) => b[1] - a[1])[0][0];

        html += `<div class="arc-section" data-arc="${arcName}">
          <div class="arc-header" onclick="this.parentElement.classList.toggle('open')">
            <span class="arc-title"><span class="type-dot ${mainType}"></span>${arcName}</span>
            <span class="arc-meta">
              <span>${eps.length} ep</span>
              ${types.canon ? `<span style="color:var(--green)">${types.canon} canon</span>` : ""}
              ${types.filler ? `<span style="color:var(--red)">${types.filler} filler</span>` : ""}
              ${types.mixed ? `<span style="color:var(--yellow)">${types.mixed} mixed</span>` : ""}
            </span>
            <span class="arc-toggle">▶</span>
          </div>
          <div class="arc-body">
            <div class="table-wrap">
              <table class="ep-table">
                <thead><tr>
                  <th data-sort="num">#</th>
                  <th>✓</th>
                  <th data-sort="title">Title</th>
                  <th data-sort="type">Type</th>
                </tr></thead>
                <tbody>
                  ${sorted.map(ep => `<tr class="${ep.type}-row">
                    <td class="ep-num">${ep.num}</td>
                    <td><input type="checkbox" class="watch-checkbox" data-ep="${ep.num}" ${watched.includes(ep.num) ? "checked" : ""} /></td>
                    <td>${ep.title}</td>
                    <td><span class="type-dot ${ep.type}"></span>${ep.type}</td>
                  </tr>`).join("")}
                </tbody>
              </table>
            </div>
          </div>
        </div>`;
      }

      if (!filtered.length) {
        html = `<p style="text-align:center;color:var(--text-secondary);padding:2rem 0;">No episodes match your filters.</p>`;
      }

      container.innerHTML = html;
    }

    // ── ARC SELECT OPTIONS ──
    function populateArcSelect() {
      const select = document.getElementById("arc-select");
      const seen = new Set();
      for (const ep of ALL_EPISODES) {
        if (!seen.has(ep.arc)) {
          seen.add(ep.arc);
          const opt = document.createElement("option");
          opt.value = ep.arc;
          opt.textContent = ep.arc;
          select.appendChild(opt);
        }
      }
    }

    // ── EVENT LISTENERS ──
    function init() {
      updateStats();
      renderSkipGuide();
      populateArcSelect();
      renderArcView();

      // Filter buttons
      document.querySelectorAll(".filter-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          currentFilter = btn.dataset.filter;
          renderArcView();
        });
      });

      // Arc select
      document.getElementById("arc-select").addEventListener("change", (e) => {
        currentArc = e.target.value;
        renderArcView();
      });

      // Search
      let debounce;
      document.getElementById("search-input").addEventListener("input", (e) => {
        clearTimeout(debounce);
        debounce = setTimeout(() => {
          searchQuery = e.target.value;
          renderArcView();
        }, 200);
      });

      // Sort
      document.getElementById("arc-view").addEventListener("click", (e) => {
        const th = e.target.closest("th[data-sort]");
        if (th) {
          const col = th.dataset.sort;
          if (sortCol === col) sortDir *= -1;
          else { sortCol = col; sortDir = 1; }
          renderArcView();
        }
      });

      // Watch checkboxes
      document.getElementById("arc-view").addEventListener("change", (e) => {
        if (e.target.classList.contains("watch-checkbox")) {
          const ep = parseInt(e.target.dataset.ep);
          toggleWatched(ep);
          updateProgress();
        }
      });

      // Mark all canon watched
      document.getElementById("btn-mark-canon").addEventListener("click", () => {
        const canonEps = ALL_EPISODES.filter(e => e.type === "canon").map(e => e.num);
        const watched = getWatched();
        const merged = [...new Set([...watched, ...canonEps])];
        setWatched(merged);
        updateProgress();
        renderArcView();
      });

      // Clear progress
      document.getElementById("btn-clear-progress").addEventListener("click", () => {
        if (confirm("Clear all watch progress?")) {
          setWatched([]);
          updateProgress();
          renderArcView();
        }
      });
    }

    document.addEventListener("DOMContentLoaded", init);
  </script>
</SiteLayout>
