      padding: .5rem .6rem;
      background: var(--surface);
      border-bottom: 1px solid var(--border-color);
      font-size: .75rem;
      text-transform: uppercase;
      color: var(--text-secondary);
      position: sticky;
      top: 0;
      cursor: pointer;
      user-select: none;
