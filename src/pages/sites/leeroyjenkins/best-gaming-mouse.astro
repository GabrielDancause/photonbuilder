    badge: "Best Wired",
    price: 70,
    sensor: "Focus Pro 26K",
    dpi: 26000,
    weight: "101g",
    wireless: "Wired (USB-C)",
    shape: "Ergonomic (right-hand)",
    switches: "Optical Gen-3",
    battery: "N/A (wired)",
    grip: "Palm / Claw",
    pros: ["$70 — best value on the list", "Tilt scroll wheel with free-spin", "11 programmable buttons", "Smart Reel auto-switch scroll mode"],
    cons: ["Wired only", "101g is heavy", "Bulky for smaller hands"],
    summary: "If you don't need wireless, the Basilisk V3 delivers premium features at $70. The Smart Reel scroll wheel automatically switches between tactile and free-spin modes based on how fast you scroll — a feature you didn't know you needed until you try it. Optical switches and a 26K sensor round out a complete package."
  },
  {
    name: "Glorious Model O 2",
    badge: "Best Budget",
    price: 80,
    sensor: "BAMF 2.0 (PAW3395)",
