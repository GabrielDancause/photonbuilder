  },
  {
    name: "SteelSeries Aerox 5 Wireless",
    badge: "Best for MMO/MOBA",
    price: 110,
    sensor: "TrueMove Air",
    dpi: 18000,
    weight: "74g",
    wireless: "2.4GHz + Bluetooth",
