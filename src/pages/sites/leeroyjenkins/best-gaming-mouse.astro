    badge: "Best Lightweight",
    price: 160,
    sensor: "Focus Pro 30K",
    dpi: 35000,
    weight: "54g",
    wireless: "2.4GHz + Bluetooth",
    shape: "Ambidextrous (low profile)",
    switches: "Optical Gen-3",
