    name: "Logitech G Pro X Superlight 2",
    badge: "Best for FPS",
    price: 160,
    sensor: "HERO 2",
    dpi: 44000,
    weight: "60g",
    wireless: "2.4GHz",
    shape: "Ambidextrous",
    switches: "Lightforce Hybrid (Optical-Mechanical)",
    battery: "95 hours",
    grip: "Claw / Fingertip",
