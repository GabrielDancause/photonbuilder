---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const mice = [
  {
    name: "Razer DeathAdder V3 Pro",
    badge: "Best Overall",
    price: 150,
    sensor: "Focus Pro 30K",
    dpi: 30000,
    weight: "63g",
    wireless: "2.4GHz + Bluetooth",
    shape: "Ergonomic (right-hand)",
    switches: "Optical Gen-3",
    battery: "90 hours",
    grip: "Palm / Claw",
    pros: ["Flawless 30K optical sensor", "63g is featherweight for ergo shape", "90-hour battery life", "Comfortable for long sessions"],
    cons: ["No USB-C dongle — uses USB-A", "No RGB lighting", "Expensive at $150"],
    summary: "The DeathAdder V3 Pro is the best gaming mouse for most people. Razer took the beloved DeathAdder ergonomic shape, shaved it down to 63g, and paired it with their top-tier Focus Pro 30K sensor. It tracks flawlessly on any surface, the optical switches eliminate double-click issues, and 90 hours of battery means weekly charging at most."
  },
