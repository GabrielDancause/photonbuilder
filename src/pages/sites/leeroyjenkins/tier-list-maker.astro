---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tier List Maker - Create & Share Custom Tier Lists for Free",
  description: "Create custom tier lists for games, movies, food, anime, and more. Drag-and-drop interface with templates, customizable tiers, and image export. Free tier list maker tool.",
  category: "tool"
};
---

<SiteLayout site="leeroyjenkins" meta={meta}>
  <main>
    <!-- Tool Section -->
    <section class="tool-section">
      <div class="container">
        <h1>Tier List Maker</h1>
        <p class="subtitle">Create and share custom tier lists for anything — games, movies, food, anime, and more!</p>
        
        <!-- Template Bar -->
        <div class="template-bar">
          <button class="template-btn" data-template="blank">Blank</button>
          <button class="template-btn" data-template="league">League Champions</button>
          <button class="template-btn" data-template="marvel">Marvel Heroes</button>
          <button class="template-btn" data-template="fastfood">Fast Food</button>
          <button class="template-btn" data-template="programming">Programming Languages</button>
          <button class="template-btn" data-template="anime">Anime</button>
        </div>

        <!-- Tool Controls -->
        <div class="tool-controls">
          <button id="add-tier" class="control-btn">+ Add Tier</button>
          <button id="reset-all" class="control-btn danger">Reset All</button>
          <button id="export-image" class="control-btn primary">Save as Image</button>
        </div>

        <!-- Tier List Container -->
        <div id="tier-list" class="tier-list">
          <div class="tier-row" data-tier="S">
            <div class="tier-label" contenteditable="true" style="background-color: #FFD700;">S</div>
            <div class="tier-items" data-drop-zone="S"></div>
            <button class="remove-tier" title="Remove Tier">×</button>
          </div>
          <div class="tier-row" data-tier="A">
            <div class="tier-label" contenteditable="true" style="background-color: #FF4444;">A</div>
            <div class="tier-items" data-drop-zone="A"></div>
            <button class="remove-tier" title="Remove Tier">×</button>
          </div>
          <div class="tier-row" data-tier="B">
            <div class="tier-label" contenteditable="true" style="background-color: #FF8C00;">B</div>
            <div class="tier-items" data-drop-zone="B"></div>
            <button class="remove-tier" title="Remove Tier">×</button>
          </div>
          <div class="tier-row" data-tier="C">
            <div class="tier-label" contenteditable="true" style="background-color: #FFDD00;">C</div>
            <div class="tier-items" data-drop-zone="C"></div>
            <button class="remove-tier" title="Remove Tier">×</button>
          </div>
          <div class="tier-row" data-tier="D">
            <div class="tier-label" contenteditable="true" style="background-color: #22CC22;">D</div>
            <div class="tier-items" data-drop-zone="D"></div>
            <button class="remove-tier" title="Remove Tier">×</button>
          </div>
          <div class="tier-row" data-tier="F">
            <div class="tier-label" contenteditable="true" style="background-color: #888888;">F</div>
            <div class="tier-items" data-drop-zone="F"></div>
            <button class="remove-tier" title="Remove Tier">×</button>
          </div>
        </div>

        <!-- Item Pool -->
        <div class="item-pool">
          <h3>Add Items</h3>
          <div class="add-item-controls">
            <input type="text" id="item-name" placeholder="Enter item name..." maxlength="50">
            <button id="add-text-item" class="control-btn">+ Add Item</button>
            <input type="file" id="image-upload" accept="image/*" style="display: none;">
            <button id="add-image-item" class="control-btn">+ Add Image</button>
          </div>
          <div id="unranked-items" class="unranked-items" data-drop-zone="unranked">
            <p class="empty-state">Add items above or use a template to get started!</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Sections -->
    <section class="content-section">
      <div class="container">
        <h2>What Is a Tier List?</h2>
        <p>A tier list is a ranking system that organizes items into different tiers based on their quality, performance, or personal preference. Originally popularized by the fighting game community (FGC), tier lists have become a universal way to rank and compare virtually anything.</p>
        
        <p>The traditional tier system uses letters, with "S" representing the highest tier (often meaning "Superb" or "Special"), followed by A, B, C, D, and F tiers. S-tier items are considered the best or most powerful, while F-tier represents the worst or "Fail" category. This system provides a clear visual hierarchy that's easy to understand at a glance.</p>

        <p>Today, tier lists are used for everything from video game characters and weapons to movies, food, music, and even life decisions. They're popular because they turn complex comparisons into simple, shareable visual rankings that spark discussion and debate among communities.</p>

        <h2>How to Make a Tier List</h2>
        <p>Creating a tier list is simple with our drag-and-drop tool. Start by choosing a template or adding your own items to rank. Type item names in the text box or upload images to create visual cards. Once you have your items in the pool, simply drag them into the appropriate tier rows.</p>

        <p>Feel free to customize your tier list by renaming the tier labels (just click on them), changing tier colors, or adding/removing tiers as needed. The key to a good tier list is being honest about your rankings and having fun with the process. Remember, tier lists are subjective — your S-tier might be someone else's C-tier, and that's what makes them great conversation starters!</p>

        <p>When you're satisfied with your rankings, use the "Save as Image" button to export your tier list as a PNG file. Share it with friends, post it on social media, or keep it for your own reference. The best tier lists often spark friendly debates and help you discover new perspectives on your favorite topics.</p>

        <h2>Related Tools</h2>
        <div class="related-tools">
          <a href="/minecraft-circle-generator" class="tool-link">
            <h3>Minecraft Circle Generator</h3>
            <p>Build perfect circles and spheres in Minecraft with our pixel circle calculator.</p>
          </a>
          <a href="/best-gaming-headset" class="tool-link">
            <h3>Gaming Headset Comparison</h3>
            <p>Compare top gaming headsets with detailed specs and price comparisons.</p>
          </a>
          <a href="/best-gaming-mouse" class="tool-link">
            <h3>Gaming Mouse Comparison</h3>
            <p>Find the perfect gaming mouse with our comprehensive comparison tool.</p>
          </a>
        </div>

        <h2>Frequently Asked Questions</h2>
        <div class="faq">
          <div class="faq-item">
            <h3>How do I make a tier list?</h3>
            <p>Simply add items using the text input or image upload, then drag them into the tier rows. You can customize tier labels, colors, and add or remove tiers as needed. When finished, export your tier list as an image to share.</p>
          </div>
          <div class="faq-item">
            <h3>What does S tier mean?</h3>
            <p>S tier represents the highest ranking, often meaning "Superb," "Special," or "Supreme." It originated from Japanese grading systems and was popularized by fighting games. Items in S tier are considered the absolute best in their category.</p>
          </div>
          <div class="faq-item">
            <h3>Can I save my tier list as an image?</h3>
            <p>Yes! Click the "Save as Image" button to export your tier list as a PNG file. This creates a high-quality image that you can download, share on social media, or save for later reference.</p>
          </div>
          <div class="faq-item">
            <h3>What is a tier list used for?</h3>
            <p>Tier lists are used to rank and compare items in any category - video game characters, movies, foods, music, sports teams, or anything else you want to organize by quality or preference. They're great for starting discussions and sharing opinions.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    background: #060a12;
    color: #ffffff;
    font-family: system-ui, -apple-system, sans-serif;
    margin: 0;
    padding: 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .tool-section {
    background: #060a12;
    padding: 40px 0;
    min-height: 100vh;
  }

  h1 {
    text-align: center;
    font-size: 3rem;
    margin-bottom: 10px;
    color: #9333EA;
    font-weight: 700;
  }

  .subtitle {
    text-align: center;
    font-size: 1.2rem;
    margin-bottom: 30px;
    color: #cccccc;
  }

  .template-bar {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 30px;
  }

  .template-btn {
    background: #152040;
    border: 1px solid #9333EA;
    color: #ffffff;
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 0.9rem;
  }

  .template-btn:hover {
    background: #9333EA;
    transform: translateY(-1px);
  }

  .tool-controls {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .control-btn {
    background: #0a1020;
    border: 1px solid #152040;
    color: #ffffff;
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-weight: 500;
  }

  .control-btn:hover {
    background: #152040;
    transform: translateY(-1px);
  }

  .control-btn.primary {
    background: #9333EA;
    border-color: #9333EA;
  }

  .control-btn.primary:hover {
    background: #7C2D12;
  }

  .control-btn.danger {
    background: #dc2626;
    border-color: #dc2626;
  }

  .control-btn.danger:hover {
    background: #b91c1c;
  }

  .tier-list {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 30px;
  }

  .tier-row {
    display: flex;
    min-height: 100px;
    border-bottom: 1px solid #152040;
    position: relative;
  }

  .tier-row:last-child {
    border-bottom: none;
  }

  .tier-label {
    width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: #000000;
    cursor: text;
    border-right: 2px solid #152040;
    outline: none;
  }

  .tier-items {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 10px;
    align-content: flex-start;
    min-height: 80px;
  }

  .tier-items.drag-over {
    background: rgba(147, 51, 234, 0.2);
    border: 2px dashed #9333EA;
  }

  .remove-tier {
    position: absolute;
    right: 10px;
    top: 10px;
    background: #dc2626;
    border: none;
    color: white;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .tier-row:hover .remove-tier {
    opacity: 1;
  }

  .tier-item {
    background: #152040;
    border: 1px solid #334155;
    border-radius: 6px;
    padding: 8px 12px;
    cursor: grab;
    user-select: none;
    transition: all 0.2s ease;
    max-width: 150px;
    text-align: center;
    position: relative;
  }

  .tier-item:active {
    cursor: grabbing;
  }

  .tier-item.dragging {
    opacity: 0.5;
    transform: rotate(5deg) scale(1.05);
  }

  .tier-item img {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 5px;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  .tier-item .item-name {
    font-size: 0.8rem;
    word-wrap: break-word;
  }

  .item-pool {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    padding: 20px;
  }

  .item-pool h3 {
    margin-top: 0;
    color: #9333EA;
  }

  .add-item-controls {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  #item-name {
    flex: 1;
    min-width: 200px;
    background: #060a12;
    border: 1px solid #152040;
    color: #ffffff;
    padding: 10px;
    border-radius: 6px;
    outline: none;
  }

  #item-name:focus {
    border-color: #9333EA;
  }

  .unranked-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    min-height: 100px;
    padding: 15px;
    border: 2px dashed #152040;
    border-radius: 6px;
    align-content: flex-start;
  }

  .unranked-items.drag-over {
    background: rgba(147, 51, 234, 0.2);
    border-color: #9333EA;
  }

  .empty-state {
    color: #666666;
    font-style: italic;
    margin: 0;
  }

  .content-section {
    background: #0a1020;
    padding: 60px 0;
  }

  .content-section h2 {
    color: #9333EA;
    font-size: 2rem;
    margin-bottom: 20px;
  }

  .content-section p {
    line-height: 1.6;
    margin-bottom: 20px;
    color: #cccccc;
  }

  .related-tools {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin: 30px 0;
  }

  .tool-link {
    background: #152040;
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .tool-link:hover {
    background: #1e293b;
    border-color: #9333EA;
    transform: translateY(-2px);
  }

  .tool-link h3 {
    color: #9333EA;
    margin-top: 0;
    margin-bottom: 10px;
  }

  .faq {
    margin-top: 30px;
  }

  .faq-item {
    margin-bottom: 30px;
    background: #152040;
    border-radius: 8px;
    padding: 20px;
  }

  .faq-item h3 {
    color: #9333EA;
    margin-top: 0;
    margin-bottom: 10px;
  }

  .faq-item p {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .tier-label {
      width: 60px;
      font-size: 1.2rem;
    }

    .template-bar,
    .tool-controls,
    .add-item-controls {
      justify-content: center;
    }

    .related-tools {
      grid-template-columns: 1fr;
    }
  }

  /* Touch-specific styles */
  @media (pointer: coarse) {
    .tier-item {
      padding: 12px 16px;
    }
    
    .remove-tier {
      opacity: 1;
    }
  }
</style>

<script is:inline>
// Global state
let draggedItem = null;
let touchOffset = { x: 0, y: 0 };
let tierCounter = 0;

// Templates data
const templates = {
  blank: [],
  league: ['Aatrox', 'Ahri', 'Akali', 'Alistar', 'Amumu', 'Anivia', 'Annie', 'Ashe', 'Azir', 'Blitzcrank', 'Braum', 'Caitlyn', 'Cassiopeia', 'Cho\'Gath', 'Darius', 'Diana', 'Draven', 'Dr. Mundo', 'Ekko', 'Elise'],
  marvel: ['Spider-Man', 'Iron Man', 'Captain America', 'Thor', 'Hulk', 'Black Widow', 'Hawkeye', 'Doctor Strange', 'Scarlet Witch', 'Vision', 'Falcon', 'Winter Soldier', 'Ant-Man', 'Wasp', 'Captain Marvel', 'Black Panther', 'Star-Lord', 'Gamora', 'Rocket', 'Groot'],
  fastfood: ['McDonald\'s', 'Burger King', 'Wendy\'s', 'Taco Bell', 'KFC', 'Subway', 'Pizza Hut', 'Domino\'s', 'Chick-fil-A', 'In-N-Out', 'Five Guys', 'Chipotle', 'Popeyes', 'Arby\'s', 'Jack in the Box', 'Carl\'s Jr', 'White Castle', 'Sonic', 'Dairy Queen', 'Papa John\'s'],
  programming: ['JavaScript', 'Python', 'Java', 'C++', 'C#', 'PHP', 'TypeScript', 'Ruby', 'Go', 'Rust', 'Swift', 'Kotlin', 'Scala', 'Perl', 'R', 'MATLAB', 'Objective-C', 'Dart', 'Lua', 'Haskell'],
  anime: ['Attack on Titan', 'Death Note', 'Naruto', 'One Piece', 'Dragon Ball Z', 'My Hero Academia', 'Demon Slayer', 'One Punch Man', 'Fullmetal Alchemist', 'Hunter x Hunter', 'Tokyo Ghoul', 'Mob Psycho 100', 'Jujutsu Kaisen', 'Bleach', 'Cowboy Bebop', 'Neon Genesis Evangelion', 'JoJo\'s Bizarre Adventure', 'Spirited Away', 'Your Name', 'Princess Mononoke']
};

// Initialize the app
document.addEventListener('DOMContentLoaded', function() {
  initializeEventListeners();
  setupDragAndDrop();
  setupTouchEvents();
  updateEmptyState();
});

function initializeEventListeners() {
  // Template buttons
  document.querySelectorAll('.template-btn').forEach(btn => {
    btn.addEventListener('click', () => loadTemplate(btn.dataset.template));
  });

  // Control buttons
  document.getElementById('add-tier').addEventListener('click', addTier);
  document.getElementById('reset-all').addEventListener('click', resetAll);
  document.getElementById('export-image').addEventListener('click', exportAsImage);

  // Add item controls
  document.getElementById('add-text-item').addEventListener('click', addTextItem);
  document.getElementById('add-image-item').addEventListener('click', () => {
    document.getElementById('image-upload').click();
  });
  document.getElementById('image-upload').addEventListener('change', addImageItem);

  // Enter key for adding items
  document.getElementById('item-name').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      addTextItem();
    }
  });

  // Tier label editing
  document.querySelectorAll('.tier-label').forEach(label => {
    label.addEventListener('blur', saveTierLabel);
    label.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        label.blur();
      }
    });
  });

  // Remove tier buttons
  document.querySelectorAll('.remove-tier').forEach(btn => {
    btn.addEventListener('click', removeTier);
  });
}

function loadTemplate(templateName) {
  const items = templates[templateName] || [];
  const unrankedContainer = document.getElementById('unranked-items');
  
  // Clear existing items
  clearAllItems();
  
  // Add template items
  items.forEach(itemName => {
    createItem(itemName, null, unrankedContainer);
  });
  
  updateEmptyState();
}

function addTextItem() {
  const input = document.getElementById('item-name');
  const name = input.value.trim();
  
  if (name) {
    const unrankedContainer = document.getElementById('unranked-items');
    createItem(name, null, unrankedContainer);
    input.value = '';
    updateEmptyState();
  }
}

function addImageItem() {
  const fileInput = document.getElementById('image-upload');
  const file = fileInput.files[0];
  
  if (file && file.type.startsWith('image/')) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const unrankedContainer = document.getElementById('unranked-items');
      createItem(file.name.split('.')[0], e.target.result, unrankedContainer);
      updateEmptyState();
    };
    reader.readAsDataURL(file);
  }
  
  fileInput.value = '';
}

function createItem(name, imageUrl, container) {
  const item = document.createElement('div');
  item.className = 'tier-item';
  item.draggable = true;
  item.dataset.itemId = Date.now() + Math.random();
  
  if (imageUrl) {
    item.innerHTML = `
      <img src="${imageUrl}" alt="${name}">
      <div class="item-name">${name}</div>
    `;
  } else {
    item.innerHTML = `<div class="item-name">${name}</div>`;
  }
  
  // Add drag event listeners
  item.addEventListener('dragstart', handleDragStart);
  item.addEventListener('dragend', handleDragEnd);
  
  // Add touch event listeners
  item.addEventListener('touchstart', handleTouchStart, { passive: false });
  item.addEventListener('touchmove', handleTouchMove, { passive: false });
  item.addEventListener('touchend', handleTouchEnd, { passive: false });
  
  container.appendChild(item);
  return item;
}

function setupDragAndDrop() {
  // Setup drop zones
  document.querySelectorAll('[data-drop-zone]').forEach(zone => {
    zone.addEventListener('dragover', handleDragOver);
    zone.addEventListener('drop', handleDrop);
    zone.addEventListener('dragenter', handleDragEnter);
    zone.addEventListener('dragleave', handleDragLeave);
  });
}

function handleDragStart(e) {
  draggedItem = this;
  this.classList.add('dragging');
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/html', this.outerHTML);
}

function handleDragEnd(e) {
  this.classList.remove('dragging');
  draggedItem = null;
}

function handleDragOver(e) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
}

function handleDragEnter(e) {
  e.preventDefault();
  this.classList.add('drag-over');
}

function handleDragLeave(e) {
  if (!this.contains(e.relatedTarget)) {
    this.classList.remove('drag-over');
  }
}

function handleDrop(e) {
  e.preventDefault();
  this.classList.remove('drag-over');
  
  if (draggedItem) {
    this.appendChild(draggedItem);
    updateEmptyState();
  }
}

function setupTouchEvents() {
  let activeItem = null;
  let clone = null;
  
  window.handleTouchStart = function(e) {
    activeItem = this;
    const touch = e.touches[0];
    const rect = this.getBoundingClientRect();
    
    touchOffset.x = touch.clientX - rect.left;
    touchOffset.y = touch.clientY - rect.top;
    
    // Create visual feedback
    this.style.opacity = '0.7';
  };
  
  window.handleTouchMove = function(e) {
    if (!activeItem) return;
    
    e.preventDefault();
    const touch = e.touches[0];
    
    // Create or update clone
    if (!clone) {
      clone = activeItem.cloneNode(true);
      clone.style.position = 'fixed';
      clone.style.zIndex = '9999';
      clone.style.pointerEvents = 'none';
      clone.style.transform = 'rotate(5deg) scale(1.05)';
      clone.style.opacity = '0.9';
      document.body.appendChild(clone);
    }
    
    clone.style.left = (touch.clientX - touchOffset.x) + 'px';
    clone.style.top = (touch.clientY - touchOffset.y) + 'px';
    
    // Highlight drop zones
    const elementBelow = document.elementFromPoint(touch.clientX, touch.clientY);
    document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
    
    const dropZone = elementBelow?.closest('[data-drop-zone]');
    if (dropZone) {
      dropZone.classList.add('drag-over');
    }
  };
  
  window.handleTouchEnd = function(e) {
    if (!activeItem) return;
    
    const touch = e.changedTouches[0];
    const elementBelow = document.elementFromPoint(touch.clientX, touch.clientY);
    const dropZone = elementBelow?.closest('[data-drop-zone]');
    
    // Clean up
    activeItem.style.opacity = '';
    document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
    
    if (clone) {
      document.body.removeChild(clone);
      clone = null;
    }
    
    // Handle drop
    if (dropZone && dropZone !== activeItem.parentElement) {
      dropZone.appendChild(activeItem);
      updateEmptyState();
    }
    
    activeItem = null;
  };
}

function addTier() {
  const tierList = document.getElementById('tier-list');
  const tierColors = ['#9333EA', '#06b6d4', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6'];
  const tierName = String.fromCharCode(65 + (tierCounter % 26)); // A, B, C, etc.
  tierCounter++;
  
  const tierRow = document.createElement('div');
  tierRow.className = 'tier-row';
  tierRow.dataset.tier = tierName;
  
  tierRow.innerHTML = `
    <div class="tier-label" contenteditable="true" style="background-color: ${tierColors[tierCounter % tierColors.length]};">${tierName}</div>
    <div class="tier-items" data-drop-zone="${tierName}"></div>
    <button class="remove-tier" title="Remove Tier">×</button>
  `;
  
  tierList.appendChild(tierRow);
  
  // Add event listeners
  const label = tierRow.querySelector('.tier-label');
  label.addEventListener('blur', saveTierLabel);
  label.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      label.blur();
    }
  });
  
  const removeBtn = tierRow.querySelector('.remove-tier');
  removeBtn.addEventListener('click', removeTier);
  
  const dropZone = tierRow.querySelector('.tier-items');
  dropZone.addEventListener('dragover', handleDragOver);
  dropZone.addEventListener('drop', handleDrop);
  dropZone.addEventListener('dragenter', handleDragEnter);
  dropZone.addEventListener('dragleave', handleDragLeave);
}

function removeTier(e) {
  const tierRow = e.target.closest('.tier-row');
  const tierItems = tierRow.querySelector('.tier-items');
  const unrankedContainer = document.getElementById('unranked-items');
  
  // Move all items back to unranked
  Array.from(tierItems.children).forEach(item => {
    unrankedContainer.appendChild(item);
  });
  
  tierRow.remove();
  updateEmptyState();
}

function saveTierLabel(e) {
  const newName = e.target.textContent.trim();
  if (newName) {
    const tierRow = e.target.closest('.tier-row');
    tierRow.dataset.tier = newName;
    tierRow.querySelector('.tier-items').dataset.dropZone = newName;
  }
}

function resetAll() {
  if (confirm('Are you sure you want to reset everything? This cannot be undone.')) {
    clearAllItems();
    // Reset to default tiers
    const tierList = document.getElementById('tier-list');
    const defaultTiers = ['S', 'A', 'B', 'C', 'D', 'F'];
    const defaultColors = ['#FFD700', '#FF4444', '#FF8C00', '#FFDD00', '#22CC22', '#888888'];
    
    tierList.innerHTML = '';
    tierCounter = 0;
    
    defaultTiers.forEach((tier, index) => {
      const tierRow = document.createElement('div');
      tierRow.className = 'tier-row';
      tierRow.dataset.tier = tier;
      
      tierRow.innerHTML = `
        <div class="tier-label" contenteditable="true" style="background-color: ${defaultColors[index]};">${tier}</div>
        <div class="tier-items" data-drop-zone="${tier}"></div>
        <button class="remove-tier" title="Remove Tier">×</button>
      `;
      
      tierList.appendChild(tierRow);
    });
    
    initializeEventListeners();
    setupDragAndDrop();
    updateEmptyState();
  }
}

function clearAllItems() {
  document.querySelectorAll('.tier-item').forEach(item => item.remove());
  updateEmptyState();
}

function updateEmptyState() {
  const unrankedContainer = document.getElementById('unranked-items');
  const emptyState = unrankedContainer.querySelector('.empty-state');
  const hasItems = unrankedContainer.querySelectorAll('.tier-item').length > 0;
  
  if (hasItems && emptyState) {
    emptyState.style.display = 'none';
  } else if (!hasItems && !emptyState) {
    const emptyStateElement = document.createElement('p');
    emptyStateElement.className = 'empty-state';
    emptyStateElement.textContent = 'Add items above or use a template to get started!';
    unrankedContainer.appendChild(emptyStateElement);
  } else if (!hasItems && emptyState) {
    emptyState.style.display = 'block';
  }
}

function exportAsImage() {
  const tierListElement = document.getElementById('tier-list');
  
  // Create a temporary container for the export
  const exportContainer = document.createElement('div');
  exportContainer.style.cssText = `
    position: absolute;
    left: -9999px;
    top: 0;
    background: #0a1020;
    padding: 20px;
    border-radius: 8px;
    font-family: system-ui, -apple-system, sans-serif;
  `;
  
  // Clone the tier list
  const clonedTierList = tierListElement.cloneNode(true);
  clonedTierList.querySelectorAll('.remove-tier').forEach(btn => btn.remove());
  exportContainer.appendChild(clonedTierList);
  document.body.appendChild(exportContainer);
  
  // Use html2canvas if available, otherwise fallback to manual canvas
  if (typeof html2canvas !== 'undefined') {
    html2canvas(exportContainer, {
      backgroundColor: '#0a1020',
      scale: 2
    }).then(canvas => {
      downloadCanvas(canvas, 'tier-list.png');
      document.body.removeChild(exportContainer);
    });
  } else {
    // Fallback: create a simple canvas representation
    createManualCanvas(exportContainer);
    document.body.removeChild(exportContainer);
  }
}

function createManualCanvas(element) {
  const canvas = document.createElement('canvas');
  const ctx = canvas.getContext('2d');
  
  canvas.width = 800;
  canvas.height = 600;
  
  // Fill background
  ctx.fillStyle = '#0a1020';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  
  // Add title
  ctx.fillStyle = '#9333EA';
  ctx.font = 'bold 24px system-ui';
  ctx.textAlign = 'center';
  ctx.fillText('My Tier List', canvas.width / 2, 40);
  
  // Add tier rows
  const tierRows = element.querySelectorAll('.tier-row');
  let yOffset = 80;
  
  tierRows.forEach(row => {
    const label = row.querySelector('.tier-label');
    const labelText = label.textContent;
    const labelColor = label.style.backgroundColor || '#888888';
    
    // Draw tier label
    ctx.fillStyle = labelColor;
    ctx.fillRect(20, yOffset, 80, 60);
    ctx.fillStyle = '#000000';
    ctx.font = 'bold 20px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(labelText, 60, yOffset + 35);
    
    // Draw tier items
    const items = row.querySelectorAll('.tier-item');
    let xOffset = 120;
    
    items.forEach(item => {
      const itemText = item.querySelector('.item-name').textContent;
      
      // Draw item background
      ctx.fillStyle = '#152040';
      ctx.fillRect(xOffset, yOffset + 10, 100, 40);
      
      // Draw item text
      ctx.fillStyle = '#ffffff';
      ctx.font = '12px system-ui';
      ctx.textAlign = 'center';
      ctx.fillText(itemText.substring(0, 12) + (itemText.length > 12 ? '...' : ''), 
                   xOffset + 50, yOffset + 32);
      
      xOffset += 110;
      if (xOffset > canvas.width - 110) break; // Prevent overflow
    });
    
    yOffset += 80;
  });
  
  downloadCanvas(canvas, 'tier-list.png');
}

function downloadCanvas(canvas, filename) {
  const link = document.createElement('a');
  link.download = filename;
  link.href = canvas.toDataURL('image/png');
  link.click();
}
</script>

