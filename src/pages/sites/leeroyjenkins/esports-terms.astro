---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Esports Terms",
    "description": "Esports terms: bracket, bo3, group stage, LAN, bootcamp, franchise."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Bracket?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The visual, tree-like tournament structure that dictates exactly which teams face each other. Tournaments commonly use either Single Elimination (one loss and you are out) or Double Elimination (teams drop to a lower bracket after one loss)."
        }
      },
      {
        "@type": "Question",
        "name": "What is Bo3 / Bo5 (Best of X)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The standard match format indicating the maximum possible number of games played in a series. In a Best of 3, the first team to win two games secures the overall match victory, allowing for map vetoes and strategic adjustments."
        }
      },
      {
        "@type": "Question",
        "name": "What is Group stage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The grueling initial phase of a large tournament. Teams are divided into groups and play a round-robin format against each other to determine seeding and decide which top teams advance to the high-stakes playoff bracket."
        }
      }
    ]
  }
];

export const meta = {
  title: "Esports Terms",
  description: "Esports terms: bracket, bo3, group stage, LAN, bootcamp, franchise.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Esports Terms"
  description="Esports terms: bracket, bo3, group stage, LAN, bootcamp, franchise."
  canonical="https://leeroyjenkins.quest/esports-terms"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Esports Terms</h1>
      <p>Esports terms: bracket, bo3, group stage, LAN, bootcamp, franchise.</p>
    </div>


    <div class="card">
        <h3>Bracket</h3>
        <p>The visual, tree-like tournament structure that dictates exactly which teams face each other. Tournaments commonly use either Single Elimination (one loss and you are out) or Double Elimination (teams drop to a lower bracket after one loss).</p>
    </div>
    <div class="card">
        <h3>Bo3 / Bo5 (Best of X)</h3>
        <p>The standard match format indicating the maximum possible number of games played in a series. In a Best of 3, the first team to win two games secures the overall match victory, allowing for map vetoes and strategic adjustments.</p>
    </div>
    <div class="card">
        <h3>Group stage</h3>
        <p>The grueling initial phase of a large tournament. Teams are divided into groups and play a round-robin format against each other to determine seeding and decide which top teams advance to the high-stakes playoff bracket.</p>
    </div>
    <div class="card">
        <h3>LAN (Local Area Network)</h3>
        <p>The pinnacle of esports competition. Tournaments are played in massive arenas on a local network rather than over the public internet. This provides near-zero latency, absolute competitive fairness, and a massive live audience environment.</p>
    </div>
    <div class="card">
        <h3>Bootcamp</h3>
        <p>A dedicated period of intense, highly focused practice. An entire team will travel to gather in a single location or facility, often in a different region with stronger competition, to train ruthlessly for weeks prior to a major world championship.</p>
    </div>
    <div class="card">
        <h3>Franchise</h3>
        <p>A rigid, highly structured professional league model where organizations purchase permanent slots, eliminating the risk of relegation. This model mimics traditional sports leagues like the NBA, ensuring massive financial stability, revenue sharing, and sponsor confidence.</p>
    </div>
    <div class="card">
        <h3>Prize pool</h3>
        <p>The total accumulated amount of prize money distributed among the winning teams at the conclusion of a tournament. Major events like The International boast prize pools well into the tens of millions of dollars, largely funded by the community.</p>
    </div>
    <div class="card">
        <h3>Roster</h3>
        <p>The official, finalized lineup of players actively contracted to compete for an esports organization. Managing a roster involves scouting talent, handling player buyouts, and finding the perfect synergy between vastly different player personalities.</p>
    </div>
    <div class="card">
        <h3>Stand-in</h3>
        <p>A substitute player temporarily brought in to compete in an official match when a member of the primary roster is unavailable due to sudden illness, visa issues, or internal team disputes, often with very little time to practice with the team.</p>
    </div>
    <div class="card">
        <h3>Coach</h3>
        <p>The vital mastermind behind the team who handles macro strategy, rigorous VOD reviews, drafting phases, and emotional support. A great coach ensures the players focus entirely on their mechanics while executing a cohesive, highly practiced game plan.</p>
    </div>
    <div class="card">
        <h3>MVP (Most Valuable Player)</h3>
        <p>The highly prestigious award given to the single player whose absolutely exceptional performance had the most massive, undeniable impact on their team's ultimate success throughout the entire duration of a tournament.</p>
    </div>
    <div class="card">
        <h3>IGL (In-Game Leader)</h3>
        <p>The most crucial role in a tactical shooter team. The IGL acts as the field commander, analyzing the enemy's economy and positioning on the fly, and making split-second, highly strategic calls that dictate exactly how the team executes their round.</p>
    </div>
    <div class="card">
        <h3>Drafting</h3>
        <p>The incredibly complex and highly strategic pre-game phase in MOBA titles where coaches and players take turns selecting their own champions and banning specific champions away from the enemy, aiming to build a superior team composition.</p>
    </div>
    <div class="card">
        <h3>Meta shift</h3>
        <p>A sudden, drastic change in the competitive landscape, usually caused by a major developer balance patch. It forces professional teams to entirely abandon their practiced strategies and rapidly adapt to newly powerful characters or items.</p>
    </div>
    <div class="card">
        <h3>Caster</h3>
        <p>The on-screen talent who provide live, exciting commentary during esports matches. Play-by-play casters bring massive hype during intense moments, while color commentators break down the deep, underlying strategies and decisions in real-time.</p>
    </div>
    <div class="card">
        <h3>Analyst desk</h3>
        <p>A panel of highly knowledgeable former professionals and experts who appear before and after matches to break down the draft, utilize statistics to analyze team performance, and dissect the crucial turning points of the game.</p>
    </div>
    <div class="card">
        <h3>Clutch</h3>
        <p>The incredibly tense scenario where a single remaining player successfully manages to win a round against seemingly impossible odds, often eliminating multiple opponents entirely on their own under massive pressure.</p>
    </div>
    <div class="card">
        <h3>Throw</h3>
        <p>When a professional team possesses a massive, almost guaranteed lead in gold or map control, but commits a completely catastrophic error or engages in a terrible team fight, resulting in them losing a game they absolutely should have won.</p>
    </div>
    <div class="card">
        <h3>Macro</h3>
        <p>The overarching, grand strategic view of an entire match. Teams with superior macro execute flawless map rotations, secure critical neutral objectives with perfect timing, and manage the economy perfectly, completely suffocating the enemy team.</p>
    </div>
    <div class="card">
        <h3>Micro</h3>
        <p>The intense, localized mechanical skill of a single player. Exceptional micro involves executing completely flawless, lightning-fast ability combos, perfect crosshair tracking, and mathematically precise movement in the heat of a chaotic fight.</p>
    </div>
    <div class="card">
        <h3>Roster lock</h3>
        <p>The strict, officially enforced deadline set by tournament organizers. After this exact date, teams are completely forbidden from making any further changes to their player lineup for the remainder of the competitive season.</p>
    </div>
    <div class="card">
        <h3>Buyout</h3>
        <p>The incredibly massive, often multi-million dollar fee that an esports organization must pay to legally acquire a highly skilled star player who is currently locked into a long-term, legally binding contract with a rival organization.</p>
    </div>
    <div class="card">
        <h3>Esports Organization (Org)</h3>
        <p>A massive, corporate business entity that fields multiple teams across various different gaming titles. Orgs are responsible for securing huge sponsorships, selling merchandise, and paying the lucrative salaries of their contracted players.</p>
    </div>
    <div class="card">
        <h3>Major / Minor</h3>
        <p>The classification tiers of esports tournaments. Majors are the absolute highest-prestige, developer-sponsored events with massive prize pools and global importance, while Minors serve as the highly competitive qualifiers leading up to them.</p>
    </div>
    <div class="card">
        <h3>Smokescreen</h3>
        <p>A deceptive, psychological strategy utilized during the drafting phase. A team deliberately picks specific characters early to trick the opposing team into believing they are running one strategy, before completely pivoting their composition with their final picks.</p>
    </div>
    <div class="links-section">
      <h3>Related Guides</h3>
      <ul>
        <li><a href="/gaming-jargon-dictionary">Gaming Jargon Dictionary</a></li>
        <li><a href="/competitive-gaming-terms">Competitive Gaming Terms</a></li>
        <li><a href="/moba-terms-glossary">Moba Terms Glossary</a></li>
        <li><a href="/fps-terms-glossary">Fps Terms Glossary</a></li>
      </ul>
    </div>


  </div>

  <script is:inline>
    // Page specific JS
  </script>

