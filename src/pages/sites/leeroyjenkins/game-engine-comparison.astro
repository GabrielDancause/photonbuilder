    let currentData = [...engineData];
    let sortColumn = null;
    let sortAsc = true;

    const tbody = document.getElementById('tableBody');
    const searchInput = document.getElementById('searchInput');
    const filterSelect = document.getElementById('filterSelect');
    const headers = document.querySelectorAll('th[data-sort]');
    const statsGrid = document.getElementById('stats-grid');
    const resetSortBtn = document.getElementById('resetSortBtn');

    function formatNumber(num) {
        if (num === null || num === undefined) return '<span class="text-secondary">N/A</span>';
        return new Intl.NumberFormat().format(num);
    }

    function renderStats() {
        const totalEngines = engineData.length;

        let mostSteamGames = engineData[0];
        for (let i = 1; i < engineData.length; i++) {
            if ((engineData[i].steamGames || 0) > (mostSteamGames.steamGames || 0)) {
                mostSteamGames = engineData[i];
            }
        }

        let mostGithubStars = engineData[0];
        for (let i = 1; i < engineData.length; i++) {
            if ((engineData[i].githubStars || 0) > (mostGithubStars.githubStars || 0)) {
                mostGithubStars = engineData[i];
            }
        }

        statsGrid.innerHTML = `
            <div class="stat-card">
                <h3>Engines Analyzed</h3>
                <div class="value">${totalEngines}</div>
            </div>
            <div class="stat-card">
                <h3>Most Steam Games</h3>
                <div class="value">${mostSteamGames.engine}</div>
                <div style="font-size: 0.85rem; color: #888; margin-top: 8px;">${formatNumber(mostSteamGames.steamGames)} games</div>
            </div>
            <div class="stat-card">
                <h3>Most GitHub Stars</h3>
                <div class="value">${mostGithubStars.engine}</div>
                <div style="font-size: 0.85rem; color: #888; margin-top: 8px;">${formatNumber(mostGithubStars.githubStars)} stars</div>
            </div>
        `;
    }

    function renderTable() {
        tbody.innerHTML = '';

        if (currentData.length === 0) {
            tbody.innerHTML = `<tr><td colspan="9" style="text-align: center; color: var(--text-secondary);">No results found.</td></tr>`;
            return;
        }

        currentData.forEach(engine => {
            const tr = document.createElement('tr');

            // Format arrays as badges
            const languagesHtml = engine.languages.split(',').map(l => `<span class="badge">${l.trim()}</span>`).join('');
            const platformsHtml = engine.platforms.split(',').map(p => `<span class="badge" style="background: rgba(255,255,255,0.05); color: #ccc; font-weight: 500;">${p.trim()}</span>`).join('');

            tr.innerHTML = `
                <td><div class="engine-name">${engine.engine}</div></td>
                <td><span style="color: ${engine.license === 'Proprietary' ? '#ff6b6b' : '#51cf66'}">${engine.license}</span></td>
                <td style="font-size: 0.9rem;">${engine.pricingModel}</td>
                <td><div style="display: flex; flex-wrap: wrap;">${languagesHtml}</div></td>
                <td><div style="display: flex; flex-wrap: wrap;">${platformsHtml}</div></td>
                <td class="font-mono" style="color: ${engine.githubStars ? 'var(--text-primary)' : 'var(--text-secondary)'}">${formatNumber(engine.githubStars)}</td>
                <td class="font-mono" style="color: ${engine.steamGames ? 'var(--text-primary)' : 'var(--text-secondary)'}">${formatNumber(engine.steamGames)}</td>
                <td class="font-mono" style="color: ${engine.itchGames ? 'var(--text-primary)' : 'var(--text-secondary)'}">${formatNumber(engine.itchGames)}</td>
                <td style="font-size: 0.85rem; color: var(--text-secondary); max-width: 200px;">${engine.notableGames || 'N/A'}</td>
            `;
            tbody.appendChild(tr);
        });
    }

    function handleFilterAndSearch() {
        const searchTerm = searchInput.value.toLowerCase();
        const filterValue = filterSelect.value;

        currentData = engineData.filter(engine => {
            const matchesSearch =
                engine.engine.toLowerCase().includes(searchTerm) ||
                engine.languages.toLowerCase().includes(searchTerm) ||
                engine.platforms.toLowerCase().includes(searchTerm);

            let matchesFilter = true;
            if (filterValue !== 'all') {
                if (filterValue === 'MIT') {
                     matchesFilter = engine.license.includes('MIT') || engine.license.includes('Apache');
                } else {
                     matchesFilter = engine.license === filterValue;
                }
            }

            return matchesSearch && matchesFilter;
        });

        if (sortColumn) {
            applySort();
        } else {
            renderTable();
        }
    }

    function applySort() {
        currentData.sort((a, b) => {
            let valA = a[sortColumn];
            let valB = b[sortColumn];

            if (valA === null) valA = -Infinity;
            if (valB === null) valB = -Infinity;

            if (typeof valA === 'string') {
                valA = valA.toLowerCase();
                valB = valB.toLowerCase();
            }

            if (valA < valB) return sortAsc ? -1 : 1;
            if (valA > valB) return sortAsc ? 1 : -1;
            return 0;
        });
        renderTable();
    }

    function handleSort(e) {
        const column = e.target.getAttribute('data-sort');
        if (!column) return;

        if (sortColumn === column) {
            sortAsc = !sortAsc;
        } else {
            sortColumn = column;
            sortAsc = true;
        }

        headers.forEach(th => {
            th.classList.remove('sort-asc', 'sort-desc');
        });

        e.target.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');

        applySort();
    }

    searchInput.addEventListener('input', handleFilterAndSearch);
    filterSelect.addEventListener('change', handleFilterAndSearch);

    headers.forEach(th => {
        th.addEventListener('click', handleSort);
    });

    resetSortBtn.addEventListener('click', () => {
        sortColumn = null;
        headers.forEach(th => th.classList.remove('sort-asc', 'sort-desc'));
        handleFilterAndSearch();
    });

