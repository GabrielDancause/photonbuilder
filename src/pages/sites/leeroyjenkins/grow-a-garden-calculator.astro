    .output-section h3 { margin-top: 0; margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 700; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; }
    .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 8%, transparent); border: 1px solid color-mix(in srgb, var(--accent-color) 30%, transparent); border-radius: 12px; padding: 1.25rem; text-align: center; display: flex; flex-direction: column; justify-content: center; min-height: 110px;}
    .result-label { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.5rem; }
    .result-value { font-size: 1.75rem; font-weight: 800; color: var(--accent-color); line-height: 1.2; }

    .explainer { margin: 3rem 0; line-height: 1.7; }
    .explainer h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; color: var(--text-primary); }
    .explainer h3 { font-size: 1.3rem; font-weight: 700; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--text-primary); }
    .explainer p { margin-bottom: 1.25rem; color: var(--text-secondary); }
    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer code { background: var(--bg-color); border: 1px solid var(--border-color); padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; color: var(--accent-color); }

    .faq-section { margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 2rem; }
    .faq-section h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); transition: all 0.2s; }
    .faq-section details[open] { border-color: var(--accent-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; list-style-position: inside; }
    .faq-section summary:hover { color: var(--accent-color); }
    .faq-section details p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>

