  <script is:inline>
// Expandable Sections
    function toggleSection(element) {
      const parent = element.parentElement;
      parent.classList.toggle('open');
    }

    // Copy Code functionality
    function copyCode(btn) {
      const codeBlock = btn.nextElementSibling;
      const text = codeBlock.textContent;
      navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.textContent;
        btn.textContent = 'Copied!';
        btn.style.background = 'var(--accent-color)';
        btn.style.color = '#fff';
        btn.style.borderColor = 'var(--accent-color)';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.style.background = 'var(--card-bg)';
          btn.style.color = 'var(--text-primary)';
          btn.style.borderColor = 'var(--border-color)';
        }, 2000);
      });
    }

    // Filtering and Sorting Logic
    const searchInput = document.getElementById('searchInput');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const sortSelect = document.getElementById('sortSelect');
    const botList = document.getElementById('botList');
    const bots = Array.from(document.querySelectorAll('.bot-item'));

    let currentFilter = 'all';
    let currentSearch = '';
    let currentSort = 'rating';

    function updateView() {
      // Filter
      bots.forEach(bot => {
        const categories = bot.getAttribute('data-categories');
        const textContent = bot.textContent.toLowerCase();

        const matchesFilter = currentFilter === 'all' || categories.includes(currentFilter);
        const matchesSearch = currentSearch === '' || textContent.includes(currentSearch);

        if (matchesFilter && matchesSearch) {
          bot.classList.remove('hidden');
        } else {
          bot.classList.add('hidden');
        }
      });

      // Sort
      const visibleBots = bots.filter(bot => !bot.classList.contains('hidden'));

      visibleBots.sort((a, b) => {
        if (currentSort === 'rating') {
          const ratingA = parseFloat(a.getAttribute('data-rating'));
          const ratingB = parseFloat(b.getAttribute('data-rating'));
          return ratingB - ratingA; // Descending
        } else if (currentSort === 'name') {
          const nameA = a.getAttribute('data-name');
          const nameB = b.getAttribute('data-name');
          return nameA.localeCompare(nameB); // Ascending
        }
      });

      // Re-append to DOM in new order
      visibleBots.forEach(bot => botList.appendChild(bot));
    }

    // Event Listeners
    searchInput.addEventListener('input', (e) => {
      currentSearch = e.target.value.toLowerCase().trim();
      updateView();
    });

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        filterBtns.forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        currentFilter = e.target.getAttribute('data-filter');
        updateView();
      });
    });

    sortSelect.addEventListener('change', (e) => {
      currentSort = e.target.value;
      updateView();
    });

    // Initial sort
    updateView();
  </script>

