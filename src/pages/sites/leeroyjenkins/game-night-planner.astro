    var gameResults = document.getElementById('game-results');
    var snackList = document.getElementById('snack-list');
    var randomPick = document.getElementById('random-pick');
    var randomGameName = document.getElementById('random-game-name');
    var randomGameMeta = document.getElementById('random-game-meta');
    var rerollBtn = document.getElementById('reroll-btn');
    var resultsTitle = document.getElementById('results-title');
    var copyScheduleBtn = document.getElementById('copy-schedule-btn');
    var copyFeedback = document.getElementById('copy-feedback');
    var sessionDateInput = document.getElementById('session-date');
    var sessionTimeInput = document.getElementById('session-time');
    var schedulePreview = document.getElementById('schedule-preview');

    /* Set default date to tomorrow */
    var tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    sessionDateInput.value = tomorrow.toISOString().split('T')[0];

    /* ── Player Selection ── */
    playerSelect.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-players]');
      if (!btn) return;
      this.querySelectorAll('.btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedPlayers = parseInt(btn.dataset.players);
    });

    /* ── Platform Selection ── */
    platformSelect.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-platform]');
      if (!btn) return;
      this.querySelectorAll('.platform-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedPlatform = btn.dataset.platform;
    });

    /* ── Genre Selection (multi-select) ── */
    genreSelect.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-genre]');
      if (!btn) return;
      btn.classList.toggle('active');
      selectedGenres = [];
      this.querySelectorAll('.genre-btn.active').forEach(function(b) {
        selectedGenres.push(b.dataset.genre);
      });
      if (selectedGenres.length === 0) {
        btn.classList.add('active');
        selectedGenres.push(btn.dataset.genre);
      }
    });

    /* ── Session Selection ── */
    sessionSelect.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-session]');
      if (!btn) return;
      this.querySelectorAll('.btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedSession = parseInt(btn.dataset.session);
    });

    /* ── Filter Games ── */
    function filterGames() {
      return GAMES.filter(function(g) {
        var playerFit = selectedPlayers >= g.players[0] && selectedPlayers <= g.players[1];
        var platformFit = selectedPlatform === 'crossplay'
          ? g.platforms.indexOf('crossplay') !== -1
          : g.platforms.indexOf(selectedPlatform) !== -1;
        var genreFit = g.genres.some(function(genre) { return selectedGenres.indexOf(genre) !== -1; });
        var sessionFit = g.session <= selectedSession || (selectedSession >= 5);
        return playerFit && platformFit && genreFit && sessionFit;
      }).sort(function(a, b) {
        var aScore = 0, bScore = 0;
        /* Prefer games that match more selected genres */
        a.genres.forEach(function(g) { if (selectedGenres.indexOf(g) !== -1) aScore += 2; });
        b.genres.forEach(function(g) { if (selectedGenres.indexOf(g) !== -1) bScore += 2; });
        /* Prefer f2p */
        if (a.f2p) aScore += 1;
        if (b.f2p) bScore += 1;
        /* Prefer matching session length */
        if (a.session === selectedSession) aScore += 1;
        if (b.session === selectedSession) bScore += 1;
        return bScore - aScore;
      });
    }

    /* ── Render Results ── */
    function renderResults(games, showRandom) {
      lastResults = games;
      var playerLabel = selectedPlayers >= 10 ? '10+' : selectedPlayers >= 7 ? '7-8' : selectedPlayers >= 5 ? '5-6' : selectedPlayers.toString();
      resultsTitle.textContent = games.length + ' Games for ' + playerLabel + ' Players';

      if (games.length === 0) {
        gameResults.innerHTML = '<div class="no-results"><p>No games match your criteria. Try broadening your genre selection or switching platforms.</p></div>';
        randomPick.style.display = 'none';
      } else {
        gameResults.innerHTML = games.map(function(g) {
          var tags = [];
          if (g.f2p) tags.push('<span class="tag tag-free">Free</span>');
          tags.push('<span class="tag tag-diff tag-' + g.difficulty.toLowerCase() + '">' + g.difficulty + '</span>');
          g.genres.forEach(function(genre) {
            tags.push('<span class="tag">' + genre.charAt(0).toUpperCase() + genre.slice(1).replace('-',' ') + '</span>');
          });
          var platformIcons = [];
          if (g.platforms.indexOf('pc') !== -1) platformIcons.push('🖥️');
          if (g.platforms.indexOf('ps5') !== -1) platformIcons.push('🎮');
          if (g.platforms.indexOf('xbox') !== -1) platformIcons.push('🟢');
          if (g.platforms.indexOf('switch') !== -1) platformIcons.push('🔴');
          if (g.platforms.indexOf('crossplay') !== -1) platformIcons.push('🌐');
          return '<div class="game-card">' +
            '<div class="game-card-header">' +
              '<span class="game-card-icon">' + g.icon + '</span>' +
              '<div class="game-card-info">' +
                '<strong>' + g.name + '</strong>' +
                '<span class="game-card-meta">' + g.players[0] + '-' + g.players[1] + ' players · ~' + g.session + 'h session · ' + platformIcons.join(' ') + '</span>' +
              '</div>' +
            '</div>' +
            '<div class="game-card-tags">' + tags.join('') + '</div>' +
          '</div>';
        }).join('');

        if (showRandom) {
          pickRandom(games);
        } else {
          randomPick.style.display = 'none';
        }
      }

      /* Snack suggestions */
      var snackData = SNACKS[selectedSession] || SNACKS[2];
      snackList.innerHTML = '<div class="snack-header">' + snackData.label + '</div>' +
        snackData.items.map(function(s) { return '<div class="snack-item">🍕 ' + s + '</div>'; }).join('');

      /* Schedule preview */
      updateSchedulePreview();

      resultsContainer.style.display = 'block';
      resultsContainer.scrollIntoView({ behavior:'smooth', block:'start' });
    }

    function pickRandom(games) {
      if (!games || games.length === 0) return;
      var g = games[Math.floor(Math.random() * games.length)];
      randomGameName.textContent = g.icon + ' ' + g.name;
      randomGameMeta.textContent = g.players[0] + '-' + g.players[1] + ' players · ' + g.difficulty + ' to learn · ' + (g.f2p ? 'Free to Play' : 'Paid') + ' · ~' + g.session + 'h session';
      randomPick.style.display = 'block';
    }

    function updateSchedulePreview() {
      var date = sessionDateInput.value;
      var time = sessionTimeInput.value;
      if (!date || !time) { schedulePreview.textContent = ''; return; }
      var dt = new Date(date + 'T' + time);
      var end = new Date(dt.getTime() + selectedSession * 60 * 60 * 1000);
      var opts = { weekday:'long', month:'long', day:'numeric' };
      var timeOpts = { hour:'numeric', minute:'2-digit' };
      schedulePreview.textContent = '🎮 Game Night: ' + dt.toLocaleDateString(undefined, opts) + ', ' + dt.toLocaleTimeString(undefined, timeOpts) + ' – ' + end.toLocaleTimeString(undefined, timeOpts);
    }

    /* ── Events ── */
    generateBtn.addEventListener('click', function() {
      renderResults(filterGames(), false);
    });

    randomBtn.addEventListener('click', function() {
      renderResults(filterGames(), true);
    });

    rerollBtn.addEventListener('click', function() {
      pickRandom(lastResults);
    });

    sessionDateInput.addEventListener('change', updateSchedulePreview);
    sessionTimeInput.addEventListener('change', updateSchedulePreview);

    copyScheduleBtn.addEventListener('click', function() {
      var date = sessionDateInput.value;
      var time = sessionTimeInput.value;
      if (!date || !time) return;
      var dt = new Date(date + 'T' + time);
      var end = new Date(dt.getTime() + selectedSession * 60 * 60 * 1000);
      var opts = { weekday:'long', month:'long', day:'numeric', year:'numeric' };
      var timeOpts = { hour:'numeric', minute:'2-digit' };

      var topGames = lastResults.slice(0, 5).map(function(g) { return g.icon + ' ' + g.name; }).join('\n');

      var text = '🎮 GAME NIGHT INVITE 🎮\n' +
        '═══════════════════════\n' +
        '📅 ' + dt.toLocaleDateString(undefined, opts) + '\n' +
        '🕐 ' + dt.toLocaleTimeString(undefined, timeOpts) + ' – ' + end.toLocaleTimeString(undefined, timeOpts) + '\n' +
        '👥 ' + selectedPlayers + '+ players\n' +
        '🎮 Platform: ' + selectedPlatform.toUpperCase() + '\n\n' +
        'Game lineup:\n' + topGames + '\n\n' +
        'Plan your night: leeroyjenkins.quest/game-night-planner';

      navigator.clipboard.writeText(text).then(function() {
        copyFeedback.textContent = 'Copied!';
        copyFeedback.style.opacity = '1';
        setTimeout(function() { copyFeedback.style.opacity = '0'; }, 2000);
      }).catch(function() {
        copyFeedback.textContent = 'Copy failed — try selecting text manually';
        copyFeedback.style.opacity = '1';
        setTimeout(function() { copyFeedback.style.opacity = '0'; }, 3000);
      });
    });

    /* ── Auto-generate on load ── */
    renderResults(filterGames(), false);
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Optimizer Cards */
    .optimizer-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.4rem 1.5rem; margin-bottom: 1rem; }
    .step-header { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.6rem; }
    .step-num { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: var(--accent-color); color: #fff; border-radius: 50%; font-size: 0.85rem; font-weight: 800; flex-shrink: 0; }
    .step-hint { color: var(--text-secondary); font-size: 0.85rem; margin-top: -0.5rem; margin-bottom: 0.8rem; font-style: italic; }

    /* Platform Grid */
    .platform-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem; }
    .platform-btn { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; padding: 0.8rem 0.5rem; border-radius: 10px; border: 2px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.15s; }
    .platform-btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .platform-btn.active { border-color: var(--accent-color); background: var(--accent-color); color: #fff; }
    .platform-icon { font-size: 1.4rem; }

    /* Genre Grid */
    .genre-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem; }
    .genre-btn { padding: 0.5rem 0.3rem; border-radius: 8px; border: 2px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .genre-btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .genre-btn.active { border-color: var(--accent-color); background: var(--accent-color); color: #fff; }

    /* Buttons */
    .btn-group { display: flex; gap: 0.3rem; }
    .btn { padding: 0.45rem 0.9rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn.active { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }
    .btn-primary { background: var(--accent-color); color: #fff; border-color: var(--accent-color); padding: 0.7rem 1.8rem; font-size: 1rem; font-weight: 700; }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { border-color: var(--border-color); color: var(--text-secondary); padding: 0.5rem 1.2rem; }
    .btn-secondary:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn-generate { width: 100%; margin-bottom: 1rem; }

    /* Random Pick */
    .random-pick { text-align: center; background: var(--card-bg); border: 2px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .random-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; color: var(--text-secondary); margin-bottom: 0.3rem; }
    .random-game { font-size: 1.8rem; font-weight: 900; color: var(--accent-color); }
    .random-meta { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.4rem; }

    /* Game Cards */
    .game-results { display: grid; gap: 0.6rem; margin-bottom: 1.5rem; }
    .game-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; transition: border-color 0.15s; }
    .game-card:hover { border-color: var(--accent-color); }
    .game-card-header { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.5rem; }
    .game-card-icon { font-size: 1.6rem; }
    .game-card-info { display: flex; flex-direction: column; }
    .game-card-info strong { color: var(--text-primary); font-size: 1rem; }
    .game-card-meta { color: var(--text-secondary); font-size: 0.78rem; margin-top: 0.1rem; }
    .game-card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .tag { display: inline-block; padding: 0.12rem 0.45rem; border-radius: 6px; font-size: 0.7rem; font-weight: 600; background: rgba(150,150,150,0.1); color: var(--text-secondary); }
    .tag-free { background: rgba(81,207,102,0.15); color: #51cf66; }
    .tag-easy { background: rgba(81,207,102,0.15); color: #51cf66; }
    .tag-medium { background: rgba(255,193,7,0.15); color: #ffc107; }
    .tag-hard { background: rgba(255,107,107,0.15); color: #ff6b6b; }
    .no-results { text-align: center; padding: 2rem; color: var(--text-secondary); }

    /* Snack Section */
    .snack-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; margin-bottom: 1.5rem; }
    .snack-section h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.8rem; }
    .snack-header { font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem; font-size: 0.9rem; }
    .snack-item { color: var(--text-secondary); font-size: 0.85rem; padding: 0.2rem 0; }
    .snack-list { display: flex; flex-direction: column; gap: 0.1rem; }

    /* Schedule Section */
    .schedule-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; }
    .schedule-section h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.8rem; }
    .schedule-form { display: flex; flex-direction: column; gap: 0.6rem; }
    .form-row { display: flex; align-items: center; gap: 0.8rem; }
    .form-row label { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); min-width: 80px; }
    .form-input { padding: 0.45rem 0.7rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-primary); font-size: 0.9rem; font-family: inherit; }
    .form-input:focus { outline: 2px solid var(--accent-color); outline-offset: 1px; }
    .schedule-preview { font-size: 0.9rem; color: var(--accent-color); font-weight: 600; padding: 0.5rem 0; min-height: 1.5rem; }

    /* Copy Feedback */
    .copy-feedback { margin-left: 0.8rem; font-size: 0.85rem; color: var(--accent-color); font-weight: 600; opacity: 0; transition: opacity 0.3s; }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    /* Related */
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .related-link { display: flex; flex-direction: column; gap: 0.3rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem; text-decoration: none; transition: border-color 0.2s; }
    .related-link:hover { border-color: var(--accent-color); text-decoration: none; }
    .related-link strong { color: var(--text-primary); font-size: 1rem; }
    .related-link span { color: var(--text-secondary); font-size: 0.85rem; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .platform-grid { grid-template-columns: repeat(3, 1fr); }
      .genre-grid { grid-template-columns: repeat(2, 1fr); }
      .btn-group { flex-wrap: wrap; }
      .random-game { font-size: 1.4rem; }
      .form-row { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
      .form-row label { min-width: auto; }
    }
  </style>
</SiteLayout>
