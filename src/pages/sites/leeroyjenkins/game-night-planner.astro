import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How many players do I need for a good game night?",
    a: "The sweet spot for most game nights is 3-6 players. With 2 players, you're limited to co-op or 1v1 games, but there are incredible options like It Takes Two, A Way Out, and fighting games. At 3-4 players, you unlock the widest selection of party and competitive games — Mario Kart, Smash Bros, Rocket League, and most board-game-style party games shine here. 5-8 players opens up Among Us, Jackbox Party Packs, and large lobby shooters. Above 8, you're looking at custom lobbies in games like Fortnite, Minecraft, or dedicated server games. The key is matching your player count to games designed for that range — a 4-player game forced to work with 8 feels worse than a game built for 8."
  },
  {
    q: "What are the best free-to-play games for game night?",
    a: "There are excellent free options across every genre. For shooters: Fortnite, Apex Legends, Valorant, and Call of Duty Warzone are all free and support squad play. For party games: Jackbox Party Packs require only one person to own the game (others join via phone). Fall Guys is free and supports up to 4-player squads. Rocket League went free-to-play and is perfect for 2v2 or 3v3. Among Us is practically free and works great with 5-10 players. Brawlhalla is a free Smash Bros alternative on all platforms. For co-op: Path of Exile, Genshin Impact, and Destiny 2's base game are free. The barrier to entry for game night has never been lower."
  },
  {
    q: "How do I handle crossplay between different platforms?",
    a: "Most major multiplayer games now support crossplay, but the experience varies. Full crossplay (PC, PlayStation, Xbox, Switch, Mobile) is available in Fortnite, Rocket League, Minecraft, Fall Guys, and Among Us. PC-Console crossplay (no Switch) works in Apex Legends, Call of Duty, Destiny 2, and Overwatch 2. Some games like Helldivers 2 only support PC-PS5. The biggest friction point is account linking — most games require everyone to create an Epic, EA, or Activision account and add friends through that system rather than platform-native friend lists. Set this up before game night starts to avoid 20 minutes of troubleshooting. Also note that PC players in shooters have a mouse-and-keyboard advantage, so some groups prefer to disable crossplay input or have PC players use controllers."
  },
  {
    q: "What's the ideal session length for a game night?",
    a: "Plan for 2-4 hours as the sweet spot. Under 2 hours feels rushed — by the time everyone connects, picks games, and gets settled, you've lost 20-30 minutes. A 2-hour session fits 3-4 rounds of a party game or one solid gaming session in a co-op or competitive game. 3-4 hours is ideal for variety nights where you rotate between 2-3 different games. Beyond 4 hours, fatigue sets in and performance drops — people start checking phones, losing focus, and getting tilted. If you're doing an extended marathon session (6+ hours), schedule breaks every 90 minutes, rotate games to keep energy up, and make sure everyone has snacks and drinks. The best game nights end with people wanting more, not relief that it's over."
  },
  {
    q: "How do I pick games that everyone will enjoy when skill levels vary?",
    a: "Skill gap is the number one game night killer, and the solution is game selection. Party games with built-in randomness — Mario Kart (items), Fall Guys (chaos), Jackbox (creativity over skill), Mario Party (dice and minigames) — naturally level the playing field. Co-op games like Deep Rock Galactic, Lethal Company, and Phasmophobia put everyone on the same team, so skilled players help rather than dominate. If you're playing competitive games, use handicap systems: give newer players better characters, use team balancing, or play objective modes where game sense matters more than aim. Avoid ultra-competitive ranked modes — stick to casual or custom lobbies. Games that are easy to learn but hard to master (Rocket League, Smash Bros with items on) work great because new players can contribute immediately while experienced players still have depth."
  }
];

