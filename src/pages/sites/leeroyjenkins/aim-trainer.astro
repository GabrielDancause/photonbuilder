    /* Game Area */
    .game-wrapper { border-radius: 12px; overflow: hidden; border: 2px solid var(--border-color); margin-bottom: 1rem; background: var(--card-bg); }
    .game-wrapper:fullscreen { display: flex; align-items: center; justify-content: center; background: #0a0a0f; }
    .game-wrapper:fullscreen .game-area { width: 100%; height: 100%; max-width: none; max-height: none; border-radius: 0; }
    .game-area { position: relative; width: 100%; height: 450px; overflow: hidden; user-select: none; -webkit-user-select: none; }
    .game-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.3); color: var(--text-secondary); font-size: 1.1rem; z-index: 5; }

    /* Target */
    .target { position: absolute; border-radius: 50%; cursor: crosshair; z-index: 2;
      background: radial-gradient(circle at 35% 35%, #ff6b6b, #ee5a24);
      box-shadow: 0 0 12px rgba(255,107,107,0.5), inset 0 0 8px rgba(255,255,255,0.2);
      transition: transform 0.06s;
    }
    .target::before { content: ''; position: absolute; top: 50%; left: 50%; width: 30%; height: 30%; background: rgba(255,255,255,0.7); border-radius: 50%; transform: translate(-50%, -50%); }
    .target::after { content: ''; position: absolute; top: 50%; left: 50%; width: 60%; height: 60%; border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; transform: translate(-50%, -50%); }
    .target:hover { transform: scale(1.05); }
