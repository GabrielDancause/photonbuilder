      { name: "Bount Assault on Soul Society", start: 92, end: 109, type: "filler" },
      { name: "Arrancar: The Arrival", start: 110, end: 131, type: "canon" },
      { name: "Arrancar: Hueco Mundo Sneak Entry", start: 132, end: 151, type: "canon" },
      { name: "Arrancar: The Fierce Fight", start: 152, end: 167, type: "canon" },
      { name: "New Captain Shūsuke Amagai Arc", start: 168, end: 189, type: "filler" },
      { name: "Arrancar: Decisive Battle of Karakura", start: 190, end: 205, type: "canon" },
      { name: "Turn Back the Pendulum (The Past)", start: 206, end: 212, type: "canon" },
      { name: "Fake Karakura Town", start: 213, end: 229, type: "canon" },
      { name: "Zanpakutō Unknown Tales Arc", start: 230, end: 255, type: "filler" },
      { name: "Beast Swords Arc", start: 256, end: 265, type: "filler" },
      { name: "Fake Karakura Town (cont.)", start: 266, end: 316, type: "canon" },
      { name: "Gotei 13 Invading Army Arc", start: 317, end: 342, type: "filler" },
      { name: "The Lost Agent (Fullbring Arc)", start: 343, end: 366, type: "canon" },
    ];

    const FILLER_EPISODES = new Set([
      33, 50,
      ...range(64, 109),
      ...range(128, 137),
      ...range(147, 149),
      ...range(168, 189),
      204, 205, 213, 214,
      ...range(227, 229),
      ...range(230, 265),
      266, 287,
      ...range(298, 299),
      ...range(303, 305),
      ...range(311, 316),
      ...range(317, 342),
      355
    ]);

    const MIXED_EPISODES = new Set([]);

    function range(a, b) { const r = []; for (let i = a; i <= b; i++) r.push(i); return r; }

