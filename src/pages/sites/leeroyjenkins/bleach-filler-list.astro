  <script type="module">{`
    // ─── Episode Data ───
    const ARCS = [
      { name: "Agent of the Shinigami", start: 1, end: 20, type: "canon" },
      { name: "Soul Society: The Entry", start: 21, end: 41, type: "canon" },
