    // Build episode data
    const episodes = [];
    for (let i = 1; i <= 366; i++) {
      let type = "canon";
      if (FILLER_EPISODES.has(i)) type = "filler";
      else if (MIXED_EPISODES.has(i)) type = "mixed";

      let arc = "Unknown";
      for (const a of ARCS) {
        if (i >= a.start && i <= a.end) { arc = a.name; break; }
      }

      episodes.push({
        num: i,
        title: TITLES[i] || "Episode " + i,
        type,
        arc,
      });
    }

    // Compute stats
    const canonCount = episodes.filter(e => e.type === "canon").length;
    const fillerCount = episodes.filter(e => e.type === "filler").length;
    const mixedCount = episodes.filter(e => e.type === "mixed").length;
    const fillerPct = ((fillerCount / 366) * 100).toFixed(1);
    const timeSaved = Math.round(fillerCount * 20 / 60); // ~20 min per ep

    document.getElementById("stat-canon").textContent = canonCount;
    document.getElementById("stat-filler").textContent = fillerCount;
    document.getElementById("stat-mixed").textContent = mixedCount;
    document.getElementById("stat-pct").textContent = fillerPct + "%";
    document.getElementById("stat-time").textContent = "~" + timeSaved + "h";

    // localStorage progress
    const STORAGE_KEY = "bleach-filler-watched";
    let watched = new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]"));

    function saveWatched() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...watched]));
      updateProgress();
    }

    function updateProgress() {
      const pct = ((watched.size / 366) * 100).toFixed(1);
      document.getElementById("progress-bar").style.width = pct + "%";
      document.getElementById("progress-text").textContent = watched.size + " / 366 episodes watched (" + pct + "%)";
      // Update checkboxes
      document.querySelectorAll(".ep-check").forEach(cb => {
        cb.checked = watched.has(parseInt(cb.dataset.ep));
      });
    }

    document.getElementById("btn-mark-canon").addEventListener("click", () => {
      episodes.forEach(e => { if (e.type === "canon") watched.add(e.num); });
      saveWatched();
    });

    document.getElementById("btn-reset").addEventListener("click", () => {
      if (confirm("Reset all progress?")) { watched.clear(); saveWatched(); }
    });

    // Populate arc filter dropdown
    const arcNames = [...new Set(episodes.map(e => e.arc))];
    const arcSelect = document.getElementById("arc-filter");
    arcNames.forEach(name => {
      const opt = document.createElement("option");
      opt.value = name;
      opt.textContent = name;
      arcSelect.appendChild(opt);
    });

    // Build arc view
    function buildArcView() {
      const container = document.getElementById("arc-view");
      container.innerHTML = "";
      const arcGroups = [];
      let currentArc = null;
      episodes.forEach(ep => {
        if (!currentArc || currentArc.name !== ep.arc) {
          currentArc = { name: ep.arc, episodes: [], types: new Set() };
          arcGroups.push(currentArc);
        }
        currentArc.episodes.push(ep);
        currentArc.types.add(ep.type);
      });

      arcGroups.forEach(ag => {
        const block = document.createElement("div");
        block.className = "arc-block";

        // Determine dominant type for badge
        let badgeType = "canon";
        if (ag.types.size === 1) badgeType = [...ag.types][0];
        else badgeType = "mixed";

        // Override: if all eps are filler, it's filler
        const allFiller = ag.episodes.every(e => e.type === "filler");
        const allCanon = ag.episodes.every(e => e.type === "canon");
        if (allFiller) badgeType = "filler";
        else if (allCanon) badgeType = "canon";

        const rangeStr = ag.episodes[0].num + "–" + ag.episodes[ag.episodes.length - 1].num;

        block.innerHTML = '<div class="arc-header"><div><span class="arc-title">' + ag.name + '</span></div><div class="arc-meta"><span class="arc-badge ' + badgeType + '">' + badgeType + '</span><span>Ep ' + rangeStr + ' (' + ag.episodes.length + ')</span><span class="arc-chevron">▶</span></div></div><div class="arc-eps">' + ag.episodes.map(ep => '<div class="arc-ep-row"><span class="arc-ep-num">' + ep.num + '</span><span class="arc-ep-title">' + ep.title + '</span><span class="type-tag ' + ep.type + '">' + ep.type + '</span></div>').join("") + '</div>';

        block.querySelector(".arc-header").addEventListener("click", () => {
          const eps = block.querySelector(".arc-eps");
          const chevron = block.querySelector(".arc-chevron");
          eps.classList.toggle("open");
          chevron.classList.toggle("open");
        });

        container.appendChild(block);
      });
    }
    buildArcView();

    // Render table
    let sortCol = "ep";
    let sortDir = 1;
    let filterType = "all";
    let filterArc = "all";
    let filterWatched = "all";
    let searchQuery = "";

    function getFiltered() {
      let list = [...episodes];
      if (filterType !== "all") list = list.filter(e => e.type === filterType);
      if (filterArc !== "all") list = list.filter(e => e.arc === filterArc);
      if (filterWatched === "watched") list = list.filter(e => watched.has(e.num));
      if (filterWatched === "unwatched") list = list.filter(e => !watched.has(e.num));
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        list = list.filter(e => e.title.toLowerCase().includes(q) || String(e.num).includes(q));
      }
      // Sort
      list.sort((a, b) => {
        let va, vb;
        if (sortCol === "ep") { va = a.num; vb = b.num; }
        else if (sortCol === "title") { va = a.title; vb = b.title; }
        else if (sortCol === "type") { va = a.type; vb = b.type; }
        else if (sortCol === "arc") { va = a.arc; vb = b.arc; }
        if (va < vb) return -1 * sortDir;
        if (va > vb) return 1 * sortDir;
        return 0;
      });
      return list;
    }

    function renderTable() {
      const tbody = document.getElementById("episode-tbody");
      const filtered = getFiltered();
      tbody.innerHTML = filtered.map(ep => {
        const checked = watched.has(ep.num) ? "checked" : "";
        return '<tr><td style="text-align:center"><input type="checkbox" class="ep-check" data-ep="' + ep.num + '" ' + checked + '></td><td>' + ep.num + '</td><td>' + ep.title + '</td><td><span class="type-tag ' + ep.type + '">' + ep.type + '</span></td><td>' + ep.arc + '</td></tr>';
      }).join("");
      document.getElementById("table-count").textContent = "Showing " + filtered.length + " of " + episodes.length + " episodes";

      // Attach checkbox listeners
      tbody.querySelectorAll(".ep-check").forEach(cb => {
        cb.addEventListener("change", () => {
          const num = parseInt(cb.dataset.ep);
          if (cb.checked) watched.add(num); else watched.delete(num);
          saveWatched();
        });
      });
    }

    // Filter listeners
    document.querySelectorAll("#type-filter .btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("#type-filter .btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        filterType = btn.dataset.type;
        renderTable();
      });
    });

    arcSelect.addEventListener("change", () => { filterArc = arcSelect.value; renderTable(); });
    document.getElementById("search-input").addEventListener("input", (e) => { searchQuery = e.target.value; renderTable(); });

    document.querySelectorAll("#watched-filter .btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll("#watched-filter .btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        filterWatched = btn.dataset.w;
        renderTable();
      });
    });

    // Sort listeners
    document.querySelectorAll(".sortable").forEach(th => {
      th.addEventListener("click", () => {
        const col = th.dataset.sort;
        if (sortCol === col) sortDir *= -1; else { sortCol = col; sortDir = 1; }
        renderTable();
      });
    });

    // Initial render
    renderTable();
    updateProgress();
  `}</script>
</SiteLayout>
