---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How much filler is in Bleach?",
    a: "The original Bleach anime has 366 episodes, of which approximately 163 are filler — that's about 45% of the total series. The filler spans several multi-episode arcs (like the Bount Arc at 46 episodes) and numerous standalone episodes scattered throughout the canon storyline. If you skip all filler, you can watch the core story in roughly 203 episodes. The sequel series Thousand-Year Blood War (TYBW) is 100% canon with zero filler."
  },
  {
    q: "What are the biggest filler arcs in Bleach?",
    a: "The largest filler arcs are: the Bount Arc (episodes 64–109, 46 episodes), the New Captain Shūsuke Amagai Arc (episodes 168–189, 22 episodes), the Zanpakutō Unknown Tales / Beast Swords Arc (episodes 230–265, 36 episodes), and the Gotei 13 Invading Army Arc (episodes 317–342, 26 episodes). These four arcs alone account for 130 filler episodes. The Bount Arc is the longest filler stretch and is the most commonly skipped."
  },
  {
    q: "Should I skip Bleach filler or watch it?",
    a: "If you want the tightest story experience, skip all filler — the canon episodes tell a complete, coherent story without any filler arcs. If you enjoy Bleach's characters and world and want more content, some filler arcs are better than others. The Zanpakutō Unknown Tales Arc (230–265) is often considered the best filler arc due to its creative Zanpakutō spirit designs. The Bount Arc (64–109) is generally considered the weakest. Standalone filler episodes between canon arcs are usually safe to skip."
  },
  {
    q: "What is the watch order for Bleach without filler?",
    a: "Watch episodes 1–63 (Agent of the Shinigami through Soul Society), then skip to 110–127 (Arrancar intro, but note some mixed episodes), continue with 138–167 (Hueco Mundo), skip to 190–205 and 206–212 (Fierce Fight and Past Arc), then 215–226 and 230+ canon portions of Fake Karakura Town, and finish with 343–366 (Fullbring Arc). After the original series, watch Thousand-Year Blood War (TYBW) which is entirely canon. Use the episode table below for exact episode-by-episode guidance."
  },
  {
    q: "Is Bleach: Thousand-Year Blood War (TYBW) filler-free?",
    a: "Yes, Thousand-Year Blood War is 100% canon. It adapts the final manga arc that the original anime never covered. TYBW is produced by Studio Pierrot with updated animation quality and follows the manga faithfully with some added scenes that are manga-approved expansions, not filler. If you're watching Bleach for the first time, TYBW picks up directly after episode 366 of the original series."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Bleach Filler List: Complete Episode Guide (Canon vs Filler)",
    "description": "Interactive Bleach filler episode guide with all 366 episodes classified as canon, filler, or mixed. Track progress, filter by type, and find which episodes to skip.",
    "applicationCategory": "Entertainment",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Bleach Filler List: Complete Episode Guide (Canon vs Filler)",
  description: "Complete Bleach filler list with all 366 episodes marked canon, filler, or mixed. Interactive tracker, arc guide, and skip list. Includes TYBW info.",
  category: "tool",
  published: "2026-03-29",
};
