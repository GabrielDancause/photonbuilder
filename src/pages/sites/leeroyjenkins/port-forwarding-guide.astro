        ps: { tcp: "80, 443, 1935, 3478-3480", udp: "3478-3479, 6672, 61455-61458" },
        xbox: { tcp: "80, 443, 3074", udp: "88, 500, 3074, 3544, 4500, 6672, 61455-61458" }
      },
      league: {
        pc: { tcp: "2099, 5223, 8088, 8393-8400", udp: "5000-5500" },
        ps: { tcp: "N/A", udp: "N/A" },
        xbox: { tcp: "N/A", udp: "N/A" }
      },
      minecraft: {
