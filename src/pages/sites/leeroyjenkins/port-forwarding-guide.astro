        xbox: { tcp: "3074", udp: "88, 500, 3074, 3544, 4500" }
      },
      valorant: {
        pc: { tcp: "2099, 5223, 8393-8400, 8088", udp: "5000-5500, 8166-8199" },
        ps: { tcp: "N/A", udp: "N/A" },
        xbox: { tcp: "N/A", udp: "N/A" }
      }
    };

    const gameSelect = document.getElementById('game-select');
    const platGroup = document.getElementById('platform-group');
    const platSelect = document.getElementById('platform-select');
    const resultBox = document.getElementById('port-results');

    function updateResults() {
      const game = gameSelect.value;
      const plat = platSelect.value;

      if (game && plat) {
        if (portDB[game][plat].tcp === "N/A") {
           document.getElementById('result-title').innerText = `${gameSelect.options[gameSelect.selectedIndex].text} is not available on this platform.`;
           document.getElementById('tcp-list').innerText = "N/A";
           document.getElementById('udp-list').innerText = "N/A";
        } else {
           document.getElementById('result-title').innerText = `Ports for ${gameSelect.options[gameSelect.selectedIndex].text} (${platSelect.options[platSelect.selectedIndex].text})`;
           document.getElementById('tcp-list').innerText = portDB[game][plat].tcp;
           document.getElementById('udp-list').innerText = portDB[game][plat].udp;
        }
        resultBox.style.display = 'block';
      } else {
        resultBox.style.display = 'none';
      }
    }

    gameSelect.addEventListener('change', function() {
      if (this.value) {
        platGroup.style.display = 'block';
        updateResults();
      } else {
        platGroup.style.display = 'none';
        resultBox.style.display = 'none';
        platSelect.value = '';
      }
    });

    platSelect.addEventListener('change', updateResults);

    document.getElementById('copy-ports-btn').addEventListener('click', function() {
       const tcp = document.getElementById('tcp-list').innerText;
       const udp = document.getElementById('udp-list').innerText;
       const game = gameSelect.options[gameSelect.selectedIndex].text;
       const textToCopy = `${game} Ports:\nTCP: ${tcp}\nUDP: ${udp}`;

       navigator.clipboard.writeText(textToCopy).then(() => {
           const btn = document.getElementById('copy-ports-btn');
           btn.innerText = "Copied!";
           setTimeout(() => { btn.innerText = "Copy to Clipboard"; }, 2000);
       });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; border-bottom: 1px solid var(--border-color); margin-bottom: 2rem; }
    .hero h1 { font-size: 2.8rem; font-weight: 800; margin-bottom: 1rem; color: #fff; line-height: 1.2; }
    .hero p { color: var(--text-secondary); font-size: 1.2rem; max-width: 600px; margin: 0 auto; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .tool-header { text-align: center; margin-bottom: 2rem; }
    .tool-header h2 { color: #fff; margin-bottom: 0.5rem; }
    .tool-header p { color: #94a3b8; }

    .select-group { margin-bottom: 1.5rem; max-width: 400px; margin-left: auto; margin-right: auto; }
    .select-group label { display: block; font-weight: 600; color: #e2e8f0; margin-bottom: 0.5rem; }
    .select-group select { width: 100%; padding: 0.8rem 1rem; border-radius: 8px; border: 1px solid #334155; background: #0f172a; color: #fff; font-size: 1.1rem; cursor: pointer; outline: none; }
    .select-group select:focus { border-color: var(--accent-color); }

    .results-box { margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 2rem; text-align: center; }
    .results-box h3 { color: #fff; margin-bottom: 1.5rem; font-size: 1.5rem; }

    .port-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
    @media (max-width: 600px) { .port-grid { grid-template-columns: 1fr; } }

    .port-column { background: #0f172a; border: 1px solid #334155; border-radius: 8px; padding: 1.5rem; text-align: center; }
    .port-type { font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem; display: inline-block; padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.9rem; }
    .tcp { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }
    .udp { background: rgba(16, 185, 129, 0.2); color: #10b981; }
    .port-list { color: #fff; font-family: monospace; font-size: 1.1rem; word-break: break-all; }

    .secondary-btn { background: transparent; border: 1px solid var(--accent-color); color: var(--accent-color); padding: 0.6rem 1.5rem; border-radius: 6px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .secondary-btn:hover { background: rgba(147, 51, 234, 0.1); }

    .article-content { color: #e2e8f0; font-size: 1.1rem; line-height: 1.7; margin-top: 3rem; }
    .article-content h2 { font-size: 1.8rem; color: #fff; margin-top: 2.5rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    .article-content h3 { font-size: 1.3rem; color: var(--accent-color); margin-top: 1.5rem; margin-bottom: 0.8rem; }
    .article-content p { margin-bottom: 1.5rem; }
    .article-content ul, .article-content ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .article-content li { margin-bottom: 0.5rem; }
    .article-content a { color: var(--accent-color); text-decoration: none; border-bottom: 1px dotted var(--accent-color); }
    .article-content a:hover { color: #fff; border-bottom-style: solid; }
    .article-content strong { color: #fff; font-weight: 700; }
  </style>
</SiteLayout>
