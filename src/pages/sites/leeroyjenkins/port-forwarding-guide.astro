        ps: { tcp: "1024-1124, 1935, 3216, 3478-3480, 9960-9969, 18000, 18120, 18060, 27900, 28910, 29900", udp: "1024-1124, 3074, 3478-3479, 18000, 29900, 37000-40000" },
        xbox: { tcp: "1024-1124, 3074, 3216, 9960-9969, 18000, 18120, 18060, 27900, 28910, 29900", udp: "88, 500, 1024-1124, 3074, 3544, 4500, 18000, 29900, 37000-40000" }
      },
      cod: {
        pc: { tcp: "3074, 27014-27050", udp: "3074, 3478, 4379-4380, 27000-27031, 27036" },
        ps: { tcp: "1935, 3074, 3478-3480", udp: "3074, 3478-3479" },
        xbox: { tcp: "3074", udp: "88, 500, 3074, 3544, 4500" }
      },
      cs2: {
        pc: { tcp: "27015, 27036", udp: "27015, 27031-27036" },
        ps: { tcp: "N/A", udp: "N/A" },
        xbox: { tcp: "N/A", udp: "N/A" }
      },
      destiny: {
        pc: { tcp: "1935, 3097, 3478-3480", udp: "3074, 3478-3479" },
        ps: { tcp: "1935, 3478-3480", udp: "3074, 3478-3479" },
        xbox: { tcp: "3074", udp: "88, 500, 1200, 3074, 3544, 4500" }
      },
      fifa: {
        pc: { tcp: "3569, 9946, 9988, 10000-20000, 42124", udp: "3659, 9000-9999" },
        ps: { tcp: "1935, 3478-3480, 3659, 10000-10099, 42127", udp: "3074, 3478-3479, 3659, 6000" },
        xbox: { tcp: "3074, 3659", udp: "88, 500, 3074, 3544, 3659, 4500" }
      },
      fortnite: {
        pc: { tcp: "433, 3478-3479, 5060, 5062, 5222, 6250, 12000-65000", udp: "433, 3478-3479, 5060, 5062, 6250, 12000-65000" },
        ps: { tcp: "1935, 3478-3480", udp: "3074, 3478-3479" },
        xbox: { tcp: "3074", udp: "88, 500, 3074, 3544, 4500" }
