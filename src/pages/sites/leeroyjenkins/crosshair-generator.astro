---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "What is a crosshair generator?",
    a: "A crosshair generator is a tool that lets you design and customize your in-game crosshair visually. Instead of manually tweaking console commands or menu sliders, you adjust controls like shape, color, size, thickness, and gap in real-time and see the result instantly. Once you're happy with the design, you can export the settings as a Valorant crosshair code or CS2 console commands to use in-game."
  },
  {
    q: "How do I import a crosshair code in Valorant?",
    a: "Open Valorant, go to Settings → Crosshair → Import Crosshair Profile. Paste the code generated by this tool and click Import. The crosshair will appear as a new profile you can select. You can store up to 15 crosshair profiles in Valorant. Note that Valorant crosshair codes encode all settings including color, outlines, and firing error — this generator covers the core visual settings."
  },
  {
    q: "How do I apply crosshair commands in CS2?",
    a: "Open the CS2 console (press ~ or the key you've bound it to) and paste the generated commands. Each command sets one property like cl_crosshairsize, cl_crosshairgap, cl_crosshairthickness, etc. You can also add these commands to your autoexec.cfg file so they load automatically every time you launch the game. The console must be enabled in Settings → Game → Enable Developer Console."
  },
  {
    q: "Does crosshair shape actually affect aim?",
    a: "Yes, but it's more about visibility and preference than mechanical advantage. A crosshair that's too large obscures targets at long range. A crosshair that's too small is hard to see during fast movement. Most pros use a small cross or dot with a center gap so they can see exactly where their bullets will land without blocking the target. The best crosshair is one you can see clearly without it distracting you."
  },
  {
    q: "What crosshair do pro players use?",
    a: "Pro crosshairs vary widely, but common patterns emerge. TenZ uses a small cyan cross (size 4, gap 2, thickness 2), s1mple prefers a classic green cross with tight gap in CS2, Shroud uses a small green cross with a center dot, and aceu runs a small cyan cross (size 3, gap 2, thickness 2) for fast flick-heavy play. Most pros favor small-to-medium crosses in green, cyan, or white because these colors contrast well against most game environments."
  },
  {
    q: "What's the best crosshair color for visibility?",
    a: "Green and cyan are the most popular competitive colors because they contrast well against most map environments (brown buildings, grey walls, dark corners). White works well on darker maps but can blend into bright areas. Red and pink are distinctive but can blend with blood effects or enemy UI elements. Yellow is visible but can cause eye fatigue. Ultimately, the best color is one that stands out on the maps you play most without straining your eyes."
  },
  {
    q: "Can I use a crosshair overlay instead of in-game settings?",
    a: "Some players use external crosshair overlays (software that draws a crosshair on top of any game), but this is generally discouraged in competitive play. Most anti-cheat systems flag overlay software, and some games explicitly ban them in their terms of service. Valorant's Vanguard anti-cheat is particularly strict. It's always safer to use the game's built-in crosshair customization, which is why tools like this generator that export native game codes are preferred."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Crosshair Generator — Custom Crosshairs for FPS",
    "description": "Free crosshair generator with live preview. Customize shape, color, size, thickness, gap, and outlines. Export Valorant crosshair codes and CS2 console commands. Pro player presets: TenZ, s1mple, Shroud, aceu.",
    "applicationCategory": "Game",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Crosshair Generator — Custom Crosshairs for FPS",
  description: "Free crosshair generator with live preview canvas. Customize shape, color, size, gap, thickness, and outlines. Export Valorant codes & CS2 commands. Pro player presets: TenZ, s1mple, Shroud, aceu.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Crosshair Generator — Custom Crosshairs for FPS"
  description="Free crosshair generator with live preview canvas. Customize shape, color, size, gap, thickness, and outlines. Export Valorant codes & CS2 commands. Pro player presets: TenZ, s1mple, Shroud, aceu."
  canonical="https://leeroyjenkins.quest/crosshair-generator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Crosshair Generator</h1>
      <p>Design your perfect custom crosshair with a live preview. Export Valorant crosshair codes and CS2 commands instantly. Load pro player presets with one click.</p>
    </div>

    <section class="content-section">
      <!-- Preview Canvas -->
      <div class="preview-wrapper">
        <canvas id="crosshair-canvas" width="800" height="400"></canvas>
        <div class="preview-bar">
          <span class="preview-label">Background</span>
          <div class="btn-group" id="bg-select">
            <button class="btn btn-sm active" data-bg="dark">Dark</button>
            <button class="btn btn-sm" data-bg="dust">Dust</button>
            <button class="btn btn-sm" data-bg="green">Green</button>
            <button class="btn btn-sm" data-bg="bright">Bright</button>
          </div>
        </div>
      </div>

      <!-- Controls -->
      <div class="controls-grid">
        <!-- Shape -->
        <div class="ctrl-card">
          <h3>Shape</h3>
          <div class="btn-group shape-group" id="shape-select">
            <button class="btn active" data-shape="cross">Cross</button>
            <button class="btn" data-shape="dot">Dot</button>
            <button class="btn" data-shape="circle">Circle</button>
            <button class="btn" data-shape="t-shape">T-Shape</button>
          </div>
        </div>

        <!-- Color -->
        <div class="ctrl-card">
          <h3>Color</h3>
          <div class="color-row">
            <input type="color" id="ctrl-color" value="#00ff00" />
            <div class="color-swatches" id="color-swatches">
              <button class="swatch" data-color="#00ff00" style="background:#00ff00;" title="Green"></button>
              <button class="swatch" data-color="#00ffff" style="background:#00ffff;" title="Cyan"></button>
              <button class="swatch" data-color="#ffffff" style="background:#ffffff;" title="White"></button>
              <button class="swatch" data-color="#ff0000" style="background:#ff0000;" title="Red"></button>
              <button class="swatch" data-color="#ffff00" style="background:#ffff00;" title="Yellow"></button>
              <button class="swatch" data-color="#ff00ff" style="background:#ff00ff;" title="Pink"></button>
            </div>
          </div>
          <div class="slider-row">
            <label>Opacity</label>
            <input type="range" id="ctrl-opacity" min="0.1" max="1" step="0.05" value="1" />
            <span class="slider-val" id="lbl-opacity">100%</span>
          </div>
        </div>

        <!-- Dimensions -->
        <div class="ctrl-card">
          <h3>Dimensions</h3>
          <div class="slider-row">
            <label>Size</label>
            <input type="range" id="ctrl-size" min="1" max="30" step="1" value="5" />
            <span class="slider-val" id="lbl-size">5</span>
          </div>
          <div class="slider-row">
            <label>Thickness</label>
            <input type="range" id="ctrl-thickness" min="1" max="10" step="0.5" value="2" />
            <span class="slider-val" id="lbl-thickness">2</span>
          </div>
          <div class="slider-row">
            <label>Gap</label>
            <input type="range" id="ctrl-gap" min="0" max="15" step="1" value="3" />
            <span class="slider-val" id="lbl-gap">3</span>
          </div>
        </div>

        <!-- Extras -->
        <div class="ctrl-card">
          <h3>Extras</h3>
          <div class="toggle-row">
            <label>Outline</label>
            <input type="checkbox" id="ctrl-outline" checked />
          </div>
          <div class="slider-row" id="outline-color-row">
            <label>Outline Color</label>
            <input type="color" id="ctrl-outline-color" value="#000000" />
          </div>
          <div class="slider-row" id="outline-width-row">
            <label>Outline Width</label>
            <input type="range" id="ctrl-outline-width" min="0.5" max="4" step="0.5" value="1" />
            <span class="slider-val" id="lbl-outline-width">1</span>
          </div>
          <div class="toggle-row">
            <label>Center Dot</label>
            <input type="checkbox" id="ctrl-dot" />
          </div>
          <div class="slider-row" id="dot-size-row" style="display:none;">
            <label>Dot Size</label>
            <input type="range" id="ctrl-dot-size" min="1" max="8" step="0.5" value="2" />
            <span class="slider-val" id="lbl-dot-size">2</span>
          </div>
        </div>
      </div>

      <!-- Pro Presets -->
      <h2>Pro Player Presets</h2>
      <div class="presets-grid" id="pro-presets">
        <button class="preset-card" data-preset="tenz">
          <strong>TenZ</strong>
          <span>Cyan cross · Size 4 · Gap 2 · Thickness 2</span>
        </button>
        <button class="preset-card" data-preset="s1mple">
          <strong>s1mple</strong>
          <span>Green cross · Size 3 · Gap 0 · Thickness 1</span>
        </button>
        <button class="preset-card" data-preset="shroud">
          <strong>Shroud</strong>
          <span>Green cross · Size 4 · Gap 1 · Dot on</span>
        </button>
        <button class="preset-card" data-preset="aceu">
          <strong>aceu</strong>
          <span>Cyan cross · Size 3 · Gap 2 · Thickness 2</span>
        </button>
      </div>

      <!-- Export -->
      <h2>Export Crosshair</h2>
      <div class="export-grid">
        <div class="export-card">
          <div class="export-header">
            <h3>Valorant Crosshair Code</h3>
            <button class="btn btn-sm" id="copy-val">Copy</button>
          </div>
          <code class="export-code" id="val-code">—</code>
        </div>
        <div class="export-card">
          <div class="export-header">
            <h3>CS2 Console Commands</h3>
            <button class="btn btn-sm" id="copy-cs2">Copy</button>
          </div>
          <code class="export-code" id="cs2-code">—</code>
        </div>
        <div class="export-card export-png-card" style="grid-column:1/-1;">
          <div class="export-header">
            <h3>PNG Download</h3>
            <span class="export-hint">Transparent PNG for crosshair overlay software</span>
          </div>
          <button class="btn btn-primary btn-sm" id="download-png">Download PNG (128×128)</button>
        </div>
      </div>

      <!-- Saved Presets -->
      <h2>Saved Presets</h2>
      <div class="saved-bar">
        <button class="btn btn-primary btn-sm" id="save-preset-btn">Save Current</button>
        <button class="btn btn-sm" id="clear-presets-btn">Clear All</button>
      </div>
      <div class="presets-grid" id="saved-presets-container">
        <p class="empty-presets" id="no-presets-msg">No saved presets yet — design a crosshair and click Save Current.</p>
      </div>

      <!-- Content -->
      <h2>How to Use This Crosshair Generator</h2>
      <p>Use the controls above to design your crosshair in real time. The canvas preview shows exactly how your crosshair will look against different backgrounds. Choose a shape, adjust size, thickness, gap, color, and outline settings until you're satisfied. Then export the settings as a Valorant crosshair code or CS2 console commands to use in-game.</p>

      <h3>Crosshair Shapes</h3>
      <p><strong>Cross:</strong> The standard crosshair used by most competitive players. Four lines extending from the center with an adjustable gap. Provides clear directional reference for both horizontal and vertical aim.</p>
      <p><strong>Dot:</strong> A single center dot with no extending lines. Popular among AWP/Op players and some rifle players who want minimal screen obstruction. Works best at close to medium range.</p>
      <p><strong>Circle:</strong> A ring centered on your aim point. Useful for shotgun players or games where a spread indicator is helpful. Less common in tactical shooters but popular in arena shooters.</p>
      <p><strong>T-Shape:</strong> A cross without the top line. Some players prefer this because the top line can obscure headshot-level targets. Popularized by certain CS:GO professionals and still used in CS2.</p>

      <h3>Key Settings Explained</h3>
      <p><strong>Size</strong> controls how long the crosshair lines extend from the center. Larger values help you see the crosshair in chaotic fights but obscure more of the screen. Most pros use sizes between 2-5.</p>
      <p><strong>Thickness</strong> sets the width of crosshair lines. Thinner lines are more precise but harder to see. A thickness of 1-2 is standard for competitive play.</p>
      <p><strong>Gap</strong> is the space between the center point and where the crosshair lines begin. A smaller gap overlaps lines closer to center, while a larger gap leaves space for a clearer view of your target. Gap is one of the most personal preference settings — experiment to find yours.</p>
      <p><strong>Outline</strong> adds a dark border around your crosshair lines, making them visible against any background color. Most competitive players keep outlines on with a width of 1 for maximum visibility.</p>
      <p><strong>Center Dot</strong> adds a small dot at the exact center point, independent of gap settings. Useful for players who want a precise aim reference in addition to the cross lines.</p>

      <h3>Choosing the Right Crosshair</h3>
      <ul>
        <li><strong>For Valorant:</strong> A small to medium cross in cyan or green, size 3-5, thickness 1-2, gap 2-4 with outlines on. This matches most pro Valorant setups and provides good visibility on all maps.</li>
        <li><strong>For CS2:</strong> A tight green cross with size 2-4, thickness 1, gap 0-2, and outlines on. CS2 crosshairs are typically smaller and tighter than Valorant crosshairs.</li>
        <li><strong>For beginners:</strong> Start with a medium green cross (size 4, thickness 2, gap 3) and adjust from there. Green is forgiving across all lighting conditions and map types.</li>
        <li><strong>For AWP/Op players:</strong> Consider a dot crosshair or a small cross — you're scoping most of the time, so your unscoped crosshair is mainly for quick no-scopes.</li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Tools</h2>
      <div class="related-grid">
        <a href="/aim-trainer" class="related-link">
          <strong>Aim Trainer</strong>
          <span>Free online FPS aim practice with 4 modes — train your aim after designing your crosshair</span>
        </a>
        <a href="/mouse-sensitivity-converter" class="related-link">
          <strong>Mouse Sensitivity Converter</strong>
          <span>Convert your sensitivity between Valorant, CS2, Apex, Overwatch, and more</span>
        </a>
        <a href="/fps-settings-optimizer" class="related-link">
          <strong>FPS Settings Optimizer</strong>
          <span>Optimize your in-game settings for maximum FPS and competitive advantage</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ── State ── */
    var S = {
      shape: 'cross', color: '#00ff00', opacity: 1,
      size: 5, thickness: 2, gap: 3,
      outline: true, outlineColor: '#000000', outlineWidth: 1,
      dot: false, dotSize: 2
    };
    var bgMode = 'dark';

    /* ── Pro Presets ── */
    var PRO = {
      tenz:   { shape:'cross', color:'#00ffff', opacity:1, size:4, thickness:2, gap:2, outline:true, outlineColor:'#000000', outlineWidth:1, dot:false, dotSize:2 },
      s1mple: { shape:'cross', color:'#00ff00', opacity:1, size:3, thickness:1, gap:0, outline:true, outlineColor:'#000000', outlineWidth:1, dot:false, dotSize:2 },
      shroud: { shape:'cross', color:'#00ff00', opacity:1, size:4, thickness:1, gap:1, outline:false, outlineColor:'#000000', outlineWidth:1, dot:true,  dotSize:2 },
      aceu:   { shape:'cross', color:'#00ffff', opacity:1, size:3, thickness:2, gap:2, outline:false, outlineColor:'#000000', outlineWidth:1, dot:false, dotSize:2 }
    };

    /* ── Canvas ── */
    var canvas = document.getElementById('crosshair-canvas');
    var ctx = canvas.getContext('2d');
    var SCALE = 3;

    /* ── Background Scenes ── */
    function drawBg() {
      var w = canvas.width, h = canvas.height;
      if (bgMode === 'dark') {
        var g = ctx.createLinearGradient(0, 0, 0, h);
        g.addColorStop(0, '#1a1a2e'); g.addColorStop(1, '#16213e');
        ctx.fillStyle = g; ctx.fillRect(0, 0, w, h);
        ctx.fillStyle = '#0f1629'; ctx.fillRect(50, h*0.45, 120, h*0.55);
        ctx.fillStyle = '#12182d'; ctx.fillRect(w*0.6, h*0.35, 140, h*0.65);
        ctx.fillStyle = '#1a1f3a'; ctx.fillRect(w*0.28, h*0.65, 180, h*0.35);
        ctx.fillStyle = '#0d1220'; ctx.fillRect(0, h*0.85, w, h*0.15);
        ctx.strokeStyle = 'rgba(255,255,255,0.03)'; ctx.lineWidth = 1;
        for (var x = 0; x < w; x += 40) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, h); ctx.stroke(); }
        for (var y = 0; y < h; y += 40) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke(); }
      } else if (bgMode === 'dust') {
        var g2 = ctx.createLinearGradient(0, 0, 0, h);
        g2.addColorStop(0, '#c4a35a'); g2.addColorStop(1, '#8b7240');
        ctx.fillStyle = g2; ctx.fillRect(0, 0, w, h);
        ctx.fillStyle = '#a38940'; ctx.fillRect(60, h*0.4, 130, h*0.6);
        ctx.fillStyle = '#9a8035'; ctx.fillRect(w*0.6, h*0.3, 150, h*0.7);
        ctx.fillStyle = '#7a6430'; ctx.fillRect(0, h*0.82, w, h*0.18);
      } else if (bgMode === 'green') {
        var g3 = ctx.createLinearGradient(0, 0, 0, h);
        g3.addColorStop(0, '#2d5016'); g3.addColorStop(1, '#1a3a0a');
        ctx.fillStyle = g3; ctx.fillRect(0, 0, w, h);
        ctx.fillStyle = '#243f12'; ctx.fillRect(40, h*0.45, 140, h*0.55);
        ctx.fillStyle = '#1e350e'; ctx.fillRect(w*0.6, h*0.38, 130, h*0.62);
        ctx.fillStyle = '#152808'; ctx.fillRect(0, h*0.85, w, h*0.15);
      } else {
        ctx.fillStyle = '#e8e0d0'; ctx.fillRect(0, 0, w, h);
        ctx.fillStyle = '#d0c8b8'; ctx.fillRect(50, h*0.45, 130, h*0.55);
        ctx.fillStyle = '#c5bda8'; ctx.fillRect(w*0.6, h*0.35, 140, h*0.65);
        ctx.fillStyle = '#b8b0a0'; ctx.fillRect(0, h*0.84, w, h*0.16);
      }
    }

    function drawCrosshair() {
      var w = canvas.width, h = canvas.height;
      var cx = Math.floor(w / 2), cy = Math.floor(h / 2);

      drawBg();
      ctx.save();
      ctx.globalAlpha = S.opacity;

      var sz = S.size * SCALE;
      var t = S.thickness * SCALE;
      var g = S.gap * SCALE;
      var ol = S.outline;
      var ow = S.outlineWidth * SCALE;

      function drawLine(x1, y1, x2, y2) {
        if (ol) {
          ctx.strokeStyle = S.outlineColor;
          ctx.lineWidth = t + ow * 2;
          ctx.lineCap = 'butt';
          ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
        }
        ctx.strokeStyle = S.color;
        ctx.lineWidth = t;
        ctx.lineCap = 'butt';
        ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
      }

      function drawDot(x, y, r) {
        if (ol) {
          ctx.beginPath(); ctx.arc(x, y, r + ow, 0, Math.PI * 2);
          ctx.fillStyle = S.outlineColor; ctx.fill();
        }
        ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = S.color; ctx.fill();
      }

      if (S.shape === 'cross') {
        drawLine(cx + g, cy, cx + g + sz, cy);
        drawLine(cx - g, cy, cx - g - sz, cy);
        drawLine(cx, cy - g, cx, cy - g - sz);
        drawLine(cx, cy + g, cx, cy + g + sz);
      } else if (S.shape === 'dot') {
        drawDot(cx, cy, S.size * 1.5 * SCALE / 3);
      } else if (S.shape === 'circle') {
        var r = S.size * SCALE * 0.7;
        if (ol) {
          ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2);
          ctx.strokeStyle = S.outlineColor; ctx.lineWidth = t + ow * 2; ctx.stroke();
        }
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.strokeStyle = S.color; ctx.lineWidth = t; ctx.stroke();
      } else if (S.shape === 't-shape') {
        drawLine(cx + g, cy, cx + g + sz, cy);
        drawLine(cx - g, cy, cx - g - sz, cy);
        drawLine(cx, cy + g, cx, cy + g + sz);
      }

      /* Center dot */
      if (S.dot && S.shape !== 'dot') {
        drawDot(cx, cy, S.dotSize * SCALE / 2);
      }

      ctx.restore();
    }

    /* ── Sync UI ↔ State ── */
    function syncUI() {
      document.getElementById('ctrl-color').value = S.color;
      document.getElementById('ctrl-opacity').value = S.opacity;
      document.getElementById('lbl-opacity').textContent = Math.round(S.opacity * 100) + '%';
      document.getElementById('ctrl-size').value = S.size;
      document.getElementById('lbl-size').textContent = S.size;
      document.getElementById('ctrl-thickness').value = S.thickness;
      document.getElementById('lbl-thickness').textContent = S.thickness;
      document.getElementById('ctrl-gap').value = S.gap;
      document.getElementById('lbl-gap').textContent = S.gap;
      document.getElementById('ctrl-outline').checked = S.outline;
      document.getElementById('ctrl-outline-color').value = S.outlineColor;
      document.getElementById('ctrl-outline-width').value = S.outlineWidth;
      document.getElementById('lbl-outline-width').textContent = S.outlineWidth;
      document.getElementById('ctrl-dot').checked = S.dot;
      document.getElementById('ctrl-dot-size').value = S.dotSize;
      document.getElementById('lbl-dot-size').textContent = S.dotSize;

      document.getElementById('outline-color-row').style.display = S.outline ? '' : 'none';
      document.getElementById('outline-width-row').style.display = S.outline ? '' : 'none';
      document.getElementById('dot-size-row').style.display = S.dot ? '' : 'none';

      document.querySelectorAll('#shape-select .btn').forEach(function(b) {
        b.classList.toggle('active', b.dataset.shape === S.shape);
      });
    }

    function readUI() {
      S.color = document.getElementById('ctrl-color').value;
      S.opacity = parseFloat(document.getElementById('ctrl-opacity').value);
      S.size = parseInt(document.getElementById('ctrl-size').value);
      S.thickness = parseFloat(document.getElementById('ctrl-thickness').value);
      S.gap = parseInt(document.getElementById('ctrl-gap').value);
      S.outline = document.getElementById('ctrl-outline').checked;
      S.outlineColor = document.getElementById('ctrl-outline-color').value;
      S.outlineWidth = parseFloat(document.getElementById('ctrl-outline-width').value);
      S.dot = document.getElementById('ctrl-dot').checked;
      S.dotSize = parseFloat(document.getElementById('ctrl-dot-size').value);

      document.getElementById('lbl-opacity').textContent = Math.round(S.opacity * 100) + '%';
      document.getElementById('lbl-size').textContent = S.size;
      document.getElementById('lbl-thickness').textContent = S.thickness;
      document.getElementById('lbl-gap').textContent = S.gap;
      document.getElementById('lbl-outline-width').textContent = S.outlineWidth;
      document.getElementById('lbl-dot-size').textContent = S.dotSize;

      document.getElementById('outline-color-row').style.display = S.outline ? '' : 'none';
      document.getElementById('outline-width-row').style.display = S.outline ? '' : 'none';
      document.getElementById('dot-size-row').style.display = S.dot ? '' : 'none';
    }

    function update() {
      readUI();
      drawCrosshair();
      genExport();
    }

    /* ── Control Events ── */
    ['ctrl-color','ctrl-opacity','ctrl-size','ctrl-thickness','ctrl-gap','ctrl-outline','ctrl-outline-color','ctrl-outline-width','ctrl-dot','ctrl-dot-size'].forEach(function(id) {
      var el = document.getElementById(id);
      el.addEventListener('input', update);
      el.addEventListener('change', update);
    });

    /* Shape select */
    document.getElementById('shape-select').addEventListener('click', function(e) {
      var btn = e.target.closest('[data-shape]');
      if (!btn) return;
      this.querySelectorAll('.btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      S.shape = btn.dataset.shape;
      drawCrosshair();
      genExport();
    });

    /* Background select */
    document.getElementById('bg-select').addEventListener('click', function(e) {
      var btn = e.target.closest('[data-bg]');
      if (!btn) return;
      this.querySelectorAll('.btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      bgMode = btn.dataset.bg;
      drawCrosshair();
    });

    /* Color swatches */
    document.getElementById('color-swatches').addEventListener('click', function(e) {
      var swatch = e.target.closest('[data-color]');
      if (!swatch) return;
      S.color = swatch.dataset.color;
      document.getElementById('ctrl-color').value = S.color;
      drawCrosshair();
      genExport();
    });

    /* Pro presets */
    document.getElementById('pro-presets').addEventListener('click', function(e) {
      var card = e.target.closest('[data-preset]');
      if (!card) return;
      var p = PRO[card.dataset.preset];
      if (!p) return;
      Object.keys(p).forEach(function(k) { S[k] = p[k]; });
      syncUI();
      drawCrosshair();
      genExport();
    });

    /* ── Export Code Generation ── */
    function hexToRgb(hex) {
      return { r: parseInt(hex.slice(1,3),16), g: parseInt(hex.slice(3,5),16), b: parseInt(hex.slice(5,7),16) };
    }

    function genExport() {
      /* Valorant code */
      var cMap = {'#ffffff':0,'#00ff00':1,'#7fff00':2,'#ffff00':3,'#00ffff':4,'#ff00ff':5,'#ff0000':6};
      var cIdx = cMap[S.color.toLowerCase()];
      var rgb = hexToRgb(S.color);
      var parts = ['0','s','1','P'];

      if (cIdx !== undefined) {
        parts.push('c', ''+cIdx);
      } else {
        parts.push('c','7');
        parts.push('u', rgb.r + '' + rgb.g + '' + rgb.b);
      }

      parts.push('t', S.outline ? ''+Math.round(S.outlineWidth) : '0');
      parts.push('o', S.opacity < 1 ? ''+Math.round(S.opacity*100)/100 : '1');

      var showDot = S.dot || S.shape === 'dot';
      parts.push('d', showDot ? '1' : '0');
      if (showDot) parts.push('z', ''+Math.round(S.dotSize));

      var showLines = S.shape !== 'dot';
      parts.push('f', showLines ? '0' : '1');
      if (showLines) {
        parts.push('0l', ''+S.size);
        parts.push('0t', ''+Math.round(S.thickness));
        parts.push('0g', ''+S.gap);
        parts.push('0o', '1');
        parts.push('0a', ''+Math.round(S.opacity*100)/100);
      }

      /* T-shape flag */
      if (S.shape === 't-shape') parts.push('0m', '1');

      document.getElementById('val-code').textContent = parts.join(';');

      /* CS2 commands */
      var cs = [];
      cs.push('cl_crosshairstyle 4');
      cs.push('cl_crosshaircolor 5');
      cs.push('cl_crosshaircolor_r ' + rgb.r);
      cs.push('cl_crosshaircolor_g ' + rgb.g);
      cs.push('cl_crosshaircolor_b ' + rgb.b);
      cs.push('cl_crosshairalpha ' + Math.round(S.opacity * 255));
      cs.push('cl_crosshairsize ' + (showLines ? S.size : 0));
      cs.push('cl_crosshairthickness ' + (showLines ? S.thickness : 0));
      cs.push('cl_crosshairgap ' + (showLines ? S.gap : 0));
      cs.push('cl_crosshairdot ' + (showDot ? '1' : '0'));
      cs.push('cl_crosshair_drawoutline ' + (S.outline ? '1' : '0'));
      if (S.outline) cs.push('cl_crosshair_outlinethickness ' + S.outlineWidth);
      cs.push('cl_crosshair_t ' + (S.shape === 't-shape' ? '1' : '0'));

      document.getElementById('cs2-code').textContent = cs.join('\n');

    }

    /* ── Copy Buttons ── */
    document.getElementById('copy-val').addEventListener('click', function() {
      var btn = this;
      navigator.clipboard.writeText(document.getElementById('val-code').textContent).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
      });
    });
    document.getElementById('copy-cs2').addEventListener('click', function() {
      var btn = this;
      navigator.clipboard.writeText(document.getElementById('cs2-code').textContent).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
      });
    });
    document.getElementById('download-png').addEventListener('click', function() {
      var pngCanvas = document.createElement('canvas');
      pngCanvas.width = 128;
      pngCanvas.height = 128;
      var pCtx = pngCanvas.getContext('2d');
      pCtx.clearRect(0, 0, 128, 128);

      /* Draw crosshair on transparent canvas */
      var cx = 64, cy = 64;
      pCtx.save();
      pCtx.globalAlpha = S.opacity;

      var sz = S.size * SCALE;
      var t = S.thickness * SCALE;
      var g = S.gap * SCALE;
      var ow = S.outlineWidth * SCALE;

      function pLine(x1, y1, x2, y2) {
        if (S.outline) {
          pCtx.strokeStyle = S.outlineColor;
          pCtx.lineWidth = t + ow * 2;
          pCtx.lineCap = 'butt';
          pCtx.beginPath(); pCtx.moveTo(x1, y1); pCtx.lineTo(x2, y2); pCtx.stroke();
        }
        pCtx.strokeStyle = S.color;
        pCtx.lineWidth = t;
        pCtx.lineCap = 'butt';
        pCtx.beginPath(); pCtx.moveTo(x1, y1); pCtx.lineTo(x2, y2); pCtx.stroke();
      }
      function pDot(x, y, r) {
        if (S.outline) {
          pCtx.beginPath(); pCtx.arc(x, y, r + ow, 0, Math.PI * 2);
          pCtx.fillStyle = S.outlineColor; pCtx.fill();
        }
        pCtx.beginPath(); pCtx.arc(x, y, r, 0, Math.PI * 2);
        pCtx.fillStyle = S.color; pCtx.fill();
      }

      if (S.shape === 'cross') {
        pLine(cx + g, cy, cx + g + sz, cy);
        pLine(cx - g, cy, cx - g - sz, cy);
        pLine(cx, cy - g, cx, cy - g - sz);
        pLine(cx, cy + g, cx, cy + g + sz);
      } else if (S.shape === 'dot') {
        pDot(cx, cy, S.size * 1.5 * SCALE / 3);
      } else if (S.shape === 'circle') {
        var r = S.size * SCALE * 0.7;
        if (S.outline) {
          pCtx.beginPath(); pCtx.arc(cx, cy, r, 0, Math.PI * 2);
          pCtx.strokeStyle = S.outlineColor; pCtx.lineWidth = t + ow * 2; pCtx.stroke();
        }
        pCtx.beginPath(); pCtx.arc(cx, cy, r, 0, Math.PI * 2);
        pCtx.strokeStyle = S.color; pCtx.lineWidth = t; pCtx.stroke();
      } else if (S.shape === 't-shape') {
        pLine(cx + g, cy, cx + g + sz, cy);
        pLine(cx - g, cy, cx - g - sz, cy);
        pLine(cx, cy + g, cx, cy + g + sz);
      }
      if (S.dot && S.shape !== 'dot') {
        pDot(cx, cy, S.dotSize * SCALE / 2);
      }
      pCtx.restore();

      var link = document.createElement('a');
      link.download = 'crosshair.png';
      link.href = pngCanvas.toDataURL('image/png');
      link.click();
    });

    /* ── Saved Presets (localStorage) ── */
    var STORAGE_KEY = 'crosshairPresets';

    function getSaved() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { return []; }
    }

    function renderSaved() {
      var presets = getSaved();
      var container = document.getElementById('saved-presets-container');
      var msg = document.getElementById('no-presets-msg');

      if (presets.length === 0) {
        container.innerHTML = '';
        container.appendChild(msg);
        msg.style.display = '';
        return;
      }
      msg.style.display = 'none';
      container.innerHTML = presets.map(function(p, i) {
        return '<button class="preset-card saved-preset" data-idx="' + i + '">' +
          '<strong>' + (p.name || 'Preset ' + (i+1)) + '</strong>' +
          '<span>' + p.shape + ' · ' + p.color + ' · Size ' + p.size + '</span>' +
          '<span class="del-preset" data-delidx="' + i + '" title="Delete">&#215;</span>' +
          '</button>';
      }).join('');
    }

    document.getElementById('save-preset-btn').addEventListener('click', function() {
      var name = prompt('Preset name:');
      if (!name) return;
      var presets = getSaved();
      var entry = {};
      Object.keys(S).forEach(function(k) { entry[k] = S[k]; });
      entry.name = name;
      presets.push(entry);
      if (presets.length > 20) presets = presets.slice(-20);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(presets));
      renderSaved();
    });

    document.getElementById('clear-presets-btn').addEventListener('click', function() {
      if (confirm('Delete all saved presets?')) {
        localStorage.removeItem(STORAGE_KEY);
        renderSaved();
      }
    });

    document.getElementById('saved-presets-container').addEventListener('click', function(e) {
      var del = e.target.closest('[data-delidx]');
      if (del) {
        e.stopPropagation();
        var presets = getSaved();
        presets.splice(parseInt(del.dataset.delidx), 1);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(presets));
        renderSaved();
        return;
      }
      var card = e.target.closest('[data-idx]');
      if (!card) return;
      var presets = getSaved();
      var p = presets[parseInt(card.dataset.idx)];
      if (!p) return;
      Object.keys(S).forEach(function(k) {
        if (p[k] !== undefined) S[k] = p[k];
      });
      syncUI();
      drawCrosshair();
      genExport();
    });

    /* ── Canvas Resize ── */
    function resizeCanvas() {
      var wrap = canvas.parentElement;
      var w = wrap.clientWidth;
      if (w < 800) {
        canvas.width = w;
        canvas.height = Math.round(w * 0.5);
      } else {
        canvas.width = 800;
        canvas.height = 400;
      }
      drawCrosshair();
    }
    window.addEventListener('resize', resizeCanvas);

    /* ── Init ── */
    resizeCanvas();
    syncUI();
    drawCrosshair();
    genExport();
    renderSaved();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Preview */
    .preview-wrapper { border-radius: 12px; overflow: hidden; border: 2px solid var(--border-color); margin-bottom: 1rem; background: #000; }
    .preview-wrapper canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; }
    .preview-bar { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 1rem; background: var(--card-bg); border-top: 1px solid var(--border-color); }
    .preview-label { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); }

    /* Controls */
    .controls-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1rem; }
    .ctrl-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; }
    .ctrl-card h3 { margin: 0 0 0.8rem; font-size: 1rem; font-weight: 700; color: var(--text-primary); }

    .btn-group { display: flex; gap: 0.3rem; flex-wrap: wrap; }
    .btn { padding: 0.45rem 0.9rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .btn.active { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }
    .btn-primary { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }
    .btn-primary:hover { opacity: 0.9; }
    .btn-sm { padding: 0.3rem 0.7rem; font-size: 0.8rem; }

    .slider-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
    .slider-row label { font-size: 0.85rem; color: var(--text-secondary); min-width: 90px; font-weight: 600; }
    .slider-row input[type="range"] { flex: 1; accent-color: var(--accent-color); }
    .slider-row input[type="color"] { width: 32px; height: 28px; border: 1px solid var(--border-color); border-radius: 6px; cursor: pointer; background: none; padding: 0; }
    .slider-val { font-size: 0.85rem; color: var(--text-primary); font-weight: 700; min-width: 36px; text-align: right; }

    .color-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.8rem; }
    .color-row input[type="color"] { width: 40px; height: 34px; border: 1px solid var(--border-color); border-radius: 8px; cursor: pointer; background: none; padding: 0; }
    .color-swatches { display: flex; gap: 0.35rem; }
    .swatch { width: 28px; height: 28px; border-radius: 6px; border: 2px solid var(--border-color); cursor: pointer; transition: transform 0.1s; }
    .swatch:hover { transform: scale(1.15); }

    .toggle-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
    .toggle-row label { font-size: 0.85rem; color: var(--text-secondary); font-weight: 600; min-width: 90px; }
    .toggle-row input[type="checkbox"] { accent-color: var(--accent-color); width: 18px; height: 18px; cursor: pointer; }

    /* Presets */
    .presets-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.75rem; margin: 1rem 0; }
    .preset-card { display: flex; flex-direction: column; gap: 0.2rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; cursor: pointer; text-align: left; transition: border-color 0.2s; position: relative; }
    .preset-card:hover { border-color: var(--accent-color); }
    .preset-card strong { color: var(--text-primary); font-size: 1rem; }
    .preset-card span { color: var(--text-secondary); font-size: 0.8rem; }
    .del-preset { position: absolute; top: 6px; right: 10px; font-size: 1.2rem; color: var(--text-secondary); cursor: pointer; line-height: 1; }
    .del-preset:hover { color: #ff4444; }
    .empty-presets { color: var(--text-secondary); font-style: italic; font-size: 0.9rem; grid-column: 1 / -1; }
    .saved-bar { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; }

    /* Export */
    .export-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1rem 0; }
    .export-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem 1.5rem; }
    .export-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem; }
    .export-header h3 { margin: 0; font-size: 0.95rem; font-weight: 700; color: var(--text-primary); }
    .export-code { display: block; background: rgba(0,0,0,0.2); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.75rem; font-size: 0.8rem; color: var(--text-primary); word-break: break-all; white-space: pre-wrap; line-height: 1.5; min-height: 40px; }
    .export-hint { font-size: 0.8rem; color: var(--text-secondary); }
    .export-png-card { display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem; }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    /* Related */
    .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .related-link { display: flex; flex-direction: column; gap: 0.3rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem; text-decoration: none; transition: border-color 0.2s; }
    .related-link:hover { border-color: var(--accent-color); text-decoration: none; }
    .related-link strong { color: var(--text-primary); font-size: 1rem; }
    .related-link span { color: var(--text-secondary); font-size: 0.85rem; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .controls-grid { grid-template-columns: 1fr; }
      .export-grid { grid-template-columns: 1fr; }
      .presets-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</SiteLayout>
