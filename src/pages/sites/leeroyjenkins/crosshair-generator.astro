---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "What crosshair color is best for Valorant and CS2?",
    a: "Green (#00ff00) and cyan (#00ffff) are the most popular crosshair colors because they contrast strongly against the brown, grey, and yellow environments in both Valorant and CS2. White works on darker maps but disappears on bright surfaces. Avoid red — it blends with damage indicators and enemy outlines. The best color is whatever stands out most to your eyes across all maps. Many pros use green or cyan with a black outline for maximum visibility."
  },
  {
    q: "Should I use a dot crosshair or a cross?",
    a: "Dot crosshairs offer pinpoint precision but are easy to lose during fast-paced fights. Classic crosses provide horizontal and vertical reference lines that help with spray control and crosshair placement. Most pro players use a small cross with a gap — it marks the exact center while giving spatial reference. If you play Valorant with agents that require precise ability placement, a dot can help. For CS2, a small cross is generally preferred because spray patterns matter more."
  },
  {
    q: "What crosshair do pro players like TenZ and s1mple use?",
    a: "TenZ typically uses a small cyan crosshair with inner lines only (length 4, thickness 2, gap 2) and no center dot — optimized for clean headshot angles in Valorant. s1mple uses a classic CS2 crosshair: green, size 2, gap -2 (overlapping), thickness 0.5, with outlines enabled. Shroud prefers a green cross with a center dot for all-around visibility. Pro crosshairs change frequently, but these represent their general preferences. Copy them as a starting point, then adjust to what feels natural for your aim style."
  },
  {
    q: "How do I import a crosshair code in Valorant?",
    a: "In Valorant, go to Settings → Crosshair → scroll down and click 'Import Profile Code'. Paste the crosshair code string and click Import. The code encodes all crosshair settings including color, inner lines, outer lines, center dot, outlines, and opacity. You can also share your crosshair by clicking 'Export Profile Code' in the same menu. This crosshair generator produces Valorant-compatible codes you can import directly."
  },
  {
    q: "How do I apply a crosshair in CS2 using console commands?",
    a: "Open the CS2 console (press ~ or the key bound to toggleconsole) and paste the full crosshair command string. Each setting is a separate console variable like cl_crosshairsize, cl_crosshairgap, cl_crosshairthickness, etc. You can also add these commands to your autoexec.cfg file so they load automatically every time you start the game. This generator outputs the complete console command string — just paste it into your CS2 console."
  },
  {
    q: "Does crosshair size affect aim accuracy?",
    a: "Not directly — your crosshair doesn't change bullet trajectory. But it significantly affects perceived accuracy and confidence. A crosshair that's too large obscures targets at long range, making headshots harder to line up. A crosshair that's too small can be lost during fast tracking. Research on HCI (human-computer interaction) shows that visual feedback alignment directly impacts motor precision. The ideal crosshair is small enough to not cover targets but large enough to find instantly in your peripheral vision."
  },
  {
    q: "What does crosshair outline do and should I enable it?",
    a: "A crosshair outline adds a dark border (usually black) around your crosshair lines. This dramatically improves visibility on bright surfaces — without an outline, a green crosshair disappears on green foliage, and a white crosshair vanishes on light walls. Almost every pro player enables outlines with thickness 1. The only downside is a slightly thicker overall crosshair appearance, but the visibility benefit far outweighs this. Enable outlines unless you use a very large, bold crosshair that's already easy to see."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Crosshair Generator — Custom Crosshair Maker for Valorant & CS2",
    "description": "Free crosshair generator with live preview. Customize inner/outer lines, center dot, color, and opacity. Export as Valorant crosshair code, CS2 console command, or PNG.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "Leeroy Jenkins" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": { "@type": "Answer", "text": f.a }
    }))
  }
];

export const meta = {
  title: "Crosshair Generator — Custom Crosshair Maker for Valorant & CS2",
  description: "Free crosshair generator with live canvas preview. Customize color, inner/outer lines, center dot, opacity, and outlines. Export Valorant crosshair codes, CS2 commands, or save as PNG.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="Crosshair Generator — Custom Crosshair Maker for Valorant & CS2"
  description="Free crosshair generator with live canvas preview. Customize color, inner/outer lines, center dot, opacity, and outlines. Export Valorant crosshair codes, CS2 commands, or save as PNG."
  canonical="https://leeroyjenkins.quest/crosshair-generator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Crosshair Generator</h1>
      <p>Design your perfect crosshair with live preview. Customize every detail, load pro presets, and export for Valorant, CS2, or save as PNG.</p>
    </div>

    <section class="content-section">
      <!-- Preview Canvas -->
      <div class="preview-wrapper" id="preview-wrapper">
        <canvas id="crosshair-canvas" width="800" height="400"></canvas>
        <div class="bg-switcher">
          <button class="bg-btn active" data-bg="dark" title="Dark background">Dark</button>
          <button class="bg-btn" data-bg="light" title="Light background">Light</button>
          <button class="bg-btn" data-bg="game" title="Game screenshot">Game</button>
        </div>
      </div>

      <!-- Presets -->
      <div class="presets-bar">
        <span class="presets-label">Presets</span>
        <div class="presets-list" id="presets-list">
          <button class="preset-btn active" data-preset="default">Default</button>
          <button class="preset-btn" data-preset="dot">Dot Only</button>
          <button class="preset-btn" data-preset="smallcross">Small Cross</button>
          <button class="preset-btn" data-preset="s1mple">s1mple</button>
          <button class="preset-btn" data-preset="tenz">TenZ</button>
          <button class="preset-btn" data-preset="shroud">Shroud</button>
        </div>
      </div>

      <!-- Controls -->
      <div class="controls-grid">
        <!-- Color & Outline -->
        <div class="ctrl-card">
          <h3>Color &amp; Outline</h3>
          <div class="ctrl-row">
            <label>Color</label>
            <div class="color-pick">
              <input type="color" id="ctrl-color" value="#00ff00">
              <span id="lbl-color">#00ff00</span>
            </div>
          </div>
          <div class="ctrl-row">
            <label>Opacity</label>
            <input type="range" id="ctrl-opacity" min="0.1" max="1" step="0.05" value="1">
            <span class="ctrl-val" id="lbl-opacity">1.00</span>
          </div>
          <div class="ctrl-row">
            <label>Outline</label>
            <div class="toggle-wrap">
              <input type="checkbox" id="ctrl-outline" checked>
              <span class="toggle-label" id="lbl-outline-state">On</span>
            </div>
          </div>
          <div class="ctrl-row">
            <label>Outline Thickness</label>
            <input type="range" id="ctrl-outline-thick" min="1" max="4" step="1" value="1">
            <span class="ctrl-val" id="lbl-outline-thick">1</span>
          </div>
        </div>

        <!-- Inner Lines -->
        <div class="ctrl-card">
          <h3>Inner Lines</h3>
          <div class="ctrl-row">
            <label>Show</label>
            <div class="toggle-wrap">
              <input type="checkbox" id="ctrl-inner-show" checked>
              <span class="toggle-label" id="lbl-inner-show">On</span>
            </div>
          </div>
          <div class="ctrl-row">
            <label>Length</label>
            <input type="range" id="ctrl-inner-len" min="1" max="30" step="1" value="6">
            <span class="ctrl-val" id="lbl-inner-len">6</span>
          </div>
          <div class="ctrl-row">
            <label>Thickness</label>
            <input type="range" id="ctrl-inner-thick" min="1" max="10" step="1" value="2">
            <span class="ctrl-val" id="lbl-inner-thick">2</span>
          </div>
          <div class="ctrl-row">
            <label>Gap</label>
            <input type="range" id="ctrl-inner-gap" min="0" max="20" step="1" value="3">
            <span class="ctrl-val" id="lbl-inner-gap">3</span>
          </div>
        </div>

        <!-- Outer Lines -->
        <div class="ctrl-card">
          <h3>Outer Lines</h3>
          <div class="ctrl-row">
            <label>Show</label>
            <div class="toggle-wrap">
              <input type="checkbox" id="ctrl-outer-show">
              <span class="toggle-label" id="lbl-outer-show">Off</span>
            </div>
          </div>
          <div class="ctrl-row">
            <label>Length</label>
            <input type="range" id="ctrl-outer-len" min="1" max="20" step="1" value="4">
            <span class="ctrl-val" id="lbl-outer-len">4</span>
          </div>
          <div class="ctrl-row">
            <label>Thickness</label>
            <input type="range" id="ctrl-outer-thick" min="1" max="10" step="1" value="2">
            <span class="ctrl-val" id="lbl-outer-thick">2</span>
          </div>
          <div class="ctrl-row">
            <label>Gap</label>
            <input type="range" id="ctrl-outer-gap" min="0" max="20" step="1" value="10">
            <span class="ctrl-val" id="lbl-outer-gap">10</span>
          </div>
        </div>

        <!-- Center Dot -->
        <div class="ctrl-card">
          <h3>Center Dot</h3>
          <div class="ctrl-row">
            <label>Show</label>
            <div class="toggle-wrap">
              <input type="checkbox" id="ctrl-dot-show">
              <span class="toggle-label" id="lbl-dot-show">Off</span>
            </div>
          </div>
          <div class="ctrl-row">
            <label>Size</label>
            <input type="range" id="ctrl-dot-size" min="1" max="10" step="1" value="2">
            <span class="ctrl-val" id="lbl-dot-size">2</span>
          </div>
        </div>
      </div>

      <!-- Export -->
      <div class="export-section">
        <h2>Export Crosshair</h2>
        <div class="export-grid">
          <div class="export-card">
            <div class="export-header">
              <span class="export-title">Valorant Crosshair Code</span>
              <button class="btn btn-sm copy-btn" data-target="val-code">Copy</button>
            </div>
            <code class="export-code" id="val-code"></code>
          </div>
          <div class="export-card">
            <div class="export-header">
              <span class="export-title">CS2 Console Command</span>
              <button class="btn btn-sm copy-btn" data-target="cs2-code">Copy</button>
            </div>
            <code class="export-code" id="cs2-code"></code>
          </div>
        </div>
        <button class="btn btn-primary" id="save-png-btn">Save as PNG</button>
      </div>

      <!-- Content -->
      <h2>How to Use This Crosshair Generator</h2>
      <p>Adjust the controls above and watch your crosshair update in real-time on the canvas preview. Switch between dark, light, and game backgrounds to test visibility across different scenarios. Load a pro player preset as a starting point, then fine-tune each parameter until it feels right for your playstyle.</p>

      <h3>Customization Options Explained</h3>
      <p><strong>Inner Lines:</strong> The four lines closest to the center of your crosshair. These are the primary aiming reference. Adjust length, thickness, and gap to control how much visual information surrounds your aim point. A shorter length with a small gap is precise; longer lines help with spray tracking.</p>
      <p><strong>Outer Lines:</strong> Secondary lines placed further from the center. Outer lines give a wider frame of reference for tracking targets moving across your screen. Most precision-focused players disable these, but they're useful for run-and-gun styles and spray transfers.</p>
      <p><strong>Center Dot:</strong> A single pixel or small dot at the exact center of your crosshair. Enable this for pinpoint accuracy — especially useful if you use a gapped crosshair and want a clear center reference. Disable it if your inner lines already close the gap.</p>
      <p><strong>Color &amp; Opacity:</strong> Choose any color that contrasts with your game maps. Green and cyan are the most common in competitive play. Lower opacity can reduce visual clutter, but most players keep it at full.</p>
      <p><strong>Outline:</strong> A dark border around every crosshair element. Outlines are critical for visibility — they prevent your crosshair from blending into bright surfaces. Almost every pro player uses an outline thickness of 1.</p>

      <h3>Pro Player Crosshair Presets</h3>
      <p><strong>s1mple:</strong> One of the greatest CS players of all time uses a tight green crosshair with size 2, no gap overlap, and outlines enabled. It's a no-nonsense crosshair built for headshots at any range.</p>
      <p><strong>TenZ:</strong> Valorant's most popular player prefers a small cyan crosshair with inner lines only — length 4, thickness 2, gap 2. Clean and minimal for fast headshot flicks.</p>
      <p><strong>Shroud:</strong> The retired pro turned streamer uses a green cross with a center dot. The dot helps with precise single-tap shots while the cross lines assist with tracking moving targets.</p>

      <h3>Exporting Your Crosshair</h3>
      <p><strong>Valorant:</strong> Copy the Valorant crosshair code and import it in-game via Settings → Crosshair → Import Profile Code. The code encodes all your settings into a single string.</p>
      <p><strong>CS2:</strong> Copy the CS2 console command and paste it into your in-game console or autoexec.cfg file. Each setting maps to a specific console variable that CS2 reads on startup.</p>
      <p><strong>PNG:</strong> Click "Save as PNG" to download a transparent image of your crosshair. Use this as a custom overlay in streaming software, for thumbnails, or to share your design visually.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Tools</h2>
      <div class="related-grid">
        <a href="/aim-trainer" class="related-link">
          <strong>Aim Trainer</strong>
          <span>Practice your aim with 4 modes — classic, precision, tracking, and flick shots</span>
        </a>
        <a href="/fps-settings-optimizer" class="related-link">
          <strong>FPS Settings Optimizer</strong>
          <span>Optimize your in-game graphics and performance settings for competitive play</span>
        </a>
        <a href="/best-gaming-mice-2026" class="related-link">
          <strong>Best Gaming Mouse 2026</strong>
          <span>Top-rated mice compared for every grip style and game genre</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
  (function() {
    /* ── State ── */
    const S = {
      color: '#00ff00', opacity: 1,
      outline: true, outlineThick: 1,
      innerShow: true, innerLen: 6, innerThick: 2, innerGap: 3,
      outerShow: false, outerLen: 4, outerThick: 2, outerGap: 10,
      dotShow: false, dotSize: 2,
      bg: 'dark'
    };

    const PRESETS = {
      default: { color:'#00ff00',opacity:1,outline:true,outlineThick:1,innerShow:true,innerLen:6,innerThick:2,innerGap:3,outerShow:false,outerLen:4,outerThick:2,outerGap:10,dotShow:false,dotSize:2 },
      dot: { color:'#00ff00',opacity:1,outline:true,outlineThick:1,innerShow:false,innerLen:0,innerThick:2,innerGap:0,outerShow:false,outerLen:0,outerThick:2,outerGap:0,dotShow:true,dotSize:4 },
      smallcross: { color:'#ffffff',opacity:1,outline:true,outlineThick:1,innerShow:true,innerLen:3,innerThick:1,innerGap:2,outerShow:false,outerLen:0,outerThick:1,outerGap:0,dotShow:false,dotSize:1 },
      s1mple: { color:'#00ff00',opacity:1,outline:true,outlineThick:1,innerShow:true,innerLen:4,innerThick:2,innerGap:1,outerShow:false,outerLen:0,outerThick:0,outerGap:0,dotShow:false,dotSize:0 },
      tenz: { color:'#00ffff',opacity:1,outline:true,outlineThick:1,innerShow:true,innerLen:4,innerThick:2,innerGap:2,outerShow:false,outerLen:0,outerThick:0,outerGap:0,dotShow:false,dotSize:0 },
      shroud: { color:'#00ff00',opacity:1,outline:true,outlineThick:1,innerShow:true,innerLen:5,innerThick:2,innerGap:1,outerShow:false,outerLen:0,outerThick:0,outerGap:0,dotShow:true,dotSize:2 }
    };

    const BG_COLORS = { dark: '#1a1a2e', light: '#c8c8c8', game: '#6b7353' };

    /* ── Canvas ── */
    const canvas = document.getElementById('crosshair-canvas');
    const ctx = canvas.getContext('2d');
    const SCALE = 4; // render scale for crispness

    function hexToRgb(hex) {
      const r = parseInt(hex.slice(1,3),16);
      const g = parseInt(hex.slice(3,5),16);
      const b = parseInt(hex.slice(5,7),16);
      return [r,g,b];
    }

    function drawCrosshair(exportMode) {
      const w = canvas.width;
      const h = canvas.height;
      const cx = Math.floor(w/2);
      const cy = Math.floor(h/2);

      ctx.clearRect(0,0,w,h);

      if (!exportMode) {
        ctx.fillStyle = BG_COLORS[S.bg];
        ctx.fillRect(0,0,w,h);

        // grid dots for visual reference
        ctx.fillStyle = 'rgba(255,255,255,0.04)';
        for (let x = 0; x < w; x += 40) {
          for (let y = 0; y < h; y += 40) {
            ctx.fillRect(x,y,1,1);
          }
        }
      }

      const [r,g,b] = hexToRgb(S.color);
      const mainColor = 'rgba('+r+','+g+','+b+','+S.opacity+')';
      const outColor = 'rgba(0,0,0,'+S.opacity+')';
      const ot = S.outline ? S.outlineThick * SCALE : 0;

      function drawRect(x, y, rw, rh) {
        if (S.outline) {
          ctx.fillStyle = outColor;
          ctx.fillRect(x - ot, y - ot, rw + ot*2, rh + ot*2);
        }
        ctx.fillStyle = mainColor;
        ctx.fillRect(x, y, rw, rh);
      }

      // Inner lines
      if (S.innerShow && S.innerLen > 0) {
        const len = S.innerLen * SCALE;
        const thick = S.innerThick * SCALE;
        const gap = S.innerGap * SCALE;
        const ht = Math.floor(thick / 2);

        // top
        drawRect(cx - ht, cy - gap - len, thick, len);
        // bottom
        drawRect(cx - ht, cy + gap, thick, len);
        // left
        drawRect(cx - gap - len, cy - ht, len, thick);
        // right
        drawRect(cx + gap, cy - ht, len, thick);
      }

      // Outer lines
      if (S.outerShow && S.outerLen > 0) {
        const innerEnd = (S.innerShow ? (S.innerGap + S.innerLen) : 0) * SCALE;
        const oGap = S.outerGap * SCALE;
        const oLen = S.outerLen * SCALE;
        const oThick = S.outerThick * SCALE;
        const ht = Math.floor(oThick / 2);
        const start = Math.max(innerEnd, oGap);

        // top
        drawRect(cx - ht, cy - start - oLen, oThick, oLen);
        // bottom
        drawRect(cx - ht, cy + start, oThick, oLen);
        // left
        drawRect(cx - start - oLen, cy - ht, oLen, oThick);
        // right
        drawRect(cx + start, cy - ht, oLen, oThick);
      }

      // Center dot
      if (S.dotShow && S.dotSize > 0) {
        const ds = S.dotSize * SCALE;
        const hd = Math.floor(ds / 2);
        drawRect(cx - hd, cy - hd, ds, ds);
      }
    }

    /* ── Controls binding ── */
    const bindings = [
      ['ctrl-color','color','color'],
      ['ctrl-opacity','opacity','range'],
      ['ctrl-outline','outline','checkbox'],
      ['ctrl-outline-thick','outlineThick','range'],
      ['ctrl-inner-show','innerShow','checkbox'],
      ['ctrl-inner-len','innerLen','range'],
      ['ctrl-inner-thick','innerThick','range'],
      ['ctrl-inner-gap','innerGap','range'],
      ['ctrl-outer-show','outerShow','checkbox'],
      ['ctrl-outer-len','outerLen','range'],
      ['ctrl-outer-thick','outerThick','range'],
      ['ctrl-outer-gap','outerGap','range'],
      ['ctrl-dot-show','dotShow','checkbox'],
      ['ctrl-dot-size','dotSize','range']
    ];

    const labels = {};
    bindings.forEach(function(b) {
      var id = b[0], key = b[1], type = b[2];
      var el = document.getElementById(id);
      // find label
      var lblId = 'lbl-' + id.replace('ctrl-','');
      var lbl = document.getElementById(lblId);
      labels[key] = lbl;

      function handler() {
        if (type === 'checkbox') {
          S[key] = el.checked;
          if (lbl) lbl.textContent = el.checked ? 'On' : 'Off';
        } else if (type === 'color') {
          S[key] = el.value;
          if (lbl) lbl.textContent = el.value;
        } else {
          S[key] = parseFloat(el.value);
          if (lbl) lbl.textContent = type === 'range' && key === 'opacity' ? parseFloat(el.value).toFixed(2) : el.value;
        }
        clearActivePreset();
        update();
      }
      el.addEventListener('input', handler);
      el.addEventListener('change', handler);
    });

    function syncControlsFromState() {
      bindings.forEach(function(b) {
        var id = b[0], key = b[1], type = b[2];
        var el = document.getElementById(id);
        var lblId = 'lbl-' + id.replace('ctrl-','');
        var lbl = document.getElementById(lblId);
        if (type === 'checkbox') {
          el.checked = S[key];
          if (lbl) lbl.textContent = S[key] ? 'On' : 'Off';
        } else if (type === 'color') {
          el.value = S[key];
          if (lbl) lbl.textContent = S[key];
        } else {
          el.value = S[key];
          if (lbl) lbl.textContent = key === 'opacity' ? S[key].toFixed(2) : S[key];
        }
      });
    }

    /* ── Presets ── */
    var presetBtns = document.querySelectorAll('.preset-btn');
    presetBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var name = btn.dataset.preset;
        var p = PRESETS[name];
        if (!p) return;
        Object.keys(p).forEach(function(k) { S[k] = p[k]; });
        syncControlsFromState();
        presetBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        update();
      });
    });

    function clearActivePreset() {
      presetBtns.forEach(function(b) { b.classList.remove('active'); });
    }

    /* ── Background switcher ── */
    var bgBtns = document.querySelectorAll('.bg-btn');
    bgBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        S.bg = btn.dataset.bg;
        bgBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        drawCrosshair();
      });
    });

    /* ── Export: Valorant Code ── */
    function genValCode() {
      // Valorant crosshair profile code format (simplified encoding)
      // 0;s;1;P;c;{colorFlag};h;0;d;1;z;{size};a;{opacity};f;0;m;1;
      // 0;P; primary lines, 0;s;1 for general
      var parts = ['0','s','1','P'];

      // Color: Valorant uses color index: 0=white,1=green,2=greenYellow,3=yellow,4=cyan,5=pink,6=red,7=custom
      var cMap = {'#ffffff':0,'#00ff00':1,'#7fff00':2,'#ffff00':3,'#00ffff':4,'#ff00ff':5,'#ff0000':6};
      var cIdx = cMap[S.color.toLowerCase()];
      if (cIdx !== undefined) {
        parts.push('c',''+cIdx);
      } else {
        parts.push('c','7');
        var rgb = hexToRgb(S.color);
        parts.push('u', rgb[0]+''+rgb[1]+''+rgb[2]);
      }

      // Outlines
      parts.push('t', S.outline ? ''+S.outlineThick : '0');
      parts.push('o', S.opacity < 1 ? ''+Math.round(S.opacity*100)/100 : '1');

      // Center dot
      parts.push('d', S.dotShow ? '1' : '0');
      if (S.dotShow) parts.push('z', ''+S.dotSize);

      // Inner lines
      parts.push('f', S.innerShow ? '0' : '1');
      if (S.innerShow) {
        parts.push('0l', ''+S.innerLen);
        parts.push('0t', ''+S.innerThick);
        parts.push('0g', ''+S.innerGap);
        parts.push('0o', '1');
        parts.push('0a', ''+Math.round(S.opacity*100)/100);
      }

      // Outer lines
      parts.push('1b', S.outerShow ? '0' : '1');
      if (S.outerShow) {
        parts.push('1l', ''+S.outerLen);
        parts.push('1t', ''+S.outerThick);
        parts.push('1g', ''+S.outerGap);
        parts.push('1o', '1');
        parts.push('1a', ''+Math.round(S.opacity*100)/100);
      }

      return parts.join(';');
    }

    /* ── Export: CS2 Console Command ── */
    function genCS2Cmd() {
      var cmds = [];
      // Color: CS2 uses separate R G B
      var rgb = hexToRgb(S.color);
      cmds.push('cl_crosshaircolor 5');
      cmds.push('cl_crosshaircolor_r '+rgb[0]);
      cmds.push('cl_crosshaircolor_g '+rgb[1]);
      cmds.push('cl_crosshaircolor_b '+rgb[2]);
      cmds.push('cl_crosshairalpha '+Math.round(S.opacity*255));
      cmds.push('cl_crosshairsize '+(S.innerShow ? S.innerLen : 0));
      cmds.push('cl_crosshairthickness '+(S.innerShow ? S.innerThick : 0));
      cmds.push('cl_crosshairgap '+(S.innerShow ? S.innerGap : 0));
      cmds.push('cl_crosshairdot '+(S.dotShow ? 1 : 0));
      cmds.push('cl_crosshair_drawoutline '+(S.outline ? 1 : 0));
      cmds.push('cl_crosshair_outlinethickness '+S.outlineThick);
      return cmds.join('; ');
    }

    /* ── Update ── */
    function update() {
      drawCrosshair();
      document.getElementById('val-code').textContent = genValCode();
      document.getElementById('cs2-code').textContent = genCS2Cmd();
    }

    /* ── Copy buttons ── */
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.dataset.target;
        var text = document.getElementById(target).textContent;
        navigator.clipboard.writeText(text).then(function() {
          var orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(function() { btn.textContent = orig; }, 1500);
        });
      });
    });

    /* ── Save PNG ── */
    document.getElementById('save-png-btn').addEventListener('click', function() {
      // Render crosshair on transparent background
      var expCanvas = document.createElement('canvas');
      expCanvas.width = 128;
      expCanvas.height = 128;
      var expCtx = expCanvas.getContext('2d');

      // Temporarily swap canvas and draw
      var origCanvas = canvas;
      var origCtx = ctx;
      // We'll just redraw in export mode on the temp canvas
      var tmpW = canvas.width;
      var tmpH = canvas.height;
      canvas.width = 128; canvas.height = 128;
      drawCrosshair(true);

      expCtx.drawImage(canvas, 0, 0);

      // Restore
      canvas.width = tmpW; canvas.height = tmpH;
      drawCrosshair();

      var link = document.createElement('a');
      link.download = 'crosshair.png';
      link.href = expCanvas.toDataURL('image/png');
      link.click();
    });

    /* ── Init ── */
    syncControlsFromState();
    update();
  })();
  </script>

