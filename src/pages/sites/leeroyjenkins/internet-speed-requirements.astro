        download: '35-50 Mbps', upload: '5 Mbps', ping: '< 40ms', loss: '0%',
        downloadNote: '35 for 1080p, 50 for 4K', uploadNote: 'for input commands',
        pingNote: 'adds to total input lag', lossNote: 'causes visual artifacts'
      }
    };

    /* ── Bandwidth Calculator Data ── */
    const CALC_DATA = {
      gaming:      { down: 25, up: 5 },
      video:       { down: 25, up: 1 },
      livestream:  { down: 10, up: 10 },
      videocall:   { down: 5,  up: 5 },
      browsing:    { down: 5,  up: 1 },
      downloads:   { down: 50, up: 0 },
      cloudgaming: { down: 40, up: 5 }
    };

    const counts = { gaming: 1, video: 0, livestream: 0, videocall: 0, browsing: 0, downloads: 0, cloudgaming: 0 };

    /* ── Activity Selection ── */
    const actBtns = document.querySelectorAll('.activity-btn');
    actBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        actBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateActivity(btn.dataset.activity);
      });
    });

    function updateActivity(key) {
      const a = ACTIVITIES[key];
      if (!a) return;
      document.getElementById('activity-title').textContent = a.name;
      document.getElementById('activity-desc').textContent = a.desc;
      document.getElementById('spec-download').textContent = a.download;
      document.getElementById('spec-upload').textContent = a.upload;
      document.getElementById('spec-ping').innerHTML = a.ping === 'N/A' ? 'N/A' : a.ping;
      document.getElementById('spec-loss').textContent = a.loss;
      document.getElementById('spec-download-note').textContent = a.downloadNote;
      document.getElementById('spec-upload-note').textContent = a.uploadNote;
      document.getElementById('spec-ping-note').textContent = a.pingNote;
      document.getElementById('spec-loss-note').textContent = a.lossNote;
    }

    // Initialize first activity
    updateActivity('competitive-fps');

    /* ── Bandwidth Calculator ── */
    document.querySelectorAll('.calc-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.calc;
        if (btn.classList.contains('plus')) {
          counts[key] = Math.min(counts[key] + 1, 10);
        } else {
          counts[key] = Math.max(counts[key] - 1, 0);
        }
        document.getElementById('calc-' + key).textContent = counts[key];
        updateCalc();
      });
    });

    function updateCalc() {
      let totalDown = 0, totalUp = 0;
      for (const [key, count] of Object.entries(counts)) {
        totalDown += CALC_DATA[key].down * count;
        totalUp += CALC_DATA[key].up * count;
      }
      // Add 20% headroom
      totalDown = Math.ceil(totalDown * 1.2);
      totalUp = Math.ceil(totalUp * 1.2);

      // Minimum floor
      if (totalDown < 10) totalDown = 10;
      if (totalUp < 3) totalUp = 3;

      document.getElementById('calc-total-down').textContent = totalDown + ' Mbps';
      document.getElementById('calc-total-up').textContent = totalUp + ' Mbps';

      // Suggest a plan
      let plan;
      if (totalDown <= 30) plan = '50 Mbps plan';
      else if (totalDown <= 75) plan = '100 Mbps plan';
      else if (totalDown <= 150) plan = '200 Mbps plan';
      else if (totalDown <= 300) plan = '500 Mbps plan';
      else plan = '1 Gbps plan';

      document.getElementById('calc-plan').textContent = plan;
    }

    updateCalc();
  })();
  </script>

