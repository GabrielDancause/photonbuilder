---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "FPS Terms Glossary",
    "description": "Essential FPS terms explained: peeker's advantage, spray pattern, crosshair placement, rotation."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Peeker's advantage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A networking phenomenon in online shooters where the player actively moving around a corner sees the holding player slightly before the holding player sees them on their screen. This is due to the slight delay in data traveling from the server to the defending player's client."
        }
      },
      {
        "@type": "Question",
        "name": "What is Spray pattern?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The predictable and specific path that bullets follow when a player fires a weapon continuously in fully automatic mode. Players must learn to pull their mouse in the opposite direction of the pattern to maintain accuracy, a skill known as spray control."
        }
      },
      {
        "@type": "Question",
        "name": "What is Crosshair placement?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The fundamental practice of keeping your aiming reticle consistently at head-height and anticipating exactly where an enemy might peek or appear. Good crosshair placement minimizes the physical distance the player needs to move their mouse when an engagement starts, significantly reducing reaction time."
        }
      }
    ]
  }
];

export const meta = {
  title: "Fps Terms Glossary — Free Online Tool",
  description: "Essential FPS terms explained: peeker's advantage, spray pattern, crosshair placement, rotation.",
  category: "list",
  published: "2026-03-15",
};
---

<SiteLayout
  site="leeroyjenkins"
  title="FPS Terms Glossary"
  description="Essential FPS terms explained: peeker's advantage, spray pattern, crosshair placement, rotation."
  canonical="https://leeroyjenkins.quest/fps-terms-glossary"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>FPS Terms Glossary</h1>
      <p>Essential FPS terms explained: peeker's advantage, spray pattern, crosshair placement, rotation.</p>
    </div>


    <div class="card">
        <h3>Peeker's advantage</h3>
        <p>A networking phenomenon in online shooters where the player actively moving around a corner sees the holding player slightly before the holding player sees them on their screen. This is due to the slight delay in data traveling from the server to the defending player's client.</p>
    </div>
    <div class="card">
        <h3>Spray pattern</h3>
        <p>The predictable and specific path that bullets follow when a player fires a weapon continuously in fully automatic mode. Players must learn to pull their mouse in the opposite direction of the pattern to maintain accuracy, a skill known as spray control.</p>
    </div>
    <div class="card">
        <h3>Crosshair placement</h3>
        <p>The fundamental practice of keeping your aiming reticle consistently at head-height and anticipating exactly where an enemy might peek or appear. Good crosshair placement minimizes the physical distance the player needs to move their mouse when an engagement starts, significantly reducing reaction time.</p>
    </div>
    <div class="card">
        <h3>Rotation</h3>
        <p>The tactical act of moving from one area of the map to another, typically to support teammates under attack, defend a different bomb site, or flank enemies. Fast and unpredictable rotations are key to confusing the opposing team and maintaining map control.</p>
    </div>
    <div class="card">
        <h3>Flick</h3>
        <p>An extremely fast, reactive mouse movement used to quickly acquire and shoot a target that suddenly appears on the screen. Flicks rely heavily on muscle memory rather than conscious tracking.</p>
    </div>
    <div class="card">
        <h3>TTK (Time to Kill)</h3>
        <p>The average amount of time it takes to eliminate an opponent using a specific weapon or ability. Games like Valorant have a very low TTK, meaning players die almost instantly, whereas games like Apex Legends have a high TTK, requiring sustained tracking and movement.</p>
    </div>
    <div class="card">
        <h3>ADS (Aim Down Sights)</h3>
        <p>The action of looking through a weapon's optics, scope, or iron sights for increased accuracy and zoom, often at the cost of movement speed or peripheral vision.</p>
    </div>
    <div class="card">
        <h3>Hitscan</h3>
        <p>A type of weapon mechanic where the projectile instantly hits whatever is in the center of the crosshair the moment the trigger is pulled, with absolutely no travel time or bullet drop to account for.</p>
    </div>
    <div class="card">
        <h3>Projectile</h3>
        <p>A weapon mechanic where the bullet or rocket has actual travel time and often physical drop over distance. Players must 'lead' their shots, aiming ahead of a moving target to ensure the projectile connects.</p>
    </div>
    <div class="card">
        <h3>Strafe</h3>
        <p>Moving sideways (left or right) to dodge enemy fire while keeping the camera focused forward on the target. In many tactical shooters, players must completely stop strafing to regain weapon accuracy before firing.</p>
    </div>
    <div class="card">
        <h3>Bunny hopping (B-hop)</h3>
        <p>An advanced movement technique that involves chaining perfectly timed jumps while turning in mid-air to gain or maintain momentum, often allowing a player to move faster than the game's standard running speed.</p>
    </div>
    <div class="card">
        <h3>Pre-fire</h3>
        <p>Firing a weapon at a common hiding spot or corner just before or exactly as you peek it, anticipating that an enemy is there. If an enemy is present, they take damage instantly before they can react.</p>
    </div>
    <div class="card">
        <h3>Wallbang</h3>
        <p>Shooting an enemy through a penetrable surface, such as a thin wall, wooden door, or crate. Different weapons usually have different levels of penetration power.</p>
    </div>
    <div class="card">
        <h3>Drop shot</h3>
        <p>The tactic of instantly going prone (laying flat on the ground) while simultaneously shooting at an opponent in a close-quarters engagement, causing the enemy to miss their head or body shots.</p>
    </div>
    <div class="card">
        <h3>Jiggle peek</h3>
        <p>Briefly stepping out from behind cover and immediately stepping back in to safely gain information on enemy positions or bait out sniper shots without fully committing to a fight.</p>
    </div>
    <div class="card">
        <h3>Hip fire</h3>
        <p>Shooting a weapon without aiming down the sights. It is generally less accurate but allows for faster movement and better peripheral vision in close-quarters combat.</p>
    </div>
    <div class="card">
        <h3>Spawn trap</h3>
        <p>A situation where one team gains such overwhelming map control that they can continuously kill the opposing team immediately as they respawn in their base, preventing them from playing the game.</p>
    </div>
    <div class="card">
        <h3>Camp</h3>
        <p>Remaining in a single, advantageous, and often hidden position for an extended period to ambush enemies as they walk by, rather than actively roaming the map.</p>
    </div>
    <div class="card">
        <h3>Clutch</h3>
        <p>Successfully winning a round or match when you are the last surviving member of your team against multiple remaining opponents.</p>
    </div>
    <div class="card">
        <h3>Frag</h3>
        <p>Another term for a kill. The player with the most kills on a team is often referred to as the 'top fragger'.</p>
    </div>
    <div class="card">
        <h3>One-tap</h3>
        <p>Killing an enemy with a single, perfectly placed bullet to the head. This term is heavily used in tactical shooters like Counter-Strike and Valorant.</p>
    </div>
    <div class="card">
        <h3>Smokes</h3>
        <p>Utility grenades or abilities that deploy a cloud of smoke, blocking line of sight. They are crucial for executing strategies, crossing open areas safely, or delaying enemy pushes.</p>
    </div>
    <div class="card">
        <h3>Entry fragger</h3>
        <p>The role of the first player on a team to enter a contested area or bomb site. Their primary job is to get the first kill or gather crucial information, even if they die in the process.</p>
    </div>
    <div class="card">
        <h3>Anchor</h3>
        <p>A defensive player whose job is to lock down a specific bomb site or area entirely on their own, delaying the enemy team while their teammates rotate to assist.</p>
    </div>
    <div class="card">
        <h3>Eco round</h3>
        <p>A round where a team deliberately chooses not to spend their in-game currency on expensive weapons and armor, saving their money to ensure they can afford a full loadout in the subsequent round.</p>
    </div>
    <div class="links-section">
      <h3>Related Guides</h3>
      <ul>
        <li><a href="/gaming-jargon-dictionary">Gaming Jargon Dictionary</a></li>
        <li><a href="/competitive-gaming-terms">Competitive Gaming Terms</a></li>
        <li><a href="/network-gaming-terms">Network Gaming Terms</a></li>
      </ul>
    </div>


  </div>

  <script is:inline>
    // Page specific JS
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .card h3 { color: var(--text-primary); font-size: 1.5rem; margin-bottom: 0.5rem; }
    .card p { color: var(--text-secondary); font-size: 1.05rem; line-height: 1.6; margin-bottom: 1rem; }
    .links-section { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color); }
    .links-section h3 { margin-bottom: 1rem; color: var(--text-primary); }
    .links-section ul { list-style: none; padding: 0; }
    .links-section li { margin-bottom: 0.5rem; }
    .links-section a { color: var(--accent-color); text-decoration: none; font-weight: bold; }
    .links-section a:hover { text-decoration: underline; }
  </style>
</SiteLayout>
