---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Migrating Mammals — Travel & Digital Nomad Life",
  "url": "https://migratingmammals.com/",
  "description": "Travel planning tools, digital nomad resources, visa guides, and cost of living data."
};
---

<SiteLayout
  site="migratingmammals"
  title="Migrating Mammals — Travel & Digital Nomad Life"
  description="Travel planning tools, digital nomad resources, visa guides, and cost of living data."
  canonical="https://migratingmammals.com/"
  schema={schema}
>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Travel & Digital Nomad Life</div>
      <h1>Migrating Mammals</h1>
      <p>Travel planning tools, digital nomad resources, visa guides, and cost of living data.</p>
    </div>
  </div>

  <!-- Pillar Guides -->
  <div class="section-container" id="pillars">
    <div class="section-header">
      <span class="section-tag">📚 PILLAR GUIDES</span>
      <h2 class="section-title">Complete Guides</h2>
      <p class="section-sub">Comprehensive, in-depth guides covering entire topics.</p>
    </div>
    <div class="tools-grid">
      <a class="tool-card" href="/guide-digital-nomad-complete">
        <span class="tool-emoji">📚</span>
        <h3 class="tool-name">Guide Digital Nomad Complete</h3>
        <p class="tool-desc">Comprehensive guide covering everything you need to know</p>
      </a>
      <a class="tool-card" href="/guide-money-abroad-complete">
        <span class="tool-emoji">📚</span>
        <h3 class="tool-name">Guide Money Abroad Complete</h3>
        <p class="tool-desc">Comprehensive guide covering everything you need to know</p>
      </a>
      <a class="tool-card" href="/guide-timezones-complete">
        <span class="tool-emoji">📚</span>
        <h3 class="tool-name">Guide Timezones Complete</h3>
        <p class="tool-desc">Comprehensive guide covering everything you need to know</p>
      </a>
      <a class="tool-card" href="/guide-travel-planning-complete">
        <span class="tool-emoji">📚</span>
        <h3 class="tool-name">Guide Travel Planning Complete</h3>
        <p class="tool-desc">Comprehensive guide covering everything you need to know</p>
      </a>
    </div>
  </div>

  <!-- Tools -->
  <div class="section-container" id="tools">
    <div class="section-header">
      <span class="section-tag">🛠️ TOOLS</span>
      <h2 class="section-title">Calculators & Tools</h2>
      <p class="section-sub">Free, instant calculators — no sign-ups required.</p>
    </div>
    <div class="tools-grid">
      <a class="tool-card" href="/airport-codes"><span class="tool-emoji">🔧</span><h3 class="tool-name">Airport Codes</h3><p class="tool-desc">Calculate and analyze airport codes</p></a>
      <a class="tool-card" href="/cost-of-living"><span class="tool-emoji">💰</span><h3 class="tool-name">Cost of Living</h3><p class="tool-desc">Calculate and analyze cost of living</p></a>
      <a class="tool-card" href="/currency-converter"><span class="tool-emoji">💱</span><h3 class="tool-name">Currency Converter</h3><p class="tool-desc">Calculate and analyze currency converter</p></a>
      <a class="tool-card" href="/dialing-codes"><span class="tool-emoji">🔧</span><h3 class="tool-name">Dialing Codes</h3><p class="tool-desc">Calculate and analyze dialing codes</p></a>
      <a class="tool-card" href="/distance-calculator"><span class="tool-emoji">🔧</span><h3 class="tool-name">Distance Calculator</h3><p class="tool-desc">Calculate and analyze distance calculator</p></a>
      <a class="tool-card" href="/expense-splitter"><span class="tool-emoji">⭐</span><h3 class="tool-name">Expense Splitter</h3><p class="tool-desc">Calculate and analyze expense splitter</p></a>
      <a class="tool-card" href="/flight-time"><span class="tool-emoji">✈️</span><h3 class="tool-name">Flight Time</h3><p class="tool-desc">Calculate and analyze flight time</p></a>
      <a class="tool-card" href="/jet-lag"><span class="tool-emoji">😴</span><h3 class="tool-name">Jet Lag</h3><p class="tool-desc">Calculate and analyze jet lag</p></a>
      <a class="tool-card" href="/language-phrases"><span class="tool-emoji">🔧</span><h3 class="tool-name">Language Phrases</h3><p class="tool-desc">Calculate and analyze language phrases</p></a>
      <a class="tool-card" href="/nomad-tax"><span class="tool-emoji">🏛️</span><h3 class="tool-name">Nomad Tax</h3><p class="tool-desc">Calculate and analyze nomad tax</p></a>
      <a class="tool-card" href="/packing-list"><span class="tool-emoji">🎒</span><h3 class="tool-name">Packing List</h3><p class="tool-desc">Calculate and analyze packing list</p></a>
      <a class="tool-card" href="/power-adapter"><span class="tool-emoji">🔧</span><h3 class="tool-name">Power Adapter</h3><p class="tool-desc">Calculate and analyze power adapter</p></a>
      <a class="tool-card" href="/schengen-calculator"><span class="tool-emoji">🇪🇺</span><h3 class="tool-name">Schengen Calculator</h3><p class="tool-desc">Calculate and analyze schengen calculator</p></a>
      <a class="tool-card" href="/timezone-converter"><span class="tool-emoji">🕐</span><h3 class="tool-name">Timezone Converter</h3><p class="tool-desc">Calculate and analyze timezone converter</p></a>
      <a class="tool-card" href="/timezone-overlap"><span class="tool-emoji">🕐</span><h3 class="tool-name">Timezone Overlap</h3><p class="tool-desc">Calculate and analyze timezone overlap</p></a>
      <a class="tool-card" href="/timezone-planner"><span class="tool-emoji">🕐</span><h3 class="tool-name">Timezone Planner</h3><p class="tool-desc">Calculate and analyze timezone planner</p></a>
      <a class="tool-card" href="/travel-budget"><span class="tool-emoji">📊</span><h3 class="tool-name">Travel Budget</h3><p class="tool-desc">Calculate and analyze travel budget</p></a>
      <a class="tool-card" href="/travel-card-fees"><span class="tool-emoji">✈️</span><h3 class="tool-name">Travel Card Fees</h3><p class="tool-desc">Calculate and analyze travel card fees</p></a>
      <a class="tool-card" href="/travel-checklist"><span class="tool-emoji">✈️</span><h3 class="tool-name">Travel Checklist</h3><p class="tool-desc">Calculate and analyze travel checklist</p></a>
      <a class="tool-card" href="/trip-countdown"><span class="tool-emoji">🔧</span><h3 class="tool-name">Trip Countdown</h3><p class="tool-desc">Calculate and analyze trip countdown</p></a>
      <a class="tool-card" href="/visa-checker"><span class="tool-emoji">🛂</span><h3 class="tool-name">Visa Checker</h3><p class="tool-desc">Calculate and analyze visa checker</p></a>
      <a class="tool-card" href="/world-clock"><span class="tool-emoji">🔧</span><h3 class="tool-name">World Clock</h3><p class="tool-desc">Calculate and analyze world clock</p></a>
    </div>
  </div>

  <!-- Studies -->
  <div class="section-container" id="studies">
    <div class="section-header">
      <span class="section-tag">🔬 STUDIES</span>
      <h2 class="section-title">Original Research</h2>
      <p class="section-sub">Data-driven analysis and insights.</p>
    </div>
    <div class="guides-grid">
      <a class="guide-card" href="/cost-of-living-index"><span class="section-tag" style="margin-bottom: 8px;">RESEARCH</span><h3 class="guide-name">Cost of Living Index</h3><p class="guide-desc">Data-driven analysis and research</p></a>
      <a class="guide-card" href="/coworking-prices"><span class="section-tag" style="margin-bottom: 8px;">RESEARCH</span><h3 class="guide-name">Coworking Prices</h3><p class="guide-desc">Data-driven analysis and research</p></a>
      <a class="guide-card" href="/nomad-salaries"><span class="section-tag" style="margin-bottom: 8px;">RESEARCH</span><h3 class="guide-name">Nomad Salaries</h3><p class="guide-desc">Data-driven analysis and research</p></a>
      <a class="guide-card" href="/nomad-visa-index"><span class="section-tag" style="margin-bottom: 8px;">RESEARCH</span><h3 class="guide-name">Nomad Visa Index</h3><p class="guide-desc">Data-driven analysis and research</p></a>
    </div>
  </div>

  <!-- Guides -->
  <div class="section-container" id="guides">
    <div class="section-header">
      <span class="section-tag">📚 GUIDES</span>
      <h2 class="section-title">How-To Guides</h2>
      <p class="section-sub">Step-by-step guides to get the job done right.</p>
    </div>
    <div class="guides-grid">
      <a class="guide-card" href="/guide-coworking"><span class="guide-emoji">💻</span><h3 class="guide-name">Guide Coworking</h3><p class="guide-desc">Step-by-step guide</p></a>
      <a class="guide-card" href="/guide-packing-light"><span class="guide-emoji">🎒</span><h3 class="guide-name">Guide Packing Light</h3><p class="guide-desc">Step-by-step guide</p></a>
      <a class="guide-card" href="/guide-remote-work-visa"><span class="guide-emoji">🛂</span><h3 class="guide-name">Guide Remote Work Visa</h3><p class="guide-desc">Step-by-step guide</p></a>
      <a class="guide-card" href="/guide-schengen"><span class="guide-emoji">🇪🇺</span><h3 class="guide-name">Guide Schengen</h3><p class="guide-desc">Step-by-step guide</p></a>
      <a class="guide-card" href="/guide-slow-travel"><span class="guide-emoji">✈️</span><h3 class="guide-name">Guide Slow Travel</h3><p class="guide-desc">Step-by-step guide</p></a>
      <a class="guide-card" href="/guide-travel-insurance"><span class="guide-emoji">✈️</span><h3 class="guide-name">Guide Travel Insurance</h3><p class="guide-desc">Step-by-step guide</p></a>
    </div>
  </div>

  <!-- Lists -->
  <div class="section-container" id="lists">
    <div class="section-header">
      <span class="section-tag">📋 LISTS</span>
      <h2 class="section-title">Curated Lists</h2>
      <p class="section-sub">The best tools, products, and resources.</p>
    </div>
    <div class="lists-grid">
      <a class="list-card" href="/list-esim"><span class="list-emoji">📱</span><h3 class="list-name">List Esim</h3><p class="list-desc">Curated comparison and rankings</p></a>
      <a class="list-card" href="/list-nomad-cities"><span class="list-emoji">🌍</span><h3 class="list-name">List Nomad Cities</h3><p class="list-desc">Curated comparison and rankings</p></a>
      <a class="list-card" href="/list-travel-apps"><span class="list-emoji">✈️</span><h3 class="list-name">List Travel Apps</h3><p class="list-desc">Curated comparison and rankings</p></a>
      <a class="list-card" href="/list-travel-credit-cards"><span class="list-emoji">💳</span><h3 class="list-name">List Travel Credit Cards</h3><p class="list-desc">Curated comparison and rankings</p></a>
      <a class="list-card" href="/list-vpn"><span class="list-emoji">🔒</span><h3 class="list-name">List VPN</h3><p class="list-desc">Curated comparison and rankings</p></a>
    </div>
  </div>
</SiteLayout>

<style>
  .hero { text-align: center; padding: 100px 24px 70px; position: relative; }
  .hero::before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--accent-color) 8%, transparent) 0%, transparent 60%); }
  .hero-content { position: relative; z-index: 1; }
  .hero .tagline { color: var(--accent-color); font-size: .85rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 16px; }
  .hero h1 { font-size: 3rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 20px; background: linear-gradient(135deg, #fff, var(--accent-color)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-align: left; }
  .hero p { color: #5a6a80; font-size: 1.05rem; max-width: 540px; margin: 0 auto; }
  .section-container { max-width: 1200px; margin: 0 auto; padding: 60px 24px; }
  .section-header { text-align: center; margin-bottom: 40px; }
  .section-tag { display: inline-block; background: color-mix(in srgb, var(--accent-color) 10%, transparent); color: var(--accent-color); font-size: .7rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1px; margin-bottom: 12px; }
  .section-title { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 8px; letter-spacing: -.8px; }
  .section-sub { color: #5a6a80; font-size: 1rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .tool-card { background: #0c1218; border: 1px solid #1a2230; border-radius: 12px; padding: 20px; text-decoration: none; color: inherit; display: block; transition: all .2s ease; }
  .tool-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .tool-emoji { font-size: 1.4rem; margin-bottom: 8px; display: block; }
  .tool-name { font-size: .95rem; font-weight: 700; color: #e0e8f0; margin-bottom: 6px; }
  .tool-desc { font-size: .8rem; color: #6a7a90; line-height: 1.4; }
  .guides-grid, .lists-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
  .guide-card, .list-card { background: #0c1218; border: 1px solid #1a2230; border-radius: 14px; padding: 24px 20px; text-decoration: none; color: inherit; display: block; transition: all .2s ease; }
  .guide-card:hover, .list-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .guide-emoji, .list-emoji { font-size: 1.5rem; margin-bottom: 10px; display: block; }
  .guide-name, .list-name { font-size: 1rem; font-weight: 700; color: #e0e8f0; margin-bottom: 6px; }
  .guide-desc, .list-desc { font-size: .85rem; color: #6a7a90; line-height: 1.4; }
  @media (max-width: 768px) {
    .hero h1 { font-size: 2.2rem; }
    .hero { padding: 70px 20px 50px; }
    .section-container { padding: 40px 20px; }
    .tools-grid, .guides-grid, .lists-grid { grid-template-columns: 1fr; }
  }
</style>
