const STORAGE_KEY = "mm_packing_list";

function $(id) { return document.getElementById(id); }

function getConfig() {
  return {
    destination: $("cfg-destination").value,
    duration: $("cfg-duration").value,
    style: $("cfg-style").value
  };
}

function buildItems(cfg) {
  const items = {};
  Object.keys(PACKING_DATA).forEach(catKey => {
    const cat = PACKING_DATA[catKey];
    const list = [];

    cat.base.forEach(item => list.push(formatItem(item, cfg.duration)));

    if (cat.destination && cat.destination[cfg.destination]) {
      cat.destination[cfg.destination].forEach(item => list.push(formatItem(item, cfg.duration)));
    }

    if (cat.style && cat.style[cfg.style]) {
      cat.style[cfg.style].forEach(item => list.push(formatItem(item, cfg.duration)));
    }

    if (cat.duration) {
      const durKeys = ["weekend", "1week", "2weeks", "1month"];
      const durIdx = durKeys.indexOf(cfg.duration);
      durKeys.forEach((dk, i) => {
        if (i <= durIdx && cat.duration[dk]) {
          cat.duration[dk].forEach(item => {
            const formatted = formatItem(item, cfg.duration);
            if (!list.some(l => l.name === formatted.name)) {
              list.push(formatted);
            }
          });
        }
      });
    }

    items[catKey] = list;
  });
  return items;
}

function formatItem(item, duration) {
  let name = item.name;
  if (item.qty && item.qty[duration]) {
    name += " (\u00d7" + item.qty[duration] + ")";
  }
  return { name: name, checked: false, custom: false };
}

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) return JSON.parse(raw);
  } catch (e) { /* ignore */ }
  return null;
}

function saveState(cfg, items) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ cfg: cfg, items: items, ts: Date.now() }));
  } catch (e) { /* ignore */ }
}

function clearState() {
  try { localStorage.removeItem(STORAGE_KEY); } catch (e) { /* ignore */ }
}

function updateProgress(items) {
  var total = 0, checked = 0;
  Object.values(items).forEach(function(list) {
    list.forEach(function(item) {
      total++;
      if (item.checked) checked++;
    });
  });
  $("progress-text").textContent = checked + " / " + total + " packed";
  $("progress-bar").style.width = total > 0 ? ((checked / total) * 100) + "%" : "0%";
}

function renderChecklist(items, cfg) {
  var grid = $("checklist-grid");
  grid.innerHTML = "";

  Object.keys(items).forEach(function(catKey) {
    var cat = PACKING_DATA[catKey];
    var list = items[catKey];
    if (!list || list.length === 0) return;

    var card = document.createElement("div");
    card.className = "category-card";

    var checkedCount = list.filter(function(i) { return i.checked; }).length;

    var html = '<div class="category-header"><h3>' + cat.label + '</h3><span class="category-count">' + checkedCount + '/' + list.length + '</span></div>';

    list.forEach(function(item, idx) {
      html += '<div class="checklist-item' + (item.checked ? " checked" : "") + '">' +
        '<input type="checkbox" ' + (item.checked ? "checked" : "") + ' data-cat="' + catKey + '" data-idx="' + idx + '">' +
        '<span class="item-label">' + item.name + '</span>' +
        (item.custom ? '<button class="item-remove" data-cat="' + catKey + '" data-idx="' + idx + '" title="Remove">&times;</button>' : "") +
        '</div>';
    });

    html += '<div class="add-item-row"><input type="text" placeholder="Add custom item..." data-cat="' + catKey + '"><button data-cat="' + catKey + '">Add</button></div>';

    card.innerHTML = html;
    grid.appendChild(card);
  });

  // Checkbox listeners
  grid.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
    cb.addEventListener("change", function() {
      var cat = cb.dataset.cat;
      var idx = parseInt(cb.dataset.idx);
      items[cat][idx].checked = cb.checked;
      cb.closest(".checklist-item").classList.toggle("checked", cb.checked);
      saveState(cfg, items);
      updateProgress(items);
      var cardEl = cb.closest(".category-card");
      var catList = items[cat];
      cardEl.querySelector(".category-count").textContent = catList.filter(function(i) { return i.checked; }).length + "/" + catList.length;
    });
  });

  // Remove listeners
  grid.querySelectorAll(".item-remove").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var cat = btn.dataset.cat;
      var idx = parseInt(btn.dataset.idx);
      items[cat].splice(idx, 1);
      saveState(cfg, items);
      renderChecklist(items, cfg);
      updateProgress(items);
    });
  });

  // Add item listeners
  grid.querySelectorAll(".add-item-row button").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var cat = btn.dataset.cat;
      var input = btn.previousElementSibling;
      var val = input.value.trim();
      if (!val) return;
      items[cat].push({ name: val, checked: false, custom: true });
      input.value = "";
      saveState(cfg, items);
      renderChecklist(items, cfg);
      updateProgress(items);
    });
  });

  grid.querySelectorAll(".add-item-row input").forEach(function(input) {
    input.addEventListener("keydown", function(e) {
      if (e.key === "Enter") {
        e.preventDefault();
        input.nextElementSibling.click();
      }
    });
  });

  updateProgress(items);
  $("checklist-section").style.display = "";
}

// Init
var currentItems = null;
var currentCfg = null;

var saved = loadState();
if (saved && saved.items && saved.cfg) {
  currentCfg = saved.cfg;
  currentItems = saved.items;
  $("cfg-destination").value = saved.cfg.destination;
  $("cfg-duration").value = saved.cfg.duration;
  $("cfg-style").value = saved.cfg.style;
  renderChecklist(currentItems, currentCfg);
}

$("btn-generate").addEventListener("click", function() {
  currentCfg = getConfig();
  currentItems = buildItems(currentCfg);
  saveState(currentCfg, currentItems);
  renderChecklist(currentItems, currentCfg);
  $("checklist-section").scrollIntoView({ behavior: "smooth" });
});

$("btn-check-all").addEventListener("click", function() {
  if (!currentItems) return;
  Object.values(currentItems).forEach(function(list) { list.forEach(function(i) { i.checked = true; }); });
  saveState(currentCfg, currentItems);
  renderChecklist(currentItems, currentCfg);
});

$("btn-uncheck-all").addEventListener("click", function() {
  if (!currentItems) return;
  Object.values(currentItems).forEach(function(list) { list.forEach(function(i) { i.checked = false; }); });
  saveState(currentCfg, currentItems);
  renderChecklist(currentItems, currentCfg);
});

$("btn-reset").addEventListener("click", function() {
  clearState();
  currentItems = null;
  currentCfg = null;
  $("checklist-section").style.display = "none";
  $("checklist-grid").innerHTML = "";
});
  </script>

