---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Travel Packing List Generator",
    "url": "https://migratingmammals.com/packing-list-generator",
    "applicationCategory": "TravelApplication",
    "operatingSystem": "All",
    "description": "Generate a personalized travel packing list based on your destination type, trip duration, climate, and planned activities. Check off items, track your packing progress, and save lists for future trips.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What should I pack for a trip?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "What you pack depends on your destination type, climate, trip duration, and planned activities. A basic packing list includes clothing layers, toiletries, electronics (phone, charger, adapter), travel documents (passport, visa, insurance), medications, and a few miscellaneous items like a reusable water bottle and packing cubes. Use a packing list generator to get a personalized checklist based on your specific trip details."
        }
      },
      {
        "@type": "Question",
        "name": "How do I create a travel packing list?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Start by selecting your destination type (beach, city, mountain, or business), trip duration, climate, and activities. Then organize items into categories: clothing, toiletries, electronics, documents, medicine, and miscellaneous. Check off items as you pack them to track your progress. A packing list generator automates this process and gives you a tailored checklist in seconds."
        }
      },
      {
        "@type": "Question",
        "name": "How many clothes should I pack for a 2-week trip?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For a 2-week trip, pack 5–7 tops, 3–4 bottoms, 7–10 pairs of underwear and socks, 2 pairs of shoes, and 1–2 jackets or layers. Plan to do laundry once during the trip. Choose versatile, mix-and-match pieces in neutral colors. Roll clothes instead of folding to save space, and use packing cubes to stay organized."
        }
      },
      {
        "@type": "Question",
        "name": "What should I not forget to pack when traveling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most commonly forgotten travel items include: phone charger and power bank, universal power adapter, prescription medications, travel insurance documents, copies of your passport, toothbrush, sunscreen, reusable water bottle, and a small first aid kit. Keep a master packing list that you can reuse for every trip to avoid forgetting essentials."
        }
      },
      {
        "@type": "Question",
        "name": "How do I pack light for a long trip?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To pack light: choose a carry-on-sized bag to limit yourself, pick versatile clothing that mixes and matches, wear your bulkiest items on the plane, use packing cubes and compression bags, bring travel-sized toiletries, limit shoes to 2 pairs, and plan to do laundry. A one-bag travel approach with a 40L backpack is enough for trips of any length if you pack strategically."
        }
      },
      {
        "@type": "Question",
        "name": "What size bag do I need for travel?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For a weekend trip, a 20–30L daypack or duffel is sufficient. For a 1–2 week trip, a 40–50L backpack or carry-on suitcase works well. For extended travel (1 month+), a 50–65L backpack gives you room for extras, though experienced travelers can manage with 40L by packing light and doing laundry. Always check airline carry-on size limits before flying."
        }
      },
      {
        "@type": "Question",
        "name": "Should I pack differently for different climates?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, climate dramatically affects your packing list. For tropical destinations, pack lightweight, breathable fabrics, sun protection, and insect repellent. For cold climates, layer with a base layer, insulating mid-layer, and waterproof outer shell. Temperate climates require versatile layers that handle varying temperatures. Always check the weather forecast for your specific dates."
        }
      },
      {
        "@type": "Question",
        "name": "What electronics should I bring when traveling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Essential travel electronics include: smartphone with offline maps, universal power adapter, portable charger (power bank, 10,000+ mAh), charging cables, noise-cancelling headphones, and an e-reader or tablet. For digital nomads, add a laptop, laptop stand, and portable Wi-Fi hotspot. Always bring electronics in your carry-on, never in checked luggage."
        }
      }
    ]
  }
];

export const meta = {
  title: "Packing List Generator — Personalized Travel Checklist",
  description: "Generate a personalized travel packing list based on your destination, duration, climate, and activities. Check off items, track progress, and save lists for future trips.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="migratingmammals"
  title="Packing List Generator — Personalized Travel Checklist"
  description="Generate a personalized travel packing list based on your destination, duration, climate, and activities. Check off items, track progress, and save lists for future trips."
  canonical="https://migratingmammals.com/packing-list-generator"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .container { max-width: 900px; margin: 0 auto; padding: 0 1.5rem; }

    header { padding: 4rem 0 2rem; text-align: center; }

    h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2; }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 680px;
      margin: 0 auto 2rem;
    }

    section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }

    /* Config Panel */
    .config-panel {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .config-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .config-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .config-group label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .config-group select {
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.6rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.875rem;
      outline: none;
      cursor: pointer;
    }

    .config-group select:focus { border-color: var(--accent-color); }

    .activities-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .activity-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.45rem 0.85rem;
      border: 1px solid var(--border-color);
      border-radius: 2rem;
      font-size: 0.8rem;
      cursor: pointer;
      user-select: none;
      transition: all 0.15s;
      background-color: transparent;
      color: var(--text-secondary);
    }

    .activity-tag:hover { border-color: var(--accent-color); color: var(--text-primary); }
    .activity-tag.active { background-color: var(--accent-color); color: #000; border-color: var(--accent-color); font-weight: 600; }

    .btn-generate {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background-color: var(--accent-color);
      color: #000;
      border: none;
      padding: 0.75rem 2rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .btn-generate:hover { opacity: 0.85; }

    /* Progress Bar */
    .progress-section {
      display: none;
      margin-bottom: 2rem;
    }

    .progress-section.visible { display: block; }

    .progress-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
    }

    .progress-header .label { font-size: 0.85rem; color: var(--text-secondary); }

    .progress-header .pct {
      font-family: var(--font-code);
      font-size: 1.1rem;
      font-weight: 700;
    }

    .progress-bar {
      width: 100%;
      height: 10px;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 99px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background-color: var(--accent-color);
      border-radius: 99px;
      transition: width 0.3s ease;
      width: 0%;
    }

    .progress-actions {
      display: flex;
      gap: 0.75rem;
      margin-top: 0.75rem;
      flex-wrap: wrap;
    }

    .btn-sm {
      background-color: var(--card-bg);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.45rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      cursor: pointer;
      transition: border-color 0.15s;
    }

    .btn-sm:hover { border-color: var(--accent-color); }

    /* Checklist */
    .checklist-container { display: none; }
    .checklist-container.visible { display: block; }

    .category-section {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      margin-bottom: 1rem;
      overflow: hidden;
    }

    .category-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.25rem;
      cursor: pointer;
      user-select: none;
      transition: background-color 0.15s;
    }

    .category-header:hover { background-color: rgba(255,255,255,0.03); }

    .category-header .left {
      display: flex;
      align-items: center;
      gap: 0.65rem;
    }

    .category-icon { font-size: 1.1rem; }

    .category-name { font-weight: 700; font-size: 0.95rem; }

    .category-count {
      font-size: 0.75rem;
      color: var(--text-secondary);
      font-family: var(--font-code);
    }

    .category-toggle {
      font-size: 0.75rem;
      color: var(--text-secondary);
      transition: transform 0.2s;
    }

    .category-section.collapsed .category-toggle { transform: rotate(-90deg); }
    .category-section.collapsed .category-items { display: none; }

    .category-items { border-top: 1px solid var(--border-color); }

    .checklist-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.65rem 1.25rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      transition: background-color 0.1s;
      cursor: pointer;
    }

    .checklist-item:last-child { border-bottom: none; }
    .checklist-item:hover { background-color: rgba(255,255,255,0.02); }

    .checklist-item input[type="checkbox"] {
      width: 18px;
      height: 18px;
      accent-color: var(--accent-color);
      cursor: pointer;
      flex-shrink: 0;
    }

    .checklist-item .item-label {
      font-size: 0.875rem;
      flex: 1;
      color: var(--text-primary);
    }

    .checklist-item.checked .item-label {
      text-decoration: line-through;
      color: var(--text-secondary);
      opacity: 0.6;
    }

    .checklist-item .remove-btn {
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 0.85rem;
      cursor: pointer;
      padding: 0.2rem;
      opacity: 0;
      transition: opacity 0.15s;
    }

    .checklist-item:hover .remove-btn { opacity: 1; }
    .checklist-item .remove-btn:hover { color: #ef4444; }

    /* Add custom item */
    .add-item-row {
      display: flex;
      gap: 0.5rem;
      padding: 0.65rem 1.25rem;
      border-top: 1px solid var(--border-color);
    }

    .add-item-row input {
      flex: 1;
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.45rem 0.75rem;
      border-radius: 0.375rem;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      outline: none;
    }

    .add-item-row input:focus { border-color: var(--accent-color); }

    .add-item-row select {
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.45rem 0.5rem;
      border-radius: 0.375rem;
      font-size: 0.8rem;
      font-family: var(--font-ui);
      outline: none;
    }

    .add-item-row button {
      background-color: var(--accent-color);
      color: #000;
      border: none;
      padding: 0.45rem 0.85rem;
      border-radius: 0.375rem;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
    }

    /* Saved Lists */
    .saved-lists {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      margin-bottom: 2rem;
      display: none;
    }

    .saved-lists.visible { display: block; }

    .saved-lists h3 { margin-bottom: 0.75rem; }

    .saved-list-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.5rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .saved-list-item:last-child { border-bottom: none; }

    .saved-list-info {
      display: flex;
      flex-direction: column;
    }

    .saved-list-name { font-size: 0.875rem; font-weight: 600; }
    .saved-list-meta { font-size: 0.75rem; color: var(--text-secondary); }

    .saved-list-actions { display: flex; gap: 0.5rem; }

    .saved-list-actions button {
      background: none;
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.3rem 0.6rem;
      border-radius: 0.375rem;
      font-size: 0.75rem;
      cursor: pointer;
      font-family: var(--font-ui);
    }

    .saved-list-actions button:hover { border-color: var(--accent-color); }
    .saved-list-actions button.delete:hover { border-color: #ef4444; color: #ef4444; }

    /* FAQ */
    .faq-item {
      margin-bottom: 1.5rem;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }

    .faq-item h3 { font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .faq-item p { color: var(--text-secondary); }

    /* Related */
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .related-card {
      display: block;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      transition: border-color 0.2s, transform 0.2s;
    }

    .related-card:hover {
      border-color: var(--accent-color);
      transform: translateY(-2px);
      text-decoration: none;
      opacity: 1;
    }

    .related-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
    .related-card p { font-size: 0.8rem; color: var(--text-secondary); }

    /* Prose */
    .prose { max-width: 720px; }
    .prose p { color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.95rem; }
    .prose ul { list-style: disc; padding-left: 1.25rem; margin-bottom: 1rem; }
    .prose ul li { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0.35rem; }

    /* Print */
    @media print {
      body { background: #fff !important; color: #000 !important; }
      .config-panel, .progress-actions, .add-item-row, .remove-btn, .saved-lists, .faq-item, .related-grid, .subtitle, header, nav, footer { display: none !important; }
      .container { max-width: 100%; padding: 0; }
      .category-section { border: 1px solid #ccc; break-inside: avoid; }
      .category-header { background: #f5f5f5 !important; }
      .category-name, .category-count { color: #000 !important; }
      .checklist-item { color: #000 !important; }
      .checklist-item .item-label { color: #000 !important; }
      .checklist-item.checked .item-label { color: #999 !important; }
      .progress-section { border: 1px solid #ccc; padding: 1rem; border-radius: 0.5rem; }
      .progress-bar { border: 1px solid #ccc; }
      .progress-fill { background-color: #333 !important; }
      h2 { color: #000 !important; border-color: #ccc !important; }
    }

    @media (max-width: 700px) {
      h1 { font-size: 1.75rem; }
      .config-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="container">
    <header>
      <h1>Packing List Generator</h1>
      <p class="subtitle">Build a personalized travel packing list based on your destination, trip length, climate, and activities. Check off items as you pack, save lists for future trips, and never forget an essential again.</p>
    </header>

    <!-- Intro -->
    <section>
      <div class="prose">
        <p>Whether you're heading to the beach for a weekend or embarking on a month-long business trip, a good <strong>packing list</strong> is the difference between a smooth departure and last-minute panic. This <strong>packing list generator</strong> creates a personalized <strong>travel packing list</strong> tailored to your exact trip — then lets you check off items, track your progress, and save lists for next time.</p>
        <p>Select your destination type, trip duration, climate, and planned activities below, and we'll generate a comprehensive checklist covering clothing, toiletries, electronics, documents, medicine, and more. Wondering <strong>what to pack</strong>? Start here.</p>
      </div>
    </section>

    <!-- Trip Configuration -->
    <section>
      <h2>Configure Your Trip</h2>
      <div class="config-panel">
        <div class="config-grid">
          <div class="config-group">
            <label>Destination Type</label>
            <select id="cfg-destination">
              <option value="beach">Beach / Coastal</option>
              <option value="city" selected>City / Urban</option>
              <option value="mountain">Mountain / Outdoors</option>
              <option value="business">Business Trip</option>
            </select>
          </div>
          <div class="config-group">
            <label>Duration</label>
            <select id="cfg-duration">
              <option value="weekend">Weekend (2–3 days)</option>
              <option value="1week" selected>1 Week</option>
              <option value="2week">2 Weeks</option>
              <option value="1month">1 Month+</option>
            </select>
          </div>
          <div class="config-group">
            <label>Climate</label>
            <select id="cfg-climate">
              <option value="tropical">Tropical / Hot</option>
              <option value="temperate" selected>Temperate / Mild</option>
              <option value="cold">Cold / Winter</option>
            </select>
          </div>
        </div>

        <div class="config-group" style="margin-bottom:1.25rem">
          <label>Activities (select all that apply)</label>
          <div class="activities-grid" id="activities-grid"></div>
        </div>

        <button class="btn-generate" id="btn-generate">Generate Packing List</button>
      </div>
    </section>

    <!-- Saved Lists -->
    <div class="saved-lists" id="saved-lists">
      <h3>Saved Lists</h3>
      <div id="saved-lists-body"></div>
    </div>

    <!-- Progress -->
    <div class="progress-section" id="progress-section">
      <div class="progress-header">
        <span class="label" id="progress-label">0 of 0 items packed</span>
        <span class="pct" id="progress-pct">0%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
      </div>
      <div class="progress-actions">
        <button class="btn-sm" id="btn-save">Save List</button>
        <button class="btn-sm" id="btn-print">Print List</button>
        <button class="btn-sm" id="btn-uncheck">Uncheck All</button>
        <button class="btn-sm" id="btn-reset">Reset</button>
      </div>
    </div>

    <!-- Checklist -->
    <div class="checklist-container" id="checklist-container"></div>

    <!-- Add Custom Item -->
    <div class="add-item-row" id="add-item-row" style="display:none;background-color:var(--card-bg);border:1px solid var(--border-color);border-radius:0.75rem;margin-bottom:2rem">
      <input type="text" id="custom-item-input" placeholder="Add a custom item..." />
      <select id="custom-item-category">
        <option value="clothing">Clothing</option>
        <option value="toiletries">Toiletries</option>
        <option value="electronics">Electronics</option>
        <option value="documents">Documents</option>
        <option value="medicine">Medicine</option>
        <option value="misc">Misc</option>
      </select>
      <button id="btn-add-custom">Add</button>
    </div>

    <!-- SEO Content -->
    <section>
      <h2>How to Use This Packing List Generator</h2>
      <div class="prose">
        <p>Creating the perfect <strong>travel packing list</strong> takes just a few steps:</p>
        <ul>
          <li><strong>Set your trip details</strong> — Choose your destination type, how long you're going, and the climate you'll encounter.</li>
          <li><strong>Pick your activities</strong> — Heading out for a hike? Need to pack for nightlife? Working remotely? Each activity adds relevant items to your list.</li>
          <li><strong>Generate &amp; customize</strong> — Hit generate, then add or remove items to match your specific needs.</li>
          <li><strong>Check off as you pack</strong> — The progress bar shows exactly how close you are to being fully packed.</li>
          <li><strong>Save for later</strong> — Save your list to come back to it, or print a clean version to take with you.</li>
        </ul>
      </div>
    </section>

    <section>
      <h2>Packing Tips by Trip Type</h2>
      <div class="prose">
        <p><strong>Beach vacations:</strong> Prioritize swimwear, sun protection, and light breathable fabrics. Pack a sarong — it doubles as a towel, cover-up, and blanket. Reef-safe sunscreen is a must for many coastal destinations.</p>
        <p><strong>City breaks:</strong> Comfortable walking shoes are your most important item. Pack layers for variable weather and a small daypack for sightseeing. Dress slightly nicer than you think — many European restaurants have dress codes.</p>
        <p><strong>Mountain adventures:</strong> The layering system is key: moisture-wicking base layer, insulating mid layer, waterproof outer shell. Pack more socks than you think you need. A headlamp is essential even for day hikers.</p>
        <p><strong>Business trips:</strong> Pack wrinkle-resistant clothing and a steamer if possible. Keep one full outfit in your carry-on in case luggage is delayed. A portable laptop stand and noise-cancelling headphones make hotel-room work sessions more productive.</p>
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>What should I pack for a trip?</h3>
        <p>What you pack depends on your destination type, climate, trip duration, and planned activities. A basic packing list includes clothing layers, toiletries, electronics (phone, charger, adapter), travel documents (passport, visa, insurance), medications, and a few miscellaneous items like a reusable water bottle and packing cubes. Use a packing list generator to get a personalized checklist based on your specific trip details.</p>
      </div>
      <div class="faq-item">
        <h3>How do I create a travel packing list?</h3>
        <p>Start by selecting your destination type (beach, city, mountain, or business), trip duration, climate, and activities. Then organize items into categories: clothing, toiletries, electronics, documents, medicine, and miscellaneous. Check off items as you pack them to track your progress. A packing list generator automates this process and gives you a tailored checklist in seconds.</p>
      </div>
      <div class="faq-item">
        <h3>How many clothes should I pack for a 2-week trip?</h3>
        <p>For a 2-week trip, pack 5–7 tops, 3–4 bottoms, 7–10 pairs of underwear and socks, 2 pairs of shoes, and 1–2 jackets or layers. Plan to do laundry once during the trip. Choose versatile, mix-and-match pieces in neutral colors. Roll clothes instead of folding to save space, and use packing cubes to stay organized.</p>
      </div>
      <div class="faq-item">
        <h3>What should I not forget to pack when traveling?</h3>
        <p>The most commonly forgotten travel items include: phone charger and power bank, universal power adapter, prescription medications, travel insurance documents, copies of your passport, toothbrush, sunscreen, reusable water bottle, and a small first aid kit. Keep a master packing list that you can reuse for every trip to avoid forgetting essentials.</p>
      </div>
      <div class="faq-item">
        <h3>How do I pack light for a long trip?</h3>
        <p>To pack light: choose a carry-on-sized bag to limit yourself, pick versatile clothing that mixes and matches, wear your bulkiest items on the plane, use packing cubes and compression bags, bring travel-sized toiletries, limit shoes to 2 pairs, and plan to do laundry. A one-bag travel approach with a 40L backpack is enough for trips of any length if you pack strategically.</p>
      </div>
      <div class="faq-item">
        <h3>What size bag do I need for travel?</h3>
        <p>For a weekend trip, a 20–30L daypack or duffel is sufficient. For a 1–2 week trip, a 40–50L backpack or carry-on suitcase works well. For extended travel (1 month+), a 50–65L backpack gives you room for extras, though experienced travelers can manage with 40L by packing light and doing laundry. Always check airline carry-on size limits before flying.</p>
      </div>
      <div class="faq-item">
        <h3>Should I pack differently for different climates?</h3>
        <p>Yes, climate dramatically affects your packing list. For tropical destinations, pack lightweight, breathable fabrics, sun protection, and insect repellent. For cold climates, layer with a base layer, insulating mid-layer, and waterproof outer shell. Temperate climates require versatile layers that handle varying temperatures. Always check the weather forecast for your specific dates.</p>
      </div>
      <div class="faq-item">
        <h3>What electronics should I bring when traveling?</h3>
        <p>Essential travel electronics include: smartphone with offline maps, universal power adapter, portable charger (power bank, 10,000+ mAh), charging cables, noise-cancelling headphones, and an e-reader or tablet. For digital nomads, add a laptop, laptop stand, and portable Wi-Fi hotspot. Always bring electronics in your carry-on, never in checked luggage.</p>
      </div>
    </section>

    <!-- Related Pages -->
    <section>
      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/digital-nomad-visa-guide" class="related-card">
          <h3>Digital Nomad Visa Guide</h3>
          <p>Compare remote work visas across 32 countries →</p>
        </a>
        <a href="/best-travel-backpacks" class="related-card">
          <h3>Best Travel Backpacks</h3>
          <p>Find the perfect bag for your next trip →</p>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
/* ── Activities ── */
const ACTIVITIES = [
  { id: 'hiking', label: 'Hiking' },
  { id: 'swimming', label: 'Swimming' },
  { id: 'nightlife', label: 'Nightlife' },
  { id: 'work', label: 'Remote Work' },
  { id: 'photography', label: 'Photography' },
  { id: 'gym', label: 'Gym / Fitness' },
  { id: 'snorkeling', label: 'Snorkeling / Diving' },
  { id: 'skiing', label: 'Skiing / Snowboarding' },
];

const CATEGORY_META = {
  clothing:    { icon: '👕', label: 'Clothing' },
  toiletries:  { icon: '🧴', label: 'Toiletries' },
  electronics: { icon: '🔌', label: 'Electronics' },
  documents:   { icon: '📄', label: 'Documents' },
  medicine:    { icon: '💊', label: 'Medicine' },
  misc:        { icon: '🎒', label: 'Miscellaneous' },
};

/* ── Packing Data ── */
const BASE_ITEMS = {
  clothing: ['Underwear', 'Socks', 'T-shirts', 'Pants / trousers', 'Sleepwear', 'Comfortable walking shoes'],
  toiletries: ['Toothbrush & toothpaste', 'Deodorant', 'Shampoo (travel size)', 'Body wash / soap', 'Razor', 'Sunscreen'],
  electronics: ['Phone & charger', 'Universal power adapter', 'Portable charger / power bank', 'Headphones'],
  documents: ['Passport', 'Travel insurance docs', 'Flight / hotel confirmations', 'Copies of ID (digital + paper)', 'Credit / debit cards'],
  medicine: ['Prescription medications', 'Pain reliever (ibuprofen / paracetamol)', 'Band-aids', 'Anti-diarrhea medication', 'Allergy medication'],
  misc: ['Reusable water bottle', 'Packing cubes', 'Day bag / small backpack', 'Travel lock', 'Pen (for customs forms)'],
};

const DESTINATION_ITEMS = {
  beach: {
    clothing: ['Swimsuit(s)', 'Sarong / cover-up', 'Flip flops / sandals', 'Light shorts', 'Sun hat'],
    toiletries: ['Reef-safe sunscreen', 'Aloe vera gel', 'Waterproof sunscreen SPF50+'],
    misc: ['Beach towel', 'Waterproof phone pouch', 'Sunglasses'],
  },
  city: {
    clothing: ['Smart casual outfit', 'Light jacket', 'Comfortable day shoes', 'Scarf / accessory'],
    misc: ['Umbrella (compact)', 'City guidebook / offline maps', 'Sunglasses'],
  },
  mountain: {
    clothing: ['Moisture-wicking base layer', 'Insulating mid layer (fleece)', 'Waterproof outer shell', 'Hiking boots', 'Hiking socks (merino)', 'Quick-dry pants', 'Warm hat', 'Gloves'],
    misc: ['Headlamp', 'Trekking poles', 'Trail snacks', 'Water purification tablets', 'Sunglasses'],
  },
  business: {
    clothing: ['Business suits / blazers', 'Dress shirts', 'Dress shoes', 'Belt', 'Ties / scarves', 'Wrinkle-resistant trousers'],
    electronics: ['Laptop & charger', 'USB drive', 'Presentation clicker'],
    misc: ['Business cards', 'Portfolio / notepad', 'Garment bag', 'Portable steamer'],
  },
};

const CLIMATE_ITEMS = {
  tropical: {
    clothing: ['Lightweight breathable tops', 'Linen pants / shorts', 'Rain jacket (light)', 'Sandals'],
    toiletries: ['Insect repellent', 'After-bite cream', 'Extra sunscreen'],
  },
  temperate: {
    clothing: ['Light layers', 'Long-sleeve shirt', 'Light jacket / cardigan', 'Jeans or chinos'],
  },
  cold: {
    clothing: ['Thermal base layers', 'Warm sweaters', 'Heavy winter coat', 'Warm boots (waterproof)', 'Thick wool socks', 'Warm gloves', 'Beanie / winter hat', 'Scarf'],
    toiletries: ['Lip balm (SPF)', 'Heavy moisturizer'],
    misc: ['Hand warmers'],
  },
};

const ACTIVITY_ITEMS = {
  hiking: {
    clothing: ['Hiking boots', 'Quick-dry hiking shirt', 'Hiking socks (extra pair)'],
    misc: ['Trekking poles', 'Trail map', 'Compass', 'First aid kit (trail)', 'High-energy snacks'],
  },
  swimming: {
    clothing: ['Swimsuit', 'Swim goggles', 'Rash guard'],
    misc: ['Swim towel (microfiber)', 'Waterproof bag'],
  },
  nightlife: {
    clothing: ['Going-out outfit', 'Dress shoes / heels', 'Clutch / small bag'],
    misc: ['Earplugs'],
  },
  work: {
    electronics: ['Laptop & charger', 'Laptop stand', 'Wireless mouse', 'Portable Wi-Fi hotspot', 'Noise-cancelling headphones'],
    misc: ['Notebook & pen', 'Portable monitor (optional)'],
  },
  photography: {
    electronics: ['Camera & lenses', 'Extra memory cards', 'Camera battery (extra)', 'Tripod (travel-size)'],
    misc: ['Lens cleaning kit', 'Camera bag / padded insert'],
  },
  gym: {
    clothing: ['Workout shorts', 'Workout top', 'Athletic shoes', 'Sports bra (if needed)'],
    misc: ['Gym towel', 'Resistance bands (travel)'],
  },
  snorkeling: {
    clothing: ['Rash guard', 'Water shoes'],
    misc: ['Snorkel & mask', 'Underwater camera / case', 'Reef-safe sunscreen'],
  },
  skiing: {
    clothing: ['Ski jacket', 'Ski pants', 'Thermal base layer (top + bottom)', 'Ski socks', 'Ski gloves', 'Balaclava / neck gaiter'],
    misc: ['Goggles', 'Helmet', 'Hand warmers', 'Ski boot bag'],
  },
};

const DURATION_MULTIPLIERS = {
  weekend: { underwear: 3, socks: 3, tops: 2 },
  '1week': { underwear: 7, socks: 7, tops: 5 },
  '2week': { underwear: 10, socks: 10, tops: 7 },
  '1month': { underwear: 10, socks: 10, tops: 8 },
};

const DURATION_EXTRAS = {
  '2week': { toiletries: ['Full-size toiletries'], misc: ['Laundry bag', 'Travel laundry detergent'] },
  '1month': { toiletries: ['Full-size toiletries'], electronics: ['Portable hard drive / cloud backup'], misc: ['Laundry bag', 'Travel laundry detergent', 'Sewing kit', 'Extra packing cubes'] },
};

/* ── State ── */
let currentList = [];
let checkedItems = new Set();
let selectedActivities = new Set();

/* ── Helpers ── */
function $(id) { return document.getElementById(id); }

function dedupe(arr) {
  const seen = new Set();
  return arr.filter(item => {
    const key = item.toLowerCase();
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

/* ── Render Activities ── */
function renderActivities() {
  const grid = $('activities-grid');
  ACTIVITIES.forEach(a => {
    const tag = document.createElement('button');
    tag.type = 'button';
    tag.className = 'activity-tag';
    tag.textContent = a.label;
    tag.dataset.id = a.id;
    tag.addEventListener('click', () => {
      if (selectedActivities.has(a.id)) {
        selectedActivities.delete(a.id);
        tag.classList.remove('active');
      } else {
        selectedActivities.add(a.id);
        tag.classList.add('active');
      }
    });
    grid.appendChild(tag);
  });
}

/* ── Generate List ── */
function generateList() {
  const dest = $('cfg-destination').value;
  const dur = $('cfg-duration').value;
  const climate = $('cfg-climate').value;

  const items = {};
  Object.keys(CATEGORY_META).forEach(cat => { items[cat] = []; });

  // Base items
  Object.keys(BASE_ITEMS).forEach(cat => { items[cat].push(...BASE_ITEMS[cat]); });

  // Destination items
  const dItems = DESTINATION_ITEMS[dest] || {};
  Object.keys(dItems).forEach(cat => { items[cat].push(...dItems[cat]); });

  // Climate items
  const cItems = CLIMATE_ITEMS[climate] || {};
  Object.keys(cItems).forEach(cat => { items[cat].push(...cItems[cat]); });

  // Activity items
  selectedActivities.forEach(actId => {
    const aItems = ACTIVITY_ITEMS[actId] || {};
    Object.keys(aItems).forEach(cat => { items[cat].push(...aItems[cat]); });
  });

  // Duration extras
  const dExtras = DURATION_EXTRAS[dur] || {};
  Object.keys(dExtras).forEach(cat => { items[cat].push(...dExtras[cat]); });

  // Update quantities for duration
  const mult = DURATION_MULTIPLIERS[dur];
  items.clothing = items.clothing.map(item => {
    const lower = item.toLowerCase();
    if (lower === 'underwear') return `Underwear (${mult.underwear} pairs)`;
    if (lower === 'socks') return `Socks (${mult.socks} pairs)`;
    if (lower.startsWith('t-shirt')) return `T-shirts (${mult.tops})`;
    return item;
  });

  // Dedupe each category
  Object.keys(items).forEach(cat => { items[cat] = dedupe(items[cat]); });

  // Build flat list
  currentList = [];
  checkedItems = new Set();
  Object.keys(items).forEach(cat => {
    items[cat].forEach(item => {
      currentList.push({ id: crypto.randomUUID(), category: cat, label: item, checked: false });
    });
  });

  renderChecklist();
  updateProgress();
  $('progress-section').classList.add('visible');
  $('checklist-container').classList.add('visible');
  $('add-item-row').style.display = 'flex';
  renderSavedLists();
}

/* ── Render Checklist ── */
function renderChecklist() {
  const container = $('checklist-container');
  container.innerHTML = '';

  const groups = {};
  currentList.forEach(item => {
    if (!groups[item.category]) groups[item.category] = [];
    groups[item.category].push(item);
  });

  Object.keys(CATEGORY_META).forEach(cat => {
    const items = groups[cat];
    if (!items || items.length === 0) return;

    const meta = CATEGORY_META[cat];
    const checkedCount = items.filter(i => checkedItems.has(i.id)).length;

    const section = document.createElement('div');
    section.className = 'category-section';
    section.innerHTML = `
      <div class="category-header">
        <div class="left">
          <span class="category-icon">${meta.icon}</span>
          <span class="category-name">${meta.label}</span>
          <span class="category-count">${checkedCount}/${items.length}</span>
        </div>
        <span class="category-toggle">▼</span>
      </div>
      <div class="category-items"></div>
    `;

    const header = section.querySelector('.category-header');
    header.addEventListener('click', () => { section.classList.toggle('collapsed'); });

    const itemsContainer = section.querySelector('.category-items');
    items.forEach(item => {
      const row = document.createElement('div');
      row.className = 'checklist-item' + (checkedItems.has(item.id) ? ' checked' : '');
      row.innerHTML = `
        <input type="checkbox" ${checkedItems.has(item.id) ? 'checked' : ''} />
        <span class="item-label">${item.label}</span>
        <button class="remove-btn" title="Remove item">✕</button>
      `;

      const checkbox = row.querySelector('input');
      const label = row.querySelector('.item-label');

      const toggleCheck = () => {
        if (checkedItems.has(item.id)) {
          checkedItems.delete(item.id);
          checkbox.checked = false;
          row.classList.remove('checked');
        } else {
          checkedItems.add(item.id);
          checkbox.checked = true;
          row.classList.add('checked');
        }
        updateProgress();
        updateCategoryCount(section, cat);
      };

      checkbox.addEventListener('change', toggleCheck);
      label.addEventListener('click', toggleCheck);

      row.querySelector('.remove-btn').addEventListener('click', (e) => {
        e.stopPropagation();
        currentList = currentList.filter(i => i.id !== item.id);
        checkedItems.delete(item.id);
        row.remove();
        updateProgress();
        updateCategoryCount(section, cat);
      });

      itemsContainer.appendChild(row);
    });

    container.appendChild(section);
  });
}

function updateCategoryCount(section, cat) {
  const items = currentList.filter(i => i.category === cat);
  const checkedCount = items.filter(i => checkedItems.has(i.id)).length;
  const countEl = section.querySelector('.category-count');
  if (countEl) countEl.textContent = `${checkedCount}/${items.length}`;
}

/* ── Progress ── */
function updateProgress() {
  const total = currentList.length;
  const checked = checkedItems.size;
  const pct = total === 0 ? 0 : Math.round((checked / total) * 100);
  $('progress-label').textContent = `${checked} of ${total} items packed`;
  $('progress-pct').textContent = pct + '%';
  $('progress-fill').style.width = pct + '%';
  $('progress-pct').style.color = pct === 100 ? '#22c55e' : 'var(--text-primary)';
}

/* ── Save / Load ── */
function saveList() {
  const name = prompt('Name this packing list:');
  if (!name) return;

  const saved = JSON.parse(localStorage.getItem('mm_packing_lists') || '[]');
  saved.push({
    name: name,
    date: new Date().toISOString().split('T')[0],
    config: {
      destination: $('cfg-destination').value,
      duration: $('cfg-duration').value,
      climate: $('cfg-climate').value,
      activities: [...selectedActivities],
    },
    items: currentList,
    checked: [...checkedItems],
  });
  localStorage.setItem('mm_packing_lists', JSON.stringify(saved));
  renderSavedLists();
}

function loadList(index) {
  const saved = JSON.parse(localStorage.getItem('mm_packing_lists') || '[]');
  const list = saved[index];
  if (!list) return;

  $('cfg-destination').value = list.config.destination;
  $('cfg-duration').value = list.config.duration;
  $('cfg-climate').value = list.config.climate;

  selectedActivities = new Set(list.config.activities);
  document.querySelectorAll('.activity-tag').forEach(tag => {
    tag.classList.toggle('active', selectedActivities.has(tag.dataset.id));
  });

  currentList = list.items;
  checkedItems = new Set(list.checked);

  renderChecklist();
  updateProgress();
  $('progress-section').classList.add('visible');
  $('checklist-container').classList.add('visible');
  $('add-item-row').style.display = 'flex';
}

function deleteList(index) {
  const saved = JSON.parse(localStorage.getItem('mm_packing_lists') || '[]');
  saved.splice(index, 1);
  localStorage.setItem('mm_packing_lists', JSON.stringify(saved));
  renderSavedLists();
}

function renderSavedLists() {
  const saved = JSON.parse(localStorage.getItem('mm_packing_lists') || '[]');
  const container = $('saved-lists');
  const body = $('saved-lists-body');

  if (saved.length === 0) {
    container.classList.remove('visible');
    return;
  }

  container.classList.add('visible');
  body.innerHTML = '';
  saved.forEach((list, i) => {
    const row = document.createElement('div');
    row.className = 'saved-list-item';
    row.innerHTML = `
      <div class="saved-list-info">
        <span class="saved-list-name">${list.name}</span>
        <span class="saved-list-meta">${list.config.destination} · ${list.config.duration} · ${list.config.climate} · saved ${list.date}</span>
      </div>
      <div class="saved-list-actions">
        <button class="load-btn">Load</button>
        <button class="delete">Delete</button>
      </div>
    `;
    row.querySelector('.load-btn').addEventListener('click', () => loadList(i));
    row.querySelector('.delete').addEventListener('click', () => deleteList(i));
    body.appendChild(row);
  });
}

/* ── Custom Items ── */
function addCustomItem() {
  const input = $('custom-item-input');
  const catSelect = $('custom-item-category');
  const label = input.value.trim();
  if (!label) return;

  const item = { id: crypto.randomUUID(), category: catSelect.value, label: label, checked: false };
  currentList.push(item);
  input.value = '';

  renderChecklist();
  updateProgress();
}

/* ── Init ── */
renderActivities();
renderSavedLists();

$('btn-generate').addEventListener('click', generateList);
$('btn-save').addEventListener('click', saveList);
$('btn-print').addEventListener('click', () => window.print());
$('btn-uncheck').addEventListener('click', () => {
  checkedItems.clear();
  renderChecklist();
  updateProgress();
});
$('btn-reset').addEventListener('click', () => {
  currentList = [];
  checkedItems.clear();
  $('checklist-container').innerHTML = '';
  $('checklist-container').classList.remove('visible');
  $('progress-section').classList.remove('visible');
  $('add-item-row').style.display = 'none';
  updateProgress();
});
$('btn-add-custom').addEventListener('click', addCustomItem);
$('custom-item-input').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') addCustomItem();
});
  </script>
</SiteLayout>
