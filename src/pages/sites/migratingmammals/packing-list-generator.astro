          <p>Compare living costs between 40 nomad cities →</p>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
const PACKING_DATA = {
  clothing: {
    label: "Clothing",
    base: [
      { name: "Underwear", qty: { weekend: 3, "1week": 7, "2weeks": 10, "1month": 14 } },
      { name: "Socks", qty: { weekend: 3, "1week": 7, "2weeks": 10, "1month": 14 } },
      { name: "Sleepwear", qty: { weekend: 1, "1week": 1, "2weeks": 2, "1month": 2 } }
    ],
