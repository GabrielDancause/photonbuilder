---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Visa-Free Countries Checker — Passport Travel Access 2026",
    "url": "https://migratingmammals.com/visa-free-countries",
    "applicationCategory": "TravelApplication",
    "operatingSystem": "All",
    "description": "Check which countries you can visit visa-free, with visa on arrival, eVisa, or visa required based on your passport. Covers 30 passport nationalities and 50+ destinations with 2026 data.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does visa-free travel mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Visa-free travel means you can enter a country without obtaining a visa in advance. You simply show your valid passport at the border and receive an entry stamp. The allowed stay varies by country, typically ranging from 14 to 90 days. Visa-free access depends on your passport nationality and bilateral agreements between countries."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between visa-free and visa on arrival?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Visa-free means no visa is needed at all — you enter with just your passport. Visa on arrival (VOA) means you obtain a visa at the airport or border upon landing, which may involve a fee, a form, and a short wait. Both are convenient compared to applying for a visa in advance, but VOA may require cash payment in local currency and proof of onward travel."
        }
      },
      {
        "@type": "Question",
        "name": "Which passport has the most visa-free countries in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "As of 2026, Japanese, Singaporean, and several European passports (France, Germany, Italy, Spain) consistently rank at the top, offering visa-free or visa-on-arrival access to 190+ destinations. South Korean and British passports also rank very highly. Rankings can shift as countries update their visa policies throughout the year."
        }
      },
      {
        "@type": "Question",
        "name": "What is an eVisa and how does it work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An eVisa (electronic visa) is a visa you apply for and receive online before traveling. You fill out an application form on the destination country's official portal, upload documents, pay a fee, and receive your visa via email — usually within a few days. You print it or save it on your phone. eVisas are faster and cheaper than traditional embassy visas and are offered by countries like India, Turkey, Australia, Kenya, and many others."
        }
      },
      {
        "@type": "Question",
        "name": "How often do visa policies change?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Visa policies can change at any time due to diplomatic agreements, security concerns, or political shifts. Countries may add or remove visa-free access with little notice. It's important to verify current requirements with the destination country's official immigration website or your country's foreign affairs department before booking travel. This tool is updated regularly but should be used as a starting reference, not a legal guarantee."
        }
      }
    ]
  }
];

export const meta = {
  title: "Visa-Free Countries Checker — Passport Travel Access 2026",
  description: "Check which countries you can visit visa-free, visa on arrival, eVisa, or visa required based on your passport nationality. Covers 30 passports and 50+ destinations.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="migratingmammals"
  title="Visa-Free Countries Checker — Passport Travel Access 2026"
  description="Check which countries you can visit visa-free, visa on arrival, eVisa, or visa required based on your passport nationality. Covers 30 passports and 50+ destinations."
  canonical="https://migratingmammals.com/visa-free-countries"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    header { padding: 4rem 0 2rem; text-align: center; }

    h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2; }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 680px;
      margin: 0 auto 2rem;
    }

    section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }

    /* Config Panel */
    .config-panel {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .config-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .config-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .config-group label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .config-group select {
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.7rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.9rem;
      outline: none;
      cursor: pointer;
    }

    .config-group select:focus { border-color: var(--accent-color); }

    /* Stats bar */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      text-align: center;
      border-top: 3px solid var(--border-color);
    }

    .stat-card.visa-free { border-top-color: #22c55e; }
    .stat-card.visa-arrival { border-top-color: #3b82f6; }
    .stat-card.evisa { border-top-color: #f59e0b; }
    .stat-card.visa-required { border-top-color: #ef4444; }

    .stat-number {
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .stat-card.visa-free .stat-number { color: #22c55e; }
    .stat-card.visa-arrival .stat-number { color: #3b82f6; }
    .stat-card.evisa .stat-number { color: #f59e0b; }
    .stat-card.visa-required .stat-number { color: #ef4444; }

    .stat-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    /* Search/filter bar */
    .filter-bar {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .search-input {
      flex: 1;
      min-width: 200px;
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.7rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.9rem;
      outline: none;
    }

    .search-input:focus { border-color: var(--accent-color); }

    .filter-btn {
      background-color: var(--card-bg);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.6rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      cursor: pointer;
      transition: border-color 0.2s, background-color 0.2s;
      white-space: nowrap;
    }

    .filter-btn:hover { border-color: var(--accent-color); }
    .filter-btn.active { background-color: var(--accent-color); color: #000; border-color: var(--accent-color); font-weight: 700; }

    /* Destination cards grid */
    .destinations-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1rem;
    }

    .dest-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      border-left: 4px solid var(--border-color);
      transition: transform 0.2s, border-color 0.2s;
    }

    .dest-card:hover { transform: translateY(-2px); }

    .dest-card.visa-free { border-left-color: #22c55e; }
    .dest-card.visa-arrival { border-left-color: #3b82f6; }
    .dest-card.evisa { border-left-color: #f59e0b; }
    .dest-card.visa-required { border-left-color: #ef4444; }

    .dest-name {
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 0.35rem;
    }

    .dest-status {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 0.35rem;
    }

    .dest-card.visa-free .dest-status { color: #22c55e; }
    .dest-card.visa-arrival .dest-status { color: #3b82f6; }
    .dest-card.evisa .dest-status { color: #f59e0b; }
    .dest-card.visa-required .dest-status { color: #ef4444; }

    .dest-detail {
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .no-results {
      text-align: center;
      padding: 3rem;
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    /* Prose */
    .prose { max-width: 720px; }
    .prose p { color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.95rem; }
    .prose ul { list-style: disc; padding-left: 1.25rem; margin-bottom: 1rem; }
    .prose ul li { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0.35rem; }

    /* FAQ */
    .faq-item {
      margin-bottom: 1.5rem;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }

    .faq-item h3 { font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .faq-item p { color: var(--text-secondary); }

    /* Related */
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .related-card {
      display: block;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      transition: border-color 0.2s, transform 0.2s;
    }

    .related-card:hover {
      border-color: var(--accent-color);
      transform: translateY(-2px);
      text-decoration: none;
      opacity: 1;
