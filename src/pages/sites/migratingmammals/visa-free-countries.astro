    var name = d[0], region = d[1], defStatus = d[2], defDetail = d[3], overrides = d[4];
    var entry = {};
    /* Start with default for all passports */
    PASSPORTS.forEach(function(p) { entry[p[0]] = [defStatus, defDetail]; });
    /* Apply overrides */
    overrides.forEach(function(ov) {
      var st = ov[0], dt = ov[1];
      for (var i = 2; i < ov.length; i++) {
        entry[ov[i]] = [st, dt];
      }
    });
    db[name] = [region, entry];
  });

  return db;
}

/* DOM helpers */
function $(id) { return document.getElementById(id); }

/* Populate passport dropdown */
PASSPORTS.forEach(function(p) {
  var opt = document.createElement("option");
  opt.value = p[0];
  opt.textContent = p[1];
  $("passport-select").appendChild(opt);
});

var currentFilter = "all";
var currentPassport = "";
var currentSearch = "";

$("passport-select").addEventListener("change", function() {
  currentPassport = this.value;
  if (currentPassport) {
    renderResults();
    $("results-section").style.display = "";
    $("results-section").scrollIntoView({ behavior: "smooth" });
  } else {
    $("results-section").style.display = "none";
  }
});

$("dest-search").addEventListener("input", function() {
  currentSearch = this.value.toLowerCase().trim();
  renderCards();
});

document.querySelectorAll(".filter-btn").forEach(function(btn) {
  btn.addEventListener("click", function() {
    document.querySelectorAll(".filter-btn").forEach(function(b) { b.classList.remove("active"); });
    btn.classList.add("active");
    currentFilter = btn.dataset.filter;
    renderCards();
  });
});

function getStatusClass(code) {
  if (code === "vf") return "visa-free";
  if (code === "voa") return "visa-arrival";
  if (code === "ev") return "evisa";
  return "visa-required";
}

function getStatusLabel(code) {
  if (code === "vf") return "Visa-Free";
  if (code === "voa") return "Visa on Arrival";
  if (code === "ev") return "eVisa";
  return "Visa Required";
}

function renderResults() {
  if (!currentPassport) return;
  var counts = { vf: 0, voa: 0, ev: 0, vr: 0 };
  Object.keys(D).forEach(function(dest) {
    var info = D[dest][1][currentPassport];
    if (info) counts[info[0]]++;
  });

  $("stat-vf").textContent = counts.vf;
  $("stat-voa").textContent = counts.voa;
  $("stat-ev").textContent = counts.ev;
  $("stat-vr").textContent = counts.vr;

  var passportName = "";
  PASSPORTS.forEach(function(p) { if (p[0] === currentPassport) passportName = p[1]; });
  $("results-heading").textContent = passportName + " Passport — Travel Access";

  renderCards();
}

function renderCards() {
  var grid = $("dest-grid");
  grid.innerHTML = "";

  var destinations = [];
  Object.keys(D).forEach(function(dest) {
    var data = D[dest];
    var info = data[1][currentPassport];
    if (!info) return;
    destinations.push({ name: dest, region: data[0], status: info[0], detail: info[1] });
  });

  /* Sort: visa-free first, then voa, ev, vr, then alpha */
  var order = { vf: 0, voa: 1, ev: 2, vr: 3 };
  destinations.sort(function(a, b) {
    if (order[a.status] !== order[b.status]) return order[a.status] - order[b.status];
    return a.name.localeCompare(b.name);
  });

  /* Filter */
  var filtered = destinations.filter(function(d) {
    if (currentFilter !== "all" && getStatusClass(d.status) !== currentFilter) return false;
    if (currentSearch && d.name.toLowerCase().indexOf(currentSearch) === -1 && d.region.toLowerCase().indexOf(currentSearch) === -1) return false;
    return true;
  });

  if (filtered.length === 0) {
    grid.innerHTML = '<div class="no-results">No destinations match your search.</div>';
    return;
  }

  filtered.forEach(function(d) {
    var card = document.createElement("div");
    card.className = "dest-card " + getStatusClass(d.status);
    card.innerHTML = '<div class="dest-name">' + d.name + '</div>' +
      '<div class="dest-status">' + getStatusLabel(d.status) + '</div>' +
      '<div class="dest-detail">' + d.detail + '</div>' +
      '<div class="dest-detail" style="margin-top:0.25rem;opacity:0.7">' + d.region + '</div>';
    grid.appendChild(card);
  });
}
