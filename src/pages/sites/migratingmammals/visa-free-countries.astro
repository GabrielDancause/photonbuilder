      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-bottom: 2rem;
    }

    .disclaimer strong { color: var(--text-primary); }

