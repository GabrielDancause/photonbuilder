          <div class="stat-label">Visa-Free</div>
        </div>
        <div class="stat-card visa-arrival">
          <div class="stat-number" id="stat-voa">0</div>
          <div class="stat-label">Visa on Arrival</div>
        </div>
        <div class="stat-card evisa">
          <div class="stat-number" id="stat-ev">0</div>
          <div class="stat-label">eVisa</div>
        </div>
        <div class="stat-card visa-required">
          <div class="stat-number" id="stat-vr">0</div>
