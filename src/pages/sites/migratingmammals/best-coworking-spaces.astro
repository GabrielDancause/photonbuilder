    let sortCol = 'price';
    let sortAsc = true;

    function renderTable() {
      const sorted = [...SPACES].sort((a, b) => {
        let va = a[sortCol], vb = b[sortCol];
        if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return sortAsc ? va - vb : vb - va;
      });

      const tbody = document.getElementById('coworking-body');
      tbody.innerHTML = '';

      sorted.forEach(s => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td><strong>${s.city}</strong></td>
          <td>${s.space}</td>
          <td class="number">$${s.price}</td>
          <td class="number">${s.speed} Mbps</td>
          <td style="font-size: 0.85rem;">${s.vibe}</td>
        `;
        tbody.appendChild(tr);
      });

      document.querySelectorAll('#coworking-table th').forEach(th => {
        th.classList.remove('sort-asc', 'sort-desc');
        if (th.dataset.sort === sortCol) {
          th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
        }
      });
    }

    renderTable();

    document.querySelectorAll('#coworking-table th').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (!col) return;
        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = true;
        }
        renderTable();
      });
    });
  </script>
