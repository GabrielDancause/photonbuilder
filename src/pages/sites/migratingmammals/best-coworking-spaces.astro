// Initial default sort matches the data representation in JS
SPACES.sort((a, b) => a.price - b.price);

---

<SiteLayout
  site="migratingmammals"
  title="Best Coworking Spaces 2026 | Migrating Mammals"
  description="Compare the top 30 coworking spaces across 15 digital nomad hubs."
  canonical="https://migratingmammals.com/best-coworking-spaces"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color, #ffffff);
      color: var(--text-primary, #333333);
      font-family: var(--font-ui, system-ui, -apple-system, sans-serif);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color, #2563eb); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .header-section {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(180deg, var(--card-bg, #f8fafc) 0%, var(--bg-color, #ffffff) 100%);
      border-bottom: 1px solid var(--border-color, #e2e8f0);
    }
    .header-section h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: var(--text-primary, #1e293b);
    }
    .header-section p {
      font-size: 1.125rem;
      color: var(--text-secondary, #64748b);
      max-width: 600px;
      margin: 0 auto;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    .table-container {
      overflow-x: auto;
      background: var(--card-bg, #ffffff);
      border: 1px solid var(--border-color, #e2e8f0);
      border-radius: 8px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
      margin-bottom: 60px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    th, td {
      padding: 16px;
      border-bottom: 1px solid var(--border-color, #e2e8f0);
    }
    th {
      background-color: var(--card-bg, #f8fafc);
      font-weight: 600;
      color: var(--text-primary, #1e293b);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
      position: relative;
    }
    th:hover { background-color: var(--border-color, #e2e8f0); }
    th.sort-asc::after { content: " ↑"; }
    th.sort-desc::after { content: " ↓"; }

    td {
      color: var(--text-secondary, #475569);
    }
    td.number {
      font-family: var(--font-mono, "JetBrains Mono", monospace);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background-color: rgba(0,0,0,0.02); }

    .status-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .status-yes { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
    .status-no { background: rgba(239, 68, 68, 0.1); color: #ef4444; }

    .faq-section {
      max-width: 800px;
      margin: 0 auto 60px;
    }
    .faq-section h2 {
      font-size: 2rem;
      margin-bottom: 30px;
      text-align: center;
      color: var(--text-primary, #1e293b);
    }
    .faq-item {
      margin-bottom: 24px;
      border: 1px solid var(--border-color, #e2e8f0);
      border-radius: 8px;
      padding: 24px;
      background: var(--card-bg, #ffffff);
    }
    .faq-question {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text-primary, #1e293b);
      margin-bottom: 12px;
    }
    .faq-answer {
      color: var(--text-secondary, #475569);
      line-height: 1.7;
    }

    .related-section {
      background: var(--card-bg, #f8fafc);
      border: 1px solid var(--border-color, #e2e8f0);
      border-radius: 8px;
      padding: 40px;
      text-align: center;
    }
    .related-title {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 24px;
      color: var(--text-primary, #1e293b);
    }
    .related-links {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }
    .related-link {
      display: block;
      padding: 20px;
      background: var(--bg-color, #ffffff);
      border: 1px solid var(--border-color, #e2e8f0);
      border-radius: 6px;
    }
    .related-link h3 {
      font-size: 1.125rem;
      margin-bottom: 8px;
      color: var(--text-primary, #1e293b);
    }
    .related-link p {
      font-size: 0.875rem;
      color: var(--text-secondary, #64748b);
    }
    .related-link:hover {
      border-color: var(--accent-color, #2563eb);
      text-decoration: none;
    }
  </style>

  <div class="header-section">
    <h1>Best Coworking Spaces 2026</h1>
    <p>Compare the top 30 coworking spaces across 15 digital nomad hubs. Sort by price, internet speed, and vibe.</p>
  </div>

  <div class="container">
    <div class="table-container">
      <table id="spaces-table">
        <thead>
          <tr>
            <th data-sort="city">City</th>
            <th data-sort="space">Coworking Space</th>
            <th data-sort="price" class="sort-asc">Price/Mo (USD)</th>
            <th data-sort="speed">Speed (Mbps)</th>
            <th data-sort="amenities">Amenities</th>
            <th data-sort="vibe">Vibe</th>
          </tr>
        </thead>
        <tbody id="spaces-body">
          {SPACES.map((s) => (
            <tr>
              <td><strong>{s.city}</strong></td>
              <td>{s.space}</td>
              <td class="number" data-value={s.price}>${s.price}</td>
              <td class="number" data-value={s.speed}>{s.speed}</td>
              <td style="font-size: 0.85rem;">{s.amenities}</td>
              <td style="font-size: 0.85rem;">{s.vibe}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-question">How much does a coworking space usually cost?</div>
        <div class="faq-answer">The cost of a coworking space varies greatly by city. In affordable hubs like Chiang Mai or Medellin, a hot desk might cost $100-$150 per month. In expensive cities like London or New York, prices can range from $300 to $500+ per month.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">What internet speed do I need for a coworking space?</div>
        <div class="faq-answer">For most digital nomad tasks, including video calls and large file transfers, a reliable connection of at least 50-100 Mbps is recommended. Many top coworking spaces now offer 500+ Mbps or even Gigabit speeds.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">Do coworking spaces offer day passes?</div>
        <div class="faq-answer">Yes, almost all coworking spaces offer day passes, which are great for travelers passing through a city or for testing out a space before committing to a weekly or monthly membership.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">Are coworking spaces open 24/7?</div>
        <div class="faq-answer">Many premium coworking spaces offer 24/7 access to their monthly members, often via a keycard or app. However, day pass users are typically restricted to regular staff hours (e.g., 9 AM to 6 PM).</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">What amenities should I look for in a coworking space?</div>
        <div class="faq-answer">Key amenities include ergonomic chairs, fast and reliable Wi-Fi, private call booths, free coffee/tea, printing facilities, and community events. Some spaces also offer perks like gym access, nap rooms, or swimming pools.</div>
      </div>
    </div>

    <div class="related-section">
      <div class="related-title">Related Resources</div>
      <div class="related-links">
        <a href="/digital-nomad-visa-guide" class="related-link">
          <h3>Digital Nomad Visa Guide</h3>
          <p>Compare visas for 32 countries and find your next destination.</p>
        </a>
        <a href="/cost-of-living-comparison" class="related-link">
          <h3>Cost of Living Comparison</h3>
          <p>Analyze living expenses across popular digital nomad cities.</p>
        </a>
      </div>
    </div>
  </div>

  <script>
    let sortCol = 'price';
    let sortAsc = true;

    document.querySelectorAll('#spaces-table th').forEach((th, idx) => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (!col) return;

        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = true;
        }

        const tbody = document.getElementById('spaces-body');
        const rows = Array.from(tbody.querySelectorAll('tr'));

        rows.sort((a, b) => {
          const cellA = a.children[idx];
          const cellB = b.children[idx];

          let valA = cellA.dataset.value || cellA.textContent.trim();
          let valB = cellB.dataset.value || cellB.textContent.trim();

          if (!isNaN(parseFloat(valA)) && !isNaN(parseFloat(valB))) {
             valA = parseFloat(valA);
             valB = parseFloat(valB);
             return sortAsc ? valA - valB : valB - valA;
          }

          return sortAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
        });

        rows.forEach(row => tbody.appendChild(row));

        document.querySelectorAll('#spaces-table th').forEach(header => {
          header.classList.remove('sort-asc', 'sort-desc');
          if (header.dataset.sort === sortCol) {
            header.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
          }
        });
      });
    });
  </script>
</SiteLayout>
