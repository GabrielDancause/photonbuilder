  { city: "Bali, Indonesia", space: "Dojo Bali (Canggu)", price: 200, speed: 300, amenities: "Pool, Skype Booths, Cafe", vibe: "Community & Surf" },
  { city: "Bali, Indonesia", space: "Outpost (Ubud)", price: 190, speed: 400, amenities: "Jungle Views, Events, Pool", vibe: "Zen & Focused" },
  { city: "Lisbon, Portugal", space: "Second Home Lisboa", price: 280, speed: 1000, amenities: "Plant-filled, Bar, Events", vibe: "Creative & Hip" },
  { city: "Lisbon, Portugal", space: "Hut Lisbon", price: 150, speed: 500, amenities: "Kitchen, 24/7 Access, Lounge", vibe: "Cozy & Quiet" },
  { city: "Barcelona, Spain", space: "Betahaus Barcelona", price: 220, speed: 600, amenities: "Terraces, Cafe, Workshops", vibe: "Startup & Maker" },
  { city: "Barcelona, Spain", space: "OneCoWork Marina", price: 290, speed: 800, amenities: "Waterfront Views, Gym, Bar", vibe: "Premium & Professional" },
  { city: "Medellin, Colombia", space: "Selina CoWork", price: 120, speed: 200, amenities: "Coliving, Bar, Events", vibe: "Backpacker & Social" },
  { city: "Medellin, Colombia", space: "Tinkko", price: 140, speed: 400, amenities: "Ergonomic Chairs, 24/7, Coffee", vibe: "Professional & Quiet" },
  { city: "Chiang Mai, Thailand", space: "Punspace (Nimman)", price: 110, speed: 500, amenities: "Skype Rooms, Courtyard, 24/7", vibe: "Focused & Classic" },
  { city: "Chiang Mai, Thailand", space: "Yellow Coworking", price: 130, speed: 1000, amenities: "Blockchain Focus, Cafe, Events", vibe: "Tech & Crypto" },
