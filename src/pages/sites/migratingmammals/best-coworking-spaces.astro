  { city: "Tbilisi, Georgia", space: "Impact Hub Tbilisi", price: 150, speed: 500, amenities: "Industrial Design, Events, Cafe", vibe: "Community & Creative" },
  { city: "Tbilisi, Georgia", space: "Terminal", price: 170, speed: 600, amenities: "Multiple Locations, 24/7, Modern", vibe: "Professional & Sleek" },
  { city: "Prague, Czechia", space: "Locus Workspace", price: 180, speed: 400, amenities: "International, Quiet, Kitchen", vibe: "Focused & Expat" },
  { city: "Prague, Czechia", space: "Node5", price: 160, speed: 500, amenities: "Startup Focus, Events, Cafe", vibe: "Tech & Hustle" },
  { city: "Ho Chi Minh City, Vietnam", space: "Dreamplex", price: 130, speed: 500, amenities: "Multiple Locations, Events, Cafe", vibe: "Professional & Dynamic" },
  { city: "Ho Chi Minh City, Vietnam", space: "The Hive (D1)", price: 150, speed: 600, amenities: "Rooftop, Central, Community", vibe: "Social & Trendy" },
  { city: "Seoul, South Korea", space: "FastFive", price: 300, speed: 1000, amenities: "Premium, Free Snacks, 24/7", vibe: "Corporate & Fast-paced" },
  { city: "Seoul, South Korea", space: "Heyground", price: 280, speed: 800, amenities: "Social Impact, Cafe, Modern", vibe: "Mission-driven & Calm" }
