---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Coming Soon — Content Roadmap', description: 'See what tools, guides, and research are coming next to Migrating Mammals.', category: 'guides', published: '2026-03-15' };

const SITE_ID = 'migratingmammals';

const allPages = import.meta.glob('./*.astro', { eager: true });
const publishedCount = Object.keys(allPages).filter(k => !k.includes('index') && !k.includes('coming-soon')).length;

const categories = [
  {
    icon: '✈️',
    title: 'Flight Tools',
    description: 'Flight trackers, airline tools, and airport guides',
    total: 5,
    items: [
      { name: 'Taylor Swift Flight Tracker', searches: '—', status: 'published', href: '/migratingmammals/taylor-swift-flight-tracker' },
      { name: 'Airport Codes', searches: '—', status: 'published', href: '/migratingmammals/airport-codes' },
      { name: 'Google Flight Tracker', searches: '—', status: 'published', href: '/migratingmammals/google-flight-tracker' },
      { name: 'How To Use A Flight Tracker', searches: '—', status: 'published', href: '/migratingmammals/how-to-use-a-flight-tracker' },
      { name: 'Flight Time', searches: '—', status: 'published', href: '/migratingmammals/flight-time' }
    ]
  },
  {
    icon: '🛂',
    title: 'Visa & Immigration',
    description: 'Visa requirements, digital nomad visas, and immigration guides',
    total: 17,
    items: [
      { name: 'Nomad Guide Medellin', searches: '—', status: 'published', href: '/migratingmammals/nomad-guide-medellin' },
      { name: 'Nomad Salaries', searches: '—', status: 'published', href: '/migratingmammals/nomad-salaries' },
      { name: 'Nomad Guide Chiang Mai', searches: '—', status: 'published', href: '/migratingmammals/nomad-guide-chiang-mai' },
      { name: 'Nomad Guide Lisbon', searches: '—', status: 'published', href: '/migratingmammals/nomad-guide-lisbon' },
      { name: 'Nomad Tax', searches: '—', status: 'published', href: '/migratingmammals/nomad-tax' },
      { name: 'List Nomad Cities', searches: '—', status: 'published', href: '/migratingmammals/list-nomad-cities' },
      { name: 'Nomad Guide Bangkok', searches: '—', status: 'published', href: '/migratingmammals/nomad-guide-bangkok' },
      { name: 'Guide Digital Nomad Complete', searches: '—', status: 'published', href: '/migratingmammals/guide-digital-nomad-complete' }
    ]
  },
  {
    icon: '💵',
    title: 'Cost of Living',
    description: 'Cost of living comparisons and budget guides for travelers',
    total: 5,
    items: [
      { name: 'Coworking Prices', searches: '—', status: 'published', href: '/migratingmammals/coworking-prices' },
      { name: 'Cost Of Living Index', searches: '—', status: 'published', href: '/migratingmammals/cost-of-living-index' },
      { name: 'Expense Splitter', searches: '—', status: 'published', href: '/migratingmammals/expense-splitter' },
      { name: 'Travel Budget', searches: '—', status: 'published', href: '/migratingmammals/travel-budget' },
      { name: 'Cost Of Living', searches: '—', status: 'published', href: '/migratingmammals/cost-of-living' }
    ]
  },
  {
    icon: '🌍',
    title: 'Travel Guides',
    description: 'Destination guides, itineraries, and travel tips',
    total: 18,
    items: [
      { name: 'Guide Health Records Abroad', searches: '—', status: 'published', href: '/migratingmammals/guide-health-records-abroad' },
      { name: 'Guide Phone Plan Abroad', searches: '—', status: 'published', href: '/migratingmammals/guide-phone-plan-abroad' },
      { name: 'Guide Mail Forwarding', searches: '—', status: 'published', href: '/migratingmammals/guide-mail-forwarding' },
      { name: 'Guide Schengen', searches: '—', status: 'published', href: '/migratingmammals/guide-schengen' },
      { name: 'Guide Shipping Belongings', searches: '—', status: 'published', href: '/migratingmammals/guide-shipping-belongings' },
      { name: 'First Month Abroad Guide', searches: '—', status: 'published', href: '/migratingmammals/first-month-abroad-guide' },
      { name: 'Guide Travel Planning Complete', searches: '—', status: 'published', href: '/migratingmammals/guide-travel-planning-complete' },
      { name: 'Guide Travel Insurance', searches: '—', status: 'published', href: '/migratingmammals/guide-travel-insurance' }
    ]
  },
  {
    icon: '🧳',
    title: 'Travel Tools',
    description: 'General travel utilities and resources',
    total: 31,
    items: [
      { name: 'Travel Insurance Credit Cards', searches: '—', status: 'published', href: '/migratingmammals/travel-insurance-credit-cards' },
      { name: 'Timezone Planner', searches: '—', status: 'published', href: '/migratingmammals/timezone-planner' },
      { name: 'Cruise Ship Tracker', searches: '—', status: 'published', href: '/migratingmammals/cruise-ship-tracker' },
      { name: 'Lounge Access Cards', searches: '—', status: 'published', href: '/migratingmammals/lounge-access-cards' },
      { name: 'Travel Card Comparison Tool', searches: '—', status: 'published', href: '/migratingmammals/travel-card-comparison-tool' },
      { name: 'Schengen Calculator', searches: '—', status: 'published', href: '/migratingmammals/schengen-calculator' },
      { name: 'Packing List', searches: '—', status: 'published', href: '/migratingmammals/packing-list' },
      { name: 'Dialing Codes', searches: '—', status: 'published', href: '/migratingmammals/dialing-codes' }
    ]
  }
];
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID}>
  <style is:inline>
    .coming-soon-hero { text-align: center; padding: 3rem 1rem 2rem; max-width: 800px; margin: 0 auto; }
    .coming-soon-hero h1 { font-size: 2.2rem; margin-bottom: 0.5rem; background: linear-gradient(135deg, var(--accent), #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .coming-soon-hero p { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.6; }
    .stats-bar { display: flex; justify-content: center; gap: 2rem; padding: 1.5rem; margin: 0 auto 2rem; max-width: 700px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; }
    .stat { text-align: center; }
    .stat-number { font-size: 1.8rem; font-weight: 700; color: var(--accent); }
    .stat-label { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem; }
    .category-section { max-width: 900px; margin: 0 auto 2.5rem; padding: 0 1rem; }
    .category-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
    .category-header h2 { font-size: 1.4rem; margin: 0; }
    .category-count { background: var(--card-bg); border: 1px solid var(--border); padding: 0.15rem 0.6rem; border-radius: 20px; font-size: 0.75rem; color: var(--text-secondary); }
    .category-desc { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }
    .items-grid { display: grid; gap: 0.5rem; }
    .item-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; transition: border-color 0.2s; }
    .item-row:hover { border-color: var(--accent); }
    .item-row a { color: var(--text-primary); text-decoration: none; font-weight: 500; }
    .item-row a:hover { color: var(--accent); }
    .item-name { font-weight: 500; }
    .item-right { display: flex; align-items: center; gap: 1rem; }
    .item-searches { font-size: 0.8rem; color: var(--text-secondary); }
    .badge { font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; }
    .badge-published { background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }
    .badge-building { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
    .more-coming { text-align: center; padding: 1rem; color: var(--text-secondary); font-size: 0.9rem; border-top: 1px solid var(--border); margin-top: 0.5rem; }
    @media (max-width: 640px) { .stats-bar { flex-wrap: wrap; gap: 1rem; } .item-searches { display: none; } .coming-soon-hero h1 { font-size: 1.6rem; } }
  </style>

  <div class="coming-soon-hero">
    <h1>📋 Content Roadmap</h1>
    <p>Here's what's published and what's coming next.</p>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-number">{publishedCount}</div>
      <div class="stat-label">Published</div>
    </div>
    <div class="stat">
      <div class="stat-number">0</div>
      <div class="stat-label">In Pipeline</div>
    </div>
    <div class="stat">
      <div class="stat-number">5</div>
      <div class="stat-label">Categories</div>
    </div>
  </div>

  {categories.map(cat => (
    <div class="category-section">
      <div class="category-header">
        <span style="font-size:1.5rem">{cat.icon}</span>
        <h2>{cat.title}</h2>
        <span class="category-count">{cat.total} planned</span>
      </div>
      <p class="category-desc">{cat.description}</p>
      <div class="items-grid">
        {cat.items.map(item => (
          <div class="item-row">
            {item.status === 'published' && item.href ? (
              <a href={item.href}>{item.name}</a>
            ) : (
              <span class="item-name">{item.name}</span>
            )}
            <div class="item-right">
              <span class="item-searches">{item.searches}/mo</span>
              <span class={`badge ${item.status === 'published' ? 'badge-published' : 'badge-building'}`}>
                {item.status === 'published' ? '✓ Live' : '🔨 Building'}
              </span>
            </div>
          </div>
        ))}
      </div>
      {cat.total > 8 && (
        <div class="more-coming">+ {cat.total - 8} more {cat.title.toLowerCase()} coming soon</div>
      )}
    </div>
  ))}
</SiteLayout>
