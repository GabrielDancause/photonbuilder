          <p>Full cost of living index across 40+ nomad destinations →</p>
        </a>
        <a href="/airport-codes" class="related-card">
          <h3>Airport Codes Lookup</h3>
          <p>Search IATA codes for airports worldwide →</p>
        </a>
      </div>
    </section>
  </div>

