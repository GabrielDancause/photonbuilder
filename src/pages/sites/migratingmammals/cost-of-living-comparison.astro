  CITIES.sort(function(a, b) { return a.total - b.total; });

  function fmt(n) { return '$' + Math.round(n).toLocaleString(); }

  var selA = document.getElementById('compare-a');
  var selB = document.getElementById('compare-b');
  var selTarget = document.getElementById('target-city');

  CITIES.forEach(function(c) {
    var opt = document.createElement('option');
    opt.value = c.name;
    opt.textContent = c.name + ' (' + fmt(c.total) + '/mo)';
    selA.appendChild(opt.cloneNode(true));
    selB.appendChild(opt.cloneNode(true));
    selTarget.appendChild(opt.cloneNode(true));
  });

  // Default selections
  selA.value = 'NYC';
  selB.value = 'Chiang Mai';
  selTarget.value = 'Lisbon';

  function updateCard(cardId, city) {
    document.getElementById(cardId + '-title').textContent = city.name;
    document.getElementById(cardId + '-total').textContent = fmt(city.total);

    var html = '';
    var categories = ['rent', 'food', 'transport', 'internet', 'coworking'];
    categories.forEach(function(cat) {
      html += '<div class="col-stat-row"><span class="label">' + cat.charAt(0).toUpperCase() + cat.slice(1) + '</span><span class="val">' + fmt(city[cat]) + '</span></div>';
    });
    document.getElementById(cardId + '-breakdown').innerHTML = html;
  }

  function updateComparison() {
    var cityA = CITIES.find(function(c) { return c.name === selA.value; });
    var cityB = CITIES.find(function(c) { return c.name === selB.value; });

    if (!cityA || !cityB) return;

    updateCard('card-a', cityA);
    updateCard('card-b', cityB);

    var total = cityA.total + cityB.total;
    var pctA = (cityA.total / total) * 100;
    var pctB = (cityB.total / total) * 100;

    document.querySelector('.bar-a').style.width = pctA + '%';
    document.querySelector('.bar-b').style.width = pctB + '%';

    var diff = Math.abs(cityA.total - cityB.total);
    var cheaper = cityA.total < cityB.total ? cityA.name : cityB.name;
    var exp = cityA.total > cityB.total ? cityA.name : cityB.name;

    if (diff === 0) {
      document.getElementById('compare-insight').innerHTML = 'Both cities cost exactly the same.';
    } else {
      document.getElementById('compare-insight').innerHTML = '<strong>' + cheaper + '</strong> is ' + fmt(diff) + '/mo cheaper than <strong>' + exp + '</strong>.';
    }
  }

  selA.addEventListener('change', updateComparison);
  selB.addEventListener('change', updateComparison);
  updateComparison();

  // BUDGET CALCULATOR
  document.getElementById('calc-btn').addEventListener('click', function() {
    var salary = parseFloat(document.getElementById('input-salary').value) || 0;
    var taxRate = parseFloat(document.getElementById('visa-select').value) || 0;
    var targetCityName = document.getElementById('target-city').value;

    var city = CITIES.find(function(c) { return c.name === targetCityName; });
    if (!city) return;

    var netAnnual = salary * (1 - (taxRate / 100));
    var netMonthly = netAnnual / 12;
    var leftover = netMonthly - city.total;

    document.getElementById('budget-net-income').textContent = fmt(netMonthly);
    document.getElementById('budget-expenses').textContent = fmt(city.total);
    var leftEl = document.getElementById('budget-leftover');
    leftEl.textContent = fmt(leftover);
    leftEl.style.color = leftover >= 0 ? '#10b981' : '#ef4444';

    document.getElementById('budget-results').style.display = 'block';
  });

  // RANKINGS
  var rTable = document.getElementById('rankings-table');
  var header = document.createElement('div');
