  { city: "Marrakech", country: "Morocco", region: "Africa", rent: 323, groceries: 140, dining: 65, transport: 15, internet: 18, coworking: 65 },
  { city: "Cairo", country: "Egypt", region: "Africa", rent: 280, groceries: 110, dining: 60, transport: 10, internet: 12, coworking: 50 },
  { city: "Bucharest", country: "Romania", region: "Europe", rent: 570, groceries: 220, dining: 220, transport: 22, internet: 10, coworking: 100 },
  { city: "Sofia", country: "Bulgaria", region: "Europe", rent: 590, groceries: 210, dining: 210, transport: 25, internet: 12, coworking: 95 }
];

// Pre-compute totals
CITIES.forEach(c => { c.total = c.rent + c.groceries + c.dining + c.transport + c.internet + c.coworking; });
CITIES.sort((a, b) => a.total - b.total);

const PIE_COLORS = ['#C4956A','#6AAHC4','#8B6AC4','#C46A8B','#6AC48B','#C4B06A'].map((_,i) => ['#C4956A','#6A9EC4','#8B6AC4','#C46A8B','#6AC48B','#C4B06A'][i]);
const CATEGORIES = ['rent','groceries','dining','transport','internet','coworking'];
const CAT_LABELS = { rent: 'Rent (1BR)', groceries: 'Groceries', dining: 'Dining Out', transport: 'Transport', internet: 'Internet', coworking: 'Coworking' };

function $(id) { return document.getElementById(id); }
function fmt(v) { return '$' + v.toLocaleString('en-US'); }

// Populate selects
function populateSelects() {
  const selects = [$('city-a'), $('city-b'), $('salary-city-a'), $('salary-city-b')];
  selects.forEach((sel, idx) => {
    CITIES.forEach((c, i) => {
      const opt = document.createElement('option');
      opt.value = i;
      opt.textContent = c.city + ', ' + c.country;
      sel.appendChild(opt);
    });
    // Default: Chiang Mai vs NYC (indices after sort)
    const chiangIdx = CITIES.findIndex(c => c.city === 'Chiang Mai');
    const nycIdx = CITIES.findIndex(c => c.city === 'New York');
    if (idx === 0 || idx === 2) sel.value = chiangIdx >= 0 ? chiangIdx : 0;
    if (idx === 1 || idx === 3) sel.value = nycIdx >= 0 ? nycIdx : 1;
  });
}

function renderComparison() {
  const a = CITIES[$('city-a').value];
  const b = CITIES[$('city-b').value];

  // Diff summary
  const diff = ((b.total - a.total) / a.total * 100).toFixed(0);
  const diffAbs = Math.abs(diff);
  const summaryEl = $('diff-summary');
  if (a.city === b.city) {
    summaryEl.innerHTML = '<p>Select two different cities to compare</p>';
  } else {
    const cheaper = b.total < a.total;
    summaryEl.innerHTML = `
      <p>${b.city} is</p>
      <div class="big-number" style="color: ${cheaper ? '#22c55e' : '#ef4444'}">${diffAbs}% ${cheaper ? 'cheaper' : 'more expensive'}</div>
      <p>than ${a.city} overall</p>
    `;
  }

  // Side-by-side cards
  const grid = $('comparison-grid');
  grid.innerHTML = '';
  [a, b].forEach(city => {
    const card = document.createElement('div');
    card.className = 'city-card';
    let rows = '';
    CATEGORIES.forEach(cat => {
      rows += `<div class="cost-row"><span class="cost-label">${CAT_LABELS[cat]}</span><span class="cost-value">${fmt(city[cat])}</span></div>`;
    });
    card.innerHTML = `
      <div class="city-card-header">
        <h3>${city.city}</h3>
        <div class="country">${city.country}</div>
        <div class="total">${fmt(city.total)}<span style="font-size:0.875rem;font-weight:400;color:var(--text-secondary)">/mo</span></div>
      </div>
      ${rows}
    `;
    grid.appendChild(card);
  });

  renderPies(a, b);
}

function renderPies(a, b) {
  const container = $('pie-grid');
  container.innerHTML = '';
  [a, b].forEach(city => {
    const card = document.createElement('div');
    card.className = 'pie-card';

    // Build conic gradient
    let cumulative = 0;
    const stops = [];
    CATEGORIES.forEach((cat, i) => {
      const pct = (city[cat] / city.total) * 100;
      stops.push(`${PIE_COLORS[i]} ${cumulative}% ${cumulative + pct}%`);
      cumulative += pct;
    });

    let legendHTML = '';
    CATEGORIES.forEach((cat, i) => {
      const pct = ((city[cat] / city.total) * 100).toFixed(1);
      legendHTML += `<span class="legend-item"><span class="legend-dot" style="background:${PIE_COLORS[i]}"></span>${CAT_LABELS[cat]} ${pct}%</span>`;
    });

    card.innerHTML = `
      <h3>${city.city}</h3>
      <div class="pie-wrapper" style="background: conic-gradient(${stops.join(', ')})"></div>
      <div class="pie-legend">${legendHTML}</div>
    `;
    container.appendChild(card);
  });
}

// Salary calculator
function calcSalary() {
  const salary = parseFloat($('salary-input').value) || 0;
  const a = CITIES[$('salary-city-a').value];
  const b = CITIES[$('salary-city-b').value];
  const ratio = b.total / a.total;
  const equiv = Math.round(salary * ratio);
  $('salary-result').innerHTML = `
    <div class="result-value">${fmt(equiv)}/yr</div>
    <p>A ${fmt(salary)}/yr salary in ${a.city} equals ${fmt(equiv)}/yr in ${b.city}</p>
  `;
}

// Master table
let sortCol = 'total';
let sortAsc = true;

function renderTable() {
  const sorted = [...CITIES].sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
    return sortAsc ? va - vb : vb - va;
  });

  const tbody = $('table-body');
  tbody.innerHTML = '';
  sorted.forEach(c => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><strong>${c.city}</strong><br><span style="font-size:0.75rem;color:var(--text-secondary)">${c.country}</span></td>
      <td><span class="region-badge">${c.region}</span></td>
      <td class="number" style="color:var(--accent-color)">${fmt(c.total)}</td>
      <td class="number">${fmt(c.rent)}</td>
      <td class="number">${fmt(c.groceries)}</td>
      <td class="number">${fmt(c.dining)}</td>
      <td class="number">${fmt(c.transport)}</td>
      <td class="number">${fmt(c.internet)}</td>
      <td class="number">${fmt(c.coworking)}</td>
    `;
    tbody.appendChild(tr);
  });

  document.querySelectorAll('#master-table th').forEach(th => {
    th.classList.remove('sort-asc','sort-desc');
    if (th.dataset.sort === sortCol) th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
  });
}

// Init
populateSelects();
renderComparison();
calcSalary();
renderTable();

$('city-a').addEventListener('change', renderComparison);
$('city-b').addEventListener('change', renderComparison);
$('salary-input').addEventListener('input', calcSalary);
$('salary-city-a').addEventListener('change', calcSalary);
$('salary-city-b').addEventListener('change', calcSalary);

document.querySelectorAll('#master-table th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.sort;
    if (!col) return;
    if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
    renderTable();
  });
});
  </script>

  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-digital-nomad-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">The Complete Guide to Becoming a Digital Nomad</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
