---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Cost of Living Comparison Tool | Nomad Cities',
  description: 'Interactive cost of living comparison tool for digital nomads. Compare rent, food, transport, and more across 30+ top global cities.',
  category: 'calculator',
  keywords: ['cost of living comparison', 'nomad budget planner', 'digital nomad visa', 'city living costs', 'relocation calculator']
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Migrating Mammals" },
    "publisher": { "@type": "Organization", "name": "Migrating Mammals" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does it cost to live in Chiang Mai?",
        "acceptedAnswer": { "@type": "Answer", "text": "Chiang Mai is extremely affordable for digital nomads. You can live comfortably for around $730 to $1,200 per month, covering rent, food, transport, internet, and a coworking space." }
      },
      {
        "@type": "Question",
        "name": "Is Lisbon still cheap for digital nomads?",
        "acceptedAnswer": { "@type": "Answer", "text": "Lisbon's cost of living has risen significantly in recent years. A typical monthly budget now ranges from $1,900 to $2,500, with rent being the largest expense." }
      },
      {
        "@type": "Question",
        "name": "How do digital nomad visas affect my budget?",
        "acceptedAnswer": { "@type": "Answer", "text": "Digital nomad visas can introduce tax liabilities depending on the country. Some offer 0% tax for the first year, while others may tax you at 15% or more, which reduces your net salary and affects your monthly budget." }
      },
      {
        "@type": "Question",
        "name": "Which city has the cheapest rent?",
        "acceptedAnswer": { "@type": "Answer", "text": "Among popular nomad hubs, Chiang Mai, Bali, and Buenos Aires offer some of the cheapest rent, often falling between $400 and $800 per month for a comfortable apartment." }
      },
      {
        "@type": "Question",
        "name": "How much should I budget for coworking spaces?",
        "acceptedAnswer": { "@type": "Answer", "text": "Coworking space costs vary widely by city. Expect to pay around $80-$150 per month in Southeast Asia and Latin America, but up to $300-$400 in major US or European cities." }
      }
    ]
  }
];
---

<SiteLayout site="migratingmammals" title={meta.title} description={meta.description} schema={JSON.stringify(schema)} canonical="https://migratingmammals.com/cost-of-living-comparison">
  <!-- HERO -->
  <section class="col-hero">
    <div class="col-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>Global Cost of Living <em>Comparison</em></h1>
    <p class="col-hero-hook">You need $4,500/mo in NYC but only <strong>$1,200 in Chiang Mai</strong>. <br/>Compare 30+ nomad hubs side-by-side.</p>
    <div class="col-hero-stats">
      <div class="col-stat">
        <span class="col-stat-num" id="hero-cheapest">Chiang Mai</span>
        <span class="col-stat-label">Most Affordable</span>
      </div>
      <div class="col-stat">
        <span class="col-stat-num" id="hero-expensive">NYC</span>
        <span class="col-stat-label">Most Expensive</span>
      </div>
      <div class="col-stat">
        <span class="col-stat-num">30+</span>
        <span class="col-stat-label">Cities Tracked</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="col-section">
    <h2 class="col-section-title">City Match-up</h2>
    <p class="col-section-sub">Select two cities to compare expenses and see where your money goes further.</p>

    <div class="col-compare-controls">
      <div class="col-input-group">
        <label for="compare-a">City A</label>
        <select id="compare-a"></select>
      </div>
      <div class="col-vs">VS</div>
      <div class="col-input-group">
        <label for="compare-b">City B</label>
        <select id="compare-b"></select>
      </div>
    </div>

    <!-- COMPARISON RESULTS -->
    <div class="col-compare-results" id="compare-results">
      <div class="col-compare-cards">
        <div class="col-compare-card" id="card-a">
          <h3 id="card-a-title">City A</h3>
          <div class="col-total" id="card-a-total">$0</div>
          <div class="col-total-label">Monthly Total</div>
          <div class="col-breakdown" id="card-a-breakdown"></div>
        </div>
        <div class="col-compare-card" id="card-b">
          <h3 id="card-b-title">City B</h3>
          <div class="col-total" id="card-b-total">$0</div>
          <div class="col-total-label">Monthly Total</div>
          <div class="col-breakdown" id="card-b-breakdown"></div>
        </div>
      </div>

      <!-- RACE BAR -->
      <div class="col-compare-race" id="compare-race">
        <div class="col-race-label">Cost Difference</div>
        <div class="col-race-track">
          <div class="col-race-bar bar-a" style="width: 50%;"></div>
          <div class="col-race-bar bar-b" style="width: 50%;"></div>
        </div>
        <div class="col-insight" id="compare-insight"></div>
      </div>
    </div>
  </section>

  <!-- BUDGET PLANNER & SALARY -->
  <section class="col-section">
    <h2 class="col-section-title">Salary & Visa Impact</h2>
    <p class="col-section-sub">Enter your income and visa type to calculate your true purchasing power.</p>

    <div class="col-calc-container">
      <div class="col-calc-inputs">
        <div class="col-input-row">
          <div class="col-input-group">
            <label for="input-salary">Annual Gross Salary</label>
            <div class="col-input-wrap">
              <span class="col-input-prefix">$</span>
              <input type="number" id="input-salary" min="0" max="1000000" step="1000" value="60000" />
            </div>
          </div>
          <div class="col-input-group">
            <label for="visa-select">Visa Type</label>
            <select id="visa-select">
              <option value="0">Tourist / Nomad (0% Tax)</option>
              <option value="15">Digital Nomad Visa (15% Tax)</option>
              <option value="30">Local Resident (30% Tax)</option>
            </select>
          </div>
        </div>
        <div class="col-input-group">
          <label for="target-city">Target City</label>
          <select id="target-city"></select>
        </div>
        <button id="calc-btn" class="col-btn">Calculate Budget</button>
      </div>

      <div class="col-calc-results" id="budget-results" style="display:none;">
        <div class="col-result-header">
          <div class="col-result-title">Monthly Budget</div>
          <div class="col-result-val" id="budget-net-income">$0</div>
          <div class="col-result-sub">Net Income (After Tax)</div>
        </div>

        <div class="col-budget-summary">
          <div class="col-budget-item">
            <div class="col-budget-label">City Expenses</div>
            <div class="col-budget-val" id="budget-expenses">$0</div>
          </div>
          <div class="col-budget-item">
            <div class="col-budget-label">Leftover (Savings)</div>
            <div class="col-budget-val highlight" id="budget-leftover">$0</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RANKINGS TABLE -->
  <section class="col-section">
    <h2 class="col-section-title">All Cities Ranked by Cost</h2>
    <div class="col-rankings" id="rankings-table"></div>
  </section>

  <!-- FAQ -->
  <section class="col-section">
    <h2 class="col-section-title">Frequently Asked Questions</h2>
    <div class="col-faq">
      <details class="col-faq-item">
        <summary>How much does it cost to live in Chiang Mai?</summary>
        <p>Chiang Mai is extremely affordable for digital nomads. You can live comfortably for around $730 to $1,200 per month, covering rent, food, transport, internet, and a coworking space.</p>
      </details>
      <details class="col-faq-item">
        <summary>Is Lisbon still cheap for digital nomads?</summary>
        <p>Lisbon's cost of living has risen significantly in recent years. A typical monthly budget now ranges from $1,900 to $2,500, with rent being the largest expense.</p>
      </details>
      <details class="col-faq-item">
        <summary>How do digital nomad visas affect my budget?</summary>
        <p>Digital nomad visas can introduce tax liabilities depending on the country. Some offer 0% tax for the first year, while others may tax you at 15% or more, which reduces your net salary and affects your monthly budget.</p>
      </details>
      <details class="col-faq-item">
        <summary>Which city has the cheapest rent?</summary>
        <p>Among popular nomad hubs, Chiang Mai, Bali, and Buenos Aires offer some of the cheapest rent, often falling between $400 and $800 per month for a comfortable apartment.</p>
      </details>
      <details class="col-faq-item">
        <summary>How much should I budget for coworking spaces?</summary>
        <p>Coworking space costs vary widely by city. Expect to pay around $80–$150 per month in Southeast Asia and Latin America, but up to $300–$400 in major US or European cities.</p>
      </details>
    </div>
  </section>
</SiteLayout>

<style is:global>
  /* ===== COST OF LIVING COMPARISON ===== */
  :root {
    --accent-color: #C4956A;
  }
  .col-hero {
    text-align: center;
    padding: 2.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(196,149,106,0.12) 0%, rgba(196,149,106,0.02) 60%, rgba(196,149,106,0.08) 100%);
    border-bottom: 1px solid var(--border-color, #152040);
    position: relative;
    overflow: hidden;
  }
  .col-hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    padding: 0.35rem 1rem;
    border: 1px solid var(--accent-color, #C4956A);
    border-radius: 100px;
    color: var(--accent-color, #C4956A);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }
  .col-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    margin: 0 auto 1rem;
    max-width: 700px;
    color: var(--text-primary, #c8d0de);
  }
  .col-hero h1 em {
    color: var(--accent-color, #C4956A);
    font-style: italic;
  }
  .col-hero-hook {
    font-size: 1.15rem;
    color: var(--text-secondary, #94a3b8);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }
  .col-hero-hook strong {
    color: var(--text-primary, #c8d0de);
  }
  .col-hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .col-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .col-stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent-color, #C4956A);
    white-space: nowrap;
  }
  .col-stat-label {
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* SECTIONS */
  .col-section {
    padding: 2.5rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .col-section-title {
    font-size: 1.6rem;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .col-section-sub {
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  /* COMPARISON CONTROLS */
  .col-compare-controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .col-input-group {
    flex: 1;
    min-width: 180px;
    margin-bottom: 1.25rem;
  }
  .col-input-group label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.4rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .col-input-group select,
  .col-input-group input[type="number"] {
    width: 100%;
    padding: 0.65rem 0.75rem;
    background: var(--bg-color, #060a12);
    border: 1px solid var(--border-color, #152040);
    border-radius: 8px;
    color: var(--text-primary, #c8d0de);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .col-input-group select:focus,
  .col-input-group input:focus {
    outline: none;
    border-color: var(--accent-color, #C4956A);
    box-shadow: 0 0 0 3px rgba(196,149,106,0.1);
  }
  .col-vs {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--accent-color, #C4956A);
    text-shadow: 0 0 20px rgba(196,149,106,0.3);
  }

  /* COMPARE CARDS */
  .col-compare-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 600px) {
    .col-compare-cards { grid-template-columns: 1fr; }
  }
  .col-compare-card {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.3s;
  }
  .col-compare-card h3 {
    color: var(--accent-color, #C4956A);
    margin: 0 0 0.75rem;
    font-size: 1.3rem;
    text-align: center;
  }
  .col-total {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text-primary, #c8d0de);
    text-align: center;
  }
  .col-total-label {
    font-size: 0.8rem;
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    margin-bottom: 1rem;
  }
  .col-stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.45rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.9rem;
  }
  .col-stat-row .label { color: var(--text-secondary, #94a3b8); }
  .col-stat-row .val { color: var(--text-primary, #c8d0de); font-weight: 600; }

  /* RACE BAR */
  .col-compare-race {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .col-race-label {
    font-size: 0.78rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .col-race-track {
    height: 36px;
    background: rgba(255,255,255,0.03);
    border-radius: 18px;
    position: relative;
    overflow: hidden;
    margin-bottom: 0.75rem;
    display: flex;
  }
  .col-race-bar {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    transition: width 0.5s ease;
    white-space: nowrap;
  }
  .col-race-bar.bar-a { background: linear-gradient(90deg, #C4956A, #a67c52); }
  .col-race-bar.bar-b { background: linear-gradient(90deg, #4a8fe7, #3a6fd4); }

  .col-insight {
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    margin-top: 1rem;
  }
  .col-insight strong {
    color: var(--text-primary, #c8d0de);
  }

  /* BUDGET PLANNER */
  .col-calc-container {
    display: grid;
    gap: 2rem;
  }
  .col-calc-inputs {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 2rem;
  }
  .col-input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 600px) { .col-input-row { grid-template-columns: 1fr; } }
  .col-input-wrap { position: relative; }
  .col-input-prefix {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary, #94a3b8);
    font-size: 0.95rem;
    pointer-events: none;
  }
  .col-input-wrap input { padding-left: 1.5rem !important; }
  .col-btn {
    width: 100%;
    padding: 0.85rem;
    border: none;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--accent-color, #C4956A), #a67c52);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    margin-top: 0.5rem;
  }
  .col-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(196,149,106,0.35);
  }

  /* BUDGET RESULTS */
  .col-calc-results {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 2rem;
    animation: mill-fadeUp 0.5s ease;
  }
  @keyframes mill-fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .col-result-header {
    text-align: center;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 1.5rem;
  }
  .col-result-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.5rem;
  }
  .col-result-val {
    font-size: 2.4rem;
    color: var(--accent-color, #C4956A);
    font-weight: 700;
  }
  .col-result-sub {
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
  }
  .col-budget-summary {
    display: flex;
    justify-content: space-around;
  }
  .col-budget-item {
    text-align: center;
  }
  .col-budget-label {
    font-size: 0.85rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.5rem;
  }
  .col-budget-val {
    font-size: 1.4rem;
    color: var(--text-primary, #c8d0de);
    font-weight: 700;
  }
  .col-budget-val.highlight {
    color: #10b981;
  }

  /* RANKINGS */
  .col-rankings { overflow-x: auto; }
  .col-rank-row {
    display: grid;
    grid-template-columns: 40px 1fr 80px 80px 80px 80px;
    gap: 0.5rem;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.85rem;
  }
  .col-rank-row:hover { background: rgba(196,149,106,0.05); }
  .col-rank-row.rank-header {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary, #94a3b8);
    border-bottom: 1px solid var(--border-color, #152040);
    font-weight: 600;
  }
  .col-rank-num {
    font-weight: 700;
    color: var(--accent-color, #C4956A);
  }
  .col-rank-name {
    color: var(--text-primary, #c8d0de);
    font-weight: 500;
  }
  .col-rank-val {
    color: var(--text-secondary, #94a3b8);
    text-align: right;
  }
  .col-rank-total {
    color: var(--accent-color, #C4956A);
    font-weight: 700;
    text-align: right;
  }
  @media (max-width: 700px) {
    .col-rank-row { grid-template-columns: 30px 1fr 60px; }
    .col-rank-val.hide-mobile { display: none; }
  }

  /* FAQ */
  .col-faq { max-width: 700px; margin: 0 auto; }
  .col-faq-item {
    border: 1px solid var(--border-color, #152040);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }
  .col-faq-item summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
    font-size: 0.95rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
  }
  .col-faq-item p {
    padding: 0 1.25rem 1.1rem;
    color: var(--text-secondary, #94a3b8);
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
  }
</style>

<script is:inline>
(function() {
  'use strict';

