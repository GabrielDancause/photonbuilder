    row.className = 'col-rank-row';
    row.innerHTML = '<div>' + (i+1) + '</div><div class="col-rank-name">' + c.name + '</div><div class="col-rank-val hide-mobile">' + fmt(c.rent) + '</div><div class="col-rank-val hide-mobile">' + fmt(c.food) + '</div><div class="col-rank-val hide-mobile">' + fmt(c.coworking) + '</div><div class="col-rank-total">' + fmt(c.total) + '/mo</div>';
    rTable.appendChild(row);
  });

})();
</script>