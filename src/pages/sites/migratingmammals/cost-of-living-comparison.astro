      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      background-color: rgba(255,255,255,0.1);
      color: var(--text-primary);
    }

    .empty-cell { color: var(--text-secondary); opacity: 0.5; }

