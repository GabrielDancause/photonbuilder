---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cost of Living Comparison Tool",
    "url": "https://migratingmammals.com/cost-of-living-comparison",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "All",
    "description": "Compare the cost of living between two cities side by side. Rent, groceries, dining, transport, internet, coworking, and total monthly budget for 40 cities worldwide.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you compare cost of living between two cities?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Select two cities from the dropdown menus to see a side-by-side breakdown of rent, groceries, dining out, local transport, internet, and coworking costs. The tool calculates total monthly budgets and shows the percentage difference between the two cities."
        }
      },
      {
        "@type": "Question",
        "name": "What is included in the monthly budget calculation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The monthly budget includes 1-bedroom apartment rent in the city center, estimated monthly groceries, 20 restaurant meals, local public transport pass, home internet, and a coworking space membership. These represent typical expenses for a digital nomad or remote worker."
        }
      },
      {
        "@type": "Question",
        "name": "Which city has the lowest cost of living for digital nomads?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Among popular nomad destinations, Da Nang (Vietnam), Chiang Mai (Thailand), and Cairo (Egypt) consistently rank as the most affordable cities, with total monthly budgets often under $900. However, cost should be balanced against factors like internet speed, safety, and visa accessibility."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate is the cost of living data?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Data is aggregated from crowd-sourced cost of living databases and updated for 2026. All prices are in USD and may fluctuate based on exchange rates, seasonality, and individual lifestyle choices. The figures represent typical mid-range spending for a single remote worker."
        }
      },
      {
        "@type": "Question",
        "name": "What salary do I need to live comfortably in expensive cities like NYC or London?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In cities like New York or London, a comfortable remote worker budget ranges from $4,000 to $5,500 per month. Use the salary equivalent calculator on this page to see what your current salary would need to be in another city to maintain the same standard of living."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use this tool to plan my relocation budget?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The comparison tool shows detailed cost breakdowns across seven spending categories. Combined with the salary equivalent calculator, you can estimate how far your income stretches in different cities and plan your relocation or nomad itinerary accordingly."
        }
      }
    ]
  }
];

export const meta = {
  title: "Cost of Living Comparison Tool — Compare Cities Side by Side",
  description: "Compare the cost of living between two cities. Side-by-side breakdown of rent, groceries, dining, transport, and total monthly budget for 40 popular cities worldwide.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="migratingmammals"
  title="Cost of Living Comparison Tool — Compare Cities Side by Side"
  description="Compare the cost of living between two cities. Side-by-side breakdown of rent, groceries, dining, transport, and total monthly budget for 40 popular cities worldwide."
  canonical="https://migratingmammals.com/cost-of-living-comparison"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    header { padding: 4rem 0 2rem; text-align: center; }

    h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2; }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 640px;
      margin: 0 auto 2rem;
    }

    section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    /* City selector */
    .selector-row {
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .selector-row select {
      background-color: var(--card-bg);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1.25rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 1rem;
      outline: none;
      cursor: pointer;
      min-width: 200px;
    }

    .selector-row select:focus { border-color: var(--accent-color); }

    .vs-label {
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--text-secondary);
    }

    /* Comparison cards */
    .comparison-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    @media (max-width: 700px) {
      .comparison-grid { grid-template-columns: 1fr; }
    }

    .city-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }

    .city-card-header {
      text-align: center;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border-color);
    }

    .city-card-header h3 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    .city-card-header .country {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .city-card-header .total {
      font-size: 2rem;
      font-weight: 800;
      color: var(--accent-color);
      margin-top: 0.5rem;
    }

    .cost-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .cost-row:last-child { border-bottom: none; }

    .cost-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .cost-value {
      font-family: var(--font-code);
      font-size: 0.875rem;
      font-weight: 600;
    }

    .diff-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-size: 0.875rem;
      font-weight: 700;
      text-align: center;
      margin-top: 1rem;
    }

    .diff-cheaper { background-color: rgba(34,197,94,0.15); color: #22c55e; }
    .diff-expensive { background-color: rgba(239,68,68,0.15); color: #ef4444; }

    /* Diff summary */
    .diff-summary {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
      text-align: center;
      margin-bottom: 2rem;
    }

    .diff-summary .big-number {
      font-size: 2.5rem;
      font-weight: 800;
      margin: 0.5rem 0;
    }

    .diff-summary p {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    /* Pie charts */
    .pie-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    @media (max-width: 700px) {
      .pie-grid { grid-template-columns: 1fr; }
    }

    .pie-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
      text-align: center;
    }

    .pie-card h3 { margin-bottom: 1rem; font-size: 1.125rem; }

    .pie-wrapper {
      width: 200px;
      height: 200px;
      margin: 0 auto 1rem;
      border-radius: 50%;
      position: relative;
    }

    .pie-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.75rem;
      color: var(--text-secondary);
    }

    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 2px;
      flex-shrink: 0;
    }

    /* Salary calc */
    .salary-calc {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 2rem;
    }

    .salary-calc .calc-row {
      display: flex;
      gap: 1rem;
      align-items: end;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }

    .calc-field { flex: 1; min-width: 160px; }

    .calc-field label {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      margin-bottom: 0.35rem;
    }

    .calc-field input, .calc-field select {
      width: 100%;
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.65rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 1rem;
      outline: none;
    }

    .calc-field input:focus, .calc-field select:focus { border-color: var(--accent-color); }

    .salary-result {
      text-align: center;
      padding: 1.5rem;
      background-color: rgba(255,255,255,0.03);
      border-radius: 0.5rem;
    }

    .salary-result .result-value {
      font-size: 2rem;
      font-weight: 800;
      color: var(--accent-color);
    }

    .salary-result p {
      color: var(--text-secondary);
      font-size: 0.875rem;
      margin-top: 0.25rem;
    }

