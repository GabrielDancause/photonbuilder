---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best Travel Insurance 2026",
  "url": "https://migratingmammals.com/best-travel-insurance",
  "description": "Compare top travel insurance: World Nomads, SafetyWing, Allianz, AIG Travel Guard, Travelex, Generali, Heymondo. Compare medical coverage, trip cancellation, baggage, adventure sports, pre-existing conditions, digital nomad plans, claim process, and price by trip type.",
  "author": {
    "@type": "Organization",
    "name": "migratingmammals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "migratingmammals.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://migratingmammals.com/logo.png"
    }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need travel insurance for every trip?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. For short, inexpensive domestic trips where you have refundable bookings and primary health insurance covers you, it may not be necessary. It is highly recommended for international travel, expensive non-refundable trips, or trips involving adventure sports."
      }
    },
    {
      "@type": "Question",
      "name": "Does travel insurance cover pre-existing medical conditions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Many policies offer a pre-existing medical condition waiver if you purchase the insurance within a specific timeframe after making your initial trip deposit (usually 14-21 days)."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between primary and secondary medical coverage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Primary coverage pays out first without requiring you to file a claim with your regular health insurance. Secondary coverage pays only after your regular health insurance."
      }
    },
    {
      "@type": "Question",
      "name": "Is Cancel For Any Reason (CFAR) worth it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CFAR provides ultimate flexibility, allowing you to cancel for reasons not covered by standard policies. It typically costs 40-50% more and reimburses 50-75% of your trip cost."
      }
    },
    {
      "@type": "Question",
      "name": "Does credit card travel insurance provide enough coverage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Premium travel credit cards offer good trip cancellation and baggage coverage, but often have low limits for emergency medical coverage and medical evacuation."
      }
    }
  ]
};

const schema = [articleSchema, faqSchema];

export const meta = {
  title: "Best Travel Insurance (2026)",
  description: "Compare top travel insurance: World Nomads, SafetyWing, Allianz, AIG Travel Guard, Travelex, Generali, Heymondo. Compare medical coverage, trip cancellation, baggage, adventure sports, pre-existing conditions, digital nomad plans, claim process, and price by trip type.",
  category: "list",
  published: "2026-05-20"
};

const INSURANCE = [
  { provider: "World Nomads", medical: "Up to $100k", cancellation: "Up to $10k", baggage: "$1k", adventureSports: "Yes (200+ activities)", preExisting: "No", digitalNomad: "No", claimProcess: "Online / App", priceByTripType: "Moderate (Best for Adventure)" },
  { provider: "SafetyWing", medical: "Up to $250k", cancellation: "Up to $5k", baggage: "$500", adventureSports: "Basic only", preExisting: "No", digitalNomad: "Yes (Subscription)", claimProcess: "Online Portal", priceByTripType: "Low (Best for Long-Term/Nomads)" },
  { provider: "Allianz", medical: "Up to $50k", cancellation: "100% of Trip Cost", baggage: "$1k", adventureSports: "Optional Add-on", preExisting: "Yes (Waiver available)", digitalNomad: "No", claimProcess: "TravelSmart App", priceByTripType: "High (Best for Single Expensive Trips)" },
  { provider: "AIG Travel Guard", medical: "Up to $100k", cancellation: "100% of Trip Cost", baggage: "$1k", adventureSports: "Optional Add-on", preExisting: "Yes (Waiver available)", digitalNomad: "No", claimProcess: "Online / Phone", priceByTripType: "High (Best for Families)" },
  { provider: "Travelex", medical: "Up to $50k", cancellation: "100% of Trip Cost", baggage: "$1k", adventureSports: "Optional Add-on", preExisting: "Yes (Waiver available)", digitalNomad: "No", claimProcess: "Travelex App", priceByTripType: "Moderate (Best for Domestic/Families)" },
  { provider: "Generali", medical: "Up to $250k", cancellation: "100% of Trip Cost", baggage: "$2k", adventureSports: "Included in Premium", preExisting: "Yes (Waiver available)", digitalNomad: "No", claimProcess: "eClaims Portal", priceByTripType: "High (Best for Premium Coverage)" },
  { provider: "Heymondo", medical: "Up to $10M", cancellation: "Up to $7k", baggage: "$1.2k", adventureSports: "Yes (Included)", preExisting: "No", digitalNomad: "No", claimProcess: "Heymondo App (24/7 Doc)", priceByTripType: "Moderate (Best Value)" }
];

const initialSortedInsurance = [...INSURANCE].sort((a, b) => a.provider.localeCompare(b.provider));
---

<SiteLayout
  site="migratingmammals"
  title="Best Travel Insurance 2026"
  description="Compare top travel insurance: World Nomads, SafetyWing, Allianz, AIG Travel Guard, Travelex, Generali, Heymondo. Compare medical coverage, trip cancellation, baggage, adventure sports, pre-existing conditions, digital nomad plans, claim process, and price by trip type."
  canonical="https://migratingmammals.com/best-travel-insurance"
  schema={schema}
>
  <style>
    .page-wrapper {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      color: var(--text-primary);
      font-family: var(--font-ui, sans-serif);
      line-height: 1.6;
    }

    .page-wrapper a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    .page-wrapper a:hover { opacity: 0.8; text-decoration: underline; }

    .header-section {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(180deg, var(--card-bg) 0%, var(--bg-color, #ffffff) 100%);
      border-bottom: 1px solid var(--border-color);
    }
    .header-section h1 {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 15px;
      letter-spacing: -0.02em;
    }
    .header-section p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

    .section-title {
      font-size: 2rem;
      font-weight: 700;
      margin: 40px 0 20px;
      color: var(--text-primary);
    }

    .table-container {
      width: 100%;
      overflow-x: auto;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      margin-bottom: 40px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    th, td {
      padding: 16px;
      border-bottom: 1px solid var(--border-color);
    }
    th {
      background: rgba(0,0,0,0.02);
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    th:hover { background: rgba(0,0,0,0.04); }
    th::after {
      content: ' ↕';
      opacity: 0.3;
      font-size: 0.8em;
    }
    th.sort-asc::after { content: ' ↑'; opacity: 1; }
    th.sort-desc::after { content: ' ↓'; opacity: 1; }

    td {
      font-size: 0.95rem;
      color: var(--text-primary);
      vertical-align: middle;
    }
    td.number {
      font-family: var(--font-mono, monospace);
    }
    :global(td strong) { color: var(--text-primary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(0,0,0,0.01); }

    .packing-tips {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 40px;
    }
    .packing-tips h3 {
      font-size: 1.3rem;
      margin-bottom: 15px;
      color: var(--text-primary);
    }
    .packing-tips ul {
      margin-left: 20px;
      color: var(--text-secondary);
    }
    .packing-tips li {
      margin-bottom: 10px;
    }

    .faq-section { margin-top: 60px; }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 15px;
    }
    .faq-question {
      font-weight: 700;
      font-size: 1.1rem;
      margin-bottom: 10px;
      color: var(--text-primary);
    }
    .faq-answer {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }
  </style>

  <div class="page-wrapper">
    <div style="background:rgba(196,149,106,0.1);border:1px solid rgba(196,149,106,0.25);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      🏥 <strong style="color:#C4956A;">A hospital visit abroad averages $25,000 without insurance.</strong> With currency swings making travel budgets unpredictable, proper coverage is non-negotiable. Compare plans with medical, cancellation, and nomad coverage below. <a href="https://gab.ae/news/currency-volatility-oil-crisis-travel-budgets-2026" style="color:#C4956A;">Why travel costs are volatile →</a>
    </div>
    <div class="header-section">
      <h1>Best Travel Insurance 2026</h1>
      <p>Compare the top travel insurance. Sort by medical coverage, trip cancellation, baggage, adventure sports, pre-existing conditions, digital nomad plans, and price by trip type.</p>
    </div>

    <div class="container">
      <div class="packing-tips">
        <h2 class="section-title" style="margin-top: 0;">When You Need It vs. When You Don't</h2>
        <h3>When to Buy Travel Insurance</h3>
        <ul>
          <li><strong>International Travel:</strong> Your primary health insurance (like Medicare or domestic HMOs) rarely covers you overseas. Emergency medical and evacuation coverage is essential.</li>
          <li><strong>Expensive, Non-Refundable Trips:</strong> Cruises, safaris, and high-end tours usually require large upfront payments. Trip cancellation coverage protects your investment if you must cancel due to illness or family emergencies.</li>
          <li><strong>Adventure Sports:</strong> Standard health insurance may exclude injuries from activities like scuba diving, skiing, or trekking. Specific adventure sports coverage (like World Nomads) covers these activities.</li>
          <li><strong>Digital Nomads / Long-Term Travel:</strong> If you are traveling indefinitely, subscription-based plans like SafetyWing offer continuous medical coverage.</li>
        </ul>
        <h3 style="margin-top: 20px;">When You Might Not Need It</h3>
        <ul>
          <li><strong>Short Domestic Trips:</strong> If you are traveling within your home country and have good primary health insurance, you are likely covered for medical emergencies.</li>
          <li><strong>Fully Refundable Bookings:</strong> If you booked refundable flights and hotels, there is no financial risk to insure against trip cancellation.</li>
          <li><strong>Credit Card Coverage is Sufficient:</strong> Many premium travel credit cards offer decent trip delay, baggage loss, and sometimes basic cancellation coverage. Always check the limits first.</li>
        </ul>
      </div>

      <h2 class="section-title">Insurance Comparison</h2>
      <div class="table-container">
        <table id="insurance-table">
          <thead>
            <tr>
              <th data-sort="provider">Provider</th>
              <th data-sort="medical">Medical Coverage</th>
              <th data-sort="cancellation">Trip Cancellation</th>
              <th data-sort="baggage">Baggage</th>
              <th data-sort="adventureSports">Adventure Sports</th>
              <th data-sort="preExisting">Pre-Existing Conditions</th>
              <th data-sort="digitalNomad">Digital Nomad Plan</th>
              <th data-sort="claimProcess">Claim Process</th>
              <th data-sort="priceByTripType">Price by Trip Type</th>
            </tr>
          </thead>
          <tbody id="insurance-body">
            {initialSortedInsurance.map((i) => (
              <tr>
                <td><strong>{i.provider}</strong></td>
                <td>{i.medical}</td>
                <td>{i.cancellation}</td>
                <td class="number">{i.baggage}</td>
                <td>{i.adventureSports}</td>
                <td>{i.preExisting}</td>
                <td>{i.digitalNomad}</td>
                <td>{i.claimProcess}</td>
                <td>{i.priceByTripType}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        {faqSchema.mainEntity.map((faq) => (
          <div class="faq-item">
            <div class="faq-question">{faq.name}</div>
            <div class="faq-answer">{faq.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script>
    const table = document.getElementById('insurance-table');
    const tbody = document.getElementById('insurance-body');
    const ths = table.querySelectorAll('th');

    let tableData = Array.from(tbody.querySelectorAll('tr')).map(tr => {
      const tds = tr.querySelectorAll('td');
      return {
        element: tr,
        provider: tds[0].innerText,
        medical: tds[1].innerText,
        cancellation: tds[2].innerText,
        baggage: tds[3].innerText,
        adventureSports: tds[4].innerText,
        preExisting: tds[5].innerText,
        digitalNomad: tds[6].innerText,
        claimProcess: tds[7].innerText,
        priceByTripType: tds[8].innerText
      };
    });

    let sortCol = 'provider';
    let sortAsc = true;

    function renderSortedTable() {
      const sorted = [...tableData].sort((a, b) => {
        let va = a[sortCol], vb = b[sortCol];

        if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return sortAsc ? va - vb : vb - va;
      });

      tbody.innerHTML = '';
      sorted.forEach(row => {
        tbody.appendChild(row.element);
      });

      ths.forEach(th => {
        th.classList.remove('sort-asc', 'sort-desc');
        if (th.dataset.sort === sortCol) {
          th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
        }
      });
    }

    ths.forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (!col) return;
        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = true;
        }
        renderSortedTable();
      });
    });
  </script>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/guide-travel-insurance" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Digital Nomad Travel Insurance Guide</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">A comprehensive reference guide comparing travel insurance options for digital nomads: SafetyWing, World Nomads, and Gen...</p>
      </a>
    </div>
  </div>
</SiteLayout>
