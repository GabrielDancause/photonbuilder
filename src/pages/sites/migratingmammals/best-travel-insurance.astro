---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Travel Insurance Companies 2026",
    "url": "https://migratingmammals.com/best-travel-insurance",
    "description": "Compare the top travel insurance providers for digital nomads and travelers. Find the perfect plan with our sortable comparison of coverage types, pricing models, and claims processes.",
    "author": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "migratingmammals.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://migratingmammals.com/logo.png"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does travel insurance usually cover?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Travel insurance typically covers medical emergencies, trip cancellations or interruptions, emergency evacuations, and lost or delayed baggage. Some plans also cover adventure sports and gear."
        }
      },
      {
        "@type": "Question",
        "name": "Is travel insurance necessary for digital nomads?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, it is highly recommended. Digital nomads are on the road continuously, increasing the risk of accidents, illnesses, or travel disruptions. A good insurance plan provides financial protection and peace of mind."
        }
      },
      {
        "@type": "Question",
        "name": "Do travel insurance plans cover pre-existing conditions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Many travel insurance plans exclude pre-existing medical conditions by default. However, some providers offer a pre-existing condition waiver if you purchase the policy within a certain timeframe after booking your trip."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between primary and secondary medical coverage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Primary coverage pays out first in the event of a claim, meaning you don't have to file with your regular health insurance. Secondary coverage only pays after you have exhausted your primary health insurance limits."
        }
      },
      {
        "@type": "Question",
        "name": "Can I buy travel insurance after I have already left on my trip?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Some companies, like World Nomads and SafetyWing, allow you to purchase coverage even if you are already traveling. Many traditional providers, however, require you to buy the policy before you depart."
        }
      }
    ]
  }
];

export const meta = {
  title: "Best Travel Insurance Companies (2026)",
  description: "Compare the top travel insurance providers for digital nomads and travelers. Find the perfect plan with our sortable comparison.",
  category: "list",
  published: "2026-05-15",
};

const PROVIDERS = [
  { name: "World Nomads", pricing: "Flat Rate", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "No", adventure: true, digitalnomad: true, rating: 4.2 },
  { name: "SafetyWing", pricing: "Monthly Subscription", medical: "Yes", cancellation: "Limited", evacuation: "Yes", gear: "No", preexisting: "No", adventure: false, digitalnomad: true, rating: 4.0 },
  { name: "Allianz", pricing: "Flat Rate / Annual", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "Waiver", adventure: false, digitalnomad: false, rating: 4.5 },
  { name: "Travel Guard", pricing: "Flat Rate", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "Waiver", adventure: false, digitalnomad: false, rating: 4.1 },
  { name: "Genki", pricing: "Monthly Subscription", medical: "Yes", cancellation: "No", evacuation: "Yes", gear: "No", preexisting: "No", adventure: true, digitalnomad: true, rating: 4.3 },
  { name: "IMG", pricing: "Flat Rate / Annual", medical: "Comprehensive", cancellation: "Yes", evacuation: "Yes", gear: "Limited", preexisting: "Yes", adventure: false, digitalnomad: false, rating: 3.9 },
  { name: "Seven Corners", pricing: "Flat Rate", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "Waiver", adventure: true, digitalnomad: false, rating: 4.0 }
];

// Sort descending by rating initially for server render
PROVIDERS.sort((a, b) => b.rating - a.rating);
---

<SiteLayout
  site="migratingmammals"
  title="Best Travel Insurance Companies"
  description="Compare the top travel insurance providers for digital nomads and travelers. Sort by coverage types, pricing models, and features to find the best fit."
  canonical="https://migratingmammals.com/best-travel-insurance"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .header-section {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(180deg, var(--card-bg) 0%, var(--bg-color) 100%);
      border-bottom: 1px solid var(--border-color);
    }
    .header-section h1 {
      font-size: 2.5rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 15px;
      letter-spacing: -0.02em;
    }
    .header-section p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

    .winners-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-bottom: 60px;
    }
    .winner-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 20px;
      transition: transform 0.2s, border-color 0.2s;
    }
    .winner-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }
    .winner-badge {
      display: inline-block;
      padding: 4px 10px;
      background: rgba(59, 130, 246, 0.1);
      color: var(--accent-color);
      font-size: 0.75rem;
      font-weight: 700;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 12px;
    }
    .winner-name {
      font-size: 1.25rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
    }
    .winner-desc {
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 60px;
    }
    table { width: 100%; border-collapse: collapse; min-width: 1200px; text-align: left; }
    th, td { padding: 16px 20px; border-bottom: 1px solid var(--border-color); }
    th {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      cursor: pointer;
      user-select: none;
    }
    th:hover { color: #fff; }
    th.sort-asc::after { content: " ↑"; }
    th.sort-desc::after { content: " ↓"; }

    tbody tr { transition: background-color 0.2s; }
    tbody tr:hover { background: rgba(255,255,255,0.02); }

    .number { font-family: 'JetBrains Mono', monospace; }

    .faq-section { margin-bottom: 60px; }
    .faq-section h2 { font-size: 1.75rem; margin-bottom: 30px; color: #fff; }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 15px;
    }
    .faq-question { font-weight: 600; color: #fff; margin-bottom: 10px; font-size: 1.1rem; }
    .faq-answer { color: var(--text-secondary); }

    .related-section {
      border-top: 1px solid var(--border-color);
      padding-top: 40px;
      margin-top: 40px;
    }
    .related-title {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      margin-bottom: 20px;
    }
    .related-links {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
    }
    .related-link {
      display: block;
      padding: 20px;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
    }
    .related-link h3 { color: #fff; margin-bottom: 8px; font-size: 1.1rem; }
    .related-link p { color: var(--text-secondary); font-size: 0.9rem; }

    .status-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .status-yes { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
    .status-no { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
  </style>

  <div class="header-section">
    <h1>Best Travel Insurance Companies 2026</h1>
    <p>Compare the top travel insurance providers for digital nomads and travelers. Sort by coverage types, pricing models, and features.</p>
  </div>

  <div class="container">
    <div class="winners-grid">
      <div class="winner-card">
        <div class="winner-badge">Best Overall for Digital Nomads</div>
        <div class="winner-name">SafetyWing</div>
        <div class="winner-desc">Offers a highly flexible, subscription-based model that works seamlessly for long-term travelers and remote workers.</div>
      </div>
      <div class="winner-card">
        <div class="winner-badge">Best for Adventure Travel</div>
        <div class="winner-name">World Nomads</div>
        <div class="winner-desc">Designed by travelers for travelers, offering extensive coverage for hundreds of high-risk adventure sports and activities.</div>
      </div>
      <div class="winner-card">
        <div class="winner-badge">Best for Families</div>
        <div class="winner-name">Allianz</div>
        <div class="winner-desc">Provides robust plans with high coverage limits and kids-included pricing, backed by a global network.</div>
      </div>
      <div class="winner-card">
        <div class="winner-badge">Best for Medical Coverage</div>
        <div class="winner-name">IMG</div>
        <div class="winner-desc">Specializes in comprehensive international medical insurance, ideal for expats and long-term expatriates.</div>
      </div>
      <div class="winner-card">
        <div class="winner-badge">Best Value</div>
        <div class="winner-name">Genki</div>
        <div class="winner-desc">A modern provider offering highly competitive rates and simple, transparent policies tailored for nomads.</div>
      </div>
    </div>

    <div class="table-container">
      <table id="insurance-table">
        <thead>
          <tr>
            <th data-sort="name">Provider</th>
            <th data-sort="pricing">Pricing Model</th>
            <th data-sort="medical">Medical</th>
            <th data-sort="cancellation">Cancellation</th>
            <th data-sort="evacuation">Evacuation</th>
            <th data-sort="gear">Gear</th>
            <th data-sort="preexisting">Pre-existing</th>
            <th data-sort="adventure">Adventure</th>
            <th data-sort="digitalnomad">Nomad Plan</th>
            <th data-sort="rating" class="sort-desc">Claims Rating</th>
          </tr>
        </thead>
        <tbody id="insurance-body">
          {PROVIDERS.map((p) => (
            <tr>
              <td><strong>{p.name}</strong></td>
              <td>{p.pricing}</td>
              <td>{p.medical}</td>
              <td>{p.cancellation}</td>
              <td>{p.evacuation}</td>
              <td>{p.gear}</td>
              <td>{p.preexisting}</td>
              <td>
                {p.adventure ? (
                  <span class="status-badge status-yes">Yes</span>
                ) : (
                  <span class="status-badge status-no">No</span>
                )}
              </td>
              <td>
                {p.digitalnomad ? (
                  <span class="status-badge status-yes">Yes</span>
                ) : (
                  <span class="status-badge status-no">No</span>
                )}
              </td>
              <td class="number">{p.rating.toFixed(1)} / 5.0</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-question">What does travel insurance usually cover?</div>
        <div class="faq-answer">Travel insurance typically covers medical emergencies, trip cancellations or interruptions, emergency evacuations, and lost or delayed baggage. Some plans also cover adventure sports and gear.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">Is travel insurance necessary for digital nomads?</div>
        <div class="faq-answer">Yes, it is highly recommended. Digital nomads are on the road continuously, increasing the risk of accidents, illnesses, or travel disruptions. A good insurance plan provides financial protection and peace of mind.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">Do travel insurance plans cover pre-existing conditions?</div>
        <div class="faq-answer">Many travel insurance plans exclude pre-existing medical conditions by default. However, some providers offer a pre-existing condition waiver if you purchase the policy within a certain timeframe after booking your trip.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">What is the difference between primary and secondary medical coverage?</div>
        <div class="faq-answer">Primary coverage pays out first in the event of a claim, meaning you don't have to file with your regular health insurance. Secondary coverage only pays after you have exhausted your primary health insurance limits.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">Can I buy travel insurance after I have already left on my trip?</div>
        <div class="faq-answer">Some companies, like World Nomads and SafetyWing, allow you to purchase coverage even if you are already traveling. Many traditional providers, however, require you to buy the policy before you depart.</div>
      </div>
    </div>

    <div class="related-section">
      <div class="related-title">Related Resources</div>
      <div class="related-links">
        <a href="/best-travel-backpacks" class="related-link">
          <h3>Best Travel Backpacks</h3>
          <p>Compare the top 12 travel backpacks for digital nomads.</p>
        </a>
        <a href="/digital-nomad-visa-guide" class="related-link">
          <h3>Digital Nomad Visa Guide</h3>
          <p>Compare visas for 32 countries and find your next destination.</p>
        </a>
      </div>
    </div>
  </div>

  <script>
    const PROVIDERS = [
      { name: "World Nomads", pricing: "Flat Rate", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "No", adventure: true, digitalnomad: true, rating: 4.2 },
      { name: "SafetyWing", pricing: "Monthly Subscription", medical: "Yes", cancellation: "Limited", evacuation: "Yes", gear: "No", preexisting: "No", adventure: false, digitalnomad: true, rating: 4.0 },
      { name: "Allianz", pricing: "Flat Rate / Annual", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "Waiver", adventure: false, digitalnomad: false, rating: 4.5 },
      { name: "Travel Guard", pricing: "Flat Rate", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "Waiver", adventure: false, digitalnomad: false, rating: 4.1 },
      { name: "Genki", pricing: "Monthly Subscription", medical: "Yes", cancellation: "No", evacuation: "Yes", gear: "No", preexisting: "No", adventure: true, digitalnomad: true, rating: 4.3 },
      { name: "IMG", pricing: "Flat Rate / Annual", medical: "Comprehensive", cancellation: "Yes", evacuation: "Yes", gear: "Limited", preexisting: "Yes", adventure: false, digitalnomad: false, rating: 3.9 },
      { name: "Seven Corners", pricing: "Flat Rate", medical: "Yes", cancellation: "Yes", evacuation: "Yes", gear: "Yes", preexisting: "Waiver", adventure: true, digitalnomad: false, rating: 4.0 }
    ];

    let sortCol = 'rating';
    let sortAsc = false;

    function renderTable() {
      const sorted = [...PROVIDERS].sort((a, b) => {
        let va = a[sortCol], vb = b[sortCol];
        if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return sortAsc ? va - vb : vb - va;
      });

      const tbody = document.getElementById('insurance-body');
      if (!tbody) return;

      tbody.innerHTML = '';

      sorted.forEach(p => {
        const tr = document.createElement('tr');
        const advHtml = p.adventure
          ? '<span class="status-badge status-yes">Yes</span>'
          : '<span class="status-badge status-no">No</span>';
        const nomadHtml = p.digitalnomad
          ? '<span class="status-badge status-yes">Yes</span>'
          : '<span class="status-badge status-no">No</span>';

        tr.innerHTML = `
          <td><strong>${p.name}</strong></td>
          <td>${p.pricing}</td>
          <td>${p.medical}</td>
          <td>${p.cancellation}</td>
          <td>${p.evacuation}</td>
          <td>${p.gear}</td>
          <td>${p.preexisting}</td>
          <td>${advHtml}</td>
          <td>${nomadHtml}</td>
          <td class="number">${p.rating.toFixed(1)} / 5.0</td>
        `;
        tbody.appendChild(tr);
      });

      document.querySelectorAll('#insurance-table th').forEach(th => {
        th.classList.remove('sort-asc', 'sort-desc');
        if (th.dataset.sort === sortCol) {
          th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
        }
      });
    }

    document.querySelectorAll('#insurance-table th').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (!col) return;
        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = true;
        }
        renderTable();
      });
    });
  </script>
</SiteLayout>