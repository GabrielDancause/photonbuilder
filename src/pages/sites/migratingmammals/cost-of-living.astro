---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Cost of Living Comparator for Digital Nomads",
  "url": "https://migratingmammals.com/cost-of-living",
  "description": "Compare cost of living between 25+ cities worldwide. Pre-loaded data for popular digital nomad destinations including Bangkok, Lisbon, Bali, and more.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "GAB Ventures", "url": "https://gab.ae" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the cheapest city for digital nomads?", "acceptedAnswer": { "@type": "Answer", "text": "Among popular nomad destinations, cities like Chiang Mai ($800-1,200/mo), Ho Chi Minh City ($900-1,300/mo), and Bangkok ($1,200-1,800/mo) offer the lowest cost of living while maintaining excellent infrastructure and internet connectivity." }},
    { "@type": "Question", "name": "How much does it cost to live in Bangkok?", "acceptedAnswer": { "@type": "Answer", "text": "A comfortable digital nomad lifestyle in Bangkok costs $1,200-1,800/month including rent ($500/mo for a one-bedroom), food ($250/mo), transport ($35/mo), coworking ($100/mo), and utilities ($80/mo). This is 65-70% cheaper than New York or London." }},
    { "@type": "Question", "name": "How do you compare cost of living between cities?", "acceptedAnswer": { "@type": "Answer", "text": "Compare four main categories: housing (typically 40-60% of budget), food and groceries, transportation, and utilities/internet. Our tool provides pre-loaded data for 25+ cities or lets you enter custom amounts for a personalized comparison." }},
    { "@type": "Question", "name": "What salary do I need to live like a local in Lisbon?", "acceptedAnswer": { "@type": "Answer", "text": "A comfortable expat lifestyle in Lisbon costs approximately $2,400/month ($1,200 rent, $400 food, $55 transport, $130 utilities). To match a New York lifestyle in Lisbon, you'd need about 45% less income." }},
    { "@type": "Question", "name": "Is Bali cheaper than Bangkok for digital nomads?", "acceptedAnswer": { "@type": "Answer", "text": "Bali and Bangkok are similarly priced for nomads ($1,200-1,800/mo), but Bali has slightly cheaper rent ($400 vs $500) while Bangkok offers better public transport and infrastructure. Bangkok has faster internet and more coworking options." }}
  ]
};

export const meta = {
  title: "Cost of Living Comparator — 25+ Cities | Digital Nomad Tool",
  description: "Compare cost of living between 25+ popular digital nomad cities. Pre-loaded data for Bangkok, Lisbon, Bali, Mexico City, and more. Salary equivalence calculator included.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="migratingmammals"
  title="Cost of Living Comparator — 25+ Cities | Digital Nomad Tool"
  description="Compare cost of living between 25+ popular digital nomad cities. Pre-loaded data for Bangkok, Lisbon, Bali, Mexico City, and more."
  canonical="https://migratingmammals.com/cost-of-living"
  schema={schema}
>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style is:inline>
.col-hero { text-align: center; padding: 48px 24px 24px; }
.col-hero h1 { font-size: 2rem; font-weight: 900; letter-spacing: -0.5px; margin-bottom: 8px; background: linear-gradient(135deg, #fff, var(--accent-color, #C4956A)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.col-hero p { color: var(--text-secondary, #888); font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.col-wrap { max-width: 960px; margin: 0 auto; padding: 20px 16px 48px; }
.col-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
.col-card { background: var(--card-bg, #1a1510); border: 2px solid var(--border-color, #2a2018); border-radius: 16px; overflow: hidden; }
.col-card-hd { padding: 14px 20px; background: rgba(0,0,0,0.2); border-bottom: 1px solid var(--border-color, #2a2018); display: flex; align-items: center; justify-content: space-between; }
.col-card-hd h2 { font-size: 0.95rem; font-weight: 700; color: var(--text-primary, #e0d0c8); }
.col-card-bd { padding: 20px; }
.col-select { width: 100%; background: var(--bg-color, #0d0a08); border: 1px solid var(--border-color, #2a2018); color: var(--text-primary, #e0d0c8); padding: 10px 14px; border-radius: 8px; font-size: 0.9rem; margin-bottom: 16px; font-family: inherit; }
.col-select:focus { border-color: var(--accent-color, #C4956A); outline: none; }
.col-fg { margin-bottom: 14px; }
.col-fg:last-child { margin-bottom: 0; }
.col-fg label { display: block; font-size: 0.82rem; color: var(--text-secondary, #888); margin-bottom: 5px; font-weight: 600; }
.col-iw { position: relative; }
.col-iw::before { content: '$'; position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-secondary, #666); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; }
.col-iw input { width: 100%; background: var(--bg-color, #0d0a08); border: 1px solid var(--border-color, #2a2018); color: var(--text-primary, #fff); padding: 10px 14px 10px 28px; border-radius: 8px; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; outline: none; }
.col-iw input:focus { border-color: var(--accent-color, #C4956A); }
.col-results { background: var(--card-bg, #1a1510); border: 2px solid var(--border-color, #2a2018); border-radius: 16px; padding: 24px; margin-bottom: 24px; }
.col-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 20px; }
.col-stat { background: var(--bg-color, #0d0a08); padding: 16px; border-radius: 12px; border: 1px solid var(--border-color, #2a2018); text-align: center; }
.col-stat .lbl { font-size: 0.78rem; color: var(--text-secondary, #888); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
.col-stat .val { font-family: 'JetBrains Mono', monospace; font-size: 1.6rem; font-weight: 700; }
.col-cheaper { color: #22c55e; }
.col-pricier { color: #ef4444; }
.col-same { color: var(--text-primary, #ccc); }
.col-summary { text-align: center; font-size: 0.95rem; color: var(--text-secondary, #aaa); margin-bottom: 20px; line-height: 1.6; }
.col-summary strong { color: var(--accent-color, #C4956A); }
.col-bars { margin-top: 20px; }
.col-bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; font-size: 0.85rem; }
.col-bar-label { width: 80px; color: var(--text-secondary, #888); text-align: right; flex-shrink: 0; }
.col-bar-track { flex: 1; height: 28px; background: var(--bg-color, #0d0a08); border-radius: 6px; position: relative; overflow: hidden; display: flex; }
.col-bar-fill { height: 100%; border-radius: 6px; display: flex; align-items: center; justify-content: flex-end; padding-right: 8px; font-size: 0.75rem; font-weight: 600; color: #fff; font-family: 'JetBrains Mono', monospace; transition: width 0.4s ease; min-width: 40px; }
.col-bar-c1 { background: var(--accent-color, #C4956A); }
.col-bar-c2 { background: #6b8aad; }
.col-bar-legend { display: flex; gap: 20px; justify-content: center; margin-top: 12px; font-size: 0.8rem; color: var(--text-secondary, #888); }
.col-bar-legend span { display: flex; align-items: center; gap: 6px; }
.col-bar-legend .dot { width: 10px; height: 10px; border-radius: 3px; }
.col-salary { background: var(--card-bg, #1a1510); border: 2px solid var(--border-color, #2a2018); border-radius: 16px; padding: 24px; margin-bottom: 24px; }
.col-salary h3 { font-size: 1rem; font-weight: 700; color: var(--text-primary, #ccc); margin-bottom: 16px; }
.col-salary-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.col-salary-row label { font-size: 0.85rem; color: var(--text-secondary, #888); }
.col-salary-input { background: var(--bg-color, #0d0a08); border: 1px solid var(--border-color, #2a2018); color: var(--text-primary, #fff); padding: 10px 14px; border-radius: 8px; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; width: 140px; }
.col-salary-result { font-size: 1.1rem; font-weight: 700; color: var(--accent-color, #C4956A); font-family: 'JetBrains Mono', monospace; }
.col-actions { display: flex; gap: 12px; justify-content: center; }
.col-btn { background: var(--accent-color, #C4956A); color: #000; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 700; cursor: pointer; font-family: inherit; font-size: 0.9rem; }
.col-btn:hover { opacity: 0.9; }
.col-btn-o { background: transparent; border: 1px solid var(--border-color, #2a2018); color: var(--text-primary, #ccc); }
.col-btn-o:hover { border-color: var(--accent-color, #C4956A); }
.col-content { max-width: 720px; margin: 40px auto 0; padding: 0 20px; }
.col-content h2 { font-size: 1.3rem; font-weight: 800; color: var(--text-primary, #fff); margin: 36px 0 12px; }
.col-content h2:first-child { margin-top: 0; }
.col-content p { font-size: 0.88rem; color: var(--text-secondary, #888); line-height: 1.8; margin-bottom: 12px; }
.col-content ul { padding-left: 20px; margin-bottom: 12px; }
.col-content li { font-size: 0.86rem; color: var(--text-secondary, #888); line-height: 1.8; margin-bottom: 4px; }
.col-content strong { color: var(--text-primary, #ccc); }
@media (max-width: 768px) {
  .col-grid { grid-template-columns: 1fr; }
  .col-stats { grid-template-columns: 1fr; }
  .col-hero h1 { font-size: 1.6rem; }
  .col-stat .val { font-size: 1.3rem; }
  .col-salary-row { flex-direction: column; align-items: flex-start; }
}
</style>

<div class="col-hero">
  <h1>Cost of Living Comparator 🌍</h1>
  <p>Compare monthly costs between 25+ cities. Pre-loaded data for popular digital nomad destinations — or enter your own numbers.</p>
</div>

<div class="col-wrap">
  <div class="col-grid">
    <div class="col-card">
      <div class="col-card-hd"><h2>📍 City 1 (Home Base)</h2></div>
      <div class="col-card-bd">
        <select class="col-select" id="sel1" onchange="loadCity(1)">
          <option value="">— Custom / Enter manually —</option>
        </select>
        <div class="col-fg"><label>City Name</label><input type="text" id="c1-name" value="New York, USA" style="width:100%;background:var(--bg-color,#0d0a08);border:1px solid var(--border-color,#2a2018);color:var(--text-primary,#fff);padding:10px 14px;border-radius:8px;font-family:inherit;font-size:0.9rem;outline:none;"></div>
        <div class="col-fg"><label>Rent (1BR, Monthly)</label><div class="col-iw"><input type="number" id="c1-rent" value="3200" min="0" step="10"></div></div>
        <div class="col-fg"><label>Food & Groceries</label><div class="col-iw"><input type="number" id="c1-food" value="600" min="0" step="10"></div></div>
        <div class="col-fg"><label>Transport</label><div class="col-iw"><input type="number" id="c1-transport" value="132" min="0" step="5"></div></div>
        <div class="col-fg"><label>Utilities + Internet</label><div class="col-iw"><input type="number" id="c1-utils" value="200" min="0" step="10"></div></div>
        <div class="col-fg"><label>Coworking / Office</label><div class="col-iw"><input type="number" id="c1-cowork" value="350" min="0" step="10"></div></div>
        <div class="col-fg"><label>Entertainment</label><div class="col-iw"><input type="number" id="c1-fun" value="300" min="0" step="10"></div></div>
      </div>
    </div>
    <div class="col-card">
      <div class="col-card-hd"><h2>✈️ City 2 (Destination)</h2></div>
      <div class="col-card-bd">
        <select class="col-select" id="sel2" onchange="loadCity(2)">
          <option value="">— Custom / Enter manually —</option>
        </select>
        <div class="col-fg"><label>City Name</label><input type="text" id="c2-name" value="Bangkok, Thailand" style="width:100%;background:var(--bg-color,#0d0a08);border:1px solid var(--border-color,#2a2018);color:var(--text-primary,#fff);padding:10px 14px;border-radius:8px;font-family:inherit;font-size:0.9rem;outline:none;"></div>
        <div class="col-fg"><label>Rent (1BR, Monthly)</label><div class="col-iw"><input type="number" id="c2-rent" value="500" min="0" step="10"></div></div>
        <div class="col-fg"><label>Food & Groceries</label><div class="col-iw"><input type="number" id="c2-food" value="250" min="0" step="10"></div></div>
        <div class="col-fg"><label>Transport</label><div class="col-iw"><input type="number" id="c2-transport" value="35" min="0" step="5"></div></div>
        <div class="col-fg"><label>Utilities + Internet</label><div class="col-iw"><input type="number" id="c2-utils" value="80" min="0" step="10"></div></div>
        <div class="col-fg"><label>Coworking / Office</label><div class="col-iw"><input type="number" id="c2-cowork" value="100" min="0" step="10"></div></div>
        <div class="col-fg"><label>Entertainment</label><div class="col-iw"><input type="number" id="c2-fun" value="150" min="0" step="10"></div></div>
      </div>
    </div>
  </div>

  <!-- RESULTS -->
  <div class="col-results" id="results">
    <div class="col-stats">
      <div class="col-stat"><div class="lbl" id="r-lbl1">New York</div><div class="val" id="r-total1">$4,782</div></div>
      <div class="col-stat"><div class="lbl" id="r-lbl2">Bangkok</div><div class="val" id="r-total2">$1,115</div></div>
      <div class="col-stat"><div class="lbl">Difference</div><div class="val col-cheaper" id="r-diff">-77%</div></div>
    </div>
    <div class="col-summary" id="r-summary">Living in <strong>Bangkok</strong> is <strong>77% cheaper</strong> than <strong>New York</strong>. You'd save approximately <strong>$3,667/month</strong>.</div>

    <div class="col-bars" id="bars-container">
      <div class="col-bar-legend">
        <span><span class="dot" style="background:var(--accent-color,#C4956A);"></span> <span id="bar-leg1">New York</span></span>
        <span><span class="dot" style="background:#6b8aad;"></span> <span id="bar-leg2">Bangkok</span></span>
      </div>
    </div>

    <div style="margin-top: 20px;">
      <div class="col-actions">
        <button class="col-btn col-btn-o" onclick="copyResults()">📋 Copy Results</button>
        <button class="col-btn col-btn-o" onclick="swapCities()">🔄 Swap Cities</button>
      </div>
    </div>
  </div>

  <!-- SALARY EQUIVALENCE -->
  <div class="col-salary">
    <h3>💰 Salary Equivalence Calculator</h3>
    <p style="font-size:0.85rem;color:var(--text-secondary,#888);margin-bottom:16px;">If you earn this much in City 1, how much would you need in City 2 for the same lifestyle?</p>
    <div class="col-salary-row">
      <label>Monthly salary in <span id="sal-city1">New York</span>:</label>
      <input type="number" class="col-salary-input" id="sal-input" value="6000" min="0" step="100" oninput="calcSalary()">
      <span style="color:var(--text-secondary,#888);">→</span>
      <label>Equivalent in <span id="sal-city2">Bangkok</span>:</label>
      <span class="col-salary-result" id="sal-result">$1,400</span>
    </div>
    <p style="font-size:0.78rem;color:var(--text-secondary,#666);margin-top:12px;">Based on the cost-of-living ratio between the two cities. Savings rate would also improve proportionally.</p>
  </div>
</div>

<div class="col-content">
  <h2>How We Calculate Cost of Living</h2>
  <p>Our comparator uses six spending categories that cover the typical monthly budget for a digital nomad or expat: <strong>rent</strong> (1-bedroom apartment in a central location), <strong>food and groceries</strong> (mix of cooking and eating out), <strong>transport</strong> (monthly pass or typical rideshare costs), <strong>utilities and internet</strong>, <strong>coworking or office space</strong>, and <strong>entertainment</strong> (social activities, gym, etc.).</p>
  <p>The pre-loaded data comes from Numbeo, Expatistan, and first-hand reports from digital nomad communities as of early 2026. Prices are in USD and represent a comfortable (not luxury) lifestyle. You can override any value with your own data for a personalized comparison.</p>

  <h2>Bangkok: The World's Most Visited City in 2026</h2>
  <p>Bangkok claimed the title of the world's most visited city in 2025 with over 32 million international visitors. The Thai capital offers a unique combination of ultra-low living costs, world-class street food, excellent internet infrastructure, and a thriving digital nomad community. A comfortable nomad lifestyle here costs <strong>$1,100-1,800/month</strong> — roughly 65-70% less than New York or London.</p>

  <h2>Top 5 Cheapest Digital Nomad Cities</h2>
  <ul>
    <li><strong>Chiang Mai, Thailand:</strong> $800-1,200/month — quieter alternative to Bangkok with mountain scenery</li>
    <li><strong>Ho Chi Minh City, Vietnam:</strong> $900-1,300/month — fast-growing tech scene, incredible food</li>
    <li><strong>Bangkok, Thailand:</strong> $1,200-1,800/month — best infrastructure-to-cost ratio in Southeast Asia</li>
    <li><strong>Bali, Indonesia:</strong> $1,200-1,800/month — beach lifestyle, strong nomad community</li>
    <li><strong>Mexico City, Mexico:</strong> $1,400-2,000/month — North American time zone, rich culture</li>
  </ul>

  <h2>Factors Beyond Monthly Costs</h2>
  <p>Cost of living is just one piece of the puzzle. Consider <strong>visa requirements</strong> (check our <a href="/visa-checker" style="color:var(--accent-color,#C4956A);">visa checker</a>), <strong>time zone overlap</strong> with clients or team, <strong>internet speed</strong> (critical for video calls), <strong>air quality</strong> (seasonal issue in some Asian cities), and <strong>healthcare access</strong>. Our <a href="/cost-of-living-index" style="color:var(--accent-color,#C4956A);">cost of living index</a> ranks 40+ cities on all these factors.</p>
</div>

<script is:inline>
var CITIES = {
  'new-york': { name: 'New York, USA', rent: 3200, food: 600, transport: 132, utils: 200, cowork: 350, fun: 300 },
  'san-francisco': { name: 'San Francisco, USA', rent: 3000, food: 550, transport: 98, utils: 180, cowork: 400, fun: 280 },
  'los-angeles': { name: 'Los Angeles, USA', rent: 2400, food: 500, transport: 110, utils: 170, cowork: 300, fun: 250 },
  'london': { name: 'London, UK', rent: 2600, food: 500, transport: 190, utils: 200, cowork: 350, fun: 280 },
  'paris': { name: 'Paris, France', rent: 1800, food: 450, transport: 90, utils: 160, cowork: 280, fun: 220 },
  'berlin': { name: 'Berlin, Germany', rent: 1200, food: 350, transport: 100, utils: 140, cowork: 200, fun: 180 },
  'amsterdam': { name: 'Amsterdam, Netherlands', rent: 1900, food: 400, transport: 110, utils: 170, cowork: 250, fun: 200 },
  'toronto': { name: 'Toronto, Canada', rent: 2200, food: 450, transport: 130, utils: 160, cowork: 300, fun: 220 },
  'sydney': { name: 'Sydney, Australia', rent: 2400, food: 500, transport: 140, utils: 180, cowork: 320, fun: 260 },
  'tokyo': { name: 'Tokyo, Japan', rent: 1400, food: 400, transport: 80, utils: 130, cowork: 200, fun: 180 },
  'seoul': { name: 'Seoul, South Korea', rent: 1100, food: 350, transport: 55, utils: 120, cowork: 180, fun: 150 },
  'dubai': { name: 'Dubai, UAE', rent: 2000, food: 500, transport: 150, utils: 160, cowork: 350, fun: 300 },
  'bangkok': { name: 'Bangkok, Thailand', rent: 500, food: 250, transport: 35, utils: 80, cowork: 100, fun: 150 },
  'chiang-mai': { name: 'Chiang Mai, Thailand', rent: 350, food: 200, transport: 25, utils: 60, cowork: 80, fun: 100 },
  'bali': { name: 'Bali, Indonesia', rent: 400, food: 220, transport: 40, utils: 70, cowork: 120, fun: 130 },
  'ho-chi-minh': { name: 'Ho Chi Minh City, Vietnam', rent: 400, food: 200, transport: 30, utils: 60, cowork: 80, fun: 100 },
  'kuala-lumpur': { name: 'Kuala Lumpur, Malaysia', rent: 500, food: 250, transport: 40, utils: 70, cowork: 100, fun: 120 },
  'lisbon': { name: 'Lisbon, Portugal', rent: 1200, food: 400, transport: 55, utils: 130, cowork: 180, fun: 170 },
  'barcelona': { name: 'Barcelona, Spain', rent: 1100, food: 380, transport: 60, utils: 130, cowork: 180, fun: 180 },
  'mexico-city': { name: 'Mexico City, Mexico', rent: 700, food: 300, transport: 25, utils: 80, cowork: 120, fun: 150 },
  'medellin': { name: 'Medellín, Colombia', rent: 500, food: 250, transport: 30, utils: 70, cowork: 100, fun: 120 },
  'buenos-aires': { name: 'Buenos Aires, Argentina', rent: 450, food: 250, transport: 20, utils: 60, cowork: 80, fun: 100 },
  'tbilisi': { name: 'Tbilisi, Georgia', rent: 400, food: 200, transport: 20, utils: 50, cowork: 70, fun: 80 },
  'budapest': { name: 'Budapest, Hungary', rent: 800, food: 300, transport: 40, utils: 110, cowork: 150, fun: 140 },
  'cape-town': { name: 'Cape Town, South Africa', rent: 600, food: 280, transport: 45, utils: 80, cowork: 120, fun: 130 }
};

// Populate dropdowns
function populateSelects() {
  var keys = Object.keys(CITIES).sort(function(a,b) { return CITIES[a].name.localeCompare(CITIES[b].name); });
  ['sel1','sel2'].forEach(function(id) {
    var sel = document.getElementById(id);
    keys.forEach(function(k) {
      var opt = document.createElement('option');
      opt.value = k;
      opt.textContent = CITIES[k].name;
      sel.appendChild(opt);
    });
  });
  document.getElementById('sel1').value = 'new-york';
  document.getElementById('sel2').value = 'bangkok';
}

function loadCity(n) {
  var sel = document.getElementById('sel' + n);
  var key = sel.value;
  if (!key || !CITIES[key]) return;
  var c = CITIES[key];
  var p = 'c' + n + '-';
  document.getElementById(p + 'name').value = c.name;
  document.getElementById(p + 'rent').value = c.rent;
  document.getElementById(p + 'food').value = c.food;
  document.getElementById(p + 'transport').value = c.transport;
  document.getElementById(p + 'utils').value = c.utils;
  document.getElementById(p + 'cowork').value = c.cowork;
  document.getElementById(p + 'fun').value = c.fun;
  calculate();
}

function gv(id) { var v = parseFloat(document.getElementById(id).value); return isNaN(v) ? 0 : v; }
function fmt(n) { return '$' + n.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}); }

function getCityData(n) {
  var p = 'c' + n + '-';
  return {
    name: document.getElementById(p + 'name').value || ('City ' + n),
    rent: gv(p + 'rent'), food: gv(p + 'food'), transport: gv(p + 'transport'),
    utils: gv(p + 'utils'), cowork: gv(p + 'cowork'), fun: gv(p + 'fun')
  };
}

function totalOf(c) { return c.rent + c.food + c.transport + c.utils + c.cowork + c.fun; }

function calculate() {
  var c1 = getCityData(1), c2 = getCityData(2);
  var t1 = totalOf(c1), t2 = totalOf(c2);

  document.getElementById('r-lbl1').textContent = c1.name.split(',')[0];
  document.getElementById('r-lbl2').textContent = c2.name.split(',')[0];
  document.getElementById('r-total1').textContent = fmt(t1);
  document.getElementById('r-total2').textContent = fmt(t2);

  var diff = t1 > 0 ? ((t2 - t1) / t1 * 100) : 0;
  var absDiff = Math.abs(diff).toFixed(0);
  var diffEl = document.getElementById('r-diff');
  var savingsAmt = Math.abs(t2 - t1);

  if (diff < -1) {
    diffEl.textContent = '-' + absDiff + '%';
    diffEl.className = 'val col-cheaper';
    document.getElementById('r-summary').innerHTML = 'Living in <strong>' + c2.name.split(',')[0] + '</strong> is <strong>' + absDiff + '% cheaper</strong> than <strong>' + c1.name.split(',')[0] + '</strong>. You\'d save approximately <strong>' + fmt(savingsAmt) + '/month</strong>.';
  } else if (diff > 1) {
    diffEl.textContent = '+' + absDiff + '%';
    diffEl.className = 'val col-pricier';
    document.getElementById('r-summary').innerHTML = 'Living in <strong>' + c2.name.split(',')[0] + '</strong> is <strong>' + absDiff + '% more expensive</strong> than <strong>' + c1.name.split(',')[0] + '</strong>. You\'d spend an extra <strong>' + fmt(savingsAmt) + '/month</strong>.';
  } else {
    diffEl.textContent = '0%';
    diffEl.className = 'val col-same';
    document.getElementById('r-summary').innerHTML = 'The cost of living is roughly the <strong>same</strong> in both cities.';
  }

  // Update legends
  document.getElementById('bar-leg1').textContent = c1.name.split(',')[0];
  document.getElementById('bar-leg2').textContent = c2.name.split(',')[0];

  // Draw bars
  var cats = [
    { label: 'Rent', v1: c1.rent, v2: c2.rent },
    { label: 'Food', v1: c1.food, v2: c2.food },
    { label: 'Transport', v1: c1.transport, v2: c2.transport },
    { label: 'Utilities', v1: c1.utils, v2: c2.utils },
    { label: 'Coworking', v1: c1.cowork, v2: c2.cowork },
    { label: 'Fun', v1: c1.fun, v2: c2.fun }
  ];

  var maxVal = 0;
  cats.forEach(function(c) { maxVal = Math.max(maxVal, c.v1, c.v2); });
  if (maxVal === 0) maxVal = 1;

  var barsHtml = '';
  cats.forEach(function(cat) {
    var w1 = Math.max(8, (cat.v1 / maxVal) * 100);
    var w2 = Math.max(8, (cat.v2 / maxVal) * 100);
    barsHtml += '<div class="col-bar-row">' +
      '<div class="col-bar-label">' + cat.label + '</div>' +
      '<div style="flex:1;">' +
        '<div class="col-bar-track" style="margin-bottom:3px;"><div class="col-bar-fill col-bar-c1" style="width:' + w1 + '%;">' + fmt(cat.v1) + '</div></div>' +
        '<div class="col-bar-track"><div class="col-bar-fill col-bar-c2" style="width:' + w2 + '%;">' + fmt(cat.v2) + '</div></div>' +
      '</div></div>';
  });

  var container = document.getElementById('bars-container');
  var legend = container.querySelector('.col-bar-legend');
  container.innerHTML = barsHtml;
  container.appendChild(legend);

  // Salary
  document.getElementById('sal-city1').textContent = c1.name.split(',')[0];
  document.getElementById('sal-city2').textContent = c2.name.split(',')[0];
  calcSalary();
}

function calcSalary() {
  var c1 = getCityData(1), c2 = getCityData(2);
  var t1 = totalOf(c1), t2 = totalOf(c2);
  var salary = gv('sal-input');
  var ratio = t1 > 0 ? t2 / t1 : 1;
  var equiv = Math.round(salary * ratio);
  document.getElementById('sal-result').textContent = fmt(equiv);
}

function swapCities() {
  var c1 = getCityData(1), c2 = getCityData(2);
  var sel1v = document.getElementById('sel1').value;
  var sel2v = document.getElementById('sel2').value;
  // Set city 1 to city 2's data
  document.getElementById('c1-name').value = c2.name;
  document.getElementById('c1-rent').value = c2.rent;
  document.getElementById('c1-food').value = c2.food;
  document.getElementById('c1-transport').value = c2.transport;
  document.getElementById('c1-utils').value = c2.utils;
  document.getElementById('c1-cowork').value = c2.cowork;
  document.getElementById('c1-fun').value = c2.fun;
  // Set city 2 to city 1's data
  document.getElementById('c2-name').value = c1.name;
  document.getElementById('c2-rent').value = c1.rent;
  document.getElementById('c2-food').value = c1.food;
  document.getElementById('c2-transport').value = c1.transport;
  document.getElementById('c2-utils').value = c1.utils;
  document.getElementById('c2-cowork').value = c1.cowork;
  document.getElementById('c2-fun').value = c1.fun;
  document.getElementById('sel1').value = sel2v;
  document.getElementById('sel2').value = sel1v;
  calculate();
}

function copyResults() {
  var c1 = getCityData(1), c2 = getCityData(2);
  var t1 = totalOf(c1), t2 = totalOf(c2);
  var diff = t1 > 0 ? ((t2 - t1) / t1 * 100).toFixed(1) : 0;
  var text = 'Cost of Living: ' + c1.name + ' vs ' + c2.name + '\n' +
    c1.name + ': ' + fmt(t1) + '/mo\n' +
    c2.name + ': ' + fmt(t2) + '/mo\n' +
    'Difference: ' + (diff > 0 ? '+' : '') + diff + '%\n\n' +
    'Rent: ' + fmt(c1.rent) + ' vs ' + fmt(c2.rent) + '\n' +
    'Food: ' + fmt(c1.food) + ' vs ' + fmt(c2.food) + '\n' +
    'Transport: ' + fmt(c1.transport) + ' vs ' + fmt(c2.transport) + '\n' +
    'Utilities: ' + fmt(c1.utils) + ' vs ' + fmt(c2.utils) + '\n' +
    'Coworking: ' + fmt(c1.cowork) + ' vs ' + fmt(c2.cowork) + '\n' +
    'Fun: ' + fmt(c1.fun) + ' vs ' + fmt(c2.fun) + '\n\n' +
    'migratingmammals.com/cost-of-living';
  navigator.clipboard.writeText(text);
}

// Attach listeners
['c1-rent','c1-food','c1-transport','c1-utils','c1-cowork','c1-fun',
 'c2-rent','c2-food','c2-transport','c2-utils','c2-cowork','c2-fun',
 'c1-name','c2-name'].forEach(function(id) {
  document.getElementById(id).addEventListener('input', calculate);
});

populateSelects();
calculate();
</script>

