  { country: "Croatia", why: "Best in the EU for tax: fully tax-free on foreign income, low visa cost, beautiful coastline, and Schengen zone access. Split and Zagreb have growing coworking scenes." },
  { country: "UAE", why: "Best for high earners: zero income tax, world-class infrastructure, 200 Mbps average internet, and Dubai's global connectivity makes it ideal for nomads serving clients worldwide." }
];

// Pre-sort by duration descending
VISAS.sort((a, b) => b.duration - a.duration);

let sortCol = 'duration';
let sortAsc = false;

function $(id) { return document.getElementById(id); }
function fmt(v) { return '$' + v.toLocaleString('en-US'); }

// Render top picks
function renderPicks() {
  const grid = $('picks-grid');
  TOP_PICKS.forEach((pick, i) => {
    const visa = VISAS.find(v => v.country === pick.country);
    if (!visa) return;
    const card = document.createElement('div');
    card.className = 'pick-card';
    card.innerHTML = `
      <div class="pick-rank">#${i + 1} Pick</div>
      <h3>${visa.country}</h3>
      <div class="visa-name">${visa.visaName}</div>
      <div class="pick-stats">
        <div class="pick-stat"><div class="label">Duration</div><div class="value">${visa.duration} months</div></div>
        <div class="pick-stat"><div class="label">Income Req.</div><div class="value">${visa.incomeReq === 0 ? 'None' : fmt(visa.incomeReq) + '/mo'}</div></div>
        <div class="pick-stat"><div class="label">Visa Cost</div><div class="value">${visa.cost === 0 ? 'Free' : fmt(visa.cost)}</div></div>
        <div class="pick-stat"><div class="label">Tax Status</div><div class="value ${visa.taxStatus === 'free' ? 'tax-free' : visa.taxStatus === 'partial' ? 'tax-partial' : 'tax-yes'}">${visa.taxStatus === 'free' ? 'Tax-Free' : visa.taxStatus === 'partial' ? 'Partial' : 'Taxed'}</div></div>
      </div>
      <div class="pick-why">${pick.why}</div>
    `;
    grid.appendChild(card);
  });
}

// Get filtered visas
function getFiltered() {
  const region = $('filter-region').value;
  const maxIncome = parseInt($('filter-income').value);
  const taxFilter = $('filter-tax').value;
  const minDuration = parseInt($('filter-duration').value);

  return VISAS.filter(v => {
    if (region !== 'all' && v.region !== region) return false;
    if (v.incomeReq > maxIncome) return false;
    if (taxFilter === 'free' && v.taxStatus !== 'free') return false;
    if (v.duration < minDuration) return false;
    return true;
  });
}

// Render table
function renderTable() {
  const filtered = getFiltered();

  // Sort
  const sorted = [...filtered].sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
    return sortAsc ? va - vb : vb - va;
  });

  $('result-count').textContent = `Showing ${sorted.length} of ${VISAS.length} countries`;

  const tbody = $('visa-body');
  tbody.innerHTML = '';
  sorted.forEach(v => {
    const tr = document.createElement('tr');
    const taxClass = v.taxStatus === 'free' ? 'tax-free' : v.taxStatus === 'partial' ? 'tax-partial' : 'tax-yes';
    const taxLabel = v.taxStatus === 'free' ? 'Tax-Free' : v.taxStatus === 'partial' ? 'Partial' : 'Taxed';
    tr.innerHTML = `
      <td><strong>${v.country}</strong><br><span class="region-badge">${v.region}</span></td>
      <td style="white-space:normal;min-width:160px">${v.visaName}</td>
      <td class="number">${v.duration} mo</td>
      <td class="number">${v.incomeReq === 0 ? '<span style="color:#22c55e">None</span>' : fmt(v.incomeReq) + '/mo'}</td>
      <td class="number">${v.cost === 0 ? '<span style="color:#22c55e">Free</span>' : fmt(v.cost)}</td>
      <td><span class="${taxClass}">${taxLabel}</span></td>
      <td>${v.processing}</td>
      <td class="number">${v.internet} Mbps</td>
    `;
    tr.title = v.taxNote;
    tbody.appendChild(tr);
  });

  // Update sort indicators
  document.querySelectorAll('#visa-table th').forEach(th => {
    th.classList.remove('sort-asc', 'sort-desc');
    if (th.dataset.sort === sortCol) th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
  });
}

// Render tax lists
function renderTaxLists() {
  const groups = { free: [], partial: [], yes: [] };
  VISAS.forEach(v => groups[v.taxStatus].push(v));

  ['free', 'partial', 'yes'].forEach(status => {
    const ul = $('tax-' + status + '-list');
    groups[status].sort((a, b) => a.country.localeCompare(b.country)).forEach(v => {
      const li = document.createElement('li');
      li.innerHTML = `<strong>${v.country}</strong> — ${v.taxNote}`;
      ul.appendChild(li);
    });
  });
}

// Init
renderPicks();
renderTable();
renderTaxLists();

// Filter listeners
['filter-region', 'filter-income', 'filter-tax', 'filter-duration'].forEach(id => {
  $(id).addEventListener('change', renderTable);
});

// Sort listeners
document.querySelectorAll('#visa-table th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.sort;
    if (!col) return;
    if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
    renderTable();
  });
});
