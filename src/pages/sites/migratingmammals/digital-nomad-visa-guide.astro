const TOP_PICKS = [
  { country: "Portugal", why: "Best overall package: vibrant nomad scene in Lisbon and Porto, excellent healthcare, NHR tax regime, fast internet, Schengen access, and a well-established application process." },
  { country: "Georgia", why: "Most accessible visa: no fee, no income requirement, instant processing. Tbilisi is one of Europe's cheapest capitals with surprisingly fast internet and a booming nomad community." },
