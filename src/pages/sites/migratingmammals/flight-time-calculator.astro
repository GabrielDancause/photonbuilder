    }

    .swap-btn:hover { border-color: var(--accent-color); color: var(--accent-color); }

    /* Results */
    .results-panel {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .total-banner {
      text-align: center;
      padding: 1.5rem;
      background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.06));
      border-radius: 0.75rem;
      margin-bottom: 2rem;
      border: 1px solid var(--border-color);
    }

    .total-amount {
      font-size: 3rem;
      font-weight: 800;
      color: var(--accent-color);
      line-height: 1.1;
    }

    .total-label {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .route-label {
      font-size: 1.125rem;
      font-weight: 600;
      margin-top: 0.5rem;
    }

    /* Stats grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background-color: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 0.5rem;
      padding: 1.25rem;
    }

    .stat-card .stat-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

