---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Flight Time Calculator — Estimate Flight Duration Between Cities",
    "url": "https://migratingmammals.com/flight-time-calculator",
    "applicationCategory": "TravelApplication",
    "operatingSystem": "All",
    "description": "Calculate estimated flight times between 50+ major airports worldwide. Get distance in km and miles, time zone differences, jet lag severity, and connecting flight estimates.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is flight time calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Flight time is estimated using the great circle distance between two airports divided by an average cruising speed of 885 km/h (550 mph). The great circle distance is the shortest path between two points on a sphere, calculated using the Haversine formula with each airport's latitude and longitude coordinates. Actual flight times may vary due to wind, routing, and air traffic."
        }
      },
      {
        "@type": "Question",
        "name": "Why are actual flight times different from estimates?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Estimated flight times can differ from actual times by 30-60 minutes due to several factors: jet stream winds (headwinds add time, tailwinds reduce it), air traffic control routing that may not follow the shortest path, time spent taxiing on the ground, takeoff and landing procedures, and detours around restricted airspace or weather systems."
        }
      },
      {
        "@type": "Question",
        "name": "What is jet lag and how long does it last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Jet lag is a temporary sleep disorder caused by crossing multiple time zones. Symptoms include fatigue, insomnia, difficulty concentrating, and digestive issues. As a rule of thumb, it takes about one day per time zone crossed to fully adjust. Traveling eastward is generally harder to recover from than traveling westward because it's easier to extend your day than shorten it."
        }
      },
      {
        "@type": "Question",
        "name": "What is the longest non-stop flight in the world?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The longest non-stop commercial flight is Singapore Airlines' route from Singapore to New York (SIN-JFK), covering approximately 15,349 km (9,537 miles) in about 18 hours and 40 minutes. Other ultra-long routes include Auckland to Doha (14,526 km), Perth to London (14,498 km), and Singapore to Los Angeles (14,114 km)."
        }
      },
      {
        "@type": "Question",
        "name": "How do connecting flights affect total travel time?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Connecting flights typically add 3-6 hours to your total travel time compared to direct flights. This includes the layover time (usually 1.5-3 hours for domestic connections and 2-4 hours for international), plus the additional flight segments which may not follow the most direct route. Some routes have no direct flights, making connections unavoidable."
        }
      }
    ]
  }
];

export const meta = {
  title: "Flight Time Calculator — Estimate Flight Duration 2026",
  description: "Calculate estimated flight times between 50+ major airports. Get distance in km and miles, time zone differences, jet lag severity ratings, and connecting flight estimates.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="migratingmammals"
  title="Flight Time Calculator — Estimate Flight Duration 2026"
  description="Calculate estimated flight times between 50+ major airports. Get distance in km and miles, time zone differences, jet lag severity ratings, and connecting flight estimates."
  canonical="https://migratingmammals.com/flight-time-calculator"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
