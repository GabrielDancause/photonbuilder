];

/* ── Longest Non-Stop Flights ── */
var LONGEST_FLIGHTS = [
  { from: "SIN", to: "JFK", airline: "Singapore Airlines", dist: 15349, time: "18h 40m" },
  { from: "AKL", to: "DOH", airline: "Qatar Airways", dist: 14526, time: "17h 50m" },
  { from: "PER", to: "LHR", airline: "Qantas", dist: 14498, time: "17h 45m" },
  { from: "SIN", to: "LAX", airline: "Singapore Airlines", dist: 14114, time: "17h 10m" },
  { from: "MNL", to: "JFK", airline: "Philippine Airlines", dist: 13710, time: "16h 45m" },
  { from: "SFO", to: "SIN", airline: "United Airlines", dist: 13593, time: "16h 35m" },
  { from: "DXB", to: "AKL", airline: "Emirates", dist: 14200, time: "17h 15m" },
  { from: "SYD", to: "LHR", airline: "Qantas", dist: 17016, time: "20h 15m" },
  { from: "JFK", to: "SIN", airline: "Singapore Airlines", dist: 15349, time: "18h 40m" },
  { from: "DOH", to: "AKL", airline: "Qatar Airways", dist: 14526, time: "17h 50m" }
];

/* ── Hubs for connecting flights ── */
var HUBS = ["LHR", "DXB", "SIN", "JFK", "LAX", "FRA", "DOH", "IST", "ORD", "HKG"];

/* ── Direct route thresholds (distance in km where direct flights are common) ── */
var MAX_DIRECT_COMMON = 12000;

var AVG_SPEED_KMH = 885;
var KM_TO_MILES = 0.621371;

function $(id) { return document.getElementById(id); }

function getAirport(code) {
  for (var i = 0; i < AIRPORTS.length; i++) {
    if (AIRPORTS[i].code === code) return AIRPORTS[i];
  }
  return null;
}

function toRad(deg) { return deg * Math.PI / 180; }

function haversine(lat1, lon1, lat2, lon2) {
  var R = 6371;
  var dLat = toRad(lat2 - lat1);
  var dLon = toRad(lon2 - lon1);
  var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
          Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
          Math.sin(dLon / 2) * Math.sin(dLon / 2);
  var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  return R * c;
}

function formatTime(hours) {
  var h = Math.floor(hours);
  var m = Math.round((hours - h) * 60);
  if (m === 60) { h++; m = 0; }
  return h + "h " + (m < 10 ? "0" : "") + m + "m";
}

function getJetLag(tzDiff) {
  var abs = Math.abs(tzDiff);
  if (abs <= 2) return { label: "Minimal", color: "#34d399", pct: 15, detail: "Little to no adjustment needed" };
  if (abs <= 4) return { label: "Mild", color: "#fbbf24", pct: 35, detail: "1-2 days to adjust" };
  if (abs <= 6) return { label: "Moderate", color: "#fb923c", pct: 55, detail: "2-4 days to adjust" };
  if (abs <= 9) return { label: "Significant", color: "#f87171", pct: 75, detail: "4-6 days to fully adjust" };
  return { label: "Severe", color: "#ef4444", pct: 95, detail: "6+ days to fully adjust" };
}

/* Populate dropdowns */
function populateDropdowns() {
  var selDep = $("cfg-departure");
  var selArr = $("cfg-arrival");
  var regions = {};

  AIRPORTS.forEach(function(a) {
    if (!regions[a.region]) regions[a.region] = [];
    regions[a.region].push(a);
  });

  Object.keys(regions).sort().forEach(function(region) {
    var groupDep = document.createElement("optgroup");
    groupDep.label = region;
    var groupArr = document.createElement("optgroup");
    groupArr.label = region;

    regions[region].sort(function(a, b) { return a.city.localeCompare(b.city); }).forEach(function(a) {
      var optDep = document.createElement("option");
      optDep.value = a.code;
      optDep.textContent = a.city + " (" + a.code + ")";
      groupDep.appendChild(optDep);

      var optArr = document.createElement("option");
      optArr.value = a.code;
      optArr.textContent = a.city + " (" + a.code + ")";
      groupArr.appendChild(optArr);
    });

    selDep.appendChild(groupDep);
    selArr.appendChild(groupArr);
  });

  /* Default: New York -> London */
  selDep.value = "JFK";
  selArr.value = "LHR";
}

function findBestHub(dep, arr) {
  var bestHub = null;
  var bestTotal = Infinity;

  for (var i = 0; i < HUBS.length; i++) {
    var hubCode = HUBS[i];
    if (hubCode === dep.code || hubCode === arr.code) continue;
    var hub = getAirport(hubCode);
    if (!hub) continue;

    var d1 = haversine(dep.lat, dep.lon, hub.lat, hub.lon);
    var d2 = haversine(hub.lat, hub.lon, arr.lat, arr.lon);
    var total = d1 + d2;

    /* Hub should not be more than 40% longer than direct */
    var direct = haversine(dep.lat, dep.lon, arr.lat, arr.lon);
    if (total < bestTotal && total < direct * 1.4) {
      bestTotal = total;
      bestHub = hub;
    }
  }
  return bestHub;
}

function calculate() {
  var depCode = $("cfg-departure").value;
  var arrCode = $("cfg-arrival").value;

  if (depCode === arrCode) {
    $("results-section").style.display = "";
    $("flight-time").textContent = "0h 00m";
    $("route-label").textContent = "Same city selected";
    $("stat-km").textContent = "0 km";
    $("stat-miles").textContent = "0 miles";
    $("stat-tz").textContent = "0 hours";
    $("stat-tz-detail").textContent = "Same time zone";
    $("stat-jetlag").textContent = "None";
    $("stat-jetlag-detail").textContent = "No time zone change";
    $("jetlag-fill").style.width = "0%";
    $("connecting-panel").style.display = "none";
    return;
  }

  var dep = getAirport(depCode);
  var arr = getAirport(arrCode);
  if (!dep || !arr) return;

  var distKm = haversine(dep.lat, dep.lon, arr.lat, arr.lon);
  var distMi = distKm * KM_TO_MILES;
  var flightHours = distKm / AVG_SPEED_KMH;

  /* Add 30 min for taxi/takeoff/landing */
  flightHours += 0.5;

  var tzDiff = arr.tz - dep.tz;
  var jetlag = getJetLag(tzDiff);

  $("flight-time").textContent = formatTime(flightHours);
  $("route-label").textContent = dep.city + " (" + dep.code + ") → " + arr.city + " (" + arr.code + ")";

  $("stat-km").textContent = Math.round(distKm).toLocaleString() + " km";
  $("stat-miles").textContent = Math.round(distMi).toLocaleString() + " miles";

  var tzAbs = Math.abs(tzDiff);
  var tzStr = tzAbs === 1 ? "1 hour" : tzAbs + " hours";
  if (tzDiff % 1 !== 0) tzStr = Math.abs(tzDiff) + " hours";
  $("stat-tz").textContent = (tzDiff >= 0 ? "+" : "-") + tzStr;
  $("stat-tz-detail").textContent = tzDiff === 0 ? "Same time zone" : (arr.city + " is " + tzStr + (tzDiff > 0 ? " ahead" : " behind"));

  $("stat-jetlag").textContent = jetlag.label;
  $("stat-jetlag").style.color = jetlag.color;
  $("stat-jetlag-detail").textContent = jetlag.detail;
  $("jetlag-fill").style.width = jetlag.pct + "%";
  $("jetlag-fill").style.backgroundColor = jetlag.color;

  /* Connecting flight estimate */
  if (distKm > MAX_DIRECT_COMMON) {
    var hub = findBestHub(dep, arr);
    if (hub) {
      var d1 = haversine(dep.lat, dep.lon, hub.lat, hub.lon);
      var d2 = haversine(hub.lat, hub.lon, arr.lat, arr.lon);
      var t1 = d1 / AVG_SPEED_KMH + 0.5;
      var t2 = d2 / AVG_SPEED_KMH + 0.5;
      var layover = 2.5;
      var totalConnect = t1 + layover + t2;

      $("connecting-panel").style.display = "";
      $("connecting-route").innerHTML =
        '<div class="connecting-segment">' + dep.city + ' → ' + hub.city + '<br><span style="color:var(--text-secondary);font-size:0.75rem">' + formatTime(t1) + '</span></div>' +
        '<div class="layover-badge">' + layover + 'h layover</div>' +
        '<div class="connecting-segment">' + hub.city + ' → ' + arr.city + '<br><span style="color:var(--text-secondary);font-size:0.75rem">' + formatTime(t2) + '</span></div>';
      $("connecting-total").textContent = "Total travel time with connection: ~" + formatTime(totalConnect) + " (via " + hub.city + " " + hub.code + ")";
    } else {
      $("connecting-panel").style.display = "none";
    }
  } else {
    $("connecting-panel").style.display = "none";
  }

  $("results-section").style.display = "";
}

/* Busiest routes table */
var routeSortCol = "rank";
var routeSortAsc = true;

function renderBusiestRoutes() {
  var body = $("routes-body");
  body.innerHTML = "";

  var data = BUSIEST_ROUTES.map(function(r, i) {
    var dep = getAirport(r.from);
    var arr = getAirport(r.to);
    var dist = dep && arr ? haversine(dep.lat, dep.lon, arr.lat, arr.lon) : 0;
    var time = dist / AVG_SPEED_KMH + 0.5;
    return {
      rank: i + 1,
      route: (dep ? dep.city : r.from) + " → " + (arr ? arr.city : r.to),
      routeCodes: r.from + " → " + r.to,
      distance: Math.round(dist),
      time: time,
      timeStr: formatTime(time),
      freq: r.freq
    };
  });

  data.sort(function(a, b) {
    var aVal, bVal;
    if (routeSortCol === "route") {
      aVal = a.route; bVal = b.route;
      return routeSortAsc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
    }
    aVal = a[routeSortCol]; bVal = b[routeSortCol];
    return routeSortAsc ? aVal - bVal : bVal - aVal;
  });

  data.forEach(function(d, i) {
    var tr = document.createElement("tr");
    tr.innerHTML =
      '<td>' + (i + 1) + '</td>' +
      '<td>' + d.route + ' <span style="color:var(--text-secondary);font-size:0.75rem">(' + d.routeCodes + ')</span></td>' +
      '<td>' + d.distance.toLocaleString() + ' km</td>' +
      '<td>' + d.timeStr + '</td>' +
      '<td>~' + d.freq + '</td>';
    body.appendChild(tr);
  });
}

/* Longest flights table */
function renderLongestFlights() {
  var body = $("longest-body");
  body.innerHTML = "";

  LONGEST_FLIGHTS.forEach(function(f, i) {
    var dep = getAirport(f.from);
    var arr = getAirport(f.to);
    var tr = document.createElement("tr");
    tr.innerHTML =
      '<td>' + (i + 1) + '</td>' +
      '<td>' + (dep ? dep.city : f.from) + ' → ' + (arr ? arr.city : f.to) + ' <span style="color:var(--text-secondary);font-size:0.75rem">(' + f.from + '-' + f.to + ')</span></td>' +
      '<td>' + f.airline + '</td>' +
      '<td>' + f.dist.toLocaleString() + ' km</td>' +
      '<td>' + f.time + '</td>';
    body.appendChild(tr);
  });
}

/* Table sorting for busiest routes */
document.querySelectorAll("#routes-table th").forEach(function(th) {
  th.addEventListener("click", function() {
    var col = th.dataset.sort;
    if (routeSortCol === col) { routeSortAsc = !routeSortAsc; } else { routeSortCol = col; routeSortAsc = true; }

    document.querySelectorAll("#routes-table th .sort-arrow").forEach(function(s) { s.textContent = ""; });
    th.querySelector(".sort-arrow").textContent = routeSortAsc ? " \u25b2" : " \u25bc";

    renderBusiestRoutes();
  });
});

/* Swap button */
$("btn-swap").addEventListener("click", function() {
  var dep = $("cfg-departure").value;
  var arr = $("cfg-arrival").value;
  $("cfg-departure").value = arr;
  $("cfg-arrival").value = dep;
});

/* Init */
populateDropdowns();
renderBusiestRoutes();
renderLongestFlights();

$("btn-calculate").addEventListener("click", function() {
  calculate();
  $("results-section").scrollIntoView({ behavior: "smooth" });
});
