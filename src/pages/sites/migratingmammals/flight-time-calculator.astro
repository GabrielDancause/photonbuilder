      cursor: pointer;
      transition: opacity 0.2s;
    }

    .btn-generate:hover { opacity: 0.85; }

    .swap-btn {
      background: none;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.7rem 1rem;
      border-radius: 0.5rem;
      cursor: pointer;
      font-size: 1.1rem;
      transition: border-color 0.2s, color 0.2s;
