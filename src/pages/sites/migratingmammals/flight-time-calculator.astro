/* ── Top 25 Busiest Routes ── */
var BUSIEST_ROUTES = [
  { from: "ICN", to: "NRT", freq: 80 },
  { from: "HKG", to: "TPE", freq: 65 },
  { from: "CGK", to: "SIN", freq: 62 },
