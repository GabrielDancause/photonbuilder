    .prose ul li { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0.35rem; }

    /* Print */
    @media print {
      body { background: #fff !important; color: #000 !important; }
      .config-panel, .btn-generate, .related-grid, .no-print { display: none !important; }
      .container { max-width: 100%; padding: 0; }
      .results-panel { border: 1px solid #ccc; }
      .stat-card { border: 1px solid #ccc; }
      h1, h2, h3 { color: #000 !important; }
      .total-amount { color: #000 !important; }
      a { color: #000; }
    }

    @media (max-width: 700px) {
      h1 { font-size: 1.75rem; }
      .config-grid { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .total-amount { font-size: 2.25rem; }
