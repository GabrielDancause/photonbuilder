          </div>
          <div class="config-group">
            <label>Arrival City</label>
            <select id="cfg-arrival"></select>
          </div>
        </div>
        <button class="btn-generate" id="btn-calculate">Calculate Flight Time</button>
      </div>
    </section>

    <!-- Results -->
