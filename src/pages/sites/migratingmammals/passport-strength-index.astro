---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Passport Strength Index & Ranking Tool",
    "url": "https://migratingmammals.com/passport-strength-index",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "All",
    "description": "Rank 30 passports by visa-free access, sortable by country, destinations, rank, and mobility score. Includes filtering by region and top 10 detailed passport cards.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What determines a passport's strength?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Passport strength is primarily determined by the number of countries its holders can enter visa-free, with an electronic travel authorization (eTA), or with a visa on arrival."
        }
      },
      {
        "@type": "Question",
        "name": "Which passport has the most visa-free access?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Currently, several passports tie for the top spot, including Japan, Singapore, France, Germany, Italy, and Spain, offering visa-free or visa-on-arrival access to 194 destinations."
        }
      },
      {
        "@type": "Question",
        "name": "How often do passport rankings change?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Passport rankings change continuously as countries negotiate new travel agreements, update visa policies, or impose new restrictions."
        }
      },
      {
        "@type": "Question",
        "name": "What is a mobility score?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A mobility score is an aggregate metric that evaluates the freedom of movement a passport provides, factoring in visa-free access, electronic visas, and visa-on-arrival options."
        }
      },
      {
        "@type": "Question",
        "name": "Are there any dual citizenship restrictions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, some countries do not allow dual citizenship, meaning you must renounce your current citizenship to acquire a new one. Always check the specific laws of both nations."
        }
      },
      {
        "@type": "Question",
        "name": "How does the Schengen Area affect passport strength?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Passports with visa-free access to the Schengen Area gain immediate access to 27 European countries, significantly boosting their overall strength and mobility score."
        }
      },
      {
        "@type": "Question",
        "name": "Can I improve my passport strength?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can improve your global mobility by acquiring a second passport through descent, naturalization, marriage, or citizenship-by-investment programs."
        }
      }
    ]
  }
];

export const meta = {
  title: "Passport Strength Index 2026 — Rank 30 Passports",
  description: "Rank 30 passports by visa-free access. Sortable table by country, destinations, rank, and mobility score. Filter by region and explore the top 10 detailed cards.",
  category: "guide",
  published: "2026-04-12",
};
---

<SiteLayout
  site="migratingmammals"
  title="Passport Strength Index 2026 — Rank 30 Passports"
  description="Rank 30 passports by visa-free access. Sortable table by country, destinations, rank, and mobility score. Filter by region and explore the top 10 detailed cards."
  canonical="https://migratingmammals.com/passport-strength-index"
  schema={schema}
>
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    header { padding: 4rem 0 2rem; text-align: center; }

    h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2; }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 680px;
      margin: 0 auto 2rem;
    }

    section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }

    /* Filters */
    .filters {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
      background: var(--card-bg);
      padding: 1rem;
      border-radius: 0.75rem;
      border: 1px solid var(--border-color);
    }

    .filter-group { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; min-width: 150px; }
    .filter-group label { font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }

    select {
      padding: 0.5rem;
      border-radius: 0.5rem;
      border: 1px solid var(--border-color);
      background: var(--bg-color);
      color: var(--text-primary);
      font-size: 0.875rem;
      outline: none;
    }
    select:focus { border-color: var(--accent-color); }

    /* Table */
    .table-wrap {
      overflow-x: auto;
      background: var(--card-bg);
      border-radius: 0.75rem;
      border: 1px solid var(--border-color);
    }

    table { width: 100%; border-collapse: collapse; text-align: left; font-size: 0.875rem; }

    th {
      padding: 1rem;
      background: rgba(0,0,0,0.2);
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
      border-bottom: 1px solid var(--border-color);
    }
    th:hover { color: var(--text-primary); }

    th::after { content: ' ↕'; opacity: 0.3; }
    th.sort-asc::after { content: ' ↑'; opacity: 1; }
    th.sort-desc::after { content: ' ↓'; opacity: 1; }

    td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    .region-badge {
      display: inline-block;
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      background: var(--border-color);
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .number { font-family: 'JetBrains Mono', monospace; }

    .rank-top { color: #22c55e; font-weight: bold; }

    /* Top Picks Grid */
    .picks-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .pick-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 1rem;
      padding: 1.5rem;
      position: relative;
    }

    .pick-rank {
      position: absolute;
      top: -0.75rem;
      left: 1.5rem;
      background: var(--accent-color);
      color: white;
      padding: 0.25rem 0.75rem;
      border-radius: 1rem;
      font-size: 0.75rem;
      font-weight: 700;
    }

    .pick-card h3 { font-size: 1.5rem; margin-top: 0.5rem; margin-bottom: 0.25rem; }
    .pick-card .region-name { font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1rem; }

    .pick-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border-color);
    }

    .pick-stat .label { font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.25rem; }
    .pick-stat .value { font-size: 1.125rem; font-weight: 700; font-family: 'JetBrains Mono', monospace; }

    .pick-why { font-size: 0.875rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-grid { display: grid; gap: 1rem; }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }
    .faq-item h3 { font-size: 1rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .faq-item p { font-size: 0.875rem; color: var(--text-secondary); margin: 0; }

  </style>

  <div class="container">
    <div style="background:rgba(196,149,106,0.1);border:1px solid rgba(196,149,106,0.25);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      🛂 <strong style="color:#C4956A;">Japanese passport holders can visit 194 countries visa-free — Afghans can visit 28.</strong> Your passport determines your global mobility more than your wealth. With currency volatility reshaping travel plans, knowing your access score is essential. <a href="https://gab.ae/news/currency-volatility-oil-crisis-travel-budgets-2026" style="color:#C4956A;">How currency affects travel →</a>
    </div>
    <header>
      <h1>Passport Strength Index</h1>
      <p class="subtitle">Rank 30 global passports by visa-free access, overall rank, and mobility score. Filter by region and find the strongest passports for global travel.</p>
    </header>

    <section>
      <h2>Top 10 Strongest Passports</h2>
      <div class="picks-grid" id="picks-grid">
        <!-- Rendered by JS -->
      </div>
    </section>

    <section>
      <h2>Compare All Passports</h2>

      <div class="filters">
        <div class="filter-group">
          <label>Region</label>
          <select id="filter-region">
            <option value="all">All Regions</option>
            <option value="Asia">Asia</option>
            <option value="Europe">Europe</option>
            <option value="Americas">Americas</option>
            <option value="Oceania">Oceania</option>
            <option value="Middle East">Middle East</option>
          </select>
        </div>
        <div style="margin-left:auto; display:flex; align-items:center; font-size:0.875rem; color:var(--text-secondary)">
          <span id="result-count">Showing 30 passports</span>
        </div>
      </div>

      <div class="table-wrap">
        <table id="passport-table">
          <thead>
            <tr>
              <th data-sort="country">Country</th>
              <th data-sort="visaFree" class="sort-desc">Visa-Free Destinations</th>
              <th data-sort="rank">Rank</th>
              <th data-sort="score">Mobility Score</th>
            </tr>
          </thead>
          <tbody id="passport-body">
            <!-- Rendered by JS -->
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-grid">
        {schema[1].mainEntity.map((faq) => (
          <div class="faq-item">
            <h3>{faq.name}</h3>
            <p>{faq.acceptedAnswer.text}</p>
          </div>
        ))}
      </div>
    </section>

  </div>

  <script>
const PASSPORTS = [{"country": "Japan", "region": "Asia", "visaFree": 194, "rank": 1, "score": 98}, {"country": "Singapore", "region": "Asia", "visaFree": 194, "rank": 1, "score": 98}, {"country": "France", "region": "Europe", "visaFree": 194, "rank": 1, "score": 98}, {"country": "Germany", "region": "Europe", "visaFree": 194, "rank": 1, "score": 98}, {"country": "Italy", "region": "Europe", "visaFree": 194, "rank": 1, "score": 98}, {"country": "Spain", "region": "Europe", "visaFree": 194, "rank": 1, "score": 98}, {"country": "South Korea", "region": "Asia", "visaFree": 193, "rank": 2, "score": 97}, {"country": "Finland", "region": "Europe", "visaFree": 193, "rank": 2, "score": 97}, {"country": "Sweden", "region": "Europe", "visaFree": 193, "rank": 2, "score": 97}, {"country": "Austria", "region": "Europe", "visaFree": 192, "rank": 3, "score": 96}, {"country": "Ireland", "region": "Europe", "visaFree": 192, "rank": 3, "score": 96}, {"country": "Netherlands", "region": "Europe", "visaFree": 192, "rank": 3, "score": 96}, {"country": "Luxembourg", "region": "Europe", "visaFree": 192, "rank": 3, "score": 96}, {"country": "Denmark", "region": "Europe", "visaFree": 192, "rank": 3, "score": 96}, {"country": "UK", "region": "Europe", "visaFree": 191, "rank": 4, "score": 95}, {"country": "Belgium", "region": "Europe", "visaFree": 191, "rank": 4, "score": 95}, {"country": "Portugal", "region": "Europe", "visaFree": 191, "rank": 4, "score": 95}, {"country": "Norway", "region": "Europe", "visaFree": 191, "rank": 4, "score": 95}, {"country": "New Zealand", "region": "Oceania", "visaFree": 189, "rank": 6, "score": 94}, {"country": "Australia", "region": "Oceania", "visaFree": 189, "rank": 6, "score": 94}, {"country": "USA", "region": "Americas", "visaFree": 188, "rank": 7, "score": 93}, {"country": "Canada", "region": "Americas", "visaFree": 187, "rank": 8, "score": 92}, {"country": "UAE", "region": "Middle East", "visaFree": 183, "rank": 11, "score": 90}, {"country": "Malaysia", "region": "Asia", "visaFree": 182, "rank": 12, "score": 89}, {"country": "Argentina", "region": "Americas", "visaFree": 174, "rank": 17, "score": 85}, {"country": "Brazil", "region": "Americas", "visaFree": 173, "rank": 18, "score": 84}, {"country": "Israel", "region": "Middle East", "visaFree": 170, "rank": 21, "score": 82}, {"country": "Mexico", "region": "Americas", "visaFree": 161, "rank": 23, "score": 79}, {"country": "China", "region": "Asia", "visaFree": 85, "rank": 62, "score": 50}, {"country": "India", "region": "Asia", "visaFree": 62, "rank": 80, "score": 40}];

// Pre-sort by visaFree descending
PASSPORTS.sort((a, b) => b.visaFree - a.visaFree);

// Get Top 10 for cards
const TOP_10 = PASSPORTS.slice(0, 10);

let sortCol = 'visaFree';
let sortAsc = false;

function $(id) { return document.getElementById(id); }

// Render top picks
function renderPicks() {
  const grid = $('picks-grid');
  grid.innerHTML = '';
  TOP_10.forEach((p, i) => {
    const card = document.createElement('div');
    card.className = 'pick-card';
    card.innerHTML = `
      <div class="pick-rank">#${p.rank} Rank</div>
      <h3>${p.country}</h3>
      <div class="region-name">${p.region}</div>
      <div class="pick-stats">
        <div class="pick-stat"><div class="label">Visa-Free</div><div class="value">${p.visaFree}</div></div>
        <div class="pick-stat"><div class="label">Mobility Score</div><div class="value">${p.score}</div></div>
      </div>
      <div class="pick-why">Offers extensive visa-free, eTA, and visa-on-arrival access across the globe.</div>
    `;
    grid.appendChild(card);
  });
}

// Get filtered passports
function getFiltered() {
  const region = $('filter-region').value;

  return PASSPORTS.filter(p => {
    if (region !== 'all' && p.region !== region) return false;
    return true;
  });
}

// Render table
function renderTable() {
  const filtered = getFiltered();

  // Sort
  const sorted = [...filtered].sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
    return sortAsc ? va - vb : vb - va;
  });

  $('result-count').textContent = `Showing ${sorted.length} of ${PASSPORTS.length} passports`;

  const tbody = $('passport-body');
  tbody.innerHTML = '';
  sorted.forEach(p => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><strong>${p.country}</strong><br><span class="region-badge">${p.region}</span></td>
      <td class="number">${p.visaFree}</td>
      <td class="number ${p.rank <= 10 ? 'rank-top' : ''}">#${p.rank}</td>
      <td class="number">${p.score}</td>
    `;
    tbody.appendChild(tr);
  });

  // Update sort indicators
  document.querySelectorAll('#passport-table th').forEach(th => {
    th.classList.remove('sort-asc', 'sort-desc');
    if (th.dataset.sort === sortCol) th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
  });
}

// Init
renderPicks();
renderTable();

// Filter listeners
['filter-region'].forEach(id => {
  $(id).addEventListener('change', renderTable);
});

// Sort listeners
document.querySelectorAll('#passport-table th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.sort;
    if (!col) return;
    if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
    renderTable();
  });
});
  </script>


  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/visa-free-countries" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Visa-Free Countries Checker</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Check which countries you can visit visa-free, visa on arrival, eVisa, or visa required based on your passport nationali...</p>
      </a>
    </div>
  </div>
</SiteLayout>
