---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import { sites } from '../../../../config/sites';
const SITE_ID = 'migratingmammals';
const siteConfig = sites[SITE_ID];
const allPages = import.meta.glob('../*.astro', { eager: true });
interface PageEntry { slug: string; title: string; description: string; category: string; }
const items: PageEntry[] = Object.entries(allPages)
  .filter(([path]) => !path.includes('index'))
  .map(([path, mod]: [string, any]) => ({ slug: path.replace('../', '').replace('.astro', ''), title: mod.meta?.title || path.replace('../', '').replace('.astro', '').replace(/-/g, ' '), description: mod.meta?.description || '', category: mod.meta?.category || 'tool' }))
  .filter(p => p.category === 'tool')
  .sort((a, b) => a.title.localeCompare(b.title));
function getEmoji(slug: string): string {
  if (slug.includes('calculator') || slug.includes('converter')) return '🧮';
  if (slug.includes('tracker')) return '📡';
  if (slug.includes('visa') || slug.includes('passport')) return '🛂';
  if (slug.includes('flight') || slug.includes('airline')) return '✈️';
  if (slug.includes('cruise') || slug.includes('ship')) return '🚢';
  if (slug.includes('weather') || slug.includes('hurricane')) return '🌊';
  if (slug.includes('cost') || slug.includes('budget')) return '💰';
  return '🛠️';
}
function truncate(text: string, max: number): string { if (!text || text.length <= max) return text || ''; return text.slice(0, max).replace(/\s+\S*$/, '') + '…'; }
const schema = JSON.stringify({ "@context": "https://schema.org", "@type": "CollectionPage", "name": "Travel Tools & Calculators", "url": `https://${siteConfig.domain}/tools/`, "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": `https://${siteConfig.domain}/` } });
---
<SiteLayout site={SITE_ID} title={`Travel Tools & Calculators — ${siteConfig.name}`} description={`${items.length} free travel calculators, trackers, and planning tools. Flight trackers, visa checkers, and cost comparisons.`} canonical={`https://${siteConfig.domain}/tools/`} schema={schema}>
  <div class="hero"><div class="hero-content"><span class="hero-tag">🛠️ TOOLS</span><h1>Travel Tools & Calculators</h1><p>{items.length} travel calculators, trackers, and planning tools.</p><div class="search-box"><svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg><input type="text" id="searchInput" placeholder={`Search ${items.length} tools…`} autocomplete="off" /></div></div></div>
  <div class="page-container"><div class="results-count" id="resultsCount">{items.length} tools</div><div class="grid" id="itemsGrid">{items.map(page => (<a class="card" href={`/${page.slug}`} data-title={page.title.toLowerCase()} data-desc={page.description.toLowerCase()}><span class="card-emoji">{getEmoji(page.slug)}</span><h2 class="card-name">{page.title}</h2><p class="card-desc">{truncate(page.description, 130)}</p></a>))}</div><div class="no-results" id="noResults">No tools found.</div></div>
  <script is:inline>document.addEventListener('DOMContentLoaded',()=>{const i=document.getElementById('searchInput'),c=document.getElementById('itemsGrid').querySelectorAll('.card'),n=document.getElementById('resultsCount'),nr=document.getElementById('noResults');i.addEventListener('input',()=>{const q=i.value.toLowerCase().trim();let v=0;c.forEach(x=>{const m=!q||x.dataset.title.includes(q)||x.dataset.desc.includes(q);x.style.display=m?'':'none';if(m)v++});n.textContent=v+' tools';nr.style.display=v===0?'block':'none'})});</script>
  <style is:inline>.hero{text-align:center;padding:4rem 1.5rem 2.5rem}.hero-tag{display:inline-block;background:color-mix(in srgb,var(--accent-color) 10%,transparent);color:var(--accent-color);font-size:.7rem;font-weight:800;padding:6px 16px;border-radius:20px;letter-spacing:1px;margin-bottom:1rem}.hero h1{font-size:2.2rem;font-weight:800;margin-bottom:.5rem}.hero p{color:var(--text-secondary);font-size:1.05rem;margin-bottom:1.5rem}.search-box{max-width:420px;margin:0 auto;position:relative}.search-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);width:18px;height:18px;color:var(--text-secondary)}.search-box input{width:100%;padding:12px 16px 12px 42px;border:1px solid var(--border-color);border-radius:10px;font-size:.95rem;background:var(--card-bg);color:var(--text-primary);outline:none;box-sizing:border-box}.search-box input:focus{border-color:var(--accent-color)}.page-container{max-width:1100px;margin:0 auto 3rem;padding:0 1.5rem}.results-count{font-size:.85rem;color:var(--text-secondary);margin-bottom:1rem}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}.card{display:block;background:var(--card-bg);border:1px solid var(--border-color);border-radius:12px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color .2s,transform .2s}.card:hover{border-color:var(--accent-color);transform:translateY(-2px)}.card-emoji{font-size:1.5rem;display:block;margin-bottom:.5rem}.card-name{font-size:1rem;font-weight:700;margin:0 0 .35rem;line-height:1.3}.card-desc{font-size:.85rem;color:var(--text-secondary);line-height:1.4;margin:0}.no-results{display:none;text-align:center;color:var(--text-secondary);padding:3rem 0}@media(max-width:640px){.hero h1{font-size:1.6rem}.grid{grid-template-columns:1fr}}</style>
</SiteLayout>
