      {id:147,cat:"Random",title:"Spend a full day saying yes to everything",desc:"Channel your inner Yes Man for 24 hours and see what happens.",cost:"$",diff:"easy",type:"solo",loc:null},
      {id:148,cat:"Random",title:"Go to a movie alone",desc:"Pick a film nobody else wants to see and enjoy your own company.",cost:"$",diff:"easy",type:"solo",loc:null},
      {id:149,cat:"Random",title:"Visit the world's largest something",desc:"Biggest ball of twine, tallest statue, longest bench — pick your record.",cost:"$",diff:"easy",type:"solo",loc:"Various"},
      {id:150,cat:"Random",title:"Float in a sensory deprivation tank",desc:"Lie in a dark, silent, salt-filled pod and lose track of your body.",cost:"$",diff:"easy",type:"solo",loc:null},
      {id:151,cat:"Random",title:"Take a train with no destination in mind",desc:"Board a random departure and see where you end up.",cost:"$",diff:"easy",type:"solo",loc:null},
      {id:152,cat:"Random",title:"Go to a costume party as something absurd",desc:"Commit fully — not half-effort — to the weirdest costume possible.",cost:"$",diff:"easy",type:"group",loc:null},
      {id:153,cat:"Random",title:"Bury a time capsule",desc:"Fill a box with objects and letters, bury it, and set a date to dig it up.",cost:"free",diff:"easy",type:"group",loc:null},
      {id:154,cat:"Random",title:"Try zero-gravity (parabolic flight)",desc:"Experience weightlessness on a zero-G airplane flight.",cost:"$$$$",diff:"medium",type:"solo",loc:"USA / Europe"},
      {id:155,cat:"Random",title:"Do a polar bear swim on New Year's Day",desc:"Join the annual tradition of jumping into freezing water to start the year.",cost:"free",diff:"easy",type:"group",loc:null}
    ];

    const CATS = [
      {key:"Travel",emoji:"✈️"},
      {key:"Adventure",emoji:"🧗"},
      {key:"Food & Drink",emoji:"🍜"},
      {key:"Career",emoji:"💼"},
      {key:"Creative",emoji:"🎨"},
      {key:"Learning",emoji:"📚"},
      {key:"Relationships",emoji:"💛"},
      {key:"Health & Fitness",emoji:"🏃"},
      {key:"Nature",emoji:"🌿"},
      {key:"Random",emoji:"🎲"}
    ];

    const LS_KEY = "mm_bucket_list";

    /* helpers */
    function loadList() { try { return JSON.parse(localStorage.getItem(LS_KEY)) || []; } catch { return []; } }
    function saveList(list) { localStorage.setItem(LS_KEY, JSON.stringify(list)); }
    function diffClass(d) { return "diff-" + d; }
    function emojiFor(cat) { const c = CATS.find(x => x.key === cat); return c ? c.emoji : "🎯"; }

    /* state */
    let selectedCats = new Set();
    let myList = loadList();
    let listFilter = "all";
    let editingId = null;

    /* ===== TABS ===== */
    document.querySelectorAll(".tab-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
        document.querySelectorAll(".tab-panel").forEach(p => p.classList.remove("active"));
        btn.classList.add("active");
        document.getElementById("tab-" + btn.dataset.tab).classList.add("active");
        if (btn.dataset.tab === "mylist") renderMyList();
        if (btn.dataset.tab === "stats") renderStats();
      });
    });

    /* ===== CATEGORY CHIPS ===== */
    const chipGrid = document.getElementById("catChips");
    CATS.forEach(c => {
      const chip = document.createElement("button");
      chip.className = "chip";
      chip.innerHTML = '<span class="emoji">' + c.emoji + '</span>' + c.key;
      chip.addEventListener("click", () => {
        if (selectedCats.has(c.key)) { selectedCats.delete(c.key); chip.classList.remove("selected"); }
        else { selectedCats.add(c.key); chip.classList.add("selected"); }
      });
      chipGrid.appendChild(chip);
    });

    /* ===== GENERATE ===== */
    const ideasGrid = document.getElementById("ideasGrid");
    const noResults = document.getElementById("noResults");

    function filterIdeas() {
      const costVal = document.getElementById("filterCost").value;
      const diffVal = document.getElementById("filterDiff").value;
      const typeVal = document.getElementById("filterType").value;
      let ideas = DB;
      if (selectedCats.size > 0) ideas = ideas.filter(i => selectedCats.has(i.cat));
      if (costVal !== "all") ideas = ideas.filter(i => i.cost === costVal);
      if (diffVal !== "all") ideas = ideas.filter(i => i.diff === diffVal);
      if (typeVal !== "all") ideas = ideas.filter(i => i.type === typeVal);
      return ideas;
    }

    function isInList(id) { return myList.some(item => item.id === id); }

    function renderIdeas(ideas) {
      ideasGrid.innerHTML = "";
      noResults.style.display = ideas.length === 0 ? "block" : "none";
      ideas.forEach(idea => {
        const card = document.createElement("div");
        card.className = "idea-card";
        const inList = isInList(idea.id);
        card.innerHTML =
          '<div class="card-cat">' + emojiFor(idea.cat) + " " + idea.cat + '</div>' +
          '<div class="card-title">' + idea.title + '</div>' +
          '<div class="card-desc">' + idea.desc + '</div>' +
          '<div class="card-meta">' +
            '<span class="meta-tag ' + diffClass(idea.diff) + '">' + idea.diff.charAt(0).toUpperCase() + idea.diff.slice(1) + '</span>' +
            '<span class="meta-tag">' + (idea.cost === "free" ? "Free" : idea.cost) + '</span>' +
            '<span class="meta-tag">' + (idea.type === "solo" ? "Solo-friendly" : "Best with others") + '</span>' +
            (idea.loc ? '<span class="meta-tag">📍 ' + idea.loc + '</span>' : '') +
          '</div>' +
          '<div class="card-actions">' +
            '<button class="btn-add-small' + (inList ? " added" : "") + '" data-id="' + idea.id + '">' + (inList ? "✓ Added" : "+ Add to List") + '</button>' +
          '</div>';
        ideasGrid.appendChild(card);
      });

      ideasGrid.querySelectorAll(".btn-add-small:not(.added)").forEach(btn => {
        btn.addEventListener("click", () => {
          const id = parseInt(btn.dataset.id);
          const idea = DB.find(i => i.id === id);
          if (idea && !isInList(id)) {
            myList.push({ id: idea.id, title: idea.title, cat: idea.cat, status: "want", notes: "", date: "" });
            saveList(myList);
            btn.textContent = "✓ Added";
            btn.classList.add("added");
          }
        });
      });
    }

    document.getElementById("btnGenerate").addEventListener("click", () => {
      const ideas = filterIdeas();
      /* shuffle */
      for (let i = ideas.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [ideas[i], ideas[j]] = [ideas[j], ideas[i]]; }
      renderIdeas(ideas.slice(0, 30));
      document.getElementById("surpriseCard").classList.remove("visible");
    });

    /* ===== SURPRISE ME ===== */
    document.getElementById("btnSurprise").addEventListener("click", () => {
      const sc = document.getElementById("surpriseCard");
      const btn = document.getElementById("btnSurprise");
      const dice = btn.querySelector("span") || btn;
      sc.classList.remove("visible");
      btn.style.pointerEvents = "none";

      /* quick spin animation on button text */
      const origText = btn.innerHTML;
      btn.innerHTML = '<span class="spinning">🎲</span> Rolling...';
      setTimeout(() => {
        btn.innerHTML = origText;
        btn.style.pointerEvents = "";
        const idea = DB[Math.floor(Math.random() * DB.length)];
        const inList = isInList(idea.id);
        sc.className = "surprise-card idea-card visible";
        sc.innerHTML =
          '<div class="card-cat">' + emojiFor(idea.cat) + " " + idea.cat + '</div>' +
          '<div class="card-title">' + idea.title + '</div>' +
          '<div class="card-desc">' + idea.desc + '</div>' +
          '<div class="card-meta">' +
            '<span class="meta-tag ' + diffClass(idea.diff) + '">' + idea.diff.charAt(0).toUpperCase() + idea.diff.slice(1) + '</span>' +
            '<span class="meta-tag">' + (idea.cost === "free" ? "Free" : idea.cost) + '</span>' +
            '<span class="meta-tag">' + (idea.type === "solo" ? "Solo-friendly" : "Best with others") + '</span>' +
            (idea.loc ? '<span class="meta-tag">📍 ' + idea.loc + '</span>' : '') +
          '</div>' +
          '<div class="card-actions">' +
            '<button class="btn-add-small' + (inList ? " added" : "") + '" data-id="' + idea.id + '">' + (inList ? "✓ Added" : "+ Add to List") + '</button>' +
          '</div>';
        sc.querySelector(".btn-add-small:not(.added)")?.addEventListener("click", function() {
          const id = parseInt(this.dataset.id);
          const item = DB.find(i => i.id === id);
          if (item && !isInList(id)) {
            myList.push({ id: item.id, title: item.title, cat: item.cat, status: "want", notes: "", date: "" });
            saveList(myList);
            this.textContent = "✓ Added";
            this.classList.add("added");
          }
        });
      }, 700);
    });

    /* ===== MY LIST ===== */
    const myListItems = document.getElementById("myListItems");
    const emptyList = document.getElementById("emptyList");

    document.querySelectorAll(".status-chip").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".status-chip").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        listFilter = btn.dataset.status;
        renderMyList();
      });
    });

    const statusCycle = ["want", "progress", "done"];
    const statusIcons = { want: "○", progress: "◐", done: "✓" };
    const statusLabels = { want: "Want to do", progress: "In progress", done: "Done" };

    function renderMyList() {
      myListItems.innerHTML = "";
      let items = myList;
      if (listFilter !== "all") items = items.filter(i => i.status === listFilter);
      emptyList.style.display = myList.length === 0 ? "block" : "none";
      if (myList.length > 0 && items.length === 0) {
        myListItems.innerHTML = '<div class="no-results">No items with this status.</div>';
      }
      items.forEach((item, idx) => {
        const realIdx = myList.indexOf(item);
        const el = document.createElement("div");
        el.className = "list-item";
        el.innerHTML =
          '<button class="list-item-status status-' + item.status + '" data-idx="' + realIdx + '" title="Click to change status">' + statusIcons[item.status] + '</button>' +
          '<div class="list-item-body">' +
            '<div class="list-item-title">' + item.title + '</div>' +
            '<div class="list-item-cat">' + emojiFor(item.cat) + ' ' + item.cat + ' · ' + statusLabels[item.status] + '</div>' +
            (item.notes ? '<div class="list-item-notes">"' + item.notes + '"</div>' : '') +
            (item.date ? '<div class="list-item-date">Completed: ' + item.date + '</div>' : '') +
          '</div>' +
          '<div class="list-item-actions">' +
            '<button class="btn-icon" data-action="notes" data-idx="' + realIdx + '" title="Edit notes">✎</button>' +
            '<button class="btn-icon delete" data-action="delete" data-idx="' + realIdx + '" title="Remove">✕</button>' +
          '</div>';
        myListItems.appendChild(el);
      });

      /* status toggle */
      myListItems.querySelectorAll(".list-item-status").forEach(btn => {
        btn.addEventListener("click", () => {
          const i = parseInt(btn.dataset.idx);
          const cur = statusCycle.indexOf(myList[i].status);
          myList[i].status = statusCycle[(cur + 1) % 3];
          saveList(myList);
          renderMyList();
          updateProgress();
        });
      });

      /* actions */
      myListItems.querySelectorAll(".btn-icon").forEach(btn => {
        btn.addEventListener("click", () => {
          const i = parseInt(btn.dataset.idx);
          if (btn.dataset.action === "delete") {
            myList.splice(i, 1);
            saveList(myList);
            renderMyList();
            updateProgress();
          } else if (btn.dataset.action === "notes") {
            editingId = i;
            document.getElementById("modalNotes").value = myList[i].notes || "";
            document.getElementById("modalDate").value = myList[i].date || "";
            document.getElementById("notesModal").classList.add("visible");
          }
        });
      });

      updateProgress();
    }

    function updateProgress() {
      const total = myList.length;
      const done = myList.filter(i => i.status === "done").length;
      const pct = total > 0 ? Math.round((done / total) * 100) : 0;
      document.getElementById("progressFill").style.width = pct + "%";
      document.getElementById("progressText").textContent = done + " / " + total + " completed (" + pct + "%)";
    }

    /* notes modal */
    document.getElementById("modalCancel").addEventListener("click", () => {
      document.getElementById("notesModal").classList.remove("visible");
    });
    document.getElementById("modalSave").addEventListener("click", () => {
      if (editingId !== null) {
        myList[editingId].notes = document.getElementById("modalNotes").value.trim();
        myList[editingId].date = document.getElementById("modalDate").value;
        saveList(myList);
        renderMyList();
      }
      document.getElementById("notesModal").classList.remove("visible");
    });
    document.getElementById("notesModal").addEventListener("click", (e) => {
      if (e.target === e.currentTarget) e.currentTarget.classList.remove("visible");
    });

    /* custom idea */
    document.getElementById("btnAddCustom").addEventListener("click", () => {
      const title = document.getElementById("customTitle").value.trim();
      if (!title) return;
      const cat = document.getElementById("customCat").value;
      const notes = document.getElementById("customNotes").value.trim();
      myList.push({ id: "custom_" + Date.now(), title, cat, status: "want", notes, date: "" });
      saveList(myList);
      document.getElementById("customTitle").value = "";
      document.getElementById("customNotes").value = "";
      renderMyList();
    });

    /* export */
    document.getElementById("btnExport").addEventListener("click", () => {
      if (myList.length === 0) return;
      let text = "MY BUCKET LIST\n" + "=".repeat(40) + "\n\n";
      const grouped = {};
      myList.forEach(item => {
        if (!grouped[item.cat]) grouped[item.cat] = [];
        grouped[item.cat].push(item);
      });
      Object.keys(grouped).forEach(cat => {
        text += cat.toUpperCase() + "\n" + "-".repeat(20) + "\n";
        grouped[cat].forEach(item => {
          const mark = item.status === "done" ? "[x]" : item.status === "progress" ? "[-]" : "[ ]";
          text += mark + " " + item.title;
          if (item.notes) text += "  — " + item.notes;
          if (item.date) text += "  (" + item.date + ")";
          text += "\n";
        });
        text += "\n";
      });
      const done = myList.filter(i => i.status === "done").length;
      text += "PROGRESS: " + done + "/" + myList.length + " completed\n";
      text += "Generated at migratingmammals.com/bucket-list-ideas\n";

      const blob = new Blob([text], { type: "text/plain" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = "my-bucket-list.txt";
      a.click();
      URL.revokeObjectURL(a.href);
    });

    /* ===== STATS ===== */
    function renderStats() {
      const grid = document.getElementById("statsGrid");
      const chart = document.getElementById("catBarChart");
      const empty = document.getElementById("emptyStats");

      if (myList.length === 0) {
        grid.innerHTML = "";
        chart.innerHTML = "";
        empty.style.display = "block";
        return;
      }
      empty.style.display = "none";

      const total = myList.length;
      const done = myList.filter(i => i.status === "done").length;
      const inProg = myList.filter(i => i.status === "progress").length;
      const want = myList.filter(i => i.status === "want").length;

      /* category counts */
      const catCounts = {};
      CATS.forEach(c => catCounts[c.key] = 0);
      myList.forEach(item => { catCounts[item.cat] = (catCounts[item.cat] || 0) + 1; });

      /* most popular category */
      let topCat = "";
      let topCount = 0;
      Object.entries(catCounts).forEach(([k, v]) => { if (v > topCount) { topCat = k; topCount = v; } });

      grid.innerHTML =
        '<div class="stat-card"><div class="stat-number">' + total + '</div><div class="stat-label">Total Ideas</div></div>' +
        '<div class="stat-card"><div class="stat-number">' + done + '</div><div class="stat-label">Completed</div></div>' +
        '<div class="stat-card"><div class="stat-number">' + inProg + '</div><div class="stat-label">In Progress</div></div>' +
        '<div class="stat-card"><div class="stat-number">' + want + '</div><div class="stat-label">Want to Do</div></div>' +
        '<div class="stat-card"><div class="stat-number">' + (total > 0 ? Math.round((done / total) * 100) + "%" : "0%") + '</div><div class="stat-label">Completion Rate</div></div>' +
        '<div class="stat-card"><div class="stat-number">' + emojiFor(topCat) + '</div><div class="stat-label">Top Category: ' + topCat + '</div></div>';

      /* bar chart */
      const maxCount = Math.max(...Object.values(catCounts), 1);
      let chartHTML = '<h3 style="margin-bottom:1rem;">Ideas by Category</h3>';
      CATS.forEach(c => {
        const count = catCounts[c.key] || 0;
        const pct = Math.round((count / maxCount) * 100);
        chartHTML +=
          '<div class="cat-bar-row">' +
            '<div class="cat-bar-label">' + c.emoji + " " + c.key + '</div>' +
            '<div class="cat-bar-track"><div class="cat-bar-fill" style="width:' + pct + '%"></div></div>' +
            '<div class="cat-bar-count">' + count + '</div>' +
          '</div>';
      });
      chart.innerHTML = chartHTML;
    }

    /* initial render */
    updateProgress();
  })();
  </script>
</SiteLayout>
