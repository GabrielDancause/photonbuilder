---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "150+ Bucket List Ideas: Interactive Generator & Tracker",
    "url": "https://migratingmammals.com/bucket-list-ideas",
    "applicationCategory": "LifestyleApplication",
    "operatingSystem": "All",
    "description": "Explore 150+ curated bucket list ideas across 10 categories. Generate ideas by category, difficulty, and cost — then track your progress with a built-in localStorage tracker.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does the bucket list generator work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Select one or more categories (Travel, Adventure, Food & Drink, etc.), set optional filters for cost range and difficulty, then click Generate. The tool pulls matching ideas from a curated database of 150+ real bucket list experiences and displays them with estimated costs, difficulty ratings, and descriptions."
        }
      },
      {
        "@type": "Question",
        "name": "Is my bucket list saved?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Your bucket list is stored in your browser's localStorage, so it persists between visits on the same device and browser. No account or sign-up is required. You can also export your list as plain text to save or share it."
        }
      },
      {
        "@type": "Question",
        "name": "Can I add my own custom bucket list ideas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. In the My Bucket List section, use the Add Custom Idea form to enter any goal you like — with your own title, category, and notes. Custom ideas are tracked alongside generator ideas."
        }
      },
      {
        "@type": "Question",
        "name": "What do the difficulty levels mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Easy means minimal planning or cost — you could do it this weekend. Medium requires some preparation, travel, or moderate expense. Hard involves significant planning, training, or budget. Epic is a once-in-a-lifetime challenge that may take months or years of preparation."
        }
      },
      {
        "@type": "Question",
        "name": "How were these bucket list ideas chosen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The ideas are curated from popular travel blogs, adventure communities, and life-experience surveys. They range from free local activities to multi-thousand-dollar adventures, ensuring there is something achievable for every budget and lifestyle."
        }
      }
    ]
  }
];

export const meta = {
  title: "150+ Bucket List Ideas: Interactive Generator & Tracker",
  description: "Explore 150+ curated bucket list ideas across 10 categories. Generate by difficulty and cost, track your progress, and export your list — no sign-up needed.",
  category: "tool",
  published: "2026-03-29",
};
---

<SiteLayout
  site="migratingmammals"
  title="150+ Bucket List Ideas: Interactive Generator & Tracker"
  description="Explore 150+ curated bucket list ideas across 10 categories. Generate by difficulty and cost, track your progress, and export your list — no sign-up needed."
  canonical="https://migratingmammals.com/bucket-list-ideas"
  schema={schema}
>
  <style is:inline>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    header { padding: 4rem 0 2rem; text-align: center; }

    h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2; }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 640px;
      margin: 0 auto 2rem;
    }

    section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--border-color);
    }

    h3 { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.75rem; }

    /* Tabs */
    .tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .tab-btn {
      padding: 0.625rem 1.25rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      background: var(--bg-color);
      color: var(--text-primary);
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: var(--font-ui);
    }

    .tab-btn:hover { border-color: var(--accent-color); }

    .tab-btn.active {
      background: var(--accent-color);
      color: #fff;
      border-color: var(--accent-color);
    }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* Category chips */
    .chip-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .chip {
      padding: 0.5rem 1rem;
      border: 2px solid var(--border-color);
      border-radius: 24px;
      background: var(--bg-color);
      color: var(--text-primary);
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      user-select: none;
      font-family: var(--font-ui);
    }

    .chip:hover { border-color: var(--accent-color); }

    .chip.selected {
      background: var(--accent-color);
      color: #fff;
      border-color: var(--accent-color);
    }

    .chip .emoji { margin-right: 0.375rem; }

    /* Filters row */
    .filters-row {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
      align-items: end;
    }

    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    .filter-group label {
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .filter-group select {
      padding: 0.5rem 0.75rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      background: var(--card-bg, var(--bg-color));
      color: var(--text-primary);
      font-size: 0.9375rem;
      font-family: var(--font-ui);
      min-width: 160px;
    }

    /* Buttons */
    .btn {
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      font-family: var(--font-ui);
    }

    .btn-primary {
      background: var(--accent-color);
      color: #fff;
    }

    .btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }

    .btn-secondary {
      background: transparent;
      color: var(--accent-color);
      border: 2px solid var(--accent-color);
    }

    .btn-secondary:hover { background: var(--accent-color); color: #fff; }

    .btn-surprise {
      background: linear-gradient(135deg, #f59e0b, #ef4444, #8b5cf6);
      color: #fff;
      font-size: 1.0625rem;
      padding: 0.875rem 2rem;
    }

    .btn-surprise:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 8px 24px rgba(245,158,11,0.3); }

    .btn-row {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    /* Idea cards */
    .ideas-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .idea-card {
      background: var(--card-bg, rgba(255,255,255,0.05));
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      transition: all 0.25s;
      position: relative;
    }

    .idea-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }

    .idea-card .card-cat {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--accent-color);
      margin-bottom: 0.375rem;
    }

    .idea-card .card-title {
      font-size: 1.0625rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .idea-card .card-desc {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 0.75rem;
      line-height: 1.5;
    }

    .idea-card .card-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-size: 0.8125rem;
    }

    .meta-tag {
      padding: 0.25rem 0.625rem;
      border-radius: 6px;
      background: rgba(255,255,255,0.07);
      font-weight: 500;
    }

    .diff-easy { color: #34d399; }
    .diff-medium { color: #fbbf24; }
    .diff-hard { color: #f97316; }
    .diff-epic { color: #f43f5e; }

    .idea-card .card-actions { margin-top: 0.75rem; }

    .btn-add-small {
      padding: 0.375rem 0.75rem;
      border: 1.5px solid var(--accent-color);
      border-radius: 6px;
      background: transparent;
      color: var(--accent-color);
      font-size: 0.8125rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: var(--font-ui);
    }

    .btn-add-small:hover { background: var(--accent-color); color: #fff; }
    .btn-add-small.added { background: #34d399; color: #fff; border-color: #34d399; pointer-events: none; }

    /* Surprise animation */
    .surprise-area { text-align: center; margin: 2rem 0; }

    .surprise-card {
      display: none;
      max-width: 480px;
      margin: 1.5rem auto 0;
      text-align: left;
    }

    .surprise-card.visible { display: block; animation: popIn 0.4s cubic-bezier(0.34,1.56,0.64,1); }

    @keyframes popIn {
      0% { opacity: 0; transform: scale(0.8) rotate(-2deg); }
      100% { opacity: 1; transform: scale(1) rotate(0); }
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .spinning { animation: spin 0.6s ease-out; display: inline-block; }

    /* My list */
    .my-list-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .progress-bar-container {
      width: 100%;
      max-width: 400px;
      background: rgba(255,255,255,0.1);
      border-radius: 12px;
      overflow: hidden;
      height: 24px;
      position: relative;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent-color), #34d399);
      border-radius: 12px;
      transition: width 0.5s ease;
      min-width: 0;
    }

    .progress-text {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 1px 2px rgba(0,0,0,0.4);
    }

    .status-filters {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .status-chip {
      padding: 0.375rem 0.875rem;
      border-radius: 20px;
      font-size: 0.8125rem;
      font-weight: 600;
      cursor: pointer;
      border: 1.5px solid var(--border-color);
      background: transparent;
      color: var(--text-primary);
      transition: all 0.2s;
      font-family: var(--font-ui);
    }

    .status-chip.active { border-color: var(--accent-color); background: var(--accent-color); color: #fff; }

    .my-list-items { display: flex; flex-direction: column; gap: 0.75rem; }

    .list-item {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      background: var(--card-bg, rgba(255,255,255,0.05));
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 1rem;
      transition: all 0.2s;
    }

    .list-item:hover { border-color: var(--accent-color); }

    .list-item-status {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 2px solid var(--border-color);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      transition: all 0.2s;
      background: transparent;
      color: var(--text-primary);
      font-family: var(--font-ui);
    }

    .list-item-status.status-want { border-color: #60a5fa; }
    .list-item-status.status-progress { border-color: #fbbf24; background: rgba(251,191,36,0.15); }
    .list-item-status.status-done { border-color: #34d399; background: #34d399; color: #fff; }

    .list-item-body { flex: 1; min-width: 0; }

    .list-item-title { font-weight: 700; font-size: 0.9375rem; }

    .list-item-cat {
      font-size: 0.75rem;
      color: var(--accent-color);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .list-item-notes {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
      font-style: italic;
    }

    .list-item-date {
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .list-item-actions {
      display: flex;
      gap: 0.375rem;
      flex-shrink: 0;
    }

    .btn-icon {
      width: 32px;
      height: 32px;
      border: 1.5px solid var(--border-color);
      border-radius: 6px;
      background: transparent;
      color: var(--text-secondary);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.875rem;
      transition: all 0.2s;
    }

    .btn-icon:hover { border-color: var(--accent-color); color: var(--accent-color); }
    .btn-icon.delete:hover { border-color: #f43f5e; color: #f43f5e; }

    /* Custom idea form */
    .custom-form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      background: var(--card-bg, rgba(255,255,255,0.05));
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .custom-form .full { grid-column: 1 / -1; }

    .custom-form input,
    .custom-form select,
    .custom-form textarea {
      width: 100%;
      padding: 0.5rem 0.75rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      background: var(--bg-color);
      color: var(--text-primary);
      font-size: 0.9375rem;
      font-family: var(--font-ui);
    }

    .custom-form textarea { resize: vertical; min-height: 60px; }

    .custom-form label {
      display: block;
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-bottom: 0.25rem;
    }

    /* Stats */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }

    .stat-card {
      background: var(--card-bg, rgba(255,255,255,0.05));
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      text-align: center;
    }

    .stat-number {
      font-size: 2rem;
      font-weight: 800;
      color: var(--accent-color);
    }

    .stat-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .cat-bar-chart { margin-top: 1.5rem; }

    .cat-bar-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }

    .cat-bar-label {
      width: 120px;
      font-size: 0.8125rem;
      font-weight: 600;
      text-align: right;
      flex-shrink: 0;
    }

    .cat-bar-track {
      flex: 1;
      height: 20px;
      background: rgba(255,255,255,0.07);
      border-radius: 6px;
      overflow: hidden;
    }

    .cat-bar-fill {
      height: 100%;
      border-radius: 6px;
      background: var(--accent-color);
      transition: width 0.5s ease;
    }

    .cat-bar-count {
      width: 30px;
      font-size: 0.8125rem;
      font-weight: 700;
      color: var(--text-secondary);
    }

    /* FAQ */
    details {
      background: var(--card-bg, rgba(255,255,255,0.05));
      border: 1px solid var(--border-color);
      border-radius: 10px;
      margin-bottom: 0.75rem;
      transition: border-color 0.2s;
    }

    details:hover { border-color: var(--accent-color); }
    details[open] { border-color: var(--accent-color); }

    summary {
      padding: 1rem 1.25rem;
      font-weight: 600;
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    summary::-webkit-details-marker { display: none; }
    summary::after { content: "+"; font-size: 1.25rem; font-weight: 400; color: var(--text-secondary); }
    details[open] summary::after { content: "−"; }

    details .answer { padding: 0 1.25rem 1rem; color: var(--text-secondary); font-size: 0.9375rem; line-height: 1.7; }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--text-secondary);
    }

    .empty-state .empty-icon { font-size: 3rem; margin-bottom: 1rem; }

    /* Modal overlay */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 999;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .modal-overlay.visible { display: flex; }

    .modal {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      max-width: 400px;
      width: 100%;
    }

    .modal h3 { margin-bottom: 1rem; }

    .modal textarea {
      width: 100%;
      padding: 0.5rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      background: var(--card-bg, rgba(255,255,255,0.05));
      color: var(--text-primary);
      font-size: 0.9375rem;
      font-family: var(--font-ui);
      min-height: 80px;
      resize: vertical;
      margin-bottom: 0.75rem;
    }

    .modal input[type="date"] {
      width: 100%;
      padding: 0.5rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      background: var(--card-bg, rgba(255,255,255,0.05));
      color: var(--text-primary);
      font-size: 0.9375rem;
      font-family: var(--font-ui);
      margin-bottom: 0.75rem;
    }

    .modal .btn-row { justify-content: flex-end; }

    .no-results { padding: 2rem; text-align: center; color: var(--text-secondary); }

    @media (max-width: 640px) {
      h1 { font-size: 1.75rem; }
      .ideas-grid { grid-template-columns: 1fr; }
      .custom-form { grid-template-columns: 1fr; }
      .filters-row { flex-direction: column; }
      .filter-group select { min-width: 100%; }
      .cat-bar-label { width: 80px; font-size: 0.75rem; }
      .list-item { flex-direction: column; }
      .list-item-actions { align-self: flex-end; }
      .my-list-header { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <div class="container">
    <header>
      <h1>Bucket List Ideas</h1>
      <p class="subtitle">150+ curated experiences across 10 categories. Generate ideas, build your list, and track every adventure from dream to done.</p>
    </header>

    <!-- Tabs -->
    <div class="tabs">
      <button class="tab-btn active" data-tab="generator">Generator</button>
      <button class="tab-btn" data-tab="mylist">My Bucket List</button>
      <button class="tab-btn" data-tab="stats">Stats</button>
    </div>

    <!-- ========== GENERATOR TAB ========== -->
    <div id="tab-generator" class="tab-panel active">
      <section>
        <h2>Pick Categories</h2>
        <div class="chip-grid" id="catChips"></div>

        <div class="filters-row">
          <div class="filter-group">
            <label>Cost Range</label>
            <select id="filterCost">
              <option value="all">Any cost</option>
              <option value="free">Free</option>
              <option value="$">$ (Under $100)</option>
              <option value="$$">$$ ($100 – $500)</option>
              <option value="$$$">$$$ ($500 – $2,000)</option>
              <option value="$$$$">$$$$ ($2,000+)</option>
            </select>
          </div>
          <div class="filter-group">
            <label>Difficulty</label>
            <select id="filterDiff">
              <option value="all">Any difficulty</option>
              <option value="easy">Easy</option>
              <option value="medium">Medium</option>
              <option value="hard">Hard</option>
              <option value="epic">Epic</option>
            </select>
          </div>
          <div class="filter-group">
            <label>Type</label>
            <select id="filterType">
              <option value="all">Solo & Group</option>
              <option value="solo">Solo-friendly</option>
              <option value="group">Best with others</option>
            </select>
          </div>
        </div>

        <div class="btn-row">
          <button class="btn btn-primary" id="btnGenerate">Generate Ideas</button>
          <button class="btn btn-surprise" id="btnSurprise">🎲 Surprise Me</button>
        </div>

        <div class="surprise-area">
          <div class="surprise-card" id="surpriseCard"></div>
        </div>

        <div class="ideas-grid" id="ideasGrid"></div>
        <div class="no-results" id="noResults" style="display:none;">No ideas match your filters. Try broadening your selection.</div>
      </section>
    </div>

    <!-- ========== MY LIST TAB ========== -->
    <div id="tab-mylist" class="tab-panel">
      <section>
        <h2>My Bucket List</h2>

        <div class="my-list-header">
          <div class="progress-bar-container">
            <div class="progress-fill" id="progressFill" style="width:0%"></div>
            <div class="progress-text" id="progressText">0 / 0 completed</div>
          </div>
          <div class="btn-row">
            <button class="btn btn-secondary" id="btnExport">Export List</button>
          </div>
        </div>

        <div class="status-filters">
          <button class="status-chip active" data-status="all">All</button>
