---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Best Packing List for Southeast Asia",
  description: "Ultimate SE Asia packing list: carry-on only strategy, clothing, toiletries, electronics, first aid, documents, and money.",
  category: "guide",
  published: "2026-03-22"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Packing List for Southeast Asia",
    "url": "https://migratingmammals.com/packing-list-southeast-asia",
    "description": "Ultimate SE Asia packing list: carry-on only strategy, clothing, toiletries, electronics, first aid, documents, and money.",
    "author": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "migratingmammals.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://migratingmammals.com/logo.png"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is it possible to travel Southeast Asia with just a carry-on?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! A 40L backpack is the perfect size. It forces you to pack light, saves money on checked bag fees, and makes navigating crowded streets and ferries much easier."
        }
      },
      {
        "@type": "Question",
        "name": "What kind of clothes should I pack for Southeast Asia?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pack lightweight, breathable, and quick-dry clothing. Avoid heavy jeans. Bring modest options (like linen pants or a sarong) that cover your shoulders and knees for temple visits."
        }
      },
      {
        "@type": "Question",
        "name": "Should I bring a mosquito net?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, it's usually not necessary. Most hostels and guesthouses provide them if needed, or they have AC and sealed windows. Just bring a good mosquito repellent with DEET or Picaridin."
        }
      },
      {
        "@type": "Question",
        "name": "How should I handle money in Southeast Asia?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Carry a travel card with zero foreign transaction fees, like the Wise card or Charles Schwab debit card. Always have some local cash on hand for street food and small purchases, as many places are cash-only."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need to pack all my toiletries?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bring travel-sized essentials for the first few days, but buy the rest locally at 7-Eleven or pharmacies. You can find almost everything you need in major hubs like Bangkok or Bali, often cheaper."
        }
      }
    ]
  }
];

const countrySpecific = [
  { country: "Thailand", item: "Slip-on shoes for easy removal at temples and shops." },
  { country: "Vietnam", item: "A light jacket or sweater for the cooler northern regions (Hanoi, Sapa)." },
  { country: "Cambodia", item: "Crisp, unblemished US Dollar bills (widely accepted and often required for visas)." },
  { country: "Indonesia", item: "A high-quality dry bag for boat trips and island hopping." },
  { country: "Philippines", item: "Water shoes for rocky beaches and coral reefs." },
  { country: "Laos", item: "Modest swimwear (board shorts or a t-shirt over a swimsuit) for public rivers and waterfalls." }
];
---

<SiteLayout
  site="migratingmammals"
  title="Best Packing List for Southeast Asia"
  description="Ultimate SE Asia packing list: carry-on only strategy, clothing, toiletries, electronics, first aid, documents, and money."
  canonical="https://migratingmammals.com/packing-list-southeast-asia"
  schema={JSON.stringify(schema)}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    .page-wrapper {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .header-section {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(180deg, var(--card-bg) 0%, var(--bg-color) 100%);
      border-bottom: 1px solid var(--border-color);
    }
    .header-section h1 {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 15px;
      letter-spacing: -0.02em;
    }
    .header-section p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

    .content-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 30px;
      margin-bottom: 40px;
    }
    .content-section h2 {
      font-size: 1.8rem;
      color: var(--text-primary);
      margin-bottom: 20px;
    }
    .content-section h3 {
      font-size: 1.3rem;
      color: var(--text-primary);
      margin-top: 15px;
      margin-bottom: 10px;
    }
    .content-section p {
      margin-bottom: 15px;
      color: var(--text-secondary);
    }
    .content-section ul, .content-section ol {
      margin-left: 20px;
      color: var(--text-secondary);
      margin-bottom: 15px;
    }
    .content-section li {
      margin-bottom: 8px;
    }

    .chains-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }
    .chain-card {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
    }
    .chain-card h3 {
      margin-top: 0;
      color: var(--text-primary);
    }
    .chain-card p {
      margin-bottom: 0;
    }

    .faq-section {
      margin-top: 60px;
    }
    .faq-section h2 {
      font-size: 2rem;
      margin-bottom: 20px;
      color: var(--text-primary);
      text-align: center;
    }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 15px;
    }
    .faq-question {
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--text-primary);
      margin-bottom: 10px;
    }
    .faq-answer {
      color: var(--text-secondary);
    }
  </style>

  <div class="page-wrapper">
    <div class="header-section">
      <h1>Best Packing List for Southeast Asia</h1>
      <p>The ultimate SE Asia packing list: master the carry-on only strategy and bring exactly what you need.</p>
    </div>

    <div class="container">
      <div class="content-section">
        <h2>The Carry-On Only Strategy</h2>
        <p>Traveling Southeast Asia with just a carry-on (typically a 40L backpack) is the best decision you can make. It saves you money on budget airline baggage fees, prevents lost luggage, and makes moving through crowded streets, jumping on ferries, or squeezing into minivans significantly less stressful. You will need less than you think.</p>
      </div>

      <div class="content-section">
        <h2>Clothing Essentials</h2>
        <p>The heat and humidity are intense. Prioritize lightweight, breathable, and quick-dry fabrics (like linen, merino wool blends, or athletic synthetics). Leave heavy denim at home.</p>
        <ul>
          <li><strong>T-shirts / Tank tops:</strong> 4-5 total.</li>
          <li><strong>Shorts:</strong> 2-3 pairs.</li>
          <li><strong>Temple Wear:</strong> 1 pair of lightweight pants (elephant pants are popular) and a shirt that covers shoulders. Sarongs are also great for quick temple cover-ups.</li>
          <li><strong>Swimwear:</strong> 2 pairs so one can dry while you wear the other.</li>
          <li><strong>Underwear & Socks:</strong> 5-7 pairs of quick-dry underwear; 3 pairs of socks.</li>
          <li><strong>Footwear:</strong> 1 pair of comfortable walking/hiking shoes, and 1 pair of durable sandals or flip-flops (essential for showers and beaches).</li>
        </ul>
      </div>

      <div class="content-section">
        <h2>Toiletries & First Aid</h2>
        <h3>What to Bring vs. Buy There</h3>
        <p>Southeast Asia has excellent pharmacies and ubiquitous convenience stores (like 7-Eleven in Thailand). Buy heavy liquids like shampoo, conditioner, and body wash locally.</p>
        <p><strong>Bring these from home:</strong> Sunscreen (it's expensive and often contains skin-whitening ingredients in Asia), your preferred deodorant, feminine hygiene products (tampons can be hard to find outside major cities), and any prescription medications.</p>

        <h3>First Aid Kit</h3>
        <ul>
          <li><strong>Traveler's Diarrhea Kit:</strong> Loperamide (Imodium), rehydration salts (electrolytes), and maybe a doctor-prescribed antibiotic.</li>
          <li><strong>Mosquito Repellent:</strong> Bring a good repellent containing DEET or Picaridin.</li>
          <li>Basic painkillers (Ibuprofen/Paracetamol), motion sickness pills (for bumpy bus and boat rides), and a few bandaids.</li>
        </ul>
      </div>

      <div class="content-section">
        <h2>Electronics & Documents</h2>
        <h3>Electronics</h3>
        <ul>
          <li><strong>Universal Adapter:</strong> Essential as plug types vary by country.</li>
          <li><strong>Power Bank:</strong> Crucial for long bus rides and navigating with your phone. (10,000mAh - 20,000mAh is ideal).</li>
          <li>Unlocked smartphone (for local SIM cards or eSIMs), e-reader (optional), and necessary charging cables.</li>
        </ul>

        <h3>Documents & Money</h3>
        <ul>
          <li><strong>Passport:</strong> With at least 6 months validity and plenty of blank pages.</li>
          <li><strong>Visas:</strong> Check requirements for each country beforehand; print e-visas or prepare passport photos for visa-on-arrival.</li>
          <li><strong>Money Strategy:</strong> Cash is king in SE Asia. Use a travel card with zero foreign transaction fees and ATM fee reimbursements (like the Wise card or Charles Schwab debit card). Always carry some small denominations of local currency for street food and tuk-tuks.</li>
        </ul>
      </div>

      <div class="content-section">
        <h2>Monsoon Season Gear & Daypack</h2>
        <p>If you're traveling during the rainy season, pack a lightweight, breathable rain jacket or simply buy a cheap poncho locally. A waterproof cover for your main backpack is highly recommended.</p>
        <p><strong>Daypack:</strong> A 15-20L daypack is essential for daily excursions, carrying water, sunscreen, and your camera. Look for a packable one that folds down small when not in use.</p>
      </div>

      <div class="content-section">
        <h2>Country-Specific Items</h2>
        <div class="chains-grid">
          {countrySpecific.map(item => (
            <div class="chain-card">
              <h3>{item.country}</h3>
              <p>{item.item}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {schema[1].mainEntity.map((faq: any) => (
          <div class="faq-item">
            <div class="faq-question">{faq.name}</div>
            <div class="faq-answer">{faq.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</SiteLayout>
