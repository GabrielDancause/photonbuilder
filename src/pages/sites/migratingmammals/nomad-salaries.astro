---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Digital Nomad Average Salaries by Role 2026",
      "description": "Comprehensive study of remote worker salaries across common remote-friendly roles, aggregated from multiple remote job boards.",
      "author": {
        "@type": "Organization",
        "name": "migratingmammals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "migratingmammals.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://migratingmammals.com/logo.png"
        }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the highest paying remote job?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Based on our 2026 data, engineering and specialized finance roles tend to be the highest paying remote positions, often exceeding $140,000 USD in median base salary."
          }
        },
        {
          "@type": "Question",
          "name": "How much do remote software engineers make?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Remote software engineers typically earn a median salary between $98,000 and $145,000 depending on specialization (Frontend, Backend, DevOps) and experience level."
          }
        },
        {
          "@type": "Question",
          "name": "Are remote jobs paying less in 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While base salaries have stabilized, top-tier remote roles still command premium compensation, particularly in tech and data sectors, though increased global competition has impacted junior roles."
          }
        },
        {
          "@type": "Question",
          "name": "Which non-tech remote jobs pay the most?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sales Representatives and Finance Managers are among the highest paying non-engineering remote roles, with medians frequently crossing the $140,000 threshold."
          }
        },
        {
          "@type": "Question",
          "name": "Where does this salary data come from?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Data is aggregated from major remote job boards including RemoteOK, We Work Remotely, and Remotive, specifically filtering for listings that provide explicit salary ranges."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="migratingmammals"
  title="Digital Nomad Average Salaries by Role 2026"
  description="Compare remote worker salaries across 30+ remote-friendly roles including engineering, design, marketing, and more."
  canonical="" schema={schema}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #0a0b10;
      color: #e0d5c8;
      line-height: 1.6;
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: 100px 24px 60px;
      background: linear-gradient(180deg, #1a0f08 0%, #0a0b10 100%);
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 40%, rgba(196,149,106,0.08) 0%, transparent 60%);
    }
    .hero-content { position: relative; z-index: 1; max-width: 800px; margin: 0 auto; }
    .tagline {
      color: #C4956A;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 16px;
      display: inline-block;
      background: rgba(196,149,106,0.1);
      padding: 6px 16px;
      border-radius: 20px;
    }
    .hero h1 {
      font-size: 3rem;
      font-weight: 900;
      letter-spacing: -1px;
      margin-bottom: 20px;
      color: #fff;
    }
    .hero p {
      color: #888;
      font-size: 1.1rem;
    }

    /* Container */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px;
    }

    /* Stats summary */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 60px;
    }
    .stat-card {
      background: #111318;
      border: 1px solid #1e2030;
      border-radius: 12px;
      padding: 24px;
      text-align: center;
    }
    .stat-val {
      font-family: 'JetBrains Mono', monospace;
      font-size: 2rem;
      font-weight: 600;
      color: #C4956A;
      margin-bottom: 8px;
    }
    .stat-label {
      font-size: 0.85rem;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* Toolbar */
    .toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      gap: 16px;
      flex-wrap: wrap;
    }
    .search-box {
      flex: 1;
      min-width: 250px;
    }
    .search-input {
      width: 100%;
      background: #111318;
      border: 1px solid #1e2030;
      color: #fff;
      padding: 12px 16px;
      border-radius: 8px;
      font-family: inherit;
      font-size: 1rem;
    }
    .search-input:focus {
      outline: none;
      border-color: #C4956A;
    }
    .filter-group {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .filter-btn {
      background: #111318;
      border: 1px solid #1e2030;
      color: #888;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .filter-btn:hover { border-color: #C4956A; color: #fff; }
    .filter-btn.active { background: rgba(196,149,106,0.1); border-color: #C4956A; color: #C4956A; }

    /* Table */
    .table-container {
      background: #111318;
      border: 1px solid #1e2030;
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 60px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    th {
      background: rgba(30,32,48,0.5);
      padding: 16px 20px;
      font-size: 0.85rem;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
      cursor: pointer;
      user-select: none;
    }
    th:hover { color: #fff; }
    th.sort-asc::after { content: ' ↑'; color: #C4956A; }
    th.sort-desc::after { content: ' ↓'; color: #C4956A; }
    td {
      padding: 20px;
      border-top: 1px solid #1e2030;
      font-size: 1rem;
    }
    .role-cell { font-weight: 600; color: #fff; }
    .cat-badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 0.75rem;
      background: #1e2030;
      color: #888;
    }
    .salary-cell {
      font-family: 'JetBrains Mono', monospace;
      color: #C4956A;
      font-weight: 500;
    }
    .range-cell {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem;
      color: #888;
    }
    .count-cell {
      font-size: 0.9rem;
      color: #888;
    }

    /* Content sections */
    .content-section {
      max-width: 800px;
      margin: 0 auto 60px;
    }
    .content-section h2 {
      font-size: 2rem;
      margin-bottom: 24px;
      color: #fff;
      border-bottom: 1px solid #1e2030;
      padding-bottom: 12px;
    }
    .faq-item {
      margin-bottom: 24px;
    }
    .faq-q {
      font-size: 1.1rem;
      font-weight: 600;
      color: #C4956A;
      margin-bottom: 8px;
    }
    .faq-a {
      color: #888;
    }
    .methodology p {
      color: #888;
      margin-bottom: 16px;
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 50px 24px;
      font-size: 0.85rem;
      color: #888;
      border-top: 1px solid #1e2030;
      background: #0a0b10;
    }
    .footer a {
      color: #C4956A;
      text-decoration: none;
    }
    .footer a:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .hero h1 { font-size: 2.2rem; }
      .toolbar { flex-direction: column; align-items: stretch; }
      .search-box { width: 100%; }
      td, th { padding: 12px 16px; }
      .range-cell { display: none; } /* hide range on mobile to save space */
    }
  </style>

<div class="hero">
    <div class="hero-content">
      <div class="tagline">Original Research</div>
      <h1>Digital Nomad Average Salaries 2026</h1>
      <p>What do remote workers actually earn? We analyzed current remote job listings to find the real market rates across popular digital nomad roles.</p>
    </div>
  </div>

  <div class="container">
    <div class="stats-grid" id="stats-grid">
      <!-- Stats injected here -->
    </div>

    <div class="toolbar">
      <div class="search-box">
        <input type="text" id="search-input" class="search-input" placeholder="Search roles...">
      </div>
      <div class="filter-group" id="filter-group">
        <button class="filter-btn active" data-category="All">All Roles</button>
        <!-- Categories injected here -->
      </div>
    </div>

    <div class="table-container">
      <table id="salary-table">
        <thead>
          <tr>
            <th data-sort="role">Role</th>
            <th data-sort="category">Category</th>
            <th data-sort="medianSalaryUSD" class="sort-desc">Median Salary (USD)</th>
            <th data-sort="p25">25th - 75th Percentile</th>
            <th data-sort="remoteListings">Listings Analyzed</th>
          </tr>
        </thead>
        <tbody id="table-body">
          <!-- Rows injected here -->
        </tbody>
      </table>
    </div>

    <div class="content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q">What is the highest paying remote job?</div>
        <div class="faq-a">Based on our 2026 data, specialized engineering (like Frontend and DevOps) and senior finance roles are the highest paying remote positions, often exceeding $140,000 USD in median base salary.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How much do remote software engineers make?</div>
        <div class="faq-a">Remote software engineers typically earn a median salary between $98,000 and $145,000 depending on their specific domain (Frontend, Backend, Full Stack, DevOps) and experience level.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Are remote jobs paying less in 2026?</div>
        <div class="faq-a">While the massive hiring spikes of previous years have stabilized, top-tier remote roles still command premium compensation. However, increased global competition means companies often have more leverage, especially for entry-level positions.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Which non-tech remote jobs pay the most?</div>
        <div class="faq-a">Sales Representatives, Customer Success Managers, and Finance Managers are among the highest paying non-engineering remote roles, with medians frequently crossing the $140,000 threshold.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Where does this salary data come from?</div>
        <div class="faq-a">Data is algorithmically aggregated from major remote job boards including RemoteOK, We Work Remotely, and Remotive. We specifically filter for listings that provide explicit, transparent salary ranges to calculate our medians and percentiles.</div>
      </div>
    </div>

    <div class="content-section methodology">
      <h2>Methodology</h2>
      <p>We collected data by scraping and parsing live remote job listings across major platforms (RemoteOK, We Work Remotely, and Remotive). We specifically targeted listings that provided explicit salary ranges or base compensation figures.</p>
      <p>For each matched role, we calculated the median, 25th percentile, and 75th percentile based on the average of the provided salary ranges. Roles with insufficient data points or without transparent salary listings were excluded from the final results to ensure accuracy over speculation (null over fake data).</p>
      <p>All figures are presented in USD and generally represent Mid-to-Senior level base compensation, excluding equity, bonuses, or localized cost-of-living adjustments unless explicitly stated in the listing.</p>
    </div>
  </div>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-digital-nomad-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">The Complete Guide to Becoming a Digital Nomad</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
