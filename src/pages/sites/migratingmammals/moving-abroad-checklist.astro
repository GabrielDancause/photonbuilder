var STORAGE_KEY = "mm_moving_abroad_checklist";

function $(id) { return document.getElementById(id); }

function loadState() {
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    if (raw) return JSON.parse(raw);
  } catch (e) { /* ignore */ }
  return null;
}

function saveState(checked) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ checked: checked, ts: Date.now() }));
  } catch (e) { /* ignore */ }
}

function clearState() {
  try { localStorage.removeItem(STORAGE_KEY); } catch (e) { /* ignore */ }
}

function getItemKey(phase, cat, idx) {
  return phase + "::" + cat + "::" + idx;
}

function countAll(checkedMap) {
  var total = 0, done = 0;
  Object.keys(CHECKLIST_DATA).forEach(function(phase) {
    var cats = CHECKLIST_DATA[phase].categories;
    Object.keys(cats).forEach(function(catKey) {
      cats[catKey].items.forEach(function(item, idx) {
        total++;
        if (checkedMap[getItemKey(phase, catKey, idx)]) done++;
      });
    });
  });
  return { total: total, done: done };
}

function countPhase(phase, checkedMap) {
  var total = 0, done = 0;
  var cats = CHECKLIST_DATA[phase].categories;
  Object.keys(cats).forEach(function(catKey) {
    cats[catKey].items.forEach(function(item, idx) {
      total++;
      if (checkedMap[getItemKey(phase, catKey, idx)]) done++;
    });
  });
  return { total: total, done: done };
}

function updateProgress(checkedMap) {
  var c = countAll(checkedMap);
  $("progress-text").textContent = c.done + " / " + c.total + " tasks complete";
  var pct = c.total > 0 ? Math.round((c.done / c.total) * 100) : 0;
  $("progress-percent").textContent = pct + "%";
  $("progress-bar").style.width = pct + "%";
}

function renderChecklist(checkedMap, filter) {
  var output = $("checklist-output");
  output.innerHTML = "";

  Object.keys(CHECKLIST_DATA).forEach(function(phaseKey) {
    if (filter !== "all" && filter !== phaseKey) return;

    var phase = CHECKLIST_DATA[phaseKey];
    var phaseCount = countPhase(phaseKey, checkedMap);

    var section = document.createElement("div");
    section.className = "timeline-section";

    var headerHtml = '<div class="timeline-header">' +
      '<span class="timeline-badge">' + phase.label + '</span>' +
      '<span class="timeline-progress">' + phaseCount.done + '/' + phaseCount.total + '</span>' +
      '</div>';

    var gridHtml = '<div class="checklist-grid">';

    Object.keys(phase.categories).forEach(function(catKey) {
      var cat = phase.categories[catKey];
      var catDone = 0;
      cat.items.forEach(function(item, idx) {
        if (checkedMap[getItemKey(phaseKey, catKey, idx)]) catDone++;
      });

      gridHtml += '<div class="category-card">';
      gridHtml += '<div class="category-header"><h4>' + cat.label + '</h4><span class="category-count">' + catDone + '/' + cat.items.length + '</span></div>';

      cat.items.forEach(function(item, idx) {
        var key = getItemKey(phaseKey, catKey, idx);
        var isChecked = !!checkedMap[key];
        gridHtml += '<div class="checklist-item' + (isChecked ? " checked" : "") + '">' +
          '<input type="checkbox" ' + (isChecked ? "checked" : "") + ' data-key="' + key + '">' +
          '<span class="item-label">' + item + '</span>' +
          '</div>';
      });

      gridHtml += '</div>';
    });

    gridHtml += '</div>';

    section.innerHTML = headerHtml + gridHtml;
    output.appendChild(section);
  });

  // Checkbox listeners
  output.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
    cb.addEventListener("change", function() {
      checkedMap[cb.dataset.key] = cb.checked;
      if (!cb.checked) delete checkedMap[cb.dataset.key];
      cb.closest(".checklist-item").classList.toggle("checked", cb.checked);
      saveState(checkedMap);
      updateProgress(checkedMap);

      // Update category count
      var card = cb.closest(".category-card");
      var cbs = card.querySelectorAll('input[type="checkbox"]');
      var catDone = 0;
      cbs.forEach(function(c) { if (c.checked) catDone++; });
      card.querySelector(".category-count").textContent = catDone + "/" + cbs.length;

      // Update phase count
      var sec = cb.closest(".timeline-section");
      var allCbs = sec.querySelectorAll('input[type="checkbox"]');
      var phaseDone = 0;
      allCbs.forEach(function(c) { if (c.checked) phaseDone++; });
      sec.querySelector(".timeline-progress").textContent = phaseDone + "/" + allCbs.length;
    });
  });
}

// Init
var checkedMap = {};
var saved = loadState();
if (saved && saved.checked) {
  checkedMap = saved.checked;
}

var currentFilter = "all";

renderChecklist(checkedMap, currentFilter);
updateProgress(checkedMap);

// Filter buttons
$("filter-bar").addEventListener("click", function(e) {
  var btn = e.target.closest(".filter-btn");
  if (!btn) return;
  currentFilter = btn.dataset.filter;
  $("filter-bar").querySelectorAll(".filter-btn").forEach(function(b) { b.classList.remove("active"); });
  btn.classList.add("active");
  renderChecklist(checkedMap, currentFilter);
});

// Action buttons
$("btn-check-all").addEventListener("click", function() {
  Object.keys(CHECKLIST_DATA).forEach(function(phase) {
    var cats = CHECKLIST_DATA[phase].categories;
    Object.keys(cats).forEach(function(catKey) {
      cats[catKey].items.forEach(function(item, idx) {
        checkedMap[getItemKey(phase, catKey, idx)] = true;
      });
    });
  });
  saveState(checkedMap);
  renderChecklist(checkedMap, currentFilter);
  updateProgress(checkedMap);
});

$("btn-uncheck-all").addEventListener("click", function() {
  checkedMap = {};
  saveState(checkedMap);
  renderChecklist(checkedMap, currentFilter);
  updateProgress(checkedMap);
});

$("btn-reset").addEventListener("click", function() {
  checkedMap = {};
  clearState();
  renderChecklist(checkedMap, currentFilter);
  updateProgress(checkedMap);
});
  </script>

