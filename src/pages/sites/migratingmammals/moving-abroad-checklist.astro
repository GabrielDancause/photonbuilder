---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Moving Abroad Checklist — International Relocation Planner",
    "url": "https://migratingmammals.com/moving-abroad-checklist",
    "applicationCategory": "LifestyleApplication",
    "operatingSystem": "All",
    "description": "Interactive moving abroad checklist organized by timeline — 6 months to first month after arrival. Track documents, finances, housing, healthcare, logistics, and digital tasks with localStorage persistence and progress tracking.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How far in advance should I start planning a move abroad?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Start planning at least 6 months before your move date. This gives you time to research visa requirements, gather and apostille documents, sort out finances, notify employers, arrange housing, and handle logistics like international shipping and pet relocation. Some visa applications can take 3-6 months to process, so early planning is essential."
        }
      },
      {
        "@type": "Question",
        "name": "What documents do I need to move to another country?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Essential documents include: a valid passport (with at least 12 months validity), visa or residence permit, apostilled birth certificate, apostilled marriage certificate (if applicable), medical records and vaccination history, police clearance certificate, academic transcripts and diplomas, employment references, international driving permit, and multiple certified copies of all documents. Requirements vary by country, so check your destination's specific consulate requirements."
        }
      },
      {
        "@type": "Question",
        "name": "How do I manage my finances when moving abroad?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Open a multi-currency bank account or international-friendly account (like Wise or Revolut) before you move. Notify your current bank of your relocation, understand tax obligations in both countries, research whether a tax treaty exists, set up mail forwarding for financial documents, transfer funds gradually to get better exchange rates, and keep at least one bank account in your home country for any ongoing obligations."
        }
      },
      {
        "@type": "Question",
        "name": "What should I do about healthcare when relocating internationally?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Research the healthcare system in your destination country and arrange international health insurance that covers you during the transition. Get a full medical and dental checkup before leaving, request copies of all medical records, stock up on prescription medications (with documentation), check required vaccinations for your destination, and research how to register with local healthcare providers upon arrival."
        }
      },
      {
        "@type": "Question",
        "name": "How do I ship my belongings to another country?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Get quotes from at least 3 international moving companies. Decide between sea freight (cheaper, 4-8 weeks) and air freight (faster, more expensive). Create a detailed inventory of items, check customs restrictions for your destination, purchase international moving insurance, and start decluttering early — often it's cheaper to sell furniture and rebuy than to ship. Keep essential items in your carry-on luggage for the first few weeks."
        }
      }
    ]
  }
];

export const meta = {
  title: "Moving Abroad Checklist — Relocation Planner 2026",
  description: "Interactive moving abroad checklist with timeline from 6 months before to first month after arrival. Track documents, finances, housing, healthcare, logistics, and digital setup tasks.",
  category: "tool",
  published: "2026-03-21",
};
