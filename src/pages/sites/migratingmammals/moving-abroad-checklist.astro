    }

    .action-bar {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .btn-small {
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.5rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.8rem;
      cursor: pointer;
      transition: border-color 0.2s;
    }

