  { name: "Dubai", region: "Middle East", budget: { accom: 35, food: 20, transport: 10, activities: 12, misc: 6 }, mid: { accom: 130, food: 50, transport: 22, activities: 30, misc: 15 }, luxury: { accom: 400, food: 120, transport: 50, activities: 70, misc: 40 } },
