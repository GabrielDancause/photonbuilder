var CATEGORIES = [
  { key: "accom", label: "Accommodation", color: "#4f8cff" },
  { key: "food", label: "Food & Dining", color: "#34d399" },
  { key: "transport", label: "Transport", color: "#fbbf24" },
  { key: "activities", label: "Activities", color: "#a78bfa" },
  { key: "misc", label: "Miscellaneous", color: "#f87171" }
];

var CURRENCY_RATES = { USD: 1, EUR: 0.92, GBP: 0.79, CAD: 1.36, AUD: 1.53 };
var CURRENCY_SYMBOLS = { USD: "$", EUR: "\u20ac", GBP: "\u00a3", CAD: "C$", AUD: "A$" };

var customCosts = null;
var currentDest = null;

function $(id) { return document.getElementById(id); }

/* Populate destination dropdown */
function populateDestinations() {
  var sel = $("cfg-destination");
  var regions = {};
  DESTINATIONS.forEach(function(d) {
    if (!regions[d.region]) regions[d.region] = [];
    regions[d.region].push(d);
  });
  Object.keys(regions).sort().forEach(function(region) {
    var group = document.createElement("optgroup");
    group.label = region;
    regions[region].sort(function(a, b) { return a.name.localeCompare(b.name); }).forEach(function(d) {
      var opt = document.createElement("option");
      opt.value = d.name;
      opt.textContent = d.name;
      group.appendChild(opt);
    });
    sel.appendChild(group);
  });
}

function getDest(name) {
  for (var i = 0; i < DESTINATIONS.length; i++) {
    if (DESTINATIONS[i].name === name) return DESTINATIONS[i];
  }
  return DESTINATIONS[0];
}

function convert(usd) {
  var rate = CURRENCY_RATES[$("cfg-currency").value] || 1;
  return Math.round(usd * rate);
}

function symbol() {
  return CURRENCY_SYMBOLS[$("cfg-currency").value] || "$";
}

function fmt(amount) {
  return symbol() + amount.toLocaleString();
}

function getBaseCosts(dest, style) {
  return JSON.parse(JSON.stringify(dest[style]));
}

function calculate() {
  var destName = $("cfg-destination").value;
  var style = $("cfg-style").value;
  var days = parseInt($("cfg-days").value) || 7;
  if (days < 1) days = 1;
  if (days > 365) days = 365;
  $("cfg-days").value = days;

  var dest = getDest(destName);
  currentDest = dest;

  if (!customCosts || customCosts._dest !== destName || customCosts._style !== style) {
    customCosts = getBaseCosts(dest, style);
    customCosts._dest = destName;
    customCosts._style = style;
  }

  var dailyTotal = 0;
  CATEGORIES.forEach(function(cat) { dailyTotal += customCosts[cat.key]; });

  var tripTotal = dailyTotal * days;

  $("total-amount").textContent = fmt(convert(tripTotal));
  $("daily-amount").textContent = fmt(convert(dailyTotal)) + " / day";

  renderBreakdown(days);
  renderChart(dailyTotal);
  highlightComparison(destName);

  $("results-section").style.display = "";
}

function renderBreakdown(days) {
  var grid = $("breakdown-grid");
  grid.innerHTML = "";

  CATEGORIES.forEach(function(cat) {
    var daily = customCosts[cat.key];
    var total = daily * days;
    var card = document.createElement("div");
    card.className = "breakdown-card";
    card.innerHTML =
      '<div class="cat-label">' + cat.label + '</div>' +
      '<div class="cat-daily" style="color:' + cat.color + '">' + fmt(convert(daily)) + '<span style="font-size:0.7rem;color:var(--text-secondary)">/day</span></div>' +
      '<div class="cat-total">' + fmt(convert(total)) + ' total</div>' +
      '<div class="cat-input"><input type="number" min="0" data-key="' + cat.key + '" value="' + daily + '" title="Edit daily cost in USD"></div>';
    grid.appendChild(card);
  });

  grid.querySelectorAll('input[type="number"]').forEach(function(inp) {
    inp.addEventListener("change", function() {
      var val = parseInt(inp.value) || 0;
      if (val < 0) val = 0;
      inp.value = val;
      customCosts[inp.dataset.key] = val;
      calculate();
    });
  });
}

function renderChart(dailyTotal) {
  var container = $("chart-container");
  container.innerHTML = "";

  CATEGORIES.forEach(function(cat) {
    var val = customCosts[cat.key];
    var pct = dailyTotal > 0 ? Math.round((val / dailyTotal) * 100) : 0;

    var row = document.createElement("div");
    row.className = "chart-bar-row";
    row.innerHTML =
      '<span class="chart-bar-label">' + cat.label + '</span>' +
      '<div class="chart-bar-track"><div class="chart-bar-fill" style="width:' + pct + '%;background-color:' + cat.color + '">' + fmt(convert(val)) + '</div></div>' +
      '<span class="chart-bar-pct">' + pct + '%</span>';
    container.appendChild(row);
  });
}

function sumCosts(costs) {
  return costs.accom + costs.food + costs.transport + costs.activities + costs.misc;
}

/* Comparison table */
var sortCol = "budget";
var sortAsc = true;

function renderComparison() {
  var body = $("comparison-body");
  body.innerHTML = "";

  var sorted = DESTINATIONS.slice().sort(function(a, b) {
    if (sortCol === "name") return sortAsc ? a.name.localeCompare(b.name) : b.name.localeCompare(a.name);
    if (sortCol === "region") return sortAsc ? a.region.localeCompare(b.region) : b.region.localeCompare(a.region);
    var aVal = sumCosts(a[sortCol]);
    var bVal = sumCosts(b[sortCol]);
    return sortAsc ? aVal - bVal : bVal - aVal;
  });

  sorted.forEach(function(d) {
    var tr = document.createElement("tr");
    tr.dataset.name = d.name;
    tr.innerHTML =
      '<td>' + d.name + '</td>' +
      '<td>' + d.region + '</td>' +
      '<td>' + fmt(convert(sumCosts(d.budget))) + '</td>' +
      '<td>' + fmt(convert(sumCosts(d.mid))) + '</td>' +
      '<td>' + fmt(convert(sumCosts(d.luxury))) + '</td>';
    body.appendChild(tr);
  });
}

function highlightComparison(destName) {
  var rows = $("comparison-body").querySelectorAll("tr");
  rows.forEach(function(tr) {
    tr.classList.toggle("highlight-row", tr.dataset.name === destName);
  });
}

/* Table sorting */
document.querySelectorAll("#comparison-table th").forEach(function(th) {
  th.addEventListener("click", function() {
    var col = th.dataset.sort;
    if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }

    document.querySelectorAll("#comparison-table th .sort-arrow").forEach(function(s) { s.textContent = ""; });
    th.querySelector(".sort-arrow").textContent = sortAsc ? " \u25b2" : " \u25bc";

    renderComparison();
    if (currentDest) highlightComparison(currentDest.name);
  });
});

/* Currency change recalculates */
$("cfg-currency").addEventListener("change", function() {
  renderComparison();
  if (currentDest) calculate();
});

/* Init */
populateDestinations();
renderComparison();

$("btn-calculate").addEventListener("click", function() {
  calculate();
  $("results-section").scrollIntoView({ behavior: "smooth" });
});
  </script>

