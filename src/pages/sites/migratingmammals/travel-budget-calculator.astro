---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Travel Budget Calculator — Trip Cost Planner",
    "url": "https://migratingmammals.com/travel-budget-calculator",
    "applicationCategory": "TravelApplication",
    "operatingSystem": "All",
    "description": "Plan your trip budget by destination. Select a country, trip duration, and travel style to get estimated daily costs for accommodation, food, transport, activities, and more. Compare costs across 30+ destinations.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does it cost to travel per day?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Daily travel costs vary widely by destination and travel style. Budget travelers can spend $20-40/day in Southeast Asia, $40-70/day in Eastern Europe, and $80-120/day in Western Europe or Japan. Mid-range travelers typically spend 2-3x more, while luxury travelers can spend $300+/day. Key factors include accommodation, food, transport, and activities."
        }
      },
      {
        "@type": "Question",
        "name": "What is the cheapest region to travel in?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Southeast Asia is consistently the most affordable region for travelers, with countries like Vietnam, Cambodia, and Laos offering budget daily costs of $20-30. South Asia (India, Nepal) and parts of Central America (Guatemala, Nicaragua) are similarly affordable. Eastern Europe (Bulgaria, Romania) offers good value within Europe."
        }
      },
      {
        "@type": "Question",
        "name": "How do I create a travel budget?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Start by estimating daily costs in five categories: accommodation, food, local transport, activities, and miscellaneous expenses. Multiply by your trip length, then add one-time costs like flights, travel insurance, and visa fees. Use a travel budget calculator to get average costs for your destination, then adjust based on your personal travel style and preferences."
        }
      },
      {
        "@type": "Question",
        "name": "What percentage of my travel budget should go to accommodation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Accommodation typically accounts for 30-40% of a travel budget for mid-range travelers. Budget travelers staying in hostels may spend only 20-25%, while luxury travelers could allocate 40-50%. Food usually takes 25-30%, transport 15-20%, activities 10-15%, and miscellaneous expenses 5-10%."
        }
      },
      {
        "@type": "Question",
        "name": "How can I save money while traveling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Top money-saving strategies include: staying in hostels or guesthouses, eating at local markets and street food stalls, using public transport instead of taxis, traveling in shoulder season, booking activities directly rather than through tour agencies, cooking some meals if you have kitchen access, and choosing free walking tours and public parks over paid attractions."
        }
      }
    ]
  }
];

export const meta = {
  title: "Travel Budget Calculator — Trip Cost Planner 2026",
  description: "Plan your trip budget by destination with estimated daily costs for accommodation, food, transport, and activities. Compare 30+ destinations across budget, mid-range, and luxury travel styles.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="migratingmammals"
  title="Travel Budget Calculator — Trip Cost Planner 2026"
  description="Plan your trip budget by destination with estimated daily costs for accommodation, food, transport, and activities. Compare 30+ destinations across budget, mid-range, and luxury travel styles."
  canonical="https://migratingmammals.com/travel-budget-calculator"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    header { padding: 4rem 0 2rem; text-align: center; }

    h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2; }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 680px;
      margin: 0 auto 2rem;
    }

    section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }

    /* Config Panel */
    .config-panel {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .config-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
      margin-bottom: 1.5rem;
    }

    .config-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .config-group label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .config-group select,
    .config-group input[type="number"] {
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.7rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.9rem;
      outline: none;
      cursor: pointer;
    }

    .config-group select:focus,
    .config-group input[type="number"]:focus { border-color: var(--accent-color); }

    .btn-generate {
      background-color: var(--accent-color);
      color: #000;
      border: none;
      padding: 0.75rem 2rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 0.95rem;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .btn-generate:hover { opacity: 0.85; }

    /* Results */
    .results-panel {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    .total-banner {
      text-align: center;
      padding: 1.5rem;
      background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.06));
      border-radius: 0.75rem;
      margin-bottom: 2rem;
      border: 1px solid var(--border-color);
    }

    .total-amount {
      font-size: 3rem;
      font-weight: 800;
      color: var(--accent-color);
      line-height: 1.1;
    }

    .total-label {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .daily-amount {
      font-size: 1.25rem;
      font-weight: 600;
      margin-top: 0.5rem;
    }

    /* Budget breakdown grid */
    .breakdown-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .breakdown-card {
      background-color: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 0.5rem;
      padding: 1.25rem;
    }

    .breakdown-card .cat-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .breakdown-card .cat-daily {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    .breakdown-card .cat-total {
      font-size: 0.8rem;
      color: var(--text-secondary);
    }

    .breakdown-card .cat-input {
      margin-top: 0.5rem;
    }

    .breakdown-card .cat-input input {
      width: 100%;
      background-color: var(--card-bg);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.45rem 0.75rem;
      border-radius: 0.375rem;
      font-family: var(--font-ui);
      font-size: 0.85rem;
      outline: none;
    }

    .breakdown-card .cat-input input:focus { border-color: var(--accent-color); }

    /* Chart */
    .chart-container {
      margin-bottom: 2rem;
    }

    .chart-bar-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
    }

    .chart-bar-label {
      width: 110px;
      font-size: 0.8rem;
      text-align: right;
      flex-shrink: 0;
      color: var(--text-secondary);
    }

    .chart-bar-track {
      flex: 1;
      height: 28px;
      background-color: var(--bg-color);
      border-radius: 4px;
      overflow: hidden;
      position: relative;
    }

    .chart-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.5s ease;
      display: flex;
      align-items: center;
      padding-left: 0.5rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: #000;
      min-width: fit-content;
    }

    .chart-bar-pct {
      font-size: 0.75rem;
      color: var(--text-secondary);
      width: 45px;
      flex-shrink: 0;
      text-align: right;
    }

    /* Comparison table */
    .table-container {
      overflow-x: auto;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
    }

    table { width: 100%; border-collapse: collapse; text-align: left; }

    th, td {
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      background-color: rgba(255,255,255,0.02);
      cursor: pointer;
      user-select: none;
    }

    th:hover { color: var(--text-primary); }

    td { font-size: 0.85rem; }
    td:first-child { font-weight: 600; }

    tbody tr:hover { background-color: rgba(255,255,255,0.03); }

    tr.highlight-row { background-color: rgba(255,255,255,0.06); }

    .sort-arrow { font-size: 0.6rem; margin-left: 0.25rem; }

    /* FAQ */
    .faq-item {
      margin-bottom: 1.5rem;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }

    .faq-item h3 { font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .faq-item p { color: var(--text-secondary); }

    /* Related */
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .related-card {
      display: block;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      transition: border-color 0.2s, transform 0.2s;
    }

    .related-card:hover {
      border-color: var(--accent-color);
      transform: translateY(-2px);
      text-decoration: none;
      opacity: 1;
    }

    .related-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
    .related-card p { font-size: 0.8rem; color: var(--text-secondary); }

    /* Prose */
    .prose { max-width: 720px; }
    .prose p { color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.95rem; }
    .prose ul { list-style: disc; padding-left: 1.25rem; margin-bottom: 1rem; }
    .prose ul li { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0.35rem; }

    /* Print */
    @media print {
      body { background: #fff !important; color: #000 !important; }
      .config-panel, .btn-generate, .related-grid, .no-print { display: none !important; }
      .container { max-width: 100%; padding: 0; }
      .results-panel { border: 1px solid #ccc; }
      .breakdown-card { border: 1px solid #ccc; }
      .breakdown-card .cat-input { display: none; }
      h1, h2, h3 { color: #000 !important; }
      .total-amount { color: #000 !important; }
      a { color: #000; }
    }

    @media (max-width: 700px) {
      h1 { font-size: 1.75rem; }
      .config-grid { grid-template-columns: 1fr; }
      .breakdown-grid { grid-template-columns: 1fr 1fr; }
      .total-amount { font-size: 2.25rem; }
      .chart-bar-label { width: 80px; font-size: 0.7rem; }
    }
  </style>

  <div class="container">
    <div style="background:rgba(196,149,106,0.1);border:1px solid rgba(196,149,106,0.25);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      🌍 <strong style="color:#C4956A;">Currency swings are reshaping travel costs.</strong> The Thai baht dropped 8% against the dollar, making Bangkok 15% cheaper for US travelers. But European destinations got pricier. Plan your budget with real-time cost data below. <a href="https://gab.ae/news/currency-volatility-oil-crisis-travel-budgets-2026" style="color:#C4956A;">How currencies are shifting →</a>
    </div>
    <header>
      <h1>Travel Budget Calculator</h1>
      <p class="subtitle">Plan your <strong>trip budget</strong> by destination. Get estimated daily costs, customize your spending, and compare prices across 30+ popular destinations worldwide.</p>
    </header>

    <!-- Intro -->
    <section>
      <div class="prose">
        <p>Knowing how much a trip will cost before you book is the difference between a relaxed vacation and a stressful one. This <strong>travel budget calculator</strong> gives you realistic daily cost estimates for accommodation, food, transport, activities, and miscellaneous expenses based on your chosen destination and travel style.</p>
        <p>Select from over 30 popular destinations, pick your travel style — budget, mid-range, or luxury — set your trip length, and get an instant <strong>trip cost estimate</strong>. Customize any category to match your actual spending habits, then compare your destination against others to find the best value.</p>
      </div>
    </section>

    <!-- Calculator Config -->
    <section>
      <h2>Plan Your Trip Budget</h2>
      <div class="config-panel">
        <div class="config-grid">
          <div class="config-group">
            <label>Destination</label>
            <select id="cfg-destination"></select>
          </div>
          <div class="config-group">
            <label>Travel Style</label>
            <select id="cfg-style">
              <option value="budget">Budget</option>
              <option value="mid" selected>Mid-Range</option>
              <option value="luxury">Luxury</option>
            </select>
          </div>
          <div class="config-group">
            <label>Trip Duration (days)</label>
            <input type="number" id="cfg-days" value="7" min="1" max="365">
          </div>
          <div class="config-group">
            <label>Currency</label>
            <select id="cfg-currency">
              <option value="USD" selected>USD ($)</option>
              <option value="EUR">EUR (&euro;)</option>
              <option value="GBP">GBP (&pound;)</option>
              <option value="CAD">CAD (C$)</option>
              <option value="AUD">AUD (A$)</option>
            </select>
          </div>
        </div>
        <button class="btn-generate" id="btn-calculate">Calculate Budget</button>
      </div>
    </section>

    <!-- Results -->
    <section id="results-section" style="display:none">
      <h2>Your Trip Budget</h2>
      <div class="results-panel">
        <div class="total-banner">
          <div class="total-amount" id="total-amount">$0</div>
          <div class="total-label">Estimated Total Trip Cost</div>
          <div class="daily-amount" id="daily-amount">$0 / day</div>
        </div>

        <h3 style="margin-bottom:1rem">Daily Costs by Category</h3>
        <div class="breakdown-grid" id="breakdown-grid"></div>

        <h3 style="margin-bottom:1rem">Spending Breakdown</h3>
        <div class="chart-container" id="chart-container"></div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section>
      <h2>Destination Cost Comparison</h2>
      <div class="table-container">
        <table id="comparison-table">
          <thead>
            <tr>
              <th data-sort="name">Destination <span class="sort-arrow"></span></th>
              <th data-sort="region">Region <span class="sort-arrow"></span></th>
              <th data-sort="budget">Budget/Day <span class="sort-arrow"></span></th>
              <th data-sort="mid">Mid-Range/Day <span class="sort-arrow"></span></th>
              <th data-sort="luxury">Luxury/Day <span class="sort-arrow"></span></th>
            </tr>
          </thead>
          <tbody id="comparison-body"></tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>How much does it cost to travel per day?</h3>
        <p>Daily travel costs vary widely by destination and travel style. Budget travelers can spend $20-40/day in Southeast Asia, $40-70/day in Eastern Europe, and $80-120/day in Western Europe or Japan. Mid-range travelers typically spend 2-3x more, while luxury travelers can spend $300+/day. Key factors include accommodation, food, transport, and activities.</p>
      </div>
      <div class="faq-item">
        <h3>What is the cheapest region to travel in?</h3>
        <p>Southeast Asia is consistently the most affordable region for travelers, with countries like Vietnam, Cambodia, and Laos offering budget daily costs of $20-30. South Asia (India, Nepal) and parts of Central America (Guatemala, Nicaragua) are similarly affordable. Eastern Europe (Bulgaria, Romania) offers good value within Europe.</p>
      </div>
      <div class="faq-item">
        <h3>How do I create a travel budget?</h3>
        <p>Start by estimating daily costs in five categories: accommodation, food, local transport, activities, and miscellaneous expenses. Multiply by your trip length, then add one-time costs like flights, travel insurance, and visa fees. Use a travel budget calculator to get average costs for your destination, then adjust based on your personal travel style and preferences.</p>
      </div>
      <div class="faq-item">
        <h3>What percentage of my travel budget should go to accommodation?</h3>
        <p>Accommodation typically accounts for 30-40% of a travel budget for mid-range travelers. Budget travelers staying in hostels may spend only 20-25%, while luxury travelers could allocate 40-50%. Food usually takes 25-30%, transport 15-20%, activities 10-15%, and miscellaneous expenses 5-10%.</p>
      </div>
      <div class="faq-item">
        <h3>How can I save money while traveling?</h3>
        <p>Top money-saving strategies include: staying in hostels or guesthouses, eating at local markets and street food stalls, using public transport instead of taxis, traveling in shoulder season, booking activities directly rather than through tour agencies, cooking some meals if you have kitchen access, and choosing free walking tours and public parks over paid attractions.</p>
      </div>
    </section>

    <!-- Related pages -->
    <section>
      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/packing-list-generator" class="related-card">
          <h3>Packing List Generator</h3>
          <p>Build a custom packing checklist for any trip &rarr;</p>
        </a>
        <a href="/cost-of-living-comparison" class="related-card">
          <h3>Cost of Living Comparison</h3>
          <p>Compare living costs between 40 nomad cities &rarr;</p>
        </a>
        <a href="/digital-nomad-visa-guide" class="related-card">
          <h3>Digital Nomad Visa Guide</h3>
          <p>Compare remote work visas across 32 countries &rarr;</p>
        </a>
      </div>
    </section>
  </div>

