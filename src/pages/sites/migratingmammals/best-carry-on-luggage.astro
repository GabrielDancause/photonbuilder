---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Carry-On Luggage 2026",
    "url": "https://migratingmammals.com/best-carry-on-luggage",
    "description": "Compare the top carry-on luggage for 2026. Rankings include Away, Samsonite, Travelpro, Monos, RIMOWA, and more. Compare dimensions, weight, materials, and features.",
    "author": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "migratingmammals.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://migratingmammals.com/logo.png"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the standard carry-on luggage size?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For most major US airlines (Delta, United, American), the standard carry-on limit is 22\" x 14\" x 9\". Always check with your specific airline before flying, especially for international carriers which may have stricter size and weight limits."
        }
      },
      {
        "@type": "Question",
        "name": "Are hard shell or soft-sided carry-ons better?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Hard shell luggage (polycarbonate or aluminum) offers better protection for fragile items and is easier to clean. Soft-sided luggage (nylon or polyester) is more flexible, can often fit into tighter overhead bins, and typically features exterior pockets for easy access."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between spinner and 2-wheel luggage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Spinner luggage has four wheels that rotate 360 degrees, allowing you to glide the bag upright alongside you. 2-wheel (rollaboard) luggage has larger, recessed wheels that you pull behind you, which perform better on uneven surfaces like cobblestones."
        }
      },
      {
        "@type": "Question",
        "name": "How much should a good carry-on weigh?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good hard shell carry-on should weigh between 7 to 8.5 lbs empty. Soft-sided bags can weigh closer to 6.5 to 7.5 lbs. Ultralight options exist under 6 lbs, while aluminum cases can weigh 9.5 lbs or more."
        }
      },
      {
        "@type": "Question",
        "name": "Is aluminum luggage worth the price?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Aluminum luggage like RIMOWA is highly durable, secure, and stylish, but it is heavier and prone to dents and scratches. It is worth the price for frequent travelers who prioritize aesthetics and longevity over lightweight packing."
        }
      }
    ]
  }
];

export const meta = {
  title: "Best Carry-On Luggage (2026)",
  description: "Compare the top carry-on luggage for 2026. Rankings include Away, Samsonite, Travelpro, Monos, RIMOWA, and more. Compare dimensions, weight, materials, and features.",
  category: "list",
  published: "2026-05-20"
};

const LUGGAGE = [
  { name: "Away The Carry-On", dimensions: "21.7\" x 13.7\" x 9\"", weight: 7.1, material: "Polycarbonate", wheels: "Spinner", warranty: "Lifetime", compartments: 2, price: 275 },
  { name: "Samsonite Freeform Carry-On", dimensions: "21.25\" x 15.25\" x 10\"", weight: 6.5, material: "Polypropylene", wheels: "Spinner", warranty: "10 Year", compartments: 2, price: 199 },
  { name: "Travelpro Platinum Elite", dimensions: "21\" x 14\" x 9\"", weight: 7.8, material: "Nylon", wheels: "Spinner", warranty: "Lifetime", compartments: 3, price: 369 },
  { name: "Monos Carry-On", dimensions: "22\" x 14\" x 9\"", weight: 7.01, material: "Polycarbonate", wheels: "Spinner", warranty: "Lifetime", compartments: 2, price: 255 },
  { name: "RIMOWA Original Cabin", dimensions: "21.7\" x 15.8\" x 9.1\"", weight: 9.5, material: "Aluminum", wheels: "Spinner", warranty: "Lifetime", compartments: 2, price: 1430 },
  { name: "July Carry On", dimensions: "21.5\" x 15\" x 8.5\"", weight: 7.4, material: "Polycarbonate", wheels: "Spinner", warranty: "Lifetime", compartments: 2, price: 295 },
  { name: "Beis The Carry-On Roller", dimensions: "22.8\" x 15.7\" x 9.8\"", weight: 8.36, material: "Polycarbonate", wheels: "Spinner", warranty: "Limited Lifetime", compartments: 2, price: 218 },
  { name: "Paravel Aviator Carry-On", dimensions: "21.7\" x 13.7\" x 9\"", weight: 8.2, material: "Recycled Polycarbonate", wheels: "Spinner", warranty: "5 Year", compartments: 2, price: 395 }
];

const initialSortedLuggage = [...LUGGAGE].sort((a, b) => a.weight - b.weight);
---

<SiteLayout
  site="migratingmammals"
  title="Best Carry-On Luggage 2026"
  description="Compare the top carry-on luggage for 2026. Rankings include Away, Samsonite, Travelpro, Monos, RIMOWA, and more. Compare dimensions, weight, materials, and features."
  canonical="https://migratingmammals.com/best-carry-on-luggage"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <style>
    .page-wrapper {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      color: var(--text-primary);
      font-family: var(--font-ui, sans-serif);
      line-height: 1.6;
    }

    .page-wrapper a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    .page-wrapper a:hover { opacity: 0.8; text-decoration: underline; }

    .header-section {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(180deg, var(--card-bg) 0%, var(--bg-color, #ffffff) 100%);
      border-bottom: 1px solid var(--border-color);
    }
    .header-section h1 {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 15px;
      letter-spacing: -0.02em;
    }
    .header-section p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

    .winners-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-bottom: 50px;
    }
    .winner-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 25px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .winner-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 15px rgba(0,0,0,0.1);
    }
    .winner-badge {
      display: inline-block;
      background: var(--accent-color);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 20px;
      margin-bottom: 15px;
    }
    .winner-name {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 10px;
      color: var(--text-primary);
    }
    .winner-desc {
      font-size: 0.95rem;
      color: var(--text-secondary);
    }

    .section-title {
      font-size: 2rem;
      font-weight: 700;
      margin: 40px 0 20px;
      color: var(--text-primary);
    }

    .table-container {
      width: 100%;
      overflow-x: auto;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      margin-bottom: 40px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    th, td {
      padding: 16px;
      border-bottom: 1px solid var(--border-color);
    }
    th {
      background: rgba(0,0,0,0.02);
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    th:hover { background: rgba(0,0,0,0.04); }
    th::after {
      content: ' ↕';
      opacity: 0.3;
      font-size: 0.8em;
    }
    th.sort-asc::after { content: ' ↑'; opacity: 1; }
    th.sort-desc::after { content: ' ↓'; opacity: 1; }

    td {
      font-size: 0.95rem;
      color: var(--text-primary);
      vertical-align: middle;
    }
    td.number {
      font-family: var(--font-mono, monospace);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(0,0,0,0.01); }

    .airline-chart {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 40px;
    }
    .airline-chart ul {
      list-style-type: none;
      padding: 0;
    }
    .airline-chart li {
      padding: 10px 0;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
    }
    .airline-chart li:last-child {
      border-bottom: none;
    }

    .packing-tips {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 40px;
    }
    .packing-tips h3 {
      font-size: 1.3rem;
      margin-bottom: 15px;
      color: var(--text-primary);
    }
    .packing-tips ul {
      margin-left: 20px;
      color: var(--text-secondary);
    }
    .packing-tips li {
      margin-bottom: 10px;
    }

    .faq-section { margin-top: 60px; }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 15px;
    }
    .faq-question {
      font-weight: 700;
      font-size: 1.1rem;
      margin-bottom: 10px;
      color: var(--text-primary);
    }
    .faq-answer {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }
  </style>

  <div class="page-wrapper">
    <div style="background:rgba(196,149,106,0.1);border:1px solid rgba(196,149,106,0.25);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      ✈️ <strong style="color:#C4956A;">Checked bag fees now cost $35-70 round trip.</strong> With airlines shrinking overhead bins, the right carry-on saves hundreds per year. Size compliance matters — an oversized bag gets gate-checked and you lose. <a href="https://gab.ae/news/currency-volatility-oil-crisis-travel-budgets-2026" style="color:#C4956A;">Travel costs are climbing →</a>
    </div>
    <div class="header-section">
      <h1>Best Carry-On Luggage 2026</h1>
      <p>Compare the top carry-on bags. Sort by dimensions, weight, material, and features.</p>
    </div>

    <div class="container">
      <div class="winners-grid">
        <div class="winner-card">
          <div class="winner-badge">Best Overall</div>
          <div class="winner-name">Monos Carry-On</div>
          <div class="winner-desc">Sleek, incredibly durable polycarbonate shell, whisper-quiet wheels, and thoughtfully designed interior compartments.</div>
        </div>
        <div class="winner-card">
          <div class="winner-badge">Best Value</div>
          <div class="winner-name">Away The Carry-On</div>
          <div class="winner-desc">The bag that modernized luggage. Excellent warranty, great compression system, and reliable construction.</div>
        </div>
        <div class="winner-card">
          <div class="winner-badge">Best Softside</div>
          <div class="winner-name">Travelpro Platinum Elite</div>
          <div class="winner-desc">A favorite among flight crews. Premium nylon, external pockets, and effortless glide.</div>
        </div>
        <div class="winner-card">
          <div class="winner-badge">Best Luxury</div>
          <div class="winner-name">RIMOWA Original Cabin</div>
          <div class="winner-desc">Iconic grooved aluminum design. Unmatched heritage, security, and a statement piece for frequent fliers.</div>
        </div>
      </div>

      <h2 class="section-title">Luggage Comparison</h2>
      <div class="table-container">
        <table id="luggage-table">
          <thead>
            <tr>
              <th data-sort="name">Name</th>
              <th data-sort="dimensions">Dimensions</th>
              <th data-sort="weight" class="sort-asc">Weight (lbs)</th>
              <th data-sort="price">Price (USD)</th>
              <th data-sort="material">Material</th>
              <th data-sort="wheels">Wheels</th>
              <th data-sort="compartments">Compartments</th>
              <th data-sort="warranty">Warranty</th>
            </tr>
          </thead>
          <tbody id="luggage-body">
            {initialSortedLuggage.map((l) => (
              <tr>
                <td><strong>{l.name}</strong></td>
                <td>{l.dimensions}</td>
                <td class="number">{l.weight.toFixed(2)}</td>
                <td class="number">${l.price}</td>
                <td>{l.material}</td>
                <td>{l.wheels}</td>
                <td class="number">{l.compartments}</td>
                <td>{l.warranty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="airline-chart">
        <h2 class="section-title" style="margin-top: 0;">Airline Compliance Chart (Major US Airlines)</h2>
        <ul>
          <li><strong>Delta Air Lines</strong> <span>22" x 14" x 9"</span></li>
          <li><strong>United Airlines</strong> <span>22" x 14" x 9"</span></li>
          <li><strong>American Airlines</strong> <span>22" x 14" x 9"</span></li>
          <li><strong>Southwest Airlines</strong> <span>24" x 16" x 10"</span></li>
          <li><strong>JetBlue Airways</strong> <span>22" x 14" x 9"</span></li>
          <li><strong>Alaska Airlines</strong> <span>22" x 14" x 9"</span></li>
        </ul>
        <p style="margin-top: 15px; font-size: 0.9rem; color: var(--text-secondary);">* Always check directly with the airline before your flight as policies can change.</p>
      </div>

      <div class="packing-tips">
        <h2 class="section-title" style="margin-top: 0;">Packing Tips for Carry-On Only Travel</h2>
        <ul>
          <li><strong>Use Packing Cubes:</strong> They compress your clothes, keep items organized by category, and make unpacking at your destination a breeze.</li>
          <li><strong>Roll, Don't Fold:</strong> Rolling your clothes saves space and minimizes wrinkles.</li>
          <li><strong>Wear Your Bulkiest Items:</strong> Wear your heaviest shoes, thickest sweater, or jacket on the plane to save precious space and weight in your bag.</li>
          <li><strong>Limit Your Liquids:</strong> Stick to the TSA 3-1-1 rule. Consider solid toiletries (like solid shampoo or deodorant) to save space in your liquids bag.</li>
          <li><strong>Plan a Capsule Wardrobe:</strong> Pack clothes in coordinating colors so every top matches every bottom, maximizing your outfit combinations.</li>
        </ul>
      </div>

      <div class="faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-item">
          <div class="faq-question">What is the standard carry-on luggage size?</div>
          <div class="faq-answer">For most major US airlines (Delta, United, American), the standard carry-on limit is 22" x 14" x 9". Always check with your specific airline before flying, especially for international carriers which may have stricter size and weight limits.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Are hard shell or soft-sided carry-ons better?</div>
          <div class="faq-answer">Hard shell luggage (polycarbonate or aluminum) offers better protection for fragile items and is easier to clean. Soft-sided luggage (nylon or polyester) is more flexible, can often fit into tighter overhead bins, and typically features exterior pockets for easy access.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">What is the difference between spinner and 2-wheel luggage?</div>
          <div class="faq-answer">Spinner luggage has four wheels that rotate 360 degrees, allowing you to glide the bag upright alongside you. 2-wheel (rollaboard) luggage has larger, recessed wheels that you pull behind you, which perform better on uneven surfaces like cobblestones.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">How much should a good carry-on weigh?</div>
          <div class="faq-answer">A good hard shell carry-on should weigh between 7 to 8.5 lbs empty. Soft-sided bags can weigh closer to 6.5 to 7.5 lbs. Ultralight options exist under 6 lbs, while aluminum cases can weigh 9.5 lbs or more.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Is aluminum luggage worth the price?</div>
          <div class="faq-answer">Aluminum luggage like RIMOWA is highly durable, secure, and stylish, but it is heavier and prone to dents and scratches. It is worth the price for frequent travelers who prioritize aesthetics and longevity over lightweight packing.</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const table = document.getElementById('luggage-table');
    const tbody = document.getElementById('luggage-body');
    const ths = table.querySelectorAll('th');

    // Store the raw data directly from the DOM on load to maintain data consistency.
    let tableData = Array.from(tbody.querySelectorAll('tr')).map(tr => {
      const tds = tr.querySelectorAll('td');
      return {
        element: tr,
        name: tds[0].innerText,
        dimensions: tds[1].innerText,
        weight: parseFloat(tds[2].innerText),
        price: parseFloat(tds[3].innerText.replace('$', '')),
        material: tds[4].innerText,
        wheels: tds[5].innerText,
        compartments: parseInt(tds[6].innerText, 10),
        warranty: tds[7].innerText
      };
    });

    let sortCol = 'weight';
    let sortAsc = true;

    function renderSortedTable() {
      const sorted = [...tableData].sort((a, b) => {
        let va = a[sortCol], vb = b[sortCol];
        if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return sortAsc ? va - vb : vb - va;
      });

      // Clear existing rows
      tbody.innerHTML = '';

      // Append pre-rendered row elements in sorted order
      sorted.forEach(row => {
        tbody.appendChild(row.element);
      });

      // Update header indicators
      ths.forEach(th => {
        th.classList.remove('sort-asc', 'sort-desc');
        if (th.dataset.sort === sortCol) {
          th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');
        }
      });
    }

    ths.forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (!col) return;
        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = true;
        }
        renderSortedTable();
      });
    });
  </script>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/best-travel-backpacks" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Best Travel Backpacks 2026</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Top travel backpacks by type: carry-on, daypack, ultralight, anti-theft. Compare: capacity, weight, laptop sleeve, hip b...</p>
      </a>
    </div>
  </div>
</SiteLayout>
