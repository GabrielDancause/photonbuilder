---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Currency Converter — Exchange Rate Calculator",
    "url": "https://migratingmammals.com/currency-converter",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "All",
    "description": "Convert between 30 world currencies with approximate exchange rates. Multi-currency comparison, rate reference table, and cost of living context for digital nomads and travelers.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "provider": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does this currency converter work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Enter an amount, select the source and target currencies, and the tool instantly calculates the converted value using approximate exchange rates as of March 2026. You can also view the equivalent amount in the top 10 most-traded currencies at once."
        }
      },
      {
        "@type": "Question",
        "name": "Are the exchange rates accurate and up to date?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The rates shown are approximate mid-market rates as of March 2026. They are suitable for budgeting and estimation but may differ from the rates offered by banks, money transfer services, or currency exchanges, which include spreads and fees."
        }
      },
      {
        "@type": "Question",
        "name": "What is the best way to exchange money when traveling abroad?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For the best rates, use a travel-friendly debit card (like Wise or Revolut) that charges no foreign transaction fees. Avoid airport currency exchange kiosks, which typically have the worst rates. ATM withdrawals in-country often provide rates close to mid-market."
        }
      },
      {
        "@type": "Question",
        "name": "How many currencies does this converter support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This converter supports 30 of the world's most commonly used currencies, including USD, EUR, GBP, JPY, CAD, AUD, CHF, CNY, INR, BRL, MXN, KRW, SGD, HKD, THB, VND, PHP, MYR, IDR, TWD, NZD, SEK, NOK, DKK, PLN, CZK, HUF, TRY, ZAR, and AED."
        }
      },
      {
        "@type": "Question",
        "name": "Why do exchange rates change?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Exchange rates fluctuate based on economic factors including interest rates, inflation, trade balances, political stability, and market speculation. Central bank policies and global events can cause significant short-term movements. Rates are determined by supply and demand in the foreign exchange market."
        }
      },
      {
        "@type": "Question",
        "name": "How can I get the best exchange rate as a digital nomad?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Use a multi-currency account (Wise, Revolut) to hold and convert currencies at mid-market rates. Pay with local currency when given the option to avoid dynamic currency conversion markups. Withdraw larger amounts less frequently to minimize per-transaction ATM fees."
        }
      }
    ]
  }
];

export const meta = {
  title: "Currency Converter — Exchange Rates for 30 Currencies",
  description: "Convert between 30 world currencies instantly. Multi-currency comparison, exchange rate table, and cost of living context for travelers and digital nomads.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="migratingmammals"
  title="Currency Converter — Exchange Rates for 30 Currencies"
  description="Convert between 30 world currencies instantly. Multi-currency comparison, exchange rate table, and cost of living context for travelers and digital nomads."
  canonical="https://migratingmammals.com/currency-converter"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    header { padding: 4rem 0 2rem; text-align: center; }

    h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.2; }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 640px;
      margin: 0 auto 2rem;
    }

    section { margin-bottom: 4rem; }

    h2 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    /* Converter card */
    .converter-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 2rem;
      max-width: 600px;
      margin: 0 auto;
    }

    .amount-input-group {
      margin-bottom: 1.5rem;
    }

    .amount-input-group label {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      margin-bottom: 0.35rem;
    }

    .amount-input-group input {
      width: 100%;
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-code);
      font-size: 1.25rem;
      outline: none;
    }

    .amount-input-group input:focus { border-color: var(--accent-color); }

    .currency-row {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .currency-select-wrapper { flex: 1; }

    .currency-select-wrapper label {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      margin-bottom: 0.35rem;
    }

    .currency-select-wrapper select {
      width: 100%;
      background-color: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-family: var(--font-ui);
      font-size: 1rem;
      outline: none;
      cursor: pointer;
    }

    .currency-select-wrapper select:focus { border-color: var(--accent-color); }

    .swap-btn {
      background: var(--accent-color);
      color: #fff;
      border: none;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      font-size: 1.125rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 1.25rem;
      transition: opacity 0.2s, transform 0.2s;
      flex-shrink: 0;
    }

    .swap-btn:hover { opacity: 0.85; transform: rotate(180deg); }

    .result-display {
      text-align: center;
      padding: 1.5rem;
      background-color: rgba(255,255,255,0.03);
      border-radius: 0.5rem;
      margin-bottom: 1rem;
    }

    .result-display .converted-amount {
      font-size: 2.25rem;
      font-weight: 800;
      color: var(--accent-color);
      font-family: var(--font-code);
      word-break: break-all;
    }

    .result-display .rate-info {
      color: var(--text-secondary);
      font-size: 0.875rem;
      margin-top: 0.25rem;
    }

    .disclaimer {
      text-align: center;
      font-size: 0.75rem;
      color: var(--text-secondary);
      opacity: 0.7;
    }

    /* Multi-currency comparison */
    .multi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
    }

    .multi-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .multi-card .mc-currency {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .multi-card .mc-currency .mc-code {
      font-weight: 700;
      color: var(--text-primary);
      font-size: 1rem;
    }

    .multi-card .mc-amount {
      font-family: var(--font-code);
      font-size: 1rem;
      font-weight: 600;
      color: var(--accent-color);
    }

    /* Rate table */
    .table-container {
      overflow-x: auto;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
    }

    table { width: 100%; border-collapse: collapse; text-align: left; }

    th, td {
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--border-color);
      white-space: nowrap;
    }

    th {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      cursor: pointer;
      user-select: none;
      background-color: rgba(255,255,255,0.02);
    }

    th:hover { color: var(--text-primary); background-color: rgba(255,255,255,0.05); }
    th.sort-asc::after { content: " ▲"; }
    th.sort-desc::after { content: " ▼"; }

    td { font-size: 0.875rem; }
    td.number { font-family: var(--font-code); }
    tbody tr:hover { background-color: rgba(255,255,255,0.03); }

    /* Nomad tips */
    .tip-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }

    .tip-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }

    .tip-card h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }
    .tip-card .tip-rate { font-family: var(--font-code); color: var(--accent-color); font-size: 0.875rem; margin-bottom: 0.5rem; }
    .tip-card p { color: var(--text-secondary); font-size: 0.875rem; line-height: 1.5; }

    /* FAQ */
    .faq-item {
      margin-bottom: 1.5rem;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }

    .faq-item h3 { font-size: 1.125rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .faq-item p { color: var(--text-secondary); }

    /* Related */
    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .related-card {
      display: block;
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      transition: border-color 0.2s, transform 0.2s;
    }

    .related-card:hover {
      border-color: var(--accent-color);
      transform: translateY(-2px);
      text-decoration: none;
      opacity: 1;
    }

    .related-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
    .related-card p { font-size: 0.8rem; color: var(--text-secondary); }

    @media (max-width: 600px) {
      .currency-row { flex-direction: column; }
      .swap-btn { margin-top: 0; align-self: center; transform: rotate(90deg); }
      .swap-btn:hover { transform: rotate(270deg); }
      .result-display .converted-amount { font-size: 1.75rem; }
    }
  </style>

  <div class="container">
    <header>
      <h1>Currency Converter</h1>
      <p class="subtitle">Convert between 30 world currencies instantly. Exchange rate calculator with multi-currency comparison for travelers and digital nomads.</p>
    </header>

    <!-- Main converter -->
    <section>
      <div class="converter-card">
        <div class="amount-input-group">
          <label for="amount">Amount</label>
          <input type="number" id="amount" value="1000" min="0" step="any">
        </div>

        <div class="currency-row">
          <div class="currency-select-wrapper">
            <label for="from-currency">From</label>
            <select id="from-currency"></select>
          </div>

          <button class="swap-btn" id="swap-btn" title="Swap currencies" aria-label="Swap currencies">⇄</button>

          <div class="currency-select-wrapper">
            <label for="to-currency">To</label>
            <select id="to-currency"></select>
          </div>
        </div>

        <div class="result-display" id="result-display">
          <div class="converted-amount" id="converted-amount">—</div>
          <div class="rate-info" id="rate-info"></div>
        </div>

        <p class="disclaimer">Approximate mid-market rates as of March 2026. Actual rates from banks and transfer services may vary.</p>
      </div>
    </section>

    <!-- Multi-currency comparison -->
    <section>
      <h2>Multi-Currency Comparison</h2>
      <p style="margin-bottom:1rem; color:var(--text-secondary); font-size:0.875rem;" id="multi-subtitle">See your amount in the 10 most popular currencies at a glance.</p>
      <div class="multi-grid" id="multi-grid"></div>
    </section>

    <!-- Rate reference table -->
    <section>
      <h2>Exchange Rate Reference Table</h2>
      <p style="margin-bottom:1rem; color:var(--text-secondary); font-size:0.875rem;">All rates shown per 1 <span id="table-base-label">USD</span>. Click a column header to sort.</p>
      <div class="table-container">
        <table id="rate-table">
          <thead>
            <tr>
              <th data-sort="code">Code</th>
              <th data-sort="name">Currency</th>
              <th data-sort="rate" class="sort-asc">Rate per 1 <span id="th-base">USD</span></th>
              <th data-sort="inverse">Inverse</th>
            </tr>
          </thead>
          <tbody id="rate-table-body"></tbody>
        </table>
      </div>
    </section>

    <!-- Nomad tips -->
    <section>
      <h2>Nomad Currency Tips by Destination</h2>
      <p style="margin-bottom:1rem; color:var(--text-secondary); font-size:0.875rem;">Cost of living context and money tips for popular nomad destinations.</p>
      <div class="tip-grid" id="tip-grid"></div>
    </section>

    <!-- FAQ -->
    <section>
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>How does this currency converter work?</h3>
        <p>Enter an amount, select the source and target currencies, and the tool instantly calculates the converted value using approximate exchange rates as of March 2026. You can also view the equivalent amount in the top 10 most-traded currencies at once.</p>
      </div>
      <div class="faq-item">
        <h3>Are the exchange rates accurate and up to date?</h3>
        <p>The rates shown are approximate mid-market rates as of March 2026. They are suitable for budgeting and estimation but may differ from the rates offered by banks, money transfer services, or currency exchanges, which include spreads and fees.</p>
      </div>
      <div class="faq-item">
        <h3>What is the best way to exchange money when traveling abroad?</h3>
        <p>For the best rates, use a travel-friendly debit card (like Wise or Revolut) that charges no foreign transaction fees. Avoid airport currency exchange kiosks, which typically have the worst rates. ATM withdrawals in-country often provide rates close to mid-market.</p>
      </div>
      <div class="faq-item">
        <h3>How many currencies does this converter support?</h3>
        <p>This converter supports 30 of the world's most commonly used currencies, including USD, EUR, GBP, JPY, CAD, AUD, CHF, CNY, INR, BRL, MXN, KRW, SGD, HKD, THB, VND, PHP, MYR, IDR, TWD, NZD, SEK, NOK, DKK, PLN, CZK, HUF, TRY, ZAR, and AED.</p>
      </div>
      <div class="faq-item">
        <h3>Why do exchange rates change?</h3>
        <p>Exchange rates fluctuate based on economic factors including interest rates, inflation, trade balances, political stability, and market speculation. Central bank policies and global events can cause significant short-term movements. Rates are determined by supply and demand in the foreign exchange market.</p>
      </div>
      <div class="faq-item">
        <h3>How can I get the best exchange rate as a digital nomad?</h3>
        <p>Use a multi-currency account (Wise, Revolut) to hold and convert currencies at mid-market rates. Pay with local currency when given the option to avoid dynamic currency conversion markups. Withdraw larger amounts less frequently to minimize per-transaction ATM fees.</p>
      </div>
    </section>

    <!-- Related pages -->
    <section>
      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/cost-of-living-comparison" class="related-card">
          <h3>Cost of Living Comparison</h3>
          <p>Compare monthly budgets between 40 cities side by side →</p>
        </a>
        <a href="/digital-nomad-visa-guide" class="related-card">
          <h3>Digital Nomad Visa Guide</h3>
          <p>Visa requirements and remote work permits by country →</p>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
// 30 currencies with approximate rates vs USD (March 2026)
const CURRENCIES = [
  { code: 'USD', name: 'US Dollar', symbol: '$', rate: 1 },
  { code: 'EUR', name: 'Euro', symbol: '€', rate: 0.92 },
  { code: 'GBP', name: 'British Pound', symbol: '£', rate: 0.79 },
  { code: 'CAD', name: 'Canadian Dollar', symbol: 'C$', rate: 1.36 },
  { code: 'AUD', name: 'Australian Dollar', symbol: 'A$', rate: 1.54 },
  { code: 'JPY', name: 'Japanese Yen', symbol: '¥', rate: 149.5 },
  { code: 'CHF', name: 'Swiss Franc', symbol: 'CHF', rate: 0.88 },
  { code: 'CNY', name: 'Chinese Yuan', symbol: '¥', rate: 7.24 },
  { code: 'INR', name: 'Indian Rupee', symbol: '₹', rate: 83.1 },
  { code: 'BRL', name: 'Brazilian Real', symbol: 'R$', rate: 4.97 },
  { code: 'MXN', name: 'Mexican Peso', symbol: '$', rate: 17.15 },
  { code: 'KRW', name: 'South Korean Won', symbol: '₩', rate: 1325 },
  { code: 'SGD', name: 'Singapore Dollar', symbol: 'S$', rate: 1.34 },
  { code: 'HKD', name: 'Hong Kong Dollar', symbol: 'HK$', rate: 7.82 },
  { code: 'THB', name: 'Thai Baht', symbol: '฿', rate: 35.2 },
  { code: 'VND', name: 'Vietnamese Dong', symbol: '₫', rate: 24850 },
  { code: 'PHP', name: 'Philippine Peso', symbol: '₱', rate: 55.8 },
  { code: 'MYR', name: 'Malaysian Ringgit', symbol: 'RM', rate: 4.47 },
  { code: 'IDR', name: 'Indonesian Rupiah', symbol: 'Rp', rate: 15650 },
  { code: 'TWD', name: 'Taiwan Dollar', symbol: 'NT$', rate: 31.5 },
  { code: 'NZD', name: 'New Zealand Dollar', symbol: 'NZ$', rate: 1.67 },
  { code: 'SEK', name: 'Swedish Krona', symbol: 'kr', rate: 10.45 },
  { code: 'NOK', name: 'Norwegian Krone', symbol: 'kr', rate: 10.6 },
  { code: 'DKK', name: 'Danish Krone', symbol: 'kr', rate: 6.87 },
  { code: 'PLN', name: 'Polish Zloty', symbol: 'zł', rate: 3.98 },
  { code: 'CZK', name: 'Czech Koruna', symbol: 'Kč', rate: 23.1 },
  { code: 'HUF', name: 'Hungarian Forint', symbol: 'Ft', rate: 365 },
  { code: 'TRY', name: 'Turkish Lira', symbol: '₺', rate: 32.1 },
  { code: 'ZAR', name: 'South African Rand', symbol: 'R', rate: 18.6 },
  { code: 'AED', name: 'UAE Dirham', symbol: 'د.إ', rate: 3.67 }
];

// Top 10 for multi-currency comparison
var TOP10 = ['USD','EUR','GBP','JPY','CAD','AUD','CHF','CNY','INR','BRL'];

// Nomad destination tips
var NOMAD_TIPS = [
  { city: 'Bangkok', country: 'Thailand', currency: 'THB', budget: '$900/mo', tip: 'Street food averages 40–80 THB ($1–2). Use Wise or a Thai bank account for best ATM rates. 7-Eleven accepts contactless payments everywhere.' },
  { city: 'Mexico City', country: 'Mexico', currency: 'MXN', budget: '$1,400/mo', tip: 'Pesos are king — many small shops and taquerias are cash-only. Bank ATMs (Citibanamex, HSBC) give better rates than standalone machines. Avoid DCC at card terminals.' },
  { city: 'Lisbon', country: 'Portugal', currency: 'EUR', budget: '$2,000/mo', tip: 'Portugal is eurozone so no conversion needed if coming from EU. Cards accepted almost everywhere, but keep small euros for markets. MB Way is the local payment app.' },
  { city: 'Bali', country: 'Indonesia', currency: 'IDR', budget: '$1,000/mo', tip: 'Always carry cash in rupiah — many warungs and local shops are cash-only. Use BCA or Mandiri ATMs for best rates. Count carefully as notes go up to 100,000 IDR.' },
  { city: 'Medellín', country: 'Colombia', currency: 'MXN', budget: '$750/mo', tip: 'Always choose "sin conversión" (without conversion) when paying by card. Withdraw COP from Bancolombia ATMs. The peso is strong for budget travelers.' },
  { city: 'Tokyo', country: 'Japan', currency: 'JPY', budget: '$1,400/mo', tip: 'Japan is still partially cash-based. 7-Eleven ATMs accept foreign cards reliably. IC cards (Suica/Pasmo) work for trains and convenience stores. Yen coins come in 6 denominations.' },
  { city: 'Prague', country: 'Czech Republic', currency: 'CZK', budget: '$1,540/mo', tip: 'Czech Republic uses koruna, not euros. Always refuse DCC and pay in CZK. Revolut and Wise work well here. Tipping 10% is customary but not required.' },
  { city: 'Ho Chi Minh City', country: 'Vietnam', currency: 'VND', budget: '$800/mo', tip: 'Vietnam is heavily cash-based. Carry dong for street food and local shops. 1 USD ≈ 25,000 VND — get used to large numbers. BIDV and Vietcombank ATMs are reliable.' }
];

var currencyMap = {};
CURRENCIES.forEach(function(c) { currencyMap[c.code] = c; });

function $(id) { return document.getElementById(id); }

function convert(amount, from, to) {
  var fromRate = currencyMap[from].rate;
  var toRate = currencyMap[to].rate;
  return amount / fromRate * toRate;
}

function formatCurrency(value, code) {
  var c = currencyMap[code];
  if (value >= 100000) return c.symbol + Math.round(value).toLocaleString('en-US');
  if (value >= 100) return c.symbol + value.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  if (value >= 1) return c.symbol + value.toFixed(2);
  return c.symbol + value.toFixed(4);
}

// Populate dropdowns
function populateSelects() {
  var fromSel = $('from-currency');
  var toSel = $('to-currency');
  CURRENCIES.forEach(function(c) {
    var opt1 = document.createElement('option');
    opt1.value = c.code;
    opt1.textContent = c.code + ' — ' + c.name;
    fromSel.appendChild(opt1);

    var opt2 = document.createElement('option');
    opt2.value = c.code;
    opt2.textContent = c.code + ' — ' + c.name;
    toSel.appendChild(opt2);
  });
  fromSel.value = 'USD';
  toSel.value = 'EUR';
}

// Main conversion
function updateConversion() {
  var amount = parseFloat($('amount').value) || 0;
  var from = $('from-currency').value;
  var to = $('to-currency').value;
  var result = convert(amount, from, to);
  var rate = convert(1, from, to);
  var inverseRate = convert(1, to, from);

  $('converted-amount').textContent = formatCurrency(result, to);
  $('rate-info').textContent = '1 ' + from + ' = ' + formatCurrency(rate, to) + '  •  1 ' + to + ' = ' + formatCurrency(inverseRate, from);

  updateMultiCurrency();
  updateRateTable();
}

// Multi-currency comparison
function updateMultiCurrency() {
  var amount = parseFloat($('amount').value) || 0;
  var from = $('from-currency').value;
  var grid = $('multi-grid');
  grid.innerHTML = '';

  TOP10.forEach(function(code) {
    var val = convert(amount, from, code);
    var c = currencyMap[code];
    var card = document.createElement('div');
    card.className = 'multi-card';
    card.innerHTML = '<div class="mc-currency"><span class="mc-code">' + c.code + '</span><br>' + c.name + '</div><div class="mc-amount">' + formatCurrency(val, code) + '</div>';
    grid.appendChild(card);
  });

  $('multi-subtitle').textContent = formatCurrency(amount, from) + ' ' + from + ' in the 10 most popular currencies.';
}

// Rate reference table
var tableSortCol = 'rate';
var tableSortAsc = true;

function updateRateTable() {
  var base = $('from-currency').value;
  $('table-base-label').textContent = base;
  $('th-base').textContent = base;

  var rows = CURRENCIES.filter(function(c) { return c.code !== base; }).map(function(c) {
    var rate = convert(1, base, c.code);
    var inverse = convert(1, c.code, base);
    return { code: c.code, name: c.name, rate: rate, inverse: inverse };
  });

  rows.sort(function(a, b) {
    var va = a[tableSortCol], vb = b[tableSortCol];
    if (typeof va === 'string') return tableSortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
    return tableSortAsc ? va - vb : vb - va;
  });

  var tbody = $('rate-table-body');
  tbody.innerHTML = '';
  rows.forEach(function(r) {
    var tr = document.createElement('tr');
    var rateStr = r.rate >= 100 ? r.rate.toFixed(2) : r.rate >= 1 ? r.rate.toFixed(4) : r.rate.toFixed(6);
    var invStr = r.inverse >= 100 ? r.inverse.toFixed(2) : r.inverse >= 1 ? r.inverse.toFixed(4) : r.inverse.toFixed(6);
    tr.innerHTML = '<td><strong>' + r.code + '</strong></td><td>' + r.name + '</td><td class="number">' + rateStr + '</td><td class="number">' + invStr + '</td>';
    tbody.appendChild(tr);
  });

  document.querySelectorAll('#rate-table th').forEach(function(th) {
    th.classList.remove('sort-asc','sort-desc');
    if (th.dataset.sort === tableSortCol) th.classList.add(tableSortAsc ? 'sort-asc' : 'sort-desc');
  });
}

// Nomad tips
function renderTips() {
  var grid = $('tip-grid');
  grid.innerHTML = '';
  NOMAD_TIPS.forEach(function(t) {
    var c = currencyMap[t.currency];
    var rate = c ? '1 USD = ' + formatCurrency(c.rate, t.currency) : '';
    var card = document.createElement('div');
    card.className = 'tip-card';
    card.innerHTML = '<h3>' + t.city + ', ' + t.country + '</h3>' + (rate ? '<div class="tip-rate">' + rate + (t.budget ? ' • Budget: ' + t.budget : '') + '</div>' : '') + '<p>' + t.tip + '</p>';
    grid.appendChild(card);
  });
}

// Swap
function swapCurrencies() {
  var from = $('from-currency').value;
  var to = $('to-currency').value;
  $('from-currency').value = to;
  $('to-currency').value = from;
  updateConversion();
}

// Init
populateSelects();
updateConversion();
renderTips();

$('amount').addEventListener('input', updateConversion);
$('from-currency').addEventListener('change', updateConversion);
$('to-currency').addEventListener('change', updateConversion);
$('swap-btn').addEventListener('click', swapCurrencies);

document.querySelectorAll('#rate-table th').forEach(function(th) {
  th.addEventListener('click', function() {
    var col = th.dataset.sort;
    if (!col) return;
    if (tableSortCol === col) { tableSortAsc = !tableSortAsc; } else { tableSortCol = col; tableSortAsc = true; }
    updateRateTable();
  });
});
  </script>

