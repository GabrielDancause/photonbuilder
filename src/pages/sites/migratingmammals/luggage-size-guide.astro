      { name:"Spirit Airlines", dims:"22 x 18 x 10", weight:"No limit", personal:false, region:"north-america", checkedDims:"62 linear in", checkedWeight:"18 kg (40 lbs)", freeChecked:"0" },
      { name:"Frontier Airlines", dims:"24 x 16 x 10", weight:"No limit", personal:false, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"Air Canada", dims:"21.5 x 15.5 x 9", weight:"10 kg (22 lbs)", personal:true, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"WestJet", dims:"21.5 x 15.5 x 9", weight:"10 kg (22 lbs)", personal:true, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"British Airways", dims:"22 x 18 x 10", weight:"23 kg (50 lbs)", personal:true, region:"europe", checkedDims:"35 x 30 x 75 cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Lufthansa", dims:"21.5 x 15.5 x 9", weight:"8 kg (17 lbs)", personal:true, region:"europe", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Air France", dims:"21.5 x 13.5 x 9.5", weight:"12 kg (26 lbs)", personal:true, region:"europe", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"KLM", dims:"21.5 x 13.5 x 9.5", weight:"12 kg (26 lbs)", personal:true, region:"europe", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Ryanair", dims:"21.5 x 15.5 x 7.5", weight:"10 kg (22 lbs)", personal:false, region:"europe", checkedDims:"81 x 119 x 119 cm", checkedWeight:"20 kg (44 lbs)", freeChecked:"0" },
      { name:"EasyJet", dims:"22 x 17.5 x 9.5", weight:"15 kg (33 lbs)", personal:false, region:"europe", checkedDims:"170 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"Wizz Air", dims:"21.5 x 15.5 x 7.5", weight:"10 kg (22 lbs)", personal:false, region:"europe", checkedDims:"149 linear cm", checkedWeight:"20 kg (44 lbs)", freeChecked:"0" },
      { name:"Norwegian", dims:"21.5 x 15.5 x 9.5", weight:"10 kg (22 lbs)", personal:false, region:"europe", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"Turkish Airlines", dims:"21.5 x 15.5 x 9", weight:"8 kg (17 lbs)", personal:true, region:"europe", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Iberia", dims:"22 x 18 x 10", weight:"No limit", personal:true, region:"europe", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Emirates", dims:"22 x 15 x 8", weight:"7 kg (15 lbs)", personal:true, region:"middle-east", checkedDims:"150 linear cm", checkedWeight:"30 kg (66 lbs)", freeChecked:"2" },
      { name:"Qatar Airways", dims:"19.5 x 14.5 x 9.5", weight:"7 kg (15 lbs)", personal:true, region:"middle-east", checkedDims:"158 linear cm", checkedWeight:"30 kg (66 lbs)", freeChecked:"2" },
      { name:"Etihad Airways", dims:"22 x 15 x 8", weight:"7 kg (15 lbs)", personal:true, region:"middle-east", checkedDims:"150 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Singapore Airlines", dims:"22 x 14 x 9", weight:"7 kg (15 lbs)", personal:true, region:"asia", checkedDims:"158 linear cm", checkedWeight:"30 kg (66 lbs)", freeChecked:"2" },
      { name:"ANA", dims:"22 x 16 x 10", weight:"10 kg (22 lbs)", personal:true, region:"asia", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"2" },
      { name:"Japan Airlines", dims:"22 x 16 x 10", weight:"10 kg (22 lbs)", personal:true, region:"asia", checkedDims:"203 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"2" },
      { name:"Cathay Pacific", dims:"22 x 14 x 9", weight:"7 kg (15 lbs)", personal:true, region:"asia", checkedDims:"158 linear cm", checkedWeight:"30 kg (66 lbs)", freeChecked:"1" },
      { name:"Korean Air", dims:"22 x 14 x 9", weight:"12 kg (26 lbs)", personal:true, region:"asia", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Thai Airways", dims:"22 x 14 x 9", weight:"7 kg (15 lbs)", personal:true, region:"asia", checkedDims:"158 linear cm", checkedWeight:"30 kg (66 lbs)", freeChecked:"1" },
      { name:"AirAsia", dims:"22 x 14 x 9", weight:"7 kg (15 lbs)", personal:false, region:"asia", checkedDims:"62 linear in", checkedWeight:"20 kg (44 lbs)", freeChecked:"0" },
      { name:"Qantas", dims:"22 x 14 x 9", weight:"7 kg (15 lbs)", personal:true, region:"asia", checkedDims:"158 linear cm", checkedWeight:"30 kg (66 lbs)", freeChecked:"1" },
      { name:"LATAM Airlines", dims:"21.5 x 13.5 x 9.5", weight:"10 kg (22 lbs)", personal:true, region:"latin-america", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Avianca", dims:"22 x 14 x 9", weight:"10 kg (22 lbs)", personal:true, region:"latin-america", checkedDims:"158 linear cm", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" },
      { name:"Copa Airlines", dims:"22 x 14 x 9", weight:"10 kg (22 lbs)", personal:true, region:"latin-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"1" }
    ];

    const WEIGHT_ITEMS = [
      { name:"Empty Bag", default:2.5 }, { name:"Clothes", default:3.0 },
      { name:"Shoes (extra pair)", default:0.8 }, { name:"Toiletries", default:1.0 },
      { name:"Laptop", default:1.5 }, { name:"Chargers & Cables", default:0.5 },
      { name:"Camera", default:0.7 }, { name:"Books / Kindle", default:0.3 },
      { name:"Jacket / Coat", default:1.0 }, { name:"Snacks & Water", default:0.5 },
      { name:"Travel Pillow", default:0.3 }, { name:"Misc Items", default:0.5 }
    ];

    /* ---- Tabs ---- */
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      });
    });

    /* ---- Airline Tables ---- */
    let carryonSort = { col:'name', asc:true };
    let checkedSort = { col:'name', asc:true };

    function filterAirlines() {
      const q = document.getElementById('airline-search').value.toLowerCase();
      const region = document.getElementById('region-filter').value;
      return AIRLINES.filter(a => {
        if (q && !a.name.toLowerCase().includes(q)) return false;
        if (region !== 'all' && a.region !== region) return false;
        return true;
      });
    }

    function renderCarryonTable() {
      const data = filterAirlines().sort((a, b) => {
        let va = a[carryonSort.col], vb = b[carryonSort.col];
        if (typeof va === 'boolean') { va = va ? 1 : 0; vb = vb ? 1 : 0; }
        if (typeof va === 'string') return carryonSort.asc ? va.localeCompare(vb) : vb.localeCompare(va);
        return carryonSort.asc ? va - vb : vb - va;
      });
      const tbody = document.getElementById('carryon-body');
      tbody.innerHTML = '';
      data.forEach(a => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td><strong>${a.name}</strong></td>
          <td class="number">${a.dims}</td>
          <td class="number">${a.weight}</td>
          <td>${a.personal ? '<span class="status-badge status-yes">Yes</span>' : '<span class="status-badge status-no">No</span>'}</td>
          <td style="text-transform:capitalize;">${a.region.replace('-',' ')}</td>
        `;
        tbody.appendChild(tr);
      });
      document.querySelectorAll('#carryon-table th').forEach(th => {
        th.classList.remove('sort-asc','sort-desc');
        if (th.dataset.sort === carryonSort.col) th.classList.add(carryonSort.asc ? 'sort-asc' : 'sort-desc');
      });
    }

    function renderCheckedTable() {
      const data = filterAirlines().sort((a, b) => {
        let va = a[checkedSort.col], vb = b[checkedSort.col];
        if (typeof va === 'string') return checkedSort.asc ? va.localeCompare(vb) : vb.localeCompare(va);
        return checkedSort.asc ? va - vb : vb - va;
      });
      const tbody = document.getElementById('checked-body');
      tbody.innerHTML = '';
      data.forEach(a => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td><strong>${a.name}</strong></td>
          <td class="number">${a.checkedDims}</td>
          <td class="number">${a.checkedWeight}</td>
          <td class="number">${a.freeChecked}</td>
          <td style="text-transform:capitalize;">${a.region.replace('-',' ')}</td>
        `;
        tbody.appendChild(tr);
      });
      document.querySelectorAll('#checked-table th').forEach(th => {
        th.classList.remove('sort-asc','sort-desc');
        if (th.dataset.sort === checkedSort.col) th.classList.add(checkedSort.asc ? 'sort-asc' : 'sort-desc');
      });
    }

    function renderTables() { renderCarryonTable(); renderCheckedTable(); }
    renderTables();

    document.getElementById('airline-search').addEventListener('input', renderTables);
    document.getElementById('region-filter').addEventListener('change', renderTables);

    document.querySelectorAll('#carryon-table th').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (!col) return;
        if (carryonSort.col === col) { carryonSort.asc = !carryonSort.asc; }
        else { carryonSort.col = col; carryonSort.asc = true; }
        renderCarryonTable();
      });
    });
    document.querySelectorAll('#checked-table th').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (!col) return;
        if (checkedSort.col === col) { checkedSort.asc = !checkedSort.asc; }
        else { checkedSort.col = col; checkedSort.asc = true; }
        renderCheckedTable();
      });
    });

    /* ---- Trip Recommender ---- */
    document.getElementById('recommend-btn').addEventListener('click', () => {
      const days = parseInt(document.getElementById('trip-days').value) || 7;
      const style = document.getElementById('travel-style').value;
      const climate = document.getElementById('trip-climate').value;
      const laundry = document.getElementById('laundry-access').value;

      const styleMult = { ultralight:0.6, light:0.8, normal:1.0, heavy:1.3 }[style];
      const climateMult = { warm:0.8, mild:1.0, cold:1.4, mixed:1.2 }[climate];
      const laundryDiv = { yes:3, weekly:2, no:1 }[laundry];

      const effectiveDays = Math.ceil(days / laundryDiv);
      const baseL = 15 + effectiveDays * 4.5;
      const liters = Math.round(baseL * styleMult * climateMult);

      let rec, typ, tip;
      if (liters <= 30) {
        rec = 'Underseat / Personal Item'; typ = '18" bag or small backpack (25-35L)';
        tip = 'You can travel with just a personal item. Focus on versatile, wrinkle-free clothing.';
      } else if (liters <= 45) {
        rec = 'Carry-On Bag'; typ = '20-22" roller or 35-45L backpack';
        tip = 'A standard carry-on will work perfectly. Use packing cubes to maximize space.';
      } else if (liters <= 75) {
        rec = 'Medium Checked Bag'; typ = '25-27" suitcase (60-75L)';
        tip = 'Consider checking a medium bag, or reduce items to fit a carry-on and save on fees.';
      } else {
        rec = 'Large Checked Bag'; typ = '29-32" suitcase (90-120L)';
        tip = 'You will need a large checked bag. Consider laundry services to pack lighter.';
      }

      document.getElementById('rec-title').textContent = rec;
      document.getElementById('rec-size').innerHTML = `<strong>Recommended capacity:</strong> ~${liters}L for ${days} days`;
      document.getElementById('rec-type').innerHTML = `<strong>Bag type:</strong> ${typ}`;
      document.getElementById('rec-tip').innerHTML = `<strong>Tip:</strong> ${tip}`;
      document.getElementById('recommend-result').classList.add('visible');
    });

    /* ---- Weight Calculator ---- */
    const weightContainer = document.getElementById('weight-items');
    WEIGHT_ITEMS.forEach((item, i) => {
      const div = document.createElement('div');
      div.className = 'weight-item';
      div.innerHTML = `
        <span class="weight-item-name">${item.name}</span>
        <input type="number" class="weight-item-input" id="wi-${i}" value="${item.default}" min="0" max="50" step="0.1" />
      `;
      weightContainer.appendChild(div);
    });

    function getWeightLimit() {
      const preset = document.getElementById('weight-limit-preset').value;
      if (preset === 'custom') return parseFloat(document.getElementById('weight-limit-custom').value) || 10;
      return parseFloat(preset);
    }

    function calcWeight() {
      let total = 0;
      WEIGHT_ITEMS.forEach((_, i) => {
        total += parseFloat(document.getElementById('wi-' + i).value) || 0;
      });
      const limit = getWeightLimit();
      const remaining = limit - total;
      const pct = Math.min((total / limit) * 100, 100);

      document.getElementById('weight-total').textContent = total.toFixed(1) + ' kg';
      document.getElementById('weight-remaining').textContent = remaining.toFixed(1) + ' kg';

      const totalEl = document.getElementById('weight-total');
      const remEl = document.getElementById('weight-remaining');
      const bar = document.getElementById('weight-bar');

      totalEl.className = 'weight-total-value';
      remEl.className = 'weight-total-value';

      if (pct <= 70) {
        totalEl.classList.add('weight-ok'); remEl.classList.add('weight-ok');
        bar.style.background = '#22c55e';
      } else if (pct <= 90) {
        totalEl.classList.add('weight-warn'); remEl.classList.add('weight-warn');
        bar.style.background = '#f59e0b';
      } else {
        totalEl.classList.add('weight-over'); remEl.classList.add('weight-over');
        bar.style.background = '#ef4444';
      }
      bar.style.width = pct + '%';
    }

    calcWeight();

    document.querySelectorAll('.weight-item-input').forEach(input => {
      input.addEventListener('input', calcWeight);
    });

    document.getElementById('weight-limit-preset').addEventListener('change', (e) => {
      const custom = document.getElementById('weight-limit-custom');
      if (e.target.value === 'custom') { custom.style.display = 'block'; }
      else { custom.style.display = 'none'; }
      calcWeight();
    });
    document.getElementById('weight-limit-custom').addEventListener('input', calcWeight);
  </script>
