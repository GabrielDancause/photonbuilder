---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Luggage Size Guide",
    "url": "https://migratingmammals.com/luggage-size-guide",
    "description": "Interactive luggage size guide with carry-on limits for 30+ airlines, size comparison visualizer, trip duration recommender, and packing weight calculator.",
    "applicationCategory": "TravelApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "migratingmammals.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "migratingmammals.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://migratingmammals.com/logo.png"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the standard carry-on luggage size?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most common carry-on size limit is 22 x 14 x 9 inches (56 x 36 x 23 cm) including handles and wheels. However, limits vary by airline — budget carriers like Ryanair and Spirit enforce stricter dimensions, so always verify with your specific airline before flying."
        }
      },
      {
        "@type": "Question",
        "name": "What size luggage do I need for a 2-week trip?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For a 2-week trip, most travelers need a medium checked bag (25-27 inches). Light packers or those doing laundry mid-trip can manage with a carry-on (20-22 inches). The key factors are your packing style, climate at your destination, and whether you plan to do laundry."
        }
      },
      {
        "@type": "Question",
        "name": "Do airlines measure luggage with or without wheels?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most airlines measure total outside dimensions including wheels, handles, and pockets. This is why advertised luggage sizes often differ from airline-allowed dimensions. Always check the overall dimensions of your bag, not just the packing compartment size."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if my carry-on is too big?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If your carry-on exceeds the airline's size limits, you will typically be asked to gate-check it, which may be free or incur a fee of $25-$75 depending on the airline. Budget carriers like Spirit and Frontier are especially strict and may charge premium gate-check fees."
        }
      },
      {
        "@type": "Question",
        "name": "How much should a packed suitcase weigh?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Carry-on weight limits range from 7 kg (15 lbs) on budget airlines to 15 kg (33 lbs) on premium carriers. Checked bag limits are typically 23 kg (50 lbs) for economy and 32 kg (70 lbs) for business/first class. Overweight fees usually range from $50-$200 per bag."
        }
      }
    ]
  }
];

export const meta = {
  title: "Luggage Size Guide — Airline Limits & Packing Tips",
  description: "Interactive luggage size guide with carry-on limits for 30+ airlines, size comparison visualizer, trip duration recommender, and packing weight calculator.",
  category: "tool",
  published: "2026-04-12",
};
---

<SiteLayout
  site="migratingmammals"
  title="Luggage Size Guide"
  description="Interactive luggage size guide with carry-on limits for 30+ airlines, size comparison visualizer, trip duration recommender, and packing weight calculator."
  canonical="https://migratingmammals.com/luggage-size-guide"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
      font-family: var(--font-ui);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--accent-color); text-decoration: none; transition: opacity 0.2s; }
    a:hover { opacity: 0.8; text-decoration: underline; }

    .header-section {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(180deg, var(--card-bg) 0%, var(--bg-color) 100%);
      border-bottom: 1px solid var(--border-color);
    }
    .header-section h1 {
      font-size: 2.5rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 15px;
      letter-spacing: -0.02em;
    }
    .header-section p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }

    .section-title {
      font-size: 1.8rem;
      color: #fff;
      margin-bottom: 10px;
      font-weight: 800;
    }
    .section-desc {
      color: var(--text-secondary);
      margin-bottom: 25px;
      font-size: 0.95rem;
    }

    .section-block { margin-bottom: 60px; }

    /* Search & Filter */
    .search-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .search-bar input, .search-bar select {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 12px 16px;
      color: #fff;
      font-size: 0.95rem;
      font-family: var(--font-ui);
      outline: none;
      transition: border-color 0.2s;
    }
    .search-bar input:focus, .search-bar select:focus { border-color: var(--accent-color); }
    .search-bar input { flex: 1; min-width: 200px; }
    .search-bar select { min-width: 160px; }
    .search-bar select option { background: var(--card-bg); color: #fff; }

    /* Tables */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
    }
    table { width: 100%; border-collapse: collapse; min-width: 900px; text-align: left; }
    th, td { padding: 14px 18px; border-bottom: 1px solid var(--border-color); }
    th {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      font-weight: 600;
      background: rgba(0,0,0,0.2);
      cursor: pointer;
      user-select: none;
    }
    th:hover { color: #fff; }
    th.sort-asc::after { content: " ↑"; color: var(--accent-color); }
    th.sort-desc::after { content: " ↓"; color: var(--accent-color); }
    td { font-size: 0.9rem; }
    td strong { color: #fff; }
    td.number { font-family: var(--font-mono); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.02); }

    .status-badge {
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 600;
      display: inline-block;
    }
    .status-yes { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
    .status-no { background: rgba(239, 68, 68, 0.1); color: #ef4444; }

    /* Size Visualizer */
    .visualizer-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      align-items: end;
    }
    @media (max-width: 700px) { .visualizer-grid { grid-template-columns: repeat(2, 1fr); } }
    .size-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      transition: border-color 0.2s;
    }
    .size-card:hover { border-color: var(--accent-color); }
    .size-visual {
      margin: 0 auto 16px;
      border-radius: 8px;
      border: 2px solid var(--accent-color);
      background: rgba(59, 130, 246, 0.08);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--accent-color);
    }
    .size-label {
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 6px;
    }
    .size-dims {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-bottom: 4px;
    }
    .size-capacity {
      font-size: 0.8rem;
      color: var(--accent-color);
      font-weight: 600;
    }

    /* Tabs */
    .tab-bar {
      display: flex;
      gap: 0;
      margin-bottom: 20px;
      border-bottom: 1px solid var(--border-color);
    }
    .tab-btn {
      background: none;
      border: none;
      padding: 12px 24px;
      color: var(--text-secondary);
      font-size: 0.9rem;
      font-weight: 600;
      font-family: var(--font-ui);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
    }
    .tab-btn:hover { color: #fff; }
    .tab-btn.active { color: var(--accent-color); border-bottom-color: var(--accent-color); }
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* Tools */
    .tool-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 30px;
    }
    .tool-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    @media (max-width: 600px) { .tool-grid { grid-template-columns: 1fr; } }
    .tool-label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }
    .tool-input, .tool-select {
      width: 100%;
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 12px 16px;
      color: #fff;
      font-size: 0.95rem;
      font-family: var(--font-ui);
      outline: none;
      transition: border-color 0.2s;
    }
    .tool-input:focus, .tool-select:focus { border-color: var(--accent-color); }
    .tool-select option { background: var(--card-bg); color: #fff; }
    .tool-btn {
      background: var(--accent-color);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 12px 28px;
      font-size: 0.95rem;
      font-weight: 700;
      font-family: var(--font-ui);
      cursor: pointer;
      transition: opacity 0.2s;
      margin-top: 10px;
    }
    .tool-btn:hover { opacity: 0.85; }

    .result-box {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      margin-top: 20px;
      display: none;
    }
    .result-box.visible { display: block; }
    .result-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 8px;
    }
    .result-detail {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-bottom: 6px;
    }
    .result-detail strong { color: #fff; }
    .result-highlight {
      display: inline-block;
      padding: 4px 10px;
      background: rgba(59, 130, 246, 0.1);
      color: var(--accent-color);
      font-size: 0.85rem;
      font-weight: 700;
      border-radius: 4px;
      margin-top: 6px;
    }

    /* Weight calc */
    .weight-items {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }
    .weight-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 10px 14px;
    }
    .weight-item-name {
      font-size: 0.9rem;
      color: #fff;
    }
    .weight-item-input {
      width: 60px;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 6px 8px;
      color: #fff;
      font-size: 0.85rem;
      font-family: var(--font-mono);
      text-align: center;
      outline: none;
    }
    .weight-item-input:focus { border-color: var(--accent-color); }
    .weight-total-bar {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }
    .weight-total-label {
      font-size: 0.85rem;
      color: var(--text-secondary);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .weight-total-value {
      font-size: 1.4rem;
      font-weight: 800;
      font-family: var(--font-mono);
    }
    .weight-ok { color: #22c55e; }
    .weight-warn { color: #f59e0b; }
    .weight-over { color: #ef4444; }
    .weight-bar-track {
      width: 100%;
      height: 8px;
      background: rgba(255,255,255,0.05);
      border-radius: 4px;
      overflow: hidden;
      margin-top: 8px;
    }
    .weight-bar-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 0.3s, background 0.3s;
    }

    /* FAQ */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 60px;
    }
    .faq-section h2 {
      font-size: 1.8rem;
      color: #fff;
      margin-bottom: 30px;
      text-align: center;
    }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      margin-bottom: 15px;
      padding: 20px;
    }
    .faq-question {
      font-weight: 700;
      color: #fff;
      font-size: 1.1rem;
      margin-bottom: 10px;
    }
    .faq-answer {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    /* Related */
    .related-section {
      max-width: 800px;
      margin: 0 auto;
      border-top: 1px solid var(--border-color);
      padding-top: 40px;
    }
    .related-title {
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 15px;
    }
    .related-links {
      display: grid;
      grid-template-columns: 1fr;
      gap: 15px;
    }
    @media (min-width: 600px) { .related-links { grid-template-columns: 1fr 1fr; } }
    .related-link {
      display: block;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 15px 20px;
      transition: all 0.2s;
    }
    .related-link:hover {
      border-color: var(--accent-color);
      transform: translateY(-2px);
    }
    .related-link h3 {
      font-size: 1rem;
      color: #fff;
      margin-bottom: 4px;
    }
    .related-link p {
      font-size: 0.85rem;
      color: var(--text-secondary);
    }
  </style>

  <div class="header-section">
    <h1>Luggage Size Guide</h1>
    <p>Compare carry-on limits for 30+ airlines, visualize luggage sizes, and calculate the perfect bag for your trip.</p>
  </div>

  <div class="container">
    <!-- Size Comparison Visualizer -->
    <div class="section-block">
      <h2 class="section-title">Luggage Size Comparison</h2>
      <p class="section-desc">Visual comparison of the four main luggage categories with standard dimensions.</p>
      <div class="visualizer-grid">
        <div class="size-card">
          <div class="size-visual" style="width:70px;height:90px;">18"</div>
          <div class="size-label">Underseat</div>
          <div class="size-dims">18 x 14 x 8 in</div>
          <div class="size-capacity">25-35L</div>
        </div>
        <div class="size-card">
          <div class="size-visual" style="width:85px;height:120px;">22"</div>
          <div class="size-label">Carry-On</div>
          <div class="size-dims">22 x 14 x 9 in</div>
          <div class="size-capacity">35-45L</div>
        </div>
        <div class="size-card">
          <div class="size-visual" style="width:100px;height:145px;">26"</div>
          <div class="size-label">Medium Checked</div>
          <div class="size-dims">26 x 18 x 11 in</div>
          <div class="size-capacity">60-75L</div>
        </div>
        <div class="size-card">
          <div class="size-visual" style="width:115px;height:170px;">30"</div>
          <div class="size-label">Large Checked</div>
          <div class="size-dims">30 x 20 x 13 in</div>
          <div class="size-capacity">90-120L</div>
        </div>
      </div>
    </div>

    <!-- Airline Limits Table -->
    <div class="section-block">
      <h2 class="section-title">Airline Luggage Limits</h2>
      <p class="section-desc">Carry-on and checked bag size and weight limits for major airlines worldwide.</p>

      <div class="tab-bar">
        <button class="tab-btn active" data-tab="carryon">Carry-On Limits</button>
        <button class="tab-btn" data-tab="checked">Checked Bag Limits</button>
      </div>

      <div class="search-bar">
        <input type="text" id="airline-search" placeholder="Search airlines..." />
        <select id="region-filter">
          <option value="all">All Regions</option>
          <option value="north-america">North America</option>
          <option value="europe">Europe</option>
          <option value="asia">Asia-Pacific</option>
          <option value="middle-east">Middle East</option>
          <option value="latin-america">Latin America</option>
        </select>
      </div>

      <div id="tab-carryon" class="tab-content active">
        <div class="table-container">
          <table id="carryon-table">
            <thead>
              <tr>
                <th data-sort="name">Airline</th>
                <th data-sort="dims" class="sort-asc">Max Dimensions</th>
                <th data-sort="weight">Max Weight</th>
                <th data-sort="personal">Personal Item</th>
                <th data-sort="region">Region</th>
              </tr>
            </thead>
            <tbody id="carryon-body"></tbody>
          </table>
        </div>
      </div>

      <div id="tab-checked" class="tab-content">
        <div class="table-container">
          <table id="checked-table">
            <thead>
              <tr>
                <th data-sort="name">Airline</th>
                <th data-sort="checkedDims">Max Dimensions</th>
                <th data-sort="checkedWeight">Max Weight</th>
                <th data-sort="freeChecked">Free Bags (Economy)</th>
                <th data-sort="region">Region</th>
              </tr>
            </thead>
            <tbody id="checked-body"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Trip Duration Recommender -->
    <div class="section-block">
      <h2 class="section-title">Trip Duration Recommender</h2>
      <p class="section-desc">Enter your trip details and get a personalized luggage size recommendation.</p>
      <div class="tool-card">
        <div class="tool-grid">
          <div>
            <label class="tool-label">Trip Length (days)</label>
            <input type="number" class="tool-input" id="trip-days" min="1" max="365" value="7" />
          </div>
          <div>
            <label class="tool-label">Travel Style</label>
            <select class="tool-select" id="travel-style">
              <option value="ultralight">Ultralight Minimalist</option>
              <option value="light">Light Packer</option>
              <option value="normal" selected>Normal Packer</option>
              <option value="heavy">Heavy Packer</option>
            </select>
          </div>
          <div>
            <label class="tool-label">Climate</label>
            <select class="tool-select" id="trip-climate">
              <option value="warm">Warm / Tropical</option>
              <option value="mild" selected>Mild / Temperate</option>
              <option value="cold">Cold / Winter</option>
              <option value="mixed">Mixed / Layering</option>
            </select>
          </div>
          <div>
            <label class="tool-label">Laundry Access</label>
            <select class="tool-select" id="laundry-access">
              <option value="yes">Yes, every few days</option>
              <option value="weekly">Yes, weekly</option>
              <option value="no" selected>No laundry access</option>
            </select>
          </div>
        </div>
        <button class="tool-btn" id="recommend-btn">Get Recommendation</button>
        <div class="result-box" id="recommend-result">
          <div class="result-title" id="rec-title"></div>
          <div class="result-detail" id="rec-size"></div>
          <div class="result-detail" id="rec-type"></div>
          <div class="result-detail" id="rec-tip"></div>
        </div>
      </div>
    </div>

    <!-- Packing Weight Calculator -->
    <div class="section-block">
      <h2 class="section-title">Packing Weight Calculator</h2>
      <p class="section-desc">Estimate your total packed weight and check against airline limits.</p>
      <div class="tool-card">
        <div style="margin-bottom:16px;">
          <label class="tool-label">Airline Weight Limit</label>
          <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
            <select class="tool-select" id="weight-limit-preset" style="width:auto;min-width:180px;">
              <option value="7">Budget Carrier — 7 kg</option>
              <option value="10" selected>Standard — 10 kg</option>
              <option value="12">Premium Economy — 12 kg</option>
              <option value="15">Business Class — 15 kg</option>
              <option value="23">Checked Bag — 23 kg</option>
              <option value="32">Checked (Business) — 32 kg</option>
              <option value="custom">Custom...</option>
            </select>
            <input type="number" class="tool-input" id="weight-limit-custom" style="width:80px;display:none;" min="1" max="50" placeholder="kg" />
          </div>
        </div>
        <div class="weight-items" id="weight-items"></div>
        <div class="weight-total-bar">
          <div>
            <div class="weight-total-label">Total Packed Weight</div>
            <div class="weight-total-value" id="weight-total">0.0 kg</div>
          </div>
          <div style="text-align:right;">
            <div class="weight-total-label">Remaining</div>
            <div class="weight-total-value" id="weight-remaining">10.0 kg</div>
          </div>
        </div>
        <div class="weight-bar-track">
          <div class="weight-bar-fill" id="weight-bar" style="width:0%;background:#22c55e;"></div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-question">What is the standard carry-on luggage size?</div>
        <div class="faq-answer">The most common carry-on size limit is 22 x 14 x 9 inches (56 x 36 x 23 cm) including handles and wheels. However, limits vary by airline — budget carriers like Ryanair and Spirit enforce stricter dimensions, so always verify with your specific airline before flying.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">What size luggage do I need for a 2-week trip?</div>
        <div class="faq-answer">For a 2-week trip, most travelers need a medium checked bag (25-27 inches). Light packers or those doing laundry mid-trip can manage with a carry-on (20-22 inches). The key factors are your packing style, climate at your destination, and whether you plan to do laundry.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">Do airlines measure luggage with or without wheels?</div>
        <div class="faq-answer">Most airlines measure total outside dimensions including wheels, handles, and pockets. This is why advertised luggage sizes often differ from airline-allowed dimensions. Always check the overall dimensions of your bag, not just the packing compartment size.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">What happens if my carry-on is too big?</div>
        <div class="faq-answer">If your carry-on exceeds the airline's size limits, you will typically be asked to gate-check it, which may be free or incur a fee of $25-$75 depending on the airline. Budget carriers like Spirit and Frontier are especially strict and may charge premium gate-check fees.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">How much should a packed suitcase weigh?</div>
        <div class="faq-answer">Carry-on weight limits range from 7 kg (15 lbs) on budget airlines to 15 kg (33 lbs) on premium carriers. Checked bag limits are typically 23 kg (50 lbs) for economy and 32 kg (70 lbs) for business/first class. Overweight fees usually range from $50-$200 per bag.</div>
      </div>
    </div>

    <!-- Related -->
    <div class="related-section">
      <div class="related-title">Related Resources</div>
      <div class="related-links">
        <a href="/best-travel-backpacks" class="related-link">
          <h3>Best Travel Backpacks</h3>
          <p>Compare the top 12 travel backpacks for digital nomads.</p>
        </a>
        <a href="/cost-of-living-comparison" class="related-link">
          <h3>Cost of Living Comparison</h3>
          <p>Analyze living expenses across popular digital nomad cities.</p>
        </a>
      </div>
    </div>
  </div>

  <script>
    const AIRLINES = [
      { name:"American Airlines", dims:"22 x 14 x 9", weight:"No limit", personal:true, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"Delta Air Lines", dims:"22 x 14 x 9", weight:"No limit", personal:true, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"United Airlines", dims:"22 x 14 x 9", weight:"No limit", personal:true, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
      { name:"Southwest Airlines", dims:"24 x 16 x 10", weight:"No limit", personal:true, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"2" },
      { name:"JetBlue", dims:"22 x 14 x 9", weight:"No limit", personal:true, region:"north-america", checkedDims:"62 linear in", checkedWeight:"23 kg (50 lbs)", freeChecked:"0" },
