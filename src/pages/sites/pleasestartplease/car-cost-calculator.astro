---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'The Real Cost of Owning a Car | 5-Year Cost Calculator',
  description: 'Interactive calculator showing the true 5-year cost of owning different vehicles. Compare MSRP, depreciation, insurance, and maintenance to find the smartest buy.',
  category: 'calculator',
  keywords: ['car cost calculator', 'true cost to own', 'depreciation calculator', 'car ownership cost', 'buy vs lease', 'used vs new car']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Please Start Please" },
    "publisher": { "@type": "Organization", "name": "Please Start Please" },
    "datePublished": "2023-10-25",
    "dateModified": "2023-10-25"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the biggest hidden cost of owning a car?",
        "acceptedAnswer": { "@type": "Answer", "text": "Depreciation is usually the largest hidden cost, often accounting for 40% or more of the total 5-year ownership cost. A new car loses roughly 15% of its value each year for the first few years." }
      },
      {
        "@type": "Question",
        "name": "How much does the average American spend on a car per year?",
        "acceptedAnswer": { "@type": "Answer", "text": "According to AAA, the average American spends over $12,182 per year to own and operate a new vehicle, which includes depreciation, insurance, fuel, maintenance, and taxes." }
      },
      {
        "@type": "Question",
        "name": "Is it cheaper to buy a used car?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. A 5-year-old used car has already experienced its steepest depreciation. While maintenance costs might be slightly higher, the savings on depreciation and insurance typically make used cars significantly cheaper to own overall." }
      },
      {
        "@type": "Question",
        "name": "Are electric vehicles cheaper to own?",
        "acceptedAnswer": { "@type": "Answer", "text": "EVs generally have much lower fuel and maintenance costs. However, they may have a higher initial purchase price and sometimes higher insurance rates. Over a 5-year period, EVs often cost less to own than comparable gas vehicles." }
      },
      {
        "@type": "Question",
        "name": "Should I buy or lease my next car?",
        "acceptedAnswer": { "@type": "Answer", "text": "Buying is generally cheaper in the long run, especially if you keep the car for more than 5 years. Leasing typically results in higher lifetime costs but offers lower monthly payments and a new car every few years." }
      }
    ]
  }
]);
---

<SiteLayout site="pleasestartplease" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <section class="car-hero">
    <div class="car-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>The <em>Real</em> Cost of Owning a Car</h1>
    <p class="car-hero-hook">The average American spends <strong>$12,182 every year</strong> on their vehicle. <br/>See where your money actually goes.</p>
    <div class="car-hero-stats">
      <div class="car-stat">
        <span class="car-stat-num">$12,182</span>
        <span class="car-stat-label">Avg Yearly Cost</span>
      </div>
      <div class="car-stat">
        <span class="car-stat-num">~40%</span>
        <span class="car-stat-label">Lost to Depreciation</span>
      </div>
      <div class="car-stat">
        <span class="car-stat-num">5 Years</span>
        <span class="car-stat-label">Standard Loan Term</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="car-section">
    <h2 class="car-section-title">5-Year Ownership Calculator</h2>
    <p class="car-section-sub">Select a vehicle type or enter your own numbers to see the true cost of ownership over 5 years.</p>

    <div class="car-calc-container">
      <div class="car-calc-inputs">
        <div class="car-input-group full-width">
          <label for="vehicle-select">Select Vehicle Profile</label>
          <select id="vehicle-select">
            <option value="">— Select a vehicle —</option>
            <option value="custom">Custom (enter your own)</option>
          </select>
        </div>

        <div class="car-input-row">
          <div class="car-input-group">
            <label for="input-msrp">Purchase Price / MSRP</label>
            <div class="car-input-wrap"><span class="car-input-prefix">$</span><input type="number" id="input-msrp" min="0" step="500" /></div>
          </div>
          <div class="car-input-group">
            <label for="input-mpg">Fuel Efficiency (MPG / MPGe)</label>
            <div class="car-input-wrap"><input type="number" id="input-mpg" min="1" step="1" /><span class="car-input-suffix">mpg</span></div>
          </div>
        </div>

        <div class="car-input-row">
          <div class="car-input-group">
            <label for="input-ins">Annual Insurance</label>
            <div class="car-input-wrap"><span class="car-input-prefix">$</span><input type="number" id="input-ins" min="0" step="100" /></div>
          </div>
          <div class="car-input-group">
            <label for="input-maint">Annual Maintenance</label>
            <div class="car-input-wrap"><span class="car-input-prefix">$</span><input type="number" id="input-maint" min="0" step="50" /></div>
          </div>
        </div>

        <div class="car-input-row">
          <div class="car-input-group">
             <label class="car-checkbox-label">
                <input type="checkbox" id="input-is-used" />
                This is a used vehicle (lower depreciation)
             </label>
          </div>
          <div class="car-input-group">
             <label class="car-checkbox-label">
                <input type="checkbox" id="input-is-ev" />
                This is an Electric Vehicle (EV)
             </label>
          </div>
        </div>

        <div class="car-controls">
           <div class="car-slider-group">
              <div class="car-slider-header">
                <label for="slider-miles">Miles Driven per Year</label>
                <span id="val-miles">12,000</span>
              </div>
              <input type="range" id="slider-miles" min="2000" max="30000" step="500" value="12000" />
           </div>

           <div class="car-slider-group" id="gas-slider-container">
              <div class="car-slider-header">
                <label for="slider-gas">Gas Price (per gallon)</label>
                <span id="val-gas">$3.50</span>
              </div>
              <input type="range" id="slider-gas" min="1.50" max="7.00" step="0.10" value="3.50" />
           </div>

           <div class="car-slider-group" id="elec-slider-container" style="display:none;">
              <div class="car-slider-header">
                <label for="slider-elec">Electricity Price (per kWh)</label>
                <span id="val-elec">$0.13</span>
              </div>
              <input type="range" id="slider-elec" min="0.05" max="0.50" step="0.01" value="0.13" />
           </div>

           <div class="car-slider-group">
              <div class="car-slider-header">
                <label for="slider-apr">Loan Interest Rate (APR)</label>
                <span id="val-apr">6.5%</span>
              </div>
              <input type="range" id="slider-apr" min="0" max="25" step="0.5" value="6.5" />
           </div>
        </div>
      </div>

      <div class="car-calc-results">
        <h3 id="result-vehicle-name" class="car-result-title">Select a Vehicle</h3>

        <div class="car-result-highlight">
            <div class="car-total-cost">
                <span class="car-total-label">5-Year Total Cost</span>
                <span class="car-total-value" id="res-total-cost">$0</span>
            </div>
            <div class="car-monthly-cost">
                <span class="car-monthly-label">True Monthly Cost</span>
                <span class="car-monthly-value" id="res-monthly-cost">$0</span>
            </div>
        </div>

        <div class="car-donut-container">
            <canvas id="costDonut" width="240" height="240"></canvas>
            <div class="car-donut-legend" id="donut-legend"></div>
        </div>

        <div class="car-loan-info">
            <div class="car-loan-row"><span>Monthly Loan Payment (60mo):</span> <strong id="res-loan-pmt">$0</strong></div>
            <div class="car-loan-row"><span>Total Interest Paid:</span> <strong id="res-loan-int">$0</strong></div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="car-section car-alt-bg">
    <h2 class="car-section-title">Side-by-Side Comparison</h2>
    <p class="car-section-sub">Compare the 5-year costs of two vehicles directly.</p>

    <div class="car-compare-controls">
        <select id="compare-v1"></select>
        <span class="car-vs">VS</span>
        <select id="compare-v2"></select>
    </div>

    <div class="car-compare-chart-container">
        <div id="compare-bars"></div>
    </div>
  </section>

  <!-- DATA TABLE -->
  <section class="car-section">
    <h2 class="car-section-title">Vehicle Cost Rankings</h2>
    <p class="car-section-sub">How common vehicle types stack up over 5 years (12,000 miles/yr, $3.50 gas, 6.5% APR).</p>

    <div class="car-table-wrapper">
      <table class="car-table">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Vehicle Type</th>
            <th>Purchase Price</th>
            <th>5-Year Depr.</th>
            <th>Fuel/Energy</th>
            <th>Total 5-Yr Cost</th>
          </tr>
        </thead>
        <tbody id="car-table-body">
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>
  </section>

  <!-- INSIGHTS -->
  <section class="car-section">
      <div class="car-insights-grid">
          <div class="car-insight-card">
              <h3>The Hidden Killer: Depreciation</h3>
              <p>Most buyers focus on the monthly payment and ignore depreciation. A new car typically loses <strong>15% of its value</strong> each year for the first few years. On a $40,000 truck, that's $6,000 gone in the first 12 months alone—more than gas and insurance combined.</p>
          </div>
          <div class="car-insight-card">
              <h3>Opportunity Cost</h3>
              <p>If you invest the difference between an expensive luxury car and a reliable used car into an index fund returning 8%, over a decade that difference can compound into tens of thousands of dollars. The true cost of an expensive car includes the wealth you <em>didn't</em> build.</p>
          </div>
      </div>
  </section>

  <!-- METHODOLOGY & FAQ -->
  <section class="car-section car-alt-bg">
    <h2 class="car-section-title">Methodology</h2>
    <p class="car-methodology">
      This calculator estimates 5-year ownership costs based on standard industry formulas.
      <strong>Depreciation</strong> assumes 15% for years 1-2 and 10% for years 3-5 for new cars, and a flat 7% for 5-year-old used cars.
      <strong>Fuel</strong> is calculated based on MPG, miles driven, and gas/electricity price. EV efficiency assumes 1 MPGe = 33.7 kWh.
      <strong>Loan payments</strong> assume a 60-month term with 0 down (to simplify total cost comparison) at the selected APR.
      <strong>Registration</strong> is estimated at a flat $200/year.
      Taxes and fees vary widely by location and are excluded.
    </p>
  </section>

  <section class="car-section">
    <h2 class="car-section-title">Frequently Asked Questions</h2>
    <div class="car-faq-list">
      <div class="car-faq-item">
        <h3>What is the biggest hidden cost of owning a car?</h3>
        <p>Depreciation is usually the largest hidden cost, often accounting for 40% or more of the total 5-year ownership cost. A new car loses roughly 15% of its value each year for the first few years.</p>
      </div>
      <div class="car-faq-item">
        <h3>How much does the average American spend on a car per year?</h3>
        <p>According to AAA, the average American spends over $12,182 per year to own and operate a new vehicle, which includes depreciation, insurance, fuel, maintenance, and taxes.</p>
      </div>
      <div class="car-faq-item">
        <h3>Is it cheaper to buy a used car?</h3>
        <p>Yes. A 5-year-old used car has already experienced its steepest depreciation. While maintenance costs might be slightly higher, the savings on depreciation and insurance typically make used cars significantly cheaper to own overall.</p>
      </div>
      <div class="car-faq-item">
        <h3>Are electric vehicles cheaper to own?</h3>
        <p>EVs generally have much lower fuel and maintenance costs. However, they may have a higher initial purchase price and sometimes higher insurance rates. Over a 5-year period, EVs often cost less to own than comparable gas vehicles.</p>
      </div>
      <div class="car-faq-item">
        <h3>Should I buy or lease my next car?</h3>
        <p>Buying is generally cheaper in the long run, especially if you keep the car for more than 5 years. Leasing typically results in higher lifetime costs but offers lower monthly payments and a new car every few years.</p>
      </div>
    </div>
  </section>

  <style is:global>
    :root {
      --accent-color: #EF4444; /* red accent */
      --bg-main: #0a0f1d;
      --bg-card: #152040;
      --border-color: #2a3b66;
      --text-primary: #e2e8f0;
      --text-secondary: #94a3b8;

      --c-depr: #EF4444;
      --c-fuel: #f59e0b;
      --c-ins: #3b82f6;
      --c-maint: #10b981;
      --c-int: #8b5cf6;
      --c-reg: #64748b;
    }

    body {
      background-color: var(--bg-main);
      color: var(--text-primary);
      font-family: system-ui, -apple-system, sans-serif;
      margin: 0;
      padding: 0;
    }

    /* Animations */
    @keyframes car-fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Hero */
    .car-hero {
      text-align: center;
      padding: 4rem 1.5rem 3rem;
      background: linear-gradient(135deg, rgba(239,68,68,0.12) 0%, rgba(239,68,68,0.02) 60%, rgba(239,68,68,0.08) 100%);
      border-bottom: 1px solid var(--border-color);
      position: relative;
      overflow: hidden;
    }
    .car-hero-badge {
      display: inline-block;
      background: rgba(239,68,68,0.15);
      color: var(--accent-color);
      padding: 0.4rem 1rem;
      border-radius: 100px;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      margin-bottom: 1.5rem;
      animation: car-fadeUp 0.6s ease both;
    }
    .car-hero h1 {
      font-size: clamp(1.8rem, 5vw, 3rem);
      line-height: 1.15;
      margin: 0 auto 1rem;
      max-width: 700px;
      color: var(--text-primary);
      animation: car-fadeUp 0.6s 0.1s ease both;
    }
    .car-hero h1 em {
      color: var(--accent-color);
      font-style: italic;
    }
    .car-hero-hook {
      font-size: 1.15rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
      animation: car-fadeUp 0.6s 0.2s ease both;
    }
    .car-hero-stats {
      display: flex;
      justify-content: center;
      gap: 3rem;
      flex-wrap: wrap;
      animation: car-fadeUp 0.6s 0.3s ease both;
    }
    .car-stat {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .car-stat-num {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--accent-color);
    }
    .car-stat-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* Sections */
    .car-section {
      padding: 3.5rem 1.5rem;
      max-width: 1000px;
      margin: 0 auto;
    }
    .car-alt-bg {
      background: rgba(21,32,64,0.3);
      border-top: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
      max-width: 100%;
    }
    .car-section-title {
      text-align: center;
      font-size: 2rem;
      margin-bottom: 0.5rem;
      color: #fff;
    }
    .car-section-sub {
      text-align: center;
      color: var(--text-secondary);
      margin-bottom: 2.5rem;
      font-size: 1.1rem;
    }

    /* Calculator */
    .car-calc-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }
    @media (max-width: 800px) {
      .car-calc-container { grid-template-columns: 1fr; }
    }

    /* Inputs */
    .car-calc-inputs {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .car-input-row {
      display: flex;
      gap: 1rem;
    }
    .car-input-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .full-width { flex: 100%; }

    .car-input-group label {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .car-checkbox-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem !important;
      text-transform: none !important;
      color: var(--text-primary) !important;
      cursor: pointer;
      user-select: none;
      margin-top: 0.5rem;
    }
    .car-checkbox-label input {
        width: 18px;
        height: 18px;
        accent-color: var(--accent-color);
    }

    select, input[type="number"] {
      background: rgba(0,0,0,0.2);
      border: 1px solid var(--border-color);
      color: #fff;
      padding: 0.75rem 1rem;
      border-radius: 8px;
      font-size: 1rem;
      width: 100%;
      box-sizing: border-box;
      transition: all 0.2s;
    }
    select:focus, input[type="number"]:focus {
      outline: none;
      border-color: var(--accent-color);
      background: rgba(0,0,0,0.4);
    }

    .car-input-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }
    .car-input-prefix {
      position: absolute;
      left: 1rem;
      color: var(--text-secondary);
    }
    .car-input-suffix {
      position: absolute;
      right: 1rem;
      color: var(--text-secondary);
    }
    .car-input-wrap input { padding-left: 2rem; }
    #input-mpg { padding-left: 1rem; padding-right: 3rem; }

    /* Sliders */
    .car-controls {
      margin-top: 1rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .car-slider-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .car-slider-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .car-slider-header label {
      font-size: 0.85rem;
      color: var(--text-secondary);
    }
    .car-slider-header span {
      font-weight: 700;
      color: var(--accent-color);
    }
    input[type=range] {
      -webkit-appearance: none;
      width: 100%;
      background: transparent;
    }
    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      height: 18px;
      width: 18px;
      border-radius: 50%;
      background: var(--accent-color);
      cursor: pointer;
      margin-top: -7px;
    }
    input[type=range]::-webkit-slider-runnable-track {
      width: 100%;
      height: 4px;
      cursor: pointer;
      background: var(--border-color);
      border-radius: 2px;
    }

    /* Results */
    .car-calc-results {
      background: rgba(0,0,0,0.2);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .car-result-title {
      font-size: 1.25rem;
      color: #fff;
      margin: 0;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }
    .car-result-highlight {
        display: flex;
        gap: 1rem;
    }
    .car-total-cost, .car-monthly-cost {
        flex: 1;
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.2);
        padding: 1rem;
        border-radius: 8px;
        text-align: center;
    }
    .car-monthly-cost {
        background: rgba(59,130,246,0.1);
        border: 1px solid rgba(59,130,246,0.2);
    }
    .car-total-label, .car-monthly-label {
        display: block;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-bottom: 0.25rem;
    }
    .car-total-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--accent-color);
    }
    .car-monthly-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #60a5fa;
    }

    .car-donut-container {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin: 0 auto;
    }
    @media(max-width: 450px) {
        .car-donut-container { flex-direction: column; }
    }
    #costDonut {
        width: 180px;
        height: 180px;
    }
    .car-donut-legend {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        font-size: 0.85rem;
    }
    .leg-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .leg-color {
        width: 12px; height: 12px; border-radius: 3px;
    }
    .leg-val { font-weight: 600; color: #fff; margin-left: auto; padding-left: 1rem; }

    .car-loan-info {
        background: rgba(0,0,0,0.3);
        padding: 1rem;
        border-radius: 8px;
        font-size: 0.9rem;
    }
    .car-loan-row {
        display: flex;
        justify-content: space-between;
        padding: 0.25rem 0;
    }

    /* Comparison */
    .car-compare-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 2rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }
    .car-vs {
        font-weight: 800;
        color: var(--text-secondary);
    }
    .car-compare-chart-container {
        max-width: 800px;
        margin: 0 auto;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
    }
    #compare-bars {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    .comp-bar-wrapper {
        width: 100%;
    }
    .comp-bar-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }
    .comp-bar-total {
        color: var(--accent-color);
    }
    .comp-bar-track {
        height: 24px;
        background: rgba(0,0,0,0.3);
        border-radius: 12px;
        display: flex;
        overflow: hidden;
    }
    .comp-segment {
        height: 100%;
        transition: width 0.5s ease;
    }
    .comp-legend {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
        margin-top: 1.5rem;
        font-size: 0.8rem;
    }

    /* Table */
    .car-table-wrapper {
        overflow-x: auto;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
    }
    .car-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }
    .car-table th, .car-table td {
        padding: 1rem;
        border-bottom: 1px solid var(--border-color);
        white-space: nowrap;
    }
    .car-table th {
        background: rgba(0,0,0,0.2);
        color: var(--text-secondary);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .car-table tbody tr:hover {
        background: rgba(255,255,255,0.02);
    }
    .td-rank { font-weight: 800; color: var(--text-secondary); text-align: center; }
    .td-name { font-weight: 600; color: #fff; }
    .td-total { font-weight: 700; color: var(--accent-color); }

    /* Insights & FAQ */
    .car-insights-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }
    @media(max-width: 700px) {
        .car-insights-grid { grid-template-columns: 1fr; }
    }
    .car-insight-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        padding: 2rem;
        border-radius: 12px;
    }
    .car-insight-card h3 {
        color: var(--accent-color);
        margin-top: 0;
        margin-bottom: 1rem;
    }
    .car-insight-card p {
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    .car-methodology {
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--text-secondary);
        max-width: 800px;
        margin: 0 auto;
        text-align: center;
    }

    .car-faq-list {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .car-faq-item {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        padding: 1.5rem;
        border-radius: 8px;
    }
    .car-faq-item h3 {
        margin: 0 0 0.75rem 0;
        color: #fff;
        font-size: 1.1rem;
    }
    .car-faq-item p {
        margin: 0;
        color: var(--text-secondary);
        line-height: 1.5;
        font-size: 0.95rem;
    }
  </style>

  <script is:inline>
  (function() {
    'use strict';

    var VEHICLES = [
      { name: "Economy Sedan (Corolla)", msrp: 22000, mpg: 35, ins: 1400, maint: 600, isUsed: false, isEV: false },
      { name: "SUV (RAV4)", msrp: 32000, mpg: 30, ins: 1800, maint: 750, isUsed: false, isEV: false },
      { name: "Truck (F-150)", msrp: 40000, mpg: 22, ins: 2100, maint: 900, isUsed: false, isEV: false },
      { name: "Luxury (BMW 3)", msrp: 44000, mpg: 30, ins: 2400, maint: 1200, isUsed: false, isEV: false },
      { name: "EV (Tesla 3)", msrp: 40000, mpg: 132, ins: 2200, maint: 400, isUsed: false, isEV: true },
      { name: "Minivan (Odyssey)", msrp: 38000, mpg: 26, ins: 1600, maint: 700, isUsed: false, isEV: false },
      { name: "Sports (Mustang)", msrp: 32000, mpg: 25, ins: 2800, maint: 800, isUsed: false, isEV: false },
      { name: "Used (5yr Corolla)", msrp: 14000, mpg: 33, ins: 1100, maint: 800, isUsed: true, isEV: false }
    ];

    var COLORS = {
        depr: '#EF4444',
        fuel: '#f59e0b',
        ins: '#3b82f6',
        maint: '#10b981',
        int: '#8b5cf6',
        reg: '#64748b'
    };

    var REG_FEE = 200;

    function fmt(n) {
        return '$' + Math.round(n).toLocaleString();
    }

    function calculateCost(vehicleData, milesYr, gasPrice, elecPrice, apr) {
        var msrp = vehicleData.msrp;

        // Depreciation
        var deprTotal = 0;
        var currentVal = msrp;
        var deprRates = vehicleData.isUsed ? [0.07, 0.07, 0.07, 0.07, 0.07] : [0.15, 0.15, 0.10, 0.10, 0.10];
        for(var i=0; i<5; i++) {
            var drop = currentVal * deprRates[i];
            deprTotal += drop;
            currentVal -= drop;
        }

        // Fuel
        var fuelTotal = 0;
        if (vehicleData.isEV) {
            // 1 MPGe = 33.7 kWh
            var kwhPerMile = 33.7 / vehicleData.mpg;
            fuelTotal = (milesYr * kwhPerMile * elecPrice) * 5;
        } else {
            var gallonsPerYear = milesYr / vehicleData.mpg;
            fuelTotal = (gallonsPerYear * gasPrice) * 5;
        }

        // Insurance & Maint
        var insTotal = vehicleData.ins * 5;
        var maintTotal = vehicleData.maint * 5;
        var regTotal = REG_FEE * 5;

        // Loan (60 mo, 0 down)
        var pmt = 0;
        var intTotal = 0;
        if (apr > 0) {
            var r = (apr / 100) / 12;
            var n = 60;
            pmt = msrp * (r * Math.pow(1+r, n)) / (Math.pow(1+r, n) - 1);
            intTotal = (pmt * 60) - msrp;
        } else {
            pmt = msrp / 60;
        }

        var totalCost = deprTotal + fuelTotal + insTotal + maintTotal + regTotal + intTotal;

        return {
            depr: deprTotal,
            fuel: fuelTotal,
            ins: insTotal,
            maint: maintTotal,
            int: intTotal,
            reg: regTotal,
            total: totalCost,
            pmt: pmt
        };
    }

    function updateUI() {
        var vIdx = document.getElementById('vehicle-select').value;
        var msrp = parseFloat(document.getElementById('input-msrp').value) || 0;
        var mpg = parseFloat(document.getElementById('input-mpg').value) || 1;
        var ins = parseFloat(document.getElementById('input-ins').value) || 0;
        var maint = parseFloat(document.getElementById('input-maint').value) || 0;
        var isUsed = document.getElementById('input-is-used').checked;
        var isEV = document.getElementById('input-is-ev').checked;

        var miles = parseFloat(document.getElementById('slider-miles').value);
        var gas = parseFloat(document.getElementById('slider-gas').value);
        var elec = parseFloat(document.getElementById('slider-elec').value);
        var apr = parseFloat(document.getElementById('slider-apr').value);

        document.getElementById('val-miles').textContent = miles.toLocaleString();
        document.getElementById('val-gas').textContent = '$' + gas.toFixed(2);
        document.getElementById('val-elec').textContent = '$' + elec.toFixed(2);
        document.getElementById('val-apr').textContent = apr.toFixed(1) + '%';

        document.getElementById('gas-slider-container').style.display = isEV ? 'none' : 'flex';
        document.getElementById('elec-slider-container').style.display = isEV ? 'flex' : 'none';

        var vName = vIdx === 'custom' || vIdx === '' ? 'Custom Vehicle Profile' : VEHICLES[vIdx].name;
        document.getElementById('result-vehicle-name').textContent = vName;

        var vData = { msrp: msrp, mpg: mpg, ins: ins, maint: maint, isUsed: isUsed, isEV: isEV };
        var res = calculateCost(vData, miles, gas, elec, apr);

        document.getElementById('res-total-cost').textContent = fmt(res.total);
        document.getElementById('res-monthly-cost').textContent = fmt(res.total / 60);
        document.getElementById('res-loan-pmt').textContent = fmt(res.pmt);
        document.getElementById('res-loan-int').textContent = fmt(res.int);

        drawDonut(res);
        renderTable(miles, gas, elec, apr);
        updateCompare(miles, gas, elec, apr);
    }

    function drawDonut(res) {
        var canvas = document.getElementById('costDonut');
        var ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        var data = [
            { label: 'Depreciation', val: res.depr, color: COLORS.depr },
            { label: 'Fuel/Energy', val: res.fuel, color: COLORS.fuel },
            { label: 'Insurance', val: res.ins, color: COLORS.ins },
            { label: 'Maintenance', val: res.maint, color: COLORS.maint },
            { label: 'Interest', val: res.int, color: COLORS.int },
            { label: 'Reg & Fees', val: res.reg, color: COLORS.reg }
        ].filter(function(d) { return d.val > 0; });

        var total = res.total;
        var cx = canvas.width / 2;
        var cy = canvas.height / 2;
        var radius = Math.min(cx, cy) - 10;
        var innerRadius = radius * 0.6;

        var startAngle = -0.5 * Math.PI;
        data.forEach(function(d) {
            var sliceAngle = (d.val / total) * 2 * Math.PI;
            ctx.beginPath();
            ctx.arc(cx, cy, radius, startAngle, startAngle + sliceAngle);
            ctx.arc(cx, cy, innerRadius, startAngle + sliceAngle, startAngle, true);
            ctx.closePath();
            ctx.fillStyle = d.color;
            ctx.fill();
            startAngle += sliceAngle;
        });

        // Legend
        var legHTML = '';
        data.forEach(function(d) {
            var pct = Math.round((d.val / total) * 100);
            legHTML += '<div class="leg-item"><div class="leg-color" style="background:'+d.color+'"></div>'+
                       '<span>'+d.label+' ('+pct+'%)</span><span class="leg-val">'+fmt(d.val)+'</span></div>';
        });
        document.getElementById('donut-legend').innerHTML = legHTML;
    }

    function renderTable(miles, gas, elec, apr) {
        var results = VEHICLES.map(function(v) {
            var c = calculateCost(v, miles, gas, elec, apr);
            return { v: v, c: c };
        });
        results.sort(function(a, b) { return a.c.total - b.c.total; });

        var html = '';
        results.forEach(function(r, idx) {
            html += '<tr>' +
                '<td class="td-rank">#' + (idx + 1) + '</td>' +
                '<td class="td-name">' + r.v.name + '</td>' +
                '<td>' + fmt(r.v.msrp) + '</td>' +
                '<td>' + fmt(r.c.depr) + '</td>' +
                '<td>' + fmt(r.c.fuel) + '</td>' +
                '<td class="td-total">' + fmt(r.c.total) + '</td>' +
            '</tr>';
        });
        document.getElementById('car-table-body').innerHTML = html;
    }

    function updateCompare(miles, gas, elec, apr) {
        var v1Idx = document.getElementById('compare-v1').value;
        var v2Idx = document.getElementById('compare-v2').value;
        var v1 = VEHICLES[v1Idx];
        var v2 = VEHICLES[v2Idx];
        if(!v1 || !v2) return;

        var c1 = calculateCost(v1, miles, gas, elec, apr);
        var c2 = calculateCost(v2, miles, gas, elec, apr);

        var maxTotal = Math.max(c1.total, c2.total);
        if(maxTotal === 0) maxTotal = 1;

        function makeBar(name, c) {
            var cats = [
                {k:'depr', l:'Depr'}, {k:'fuel', l:'Fuel'}, {k:'ins', l:'Ins'},
                {k:'maint', l:'Maint'}, {k:'int', l:'Int'}, {k:'reg', l:'Reg'}
            ];
            var segments = '';
            cats.forEach(function(cat) {
                var pct = (c[cat.k] / maxTotal) * 100;
                if(pct > 0) {
                    segments += '<div class="comp-segment" style="width:'+pct+'%; background:'+COLORS[cat.k]+'" title="'+cat.l+': '+fmt(c[cat.k])+'"></div>';
                }
            });
            return '<div class="comp-bar-wrapper">' +
                '<div class="comp-bar-header"><span>'+name+'</span><span class="comp-bar-total">'+fmt(c.total)+'</span></div>' +
                '<div class="comp-bar-track">' + segments + '</div>' +
            '</div>';
        }

        var html = makeBar(v1.name, c1) + makeBar(v2.name, c2);

        var legend = '<div class="comp-legend">';
        var cats = [
            {k:'depr', l:'Depreciation'}, {k:'fuel', l:'Fuel/Energy'}, {k:'ins', l:'Insurance'},
            {k:'maint', l:'Maintenance'}, {k:'int', l:'Interest'}, {k:'reg', l:'Reg & Fees'}
        ];
        cats.forEach(function(cat) {
            legend += '<div style="display:flex; align-items:center; gap:0.3rem;"><div style="width:10px;height:10px;background:'+COLORS[cat.k]+'"></div>'+cat.l+'</div>';
        });
        legend += '</div>';

        document.getElementById('compare-bars').innerHTML = html + legend;
    }

    function loadPreset(idx) {
        if (idx === '' || idx === 'custom') {
            document.getElementById('input-msrp').value = 30000;
            document.getElementById('input-mpg').value = 25;
            document.getElementById('input-ins').value = 1500;
            document.getElementById('input-maint').value = 800;
            document.getElementById('input-is-used').checked = false;
            document.getElementById('input-is-ev').checked = false;
        } else {
            var v = VEHICLES[idx];
            document.getElementById('input-msrp').value = v.msrp;
            document.getElementById('input-mpg').value = v.mpg;
            document.getElementById('input-ins').value = v.ins;
            document.getElementById('input-maint').value = v.maint;
            document.getElementById('input-is-used').checked = v.isUsed;
            document.getElementById('input-is-ev').checked = v.isEV;
        }
        updateUI();
    }

    document.addEventListener('DOMContentLoaded', function() {
        var sel = document.getElementById('vehicle-select');
        var c1 = document.getElementById('compare-v1');
        var c2 = document.getElementById('compare-v2');

        VEHICLES.forEach(function(v, i) {
            sel.appendChild(new Option(v.name, i));
            c1.appendChild(new Option(v.name, i));
            c2.appendChild(new Option(v.name, i));
        });

        sel.value = 0; // default to first
        c1.value = 0;
        c2.value = 1;

        loadPreset(0);

        sel.addEventListener('change', function() { loadPreset(this.value); });

        ['input-msrp', 'input-mpg', 'input-ins', 'input-maint'].forEach(function(id) {
            document.getElementById(id).addEventListener('input', function() {
                sel.value = 'custom';
                updateUI();
            });
        });

        ['input-is-used', 'input-is-ev'].forEach(function(id) {
            document.getElementById(id).addEventListener('change', function() {
                sel.value = 'custom';
                updateUI();
            });
        });

        ['slider-miles', 'slider-gas', 'slider-elec', 'slider-apr', 'compare-v1', 'compare-v2'].forEach(function(id) {
            document.getElementById(id).addEventListener('input', updateUI);
            document.getElementById(id).addEventListener('change', updateUI);
        });

        updateUI();
    });

  })();
  </script>
</SiteLayout>
