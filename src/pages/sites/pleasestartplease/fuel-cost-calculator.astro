    text-align: center;
  }
</style>

<script>
  // Trend Chart Data
  var gasTrendData = [
    { year: 'Jan 2024', price: 3.08 },
    { year: 'Apr 2024', price: 3.61 },
    { year: 'Jul 2024', price: 3.49 },
    { year: 'Oct 2024', price: 3.13 },
    { year: 'Jan 2025', price: 3.05 },
    { year: 'Apr 2025', price: 3.55 },
    { year: 'Jul 2025', price: 3.65 },
    { year: 'Oct 2025', price: 3.25 },
    { year: 'Jan 2026', price: 3.10 },
    { year: 'Apr 2026', price: 3.45 }
  ];

  function renderTrendChart() {
    var chart = document.getElementById('gas-trend-chart');
    if(!chart) return;
    chart.innerHTML = '';

    var maxVal = 5.00;

    // Grid lines
    var levels = [1, 2, 3, 4, 5];
    levels.forEach(function(l) {
        var linePos = (l / maxVal) * 214;
        var line = document.createElement('div');
        line.className = 'mill-chart-million-line';
        line.style.bottom = (26 + linePos) + 'px';
        line.style.borderTop = '1px dashed rgba(255,255,255,0.05)';
        line.innerHTML = '<span class="mill-chart-million-label" style="color:var(--text-secondary); right:auto; left:-35px; top:-8px;">$' + l + '</span>';
        chart.appendChild(line);
    });

    gasTrendData.forEach(function(d) {
      var group = document.createElement('div');
      group.className = 'mill-chart-bar-group';

      var h = (d.price / maxVal) * 214;

      var bar = document.createElement('div');
      bar.className = 'mill-chart-bar';
      bar.style.height = '0px';

      var tooltip = document.createElement('div');
      tooltip.className = 'mill-chart-tooltip';
      tooltip.textContent = d.year + ': $' + d.price.toFixed(2) + '/gal';
      bar.appendChild(tooltip);

      var lbl = document.createElement('div');
      lbl.className = 'mill-chart-bar-label';
      // only show some labels
      if(d.year.startsWith('Jan') || d.year.startsWith('Jul')) {
         lbl.textContent = d.year.substring(0,3) + ' ' + d.year.substring(6);
      }
      group.appendChild(bar);
      group.appendChild(lbl);
      chart.appendChild(group);

      // Animate
      setTimeout(function() { bar.style.height = h + 'px'; }, 100);
    });
  }

  // Calculator Logic
  document.addEventListener('DOMContentLoaded', function() {
    renderTrendChart();

    var daysSlider = document.getElementById('days-slider');
    var daysDisplay = document.getElementById('days-display');

    if(daysSlider) {
        daysSlider.addEventListener('input', function(e) {
          daysDisplay.textContent = e.target.value + (e.target.value === '1' ? ' day' : ' days');
        });
    }

    var calcBtn = document.getElementById('calc-btn');
    if(calcBtn) {
        calcBtn.addEventListener('click', function() {
          var dist = parseFloat(document.getElementById('input-distance').value) || 0;
          var isRound = document.getElementById('input-roundtrip').checked;
          var mpg = parseFloat(document.getElementById('input-mpg').value) || 1;
          var gasPrice = parseFloat(document.getElementById('input-gas-price').value) || 0;
          var daysPerWeek = parseInt(document.getElementById('days-slider').value) || 5;

          if (isRound) {
            dist = dist * 2;
          }

          var tripCost = (dist / mpg) * gasPrice;
          var weeklyCost = tripCost * daysPerWeek;
          var monthlyCost = weeklyCost * (52 / 12);
          var yearlyCost = weeklyCost * 52;

          document.getElementById('res-trip-cost').textContent = '$' + tripCost.toFixed(2);
          document.getElementById('res-weekly-cost').textContent = '$' + weeklyCost.toFixed(2);
          document.getElementById('res-monthly-cost').textContent = '$' + monthlyCost.toFixed(2);
          document.getElementById('res-yearly-cost').textContent = '$' + yearlyCost.toFixed(2);
          document.getElementById('res-annual-cost').textContent = '$' + Math.round(yearlyCost).toLocaleString();

          var panel = document.getElementById('results-panel');
          panel.style.display = 'block';
          panel.style.animation = 'none';
          panel.offsetHeight;
          panel.style.animation = 'mill-fadeUp 0.5s ease';

          var insightEl = document.getElementById('result-insight');
          var insight = 'Over 10 years, this commute will cost you <strong>$' + Math.round(yearlyCost * 10).toLocaleString() + '</strong> in fuel alone. ';
          if (mpg < 30) {
            insight += 'Upgrading to a 40 MPG hybrid could save you roughly <strong>$' + Math.round(yearlyCost - (((dist/40)*gasPrice)*daysPerWeek*52)).toLocaleString() + '</strong> every single year.';
          } else {
             insight += 'Your vehicle is already quite efficient, helping to keep these costs manageable.';
          }
          insightEl.innerHTML = insight;
        });
    }

    // Comparison Logic
    var vehicles = {
      'gas25': { name: 'Gas SUV', eff: 25, unit: 'MPG', type: 'gas' },
      'gas30': { name: 'Gas Sedan', eff: 30, unit: 'MPG', type: 'gas' },
      'hybrid50': { name: 'Hybrid', eff: 50, unit: 'MPG', type: 'gas' },
      'ev': { name: 'Electric Vehicle', eff: 3.5, unit: 'mi/kWh', type: 'electric' }
    };

    var compareBtn = document.getElementById('compare-btn');
    if(compareBtn) {
        compareBtn.addEventListener('click', function() {
          var vA = vehicles[document.getElementById('compare-a').value];
          var vB = vehicles[document.getElementById('compare-b').value];

          var dist = parseFloat(document.getElementById('input-distance').value) || 30;
          var isRound = document.getElementById('input-roundtrip') ? document.getElementById('input-roundtrip').checked : true;
          var gasPrice = parseFloat(document.getElementById('input-gas-price').value) || 3.50;
          var elecPrice = 0.15; // fixed est. $/kWh
          var daysPerWeek = parseInt(document.getElementById('days-slider').value) || 5;

          if(isRound) dist = dist * 2;
          var annualMiles = dist * daysPerWeek * 52;

          function calcCost(v) {
            if(v.type === 'gas') return (annualMiles / v.eff) * gasPrice;
            return (annualMiles / v.eff) * elecPrice;
          }

          var costA = calcCost(vA);
          var costB = calcCost(vB);

          var diff = Math.abs(costA - costB);
          var winA = costA <= costB;

          document.getElementById('compare-card-a').innerHTML =
            '<h3>' + vA.name + '</h3>' +
            '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Efficiency</span><span class="mill-compare-stat-val">' + vA.eff + ' ' + vA.unit + '</span></div>' +
            '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Annual Miles</span><span class="mill-compare-stat-val">' + Math.round(annualMiles).toLocaleString() + '</span></div>' +
            '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Energy Cost</span><span class="mill-compare-stat-val">$' + (vA.type==='gas'?gasPrice.toFixed(2)+'/gal':'0.15/kWh') + '</span></div>' +
            '<div class="mill-compare-stat" style="border-bottom:none; margin-top:0.5rem; font-size:1.05rem;"><span class="mill-compare-stat-label">Annual Cost</span><span class="mill-compare-stat-val" style="color:var(--accent-color);">$' + Math.round(costA).toLocaleString() + '</span></div>' +
            '<div class="mill-compare-winner ' + (winA ? 'is-winner' : 'is-loser') + '">' + (winA ? ('Saves $' + Math.round(diff).toLocaleString() + '/yr') : 'More Expensive') + '</div>';

          document.getElementById('compare-card-b').innerHTML =
            '<h3>' + vB.name + '</h3>' +
            '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Efficiency</span><span class="mill-compare-stat-val">' + vB.eff + ' ' + vB.unit + '</span></div>' +
            '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Annual Miles</span><span class="mill-compare-stat-val">' + Math.round(annualMiles).toLocaleString() + '</span></div>' +
            '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Energy Cost</span><span class="mill-compare-stat-val">$' + (vB.type==='gas'?gasPrice.toFixed(2)+'/gal':'0.15/kWh') + '</span></div>' +
            '<div class="mill-compare-stat" style="border-bottom:none; margin-top:0.5rem; font-size:1.05rem;"><span class="mill-compare-stat-label">Annual Cost</span><span class="mill-compare-stat-val" style="color:#10b981;">$' + Math.round(costB).toLocaleString() + '</span></div>' +
            '<div class="mill-compare-winner ' + (!winA ? 'is-winner" style="color:#10b981; border-color:#10b981; background:rgba(16,185,129,0.1);' : 'is-loser') + '">' + (!winA ? ('Saves $' + Math.round(diff).toLocaleString() + '/yr') : 'More Expensive') + '</div>';

          var maxCost = Math.max(costA, costB, 1);
          var pctA = (costA / maxCost) * 100;
          var pctB = (costB / maxCost) * 100;

          document.getElementById('compare-race').innerHTML =
            '<div class="mill-race-label">Relative Annual Fuel Cost</div>' +
            '<div class="mill-race-track"><div class="mill-race-bar bar-a" style="width: 0%">$' + Math.round(costA).toLocaleString() + '</div></div>' +
            '<div class="mill-race-track"><div class="mill-race-bar bar-b" style="width: 0%">$' + Math.round(costB).toLocaleString() + '</div></div>';

          var res = document.getElementById('compare-results');
          res.style.display = 'block';
          res.style.animation = 'none';
          res.offsetHeight;
          res.style.animation = 'mill-fadeUp 0.5s ease';

          setTimeout(function() {
            var bars = document.getElementById('compare-race').querySelectorAll('.mill-race-bar');
            if(bars.length > 1) {
              bars[0].style.width = Math.max(pctA, 15) + '%';
              bars[1].style.width = Math.max(pctB, 15) + '%';
            }
          }, 50);
        });
    }
  });
</script>
