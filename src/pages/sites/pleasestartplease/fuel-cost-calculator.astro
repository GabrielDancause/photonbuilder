---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Interactive Fuel Cost Calculator | Compare Gas, Electric & Hybrid',
  description: 'Calculate your annual commute cost and compare gas, electric, and hybrid vehicles side by side. See the true cost of your drive based on real gas prices.',
  category: 'tool',
  keywords: ['fuel cost calculator', 'gas vs electric', 'commute cost', 'gas price calculator', 'hybrid vs gas comparison', 'cost per mile']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Please Start Please" },
    "publisher": { "@type": "Organization", "name": "Please Start Please" },
    "datePublished": "2024-05-20",
    "dateModified": "2024-05-20"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a 30-mile commute cost in gas?",
        "acceptedAnswer": { "@type": "Answer", "text": "For a typical 25 MPG car at $3.50 per gallon, a 30-mile round trip commute costs about $4.20 per day. Over a working year (260 days), that totals roughly $1,092 in gas alone." }
      },
      {
        "@type": "Question",
        "name": "Is it cheaper to drive an electric car or a gas car?",
        "acceptedAnswer": { "@type": "Answer", "text": "Electric cars are generally cheaper to drive per mile. Charging an EV at home typically costs equivalent to $1 to $1.50 per gallon of gas, saving drivers hundreds to thousands of dollars annually on fuel." }
      },
      {
        "@type": "Question",
        "name": "What is a good MPG for a commuter car?",
        "acceptedAnswer": { "@type": "Answer", "text": "A good fuel economy for a gas-powered commuter car is 30 MPG or higher. Hybrid vehicles often achieve 45-55 MPG, making them excellent choices for long daily commutes." }
      },
      {
        "@type": "Question",
        "name": "How do you calculate the cost of a road trip?",
        "acceptedAnswer": { "@type": "Answer", "text": "To calculate road trip fuel cost, divide your total trip distance by your car's MPG, then multiply by the average price of gas per gallon." }
      },
      {
        "@type": "Question",
        "name": "How much does idling waste gas?",
        "acceptedAnswer": { "@type": "Answer", "text": "Idling can consume half a gallon to a full gallon of fuel per hour depending on engine size and AC usage. Turning off your engine if parked for more than 10 seconds saves fuel and reduces emissions." }
      }
    ]
  }
]);
---

<SiteLayout site="pleasestartplease" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <section class="mill-hero">
    <div class="mill-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>The True Cost of Your Commute</h1>
    <p class="mill-hero-hook">Your 30-mile commute costs <strong>$2,400/year in gas alone.</strong> <br/>See what your drive is really costing you.</p>
    <div class="mill-hero-stats">
      <div class="mill-stat">
        <span class="mill-stat-num">$3.52</span>
        <span class="mill-stat-label">National Avg Gas</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num">25 MPG</span>
        <span class="mill-stat-label">Avg US Fleet</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num">$1,092+</span>
        <span class="mill-stat-label">Avg Yearly Gas Cost</span>
      </div>
    </div>
  </section>

  <section class="mill-section" style="padding-top:0;">
    <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      ⛽ <strong style="color:#ef4444;">Fuel prices are surging.</strong> UK petrol just hit 150p/liter (up 17p in a month). US gas averaging $3.50/gal. Filling a UK family car now costs £82+ — calculate your real commute cost below. <a href="https://gab.ae/news/energy-costs-rising-oil-prices-electricity-bills-2026" style="color:var(--accent-color);">Why prices are rising →</a>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="mill-section">
    <h2 class="mill-section-title">Fuel Cost Calculator</h2>
    <p class="mill-section-sub">Enter your trip or commute details to see the cost per trip and annually.</p>

    <div class="mill-calc-container">
      <div class="mill-calc-inputs">
        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="input-distance">Distance (miles)</label>
            <div class="mill-input-wrap"><input type="number" id="input-distance" min="1" max="5000" step="1" value="30" /></div>
          </div>
          <div class="mill-input-group" style="display:flex; align-items:flex-end;">
            <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
              <input type="checkbox" id="input-roundtrip" checked />
              Is this a Round Trip?
            </label>
          </div>
        </div>

        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="input-mpg">Your Car's MPG</label>
            <div class="mill-input-wrap"><input type="number" id="input-mpg" min="5" max="150" step="1" value="25" /></div>
          </div>
          <div class="mill-input-group">
            <label for="input-gas-price">Gas Price per Gallon</label>
            <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="input-gas-price" min="1.00" max="10.00" step="0.05" value="3.50" /></div>
          </div>
        </div>

        <div class="mill-input-group">
          <label for="days-slider">Commute Days Per Week: <strong id="days-display">5 days</strong></label>
          <input type="range" id="days-slider" min="1" max="7" value="5" />
          <div class="mill-slider-labels"><span>1 day</span><span>3 days</span><span>7 days</span></div>
        </div>

        <button id="calc-btn" class="mill-btn">Calculate Fuel Costs</button>
      </div>

      <!-- RESULTS -->
      <div class="mill-calc-results" id="results-panel" style="display:none;">
        <div class="mill-result-header">
          <div class="mill-result-title">Your Fuel Costs</div>
          <div class="mill-result-age">Cost per trip: <strong id="res-trip-cost">$0.00</strong></div>
          <div class="mill-result-years">Annual Cost: <span id="res-annual-cost">$0</span></div>
        </div>

        <!-- MILESTONES -->
        <div class="mill-milestones" id="milestones-container">
          <div class="mill-milestone reached show celebrate">
            <div class="mill-milestone-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L15 10H22L16.5 14.5L18.5 22L12 17.5L5.5 22L7.5 14.5L2 10H9L12 2Z" fill="var(--accent-color, #ef4444)" opacity="0.3" stroke="var(--accent-color, #ef4444)" stroke-width="1.2"/></svg></div>
            <div class="mill-milestone-amt">Weekly</div>
            <div class="mill-milestone-age" id="res-weekly-cost">$0.00</div>
          </div>
          <div class="mill-milestone reached show celebrate">
            <div class="mill-milestone-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--accent-color, #ef4444)" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="var(--accent-color, #ef4444)" stroke-width="1.5" stroke-linecap="round"/></svg></div>
            <div class="mill-milestone-amt">Monthly</div>
            <div class="mill-milestone-age" id="res-monthly-cost">$0.00</div>
          </div>
          <div class="mill-milestone reached show celebrate">
             <div class="mill-milestone-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 20L12 4L20 20" stroke="var(--accent-color, #ef4444)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="7" y1="14" x2="17" y2="14" stroke="var(--accent-color, #ef4444)" stroke-width="1.5"/></svg></div>
             <div class="mill-milestone-amt">Yearly</div>
             <div class="mill-milestone-age" id="res-yearly-cost">$0.00</div>
          </div>
        </div>

        <div class="mill-insight" id="result-insight"></div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="mill-section">
    <h2 class="mill-section-title">Gas vs. Electric vs. Hybrid</h2>
    <p class="mill-section-sub">Compare the annual cost of the same commute across vehicle types.</p>

    <div class="mill-compare-controls">
      <div class="mill-input-group" style="margin-bottom:0;">
        <label for="compare-a">Vehicle 1</label>
        <select id="compare-a">
          <option value="gas25">Gas SUV (25 MPG)</option>
          <option value="gas30">Gas Sedan (30 MPG)</option>
          <option value="hybrid50">Hybrid (50 MPG)</option>
          <option value="ev">Electric Vehicle (3.5 mi/kWh)</option>
        </select>
      </div>
      <div class="mill-vs">VS</div>
      <div class="mill-input-group" style="margin-bottom:0;">
        <label for="compare-b">Vehicle 2</label>
        <select id="compare-b">
          <option value="gas25">Gas SUV (25 MPG)</option>
          <option value="gas30">Gas Sedan (30 MPG)</option>
          <option value="hybrid50">Hybrid (50 MPG)</option>
          <option value="ev" selected>Electric Vehicle (3.5 mi/kWh)</option>
        </select>
      </div>
      <button id="compare-btn" class="mill-btn">Compare Vehicles</button>
    </div>

    <div class="mill-compare-results" id="compare-results" style="display:none;">
      <div class="mill-compare-cards">
        <div class="mill-compare-card" id="compare-card-a"></div>
        <div class="mill-compare-card" id="compare-card-b"></div>
      </div>
      <div class="mill-compare-race" id="compare-race"></div>
    </div>
  </section>

  <!-- TREND CHART -->
  <section class="mill-section">
    <h2 class="mill-section-title">Gas Price Trend (2024-2026 Avg)</h2>
    <p class="mill-section-sub">National average retail gasoline prices over recent years.</p>
    <div class="mill-chart-wrap" style="margin-top: 2rem;">
      <div class="mill-chart-title">Avg Price per Gallon</div>
      <div class="mill-chart" id="gas-trend-chart"></div>
    </div>
  </section>

  <!-- THE 3 LEVERS -->
  <section class="mill-section">
    <h2 class="mill-section-title">The 3 Ways to Save on Fuel</h2>
    <div class="mill-levers">
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="16" stroke="currentColor" stroke-width="1.5" opacity="0.2"/><path d="M18 8v4M18 24v4M8 18h4M24 18h4" stroke="var(--accent-color, #ef4444)" stroke-width="2" stroke-linecap="round"/><circle cx="18" cy="18" r="5" fill="var(--accent-color, #ef4444)" opacity="0.2" stroke="var(--accent-color, #ef4444)" stroke-width="1.5"/></svg>
        </div>
        <h3>Vehicle Efficiency</h3>
        <p>Switching from a 20 MPG SUV to a 50 MPG hybrid cuts your fuel bill by 60% immediately, regardless of gas prices.</p>
        <div class="mill-lever-impact">Impact: <strong>High</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="4" y="22" width="6" height="10" rx="1" fill="var(--accent-color, #ef4444)" opacity="0.25"/><rect x="13" y="16" width="6" height="16" rx="1" fill="var(--accent-color, #ef4444)" opacity="0.5"/><rect x="22" y="8" width="6" height="24" rx="1" fill="var(--accent-color, #ef4444)" opacity="0.8"/></svg>
        </div>
        <h3>Driving Habits</h3>
        <p>Smooth acceleration, maintaining steady speeds, and removing excess weight can improve your real-world MPG by up to 15%.</p>
        <div class="mill-lever-impact">Impact: <strong>Medium</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="14" stroke="var(--accent-color, #ef4444)" stroke-width="1.5" opacity="0.3"/><circle cx="18" cy="18" r="14" stroke="var(--accent-color, #ef4444)" stroke-width="2.5" stroke-dasharray="88" stroke-dashoffset="22" stroke-linecap="round"/><line x1="18" y1="18" x2="18" y2="10" stroke="var(--accent-color, #ef4444)" stroke-width="2" stroke-linecap="round"/><line x1="18" y1="18" x2="24" y2="18" stroke="var(--accent-color, #ef4444)" stroke-width="1.5" stroke-linecap="round"/><circle cx="18" cy="18" r="2" fill="var(--accent-color, #ef4444)"/></svg>
        </div>
        <h3>Alternative Fuel</h3>
        <p>Going fully electric or plug-in hybrid shifts your energy source to electricity, which is historically cheaper and less volatile than gas.</p>
        <div class="mill-lever-impact">Impact: <strong>Highest</strong></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mill-section">
    <h2 class="mill-section-title">Frequently Asked Questions</h2>
    <div class="mill-faq">
      <details class="mill-faq-item">
        <summary>How much does a 30-mile commute cost in gas?</summary>
        <p>For a typical 25 MPG car at $3.50 per gallon, a 30-mile round trip commute costs about $4.20 per day. Over a working year (260 days), that totals roughly $1,092 in gas alone.</p>
      </details>
      <details class="mill-faq-item">
        <summary>Is it cheaper to drive an electric car or a gas car?</summary>
        <p>Electric cars are generally cheaper to drive per mile. Charging an EV at home typically costs equivalent to $1 to $1.50 per gallon of gas, saving drivers hundreds to thousands of dollars annually on fuel.</p>
      </details>
      <details class="mill-faq-item">
        <summary>What is a good MPG for a commuter car?</summary>
        <p>A good fuel economy for a gas-powered commuter car is 30 MPG or higher. Hybrid vehicles often achieve 45-55 MPG, making them excellent choices for long daily commutes.</p>
      </details>
      <details class="mill-faq-item">
        <summary>How do you calculate the cost of a road trip?</summary>
        <p>To calculate road trip fuel cost, divide your total trip distance by your car's MPG, then multiply by the average price of gas per gallon.</p>
      </details>
      <details class="mill-faq-item">
        <summary>How much does idling waste gas?</summary>
        <p>Idling can consume half a gallon to a full gallon of fuel per hour depending on engine size and AC usage. Turning off your engine if parked for more than 10 seconds saves fuel and reduces emissions.</p>
      </details>
    </div>
  </section>

  <div class="mill-disclaimer">
    <p><strong>Disclaimer:</strong> This calculator uses simplified assumptions including constant gas prices and fixed vehicle efficiency. Real-world results will vary based on driving habits, terrain, traffic conditions, and fluctuating energy costs. Electricity costs are estimated at $0.15/kWh for EV comparisons.</p>
  </div>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="https://westmountfundamentals.com/dividend-yield-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Dividend Yield Calculator: Annual Income Estimator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Calculate expected annual dividend income, project yield-on-cost, and estimate portfolio growth based on real market dat...</p>
      </a>
      <a href="/car-cost-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">The Real Cost of Owning a Car</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Interactive calculator showing the true 5-year cost of owning different vehicles. Compare MSRP, depreciation, insurance,...</p>
      </a>
      <a href="https://firemaths.info/cagr-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">CAGR Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Calculate Compound Annual Growth Rate (CAGR) for your investments. Compare up to 5 investments side-by-side with interac...</p>
      </a>
    </div>
  </div>
</SiteLayout>

<style is:global>
  /* ===== FUEL COST CALCULATOR ===== */
  .mill-page { max-width: 1100px; margin: 0 auto; }
  .mill-hero {
    text-align: center;
    padding: 2.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(239,68,68,0.12) 0%, rgba(239,68,68,0.02) 60%, rgba(239,68,68,0.08) 100%);
    border-bottom: 1px solid var(--border-color, #152040);
    position: relative;
    overflow: hidden;
  }
  .mill-hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(239,68,68,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(239,68,68,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    padding: 0.35rem 1rem;
    border: 1px solid var(--accent-color, #ef4444);
    border-radius: 100px;
    color: var(--accent-color, #ef4444);
    margin-bottom: 1.5rem;
    font-weight: 600;
    animation: mill-fadeUp 0.6s ease both;
  }
  .mill-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    margin: 0 auto 1rem;
    max-width: 700px;
    color: var(--text-primary, #c8d0de);
    animation: mill-fadeUp 0.6s 0.1s ease both;
  }
  .mill-hero h1 em {
    color: var(--accent-color, #ef4444);
    font-style: italic;
  }
  .mill-hero-hook {
    font-size: 1.15rem;
    color: var(--text-secondary, #94a3b8);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    animation: mill-fadeUp 0.6s 0.2s ease both;
  }
  .mill-hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    animation: mill-fadeUp 0.6s 0.3s ease both;
  }
  .mill-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .mill-stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent-color, #ef4444);
    white-space: nowrap;
  }
  .mill-stat-label {
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* SECTIONS */
  .mill-section {
    padding: 2.5rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .mill-section-title {
    font-size: 1.6rem;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .mill-section-sub {
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  /* CALCULATOR */
  .mill-calc-container {
    display: grid;
    gap: 2rem;
  }
  .mill-calc-inputs {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 2rem;
  }
  .mill-input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .mill-input-row { grid-template-columns: 1fr; }
  }
  .mill-input-group {
    margin-bottom: 1.25rem;
  }
  .mill-input-group label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.4rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .mill-input-group select,
  .mill-input-group input[type="number"] {
    width: 100%;
    padding: 0.65rem 0.75rem;
    background: var(--bg-color, #060a12);
    border: 1px solid var(--border-color, #152040);
    border-radius: 8px;
    color: var(--text-primary, #c8d0de);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .mill-input-group select:focus,
  .mill-input-group input:focus {
    outline: none;
    border-color: var(--accent-color, #ef4444);
    box-shadow: 0 0 0 3px rgba(239,68,68,0.1);
  }
  .mill-input-wrap {
    position: relative;
  }
  .mill-input-prefix {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary, #94a3b8);
    font-size: 0.95rem;
    pointer-events: none;
  }
  .mill-input-wrap .mill-input-prefix + input {
    padding-left: 1.6rem;
  }

  .mill-input-group input[type="range"] {
    width: 100%;
    margin-top: 0.5rem;
    cursor: pointer;
    accent-color: var(--accent-color, #ef4444);
  }
  .mill-slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    margin-top: 0.3rem;
  }

  .mill-btn {
    width: 100%;
    padding: 0.8rem;
    background: var(--accent-color, #ef4444);
    color: #fff;
