  <script is:inline>
    // State variables
    let distance = 100;
    let mpg = 25;
    let price = 3.50;
    let isRoundTrip = false;
    let isCommute = false;

    // Constants for comparison
    const HYBRID_MPG = 45;
    const EV_MILES_PER_KWH = 3.6;
    const EV_COST_PER_KWH = 0.14; // National average residential rate

    // DOM Elements
    const distInput = document.getElementById('distance');
    const mpgInput = document.getElementById('efficiency');
    const priceInput = document.getElementById('price');
    const rtCheckbox = document.getElementById('roundTrip');
    const commuteCheckbox = document.getElementById('includeCommute');

    const totalCostEl = document.getElementById('totalCost');
    const gallonsNeededEl = document.getElementById('gallonsNeeded');
    const totalMilesEl = document.getElementById('totalMiles');
    const commuteNotice = document.getElementById('commuteNotice');
    const monthlyCommuteCost = document.getElementById('monthlyCommuteCost');

    // Format currency
    const formatMoney = (amount) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(amount);
    };

    function updateCalculator() {
      // Get values, handle edge cases (empty or invalid)
      const rawDist = parseFloat(distInput.value);
      const rawMpg = parseFloat(mpgInput.value);
      const rawPrice = parseFloat(priceInput.value);

      distance = isNaN(rawDist) || rawDist <= 0 ? 1 : rawDist;
      mpg = isNaN(rawMpg) || rawMpg <= 0 ? 1 : rawMpg;
      price = isNaN(rawPrice) || rawPrice <= 0 ? 0 : rawPrice;
      isRoundTrip = rtCheckbox.checked;
      isCommute = commuteCheckbox.checked;

      const multiplier = isRoundTrip ? 2 : 1;
      const actualDistance = distance * multiplier;

      // Core calculations
      const gallons = actualDistance / mpg;
      const cost = gallons * price;

      // Update core UI
      totalCostEl.textContent = formatMoney(cost);
      gallonsNeededEl.textContent = gallons.toFixed(1);
      totalMilesEl.textContent = actualDistance + ' mi';

      // Commute logic
      if (isCommute) {
        // If they checked commute, calculate monthly based on 20 days.
        // If they checked round trip, we use actualDistance. If not, we assume they only input 1 way and didn't check round trip, so we double it anyway for a commute.
        const dailyCommuteDist = isRoundTrip ? actualDistance : actualDistance * 2;
        const dailyCost = (dailyCommuteDist / mpg) * price;
        const monthlyCost = dailyCost * 20;

        commuteNotice.style.display = 'block';
        monthlyCommuteCost.textContent = formatMoney(monthlyCost);
      } else {
        commuteNotice.style.display = 'none';
      }

      // Detailed Breakdown
      document.getElementById('bdGallons').textContent = gallons.toFixed(1) + ' gal';
      const hours = actualDistance / 60; // Assuming 60mph avg
      const h = Math.floor(hours);
      const m = Math.round((hours - h) * 60);
      document.getElementById('bdTime').textContent = h > 0 ? h + 'h ' + m + 'm' : m + 'm';
      document.getElementById('bdCpm').textContent = formatMoney(cost / actualDistance);
      document.getElementById('bdCo2').textContent = (gallons * 19.6).toFixed(0) + ' lbs';

      // Comparison Calculations
      const hybridGallons = actualDistance / HYBRID_MPG;
      const hybridCost = hybridGallons * price;

      const evKwh = actualDistance / EV_MILES_PER_KWH;
      const evCost = evKwh * EV_COST_PER_KWH;

      // Update Comparison UI
      document.getElementById('compCurrent').textContent = formatMoney(cost);
      document.getElementById('compCurrentMpg').textContent = mpg;

      document.getElementById('compHybrid').textContent = formatMoney(hybridCost);
      const hybridDiff = cost - hybridCost;
      const hybridEl = document.getElementById('hybridSavings');
      if (hybridDiff > 0) {
        hybridEl.textContent = `Saves ${formatMoney(hybridDiff)}`;
        hybridEl.className = 'vehicle-savings';
      } else {
        hybridEl.textContent = `Costs ${formatMoney(Math.abs(hybridDiff))} more`;
        hybridEl.className = 'vehicle-savings negative';
      }

      document.getElementById('compEv').textContent = formatMoney(evCost);
      const evDiff = cost - evCost;
      const evEl = document.getElementById('evSavings');
      if (evDiff > 0) {
        evEl.textContent = `Saves ${formatMoney(evDiff)}`;
        evEl.className = 'vehicle-savings';
      } else {
        evEl.textContent = `Costs ${formatMoney(Math.abs(evDiff))} more`;
        evEl.className = 'vehicle-savings negative';
      }

      // Update Projections Table
      // Calculate a round trip cost for projections if not already round trip
      const rtDist = isRoundTrip ? actualDistance : actualDistance * 2;

      const cDaily = (rtDist / mpg) * price;
      const hDaily = (rtDist / HYBRID_MPG) * price;
      const eDaily = (rtDist / EV_MILES_PER_KWH) * EV_COST_PER_KWH;

      // 1 Week (5 days)
      document.getElementById('proj1wC').textContent = formatMoney(cDaily * 5);
      document.getElementById('proj1wH').textContent = formatMoney(hDaily * 5);
      document.getElementById('proj1wE').textContent = formatMoney(eDaily * 5);

      // 1 Month (20 days)
      document.getElementById('proj1mC').textContent = formatMoney(cDaily * 20);
      document.getElementById('proj1mH').textContent = formatMoney(hDaily * 20);
      document.getElementById('proj1mE').textContent = formatMoney(eDaily * 20);

      // 1 Year (240 days)
      document.getElementById('proj1yC').textContent = formatMoney(cDaily * 240);
      document.getElementById('proj1yH').textContent = formatMoney(hDaily * 240);
      document.getElementById('proj1yE').textContent = formatMoney(eDaily * 240);

      // 5 Years (1200 days)
      document.getElementById('proj5yC').textContent = formatMoney(cDaily * 1200);
      document.getElementById('proj5yH').textContent = formatMoney(hDaily * 1200);
      document.getElementById('proj5yE').textContent = formatMoney(eDaily * 1200);

      // Update Chart
      updateChart(distance, mpg, price);
    }

    function updateChart(userDist, userMpg, userPrice) {
      // Commute distances one-way
      const distances = [5, 15, userDist, 30, 50];
      const maxDist = Math.max(...distances);

      let maxCost = 0;

      // First pass to find max cost for scale
      distances.forEach((d) => {
        const cost = ((d * 2) / userMpg) * userPrice * 20; // Round trip * 20 days
        if (cost > maxCost) maxCost = cost;
      });

      // Add a little headroom (20%)
      const scaleMax = maxCost * 1.2;

      // Update Y-Axis labels
      document.getElementById('yMax').textContent = formatMoney(scaleMax);
      document.getElementById('yMid').textContent = formatMoney(scaleMax / 2);

      distances.forEach((d, index) => {
        // Monthly cost: (distance*2 / mpg) * price * 20 days
        const monthlyCost = ((d * 2) / userMpg) * userPrice * 20;

        // Calculate height percentage (min 5%, max 100%)
        const heightPct = Math.max(5, Math.min(100, (monthlyCost / scaleMax) * 100));

        const bar = document.getElementById(`bar${index + 1}`);
        const val = document.getElementById(`val${index + 1}`);

        if (bar && val) {
          bar.style.height = `${heightPct}%`;
          val.textContent = formatMoney(monthlyCost);

          // Special label for user's distance
          if (index === 2) {
            document.getElementById('yourDistLabel').textContent = `${d} mi`;
          }
        }
      });
    }

    // Event Listeners
    [distInput, mpgInput, priceInput].forEach(input => {
      input.addEventListener('input', updateCalculator);
    });
    rtCheckbox.addEventListener('change', updateCalculator);
    commuteCheckbox.addEventListener('change', updateCalculator);

    // Initial calculation
    updateCalculator();
  </script>
</SiteLayout>
