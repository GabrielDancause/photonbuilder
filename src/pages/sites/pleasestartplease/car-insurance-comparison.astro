    avgLiability: 440,
    avgFull: 1540,
    claimsSatisfaction: "Average",
    summary: "GEICO's entire business model is built on being cheaper, and it works. They consistently offer some of the lowest rates in the market, especially for drivers with clean records. The trade-off is a fully digital experience with no local agents — if you're comfortable managing everything online, you'll save real money."
  },
  {
    name: "Progressive",
    badge: "Best for Young Drivers",
    avgAnnual: 1760,
    amBest: "A+",
    jdPower: 820,
    discounts: "Snapshot usage-based, multi-policy, continuous insurance, homeowner, paid-in-full",
    bestFor: "High-risk and young drivers",
    pros: ["Snapshot telematics can dramatically lower rates", "Name Your Price tool for budget flexibility", "Accepts high-risk drivers others reject", "Competitive rates for drivers with violations"],
    cons: ["Rates can be high without Snapshot discount", "Customer service scores below average", "Claims process can be slow"],
    avgLiability: 490,
    avgFull: 1760,
    claimsSatisfaction: "Below average",
    summary: "Progressive is the insurer that will say yes when others won't. If you're a young driver, have a DUI on record, or have been dropped by another company, Progressive will likely offer you a policy — and at better rates than you'd expect. Their Snapshot program rewards safe driving with discounts of up to 30%."
  },
  {
    name: "Allstate",
    badge: "Best Rewards Program",
    avgAnnual: 2100,
    amBest: "A+",
    jdPower: 818,
    discounts: "Drivewise, safe driving bonus, multi-policy, new car, anti-lock brakes, early signing",
    bestFor: "Drivers who want perks and add-ons",
    pros: ["Drivewise rewards for safe driving", "Accident forgiveness included in some states", "Extensive add-on coverage options", "Strong local agent presence"],
    cons: ["Higher premiums than most competitors", "Discounts don't always offset base rates", "Claims satisfaction below industry average"],
    avgLiability: 590,
    avgFull: 2100,
    claimsSatisfaction: "Below average",
    summary: "Allstate charges more than average, but they pack in extras that other insurers charge for or don't offer at all. Drivewise rewards, accident forgiveness, and new car replacement can add real value — if you actually use them. Run the numbers to see if the perks justify the premium."
  },
  {
    name: "USAA",
    badge: "Best for Military",
    avgAnnual: 1290,
    amBest: "A++",
    jdPower: 890,
    discounts: "Military deployment, storage, good driver, family, multi-vehicle, new vehicle",
    bestFor: "Military members and families",
    pros: ["Cheapest rates on this list", "Highest J.D. Power satisfaction scores", "Covers vehicles during deployment", "Dividend returns in profitable years"],
    cons: ["Limited to military and their families", "No local agents", "Must be eligible to join"],
    avgLiability: 380,
    avgFull: 1290,
    claimsSatisfaction: "Excellent",
    summary: "If you're eligible, USAA is the best car insurance you can get, period. They have the lowest rates, the highest satisfaction scores, and policies designed around military life. The catch is strict eligibility — you must be active military, a veteran, or an immediate family member of a USAA member."
  },
  {
    name: "Liberty Mutual",
    badge: "Best Custom Coverage",
    avgAnnual: 2260,
    amBest: "A",
    jdPower: 810,
    discounts: "RightTrack, multi-policy, early shopper, good student, homeowner, hybrid/EV",
    bestFor: "Customized policies with add-ons",
    pros: ["Extensive customization options", "New car replacement up to 1 year", "Better car replacement after total loss", "RightTrack usage-based discounts"],
    cons: ["Rates are among the highest", "Customer satisfaction below average", "Discounts can be hard to stack"],
    avgLiability: 620,
    avgFull: 2260,
    claimsSatisfaction: "Below average",
    summary: "Liberty Mutual lets you build exactly the policy you want with options like new car replacement, better car replacement (upgrade after a total loss), and gap insurance. You'll pay more for it, but if you want every possible coverage option in one policy, Liberty Mutual delivers."
  },
  {
    name: "Farmers",
    badge: "Best for Gig Drivers",
    avgAnnual: 2050,
    amBest: "A",
    jdPower: 815,
    discounts: "Signal telematics, multi-policy, good driver, distant student, homeowner, anti-theft",
    bestFor: "Rideshare and gig economy drivers",
    pros: ["Rideshare-specific coverage available", "Strong agent network", "Signal telematics program", "Good coverage for hobbyist vehicles"],
    cons: ["Premiums higher than average", "Limited availability in some states", "Online tools lag behind GEICO/Progressive"],
    avgLiability: 570,
    avgFull: 2050,
    claimsSatisfaction: "Average",
    summary: "Farmers stands out for offering rideshare endorsements that cover the gap between your personal policy and the coverage provided by Uber or Lyft. If you drive for gig platforms, most standard policies leave you exposed during certain phases — Farmers fills that hole."
  },
  {
    name: "Nationwide",
    badge: "Best for Good Drivers",
    avgAnnual: 1680,
    amBest: "A+",
    jdPower: 825,
    discounts: "SmartRide, vanishing deductible, multi-policy, good student, anti-theft, paperless",
    bestFor: "Safe drivers who want vanishing deductible",
    pros: ["Vanishing deductible ($100 off per claim-free year)", "SmartRide telematics up to 40% discount", "On Your Side review annually", "Pet injury coverage included"],
    cons: ["Not available in every state", "Average claims experience", "Fewer local agents than State Farm"],
    avgLiability: 475,
    avgFull: 1680,
    claimsSatisfaction: "Average",
    summary: "Nationwide's vanishing deductible is a uniquely compelling feature — every year you don't file a claim, your deductible drops by $100, potentially reaching $0. Combined with SmartRide telematics that can cut rates by up to 40%, safe drivers can build significant savings over time."
  },
  {
    name: "Travelers",
    badge: "Best for Homeowners",
    avgAnnual: 1720,
    amBest: "A++",
    jdPower: 822,
    discounts: "IntelliDrive, multi-policy, new car, good student, hybrid/EV, continuous insurance",
    bestFor: "Bundling with homeowners insurance",
    pros: ["Up to 20% bundling discount", "IntelliDrive telematics program", "Excellent financial strength (A++)", "New car replacement available"],
    cons: ["Not available direct-to-consumer in all states", "Requires an agent in some regions", "Limited digital tools"],
    avgLiability: 480,
    avgFull: 1720,
    claimsSatisfaction: "Above average",
    summary: "Travelers is one of the oldest and most financially stable insurers in the country. Their auto insurance is solid on its own, but the real play is bundling — pair it with their highly-rated homeowners insurance for savings up to 20%. If you own a home, Travelers deserves a quote."
  },
  {
    name: "Erie Insurance",
    badge: "Best Customer Service",
    avgAnnual: 1450,
    amBest: "A+",
    jdPower: 882,
    discounts: "Multi-policy, good student, anti-theft, first accident forgiveness, go-green (paperless)",
    bestFor: "Exceptional service in covered states",
    pros: ["Second-highest J.D. Power satisfaction score", "Very competitive rates", "First accident forgiveness included", "Rate lock feature available"],
    cons: ["Only available in 12 states + DC", "Limited to eastern US and Midwest", "Smaller agent network"],
    avgLiability: 410,
    avgFull: 1450,
    claimsSatisfaction: "Excellent",
    summary: "Erie is the best-kept secret in car insurance. Available only in 12 states and DC, they combine some of the lowest rates in the industry with customer satisfaction scores that rival USAA. If you live in their service area (IL, IN, KY, MD, NC, NY, OH, PA, TN, VA, WV, WI, DC), get a quote — you'll likely be surprised."
  }
];

const categoryWinners = [
  { category: "Cheapest Overall", pick: "GEICO", reason: "Consistently lowest premiums for clean-record drivers — ~$1,540/yr average" },
  { category: "Best Customer Service", pick: "Erie Insurance", reason: "J.D. Power 882 — second only to USAA with far lower premiums than average" },
  { category: "Best for Military", pick: "USAA", reason: "Lowest rates, highest satisfaction, deployment-specific coverage" },
  { category: "Best for Bundling", pick: "State Farm", reason: "Save 20-25% bundling home + auto with the largest agent network" },
  { category: "Best for Young Drivers", pick: "Progressive", reason: "Snapshot telematics rewards safe driving up to 30% off" },
  { category: "Best for Good Drivers", pick: "Nationwide", reason: "Vanishing deductible + SmartRide can cut rates by 40%" }
];

const coverageTypes = [
  {
    name: "Liability",
    required: true,
    description: "Covers damage and injuries you cause to others. Every state except New Hampshire requires it. Expressed as three numbers (e.g., 50/100/50): per-person injury limit, per-accident injury limit, and property damage limit. Most experts recommend at least 100/300/100.",
    avgCost: "$550–$750/yr"
  },
  {
    name: "Collision",
    required: false,
    description: "Pays to repair or replace your car after an accident regardless of fault. Required by lenders if you're financing or leasing. Deductibles typically range from $250 to $1,000 — a higher deductible lowers your premium.",
    avgCost: "$350–$600/yr"
  },
  {
    name: "Comprehensive",
    required: false,
    description: "Covers non-collision damage: theft, vandalism, hail, flooding, animal strikes, falling objects. Also required by lenders. If you park outside in an area with severe weather, this is essential even if you own your car outright.",
    avgCost: "$150–$350/yr"
  },
  {
    name: "Uninsured/Underinsured Motorist",
    required: false,
    description: "Protects you when the other driver has no insurance or insufficient coverage. About 14% of US drivers are uninsured. Some states require this coverage, and it's strongly recommended even where optional — medical bills after a serious accident can be catastrophic.",
    avgCost: "$100–$250/yr"
  },
  {
    name: "Gap Insurance",
    required: false,
    description: "Covers the difference between what you owe on your car loan and the car's actual cash value if it's totaled. Essential if you're underwater on your loan or leasing a vehicle. Some insurers include it; others charge $20–$40/year extra.",
    avgCost: "$20–$60/yr"
  },
  {
    name: "Medical Payments / PIP",
    required: false,
    description: "Pays medical bills for you and your passengers regardless of fault. PIP (Personal Injury Protection) is required in no-fault states and also covers lost wages and funeral costs. Medical payments coverage is simpler and cheaper but covers less.",
    avgCost: "$50–$200/yr"
  }
];

const estimatorProfiles = {
  ageBrackets: ["18–25", "26–35", "36–50", "51–65", "65+"],
  coverageLevels: ["Liability Only", "Standard (50/100/50)", "Full Coverage (100/300/100)"],
  drivingRecords: ["Clean Record", "1 Minor Violation", "1 At-Fault Accident", "DUI/SR-22"]
};

const estimatorData = [
  { company: "State Farm",      rates: [[3200,2400,1900,1600,1700],[2100,1600,1300,1100,1200],[3800,2900,2300,1900,2100]] },
  { company: "GEICO",           rates: [[2800,2100,1600,1400,1500],[1800,1350,1100,950,1050],[3400,2500,1950,1650,1800]] },
  { company: "Progressive",     rates: [[2600,2000,1700,1500,1600],[1700,1300,1200,1000,1100],[3200,2400,2200,1800,1900]] },
  { company: "Allstate",        rates: [[3600,2700,2200,1900,2000],[2300,1800,1500,1300,1400],[4200,3200,2600,2200,2400]] },
  { company: "USAA",            rates: [[2200,1700,1350,1150,1250],[1400,1100,900,780,850],[2700,2100,1650,1400,1500]] },
  { company: "Liberty Mutual",  rates: [[3800,2900,2400,2000,2200],[2500,1900,1600,1400,1500],[4500,3400,2800,2400,2600]] },
  { company: "Farmers",         rates: [[3500,2700,2100,1800,1950],[2200,1700,1450,1250,1350],[4100,3100,2500,2150,2300]] },
  { company: "Nationwide",      rates: [[3000,2200,1750,1500,1600],[1900,1450,1200,1050,1150],[3600,2700,2100,1800,1950]] },
  { company: "Travelers",       rates: [[3100,2300,1800,1550,1650],[2000,1500,1250,1100,1200],[3700,2800,2200,1850,2000]] },
  { company: "Erie",            rates: [[2700,2000,1500,1300,1400],[1700,1300,1050,900,1000],[3200,2400,1850,1550,1700]] }
];

const recordMultipliers = [1.0, 1.2, 1.5, 2.1];

const faqs = [
  {
    q: "How much does car insurance cost on average?",
    a: "The national average for full coverage car insurance is approximately $2,014 per year or about $168 per month as of 2026. Liability-only coverage averages around $622 per year. However, your actual rate depends heavily on your age, location, driving record, credit score (in most states), and the vehicle you drive."
  },
  {
    q: "What's the cheapest car insurance company?",
    a: "GEICO and USAA consistently offer the lowest rates. GEICO averages around $1,540/year for full coverage and is available to everyone. USAA averages $1,290/year but is limited to military members and their families. Erie Insurance ($1,450/year) is also very competitive but only operates in 12 states."
  },
  {
    q: "Is it worth bundling home and auto insurance?",
    a: "Almost always yes. Bundling typically saves 15-25% on your auto premium. State Farm and Travelers offer the best bundling discounts. However, always compare the bundled price against separate quotes from different companies — sometimes two specialized policies beat one bundled deal."
  },
  {
    q: "How much liability coverage do I actually need?",
    a: "Most financial advisors recommend at least 100/300/100 ($100K per person, $300K per accident for injuries, $100K for property damage). State minimums are dangerously low — they won't cover a serious accident. If you have significant assets, consider an umbrella policy on top of higher liability limits."
  },
  {
    q: "Does my credit score affect car insurance rates?",
    a: "In most states, yes — significantly. Insurers use credit-based insurance scores, and the difference between excellent and poor credit can mean 40-100% higher premiums. California, Hawaii, Massachusetts, and Michigan prohibit using credit scores for auto insurance pricing."
  },
  {
    q: "What is an SR-22 and how does it affect my insurance?",
    a: "An SR-22 is a certificate proving you carry minimum liability insurance, typically required after a DUI, driving without insurance, or multiple violations. The filing itself costs $15-50, but the real cost is dramatically higher insurance rates — expect premiums to roughly double for 3-5 years. Progressive and GEICO are generally the most competitive for SR-22 policies."
  },
  {
    q: "Can I get car insurance with no down payment?",
    a: "Most insurers require your first month's premium upfront, but some like Progressive and GEICO offer low-deposit options, especially if you pay monthly. Paying the full 6-month or annual premium upfront is always cheaper — you typically save 5-10% by avoiding monthly installment fees."
  },
  {
    q: "How do telematics (usage-based) programs work?",
    a: "Telematics programs like Progressive's Snapshot, Allstate's Drivewise, and Nationwide's SmartRide use a mobile app or plug-in device to monitor your driving habits — braking, speed, mileage, and time of day. Safe drivers can earn discounts of 10-40%. The data typically doesn't increase your rate (some insurers guarantee this), but read the fine print before enrolling."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Car Insurance Companies Comparison 2026 — 10 Major Insurers Rated",
    "description": "Comprehensive comparison of 10 major US car insurance companies. Average premiums, AM Best ratings, J.D. Power scores, discounts, and category winners to help you find the best car insurance.",
    "author": {
      "@type": "Organization",
      "name": "Please Start Please"
    },
    "datePublished": "2026-03-21",
    "dateModified": "2026-03-21"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Car Insurance Companies Comparison 2026 — 10 Major Insurers Rated",
  description: "Compare 10 major US car insurance companies side by side. Average premiums, ratings, discounts, and an interactive cost estimator to find the best car insurance for you.",
  category: "guide",
  published: "2026-03-21",
};
---

<SiteLayout
  site="pleasestartplease"
  title="Car Insurance Companies Comparison 2026 — 10 Major Insurers Rated"
  description="Compare 10 major US car insurance companies side by side. Average premiums, ratings, discounts, and an interactive cost estimator to find the best car insurance for you."
  canonical="https://pleasestartplease.com/car-insurance-comparison"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      📋 <strong style="color:#EF4444;">Auto insurance premiums jumped 20% in 2026.</strong> The average driver now pays $2,543/year. Shopping around saves $500-1,200 — the gap between cheapest and priciest insurer for identical coverage is massive. <a href="https://gab.ae/news/uk-petrol-150p-diesel-177p-fuel-costs-commuters-2026" style="color:#EF4444;">Why driving costs keep rising →</a>
    </div>
    <div class="hero">
      <h1>Car Insurance Companies Comparison (2026)</h1>
      <p>We compared 10 major US auto insurers on price, ratings, customer satisfaction, and discounts. Here's how they stack up.</p>
    </div>

    <section class="content-section">
      <p>Car insurance is the second-largest vehicle expense after the car itself, yet most people just auto-renew without shopping around. That's a mistake — the difference between the cheapest and most expensive insurer for the same coverage can be $1,000+ per year.</p>
      <p>We analyzed average premiums, AM Best financial strength ratings, J.D. Power customer satisfaction scores, available discounts, and claims experiences for 10 of the largest US auto insurance companies. Whether you're looking for the cheapest rate, the best customer service, or coverage tailored to your specific situation, this guide has you covered.</p>

      <h2>Quick Verdict: Category Winners</h2>
      <div class="winners-grid">
        {categoryWinners.map(w => (
          <div class="winner-card">
            <span class="winner-label">{w.category}</span>
            <strong>{w.pick}</strong>
            <span class="winner-reason">{w.reason}</span>
          </div>
        ))}
      </div>

      <h2>Comparison Table</h2>
      <p>Click any column header to sort. Premiums are national averages for full coverage.</p>
      <div class="table-wrapper">
        <table id="comparison-table">
          <thead>
            <tr>
              <th data-sort="string">Company</th>
              <th data-sort="number">Avg Annual</th>
              <th data-sort="string">AM Best</th>
              <th data-sort="number">J.D. Power</th>
              <th data-sort="string">Discounts Available</th>
              <th data-sort="string">Best For</th>
            </tr>
          </thead>
          <tbody>
            {insurers.map(ins => (
              <tr>
                <td><strong>{ins.name}</strong></td>
                <td data-value={ins.avgAnnual}>${ins.avgAnnual.toLocaleString()}</td>
                <td>{ins.amBest}</td>
                <td data-value={ins.jdPower}>{ins.jdPower}/1000</td>
                <td class="td-discounts">{ins.discounts}</td>
                <td>{ins.bestFor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Cost Estimator</h2>
      <p>Select your profile to see estimated annual premiums per company. These are national averages — your actual rate will vary by state, vehicle, and credit score.</p>
      <div class="estimator-card">
        <div class="estimator-controls">
          <div class="control-group">
            <label for="age-select">Age Bracket</label>
            <select id="age-select">
              {estimatorProfiles.ageBrackets.map((b, i) => (
                <option value={i} selected={i === 2}>{b}</option>
              ))}
            </select>
          </div>
          <div class="control-group">
            <label for="coverage-select">Coverage Level</label>
            <select id="coverage-select">
              {estimatorProfiles.coverageLevels.map((c, i) => (
                <option value={i} selected={i === 2}>{c}</option>
              ))}
            </select>
          </div>
          <div class="control-group">
            <label for="record-select">Driving Record</label>
            <select id="record-select">
              {estimatorProfiles.drivingRecords.map((r, i) => (
                <option value={i}>{r}</option>
              ))}
            </select>
          </div>
        </div>
        <div id="estimator-results" class="estimator-results"></div>
        <p class="estimator-note">Estimates based on national averages. Actual quotes may vary by 20-40% depending on state, ZIP code, vehicle, and credit score.</p>
      </div>

      <h2>Detailed Company Reviews</h2>

      {insurers.map((ins, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{ins.name}</h3>
              {ins.badge && <span class="badge">{ins.badge}</span>}
            </div>
            <span class="review-price">${ins.avgAnnual.toLocaleString()}<small>/yr avg</small></span>
          </div>

          <p class="review-summary">{ins.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">AM Best Rating</span><span class="spec-value">{ins.amBest}</span></div>
            <div class="spec"><span class="spec-label">J.D. Power Score</span><span class="spec-value">{ins.jdPower}/1000</span></div>
            <div class="spec"><span class="spec-label">Avg Full Coverage</span><span class="spec-value">${ins.avgFull.toLocaleString()}/yr</span></div>
            <div class="spec"><span class="spec-label">Avg Liability Only</span><span class="spec-value">${ins.avgLiability.toLocaleString()}/yr</span></div>
            <div class="spec"><span class="spec-label">Claims Satisfaction</span><span class="spec-value">{ins.claimsSatisfaction}</span></div>
            <div class="spec"><span class="spec-label">Best For</span><span class="spec-value">{ins.bestFor}</span></div>
          </div>

          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{ins.pros.map(p => <li>{p}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{ins.cons.map(c => <li>{c}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Coverage Types Explained</h2>
      <p>Understanding what each coverage type does — and whether you need it — can save you hundreds per year without leaving you exposed.</p>

      <div class="coverage-grid">
        {coverageTypes.map(ct => (
          <div class="coverage-card">
            <div class="coverage-header">
              <h3>{ct.name}</h3>
              <div class="coverage-tags">
                <span class={`coverage-tag ${ct.required ? 'required' : 'optional'}`}>{ct.required ? 'Required' : 'Optional'}</span>
                <span class="coverage-cost">{ct.avgCost}</span>
              </div>
            </div>
            <p>{ct.description}</p>
          </div>
        ))}
      </div>

      <h2>How to Save on Car Insurance</h2>
      <h3>Shop Around Every 6–12 Months</h3>
      <p>Insurers adjust their pricing models constantly. The cheapest company for you last year may not be cheapest this year. Get 3-5 quotes each renewal period — it takes 30 minutes and can save hundreds.</p>

      <h3>Bundle Strategically</h3>
      <p>Bundling home and auto with State Farm or Travelers can save 20-25%. But always compare the bundled price against separate best-rate policies — sometimes two separate companies beat one bundle.</p>

      <h3>Raise Your Deductible</h3>
      <p>Increasing your collision deductible from $500 to $1,000 can cut that portion of your premium by 15-30%. Just make sure you have the deductible amount in savings.</p>

      <h3>Ask About Every Discount</h3>
      <p>Most insurers have 10-15 discounts, and agents don't always apply them automatically. Ask specifically about: multi-car, good driver, paperless, paid-in-full, anti-theft, good student, defensive driving, low mileage, and professional organization discounts.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/" class="related-link">
          <strong>Please Start Please — Home</strong>
          <span>Browse all guides and comparisons</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ estimatorData, recordMultipliers }}>
    (function() {
      // Sortable table
      const table = document.getElementById('comparison-table');
      if (table) {
        const headers = table.querySelectorAll('th');
        let currentSort = { col: -1, asc: true };

        headers.forEach((th, index) => {
          th.style.cursor = 'pointer';
          th.addEventListener('click', () => {
            const sortType = th.dataset.sort;
            const asc = currentSort.col === index ? !currentSort.asc : true;
            currentSort = { col: index, asc };

            headers.forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
            th.classList.add(asc ? 'sort-asc' : 'sort-desc');

            const tbody = table.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
              const cellA = a.children[index];
              const cellB = b.children[index];
              let valA, valB;

              if (sortType === 'number') {
                valA = parseFloat(cellA.dataset.value || cellA.textContent.replace(/[^0-9.\-]/g, ''));
                valB = parseFloat(cellB.dataset.value || cellB.textContent.replace(/[^0-9.\-]/g, ''));
                return asc ? valA - valB : valB - valA;
              } else {
                valA = cellA.textContent.trim().toLowerCase();
                valB = cellB.textContent.trim().toLowerCase();
                return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
              }
            });

            rows.forEach(row => tbody.appendChild(row));
          });
        });
      }

      // Cost Estimator
      const ageSelect = document.getElementById('age-select');
      const coverageSelect = document.getElementById('coverage-select');
      const recordSelect = document.getElementById('record-select');
      const resultsDiv = document.getElementById('estimator-results');

      function updateEstimator() {
        const age = parseInt(ageSelect.value);
        const coverage = parseInt(coverageSelect.value);
        const record = parseInt(recordSelect.value);
        const multiplier = recordMultipliers[record];

        const results = estimatorData.map(d => {
          const base = d.rates[coverage][age];
          const adjusted = Math.round(base * multiplier);
          return { company: d.company, annual: adjusted, monthly: Math.round(adjusted / 12) };
        }).sort((a, b) => a.annual - b.annual);

        resultsDiv.innerHTML = results.map((r, i) => {
          const barWidth = Math.round((r.annual / results[results.length - 1].annual) * 100);
          return '<div class="est-row">' +
            '<div class="est-rank">' + (i + 1) + '</div>' +
            '<div class="est-info">' +
              '<div class="est-company">' + r.company + '</div>' +
              '<div class="est-bar-track"><div class="est-bar" style="width:' + barWidth + '%"></div></div>' +
            '</div>' +
            '<div class="est-price">$' + r.annual.toLocaleString() + '<small>/yr</small></div>' +
            '<div class="est-monthly">$' + r.monthly + '<small>/mo</small></div>' +
          '</div>';
        }).join('');
      }

      if (ageSelect && coverageSelect && recordSelect) {
        ageSelect.addEventListener('change', updateEstimator);
        coverageSelect.addEventListener('change', updateEstimator);
        recordSelect.addEventListener('change', updateEstimator);
        updateEstimator();
      }
    })();
  </script>

