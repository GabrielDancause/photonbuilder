        { label:"Active — 1-2 hours outdoors daily", value:3 },
        { label:"Very active — running, hiking, sports daily", value:4 }
      ]},
      { id:"grooming", text:"How much grooming are you willing to do?", options:[
        { label:"Minimal — occasional brushing at most", value:1 },
        { label:"Moderate — weekly brushing, basic upkeep", value:2 },
