            <tr><td><strong>Grooming Tolerance</strong></td><td>Some breeds need daily brushing or professional grooming</td></tr>
            <tr><td><strong>Experience Level</strong></td><td>Some breeds require experienced, confident handling</td></tr>
            <tr><td><strong>Family Situation</strong></td><td>Kid-friendliness and compatibility with other pets varies widely</td></tr>
            <tr><td><strong>Size Preference</strong></td><td>Affects food costs, space needs, and physical handling</td></tr>
            <tr><td><strong>Shedding Tolerance</strong></td><td>Ranges from hypoallergenic to heavy year-round shedding</td></tr>
            <tr><td><strong>Noise Tolerance</strong></td><td>Barking frequency matters for apartments and close neighbors</td></tr>
            <tr><td><strong>Climate</strong></td><td>Coat type affects comfort in hot or cold environments</td></tr>
            <tr><td><strong>Alone Time</strong></td><td>Some breeds develop anxiety when left alone for hours</td></tr>
            <tr><td><strong>Budget</strong></td><td>Size, health issues, and grooming needs affect lifetime cost</td></tr>
            <tr><td><strong>Purpose</strong></td><td>Companion, guard dog, sport/agility, or family pet</td></tr>
          </tbody>
        </table>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-section">
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>

    </section>
