      { name:"Saint Bernard", size:"giant", energy:2, grooming:3, trainability:3, shedding:4, barking:2, lifespan:"8-10", kidFriendly:5, petFriendly:3, aloneTime:2, guard:2, sport:1, climate:"cold", cost:4, experience:2, space:3 },
      { name:"Havanese", size:"small", energy:2, grooming:4, trainability:4, shedding:1, barking:2, lifespan:"14-16", kidFriendly:5, petFriendly:4, aloneTime:1, guard:1, sport:1, climate:"any", cost:2, experience:1, space:1 }
    ];

    var questions = [
      { id:"space", text:"What best describes your living space?", options:[
        { label:"Apartment / condo", value:1 },
        { label:"House with small yard", value:2 },
        { label:"House with large yard", value:3 },
        { label:"Farm / rural property", value:4 }
      ]},
      { id:"activity", text:"How active are you on a typical day?", options:[
