        { label:"Hot and humid year-round", value:1 },
        { label:"Warm / temperate", value:2 },
        { label:"Four seasons with cold winters", value:3 },
        { label:"Cold most of the year", value:4 }
      ]},
      { id:"alone", text:"How many hours will the dog be alone daily?", options:[
        { label:"Rarely alone — I work from home", value:1 },
        { label:"2-4 hours", value:2 },
        { label:"4-8 hours (typical workday)", value:3 },
        { label:"8+ hours regularly", value:4 }
      ]},
      { id:"purpose", text:"What is the primary purpose for your dog?", options:[
        { label:"Companion / lap dog", value:1 },
        { label:"Family pet", value:2 },
        { label:"Guard / protection dog", value:3 },
        { label:"Sport / agility / working dog", value:4 }
      ]}
    ];

    var answers = {};
    var currentQ = 0;
    var questionArea = document.getElementById("questionArea");
    var progressFill = document.getElementById("progressFill");
    var counter = document.getElementById("questionCounter");
    var quizContainer = document.getElementById("quizContainer");
    var resultsPanel = document.getElementById("resultsPanel");

    function renderQuestion(idx) {
      var q = questions[idx];
      counter.textContent = "Question " + (idx + 1) + " of " + questions.length;
      progressFill.style.width = ((idx / questions.length) * 100) + "%";
      var html = '<div class="question"><h2 class="question-text">' + q.text + '</h2><div class="options">';
      q.options.forEach(function(opt, i) {
        html += '<button class="option-btn" data-qid="' + q.id + '" data-value="' + opt.value + '">' + opt.label + '</button>';
      });
      html += '</div>';
      if (idx > 0) html += '<button class="back-btn" id="backBtn">Back</button>';
      html += '</div>';
      questionArea.innerHTML = html;

      questionArea.querySelectorAll(".option-btn").forEach(function(btn) {
        btn.addEventListener("click", function() {
          answers[this.getAttribute("data-qid")] = parseInt(this.getAttribute("data-value"));
          if (currentQ < questions.length - 1) {
            currentQ++;
            renderQuestion(currentQ);
          } else {
            showResults();
          }
        });
      });

      var backBtn = document.getElementById("backBtn");
      if (backBtn) {
        backBtn.addEventListener("click", function() {
          if (currentQ > 0) { currentQ--; renderQuestion(currentQ); }
        });
      }
    }

    function scoreBreed(breed, ans) {
      var score = 0;
      var maxScore = 0;
      var reasons = [];

      // Space (weight: 10)
      var w = 10;
      maxScore += w;
      var spaceNeed = breed.space;
      if (ans.space >= spaceNeed) { score += w; reasons.push("fits your living space well"); }
      else if (ans.space === spaceNeed - 1) { score += w * 0.5; }

      // Activity (weight: 12)
      w = 12;
      maxScore += w;
      var diff = Math.abs(ans.activity - breed.energy);
      if (diff === 0) { score += w; reasons.push("matches your activity level"); }
      else if (diff === 1) { score += w * 0.6; }
      else if (diff === 2) { score += w * 0.2; }

      // Grooming (weight: 8)
      w = 8;
      maxScore += w;
      if (ans.grooming >= breed.grooming) { score += w; reasons.push("grooming needs fit your tolerance"); }
      else if (ans.grooming === breed.grooming - 1) { score += w * 0.5; }
      else { score += w * 0.1; }

      // Experience (weight: 10)
      w = 10;
      maxScore += w;
      if (ans.experience >= breed.experience) { score += w; reasons.push("good match for your experience level"); }
      else if (ans.experience === breed.experience - 1) { score += w * 0.4; }
      else { score += w * 0.1; }

      // Kids (weight: 9)
      w = 9;
      maxScore += w;
      if (ans.kids === 0) { score += w; }
      else {
        if (breed.kidFriendly >= 4) { score += w; reasons.push("great with children"); }
        else if (breed.kidFriendly === 3) { score += w * 0.5; }
        else { score += w * 0.1; }
      }

      // Other pets (weight: 7)
      w = 7;
      maxScore += w;
      if (ans.pets === 0) { score += w; }
      else {
        if (breed.petFriendly >= 4) { score += w; reasons.push("gets along well with other pets"); }
        else if (breed.petFriendly === 3) { score += w * 0.5; }
        else { score += w * 0.1; }
      }

      // Size (weight: 8)
      w = 8;
      maxScore += w;
      if (ans.size === 0) { score += w; }
      else {
        var sizeMap = { small:1, medium:2, large:3, giant:4 };
        var breedSizeVal = sizeMap[breed.size] || 2;
        if (breedSizeVal === ans.size) { score += w; reasons.push("ideal size for you"); }
        else if (Math.abs(breedSizeVal - ans.size) === 1) { score += w * 0.4; }
        else { score += w * 0.05; }
      }

      // Shedding (weight: 8)
      w = 8;
      maxScore += w;
      if (ans.shedding >= breed.shedding) { score += w; reasons.push("shedding within your tolerance"); }
      else if (ans.shedding === breed.shedding - 1) { score += w * 0.4; }
      else { score += w * 0.05; }

      // Noise (weight: 8)
      w = 8;
      maxScore += w;
      if (ans.noise >= breed.barking) { score += w; reasons.push("barking level suits your situation"); }
      else if (ans.noise === breed.barking - 1) { score += w * 0.4; }
      else { score += w * 0.1; }

      // Climate (weight: 6)
      w = 6;
      maxScore += w;
      if (breed.climate === "any") { score += w; }
      else if (breed.climate === "cold" && ans.climate >= 3) { score += w; reasons.push("thrives in your climate"); }
      else if (breed.climate === "cool" && ans.climate >= 2) { score += w; }
      else if (breed.climate === "warm" && ans.climate <= 2) { score += w; reasons.push("suited to your warm climate"); }
      else { score += w * 0.3; }

      // Alone time (weight: 9)
      w = 9;
      maxScore += w;
      if (ans.alone <= 2 || breed.aloneTime >= ans.alone) {
        score += w;
        if (breed.aloneTime >= 3 && ans.alone >= 3) reasons.push("handles alone time well");
      }
      else if (Math.abs(breed.aloneTime - ans.alone) === 1) { score += w * 0.5; }
      else { score += w * 0.15; }

      // Purpose (weight: 10)
      w = 10;
      maxScore += w;
      if (ans.purpose === 1) {
        if (breed.energy <= 2 && breed.size !== "giant") { score += w; reasons.push("perfect companion breed"); }
        else if (breed.energy <= 3) { score += w * 0.6; }
        else { score += w * 0.2; }
      } else if (ans.purpose === 2) {
        if (breed.kidFriendly >= 4 && breed.trainability >= 3) { score += w; reasons.push("excellent family dog"); }
        else if (breed.kidFriendly >= 3) { score += w * 0.5; }
        else { score += w * 0.2; }
      } else if (ans.purpose === 3) {
        if (breed.guard >= 4) { score += w; reasons.push("strong protective instinct"); }
        else if (breed.guard >= 3) { score += w * 0.5; }
        else { score += w * 0.1; }
      } else if (ans.purpose === 4) {
        if (breed.sport >= 4) { score += w; reasons.push("built for sport and agility"); }
        else if (breed.sport >= 3) { score += w * 0.5; }
        else { score += w * 0.1; }
      }

      return {
        breed: breed,
        score: Math.round((score / maxScore) * 100),
        reasons: reasons.slice(0, 4)
      };
    }

    function showResults() {
      quizContainer.style.display = "none";
      resultsPanel.style.display = "";

      var results = breeds.map(function(b) { return scoreBreed(b, answers); });
      results.sort(function(a, b) { return b.score - a.score; });

      var top5 = results.slice(0, 5);
      var matchesHtml = "";
      var statLabels = { energy:"Energy", grooming:"Grooming", trainability:"Trainability", shedding:"Shedding", barking:"Noise" };

      top5.forEach(function(m, i) {
        var b = m.breed;
        var barColor = m.score >= 80 ? "var(--accent-color)" : m.score >= 60 ? "#f59e0b" : "#94a3b8";
        matchesHtml += '<div class="match-card' + (i === 0 ? ' top-match' : '') + '">';
        matchesHtml += '<div class="match-header"><div class="match-rank">#' + (i + 1) + '</div>';
        matchesHtml += '<div class="match-info"><h3>' + b.name + '</h3>';
        matchesHtml += '<span class="match-pct" style="color:' + barColor + '">' + m.score + '% Match</span></div></div>';
        matchesHtml += '<div class="match-bar-track"><div class="match-bar-fill" style="width:' + m.score + '%;background:' + barColor + '"></div></div>';
        matchesHtml += '<div class="match-stats">';
        matchesHtml += '<div class="stat-item"><span class="stat-label">Size</span><span class="stat-value">' + b.size.charAt(0).toUpperCase() + b.size.slice(1) + '</span></div>';
        matchesHtml += '<div class="stat-item"><span class="stat-label">Lifespan</span><span class="stat-value">' + b.lifespan + ' yrs</span></div>';
        Object.keys(statLabels).forEach(function(k) {
          var val = b[k];
          var dots = "";
          for (var d = 1; d <= 5; d++) dots += '<span class="dot' + (d <= val ? ' filled' : '') + '"></span>';
          matchesHtml += '<div class="stat-item"><span class="stat-label">' + statLabels[k] + '</span><span class="stat-dots">' + dots + '</span></div>';
        });
        matchesHtml += '</div>';
        if (m.reasons.length > 0) {
          matchesHtml += '<div class="match-reasons"><strong>Why it matched:</strong><ul>';
          m.reasons.forEach(function(r) { matchesHtml += '<li>' + r.charAt(0).toUpperCase() + r.slice(1) + '</li>'; });
          matchesHtml += '</ul></div>';
        }
        matchesHtml += '</div>';
      });

      document.getElementById("topMatches").innerHTML = matchesHtml;

      // Comparison mode for top 3
      var top3 = results.slice(0, 3);
      var compareSection = document.getElementById("compareSection");
      var compareGrid = document.getElementById("compareGrid");
      compareSection.style.display = "";

      var compHtml = '<div class="compare-row compare-header-row"><div class="compare-label"></div>';
      top3.forEach(function(m) { compHtml += '<div class="compare-cell"><strong>' + m.breed.name + '</strong><br><span style="color:var(--accent-color)">' + m.score + '%</span></div>'; });
      compHtml += '</div>';

      var compRows = [
        { label:"Size", key:"size", fmt: function(v){ return v.charAt(0).toUpperCase()+v.slice(1); }},
        { label:"Energy", key:"energy" },
        { label:"Grooming", key:"grooming" },
        { label:"Trainability", key:"trainability" },
        { label:"Shedding", key:"shedding" },
        { label:"Noise", key:"barking" },
        { label:"Kid-Friendly", key:"kidFriendly" },
        { label:"Pet-Friendly", key:"petFriendly" },
        { label:"Alone Tolerance", key:"aloneTime" },
        { label:"Lifespan", key:"lifespan", fmt: function(v){ return v + " yrs"; }}
      ];

      compRows.forEach(function(row) {
        compHtml += '<div class="compare-row"><div class="compare-label">' + row.label + '</div>';
        top3.forEach(function(m) {
          var val = m.breed[row.key];
          if (row.fmt) {
            compHtml += '<div class="compare-cell">' + row.fmt(val) + '</div>';
          } else {
            var dots = "";
            for (var d = 1; d <= 5; d++) dots += '<span class="dot' + (d <= val ? ' filled' : '') + '"></span>';
            compHtml += '<div class="compare-cell"><span class="stat-dots">' + dots + '</span></div>';
          }
        });
        compHtml += '</div>';
      });

      compareGrid.innerHTML = compHtml;

      resultsPanel.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    document.getElementById("retakeBtn").addEventListener("click", function() {
      answers = {};
      currentQ = 0;
      quizContainer.style.display = "";
      resultsPanel.style.display = "none";
      renderQuestion(0);
      quizContainer.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    renderQuestion(0);
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

    strong { color: var(--text-primary); }

    /* Quiz Card */
    .quiz-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; }

    /* Progress */
    .progress-bar { height: 6px; background: var(--border-color); border-radius: 3px; margin-bottom: 0.75rem; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--accent-color); border-radius: 3px; transition: width 0.3s ease; }
    .question-counter { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem; font-weight: 600; }

    /* Question */
    .question-text { font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.25rem; margin-top: 0; }
    .options { display: flex; flex-direction: column; gap: 0.65rem; }
    .option-btn { display: block; width: 100%; text-align: left; padding: 0.9rem 1.2rem; background: var(--bg-primary, #f9fafb); border: 2px solid var(--border-color); border-radius: 10px; font-size: 1rem; color: var(--text-primary); cursor: pointer; transition: border-color 0.2s, background 0.2s; }
    .option-btn:hover { border-color: var(--accent-color); background: var(--card-bg); }
    .back-btn { margin-top: 1.25rem; padding: 0.5rem 1.2rem; background: none; border: 1px solid var(--border-color); border-radius: 8px; color: var(--text-secondary); cursor: pointer; font-size: 0.9rem; transition: border-color 0.2s; }
    .back-btn:hover { border-color: var(--text-secondary); }

    /* Results */
    .results-header { text-align: center; margin-bottom: 2rem; }
    .results-header h2 { margin-top: 0; color: var(--text-primary); }
    .results-header p { color: var(--text-secondary); }

    /* Match Cards */
    .match-card { background: var(--bg-primary, #f9fafb); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1rem; }
    .match-card.top-match { border-color: var(--accent-color); box-shadow: 0 0 0 1px var(--accent-color); }
    .match-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
    .match-rank { font-size: 1.5rem; font-weight: 900; color: var(--accent-color); min-width: 40px; }
    .match-info h3 { margin: 0; font-size: 1.2rem; color: var(--text-primary); }
    .match-pct { font-size: 1.1rem; font-weight: 700; }
    .match-bar-track { height: 8px; background: var(--border-color); border-radius: 4px; margin-bottom: 1rem; overflow: hidden; }
    .match-bar-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease; }

    .match-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.6rem; margin-bottom: 1rem; }
    .stat-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .stat-label { font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; }
    .stat-value { font-size: 0.95rem; font-weight: 700; color: var(--text-primary); }
    .stat-dots { display: flex; gap: 3px; align-items: center; padding-top: 2px; }
    .dot { width: 10px; height: 10px; border-radius: 50%; background: var(--border-color); display: inline-block; }
    .dot.filled { background: var(--accent-color); }

    .match-reasons { padding-top: 0.5rem; border-top: 1px solid var(--border-color); }
    .match-reasons strong { font-size: 0.85rem; color: var(--text-primary); }
    .match-reasons ul { margin: 0.4rem 0 0; padding-left: 1.2rem; }
    .match-reasons li { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; }

    /* Comparison */
    .compare-section { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color); }
    .compare-section h3 { margin-top: 0; font-size: 1.3rem; color: var(--text-primary); margin-bottom: 1rem; }
    .compare-grid { overflow-x: auto; }
    .compare-row { display: grid; grid-template-columns: 120px repeat(3, 1fr); gap: 0.5rem; padding: 0.6rem 0; border-bottom: 1px solid var(--border-color); align-items: center; }
    .compare-row:last-child { border-bottom: none; }
    .compare-header-row { font-weight: 700; padding-bottom: 0.75rem; border-bottom: 2px solid var(--border-color); }
    .compare-label { font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; font-weight: 600; letter-spacing: 0.03em; }
    .compare-cell { font-size: 0.9rem; color: var(--text-primary); text-align: center; }

    .retake-btn { display: block; width: 100%; margin-top: 2rem; padding: 0.8rem; background: var(--accent-color); color: #fff; border: none; border-radius: 10px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: opacity 0.2s; }
    .retake-btn:hover { opacity: 0.85; }

    /* Table */
    .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.85rem 0.75rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.75rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* FAQ */
    .faq-section { margin-top: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .question-text { font-size: 1.2rem; }
      .match-stats { grid-template-columns: repeat(2, 1fr); }
      .compare-row { grid-template-columns: 90px repeat(3, 1fr); }
      .compare-label { font-size: 0.7rem; }
      .compare-cell { font-size: 0.8rem; }
    }
  </style>
</SiteLayout>