      { name:"Basset Hound", size:"medium", energy:2, grooming:2, trainability:2, shedding:3, barking:4, lifespan:"12-13", kidFriendly:5, petFriendly:4, aloneTime:2, guard:1, sport:1, climate:"any", cost:2, experience:1, space:1 },
