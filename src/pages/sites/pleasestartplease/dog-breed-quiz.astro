  <div class="page-content">
    <div class="hero">
      <h1>Dog Breed Matcher Quiz</h1>
      <p>Answer 12 questions about your lifestyle and preferences to find the perfect dog breed for you.</p>
    </div>

    <section class="content-section">
      <div class="quiz-card">
        <div id="quizContainer">
          <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
          <div class="question-counter" id="questionCounter">Question 1 of 12</div>
          <div id="questionArea"></div>
