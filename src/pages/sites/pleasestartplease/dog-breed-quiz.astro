      { name:"Newfoundland", size:"giant", energy:2, grooming:4, trainability:4, shedding:4, barking:2, lifespan:"8-10", kidFriendly:5, petFriendly:4, aloneTime:2, guard:2, sport:2, climate:"cold", cost:4, experience:2, space:3 },
