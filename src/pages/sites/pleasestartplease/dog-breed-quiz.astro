      { name:"Corgi (Pembroke Welsh)", size:"medium", energy:4, grooming:2, trainability:4, shedding:4, barking:4, lifespan:"12-13", kidFriendly:4, petFriendly:3, aloneTime:2, guard:2, sport:3, climate:"any", cost:2, experience:2, space:1 },
      { name:"Maltese", size:"small", energy:2, grooming:5, trainability:3, shedding:1, barking:3, lifespan:"12-15", kidFriendly:3, petFriendly:3, aloneTime:1, guard:1, sport:1, climate:"warm", cost:2, experience:1, space:1 },
