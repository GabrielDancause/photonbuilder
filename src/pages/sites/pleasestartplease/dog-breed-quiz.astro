---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How accurate is this dog breed matcher quiz?",
    a: "This quiz evaluates your lifestyle, living situation, and preferences against breed characteristics compiled from AKC data, veterinary research, and breed-specific organizations. While no quiz can perfectly predict compatibility, our scoring considers 12 key factors across 30+ breeds to give you a reliable starting point for your search."
  },
  {
    q: "Should I only consider my top match?",
    a: "No — your top 3-5 matches are all worth exploring. Breeds that score within a few percentage points of each other may suit you equally well. Use the comparison feature to evaluate differences in grooming needs, exercise requirements, and temperament. Meeting dogs of your top breeds in person is the best next step."
  },
  {
    q: "Can I get a large dog if I live in an apartment?",
    a: "Yes, some large breeds adapt well to apartments if they get enough exercise. Greyhounds, for example, are surprisingly good apartment dogs because they're calm indoors. The key factors are exercise commitment, noise level (barking), and whether the dog can handle limited indoor space without becoming destructive."
  },
  {
    q: "What if I want a mixed breed or rescue dog?",
    a: "Mixed breeds often combine traits from multiple breeds, which can be a great advantage. Use your top matches as a guide — if your results favor calm, medium-sized, low-shedding breeds, look for mixes with those characteristics at shelters. Many rescue organizations also temperament-test their dogs to help with matching."
  },
  {
    q: "How important is experience level when choosing a breed?",
    a: "Very important. Some breeds like Border Collies and Akitas are intelligent but require experienced handling to prevent behavioral issues. First-time owners generally do best with eager-to-please, forgiving breeds like Labrador Retrievers, Golden Retrievers, or Cavalier King Charles Spaniels that respond well to basic training."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Dog Breed Matcher Quiz",
    "description": "Take our 12-question quiz to find your ideal dog breed. Get matched with the best breeds for your lifestyle, living space, and preferences.",
    "url": "https://pleasestartplease.photonbuilder.com/dog-breed-quiz",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Dog Breed Matcher Quiz — Find Your Ideal Dog Breed",
  description: "Take our 12-question quiz to find your ideal dog breed. Get matched with the best breeds for your lifestyle, living space, and preferences.",
  category: "quiz",
  published: "2026-03-21",
};
