---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tire Speed Rating Chart - Complete Guide & Lookup Tool",
  description: "Complete tire speed rating reference chart with interactive lookup. Learn what speed rating letters mean, max speeds in mph/km/h, and safety guidelines.",
  category: "guide"
};
---

<SiteLayout site="pleasestartplease" {meta}>
  <div class="container">
    <header class="page-header">
      <h1>Tire Speed Rating Chart</h1>
      <p class="subtitle">Complete reference guide with interactive lookup tool</p>
    </header>

    <!-- Speed Rating Lookup Tool -->
    <section class="lookup-tool">
      <h2>🔍 Speed Rating Lookup</h2>
      <div class="lookup-container">
        <div class="input-group">
          <label for="speedRating">Enter or select speed rating letter:</label>
          <select id="speedRating" class="rating-select">
            <option value="">Choose a rating...</option>
            <option value="L">L</option>
            <option value="M">M</option>
            <option value="N">N</option>
            <option value="P">P</option>
            <option value="Q">Q</option>
            <option value="R">R</option>
            <option value="S">S</option>
            <option value="T">T</option>
            <option value="U">U</option>
            <option value="H">H</option>
            <option value="V">V</option>
            <option value="W">W</option>
            <option value="Y">Y</option>
            <option value="Z">Z/ZR</option>
          </select>
        </div>
        
        <div id="lookupResult" class="lookup-result hidden">
          <div class="result-card">
            <h3 class="rating-letter"></h3>
            <div class="speed-info">
              <div class="speed-mph"></div>
              <div class="speed-kmh"></div>
            </div>
            <div class="vehicle-types"></div>
            <div class="description"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Complete Speed Rating Chart -->
    <section class="chart-section">
      <h2>📊 Complete Speed Rating Chart</h2>
      <div class="table-container">
        <table class="rating-table">
          <thead>
            <tr>
              <th>Rating</th>
              <th>Max Speed (mph)</th>
              <th>Max Speed (km/h)</th>
              <th>Typical Vehicles</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="rating-cell">L</td>
              <td class="speed-cell">75</td>
              <td class="speed-cell">120</td>
              <td>Off-road, light trucks</td>
            </tr>
            <tr>
              <td class="rating-cell">M</td>
              <td class="speed-cell">81</td>
              <td class="speed-cell">130</td>
              <td>Temporary spare tires</td>
            </tr>
            <tr>
              <td class="rating-cell">N</td>
              <td class="speed-cell">87</td>
              <td class="speed-cell">140</td>
              <td>Temporary spare tires</td>
            </tr>
            <tr>
              <td class="rating-cell">P</td>
              <td class="speed-cell">93</td>
              <td class="speed-cell">150</td>
              <td>Sedans, station wagons</td>
            </tr>
            <tr>
              <td class="rating-cell">Q</td>
              <td class="speed-cell">99</td>
              <td class="speed-cell">160</td>
              <td>Winter tires, SUVs</td>
            </tr>
            <tr>
              <td class="rating-cell">R</td>
              <td class="speed-cell">106</td>
              <td class="speed-cell">170</td>
              <td>Heavy-duty light trucks</td>
            </tr>
            <tr>
              <td class="rating-cell">S</td>
              <td class="speed-cell">112</td>
              <td class="speed-cell">180</td>
              <td>Family sedans, minivans</td>
            </tr>
            <tr>
              <td class="rating-cell">T</td>
              <td class="speed-cell">118</td>
              <td class="speed-cell">190</td>
              <td>Family sedans, minivans</td>
            </tr>
            <tr>
              <td class="rating-cell">U</td>
              <td class="speed-cell">124</td>
              <td class="speed-cell">200</td>
              <td>Sedans, coupes</td>
            </tr>
            <tr>
              <td class="rating-cell">H</td>
              <td class="speed-cell">130</td>
              <td class="speed-cell">210</td>
              <td>Sport sedans, coupes</td>
            </tr>
            <tr>
              <td class="rating-cell">V</td>
              <td class="speed-cell">149</td>
              <td class="speed-cell">240</td>
              <td>Sports cars, luxury</td>
            </tr>
            <tr>
              <td class="rating-cell">W</td>
              <td class="speed-cell">168</td>
              <td class="speed-cell">270</td>
              <td>Performance sports cars</td>
            </tr>
            <tr>
              <td class="rating-cell">Y</td>
              <td class="speed-cell">186</td>
              <td class="speed-cell">300</td>
              <td>Exotic/high-performance</td>
            </tr>
            <tr>
              <td class="rating-cell">Z/ZR</td>
              <td class="speed-cell">149+</td>
              <td class="speed-cell">240+</td>
              <td>High-performance sports</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- How to Read Tire Size -->
    <section class="tire-reading-section">
      <h2>🔍 How to Read Tire Size</h2>
      <div class="tire-diagram">
        <div class="tire-sidewall">
          <div class="tire-marking">
            <span class="marking-part">P</span><span class="marking-part">225</span><span class="marking-part">/65</span><span class="marking-part">R</span><span class="marking-part">17</span> <span class="marking-part">102</span><span class="marking-part speed-rating-highlight">H</span>
          </div>
          <div class="arrow-indicator">
            <div class="arrow"></div>
            <span class="arrow-label">Speed Rating</span>
          </div>
        </div>
        
        <div class="marking-explanations">
          <div class="explanation-grid">
            <div class="explanation-item">
              <strong>P</strong> - Passenger vehicle
            </div>
            <div class="explanation-item">
              <strong>225</strong> - Tire width in mm
            </div>
            <div class="explanation-item">
              <strong>65</strong> - Aspect ratio (height/width)
            </div>
            <div class="explanation-item">
              <strong>R</strong> - Radial construction
            </div>
            <div class="explanation-item">
              <strong>17</strong> - Rim diameter in inches
            </div>
            <div class="explanation-item">
              <strong>102</strong> - Load index
            </div>
            <div class="explanation-item highlighted">
              <strong>H</strong> - Speed Rating (130 mph max)
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Speed Rating vs Load Index -->
    <section class="comparison-section">
      <h2>⚖️ Speed Rating vs Load Index</h2>
      <div class="comparison-grid">
        <div class="comparison-card">
          <h3>Speed Rating</h3>
          <ul>
            <li><strong>What it is:</strong> Maximum safe speed for the tire</li>
            <li><strong>Represented by:</strong> Letter (H, V, W, etc.)</li>
            <li><strong>Location:</strong> Last letter in tire size</li>
            <li><strong>Example:</strong> H = 130 mph maximum</li>
          </ul>
        </div>
        <div class="comparison-card">
          <h3>Load Index</h3>
          <ul>
            <li><strong>What it is:</strong> Maximum weight per tire</li>
            <li><strong>Represented by:</strong> Number (87, 91, 102, etc.)</li>
            <li><strong>Location:</strong> Before the speed rating letter</li>
            <li><strong>Example:</strong> 102 = 1,874 lbs maximum</li>
          </ul>
        </div>
      </div>
      <div class="important-note">
        <strong>⚠️ Critical:</strong> Both speed rating and load index must match or exceed your vehicle's OEM specifications for safety and warranty coverage.
      </div>
    </section>

    <!-- Can You Mix Speed Ratings -->
    <section class="mixing-section">
      <h2>🚫 Can You Mix Speed Ratings?</h2>
      <div class="safety-guidelines">
        <div class="guideline-item danger">
          <h3>❌ Never Do This</h3>
          <p>Mix different speed ratings on the same axle (front or rear)</p>
        </div>
        
        <div class="guideline-item warning">
          <h3>⚠️ If You Must Mix</h3>
          <ul>
            <li>Put lower-rated tires on the rear axle</li>
            <li>Your vehicle's speed is limited by the lowest-rated tire</li>
            <li>Replace mismatched tires as soon as possible</li>
          </ul>
        </div>
        
        <div class="guideline-item info">
          <h3>🛡️ Insurance Implications</h3>
          <p>Using tires with lower speed ratings than OEM specs may void warranty coverage and affect insurance claims in speed-related accidents.</p>
        </div>
      </div>
    </section>

    <!-- Speed Ratings for Different Conditions -->
    <section class="conditions-section">
      <h2>🌦️ Speed Ratings for Different Conditions</h2>
      <div class="conditions-grid">
        <div class="condition-card">
          <h3>❄️ Winter Tires</h3>
          <p><strong>Common rating:</strong> Q-rated (99 mph)</p>
          <p>This is perfectly fine for winter driving. The trade-off in maximum speed allows for better cold-weather performance.</p>
        </div>
        
        <div class="condition-card">
          <h3>🌤️ All-Season Tires</h3>
          <p><strong>Common ratings:</strong> S or T rated</p>
          <p>S = 112 mph, T = 118 mph. Suitable for most daily driving and highway speeds.</p>
        </div>
        
        <div class="condition-card">
          <h3>🏁 Performance Summer</h3>
          <p><strong>Common ratings:</strong> V, W, or Y rated</p>
          <p>V = 149 mph, W = 168 mph, Y = 186 mph. For sports cars and high-performance driving.</p>
        </div>
        
        <div class="condition-card">
          <h3>🛞 Run-Flat Tires</h3>
          <p><strong>Speed ratings:</strong> Same system applies</p>
          <p>Run-flat technology doesn't change the speed rating system - the same letters and speeds apply.</p>
        </div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="related-tools">
      <h2>🔗 Related Tools</h2>
      <div class="tools-grid">
        <a href="/best-tire-brands" class="tool-card">
          <h3>Best Tire Brands</h3>
          <p>Compare top tire manufacturers and find the best brand for your needs</p>
        </a>
        <a href="/tire-sidewall-guide" class="tool-card">
          <h3>Tire Sidewall Guide</h3>
          <p>Learn to decode all the numbers and letters on your tire sidewall</p>
        </a>
        <a href="/car-maintenance-schedule" class="tool-card">
          <h3>Car Maintenance Schedule</h3>
          <p>Complete vehicle maintenance timeline and checklist</p>
        </a>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <h2>❓ Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What does H mean on a tire?</summary>
          <p>The letter "H" is a speed rating that indicates the tire is safe for speeds up to 130 mph (210 km/h). It's commonly found on sport sedans and coupes.</p>
        </details>

        <details class="faq-item">
          <summary>What speed rating do I need?</summary>
          <p>You need at least the speed rating specified by your vehicle manufacturer (found in owner's manual or door jamb sticker). You can use a higher rating, but never lower.</p>
        </details>

        <details class="faq-item">
          <summary>Can I use a higher speed rating tire?</summary>
          <p>Yes, you can always use tires with a higher speed rating than required. This may provide better handling and stability, though it might affect ride comfort slightly.</p>
        </details>

        <details class="faq-item">
          <summary>What is the difference between V and W rated tires?</summary>
          <p>V-rated tires are safe up to 149 mph, while W-rated tires can handle up to 168 mph. W-rated tires typically offer better high-speed stability and performance handling.</p>
        </details>

        <details class="faq-item">
          <summary>Does speed rating affect ride comfort?</summary>
          <p>Higher speed ratings often mean stiffer sidewalls for stability, which can result in a firmer, less comfortable ride. The trade-off is improved handling and high-speed performance.</p>
        </details>

        <details class="faq-item">
          <summary>What speed rating is best for highway driving?</summary>
          <p>For regular highway driving, S-rated (112 mph) or T-rated (118 mph) tires are perfectly adequate and offer good comfort. H-rated (130 mph) is common for sportier vehicles.</p>
        </details>
      </div>
    </section>
  </div>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does H mean on a tire?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The letter 'H' is a speed rating that indicates the tire is safe for speeds up to 130 mph (210 km/h). It's commonly found on sport sedans and coupes."
        }
      },
      {
        "@type": "Question",
        "name": "What speed rating do I need?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You need at least the speed rating specified by your vehicle manufacturer (found in owner's manual or door jamb sticker). You can use a higher rating, but never lower."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use a higher speed rating tire?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, you can always use tires with a higher speed rating than required. This may provide better handling and stability, though it might affect ride comfort slightly."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Tire Speed Rating Chart - Complete Guide & Lookup Tool",
    "description": "Complete tire speed rating reference chart with interactive lookup. Learn what speed rating letters mean, max speeds in mph/km/h, and safety guidelines.",
    "author": {
      "@type": "Organization",
      "name": "Please Start Please"
    },
    "datePublished": "2024-03-28",
    "dateModified": "2024-03-28",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://pleasestartplease.com/tire-speed-rating-chart"
    }
  }
  </script>
</SiteLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
    background: #060a12;
    color: white;
    min-height: 100vh;
  }

  .page-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .page-header h1 {
    font-size: 3rem;
    color: #EF4444;
    margin-bottom: 10px;
    font-family: 'JetBrains Mono', monospace;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #94a3b8;
    margin: 0;
  }

  section {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 30px;
    margin-bottom: 30px;
  }

  section h2 {
    color: #EF4444;
    font-size: 1.8rem;
    margin-bottom: 20px;
    font-family: 'JetBrains Mono', monospace;
  }

  /* Lookup Tool Styles */
  .lookup-container {
    max-width: 600px;
  }

  .input-group {
    margin-bottom: 20px;
  }

  .input-group label {
    display: block;
    margin-bottom: 8px;
    color: #e2e8f0;
    font-weight: 500;
  }

  .rating-select {
    width: 100%;
    padding: 12px 16px;
    background: #152040;
    border: 2px solid #1e293b;
    border-radius: 8px;
    color: white;
    font-size: 16px;
    font-family: 'JetBrains Mono', monospace;
  }

  .rating-select:focus {
    outline: none;
    border-color: #EF4444;
  }

  .lookup-result {
    margin-top: 20px;
  }

  .lookup-result.hidden {
    display: none;
  }

  .result-card {
    background: #152040;
    padding: 24px;
    border-radius: 12px;
    border: 2px solid #EF4444;
  }

  .rating-letter {
    font-size: 3rem;
    color: #EF4444;
    text-align: center;
    margin-bottom: 16px;
    font-family: 'JetBrains Mono', monospace;
  }

  .speed-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
    text-align: center;
  }

  .speed-mph, .speed-kmh {
    background: #0a1020;
    padding: 12px;
    border-radius: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
  }

  .vehicle-types {
    background: #0a1020;
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 12px;
    text-align: center;
    font-weight: 500;
  }

  .description {
    color: #94a3b8;
    text-align: center;
    font-style: italic;
  }

  /* Table Styles */
  .table-container {
    overflow-x: auto;
  }

  .rating-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .rating-table th {
    background: #152040;
    color: #EF4444;
    padding: 16px 12px;
    text-align: left;
    border-bottom: 2px solid #EF4444;
    font-family: 'JetBrains Mono', monospace;
  }

  .rating-table td {
    padding: 12px;
    border-bottom: 1px solid #152040;
  }

  .rating-table tr:hover {
    background: #152040;
  }

  .rating-cell {
    font-family: 'JetBrains Mono', monospace;
    font-weight: bold;
    color: #EF4444;
    font-size: 1.1rem;
  }

  .speed-cell {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
  }

  /* Tire Diagram Styles */
  .tire-diagram {
    max-width: 800px;
    margin: 0 auto;
  }

  .tire-sidewall {
    background: #152040;
    padding: 30px;
    border-radius: 12px;
    text-align: center;
    margin-bottom: 30px;
    position: relative;
  }

  .tire-marking {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 20px;
  }

  .marking-part {
    margin: 0 4px;
  }

  .speed-rating-highlight {
    background: #EF4444;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .arrow-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 20px;
  }

  .arrow {
    width: 0;
    height: 0;
    border-left: 15px solid transparent;
    border-right: 15px solid transparent;
    border-top: 20px solid #EF4444;
    margin-bottom: 8px;
  }

  .arrow-label {
    color: #EF4444;
    font-weight: bold;
    font-family: 'JetBrains Mono', monospace;
  }

  .explanation-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .explanation-item {
    background: #152040;
    padding: 16px;
    border-radius: 8px;
    text-align: center;
  }

  .explanation-item.highlighted {
    border: 2px solid #EF4444;
  }

  /* Comparison Styles */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 20px;
  }

  .comparison-card {
    background: #152040;
    padding: 24px;
    border-radius: 12px;
  }

  .comparison-card h3 {
    color: #EF4444;
    margin-bottom: 16px;
    font-family: 'JetBrains Mono', monospace;
  }

  .comparison-card ul {
    list-style: none;
    padding: 0;
  }

  .comparison-card li {
    margin-bottom: 12px;
    padding-left: 16px;
    position: relative;
  }

  .comparison-card li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #EF4444;
  }

  .important-note {
    background: #EF4444;
    color: white;
    padding: 16px;
    border-radius: 8px;
    text-align: center;
    font-weight: 500;
  }

  /* Safety Guidelines */
  .safety-guidelines {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }

  .guideline-item {
    padding: 20px;
    border-radius: 12px;
    border: 2px solid;
  }

  .guideline-item.danger {
    border-color: #dc2626;
    background: rgba(220, 38, 38, 0.1);
  }

  .guideline-item.warning {
    border-color: #f59e0b;
    background: rgba(245, 158, 11, 0.1);
  }

  .guideline-item.info {
    border-color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .guideline-item h3 {
    margin-bottom: 12px;
    font-size: 1.2rem;
  }

  .guideline-item ul {
    list-style: none;
    padding: 0;
  }

  .guideline-item li {
    margin-bottom: 8px;
    padding-left: 16px;
    position: relative;
  }

  .guideline-item li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: #EF4444;
  }

  /* Conditions Grid */
  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .condition-card {
    background: #152040;
    padding: 20px;
    border-radius: 12px;
    border-left: 4px solid #EF4444;
  }

  .condition-card h3 {
    color: #EF4444;
    margin-bottom: 12px;
  }

  /* Related Tools */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }

  .tool-card {
    display: block;
    background: #152040;
    padding: 24px;
    border-radius: 12px;
    border: 2px solid #152040;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
  }

  .tool-card:hover {
    border-color: #EF4444;
    transform: translateY(-2px);
  }

  .tool-card h3 {
    color: #EF4444;
    margin-bottom: 12px;
    font-family: 'JetBrains Mono', monospace;
  }

  .tool-card p {
    color: #94a3b8;
    margin: 0;
  }

  /* FAQ Styles */
  .faq-list {
    space-y: 16px;
  }

  .faq-item {
    background: #152040;
    border-radius: 8px;
    margin-bottom: 16px;
  }

  .faq-item summary {
    padding: 20px;
    cursor: pointer;
    font-weight: 500;
    color: #EF4444;
    border-radius: 8px;
    list-style: none;
  }

  .faq-item summary::marker {
    display: none;
  }

  .faq-item summary::before {
    content: "+";
    float: right;
    font-size: 1.2rem;
    font-weight: bold;
    font-family: 'JetBrains Mono', monospace;
  }

  .faq-item[open] summary::before {
    content: "−";
  }

  .faq-item p {
    padding: 0 20px 20px;
    margin: 0;
    color: #e2e8f0;
    line-height: 1.6;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .container {
      padding: 16px;
    }

    .page-header h1 {
      font-size: 2rem;
    }

    .comparison-grid {
      grid-template-columns: 1fr;
    }

    .tire-marking {
      font-size: 1.5rem;
    }

    .rating-table {
      font-size: 0.85rem;
    }

    .rating-table th,
    .rating-table td {
      padding: 8px 6px;
    }
  }
</style>

<script is:inline>
  const speedRatings = {
    'L': {
      mph: '75',
      kmh: '120',
      vehicles: 'Off-road vehicles, light trucks',
      description: 'Designed for off-road and light truck applications where high speeds are not required.'
    },
    'M': {
      mph: '81',
