      kmh: '170',
      vehicles: 'Heavy-duty light trucks',
      description: 'Used on light trucks and SUVs where load capacity is important.'
    },
    'S': {
      mph: '112',
      kmh: '180',
      vehicles: 'Family sedans, minivans',
      description: 'Standard rating for family vehicles, suitable for highway driving.'
    },
    'T': {
      mph: '118',
      kmh: '190',
      vehicles: 'Family sedans, minivans',
      description: 'Popular rating for passenger cars, offering good speed capability for daily driving.'
    },
    'U': {
      mph: '124',
