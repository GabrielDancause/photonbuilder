    },
    'Z': {
      mph: '149+',
      kmh: '240+',
      vehicles: 'High-performance sports cars',
      description: 'Indicates speed capability above 149 mph. Actual limit determined by tire manufacturer.'
    }
  };

  document.getElementById('speedRating').addEventListener('change', function() {
    const rating = this.value;
    const resultDiv = document.getElementById('lookupResult');
    
    if (!rating) {
      resultDiv.classList.add('hidden');
      return;
    }
    
    const data = speedRatings[rating];
    if (data) {
      document.querySelector('.rating-letter').textContent = rating;
      document.querySelector('.speed-mph').textContent = `${data.mph} mph`;
      document.querySelector('.speed-kmh').textContent = `${data.kmh} km/h`;
      document.querySelector('.vehicle-types').textContent = data.vehicles;
      document.querySelector('.description').textContent = data.description;
      
      resultDiv.classList.remove('hidden');
    }
  });
</script>