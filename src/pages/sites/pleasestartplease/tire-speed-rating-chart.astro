      vehicles: 'Temporary spare tires',
      description: 'Commonly used for temporary spare tires. Not intended for regular driving.'
    },
    'N': {
      mph: '87',
      kmh: '140',
      vehicles: 'Temporary spare tires',
      description: 'Another common rating for temporary spare tires with slightly higher speed capability.'
    },
    'P': {
      mph: '93',
      kmh: '150',
      vehicles: 'Sedans, station wagons',
      description: 'Basic passenger car rating suitable for moderate highway driving.'
    },
    'Q': {
      mph: '99',
      kmh: '160',
      vehicles: 'Winter tires, SUVs',
      description: 'Common for winter tires where cold-weather performance is prioritized over top speed.'
    },
    'R': {
