    type: "Innerspring",
    firmness: "Plush Soft, Luxury Firm, Firm",
    trial: "365 nights",
    warranty: "Lifetime",
    priceRange: "$$$",
    bestPosition: "Back, Stomach, Combination",
    tempReg: "Excellent",
    edgeSupport: "Excellent"
  },
  {
