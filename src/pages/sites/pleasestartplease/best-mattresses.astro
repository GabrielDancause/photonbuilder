    tempReg: "Good",
    edgeSupport: "Good"
  },
  {
    name: "Bear",
    type: "Hybrid",
    firmness: "Medium-Firm",
    trial: "120 nights",
    warranty: "Lifetime",
    priceRange: "$$",
