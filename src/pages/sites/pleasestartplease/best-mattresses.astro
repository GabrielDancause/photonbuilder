    type: "Gel Grid / Hybrid",
    firmness: "Medium-Firm",
    trial: "100 nights",
    warranty: "10 years",
    priceRange: "$$$",
    bestPosition: "Back, Hot Sleepers",
    tempReg: "Outstanding",
    edgeSupport: "Good"
  },
  {
    name: "Casper",
    type: "Memory Foam / Hybrid",
    firmness: "Medium",
    trial: "100 nights",
    warranty: "10 years",
    priceRange: "$$",
