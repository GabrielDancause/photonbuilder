---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Torque Converter Guide | How It Works, Symptoms & Replacement Cost",
  description: "Complete guide to torque converters: how they work, common failure symptoms, diagnostic checklist, replacement costs by vehicle type, and torque multiplication calculator.",
  category: "tool",
  published: "2026-03-28",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Torque Converter: Complete Guide to How It Works, Failure Symptoms & Replacement Costs",
    "description": "Everything you need to know about torque converters — how they function in automatic transmissions, common problems, diagnostic symptoms, and what replacement costs to expect.",
    "author": { "@type": "Organization", "name": "PleaseStartPlease", "url": "https://pleasestartplease.photonbuilder.com" },
    "publisher": { "@type": "Organization", "name": "PleaseStartPlease", "url": "https://pleasestartplease.photonbuilder.com" },
    "datePublished": "2026-03-28",
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://pleasestartplease.photonbuilder.com/torque-converter" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What does a torque converter do?", "acceptedAnswer": { "@type": "Answer", "text": "A torque converter is a fluid coupling device that connects the engine to the automatic transmission. It transfers and multiplies engine torque to the transmission using hydraulic fluid (ATF), allowing the engine to spin independently of the transmission — which is why automatic cars can idle in gear without stalling. It replaces the clutch used in manual transmissions." } },
      { "@type": "Question", "name": "What are the symptoms of a bad torque converter?", "acceptedAnswer": { "@type": "Answer", "text": "Common symptoms include: shuddering or vibration at 30-45 mph (torque converter shudder), slipping (RPMs increase without corresponding acceleration), overheating transmission fluid, delayed or harsh engagement when shifting from Park to Drive, unusual whining or grinding noises, and decreased fuel economy. A check engine light with codes P0740-P0744 often indicates torque converter issues." } },
      { "@type": "Question", "name": "How much does it cost to replace a torque converter?", "acceptedAnswer": { "@type": "Answer", "text": "Torque converter replacement typically costs $600-$1,200 for the part and $500-$1,000 for labor, totaling $1,100-$2,200 for most vehicles. Luxury vehicles and trucks can cost $2,000-$3,500+. The high labor cost is because the transmission must be removed to access the torque converter. Some shops recommend replacing the entire transmission if the converter fails catastrophically." } },
      { "@type": "Question", "name": "Can you drive with a bad torque converter?", "acceptedAnswer": { "@type": "Answer", "text": "You can drive short distances with a failing torque converter, but it's not recommended. A bad converter can cause transmission overheating, which damages other transmission components and turns a $1,500 repair into a $4,000+ transmission rebuild. If you notice shuddering, slipping, or overheating, have it diagnosed promptly." } },
      { "@type": "Question", "name": "How long does a torque converter last?", "acceptedAnswer": { "@type": "Answer", "text": "A torque converter typically lasts the lifetime of the transmission — roughly 150,000-200,000 miles with proper maintenance. Regular transmission fluid changes (every 30,000-60,000 miles) are the single most important factor in torque converter longevity. Towing, aggressive driving, and overheating significantly reduce lifespan." } }
    ]
  }
];
---

<SiteLayout title={meta.title} description={meta.description} site="pleasestartplease">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <style>
    .tc-container { max-width: 900px; margin: 0 auto; padding: 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #c8d6e5; }
    h1 { font-size: 2rem; color: #f1f5f9; text-align: center; margin-bottom: 8px; }
    .subtitle { text-align: center; color: #64748b; margin-bottom: 28px; font-size: 1.05rem; }
    h2 { font-size: 1.4rem; color: #e2e8f0; margin: 40px 0 16px; border-bottom: 1px solid #152040; padding-bottom: 8px; }
    h3 { font-size: 1.15rem; color: #cbd5e1; margin: 24px 0 12px; }
    p { color: #94a3b8; line-height: 1.7; }

    .card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 24px; margin-bottom: 20px; }

    /* Diagnostic Tool */
    .diag-section { margin: 20px 0; }
    .symptom-check { display: flex; flex-direction: column; gap: 8px; }
    .symptom-item { display: flex; align-items: flex-start; gap: 12px; padding: 12px 16px; background: #060a12; border: 1px solid #152040; border-radius: 10px; cursor: pointer; transition: all 0.2s; }
    .symptom-item:hover { border-color: #EF4444; }
    .symptom-item.checked { border-color: #EF4444; background: rgba(239,68,68,0.06); }
    .symptom-item input[type="checkbox"] { accent-color: #EF4444; margin-top: 3px; flex-shrink: 0; }
    .symptom-label { font-weight: 500; color: #e2e8f0; }
    .symptom-desc { font-size: 0.85rem; color: #64748b; margin-top: 2px; }

    .diag-result { margin-top: 20px; padding: 20px; border-radius: 10px; display: none; }
    .diag-result.show { display: block; }
    .diag-low { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); }
    .diag-med { background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.3); }
    .diag-high { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); }
    .diag-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
    .diag-low .diag-title { color: #4ade80; }
    .diag-med .diag-title { color: #fbbf24; }
    .diag-high .diag-title { color: #f87171; }
    .diag-text { color: #c8d6e5; font-size: 0.95rem; line-height: 1.6; }

    /* Cost Table */
    .cost-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin: 16px 0; }
    .cost-table th { background: #0f1b30; color: #94a3b8; padding: 12px 16px; text-align: left; font-weight: 600; border-bottom: 1px solid #152040; }
    .cost-table td { padding: 12px 16px; border-bottom: 1px solid #0f1629; color: #c8d6e5; }
    .cost-table tr:hover td { background: rgba(239,68,68,0.04); }
    .cost-range { font-family: 'JetBrains Mono', monospace; color: #EF4444; font-weight: 600; }

    /* How it works visual */
    .parts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin: 16px 0; }
    .part-card { background: #060a12; border: 1px solid #152040; border-radius: 10px; padding: 20px; text-align: center; }
    .part-icon { font-size: 2rem; margin-bottom: 8px; }
    .part-card h4 { color: #e2e8f0; margin: 0 0 8px; }
    .part-card p { color: #94a3b8; font-size: 0.85rem; margin: 0; line-height: 1.5; }

    /* Calculator */
    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 600px) { .calc-grid { grid-template-columns: 1fr; } }
    .field label { display: block; font-size: 0.85rem; color: #94a3b8; margin-bottom: 6px; }
    .field input, .field select { width: 100%; padding: 10px 14px; background: #060a12; border: 1px solid #152040; border-radius: 8px; color: #f1f5f9; font-size: 1rem; box-sizing: border-box; }
    .field input:focus, .field select:focus { outline: none; border-color: #EF4444; }
    .calc-output { margin-top: 16px; padding: 16px; background: #060a12; border-radius: 10px; border: 1px solid #152040; }
    .calc-big { font-size: 1.6rem; font-weight: 800; color: #EF4444; font-family: 'JetBrains Mono', monospace; }
    .calc-detail { color: #94a3b8; font-size: 0.9rem; margin-top: 8px; line-height: 1.6; }

    /* OBD codes */
    .code-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; margin: 16px 0; }
    .code-item { background: #060a12; border: 1px solid #152040; border-radius: 8px; padding: 14px; }
    .code-label { font-family: 'JetBrains Mono', monospace; color: #EF4444; font-weight: 700; font-size: 0.95rem; }
    .code-desc { color: #94a3b8; font-size: 0.85rem; margin-top: 4px; }

    .faq-section { margin-top: 40px; }
    .faq-item { border: 1px solid #152040; border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
    .faq-q { padding: 16px 20px; background: #0a1020; cursor: pointer; display: flex; justify-content: space-between; align-items: center; color: #e2e8f0; font-weight: 500; }
    .faq-q:hover { background: #0f1629; }
    .faq-arrow { transition: transform 0.2s; color: #EF4444; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }
    .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.3s, padding 0.3s; }
    .faq-item.open .faq-a { max-height: 400px; padding: 16px 20px; }
    .faq-a p { color: #94a3b8; line-height: 1.7; margin: 0; }
  </style>

  <div class="tc-container">
    <h1>Torque Converter</h1>
    <p class="subtitle">Complete guide — how it works, failure symptoms, diagnostic checklist, and replacement costs</p>

    <!-- How it Works -->
    <h2>How a Torque Converter Works</h2>
    <p>A torque converter is a donut-shaped fluid coupling between the engine and automatic transmission. Instead of a clutch (used in manual transmissions), it uses hydraulic pressure from transmission fluid (ATF) to transfer power. This is what allows an automatic car to idle in gear without stalling — the fluid coupling absorbs the difference between engine speed and wheel speed.</p>

    <div class="parts-grid">
      <div class="part-card">
        <div class="part-icon">🔄</div>
        <h4>Impeller (Pump)</h4>
        <p>Connected to the engine crankshaft. Spins with the engine and flings ATF outward using centrifugal force, creating fluid flow.</p>
      </div>
      <div class="part-card">
        <div class="part-icon">⚙️</div>
        <h4>Turbine</h4>
        <p>Connected to the transmission input shaft. Catches the fluid thrown by the impeller and converts it back into rotational force to drive the transmission.</p>
      </div>
      <div class="part-card">
        <div class="part-icon">🔀</div>
        <h4>Stator</h4>
        <p>Sits between impeller and turbine. Redirects returning fluid to boost efficiency, creating torque multiplication (up to 2:1 at stall).</p>
      </div>
      <div class="part-card">
        <div class="part-icon">🔒</div>
        <h4>Lock-Up Clutch</h4>
        <p>Mechanically locks turbine to impeller at highway speeds, eliminating fluid slip for better fuel economy. Engages around 40-50 mph.</p>
      </div>
    </div>

    <p>At low speeds, the converter multiplies torque — the turbine receives more torque than the engine produces, giving automatic cars their characteristic smooth launch. At highway speeds, the lock-up clutch creates a direct 1:1 connection for maximum efficiency.</p>

    <!-- Symptom Diagnostic Tool -->
    <h2>Torque Converter Symptom Checker</h2>
    <p>Check the symptoms you're experiencing. The tool will assess the likelihood of a torque converter problem.</p>

    <div class="card">
      <div class="symptom-check" id="symptomCheck">
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">Shuddering / vibration at 30-45 mph</div><div class="symptom-desc">Feels like driving over rumble strips, especially light acceleration at highway on-ramps</div></div>
        </label>
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">RPMs rise without acceleration (slipping)</div><div class="symptom-desc">Engine revs higher but the car doesn't speed up proportionally — like a slipping clutch</div></div>
        </label>
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">Delayed engagement (Park → Drive)</div><div class="symptom-desc">Noticeable 2-3 second delay when shifting from Park or Neutral into Drive or Reverse</div></div>
        </label>
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">Transmission overheating</div><div class="symptom-desc">Transmission temp warning light, burning smell from ATF, or temp gauge reading above 200°F</div></div>
        </label>
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">Whining or grinding noise in gear</div><div class="symptom-desc">Unusual noise that changes with engine RPM but not vehicle speed — often louder in Drive than Park</div></div>
        </label>
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">Decreased fuel economy</div><div class="symptom-desc">Noticeable drop in MPG without other changes — converter slip wastes energy as heat</div></div>
        </label>
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">Check engine light (P0740-P0744)</div><div class="symptom-desc">OBD-II codes specifically related to torque converter clutch circuit or performance</div></div>
        </label>
        <label class="symptom-item" onclick="this.querySelector('input').click(); updateDiag();">
          <input type="checkbox" onchange="updateDiag()">
          <div><div class="symptom-label">Stalling at idle when in gear</div><div class="symptom-desc">Engine dies when stopped in Drive or Reverse but runs fine in Park/Neutral</div></div>
        </label>
      </div>

      <div class="diag-result" id="diagResult"></div>
    </div>

    <!-- Replacement Cost -->
    <h2>Torque Converter Replacement Cost</h2>
    <p>Replacing a torque converter is labor-intensive because the transmission must be removed to access it. Here's what to expect by vehicle type:</p>

    <table class="cost-table">
      <thead><tr><th>Vehicle Type</th><th>Part Cost</th><th>Labor Cost</th><th>Total Estimate</th></tr></thead>
      <tbody>
        <tr><td>Economy sedan (Civic, Corolla)</td><td>$150–$350</td><td>$500–$800</td><td class="cost-range">$650–$1,150</td></tr>
        <tr><td>Mid-size sedan (Camry, Accord)</td><td>$200–$400</td><td>$600–$900</td><td class="cost-range">$800–$1,300</td></tr>
        <tr><td>SUV (RAV4, CR-V, Explorer)</td><td>$250–$500</td><td>$700–$1,100</td><td class="cost-range">$950–$1,600</td></tr>
        <tr><td>Full-size truck (F-150, Silverado)</td><td>$300–$600</td><td>$800–$1,200</td><td class="cost-range">$1,100–$1,800</td></tr>
        <tr><td>Luxury (BMW, Mercedes, Audi)</td><td>$500–$1,000</td><td>$1,000–$1,500</td><td class="cost-range">$1,500–$2,500</td></tr>
        <tr><td>Heavy-duty truck (F-250, 2500HD)</td><td>$600–$1,200</td><td>$1,200–$1,800</td><td class="cost-range">$1,800–$3,000</td></tr>
      </tbody>
    </table>

    <p><strong>Pro tip:</strong> If the converter failed catastrophically (metal debris in the fluid), expect to also flush or replace the transmission cooler and cooler lines. Contaminated fluid will destroy a new converter quickly. Budget an extra $200-$400 for a full system flush.</p>

    <!-- OBD Codes -->
    <h2>Torque Converter OBD-II Trouble Codes</h2>
    <div class="code-list">
      <div class="code-item"><div class="code-label">P0740</div><div class="code-desc">Torque Converter Clutch Circuit Malfunction — TCC solenoid circuit issue</div></div>
      <div class="code-item"><div class="code-label">P0741</div><div class="code-desc">Torque Converter Clutch Circuit Performance/Stuck Off — clutch not engaging</div></div>
      <div class="code-item"><div class="code-label">P0742</div><div class="code-desc">Torque Converter Clutch Circuit Stuck On — clutch won't disengage</div></div>
      <div class="code-item"><div class="code-label">P0743</div><div class="code-desc">Torque Converter Clutch Circuit Electrical — wiring or connector fault</div></div>
      <div class="code-item"><div class="code-label">P0744</div><div class="code-desc">Torque Converter Clutch Circuit Intermittent — inconsistent operation</div></div>
      <div class="code-item"><div class="code-label">P2769</div><div class="code-desc">Torque Converter Clutch Circuit Low — low signal from TCC solenoid</div></div>
      <div class="code-item"><div class="code-label">P2770</div><div class="code-desc">Torque Converter Clutch Circuit High — high signal from TCC solenoid</div></div>
      <div class="code-item"><div class="code-label">P0120</div><div class="code-desc">Throttle Position Sensor — can cause TCC-related symptoms (rule out first)</div></div>
    </table>

    <!-- Torque Multiplication Calculator -->
    <h2>Torque Multiplication Calculator</h2>
    <div class="calc-card card">
      <p style="margin-top:0;">Calculate the torque output at the transmission input shaft based on your engine torque and converter stall ratio.</p>
      <div class="calc-grid">
        <div class="field">
          <label>Engine Torque (lb-ft)</label>
          <input type="number" id="engineTorque" value="250" min="1" oninput="calcTorque()">
        </div>
        <div class="field">
          <label>Stall Ratio</label>
          <select id="stallRatio" onchange="calcTorque()">
            <option value="1.8">1.8:1 (Stock economy)</option>
            <option value="2.0" selected>2.0:1 (Stock standard)</option>
            <option value="2.2">2.2:1 (Stock performance)</option>
            <option value="2.5">2.5:1 (Performance converter)</option>
            <option value="2.8">2.8:1 (High-stall racing)</option>
            <option value="3.0">3.0:1 (Drag racing)</option>
          </select>
        </div>
      </div>
      <div class="calc-output">
        <div class="calc-big" id="torqueOutput">500 lb-ft</div>
        <div class="calc-detail" id="torqueDetail"></div>
      </div>
    </div>

    <!-- Maintenance -->
    <h2>How to Make Your Torque Converter Last</h2>
    <div class="parts-grid">
      <div class="part-card">
        <div class="part-icon">🛢️</div>
        <h4>Change ATF Regularly</h4>
        <p>Every 30,000-60,000 miles. Fresh fluid prevents varnish buildup and keeps the lock-up clutch functioning properly. Use manufacturer-specified fluid only.</p>
      </div>
      <div class="part-card">
        <div class="part-icon">🌡️</div>
        <h4>Avoid Overheating</h4>
        <p>Add a transmission cooler if you tow. ATF above 240°F degrades rapidly. Every 20°F above normal halves fluid life.</p>
      </div>
      <div class="part-card">
        <div class="part-icon">⏳</div>
        <h4>Don't Ride the Brakes</h4>
        <p>Holding the brake in Drive at a stop for extended periods generates heat in the converter. Shift to Neutral at long stops.</p>
      </div>
      <div class="part-card">
        <div class="part-icon">🏋️</div>
        <h4>Respect Tow Ratings</h4>
        <p>Exceeding your vehicle's tow rating puts extreme stress on the torque converter. Stay within ratings and use Tow/Haul mode when available.</p>
      </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">What does a torque converter do? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>A torque converter connects the engine to the automatic transmission using hydraulic fluid. It transfers and multiplies engine torque, allows the engine to idle in gear without stalling, and provides smooth power delivery. It replaces the clutch used in manual transmissions.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">What are the symptoms of a bad torque converter? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>Common symptoms include shuddering at 30-45 mph, slipping (RPMs rise without acceleration), delayed engagement from Park to Drive, transmission overheating, whining/grinding noises, decreased fuel economy, and check engine codes P0740-P0744.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">How much does it cost to replace a torque converter? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>Typically $600-$1,200 for the part plus $500-$1,000 for labor, totaling $1,100-$2,200 for most vehicles. Luxury vehicles and trucks can run $2,000-$3,500+. The transmission must be removed for access, which drives the labor cost.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">Can you drive with a bad torque converter? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>Short distances, yes, but it's risky. A failing converter overheats the transmission fluid, which can damage other components and escalate a $1,500 repair into a $4,000+ transmission rebuild. Get it diagnosed promptly if you notice symptoms.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">How long does a torque converter last? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>Typically 150,000-200,000 miles with proper maintenance. Regular ATF changes are the most important factor. Towing, aggressive driving, and overheating reduce lifespan significantly.</p></div>
      </div>
    </div>
  </div>

  <script is:inline>
    function updateDiag() {
      setTimeout(() => {
        const checks = document.querySelectorAll('#symptomCheck input[type=checkbox]');
        let count = 0;
        checks.forEach(c => {
          const item = c.closest('.symptom-item');
          if (c.checked) { count++; item.classList.add('checked'); }
          else { item.classList.remove('checked'); }
        });

        const result = document.getElementById('diagResult');
        if (count === 0) { result.classList.remove('show'); return; }

        result.classList.add('show');
        result.className = 'diag-result show';

        if (count <= 2) {
          result.classList.add('diag-low');
          result.innerHTML = `<div class="diag-title">⚠️ Possible Issue (${count}/8 symptoms)</div>
            <div class="diag-text">A couple of symptoms could indicate an early torque converter problem, but they could also be caused by low ATF level, dirty fluid, or other transmission issues. <strong>Start with:</strong> Check ATF level and condition. Dark/burnt-smelling fluid suggests a problem. If fluid is clean and full, monitor for worsening symptoms.</div>`;
        } else if (count <= 4) {
          result.classList.add('diag-med');
          result.innerHTML = `<div class="diag-title">🔶 Likely Torque Converter Problem (${count}/8 symptoms)</div>
            <div class="diag-text">Multiple matching symptoms suggest a torque converter issue. <strong>Recommended:</strong> Have a transmission shop perform a diagnostic scan and stall test. A stall test measures the converter's ability to multiply torque and can confirm a failing converter. Don't ignore this — continued driving risks transmission damage.</div>`;
        } else {
          result.classList.add('diag-high');
          result.innerHTML = `<div class="diag-title">🔴 Strong Torque Converter Failure Indication (${count}/8 symptoms)</div>
            <div class="diag-text">This symptom pattern is highly consistent with a failing or failed torque converter. <strong>Action needed:</strong> Minimize driving and get a professional diagnosis immediately. With this many symptoms, there's a risk of secondary transmission damage if the converter has shed debris into the fluid. Request a fluid sample analysis as part of the diagnosis.</div>`;
        }
      }, 50);
    }

    function calcTorque() {
      const engine = parseFloat(document.getElementById('engineTorque').value) || 0;
      const ratio = parseFloat(document.getElementById('stallRatio').value) || 2.0;
      const output = engine * ratio;
      document.getElementById('torqueOutput').textContent = `${Math.round(output)} lb-ft at stall`;
      document.getElementById('torqueDetail').innerHTML = `
        <strong>Engine torque:</strong> ${engine} lb-ft<br>
        <strong>Stall ratio:</strong> ${ratio}:1<br>
        <strong>Output torque:</strong> ${engine} × ${ratio} = ${Math.round(output)} lb-ft<br>
        <br>
        <em>Note: Torque multiplication is highest at stall (vehicle stationary, engine at full throttle) and decreases to 1:1 when the converter reaches "coupling speed" (typically 60-90% of engine RPM). At highway cruising with the lock-up clutch engaged, the ratio is exactly 1:1.</em>
      `;
    }
    calcTorque();
  </script>
</SiteLayout>
