    connection: "WiFi",
    sleepTracking: "Yes (Analytics)",
    alerts: "Face Covered/Rollover",
    audio: "Two-Way",
    nightVision: "Excellent",
    appQuality: "Excellent"
  },
  {
    name: "Miku Pro",
    price: "$399",
    videoQuality: "1080p HD",
    connection: "WiFi",
    sleepTracking: "Yes",
    alerts: "Contact-free Breathing",
    audio: "Two-Way",
    nightVision: "Excellent",
