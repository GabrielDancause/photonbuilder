          '</div>';
      }
      html += '<button id="quiz-restart" style="margin-top:1rem;padding:0.5rem 1.2rem;border-radius:8px;border:1px solid var(--border-color);background:transparent;color:var(--text-color);cursor:pointer;">↻ Retake Quiz</button>';
      stepEl.innerHTML = html;
      document.getElementById("quiz-restart").addEventListener("click", function() {
        answers = [];
        renderQuestion(0);
      });
    }

    renderQuestion(0);

    /* ============ EMISSIONS CALCULATOR ============ */
    var stateData = {
      "Alabama":{req:false},"Alaska":{req:false},"Arizona":{req:true,cost:17,areas:"Phoenix and Tucson metro areas"},"Arkansas":{req:false},"California":{req:true,cost:50,areas:"Statewide (smog check)"},"Colorado":{req:true,cost:25,areas:"Denver metro, North Front Range"},"Connecticut":{req:true,cost:20,areas:"Statewide"},"Delaware":{req:true,cost:20,areas:"New Castle and Kent counties"},"Florida":{req:false},"Georgia":{req:true,cost:25,areas:"Metro Atlanta (13 counties)"},"Hawaii":{req:true,cost:12,areas:"Statewide (safety + emissions)"},"Idaho":{req:true,cost:15,areas:"Ada and Canyon counties"},"Illinois":{req:true,cost:20,areas:"Chicago metro area"},"Indiana":{req:true,cost:15,areas:"Lake and Porter counties"},"Iowa":{req:false},"Kansas":{req:false},"Kentucky":{req:false},"Louisiana":{req:true,cost:10,areas:"Certain parishes"},"Maine":{req:true,cost:15,areas:"Cumberland County"},"Maryland":{req:true,cost:14,areas:"Statewide"},"Massachusetts":{req:true,cost:35,areas:"Statewide"},"Michigan":{req:false},"Minnesota":{req:false},"Mississippi":{req:false},"Missouri":{req:true,cost:24,areas:"St. Louis and Kansas City metro"},"Montana":{req:false},"Nebraska":{req:false},"Nevada":{req:true,cost:16,areas:"Clark and Washoe counties"},"New Hampshire":{req:true,cost:10,areas:"Statewide (OBD-II)"},"New Jersey":{req:true,cost:0,areas:"Statewide (free at state stations)"},"New Mexico":{req:true,cost:15,areas:"Bernalillo County"},"New York":{req:true,cost:37,areas:"Statewide"},"North Carolina":{req:true,cost:30,areas:"Statewide"},"North Dakota":{req:false},"Ohio":{req:true,cost:19,areas:"Cleveland, Columbus, Cincinnati metro (E-Check)"},"Oklahoma":{req:false},"Oregon":{req:true,cost:25,areas:"Portland metro, Medford"},"Pennsylvania":{req:true,cost:35,areas:"Statewide"},"Rhode Island":{req:true,cost:45,areas:"Statewide"},"South Carolina":{req:false},"South Dakota":{req:false},"Tennessee":{req:true,cost:9,areas:"Davidson, Hamilton, Rutherford, Sumner, Williamson, Wilson counties"},"Texas":{req:true,cost:25,areas:"Statewide (state inspection + emissions in certain counties)"},"Utah":{req:true,cost:20,areas:"Salt Lake, Davis, Utah, Weber counties"},"Vermont":{req:true,cost:15,areas:"Statewide"},"Virginia":{req:true,cost:28,areas:"Northern Virginia and Hampton Roads"},"Washington":{req:false,note:"Ended emissions testing in 2020"},"West Virginia":{req:false},"Wisconsin":{req:true,cost:15,areas:"Southeastern counties"},"Wyoming":{req:false},"District of Columbia":{req:true,cost:35,areas:"District-wide"}
    };

    var sel = document.getElementById("calc-state");
    var states = Object.keys(stateData).sort();
    for (var s = 0; s < states.length; s++) {
      var opt = document.createElement("option");
      opt.value = states[s];
      opt.textContent = states[s];
      sel.appendChild(opt);
    }

    document.getElementById("calc-btn").addEventListener("click", function() {
      var st = sel.value;
      var yr = parseInt(document.getElementById("calc-year").value);
      var resEl = document.getElementById("calc-result");

      if (!st) { resEl.innerHTML = '<p style="color:#ef4444;">Please select a state.</p>'; return; }
      if (!yr || yr < 1975 || yr > 2026) { resEl.innerHTML = '<p style="color:#ef4444;">Please enter a valid vehicle year (1975–2026).</p>'; return; }

      var info = stateData[st];
      var html = '';

      if (!info.req) {
        html = '<div style="padding:1rem;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);border-radius:8px;">' +
          '<p style="font-weight:700;">✅ ' + st + ' does not require emissions testing.</p>' +
          (info.note ? '<p style="margin-top:0.5rem;opacity:0.8;font-size:0.9rem;">' + info.note + '</p>' : '') +
          '<p style="margin-top:0.5rem;">No test needed, but a catalytic converter cleaner can still improve fuel efficiency and reduce harmful emissions.</p></div>';
      } else {
        var currentYear = 2026;
        var vehicleAge = currentYear - yr;
        var exempt = vehicleAge <= 4;
        var costStr = info.cost === 0 ? "Free (state-run stations)" : "$" + info.cost;
        var cleanerHelp = "";

        if (vehicleAge <= 4) {
          cleanerHelp = "Your vehicle is likely exempt from testing due to its age. No action needed.";
        } else if (vehicleAge <= 10) {
          cleanerHelp = "A catalytic converter cleaner is a great low-cost step if you are concerned about passing. Newer vehicles respond well to cleaning treatments.";
        } else if (vehicleAge <= 18) {
          cleanerHelp = "Definitely consider running a cleaner 1–2 tanks before your test. Vehicles in this age range often have moderate carbon buildup that cleaners can address.";
        } else {
          cleanerHelp = "A cleaner may help with mild deposits, but vehicles over 18 years old may have significant converter wear. Consider a professional inspection if the cleaner doesn't improve performance.";
        }

        html = '<div style="padding:1rem;background:rgba(234,179,8,0.1);border:1px solid rgba(234,179,8,0.25);border-radius:8px;">' +
          '<p style="font-weight:700;">📋 ' + st + ' requires emissions testing</p>' +
          '<p style="margin-top:0.5rem;"><strong>Testing areas:</strong> ' + info.areas + '</p>' +
          '<p><strong>Estimated test cost:</strong> ' + costStr + '</p>' +
          '<p><strong>Vehicle age:</strong> ' + vehicleAge + ' years' + (exempt ? ' <span style="color:#22c55e;font-weight:600;">(likely exempt — most states exempt vehicles 4 years or newer)</span>' : '') + '</p>' +
          '<p style="margin-top:0.75rem;">' + cleanerHelp + '</p></div>';
      }
      resEl.innerHTML = html;
    });
  })();
  </script>
</SiteLayout>
