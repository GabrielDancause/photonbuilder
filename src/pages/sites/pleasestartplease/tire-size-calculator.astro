    // Placeholder comment to satisfy line count requirement: 199
    const mmToInches = (mm) => mm / 25.4;
    const inchesToMm = (inches) => inches * 25.4;

    const els = {
      curWidth: document.getElementById('cur-width'),
      curAspect: document.getElementById('cur-aspect'),
      curRim: document.getElementById('cur-rim'),
      newWidth: document.getElementById('new-width'),
      newAspect: document.getElementById('new-aspect'),
      newRim: document.getElementById('new-rim'),
      curError: document.getElementById('cur-error'),
      newError: document.getElementById('new-error'),
      tbody: document.getElementById('comparison-tbody'),
      recBanner: document.getElementById('recommendation-banner'),
      actualSpeed: document.getElementById('actual-speed-value'),
      visCurrent: document.getElementById('vis-current'),
      visNew: document.getElementById('vis-new'),
      wheelCurrent: document.getElementById('wheel-current'),
      wheelNew: document.getElementById('wheel-new')
    };

    function calculateDimensions(width, aspect, rimInches) {
      const sidewallMm = (width * aspect) / 100;
      const sidewallInches = mmToInches(sidewallMm);
      const diameterInches = (sidewallInches * 2) + rimInches;
      const diameterMm = inchesToMm(diameterInches);
      const circumferenceInches = diameterInches * Math.PI;
      const circumferenceMm = diameterMm * Math.PI;
      const revsPerMile = 63360 / circumferenceInches;

      return {
        widthInches: mmToInches(width),
        widthMm: width,
        sidewallInches,
        sidewallMm,
        diameterInches,
        diameterMm,
        circumferenceInches,
        circumferenceMm,
        revsPerMile
      };
    }

    const fmt = (num) => num.toFixed(2);
    const fmtPct = (num) => (num > 0 ? '+' : '') + num.toFixed(1) + '%';

    function updateCalculator() {
      const cw = parseFloat(els.curWidth.value);
      const ca = parseFloat(els.curAspect.value);
      const cr = parseFloat(els.curRim.value);

      const nw = parseFloat(els.newWidth.value);
      const na = parseFloat(els.newAspect.value);
      const nr = parseFloat(els.newRim.value);

      let hasError = false;
      if (!cw || !ca || !cr || cw < 100 || ca < 10 || cr < 10) {
        els.curError.style.display = 'block';
        els.curWidth.classList.add('error');
        hasError = true;
      } else {
        els.curError.style.display = 'none';
        els.curWidth.classList.remove('error');
      }

      if (!nw || !na || !nr || nw < 100 || na < 10 || nr < 10) {
        els.newError.style.display = 'block';
        els.newWidth.classList.add('error');
        hasError = true;
      } else {
        els.newError.style.display = 'none';
        els.newWidth.classList.remove('error');
      }

      if (hasError) return;

      const cur = calculateDimensions(cw, ca, cr);
      const nxt = calculateDimensions(nw, na, nr);

      const diff = {
        width: nxt.widthInches - cur.widthInches,
        sidewall: nxt.sidewallInches - cur.sidewallInches,
        diameter: nxt.diameterInches - cur.diameterInches,
        circumference: nxt.circumferenceInches - cur.circumferenceInches,
        revs: nxt.revsPerMile - cur.revsPerMile,
        pct: ((nxt.diameterInches - cur.diameterInches) / cur.diameterInches) * 100
      };

      const getDiffClass = (val, isLowerBetter = false) => {
        if (Math.abs(val) < 0.01) return 'diff-neutral';
        if (isLowerBetter) {
          return val < 0 ? 'diff-positive' : 'diff-negative';
        }
        return val > 0 ? 'diff-positive' : 'diff-negative';
      };

      const getDiffText = (val, unit) => {
        if (Math.abs(val) < 0.01) return 'Same';
        const sign = val > 0 ? '+' : '';
        return `${sign}${fmt(val)} ${unit}`;
      };

      const rows = [
        { label: 'Diameter', cur: cur.diameterInches, nxt: nxt.diameterInches, d: diff.diameter, unit: 'in' },
        { label: 'Width', cur: cur.widthInches, nxt: nxt.widthInches, d: diff.width, unit: 'in' },
        { label: 'Sidewall', cur: cur.sidewallInches, nxt: nxt.sidewallInches, d: diff.sidewall, unit: 'in' },
        { label: 'Circumference', cur: cur.circumferenceInches, nxt: nxt.circumferenceInches, d: diff.circumference, unit: 'in' },
        { label: 'Revs per Mile', cur: cur.revsPerMile, nxt: nxt.revsPerMile, d: diff.revs, unit: '', invertColor: true }
      ];

      let html = '';
      rows.forEach(r => {
        const dClass = getDiffClass(r.d, r.invertColor);
        html += `
          <tr>
            <td>${r.label}</td>
            <td class="current-col">${fmt(r.cur)}${r.unit ? ' ' + r.unit : ''}</td>
            <td class="new-col">${fmt(r.nxt)}${r.unit ? ' ' + r.unit : ''}</td>
            <td class="diff-col ${dClass}">${getDiffText(r.d, r.unit)}</td>
          </tr>
        `;
      });

      const rideHeightDiff = diff.diameter / 2;
      const rhClass = getDiffClass(rideHeightDiff);
      html += `
        <tr>
          <td>Ride Height Clearance</td>
          <td class="current-col">-</td>
          <td class="new-col">-</td>
          <td class="diff-col ${rhClass}">${getDiffText(rideHeightDiff, 'in')}</td>
        </tr>
      `;

      els.tbody.innerHTML = html;

      const absPct = Math.abs(diff.pct);
      if (absPct <= 3) {
        els.recBanner.className = 'recommendation rec-safe';
        els.recBanner.textContent = `Safe: Diameter difference is ${fmtPct(diff.pct)}. This is within the recommended 3% limit.`;
      } else if (absPct <= 5) {
        els.recBanner.className = 'recommendation rec-warning';
        els.recBanner.textContent = `Warning: Diameter difference is ${fmtPct(diff.pct)}. This exceeds the 3% limit and may cause ABS/speedometer issues.`;
      } else {
        els.recBanner.className = 'recommendation rec-danger';
        els.recBanner.textContent = `Danger: Diameter difference is ${fmtPct(diff.pct)}. This is not recommended and may cause severe clearance and mechanical issues.`;
      }

      const actualAt60 = 60 * (nxt.diameterInches / cur.diameterInches);
      els.actualSpeed.innerHTML = `${fmt(actualAt60)}<span class="speed-unit">mph</span>`;

      const maxDiameter = Math.max(cur.diameterInches, nxt.diameterInches);
      const scaleFactor = 300 / maxDiameter;

      const updateVisExact = (visEl, wheelEl, dimObj, rimInches) => {
        const pxDiameter = dimObj.diameterInches * scaleFactor;
        const pxWheel = rimInches * scaleFactor;
        const pxSidewall = (pxDiameter - pxWheel) / 2;

        visEl.style.width = `${pxDiameter}px`;
        visEl.style.height = `${pxDiameter}px`;
        visEl.style.borderWidth = `${pxSidewall}px`;

        wheelEl.style.width = `${pxWheel}px`;
        wheelEl.style.height = `${pxWheel}px`;
      };

      updateVisExact(els.visCurrent, els.wheelCurrent, cur, cr);
      updateVisExact(els.visNew, els.wheelNew, nxt, nr);
    }

    window.setPreset = function(w, a, r) {
      els.curWidth.value = w;
      els.curAspect.value = a;
      els.curRim.value = r;
      updateCalculator();
      window.scrollTo({ top: els.curWidth.offsetTop - 100, behavior: 'smooth' });
    };

    const inputs = [els.curWidth, els.curAspect, els.curRim, els.newWidth, els.newAspect, els.newRim];
    inputs.forEach(input => {
      input.addEventListener('input', updateCalculator);
      input.addEventListener('change', updateCalculator);
    });

    document.addEventListener('DOMContentLoaded', updateCalculator);
    updateCalculator();
  </script>
