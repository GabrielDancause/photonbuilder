---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const dogBreeds = [
  { name: "Chihuahua", size: "small", avgLifespan: 16 },
  { name: "Pomeranian", size: "small", avgLifespan: 14 },
  { name: "Yorkshire Terrier", size: "small", avgLifespan: 14 },
  { name: "Dachshund", size: "small", avgLifespan: 14 },
  { name: "Shih Tzu", size: "small", avgLifespan: 14 },
  { name: "French Bulldog", size: "medium", avgLifespan: 11 },
  { name: "Beagle", size: "medium", avgLifespan: 13 },
  { name: "Cocker Spaniel", size: "medium", avgLifespan: 13 },
  { name: "Border Collie", size: "medium", avgLifespan: 13 },
  { name: "Australian Shepherd", size: "medium", avgLifespan: 13 },
  { name: "Bulldog", size: "medium", avgLifespan: 9 },
  { name: "Siberian Husky", size: "medium", avgLifespan: 13 },
  { name: "Labrador Retriever", size: "large", avgLifespan: 12 },
  { name: "Golden Retriever", size: "large", avgLifespan: 11 },
  { name: "German Shepherd", size: "large", avgLifespan: 11 },
  { name: "Boxer", size: "large", avgLifespan: 10 },
  { name: "Rottweiler", size: "large", avgLifespan: 10 },
  { name: "Great Dane", size: "giant", avgLifespan: 8 },
  { name: "Saint Bernard", size: "giant", avgLifespan: 9 },
  { name: "Bernese Mountain Dog", size: "giant", avgLifespan: 8 },
];

const faqs = [
  {
    q: "Why is the 7-year rule for dog age inaccurate?",
    a: "The old 7:1 ratio oversimplifies how dogs age. Dogs mature much faster in their first two years — a 1-year-old dog is roughly equivalent to a 15-year-old human. After that, aging slows and varies significantly by size and breed. Small dogs age more slowly than large dogs after reaching adulthood."
  },
  {
    q: "How do cats age compared to dogs?",
    a: "Cats age rapidly in their first two years — reaching about 24 human years by age 2. After that, each cat year equals roughly 4 human years. Unlike dogs, cat aging doesn't vary much by breed or size, making the calculation more straightforward."
  },
  {
    q: "Why do large dogs age faster than small dogs?",
    a: "Scientists believe large dogs age faster because their accelerated growth puts more physiological stress on their bodies. Larger breeds also have higher rates of age-related diseases like cancer. A Great Dane at 6 is a senior, while a Chihuahua at 6 is still in its prime."
  },
  {
    q: "At what age is a dog considered a senior?",
    a: "It depends on size. Small dogs (under 20 lbs) are seniors around 10-12 years, medium dogs (20-50 lbs) around 8-10 years, large dogs (50-90 lbs) around 6-8 years, and giant breeds (90+ lbs) can be seniors as early as 5-6 years."
  },
  {
    q: "How can I help my pet live longer?",
    a: "Regular veterinary checkups, proper nutrition, maintaining a healthy weight, daily exercise, dental care, and mental stimulation all contribute to longevity. Senior pets benefit from twice-yearly vet visits and age-appropriate diets. Spaying/neutering has also been linked to longer lifespans."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pet Age Calculator",
    "description": "Calculate your pet's age in human years using breed-specific, non-linear formulas. Supports dogs and cats with size-adjusted calculations.",
    "url": "https://pleasestartplease.photonbuilder.com/pet-age-calculator",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Pet Age Calculator — Dog & Cat Age in Human Years",
  description: "Calculate your pet's age in human years using breed-specific, non-linear formulas. Supports dogs and cats with size-adjusted calculations.",
  category: "calculator",
  published: "2026-03-21",
};
---

<SiteLayout
  site="pleasestartplease"
  title="Pet Age Calculator — Dog & Cat Age in Human Years"
  description="Calculate your pet's age in human years using breed-specific, non-linear formulas. Supports dogs and cats with size-adjusted calculations."
  canonical="https://pleasestartplease.photonbuilder.com/pet-age-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Pet Age Calculator</h1>
      <p>Calculate your pet's real age in human years using modern, breed-specific formulas — not the outdated 7× rule.</p>
    </div>

    <section class="content-section">
      <div class="calculator-card">
        <div class="calc-form">
          <div class="form-row">
            <div class="form-group">
              <label for="petType">Pet Type</label>
              <select id="petType">
                <option value="dog">Dog</option>
                <option value="cat">Cat</option>
              </select>
            </div>
            <div class="form-group" id="sizeGroup">
              <label for="dogSize">Size Category</label>
              <select id="dogSize">
                <option value="small">Small (&lt;20 lbs)</option>
                <option value="medium">Medium (20–50 lbs)</option>
                <option value="large">Large (50–90 lbs)</option>
                <option value="giant">Giant (90+ lbs)</option>
              </select>
            </div>
          </div>
          <div class="form-row" id="breedRow">
            <div class="form-group full-width">
              <label for="dogBreed">Breed (optional)</label>
              <select id="dogBreed">
                <option value="">— Select a breed —</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="petAge">Pet's Age (years)</label>
              <input type="number" id="petAge" min="0.25" max="30" step="0.25" placeholder="e.g. 5" />
            </div>
            <div class="form-group btn-group">
              <button id="calcBtn" type="button">Calculate Age</button>
            </div>
          </div>
        </div>

        <div id="results" class="results-panel" style="display:none;">
          <div class="result-hero">
            <div class="human-age-display">
              <span class="human-age-number" id="humanAge">0</span>
              <span class="human-age-label">human years</span>
            </div>
            <div class="life-stage-badge" id="lifeStageBadge">Adult</div>
          </div>

          <div class="result-grid">
            <div class="result-item">
              <span class="result-label">Life Stage</span>
              <span class="result-value" id="lifeStage">—</span>
            </div>
            <div class="result-item">
              <span class="result-label">Avg. Lifespan</span>
              <span class="result-value" id="avgLifespan">—</span>
            </div>
            <div class="result-item">
              <span class="result-label">Old 7× Rule Would Say</span>
              <span class="result-value" id="oldRule">—</span>
            </div>
          </div>

          <div class="health-recs" id="healthRecs">
            <h3>Health Recommendations</h3>
            <ul id="healthList"></ul>
          </div>

          <div class="timeline-section" id="timelineSection">
            <h3>Fun Comparison Timeline</h3>
            <div class="timeline" id="timeline"></div>
          </div>
        </div>
      </div>

      <h2>How Pet Age Calculation Really Works</h2>
      <p>For decades, the popular "multiply by 7" rule was used to convert dog years to human years. But this rule is wildly inaccurate. A 1-year-old dog can reproduce and is far more mature than a 7-year-old child.</p>
      <p>Modern veterinary science uses non-linear formulas that account for the rapid early development of pets and the slower aging that follows. Additionally, a dog's size plays a major role — smaller dogs live significantly longer than giant breeds.</p>

      <h3>Dog Age Formula by Size</h3>
      <p>Dogs mature quickly in their first two years, then aging slows at a rate that depends on their size:</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Size</th>
              <th>Weight</th>
              <th>Year 1</th>
              <th>Year 2</th>
              <th>Each Year After</th>
              <th>Avg. Lifespan</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Small</strong></td><td>&lt;20 lbs</td><td>15 human yrs</td><td>+9 yrs (24)</td><td>+4 yrs</td><td>14–16 yrs</td></tr>
            <tr><td><strong>Medium</strong></td><td>20–50 lbs</td><td>15 human yrs</td><td>+9 yrs (24)</td><td>+5 yrs</td><td>11–14 yrs</td></tr>
            <tr><td><strong>Large</strong></td><td>50–90 lbs</td><td>15 human yrs</td><td>+9 yrs (24)</td><td>+6 yrs</td><td>9–12 yrs</td></tr>
            <tr><td><strong>Giant</strong></td><td>90+ lbs</td><td>15 human yrs</td><td>+9 yrs (24)</td><td>+7 yrs</td><td>7–10 yrs</td></tr>
          </tbody>
        </table>
      </div>

      <h3>Cat Age Formula</h3>
      <p>Cats follow a simpler pattern: the first year equals about 15 human years, the second year adds 9 more (reaching 24), and every year after that adds roughly 4 human years. Most indoor cats live 12–18 years.</p>

      <h2>Popular Dog Breeds & Lifespans</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Breed</th>
              <th>Size</th>
              <th>Avg. Lifespan</th>
            </tr>
          </thead>
          <tbody>
            {dogBreeds.map(b => (
              <tr>
                <td><strong>{b.name}</strong></td>
                <td style="text-transform:capitalize;">{b.size}</td>
                <td>{b.avgLifespan} years</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-section">
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>

    </section>
  </div>

  <script is:inline>
  (function(){
    const breeds = [
      { name: "Chihuahua", size: "small", avgLifespan: 16 },
      { name: "Pomeranian", size: "small", avgLifespan: 14 },
      { name: "Yorkshire Terrier", size: "small", avgLifespan: 14 },
      { name: "Dachshund", size: "small", avgLifespan: 14 },
      { name: "Shih Tzu", size: "small", avgLifespan: 14 },
      { name: "French Bulldog", size: "medium", avgLifespan: 11 },
      { name: "Beagle", size: "medium", avgLifespan: 13 },
      { name: "Cocker Spaniel", size: "medium", avgLifespan: 13 },
      { name: "Border Collie", size: "medium", avgLifespan: 13 },
      { name: "Australian Shepherd", size: "medium", avgLifespan: 13 },
      { name: "Bulldog", size: "medium", avgLifespan: 9 },
      { name: "Siberian Husky", size: "medium", avgLifespan: 13 },
      { name: "Labrador Retriever", size: "large", avgLifespan: 12 },
      { name: "Golden Retriever", size: "large", avgLifespan: 11 },
      { name: "German Shepherd", size: "large", avgLifespan: 11 },
      { name: "Boxer", size: "large", avgLifespan: 10 },
      { name: "Rottweiler", size: "large", avgLifespan: 10 },
      { name: "Great Dane", size: "giant", avgLifespan: 8 },
      { name: "Saint Bernard", size: "giant", avgLifespan: 9 },
      { name: "Bernese Mountain Dog", size: "giant", avgLifespan: 8 }
    ];

    const sizeLifespan = { small: "14–16 years", medium: "11–14 years", large: "9–12 years", giant: "7–10 years" };
    const catLifespan = "12–18 years (indoor)";

    const petType = document.getElementById("petType");
    const dogSize = document.getElementById("dogSize");
    const sizeGroup = document.getElementById("sizeGroup");
    const breedRow = document.getElementById("breedRow");
    const breedSelect = document.getElementById("dogBreed");
    const petAge = document.getElementById("petAge");
    const calcBtn = document.getElementById("calcBtn");
    const results = document.getElementById("results");

    function populateBreeds(size) {
      breedSelect.innerHTML = '<option value="">— Select a breed —</option>';
      breeds.filter(b => b.size === size).forEach(b => {
        const o = document.createElement("option");
        o.value = b.name;
        o.textContent = b.name + " (avg " + b.avgLifespan + " yrs)";
        breedSelect.appendChild(o);
      });
    }

    petType.addEventListener("change", function(){
      const isDog = this.value === "dog";
      sizeGroup.style.display = isDog ? "" : "none";
      breedRow.style.display = isDog ? "" : "none";
      results.style.display = "none";
    });

    dogSize.addEventListener("change", function(){
      populateBreeds(this.value);
      results.style.display = "none";
    });

    populateBreeds("small");

    function calcDogHumanAge(age, size) {
      var rateAfter2 = { small: 4, medium: 5, large: 6, giant: 7 };
      if (age <= 1) return age * 15;
      if (age <= 2) return 15 + (age - 1) * 9;
      return 24 + (age - 2) * rateAfter2[size];
    }

    function calcCatHumanAge(age) {
      if (age <= 1) return age * 15;
      if (age <= 2) return 15 + (age - 1) * 9;
      return 24 + (age - 2) * 4;
    }

    function getDogLifeStage(age, size) {
      var senior = { small: 10, medium: 8, large: 6, giant: 5 };
      var geriatric = { small: 14, medium: 12, large: 10, giant: 8 };
      if (age < 1) return { stage: "Puppy", color: "#4ade80" };
      if (age < 2) return { stage: "Young Adult", color: "#60a5fa" };
      if (age < senior[size]) return { stage: "Mature Adult", color: "#a78bfa" };
      if (age < geriatric[size]) return { stage: "Senior", color: "#f59e0b" };
      return { stage: "Geriatric", color: "#ef4444" };
    }

    function getCatLifeStage(age) {
      if (age < 1) return { stage: "Kitten", color: "#4ade80" };
      if (age < 2) return { stage: "Young Adult", color: "#60a5fa" };
      if (age < 10) return { stage: "Mature Adult", color: "#a78bfa" };
      if (age < 15) return { stage: "Senior", color: "#f59e0b" };
      return { stage: "Geriatric", color: "#ef4444" };
    }

    function getHealthRecs(stage, type) {
      var recs = {
        "Puppy": [
          "Complete vaccination series and deworming schedule",
          "Start socialization and basic obedience training",
          "Feed high-quality puppy food 3–4 times daily",
          "Schedule spay/neuter discussion with your vet",
          "Begin dental hygiene habits early"
        ],
        "Kitten": [
          "Complete vaccination series (FVRCP, rabies)",
          "Start litter box training and socialization",
          "Feed kitten-formulated food 3–4 times daily",
          "Schedule spay/neuter by 5–6 months",
          "Provide scratching posts and interactive play"
        ],
        "Young Adult": [
          "Annual wellness exams and booster vaccinations",
          "Establish consistent exercise routine (30–60 min daily for dogs)",
          "Transition to adult food formula",
          "Regular dental cleanings and at-home dental care",
          "Maintain healthy weight — obesity shortens lifespan significantly"
        ],
        "Mature Adult": [
          "Bi-annual veterinary checkups recommended",
          "Watch for early signs of arthritis or joint issues",
          "Consider joint supplements (glucosamine, omega-3s)",
          "Maintain consistent exercise but watch for fatigue",
          "Monitor weight closely — metabolism begins to slow"
        ],
        "Senior": [
          "Bi-annual vet visits with bloodwork and urinalysis",
          "Switch to senior-formulated diet",
          "Provide orthopedic bedding and easy access to resources",
          "Monitor for cognitive decline (confusion, restlessness at night)",
          "Adjust exercise to low-impact activities (swimming, gentle walks)"
        ],
        "Geriatric": [
          "Quarterly vet visits for close monitoring",
          "Pain management plan for arthritis and joint issues",
          "Highly digestible, senior-specific nutrition",
          "Keep environment consistent — minimize stress and changes",
          "Focus on comfort and quality of life above all"
        ]
      };
      return recs[stage] || recs["Mature Adult"];
    }

    function getTimeline(humanAge) {
      var milestones = [
        { age: 1, label: "Learning to walk" },
        { age: 5, label: "Starting school" },
        { age: 13, label: "Becoming a teenager" },
        { age: 18, label: "Graduating high school" },
        { age: 21, label: "Legally an adult everywhere" },
        { age: 30, label: "Established career" },
        { age: 40, label: "Midlife milestone" },
        { age: 50, label: "AARP eligible" },
        { age: 60, label: "Thinking about retirement" },
        { age: 70, label: "Enjoying retirement" },
        { age: 80, label: "Wise elder status" },
        { age: 90, label: "Living legend" },
        { age: 100, label: "Centenarian!" }
      ];
      return milestones.filter(m => m.age <= humanAge + 5);
    }

    calcBtn.addEventListener("click", function(){
      var age = parseFloat(petAge.value);
      if (!age || age <= 0) { petAge.focus(); return; }

      var type = petType.value;
      var size = dogSize.value;
      var humanYears, stageInfo, lifespan, breedLifespan;

      if (type === "dog") {
        humanYears = calcDogHumanAge(age, size);
        stageInfo = getDogLifeStage(age, size);
        lifespan = sizeLifespan[size];
        var selectedBreed = breeds.find(b => b.name === breedSelect.value);
        if (selectedBreed) {
          breedLifespan = selectedBreed.avgLifespan + " years (" + selectedBreed.name + ")";
        }
      } else {
        humanYears = calcCatHumanAge(age);
        stageInfo = getCatLifeStage(age);
        lifespan = catLifespan;
      }

      document.getElementById("humanAge").textContent = Math.round(humanYears);
      document.getElementById("lifeStageBadge").textContent = stageInfo.stage;
      document.getElementById("lifeStageBadge").style.background = stageInfo.color;
      document.getElementById("lifeStage").textContent = stageInfo.stage;
      document.getElementById("avgLifespan").textContent = breedLifespan || lifespan;
      document.getElementById("oldRule").textContent = Math.round(age * 7) + " years (inaccurate!)";

      var healthList = document.getElementById("healthList");
      healthList.innerHTML = "";
      getHealthRecs(stageInfo.stage, type).forEach(function(rec){
        var li = document.createElement("li");
        li.textContent = rec;
        healthList.appendChild(li);
      });

      var timeline = document.getElementById("timeline");
      timeline.innerHTML = "";
      var milestones = getTimeline(Math.round(humanYears));
      var maxAge = milestones.length > 0 ? milestones[milestones.length - 1].age : 100;
      milestones.forEach(function(m){
        var item = document.createElement("div");
        item.className = "timeline-item";
        if (Math.round(humanYears) >= m.age) item.classList.add("reached");
        var pct = (m.age / maxAge) * 100;
        item.innerHTML = '<div class="tl-marker"></div><div class="tl-content"><strong>' + m.age + ' human years</strong><span>' + m.label + '</span></div>';
        timeline.appendChild(item);
      });

      results.style.display = "";
      results.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

    strong { color: var(--text-primary); }

    /* Calculator Card */
    .calculator-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; }
    .form-row { display: flex; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .form-group { flex: 1; min-width: 180px; display: flex; flex-direction: column; }
    .form-group.full-width { min-width: 100%; }
    .form-group label { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.4rem; }
    .form-group select,
    .form-group input { padding: 0.65rem 0.8rem; border: 1px solid var(--border-color); border-radius: 8px; font-size: 0.95rem; background: var(--bg-primary, #fff); color: var(--text-primary); }
    .form-group select:focus,
    .form-group input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px rgba(99,102,241,0.15); }
    .btn-group { justify-content: flex-end; }
    #calcBtn { padding: 0.65rem 2rem; background: var(--accent-color); color: #fff; border: none; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; margin-top: auto; transition: opacity 0.2s; }
    #calcBtn:hover { opacity: 0.85; }

    /* Results */
    .results-panel { margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border-color); }
    .result-hero { text-align: center; margin-bottom: 2rem; }
    .human-age-display { display: flex; flex-direction: column; align-items: center; margin-bottom: 1rem; }
    .human-age-number { font-size: 4.5rem; font-weight: 900; line-height: 1; color: var(--accent-color); }
    .human-age-label { font-size: 1.1rem; color: var(--text-secondary); margin-top: 0.25rem; }
    .life-stage-badge { display: inline-block; padding: 0.4rem 1.2rem; border-radius: 20px; color: #fff; font-weight: 700; font-size: 0.95rem; }

    .result-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .result-item { background: var(--bg-primary, #f9fafb); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem; text-align: center; }
    .result-label { display: block; font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; }
    .result-value { display: block; font-size: 1.1rem; font-weight: 700; color: var(--text-primary); }

    /* Health Recs */
    .health-recs { margin-bottom: 2rem; }
    .health-recs h3 { font-size: 1.2rem; color: var(--text-primary); margin-bottom: 0.75rem; margin-top: 0; }
    .health-recs ul { list-style: none; padding: 0; margin: 0; }
    .health-recs li { padding: 0.6rem 0 0.6rem 1.5rem; color: var(--text-secondary); position: relative; border-bottom: 1px solid var(--border-color); line-height: 1.5; }
    .health-recs li:last-child { border-bottom: none; }
    .health-recs li::before { content: "✓"; position: absolute; left: 0; color: var(--accent-color); font-weight: 700; }

    /* Timeline */
    .timeline-section h3 { font-size: 1.2rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 0; }
    .timeline { display: flex; flex-direction: column; gap: 0; padding-left: 1rem; }
    .timeline-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.5rem 0; position: relative; opacity: 0.4; }
    .timeline-item.reached { opacity: 1; }
    .tl-marker { width: 12px; height: 12px; border-radius: 50%; background: var(--border-color); flex-shrink: 0; margin-top: 0.3rem; position: relative; }
    .timeline-item.reached .tl-marker { background: var(--accent-color); }
    .timeline-item:not(:last-child)::before { content: ''; position: absolute; left: calc(1rem + 5px); top: 1.3rem; width: 2px; height: calc(100% - 0.5rem); background: var(--border-color); }
    .timeline-item.reached:not(:last-child)::before { background: var(--accent-color); }
    .tl-content { display: flex; flex-direction: column; }
    .tl-content strong { font-size: 0.9rem; color: var(--text-primary); }
    .tl-content span { font-size: 0.85rem; color: var(--text-secondary); }

    /* Table */
