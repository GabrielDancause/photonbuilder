---
import SiteLayout from '../../../layouts/SiteLayout.astro';


export const meta = {
  title: 'Car Insurance Guide: Coverage, Deductibles, and Tips',
  description: 'Understand car insurance: liability vs collision, gap insurance, how to lower premiums, usage-based insurance, SR-22, and comparing quotes from top companies.',
  category: 'guide',
};

const faqs = [
  {
    q: "What is the difference between liability, collision, and comprehensive?",
    a: "Liability covers damage you cause to others. Collision covers damage to your car from an accident. Comprehensive covers non-collision events like theft, weather, or hitting an animal."
  },
  {
    q: "How can I lower my car insurance premium?",
    a: "You can lower premiums by bundling policies, increasing your deductible, maintaining good credit, taking a defensive driving course, or using usage-based insurance programs."
  },
  {
    q: "What is gap insurance and do I need it?",
    a: "Gap insurance covers the difference between what your car is worth and what you owe on your loan if it is totaled. It is recommended if you lease or finance a new car with a small down payment."
  },
  {
    q: "When should I drop collision coverage?",
    a: "Consider dropping collision coverage when the value of your vehicle is so low that the cost of the coverage and deductible exceeds potential payout, usually on older cars."
  },
  {
    q: "What is an SR-22?",
    a: "An SR-22 is not insurance, but a certificate of financial responsibility required by the state for high-risk drivers, typically after a DUI, severe violation, or driving uninsured."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];
