---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const checklistCategories = [
  {
    category: "12+ Months Before",
    items: [
      { name: "Establish Budget", desc: "Determine your total budget and who is contributing." },
      { name: "Draft Guest List", desc: "Get an estimated head count to guide venue selection." },
      { name: "Hire a Planner", desc: "Decide if you need a full-service planner or day-of coordinator." },
      { name: "Book Venue", desc: "Secure your ceremony and reception locations." }
    ]
  },
  {
    category: "9-11 Months Before",
    items: [
      { name: "Hire Photographer/Videographer", desc: "The best ones book up quickly." },
      { name: "Book Caterer", desc: "Schedule tastings and finalize the menu style." },
      { name: "Purchase Attire", desc: "Order your wedding dress or suit to allow time for alterations." },
      { name: "Book Entertainment", desc: "Secure a band or DJ for the reception." }
    ]
  },
  {
    category: "6-8 Months Before",
    items: [
      { name: "Book Florist", desc: "Decide on centerpieces, bouquets, and overall floral design." },
      { name: "Send Save-the-Dates", desc: "Especially important for destination weddings or holiday weekends." },
      { name: "Book Officiant", desc: "Ensure they are available and legally recognized in your location." },
      { name: "Plan Honeymoon", desc: "Book flights, accommodations, and secure necessary travel documents." }
    ]
  },
  {
    category: "3-5 Months Before",
    items: [
      { name: "Order Invitations", desc: "Finalize design and wording, and place your order." },
      { name: "Buy Wedding Rings", desc: "Allow time for resizing or custom engravings." },
      { name: "Rentals", desc: "Finalize any necessary rentals (tents, chairs, linens)." },
      { name: "Hair & Makeup Trials", desc: "Book your stylists and do a trial run." }
    ]
  },
  {
    category: "1-2 Months Before",
    items: [
      { name: "Send Invitations", desc: "Mail them out 6-8 weeks before the wedding." },
      { name: "Final Dress Fitting", desc: "Ensure your attire fits perfectly." },
      { name: "Apply for Marriage License", desc: "Check local laws for waiting periods and validity times." },
      { name: "Create Seating Chart", desc: "Finalize who sits where based on RSVPs." }
    ]
  }
];

const diyVsPro = [
  { element: "Invitations", diy: "Print at home or use online templates. Can be cheaper but time-consuming.", pro: "Custom design, letterpress, premium paper. Saves time, higher quality." },
  { element: "Flowers", diy: "Buy wholesale and assemble yourself. Big cost savings, high stress day-of.", pro: "Expert design, delivery, setup, and teardown included." },
  { element: "Music", diy: "Spotify playlist and rented speakers. Cheap, but requires an MC and managing the vibe.", pro: "DJ or Band reads the room, provides MC services, brings their own gear." },
  { element: "Cake", diy: "Bake your own or use a grocery store cake. Very affordable.", pro: "Custom design, professional taste, delivered and set up safely." },
  { element: "Coordination", diy: "Have a friend or family member manage the timeline.", pro: "Professional handles all vendor communication and troubleshooting so you can relax." }
];

const faqs = [
  { q: "How much does an average wedding cost?", a: "The average cost of a wedding in the US is around $30,000 to $35,000, but this varies wildly by location, guest count, and style. Setting a firm budget early is the most important step." },
  { q: "How much should I tip wedding vendors?", a: "Tipping is often expected for service staff (caterers, bartenders, hair/makeup, transportation) at 15-20%. For business owners (photographers, planners, florists), it is optional but a $50-$200 tip or a thoughtful gift is appreciated." },
  { q: "When should we send our wedding invitations?", a: "Send Save-the-Dates 6-8 months in advance (up to a year for destination weddings). Send the actual invitations 6-8 weeks before the wedding, with an RSVP deadline of 3-4 weeks prior." },
  { q: "How do I create a day-of wedding timeline?", a: "Start with your ceremony time and work backward for getting ready and photos. Work forward for cocktail hour, dinner, speeches, and dancing. Build in 15-30 minute buffers for every major transition." },
  { q: "What should I consider for a destination wedding?", a: "Destination weddings require earlier planning. Factor in travel costs for key guests, local marriage laws, language barriers with vendors, and the need for a local planner. Send save-the-dates a year in advance." }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Wedding Planning Checklist: A Complete 12-Month Timeline",
    "description": "A complete wedding planning timeline covering the 12-month countdown, budget breakdown, guest list management, DIY vs Pro comparisons, and day-of details.",
    "author": {
      "@type": "Organization",
      "name": "Please Start Please"
    },
    "datePublished": "2026-06-20",
    "dateModified": "2026-06-20"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];
---

<SiteLayout
  site="pleasestartplease"
  title="Best Wedding Planning Checklist: A Complete 12-Month Timeline"
  description="A complete wedding planning timeline covering the 12-month countdown, budget breakdown, guest list management, DIY vs Pro comparisons, and day-of details."
  canonical="https://pleasestartplease.photonbuilder.com/wedding-planning-checklist"
  schema={JSON.stringify(schema)}
>
  <div class="page-content">
    <div class="hero">
      <h1>Best Wedding Planning Checklist: A Complete 12-Month Timeline</h1>
      <p>Planning a wedding is a massive undertaking, but breaking it down into a timeline makes it manageable. This guide covers everything from your 12-month countdown to the day-of details.</p>
    </div>

    <section class="content-section">
      <p>Whether you're dreaming of a massive ballroom affair or a quiet destination elopement, organization is the key to a stress-free wedding. Follow this guide to keep your planning on track.</p>

      <h2>1. The 12-Month Wedding Countdown</h2>
      <p>Don't try to plan everything at once. Tackle these tasks month by month.</p>

      <div class="winners-grid">
        {checklistCategories.map(category => (
          <div class="winner-card">
            <div class="winner-header">
              <span class="winner-category">{category.category}</span>
            </div>
            <ul>
              {category.items.map(item => (
                <li><strong>{item.name}:</strong> {item.desc}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <h2>2. Budgeting & Where to Save</h2>
      <p>Before booking anything, establish your total budget and discuss who is contributing.</p>
      <ul>
        <li><strong>Average Costs:</strong> The venue and catering will consume about 50% of your budget. Photography/Videography usually takes 10-15%, and floral/decor another 10%.</li>
        <li><strong>Where to Save:</strong> Cut the guest list (the fastest way to save money), skip the champagne toast, use in-season flowers, or choose a Friday or Sunday instead of a Saturday night.</li>
      </ul>

      <h2>3. Guest List Management</h2>
      <p>Your guest list dictates your venue size and your catering budget.</p>
      <ul>
        <li><strong>A-List vs B-List:</strong> Create an 'A-list' of must-have guests. If RSVPs decline, you can send invitations to your 'B-list'.</li>
        <li><strong>Plus Ones:</strong> Establish a clear rule early on. For example, "only married, engaged, or living together couples get a plus-one." Be consistent.</li>
        <li><strong>Adults Only:</strong> If you want an adults-only wedding, address the invitations clearly to the adults and perhaps include a polite note on your wedding website.</li>
      </ul>

      <h2>4. DIY vs Professional: What's Worth It?</h2>
      <p>Trying to save money by doing it yourself? Consider the time and stress involved.</p>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Element</th>
              <th>DIY (Do It Yourself)</th>
              <th>Professional</th>
            </tr>
          </thead>
          <tbody>
            {diyVsPro.map(item => (
              <tr>
                <td><strong>{item.element}</strong></td>
                <td>{item.diy}</td>
                <td>{item.pro}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>5. Day-Of Timeline & Tipping</h2>
      <p>A solid timeline is crucial for the wedding day.</p>
      <ul>
        <li><strong>The Timeline:</strong> Start with your ceremony time. If the ceremony is at 4 PM, plan to have photos done by 3:15 PM so you can hide as guests arrive. Build in 15-30 minute buffers for every transition.</li>
        <li><strong>Tipping Guide:</strong> Tip hair and makeup artists, transportation, and delivery staff 15-20%. Tipping business owners (like your photographer or florist) is optional but always appreciated. Prepare cash tips in labeled envelopes beforehand and give them to your coordinator or best man to distribute.</li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-section">
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
  .hero { text-align: center; padding: 3rem 0 2rem; }
  .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
  .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

  .content-section { margin-bottom: 3rem; }
  .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
  .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
  .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

  .content-section ul { padding-left: 1.5rem; margin-bottom: 1rem; color: var(--text-secondary); }
  .content-section li { margin-bottom: 0.5rem; }

  strong { color: var(--text-primary); }

  /* Category Winners */
  .winners-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; position: relative; overflow: hidden; }
  .winner-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--accent-color); }
  .winner-header { margin-bottom: 0.75rem; }
  .winner-category { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); display: block; margin-bottom: 0.25rem; }
  .winner-header h3 { margin: 0; font-size: 1.4rem; color: var(--text-primary); }
  .winner-card p { margin: 0; font-size: 0.95rem; line-height: 1.5; color: var(--text-secondary); }

  /* Table */
  .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; min-width: 900px; }
  th { background: var(--card-bg); padding: 0.85rem 0.75rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
  td { padding: 0.75rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); vertical-align: top; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--card-bg); }

  /* FAQ */
  .faq-section { margin-top: 2rem; }
  .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
  .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
  .faq-item p { margin-bottom: 0; }

  @media (max-width: 600px) {
    .hero h1 { font-size: 1.6rem; }
    .winners-grid { grid-template-columns: 1fr; }
  }
</style>