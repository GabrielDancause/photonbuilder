---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Law of Sines Calculator",
  description: "Calculate unknown angles and sides of a triangle instantly with our Law of Sines Calculator. Discover the exact formula and methodology behind the math.",
  category: "tool",
  published: "2024-05-25",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Law of Sines used for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Law of Sines is used to find unknown sides or angles in any triangle. It is particularly useful when you know two angles and one side (AAS or ASA) or two sides and a non-included angle (SSA)."
        }
      },
      {
        "@type": "Question",
        "name": "Can the Law of Sines be used on right triangles?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The Law of Sines works on any triangle, including right triangles. However, for right triangles, basic trigonometric ratios (sine, cosine, tangent) are usually faster and easier to use."
        }
      },
      {
        "@type": "Question",
        "name": "What is the ambiguous case of the Law of Sines?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The ambiguous case occurs when you are given two sides and an angle not included between them (SSA). Because of how the geometry can fold, this specific combination of knowns can result in zero, one, or two possible valid triangles."
        }
      },
      {
        "@type": "Question",
        "name": "Why do the angles of a triangle always sum to 180 degrees?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In Euclidean geometry, the sum of the interior angles of any planar triangle is exactly 180 degrees (or π radians). This property is fundamental when solving triangles, as knowing any two angles immediately gives you the third."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between the Law of Sines and the Law of Cosines?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Law of Sines relates opposite sides and angles using a direct proportion, requiring at least one known side-angle pair. The Law of Cosines is a generalized Pythagorean theorem used when you have three sides (SSS) or two sides and the included angle (SAS), where the Law of Sines cannot be applied initially."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Law of Sines Calculator",
    "description": "Calculate unknown angles and sides of a triangle instantly with our Law of Sines Calculator. Discover the exact formula and methodology behind the math.",
    "author": {
      "@type": "Organization",
      "name": "Silicon Based"
    }
  }
];
---

<SiteLayout site="mathtools" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/mathtools/law-of-sines-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>{meta.title}</h1>
      <p class="subtitle">Instantly calculate the unknown sides and angles of any triangle.</p>
    </div>

    <div class="calculator-container">
      <div class="input-grid">
        <div class="input-group">
          <label for="side-a">Side a</label>
          <input type="number" id="side-a" placeholder="e.g. 5" min="0" step="any" />
        </div>
        <div class="input-group">
          <label for="side-b">Side b</label>
          <input type="number" id="side-b" placeholder="e.g. 7" min="0" step="any" />
        </div>
        <div class="input-group">
          <label for="side-c">Side c</label>
          <input type="number" id="side-c" placeholder="e.g. 10" min="0" step="any" />
        </div>
      </div>

      <div class="input-grid">
        <div class="input-group">
          <label for="angle-a">Angle A (degrees)</label>
          <input type="number" id="angle-a" placeholder="e.g. 30" min="0" max="180" step="any" />
        </div>
        <div class="input-group">
          <label for="angle-b">Angle B (degrees)</label>
          <input type="number" id="angle-b" placeholder="e.g. 45" min="0" max="180" step="any" />
        </div>
        <div class="input-group">
          <label for="angle-c">Angle C (degrees)</label>
          <input type="number" id="angle-c" placeholder="e.g. 105" min="0" max="180" step="any" />
        </div>
      </div>

      <div class="error-message" id="error-message"></div>

      <div class="results-grid" id="results-container" style="display: none;">
        <!-- Results will be injected here -->
      </div>
      <div class="results-grid" id="alt-results-container" style="display: none;">
        <!-- Alt Results for Ambiguous Case will be injected here -->
      </div>
    </div>

    <div class="explainer">

      <h2>Understanding the Law of Sines</h2>
      <p>The Law of Sines is a fundamental trigonometric rule that establishes a proportional relationship between the sides of a triangle and the sines of their corresponding opposite angles. It is incredibly useful for solving triangles when you know either two angles and one side (AAS or ASA) or two sides and an angle opposite one of them (SSA).</p>

      <h3>The Formula</h3>
      <p>The formula for the Law of Sines can be written in two equivalent forms:</p>
      <ul>
        <li><strong>a / sin(A) = b / sin(B) = c / sin(C)</strong> (Best for finding a missing side)</li>
        <li><strong>sin(A) / a = sin(B) / b = sin(C) / c</strong> (Best for finding a missing angle)</li>
      </ul>
      <p>Where:</p>
      <ul>
        <li><strong>a, b, c</strong> are the lengths of the triangle's sides.</li>
        <li><strong>A, B, C</strong> are the interior angles opposite those respective sides.</li>
      </ul>

      <h3>When Can You Use the Law of Sines?</h3>
      <p>To use the Law of Sines effectively to solve a complete triangle, you need to know at least three distinct parts of the triangle, and importantly, one of those known parts must form a "matching pair" (a side and its opposite angle). Specifically, the Law of Sines is used in these scenarios:</p>
      <ol>
        <li><strong>AAS (Angle-Angle-Side):</strong> You know two angles and a non-included side. You can easily find the third angle (since angles must sum to 180°), and then use the Law of Sines to find the remaining sides.</li>
        <li><strong>ASA (Angle-Side-Angle):</strong> You know two angles and the included side between them. Again, find the third angle first, then use the Law of Sines.</li>
        <li><strong>SSA (Side-Side-Angle):</strong> You know two sides and an angle that is NOT between them. This is famously known as the <em>Ambiguous Case</em>.</li>
      </ol>

      <h3>The Ambiguous Case (SSA) Explained</h3>
      <p>The SSA case is considered ambiguous because the given information might not result in a single, unique triangle. Depending on the lengths of the sides and the measure of the angle, there could be:</p>
      <ul>
        <li><strong>No Triangle (0 Solutions):</strong> If the side opposite the given angle is too short to reach the other side, a closed triangle cannot be formed. Our calculator will return an "impossible triangle" error in this scenario.</li>
        <li><strong>Exactly One Triangle (1 Solution):</strong> The given information perfectly describes one unique triangle. This happens if it forms a right triangle or if the side opposite the angle is longer than the other given side.</li>
        <li><strong>Two Different Triangles (2 Solutions):</strong> If the side opposite the given angle is longer than the height but shorter than the other given side, two valid triangles can be formed (one acute and one obtuse). Our calculator automatically detects this and provides the <em>Alternative Solution</em> below the primary result.</li>
      </ul>

      <h3>Why is the Law of Sines Important?</h3>
      <p>The Law of Sines allows us to move beyond right triangles. While basic trigonometry (SOH CAH TOA) only applies to triangles with a 90-degree angle, the Law of Sines applies to <em>any</em> triangle—acute, obtuse, or right. It is heavily utilized in fields requiring precise spatial calculations, such as surveying, navigation, architecture, and engineering.</p>

    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>What is the Law of Sines used for?</summary>
        <p>The Law of Sines is used to find unknown sides or angles in any triangle. It is particularly useful when you know two angles and one side (AAS or ASA) or two sides and a non-included angle (SSA).</p>
      </details>
      <details>
        <summary>Can the Law of Sines be used on right triangles?</summary>
        <p>Yes. The Law of Sines works on any triangle, including right triangles. However, for right triangles, basic trigonometric ratios (sine, cosine, tangent) are usually faster and easier to use.</p>
      </details>
      <details>
        <summary>What is the ambiguous case of the Law of Sines?</summary>
        <p>The ambiguous case occurs when you are given two sides and an angle not included between them (SSA). Because of how the geometry can fold, this specific combination of knowns can result in zero, one, or two possible valid triangles.</p>
      </details>
      <details>
        <summary>Why do the angles of a triangle always sum to 180 degrees?</summary>
        <p>In Euclidean geometry, the sum of the interior angles of any planar triangle is exactly 180 degrees (or &pi; radians). This property is fundamental when solving triangles, as knowing any two angles immediately gives you the third.</p>
      </details>
      <details>
        <summary>What is the difference between the Law of Sines and the Law of Cosines?</summary>
        <p>The Law of Sines relates opposite sides and angles using a direct proportion, requiring at least one known side-angle pair. The Law of Cosines is a generalized Pythagorean theorem used when you have three sides (SSS) or two sides and the included angle (SAS), where the Law of Sines cannot be applied initially.</p>
      </details>

    </section>


    <div class="related-tools">
      <h2>Related Tools</h2>
      <p>Looking to calculate chronological age or days until your next birthday? Check out our <a href="/birthday-calculator">Birthday Calculator</a>.</p>
    </div>


  </div>

  <script is:inline>
    const inputs = ['side-a', 'side-b', 'side-c', 'angle-a', 'angle-b', 'angle-c'].map(id => document.getElementById(id));
    const errorEl = document.getElementById('error-message');
    const resultsContainer = document.getElementById('results-container');
    const altResultsContainer = document.getElementById('alt-results-container');

    // Convert degrees to radians and vice versa
    const toRad = deg => (deg * Math.PI) / 180;
    const toDeg = rad => (rad * 180) / Math.PI;

    function solveTriangle(a, b, c, A, B, C) {
      let knownSides = 0;
      let knownAngles = 0;

      if (a !== null) knownSides++;
      if (b !== null) knownSides++;
      if (c !== null) knownSides++;
      if (A !== null) knownAngles++;
      if (B !== null) knownAngles++;
      if (C !== null) knownAngles++;

      if (knownSides + knownAngles < 3) {
         return { error: 'Please enter at least 3 values.' };
      }
      if (knownSides === 0) {
         return { error: 'Please enter at least one side.' };
      }

      let A_rad = A !== null ? toRad(A) : null;
      let B_rad = B !== null ? toRad(B) : null;
      let C_rad = C !== null ? toRad(C) : null;

      // Calculate missing angles if 2 are known
      if (A !== null && B !== null && C === null) {
          C = 180 - A - B;
          C_rad = toRad(C);
      } else if (A !== null && C !== null && B === null) {
          B = 180 - A - C;
          B_rad = toRad(B);
      } else if (B !== null && C !== null && A === null) {
          A = 180 - B - C;
          A_rad = toRad(A);
      }

      // Check sum of angles if all are given/calculated
      if (A !== null && B !== null && C !== null) {
          if (Math.abs(A + B + C - 180) > 0.001) {
             return { error: 'The sum of angles must be 180 degrees.' };
          }
      }

      // We need at least one known side-angle pair (e.g., a and A)
      let ratio = null;
      if (a !== null && A !== null) ratio = a / Math.sin(A_rad);
      else if (b !== null && B !== null) ratio = b / Math.sin(B_rad);
      else if (c !== null && C !== null) ratio = c / Math.sin(C_rad);

      let altSolution = null;

      if (ratio !== null) {
          // We have a known pair. Calculate the rest.
          // Calculate missing sides
          if (a === null && A !== null) a = ratio * Math.sin(A_rad);
          if (b === null && B !== null) b = ratio * Math.sin(B_rad);
          if (c === null && C !== null) c = ratio * Math.sin(C_rad);

          // Ambiguous case (SSA) handling
          // This happens when two sides and an angle NOT between them are given.
          // E.g., a, b, A are known.
          // Let's check if we can calculate the angle opposite to a known side.
          if (A === null && a !== null) {
             let sinA = a / ratio;
             if (sinA > 1) return { error: 'No solution exists (impossible triangle).' };
             A = toDeg(Math.asin(sinA));
             A_rad = toRad(A);

             // Check ambiguous
             let A2 = 180 - A;
             let A2_rad = toRad(A2);
             // Assume C is the known angle, b is the other side.
             // Wait, SSA means we knew ratio from another pair, say (c,C), and we know a.
             // So A could be A or 180-A.
             // Let's calculate the third angle for A2
             // The known angle is the one that gave us the ratio.
             // Which one gave us the ratio?
             // If we had (b,B) and a, then B is known.
             // B + A2 must be < 180
             // Let's find the known angle
             let knownAngle = null;
             if (inputs[4].value !== '') knownAngle = parseFloat(inputs[4].value); // B
             else if (inputs[5].value !== '') knownAngle = parseFloat(inputs[5].value); // C
             else if (inputs[3].value !== '') knownAngle = parseFloat(inputs[3].value); // A

             if (knownAngle !== null && knownAngle + A2 < 180) {
                 altSolution = { a: a, b: b, c: c, A: A2, B: B, C: C }; // We will re-calc below
             }
          }
          if (B === null && b !== null) {
             let sinB = b / ratio;
             if (sinB > 1) return { error: 'No solution exists (impossible triangle).' };
             B = toDeg(Math.asin(sinB));
             B_rad = toRad(B);

             let B2 = 180 - B;
             let knownAngle = null;
             if (inputs[3].value !== '') knownAngle = parseFloat(inputs[3].value); // A
             else if (inputs[5].value !== '') knownAngle = parseFloat(inputs[5].value); // C

             if (knownAngle !== null && knownAngle + B2 < 180) {
                 altSolution = { a: a, b: b, c: c, A: A, B: B2, C: C };
             }
          }
          if (C === null && c !== null) {
             let sinC = c / ratio;
             if (sinC > 1) return { error: 'No solution exists (impossible triangle).' };
             C = toDeg(Math.asin(sinC));
             C_rad = toRad(C);

             let C2 = 180 - C;
             let knownAngle = null;
             if (inputs[3].value !== '') knownAngle = parseFloat(inputs[3].value); // A
             else if (inputs[4].value !== '') knownAngle = parseFloat(inputs[4].value); // B

             if (knownAngle !== null && knownAngle + C2 < 180) {
                 altSolution = { a: a, b: b, c: c, A: A, B: B, C: C2 };
             }
          }

          // If we had 2 angles missing, and we just found one, we need to find the third.
          if (A === null) { A = 180 - B - C; A_rad = toRad(A); }
          if (B === null) { B = 180 - A - C; B_rad = toRad(B); }
          if (C === null) { C = 180 - A - B; C_rad = toRad(C); }

          if (a === null) a = ratio * Math.sin(A_rad);
          if (b === null) b = ratio * Math.sin(B_rad);
          if (c === null) c = ratio * Math.sin(C_rad);

      } else {
         // No known pair. This means we have 3 sides (SSS) or 2 sides and the included angle (SAS).
         // The Law of Sines alone cannot solve this initially. Need Law of Cosines.
         // Let's implement Law of Cosines fallback for completeness.
         if (knownSides === 3) {
             A = toDeg(Math.acos((b*b + c*c - a*a) / (2*b*c)));
             B = toDeg(Math.acos((a*a + c*c - b*b) / (2*a*c)));
             C = 180 - A - B;
         } else if (a !== null && b !== null && C !== null) {
             c = Math.sqrt(a*a + b*b - 2*a*b*Math.cos(toRad(C)));
             A = toDeg(Math.asin((a * Math.sin(toRad(C))) / c));
             B = 180 - A - C;
         } else if (a !== null && c !== null && B !== null) {
             b = Math.sqrt(a*a + c*c - 2*a*c*Math.cos(toRad(B)));
             A = toDeg(Math.asin((a * Math.sin(toRad(B))) / b));
             C = 180 - A - B;
         } else if (b !== null && c !== null && A !== null) {
             a = Math.sqrt(b*b + c*c - 2*b*c*Math.cos(toRad(A)));
             B = toDeg(Math.asin((b * Math.sin(toRad(A))) / a));
             C = 180 - A - B;
         } else {
             return { error: 'Not enough information to solve.' };
         }
      }

      // Final validity check
      if (a <= 0 || b <= 0 || c <= 0 || A <= 0 || B <= 0 || C <= 0 || isNaN(a) || isNaN(b) || isNaN(c) || isNaN(A) || isNaN(B) || isNaN(C)) {
          return { error: 'Invalid triangle configuration.' };
      }

      let res = { a, b, c, A, B, C };

      if (altSolution) {
          // Re-calculate the rest of the alt triangle
          if (altSolution.A !== A || altSolution.B !== B || altSolution.C !== C) {
             let og_a = inputs[0].value !== '' ? parseFloat(inputs[0].value) : null;
             let og_b = inputs[1].value !== '' ? parseFloat(inputs[1].value) : null;
             let og_c = inputs[2].value !== '' ? parseFloat(inputs[2].value) : null;
             let og_A = inputs[3].value !== '' ? parseFloat(inputs[3].value) : null;
             let og_B = inputs[4].value !== '' ? parseFloat(inputs[4].value) : null;
             let og_C = inputs[5].value !== '' ? parseFloat(inputs[5].value) : null;

             let alt_a = og_a, alt_b = og_b, alt_c = og_c;
             let alt_A = og_A, alt_B = og_B, alt_C = og_C;

             if (og_A === null && a !== null && og_a !== null) alt_A = 180 - A;
             if (og_B === null && b !== null && og_b !== null) alt_B = 180 - B;
             if (og_C === null && c !== null && og_c !== null) alt_C = 180 - C;

             // Now find the third angle
             if (alt_A !== null && alt_B !== null && alt_C === null) alt_C = 180 - alt_A - alt_B;
             if (alt_A !== null && alt_C !== null && alt_B === null) alt_B = 180 - alt_A - alt_C;
             if (alt_B !== null && alt_C !== null && alt_A === null) alt_A = 180 - alt_B - alt_C;

             if (alt_A <= 0 || alt_B <= 0 || alt_C <= 0) {
                 altSolution = null; // Invalid
             } else {
                 // Find remaining side
                 let alt_ratio = null;
                 if (alt_a !== null && alt_A !== null) alt_ratio = alt_a / Math.sin(toRad(alt_A));
                 else if (alt_b !== null && alt_B !== null) alt_ratio = alt_b / Math.sin(toRad(alt_B));
                 else if (alt_c !== null && alt_C !== null) alt_ratio = alt_c / Math.sin(toRad(alt_C));

                 if (alt_a === null) alt_a = alt_ratio * Math.sin(toRad(alt_A));
                 if (alt_b === null) alt_b = alt_ratio * Math.sin(toRad(alt_B));
                 if (alt_c === null) alt_c = alt_ratio * Math.sin(toRad(alt_C));

                 res.alt = { a: alt_a, b: alt_b, c: alt_c, A: alt_A, B: alt_B, C: alt_C };
             }
          }
      }

      return res;
    }

    function calculate() {
      const a = inputs[0].value !== '' ? parseFloat(inputs[0].value) : null;
      const b = inputs[1].value !== '' ? parseFloat(inputs[1].value) : null;
      const c = inputs[2].value !== '' ? parseFloat(inputs[2].value) : null;
      const A = inputs[3].value !== '' ? parseFloat(inputs[3].value) : null;
      const B = inputs[4].value !== '' ? parseFloat(inputs[4].value) : null;
      const C = inputs[5].value !== '' ? parseFloat(inputs[5].value) : null;

      errorEl.style.display = 'none';
      resultsContainer.style.display = 'none';
      altResultsContainer.style.display = 'none';

      // Need at least 3 values
      let count = [a,b,c,A,B,C].filter(v => v !== null).length;
      if (count < 3) return;

      const result = solveTriangle(a, b, c, A, B, C);

      if (result.error) {
        errorEl.textContent = result.error;
        errorEl.style.display = 'block';
        return;
      }

      // Display primary result
      resultsContainer.innerHTML = `
        <div class="result-card"><div class="result-label">Side a</div><div class="result-value">${result.a.toFixed(2)}</div></div>
        <div class="result-card"><div class="result-label">Side b</div><div class="result-value">${result.b.toFixed(2)}</div></div>
        <div class="result-card"><div class="result-label">Side c</div><div class="result-value">${result.c.toFixed(2)}</div></div>
        <div class="result-card"><div class="result-label">Angle A</div><div class="result-value">${result.A.toFixed(2)}°</div></div>
        <div class="result-card"><div class="result-label">Angle B</div><div class="result-value">${result.B.toFixed(2)}°</div></div>
        <div class="result-card"><div class="result-label">Angle C</div><div class="result-value">${result.C.toFixed(2)}°</div></div>
      `;
      resultsContainer.style.display = 'grid';

      // Display alternative result (SSA Ambiguous Case)
      if (result.alt) {
        altResultsContainer.innerHTML = `
          <div style="grid-column: 1 / -1; text-align: center; font-weight: bold; color: var(--accent-color); margin-bottom: 1rem;">Alternative Solution (Ambiguous Case)</div>
          <div class="result-card"><div class="result-label">Side a</div><div class="result-value">${result.alt.a.toFixed(2)}</div></div>
          <div class="result-card"><div class="result-label">Side b</div><div class="result-value">${result.alt.b.toFixed(2)}</div></div>
          <div class="result-card"><div class="result-label">Side c</div><div class="result-value">${result.alt.c.toFixed(2)}</div></div>
          <div class="result-card"><div class="result-label">Angle A</div><div class="result-value">${result.alt.A.toFixed(2)}°</div></div>
          <div class="result-card"><div class="result-label">Angle B</div><div class="result-value">${result.alt.B.toFixed(2)}°</div></div>
          <div class="result-card"><div class="result-label">Angle C</div><div class="result-value">${result.alt.C.toFixed(2)}°</div></div>
        `;
        altResultsContainer.style.display = 'grid';
      }
    }

    inputs.forEach(input => {
      input.addEventListener('input', calculate);
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .input-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group label { font-size: 0.9rem; font-weight: 600; color: var(--text-secondary); }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .error-message { color: #ef4444; font-size: 0.9rem; margin-top: 0.5rem; display: none; text-align: center; font-weight: 600; }

    .results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1.5rem; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; text-align: center; }
    .result-label { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
    .result-value { font-size: 2rem; font-weight: 800; color: var(--accent-color); }

    .explainer { line-height: 1.7; color: var(--text-primary); margin-top: 3rem; }
    .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; }
