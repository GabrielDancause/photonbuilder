---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Fraction Calculator: Add, Subtract, Multiply & Divide",
  description: "Stop struggling with complicated math. Our interactive fraction calculator solves any equation instantly—with step-by-step working. You will never dread fractions again.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased",
      "url": "https://photonbuilder.com/mathtools"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you add or subtract fractions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To add or subtract fractions, you first need to find a common denominator (the bottom number). Once both fractions share the same denominator, you simply add or subtract the numerators (the top numbers) while keeping the denominator exactly the same. Finally, simplify the resulting fraction if possible."
        }
      },
      {
        "@type": "Question",
        "name": "How do you multiply fractions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Multiplying fractions is straightforward: you multiply the numerators straight across to get the new numerator, and multiply the denominators straight across to get the new denominator. No common denominator is needed. Afterward, simplify the result."
        }
      },
      {
        "@type": "Question",
        "name": "How do you divide fractions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To divide fractions, you use a method often called 'Keep, Change, Flip'. Keep the first fraction as it is, change the division sign to a multiplication sign, and flip the second fraction upside down (which is called taking the reciprocal). Then, multiply the two fractions together normally."
        }
      },
      {
        "@type": "Question",
        "name": "What is a mixed number?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A mixed number is a whole number combined with a proper fraction, for example, 1 1/2. To perform operations on mixed numbers, it is usually easiest to convert them into improper fractions first (where the numerator is larger than the denominator), perform the operation, and then convert the result back to a mixed number if necessary."
        }
      },
      {
        "@type": "Question",
        "name": "How do I simplify a fraction?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To simplify (or reduce) a fraction, you need to divide both the numerator and the denominator by their Greatest Common Divisor (GCD). The GCD is the largest number that divides evenly into both numbers. When you can no longer divide them by the same whole number, the fraction is fully simplified."
        }
      }
    ]
  }
];
---

<SiteLayout site="mathtools" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/mathtools/fraction-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Fraction Calculator</h1>
      <p class="subtitle">Instantly add, subtract, multiply, and divide fractions and mixed numbers.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-row">
        <!-- Fraction 1 -->
        <div class="fraction-input-group">
          <label>Fraction 1</label>
          <div class="fraction-inputs">
            <input type="number" id="whole1" placeholder="Whole" />
            <div class="frac-parts">
              <input type="number" id="num1" placeholder="Num" value="1" />
              <div class="frac-line"></div>
              <input type="number" id="den1" placeholder="Den" value="2" />
            </div>
          </div>
          <div class="error-msg" id="err1">Denominator cannot be zero.</div>
        </div>

        <!-- Operator -->
        <div class="operator-group">
          <select id="operator">
            <option value="+">+</option>
            <option value="-">−</option>
            <option value="*">×</option>
            <option value="/">÷</option>
          </select>
        </div>

        <!-- Fraction 2 -->
        <div class="fraction-input-group">
          <label>Fraction 2</label>
          <div class="fraction-inputs">
            <input type="number" id="whole2" placeholder="Whole" />
            <div class="frac-parts">
              <input type="number" id="num2" placeholder="Num" value="1" />
              <div class="frac-line"></div>
              <input type="number" id="den2" placeholder="Den" value="4" />
            </div>
          </div>
          <div class="error-msg" id="err2">Denominator cannot be zero.</div>
        </div>
      </div>

      <div class="result-card">
        <h3>Result</h3>
        <div class="result-display" id="result-display">
          <span class="res-num">3</span>
          <span class="res-slash">/</span>
          <span class="res-den">4</span>
        </div>
        <div class="decimal-result" id="decimal-result">= 0.75</div>
        <div class="error-msg" id="main-error" style="text-align: center; margin-top: 1rem; font-size: 1rem;"></div>
      </div>
    </div>

    <div class="explainer">
      <h2>How to Calculate Fractions Like a Pro</h2>
      <p>
        Fractions can often seem intimidating, but once you break down the fundamental rules, calculating them becomes a straightforward process. A fraction represents a part of a whole. It consists of two numbers: the <strong>numerator</strong> (the top number), which indicates how many parts you have, and the <strong>denominator</strong> (the bottom number), which indicates how many parts make up a whole.
      </p>

      <h3>Adding and Subtracting Fractions</h3>
      <p>
        The golden rule of adding and subtracting fractions is that they must share a <strong>common denominator</strong>. You cannot directly add 1/2 and 1/4 because the pieces are different sizes.
      </p>
      <ul>
        <li><strong>Step 1:</strong> Find the Least Common Multiple (LCM) of the two denominators. This becomes your new common denominator.</li>
        <li><strong>Step 2:</strong> Convert both fractions to have this new denominator. Whatever you multiply the bottom by to get the new denominator, you must also multiply the top by.</li>
        <li><strong>Step 3:</strong> Once the denominators match, add or subtract the numerators. Leave the denominator exactly as it is.</li>
        <li><strong>Step 4:</strong> Simplify the resulting fraction by finding the Greatest Common Divisor (GCD) of the new numerator and denominator.</li>
      </ul>

      <h3>Multiplying Fractions</h3>
      <p>
        Multiplying fractions is much simpler than adding or subtracting because you do not need to find a common denominator.
      </p>
      <ul>
        <li><strong>Step 1:</strong> Multiply the numerators straight across.</li>
        <li><strong>Step 2:</strong> Multiply the denominators straight across.</li>
        <li><strong>Step 3:</strong> Simplify the resulting fraction.</li>
      </ul>
      <p>
        For example, to multiply 2/3 by 4/5: (2 × 4) / (3 × 5) = 8/15.
      </p>

      <h3>Dividing Fractions</h3>
      <p>
        Dividing fractions uses a trick commonly remembered as <strong>"Keep, Change, Flip"</strong>.
      </p>
      <ul>
        <li><strong>Keep</strong> the first fraction exactly as it is.</li>
        <li><strong>Change</strong> the division sign to a multiplication sign.</li>
        <li><strong>Flip</strong> the second fraction upside down (this is called its reciprocal).</li>
      </ul>
      <p>
        Once you have flipped the second fraction, you simply multiply straight across using the multiplication rules above.
      </p>

      <h3>Dealing with Mixed Numbers</h3>
      <p>
        A mixed number is a whole number combined with a fraction, such as 2 1/2. When calculating with mixed numbers, the most reliable method is to convert them into <strong>improper fractions</strong> first. An improper fraction is one where the numerator is larger than the denominator.
      </p>
      <p>
        To convert a mixed number to an improper fraction:
        <br />
        1. Multiply the whole number by the denominator.
        <br />
        2. Add the numerator to that result.
        <br />
        3. Put that final number over the original denominator.
      </p>
      <p>
        For instance, to convert 2 1/2: Multiply 2 by 2 to get 4. Add the numerator 1 to get 5. The improper fraction is 5/2. After performing your operations, you can convert the final improper fraction back into a mixed number.
      </p>

      <h3>Related Tools</h3>
      <p>
        If you are using fractions to calculate dietary portions or macronutrient splits, be sure to check out our <a href="/tdee-calculator">TDEE Calculator</a> to figure out your baseline caloric needs first.
      </p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How do you add or subtract fractions?</summary>
        <p>To add or subtract fractions, you first need to find a common denominator (the bottom number). Once both fractions share the same denominator, you simply add or subtract the numerators (the top numbers) while keeping the denominator exactly the same. Finally, simplify the resulting fraction if possible.</p>
      </details>
      <details>
        <summary>How do you multiply fractions?</summary>
        <p>Multiplying fractions is straightforward: you multiply the numerators straight across to get the new numerator, and multiply the denominators straight across to get the new denominator. No common denominator is needed. Afterward, simplify the result.</p>
      </details>
      <details>
        <summary>How do you divide fractions?</summary>
        <p>To divide fractions, you use a method often called "Keep, Change, Flip". Keep the first fraction as it is, change the division sign to a multiplication sign, and flip the second fraction upside down (which is called taking the reciprocal). Then, multiply the two fractions together normally.</p>
      </details>
      <details>
        <summary>What is a mixed number?</summary>
        <p>A mixed number is a whole number combined with a proper fraction, for example, 1 1/2. To perform operations on mixed numbers, it is usually easiest to convert them into improper fractions first (where the numerator is larger than the denominator), perform the operation, and then convert the result back to a mixed number if necessary.</p>
      </details>
      <details>
        <summary>How do I simplify a fraction?</summary>
        <p>To simplify (or reduce) a fraction, you need to divide both the numerator and the denominator by their Greatest Common Divisor (GCD). The GCD is the largest number that divides evenly into both numbers. When you can no longer divide them by the same whole number, the fraction is fully simplified.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    // Inputs
    const w1Input = document.getElementById('whole1');
    const n1Input = document.getElementById('num1');
    const d1Input = document.getElementById('den1');

    const w2Input = document.getElementById('whole2');
    const n2Input = document.getElementById('num2');
    const d2Input = document.getElementById('den2');

    const opSelect = document.getElementById('operator');

    // Errors
    const err1 = document.getElementById('err1');
    const err2 = document.getElementById('err2');
    const mainErr = document.getElementById('main-error');

    // Display
    const resDisplay = document.getElementById('result-display');
    const decResult = document.getElementById('decimal-result');

    // Helper: GCD
    function gcd(a, b) {
      a = Math.abs(a);
      b = Math.abs(b);
      while (b) {
        let temp = b;
        b = a % b;
        a = temp;
      }
      return a;
    }

    function parseFraction(wStr, nStr, dStr) {
      let w = parseInt(wStr) || 0;
      let n = parseInt(nStr) || 0;
      let d = parseInt(dStr) || 1;

      if (d === 0) return null;

      // Convert mixed to improper
      if (w < 0) {
        n = (w * d) - Math.abs(n);
      } else {
        n = (w * d) + n;
      }
      return { n, d };
    }

    function calculateFraction() {
      const f1 = parseFraction(w1Input.value, n1Input.value, d1Input.value);
      const f2 = parseFraction(w2Input.value, n2Input.value, d2Input.value);

      let hasError = false;

      // Validation
      if (!f1 && d1Input.value !== "") {
        err1.style.display = 'block';
        hasError = true;
      } else {
        err1.style.display = 'none';
      }

      if (!f2 && d2Input.value !== "") {
        err2.style.display = 'block';
        hasError = true;
      } else {
        err2.style.display = 'none';
      }

      if (hasError || !f1 || !f2) {
        resDisplay.innerHTML = '<span>--</span>';
        decResult.textContent = '';
        mainErr.style.display = 'none';
        return;
      }

      const op = opSelect.value;
      let resN, resD;

      if (op === '+') {
        resN = (f1.n * f2.d) + (f2.n * f1.d);
        resD = f1.d * f2.d;
      } else if (op === '-') {
        resN = (f1.n * f2.d) - (f2.n * f1.d);
        resD = f1.d * f2.d;
      } else if (op === '*') {
        resN = f1.n * f2.n;
        resD = f1.d * f2.d;
      } else if (op === '/') {
        if (f2.n === 0) {
          mainErr.textContent = 'Cannot divide by zero.';
          mainErr.style.display = 'block';
          resDisplay.innerHTML = '<span>--</span>';
          decResult.textContent = '';
          return;
        }
        resN = f1.n * f2.d;
        resD = f1.d * f2.n;
      }

      mainErr.style.display = 'none';

      // Simplify
      const divisor = gcd(resN, resD);
      resN = resN / divisor;
      resD = resD / divisor;

      // Handle negatives
      if (resD < 0) {
        resN = -resN;
        resD = -resD;
      }

      // Format output
      const decValue = resN / resD;

      let html = '';
      if (resD === 1) {
        html = `<span class="res-num" style="font-size: 3rem;">${resN}</span>`;
      } else {
        // Convert back to mixed for display if appropriate
        let w = 0;
        let remN = Math.abs(resN);
        let displaySign = resN < 0 ? '-' : '';

        if (remN >= resD) {
          w = Math.floor(remN / resD);
          remN = remN % resD;
        }

        if (w > 0 && remN > 0) {
          html = `
            <span class="res-whole" style="font-size: 2.5rem; margin-right: 0.5rem;">${displaySign}${w}</span>
            <div style="display: inline-flex; flex-direction: column; vertical-align: middle;">
              <span class="res-num">${remN}</span>
              <div style="height: 2px; background: var(--accent-color); margin: 2px 0;"></div>
              <span class="res-den">${resD}</span>
            </div>
          `;
        } else if (w > 0 && remN === 0) {
           html = `<span class="res-num" style="font-size: 3rem;">${displaySign}${w}</span>`;
        } else {
          html = `
            <div style="display: inline-flex; flex-direction: column; vertical-align: middle;">
              <span class="res-num">${resN}</span>
              <div style="height: 2px; background: var(--accent-color); margin: 2px 0;"></div>
              <span class="res-den">${resD}</span>
            </div>
          `;
        }
      }

      resDisplay.innerHTML = html;
      decResult.textContent = `= ${decValue.toLocaleString(undefined, { maximumFractionDigits: 4 })}`;
    }

    [w1Input, n1Input, d1Input, w2Input, n2Input, d2Input, opSelect].forEach(input => {
      input.addEventListener('input', calculateFraction);
    });

    // Initial calc
    calculateFraction();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2.5rem;
      margin: 2rem 0;
    }

    .calc-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .calc-row {
        flex-direction: column;
      }
      .fraction-input-group {
        width: 100%;
      }
    }

    .fraction-input-group {
      flex: 1;
      min-width: 200px;
    }

    .fraction-input-group label {
      display: block;
      margin-bottom: 0.75rem;
      font-weight: 600;
      color: var(--text-primary);
      text-align: center;
    }

    .fraction-inputs {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }

    .frac-parts {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      width: 80px;
    }

    .frac-line {
      height: 2px;
      background: var(--text-primary);
      width: 100%;
    }

    input, select {
      background: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.5rem;
      border-radius: 8px;
      width: 100%;
      font-size: 1.1rem;
      text-align: center;
    }

    #whole1, #whole2 {
      width: 80px;
      height: 60px;
      font-size: 1.5rem;
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .operator-group {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 1.5rem;
    }

    #operator {
      font-size: 2rem;
      width: 70px;
      height: 70px;
      padding: 0;
      text-align: center;
      border-radius: 50%;
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border: 2px solid var(--accent-color);
      color: var(--accent-color);
      font-weight: bold;
      appearance: none;
      cursor: pointer;
    }

    .error-msg {
      color: #ef4444;
      font-size: 0.85rem;
      margin-top: 0.5rem;
      display: none;
      text-align: center;
    }

    .result-card {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border: 1px solid var(--accent-color);
      border-radius: 12px;
      padding: 2rem;
      margin: 3rem 0 1.5rem;
      text-align: center;
    }

    .result-card h3 {
      margin: 0 0 1.5rem 0;
      color: var(--text-primary);
    }

    .result-display {
      font-weight: 800;
      color: var(--accent-color);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 80px;
    }

    .res-num, .res-den {
      font-size: 1.8rem;
      line-height: 1.2;
    }

    .res-slash {
      font-size: 2.5rem;
      margin: 0 0.5rem;
      font-weight: 300;
    }

    .decimal-result {
      margin-top: 1.5rem;
      font-size: 1.2rem;
      color: var(--text-secondary);
      font-weight: 600;
    }

    .explainer {
      margin: 3rem 0;
      line-height: 1.7;
    }

    .explainer h2, .explainer h3 {
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    .explainer p {
      margin-bottom: 1rem;
      color: var(--text-secondary);
    }

    .explainer ul {
      margin-left: 1.5rem;
      margin-bottom: 1.5rem;
      color: var(--text-secondary);
    }

    .explainer li {
      margin-bottom: 0.5rem;
    }

    .explainer a {
      color: var(--accent-color);
      text-decoration: none;
      font-weight: 600;
    }

    .explainer a:hover {
      text-decoration: underline;
    }

    .faq-section {
      margin-top: 3rem;
    }

    .faq-section details {
      margin: 1rem 0;
      padding: 1rem;
      background: var(--card-bg);
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .faq-section summary {
      font-weight: 600;
      cursor: pointer;
      color: var(--text-primary);
    }

    .faq-section details p {
      margin-top: 1rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>
</SiteLayout>
