---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Interactive Lubricant Comparison Tool",
  "description": "Find the perfect lubricant for your needs. Filter by base type, toy compatibility, condom safety, and sensitivity to find your ideal match.",
  "author": {
    "@type": "Organization",
    "name": "The Nookie Nook"
  },
  "publisher": {
    "@type": "Organization",
    "name": "The Nookie Nook",
    "logo": {
      "@type": "ImageObject",
      "url": "https://thenookienook.com/logo.png"
    }
  },
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I choose the right lube?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Choose based on your activity. If using silicone toys, use water-based. If using latex condoms, use water or silicone-based. If playing in water, use silicone-based."
        }
      },
      {
        "@type": "Question",
        "name": "Which lube is best for sensitive skin?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "High-quality silicone lubes or glycerin-free, paraben-free water-based lubes (like pure aloe vera) are best for sensitive skin."
        }
      },
      {
        "@type": "Question",
        "name": "Can I mix different types of lube?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Generally, it's best not to mix them as they can separate or become clumpy, but mixing water-based and silicone-based on the body is usually harmless. Never mix oil with latex."
        }
      }
    ]
  }
};
---

<SiteLayout
  site="nookienook"
  title="Interactive Lube Comparison Tool | The Nookie Nook"
  description="Find the perfect lubricant for your needs. Filter by base type, toy compatibility, condom safety, and sensitivity to find your ideal match."
  canonical="https://thenookienook.com/lube-comparison-tool"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Lube Comparison Tool</h1>
      <p>Filter by your needs to find the safest, most effective lubricant for your body and activities.</p>
    </div>

    <div class="content">
      <p>Not sure which lubricant to choose? Use the filters below to narrow down your options based on what barriers you are using, what toys you have, and your specific bodily needs.</p>

      <div class="tool-container">
        <div class="filters">
          <h3>Filter By Your Needs:</h3>

          <div class="filter-group">
            <label><strong>Condom Compatibility:</strong></label>
            <div><input type="checkbox" id="condom-latex" value="latex" onchange="filterLubes()"> <label for="condom-latex">Using Latex/Polyisoprene Condoms</label></div>
          </div>

          <div class="filter-group">
            <label><strong>Toy Compatibility:</strong></label>
            <div><input type="checkbox" id="toy-silicone" value="silicone-toy" onchange="filterLubes()"> <label for="toy-silicone">Using Silicone Toys</label></div>
          </div>

          <div class="filter-group">
            <label><strong>Activity / Environment:</strong></label>
            <div><input type="checkbox" id="env-water" value="water-play" onchange="filterLubes()"> <label for="env-water">Water Play (Shower/Bath)</label></div>
            <div><input type="checkbox" id="env-anal" value="anal" onchange="filterLubes()"> <label for="env-anal">Anal Sex (Needs thick/long-lasting)</label></div>
          </div>

          <div class="filter-group">
            <label><strong>Sensitivity:</strong></label>
            <div><input type="checkbox" id="sens-yeast" value="yeast-prone" onchange="filterLubes()"> <label for="sens-yeast">Prone to Yeast Infections</label></div>
          </div>

          <button onclick="clearFilters()" class="clear-btn">Clear Filters</button>
        </div>

        <div class="results-grid" id="lube-results">
          <!-- Populated by JS -->
        </div>
      </div>

      <p style="margin-top: 2rem;"><em>This tool is part of our comprehensive <a href="/sites/nookienook/lubricant-guide">Ultimate Guide to Personal Lubricants</a>.</em></p>

      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <h3>How do I choose the right lube?</h3>
        <p>Choose based on your activity. If using silicone toys, use water-based. If using latex condoms, use water or silicone-based. If playing in water, use silicone-based.</p>

        <h3>Which lube is best for sensitive skin?</h3>
        <p>High-quality silicone lubes or glycerin-free, paraben-free water-based lubes (like pure aloe vera) are best for sensitive skin.</p>

        <h3>Can I mix different types of lube?</h3>
        <p>Generally, it's best not to mix them as they can separate or become clumpy, but mixing water-based and silicone-based on the body is usually harmless. Never mix oil with latex.</p>
      </div>
    </div>
  </div>

  <script is:inline>
    const lubes = [
      {
        id: "wb-standard",
        name: "Standard Water-Based",
        link: "/sites/nookienook/water-based-lube-guide",
        desc: "Versatile, easy cleanup. May contain glycerin.",
        tags: ["latex", "silicone-toy"],
        excludes: ["water-play", "yeast-prone", "anal"]
      },
      {
        id: "wb-gf",
        name: "Glycerin-Free Water-Based",
        link: "/sites/nookienook/water-based-lube-guide",
        desc: "Ideal for everyday use and sensitive vaginal flora.",
        tags: ["latex", "silicone-toy", "yeast-prone"],
        excludes: ["water-play", "anal"]
      },
      {
        id: "silicone",
        name: "Silicone-Based",
        link: "/sites/nookienook/silicone-lube-guide",
        desc: "Long-lasting, waterproof, never gets sticky.",
        tags: ["latex", "water-play", "anal", "yeast-prone"],
        excludes: ["silicone-toy"]
      },
      {
        id: "aloe",
        name: "Pure Aloe Vera (Natural Water-Based)",
        link: "/sites/nookienook/natural-lube-guide",
        desc: "Soothing natural option, body safe.",
        tags: ["latex", "silicone-toy", "yeast-prone"],
        excludes: ["water-play", "anal"]
      },
      {
        id: "oil",
        name: "Oil-Based (e.g., Coconut Oil)",
        link: "/sites/nookienook/oil-based-lube-guide",
        desc: "Great for massage and external play. Destroys latex.",
        tags: ["water-play", "anal", "silicone-toy"],
        excludes: ["latex", "yeast-prone"]
      }
    ];

    function filterLubes() {
      const latex = document.getElementById('condom-latex').checked;
      const siliconeToy = document.getElementById('toy-silicone').checked;
      const waterPlay = document.getElementById('env-water').checked;
      const anal = document.getElementById('env-anal').checked;
      const yeastProne = document.getElementById('sens-yeast').checked;

      const activeRequirements = [];
      if (latex) activeRequirements.push("latex");
      if (siliconeToy) activeRequirements.push("silicone-toy");
      if (waterPlay) activeRequirements.push("water-play");
      if (anal) activeRequirements.push("anal");
      if (yeastProne) activeRequirements.push("yeast-prone");

      const resultsContainer = document.getElementById('lube-results');
      resultsContainer.innerHTML = '';

      let matchCount = 0;

      lubes.forEach(lube => {
        let isMatch = true;

        // Check if lube has all required tags
        // And check if lube specifically excludes an active requirement
        for (const req of activeRequirements) {
          if (!lube.tags.includes(req) && lube.excludes.includes(req)) {
              isMatch = false;
              break;
          }
          if (lube.excludes.includes(req)) {
              isMatch = false;
              break;
          }
        }

        if (isMatch) {
          matchCount++;
          const card = document.createElement('div');
          card.className = 'lube-card';
          card.innerHTML = `
            <h4><a href="${lube.link}">${lube.name}</a></h4>
            <p>${lube.desc}</p>
          `;
          resultsContainer.appendChild(card);
        }
      });

      if (matchCount === 0) {
        resultsContainer.innerHTML = '<p style="color: var(--text-secondary); padding: 1rem;">No single lubricant matches all these strict criteria. Consider changing your barrier method or toy material for this specific activity.</p>';
      }
    }

    function clearFilters() {
      document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
      filterLubes();
    }

    // Initialize
    filterLubes();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .content a { color: var(--accent-color); text-decoration: none; font-weight: 600; }
    .content a:hover { text-decoration: underline; }

    .tool-container {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-top: 2rem;
    }
    @media (min-width: 768px) {
      .tool-container { flex-direction: row; align-items: flex-start; }
    }

    .filters {
      flex: 1;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .filters h3 { margin-top: 0; margin-bottom: 1rem; color: var(--text-primary); }

    .filter-group { margin-bottom: 1.25rem; }
    .filter-group label strong { color: var(--text-primary); display: block; margin-bottom: 0.5rem; }
    .filter-group div { margin-bottom: 0.25rem; color: var(--text-secondary); }

    .clear-btn {
      background: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.5rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      width: 100%;
      margin-top: 1rem;
    }
    .clear-btn:hover { background: var(--border-color); }

    .results-grid {
      flex: 2;
      display: grid;
      gap: 1rem;
    }

    .lube-card {
      background: var(--card-bg);
      border: 1px solid var(--accent-color);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .lube-card h4 { margin-top: 0; margin-bottom: 0.5rem; font-size: 1.2rem; }
    .lube-card p { margin: 0; color: var(--text-secondary); line-height: 1.5; }

    .faq-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 3rem 0 2rem; }
    .faq-section h2 { border-bottom: none; margin-top: 0; padding-bottom: 0; color: var(--text-primary); }
    .faq-section h3 { font-size: 1.1rem; margin-top: 1rem; color: var(--text-primary); }
    .faq-section p { color: var(--text-secondary); margin-bottom: 1rem; line-height: 1.6; }
  </style>
</SiteLayout>
