---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "The Nookie Nook",
  "url": "https://thenookienook.com",
  "description": "Evidence-based sexual health education. Guides, tools, and research for a healthier, more informed life."
};
---

<SiteLayout
  site="nookienook"
  title="The Nookie Nook — Sexual Health & Education"
  description="Evidence-based sexual health education. Guides, tools, and research for a healthier, more informed life."
  canonical="https://thenookienook.com"
  schema={schema}
>
  <div class="home-content">
    <div class="hero">
      <h1>The Nookie Nook</h1>
      <p class="tagline">Evidence-based sexual health education for everyone.</p>
      <p class="subtitle">Guides, tools, and research — informed, inclusive, and shame-free.</p>
    </div>

    <section id="guides" class="section">
      <h2 class="section-title">📚 Guides</h2>
      <div class="cards-grid">
        <a href="/sites/nookienook/lubricant-guide" class="resource-card">
          <h3>The Ultimate Guide to Personal Lubricants</h3>
          <p>Everything about personal lubricants: types, ingredients, compatibility, and health considerations.</p>
        </a>
        <a href="/sites/nookienook/water-based-lube-guide" class="resource-card">
          <h3>Water-Based Lubricants Guide</h3>
          <p>Pros, cons, best uses, and what you need to know about the most versatile lube type.</p>
        </a>
        <a href="/sites/nookienook/silicone-lube-guide" class="resource-card">
          <h3>Silicone Lubricants Guide</h3>
          <p>Long-lasting slip, water resistance, and the crucial rules for toy compatibility.</p>
        </a>
        <a href="/sites/nookienook/oil-based-lube-guide" class="resource-card">
          <h3>Oil-Based Lubricants Guide</h3>
          <p>The slickest option available, but with critical warnings for condom users.</p>
        </a>
        <a href="/sites/nookienook/natural-lube-guide" class="resource-card">
          <h3>Natural & Organic Lubricants</h3>
          <p>Navigating marketing claims to find truly body-safe, plant-based options.</p>
        </a>
        <a href="/sites/nookienook/sexual-health-guide" class="resource-card">
          <h3>The Comprehensive Guide to Sexual Health</h3>
          <p>Your definitive resource for navigating anatomy, STIs, contraception, and overall well-being.</p>
        </a>
        <a href="/sites/nookienook/consent-communication-guide" class="resource-card">
          <h3>Consent & Communication Guide</h3>
          <p>Learn the enthusiastic consent model and how to safely communicate your boundaries and desires.</p>
        </a>
        <a href="/sites/nookienook/guide-talking-to-doctor" class="resource-card">
          <h3>Talking to Your Doctor</h3>
          <p>Overcome embarrassment and learn how to advocate for yourself with medical professionals.</p>
        </a>
        <a href="/sites/nookienook/pleasure-anatomy-guide" class="resource-card">
          <h3>Anatomy & Pleasure Guide</h3>
          <p>Understand your body, erogenous zones, and the science of the arousal response cycle.</p>
        </a>
      </div>
    </section>

    <section id="tools" class="section">
      <h2 class="section-title">🔧 Tools</h2>
      <div class="cards-grid">
        <a href="/sites/nookienook/lube-comparison-tool" class="resource-card">
          <h3>Lube Comparison Tool</h3>
          <p>Filter by your needs to find the safest, most effective lubricant for your body and activities.</p>
        </a>
        <a href="/sites/nookienook/contraception-comparison" class="resource-card">
          <h3>Contraception Comparison</h3>
          <p>An interactive tool to filter and compare birth control methods side-by-side.</p>
        </a>
        <a href="/sites/nookienook/fertility-window-calculator" class="resource-card">
          <h3>Fertility Window Calculator</h3>
          <p>Estimate your ovulation day and fertile window based on your menstrual cycle.</p>
        </a>
        <a href="/sites/nookienook/sexual-health-myths" class="resource-card">
          <h3>Myth vs. Fact Quiz</h3>
          <p>Test your knowledge on common sexual health myths and learn the science-backed truth.</p>
        </a>
        <a href="/sites/nookienook/relationship-health-check" class="resource-card">
          <h3>Relationship Health Check</h3>
          <p>Assess your relationship's communication, boundaries, and intimacy with this self-reflection tool.</p>
        </a>
      </div>
    </section>

    <section id="studies" class="section">
      <h2 class="section-title">📊 Studies & Deep Dives</h2>
      <div class="cards-grid">
        <a href="/sites/nookienook/lube-ingredients-safety" class="resource-card">
          <h3>Lube Ingredient Safety Guide</h3>
          <p>Decoding the label: Osmolality, pH, and toxic ingredients to avoid.</p>
        </a>
        <a href="/sites/nookienook/lube-and-condoms" class="resource-card">
          <h3>Lube & Condoms Compatibility</h3>
          <p>Which lubes prevent breakage, and which ones destroy your protection.</p>
        </a>
        <a href="/sites/nookienook/lube-for-menopause" class="resource-card">
          <h3>Lubricants for Menopause</h3>
          <p>Finding relief and comfort when natural lubrication decreases.</p>
        </a>
        <a href="/sites/nookienook/sti-testing-guide" class="resource-card">
          <h3>Complete STI Testing Guide</h3>
          <p>Detailed information on window periods, testing frequency, and what to expect at the clinic.</p>
        </a>
      </div>
    </section>
  </div>

  <style is:inline>
    .home-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 4rem 0 3rem; }
    .hero h1 { font-size: 2.8rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .tagline { font-size: 1.3rem; color: var(--accent-color); margin-bottom: 0.5rem; font-weight: 500; }
    .subtitle { color: var(--text-secondary); font-size: 1rem; }

    .section { margin: 3rem 0; }
    .section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }

    .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }

    .resource-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      text-decoration: none;
      transition: transform 0.2s, border-color 0.2s;
      display: flex;
      flex-direction: column;
    }

    .resource-card:hover {
      border-color: var(--accent-color);
      transform: translateY(-3px);
    }

    .resource-card h3 {
      color: var(--accent-color);
      font-size: 1.2rem;
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    .resource-card p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      margin-bottom: 0;
      line-height: 1.5;
    }
  </style>
</SiteLayout>
