    "author": {
      "@type": "Organization",
      "name": "The Nookie Nook",
      "url": "https://thenookienook.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are some good spring date ideas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Great spring dates include visiting a farmers market, hiking, viewing cherry blossoms, or taking an outdoor yoga class."
        }
      },
      {
        "@type": "Question",
        "name": "What are fun summer dates?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fun summer date ideas involve a beach day, catching a drive-in movie, relaxing at a rooftop bar, or kayaking."
        }
      },
      {
        "@type": "Question",
        "name": "What are the best fall dates?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The best fall dates are apple picking, exploring a haunted house, sitting by a bonfire, or going wine tasting."
        }
      },
      {
        "@type": "Question",
        "name": "How to plan a winter date?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A perfect winter date could be ice skating, going on a hot chocolate crawl, taking a cooking class, or a museum day."
        }
      },
      {
        "@type": "Question",
        "name": "How are these date ideas categorized?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "These 100 date ideas are categorized by season, and each includes a budget estimate and an effort level."
        }
      }
    ]
  }
];

