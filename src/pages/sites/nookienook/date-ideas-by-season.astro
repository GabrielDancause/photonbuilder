export const meta = {
  title: 'Seasonal Date Ideas for Spring, Summer, Fall & Winter',
  description: 'Browse 100 date ideas organized by season, from spring hikes to winter ice skating. Each idea includes budget estimates and effort levels to help you plan.',
  category: 'guide',
  publishedDate: new Date().toISOString()
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
