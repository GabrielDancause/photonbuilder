---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate my ovulation date?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ovulation typically occurs about 14 days before your next period. To estimate your ovulation date, subtract 14 from your average cycle length and count that many days from the first day of your last period. For example, with a 28-day cycle, ovulation is expected around day 14."
      }
    },
    {
      "@type": "Question",
      "name": "What is the fertile window?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The fertile window is the approximately 6-day period each cycle when pregnancy is possible. It includes the 5 days before ovulation and the day of ovulation itself. Sperm can survive in the reproductive tract for up to 5 days, while an egg is viable for about 12-24 hours after release."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate is an ovulation calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ovulation calculators provide estimates based on average cycle lengths and are most accurate for people with regular cycles. However, ovulation can vary by several days each cycle due to stress, illness, travel, or hormonal fluctuations. For greater accuracy, combine calculator estimates with ovulation predictor kits (OPKs), basal body temperature tracking, or cervical mucus monitoring."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get pregnant outside my fertile window?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Conception is extremely unlikely outside the fertile window. However, because ovulation timing can shift unpredictably, the actual fertile window may differ from what a calculator predicts. This is why fertility awareness methods have a higher typical-use failure rate than perfect-use rate. If you are trying to avoid pregnancy, use reliable contraception throughout your cycle."
      }
    },
    {
      "@type": "Question",
      "name": "What are the signs that I am ovulating?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common signs of ovulation include a slight rise in basal body temperature (0.5–1°F), changes in cervical mucus to a clear and stretchy egg-white consistency, mild one-sided pelvic pain (mittelschmerz), breast tenderness, increased libido, and a positive ovulation predictor kit result indicating an LH surge."
      }
    },
    {
      "@type": "Question",
      "name": "What is the luteal phase and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The luteal phase is the second half of your menstrual cycle, from ovulation to the start of your next period. It typically lasts 10-16 days and is relatively consistent for each individual. A short luteal phase (less than 10 days) may make it harder to sustain a pregnancy and could indicate a hormonal imbalance worth discussing with your doctor."
      }
    },
    {
      "@type": "Question",
      "name": "How does cycle length affect ovulation timing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "With longer cycles, ovulation occurs later. With shorter cycles, it occurs earlier. The luteal phase (post-ovulation) stays relatively constant at around 14 days, so the variation happens in the follicular phase (pre-ovulation). For a 21-day cycle, ovulation may be around day 7; for a 35-day cycle, around day 21."
      }
    },
    {
      "@type": "Question",
      "name": "Can stress or illness affect my ovulation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Physical or emotional stress, illness, significant weight changes, excessive exercise, travel, and disrupted sleep can all delay or suppress ovulation. This is because the hypothalamic-pituitary-ovarian axis that controls ovulation is sensitive to stress hormones like cortisol. If your cycle becomes irregular, consult a healthcare provider."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use an ovulation calculator to prevent pregnancy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An ovulation calculator alone is not a reliable method of contraception. Fertility awareness-based methods require daily tracking of multiple fertility signs (temperature, cervical mucus, cycle length) and have a typical-use failure rate of about 23%. If you want to avoid pregnancy, use a proven contraceptive method and consult your healthcare provider."
      }
    }
  ]
};

export const meta = {
  title: "Ovulation Calculator — Find Your Fertile Window",
  description: "Free ovulation calculator and fertility calendar. Enter your last period date and cycle length to find your ovulation date, fertile window, and next 3 months of cycles.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="nookienook"
  title="Ovulation Calculator — Find Your Fertile Window"
  description="Free ovulation calculator and fertility calendar. Enter your last period date and cycle length to find your ovulation date, fertile window, and next 3 months of cycles."
  canonical="https://thenookienook.com/ovulation-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Ovulation Calculator</h1>
      <p>Estimate your ovulation date, fertile window, and upcoming cycles based on your menstrual cycle. Track when you're most likely to conceive.</p>
    </div>

    <div class="disclaimer">
      <strong>Medical Disclaimer:</strong> This ovulation calculator provides estimates only and is not a substitute for professional medical advice. Ovulation timing varies and can be affected by stress, illness, and other factors. Do not rely on this tool as a method of contraception. Always consult a qualified healthcare provider for fertility or family planning guidance.
    </div>

    <section class="content-section">

      <h2>Calculate Your Fertile Window</h2>
      <div class="calc-form">
        <div class="form-row">
          <div class="form-group">
            <label for="last-period">First Day of Last Period</label>
            <input type="date" id="last-period" />
          </div>
          <div class="form-group">
            <label for="cycle-length">Average Cycle Length (days)</label>
            <div class="cycle-input-wrap">
              <button class="cycle-btn" id="cycle-minus" aria-label="Decrease cycle length">−</button>
              <input type="number" id="cycle-length" min="21" max="35" value="28" />
              <button class="cycle-btn" id="cycle-plus" aria-label="Increase cycle length">+</button>
            </div>
            <span class="form-hint">Normal range: 21–35 days</span>
          </div>
        </div>
        <button class="calc-btn" id="calculate-btn">Calculate Ovulation</button>
      </div>

      <div id="results-section" style="display:none;">

        <h2>Your Results</h2>
        <div class="results-grid">
          <div class="result-card result-ovulation">
            <div class="result-label">Estimated Ovulation Date</div>
            <div class="result-value" id="ovulation-date"></div>
            <div class="result-sub">Most fertile day</div>
          </div>
          <div class="result-card result-fertile">
            <div class="result-label">Fertile Window</div>
            <div class="result-value" id="fertile-window"></div>
            <div class="result-sub">6 days of peak fertility</div>
          </div>
          <div class="result-card result-period">
            <div class="result-label">Next Period Expected</div>
            <div class="result-value" id="next-period"></div>
            <div class="result-sub" id="next-period-days"></div>
          </div>
        </div>

        <h2>Cycle Phase Breakdown</h2>
        <div class="phase-bar" id="phase-bar">
          <div class="phase menstrual" id="phase-menstrual"><span>Menstrual</span></div>
          <div class="phase follicular" id="phase-follicular"><span>Follicular</span></div>
          <div class="phase ovulation" id="phase-ovulation"><span>Ovulation</span></div>
          <div class="phase luteal" id="phase-luteal"><span>Luteal</span></div>
        </div>
        <div class="phase-details">
          <div class="phase-card">
            <div class="phase-dot menstrual-dot"></div>
            <div>
              <h4>Menstrual Phase (Days 1–5)</h4>
              <p>The uterine lining sheds, resulting in your period. Hormone levels (estrogen and progesterone) are at their lowest. Typical duration is 3–7 days.</p>
            </div>
          </div>
          <div class="phase-card">
            <div class="phase-dot follicular-dot"></div>
            <div>
              <h4 id="follicular-label">Follicular Phase (Days 1–<span class="follicular-end"></span>)</h4>
              <p>Begins on day 1 and overlaps with menstruation. Rising estrogen stimulates follicle development in the ovaries. The uterine lining thickens in preparation for a potential pregnancy.</p>
            </div>
          </div>
          <div class="phase-card">
            <div class="phase-dot ovulation-dot"></div>
            <div>
              <h4 id="ovulation-label">Ovulation (Day <span class="ov-day"></span>)</h4>
              <p>A surge in luteinizing hormone (LH) triggers the release of a mature egg from the ovary. The egg is viable for 12–24 hours. This is your most fertile day.</p>
            </div>
          </div>
          <div class="phase-card">
            <div class="phase-dot luteal-dot"></div>
            <div>
              <h4 id="luteal-label">Luteal Phase (Days <span class="luteal-start"></span>–<span class="cycle-end"></span>)</h4>
              <p>After ovulation, the empty follicle becomes the corpus luteum and produces progesterone. If the egg isn't fertilized, hormone levels drop, and the cycle resets with your next period.</p>
            </div>
          </div>
        </div>

        <h2>Fertility Calendar</h2>
        <div class="calendar-legend">
          <span class="legend-item"><span class="legend-dot legend-period"></span> Period</span>
          <span class="legend-item"><span class="legend-dot legend-fertile"></span> Fertile window</span>
          <span class="legend-item"><span class="legend-dot legend-ovulation"></span> Ovulation day</span>
          <span class="legend-item"><span class="legend-dot legend-today"></span> Today</span>
        </div>
        <div class="calendars" id="calendars"></div>

        <h2>Next 3 Cycles</h2>
        <div class="upcoming-table-wrap">
          <table class="upcoming-table" id="upcoming-table">
            <thead>
              <tr>
                <th>Cycle</th>
                <th>Period Start</th>
                <th>Fertile Window</th>
                <th>Ovulation Date</th>
                <th>Next Period</th>
              </tr>
            </thead>
            <tbody id="upcoming-tbody"></tbody>
          </table>
        </div>
      </div>

      <h2>Signs of Ovulation</h2>
      <div class="signs-grid">
        <div class="sign-card">
          <div class="sign-icon">🌡️</div>
          <h3>Basal Body Temperature Rise</h3>
          <p>Your resting temperature increases by 0.5–1°F after ovulation due to progesterone. Track it each morning before getting out of bed with a basal thermometer to confirm ovulation has occurred.</p>
        </div>
        <div class="sign-card">
          <div class="sign-icon">💧</div>
          <h3>Cervical Mucus Changes</h3>
          <p>As ovulation approaches, cervical mucus becomes clear, slippery, and stretchy — resembling raw egg whites. This "fertile-quality" mucus helps sperm travel to the egg and is a strong ovulation indicator.</p>
        </div>
        <div class="sign-card">
          <div class="sign-icon">📊</div>
          <h3>Positive OPK (LH Surge)</h3>
          <p>Ovulation predictor kits detect the surge in luteinizing hormone (LH) that occurs 24–36 hours before ovulation. A positive result means ovulation is imminent — this is one of the most reliable at-home indicators.</p>
        </div>
        <div class="sign-card">
          <div class="sign-icon">🤏</div>
          <h3>Mittelschmerz (Ovulation Pain)</h3>
          <p>About 20% of people experience mild, one-sided lower abdominal pain during ovulation. This "middle pain" can last minutes to hours and alternates sides between cycles as ovaries take turns releasing an egg.</p>
        </div>
        <div class="sign-card">
          <div class="sign-icon">💗</div>
          <h3>Increased Libido</h3>
          <p>Many people notice heightened sexual desire around ovulation, driven by the estrogen peak that precedes the LH surge. This is a natural biological signal aligned with peak fertility.</p>
        </div>
        <div class="sign-card">
          <div class="sign-icon">🔘</div>
          <h3>Cervical Position Changes</h3>
          <p>During ovulation, the cervix becomes softer, higher, more open, and wetter (remembered by the acronym SHOW). Between fertile days, it's firmer, lower, and closed. Checking cervical position takes practice but adds another data point.</p>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>

      <div class="card">
        <h3>How do I calculate my ovulation date?</h3>
        <p>Ovulation typically occurs about 14 days before your next period. Subtract 14 from your average cycle length and count that many days forward from the first day of your last period. For a 28-day cycle, that's around day 14. For a 30-day cycle, it's around day 16. This calculator automates that math and shows your full fertile window.</p>
      </div>

      <div class="card">
        <h3>What is the fertile window?</h3>
        <p>The fertile window spans approximately 6 days: the 5 days before ovulation plus the day of ovulation itself. Sperm can survive in the reproductive tract for up to 5 days, while a released egg is viable for 12–24 hours. Intercourse during any of these days can result in pregnancy, with the highest probability on the day before and the day of ovulation.</p>
      </div>

      <div class="card">
        <h3>How accurate is an ovulation calculator?</h3>
        <p>Ovulation calculators are most accurate for people with regular, consistent cycles. They estimate based on averages — actual ovulation can shift by several days due to stress, illness, sleep changes, or travel. For greater precision, pair calculator predictions with ovulation predictor kits, basal body temperature charting, and cervical mucus observation.</p>
      </div>

      <div class="card">
        <h3>Can I get pregnant outside my fertile window?</h3>
        <p>Conception is extremely unlikely outside the fertile window. However, because the exact day of ovulation can vary from cycle to cycle, the calculated window is an estimate. If you're trying to avoid pregnancy, use a proven contraceptive method rather than relying on cycle predictions alone.</p>
      </div>

      <div class="card">
        <h3>What are the signs that I am ovulating?</h3>
        <p>Common ovulation signs include a rise in basal body temperature, cervical mucus that becomes clear and stretchy (like egg whites), mild one-sided pelvic pain, breast tenderness, increased sex drive, and a positive ovulation predictor kit showing an LH surge. Not everyone experiences all signs, and their intensity varies.</p>
      </div>

      <div class="card">
        <h3>What is the luteal phase and why does it matter?</h3>
        <p>The luteal phase runs from ovulation to your next period and typically lasts 10–16 days. It's relatively consistent for each person. A short luteal phase (under 10 days) may make implantation difficult and could indicate a hormonal issue. If you suspect a short luteal phase, talk to your healthcare provider about progesterone testing.</p>
      </div>

      <div class="card">
        <h3>How does cycle length affect ovulation timing?</h3>
        <p>The luteal phase (post-ovulation) stays roughly constant at about 14 days, so variation in cycle length reflects changes in the follicular phase (pre-ovulation). A 21-day cycle means ovulation around day 7; a 35-day cycle means ovulation around day 21. This is why knowing your cycle length matters for accurate predictions.</p>
      </div>

      <div class="card">
        <h3>Can stress or illness affect my ovulation?</h3>
        <p>Yes. Stress, illness, drastic weight changes, excessive exercise, and disrupted sleep can all delay or prevent ovulation. The hormonal axis controlling ovulation is sensitive to cortisol and other stress hormones. If your cycles become irregular or you stop ovulating, consult a healthcare provider to rule out underlying conditions.</p>
      </div>

      <div class="card">
        <h3>Should I use an ovulation calculator to prevent pregnancy?</h3>
        <p>No. An ovulation calculator alone is not a reliable contraceptive method. Fertility awareness-based methods require tracking multiple signs daily and still have a typical-use failure rate of about 23%. If pregnancy prevention is your goal, use a proven method like an IUD, implant, or hormonal contraceptive, and consult your healthcare provider.</p>
      </div>

      <h2>Related Tools &amp; Guides</h2>
      <ul>
        <li><a href="/birth-control-comparison-chart">Birth Control Comparison Chart</a> — Compare 15+ contraceptive methods side-by-side</li>
        <li><a href="/pregnancy-due-date-calculator">Pregnancy Due Date Calculator</a> — Estimate your due date based on your last period or conception date</li>
        <li><a href="/fertility-awareness-methods">Fertility Awareness Methods Guide</a> — Learn to track your cycle for natural family planning</li>
        <li><a href="/fertility-window-calculator">Fertility Window Calculator</a> — Another approach to finding your most fertile days</li>
      </ul>
    </section>
  </div>

  <script is:inline>
  (function() {
    var lastPeriodInput = document.getElementById('last-period');
    var cycleLengthInput = document.getElementById('cycle-length');
    var calcBtn = document.getElementById('calculate-btn');
    var resultsSection = document.getElementById('results-section');

    // Set default date to today
    var today = new Date();
    lastPeriodInput.value = formatDateInput(today);

    // Cycle length +/- buttons
    document.getElementById('cycle-minus').addEventListener('click', function() {
      var v = parseInt(cycleLengthInput.value) || 28;
      if (v > 21) cycleLengthInput.value = v - 1;
    });
    document.getElementById('cycle-plus').addEventListener('click', function() {
      var v = parseInt(cycleLengthInput.value) || 28;
      if (v < 35) cycleLengthInput.value = v + 1;
    });

    calcBtn.addEventListener('click', calculate);

    function formatDateInput(d) {
      var y = d.getFullYear();
      var m = String(d.getMonth() + 1).padStart(2, '0');
      var day = String(d.getDate()).padStart(2, '0');
      return y + '-' + m + '-' + day;
    }

    function formatDate(d) {
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
    }

    function formatShort(d) {
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[d.getMonth()] + ' ' + d.getDate();
    }

    function addDays(d, n) {
      var result = new Date(d);
      result.setDate(result.getDate() + n);
      return result;
    }

    function daysBetween(a, b) {
      return Math.round((b - a) / (1000 * 60 * 60 * 24));
    }

    function sameDay(a, b) {
      return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate();
    }

    function calculate() {
      var dateVal = lastPeriodInput.value;
      var cycleLen = parseInt(cycleLengthInput.value);

      if (!dateVal) { alert('Please enter the first day of your last period.'); return; }
      if (cycleLen < 21 || cycleLen > 35) { alert('Cycle length must be between 21 and 35 days.'); return; }

      // Parse date in local timezone
      var parts = dateVal.split('-');
      var periodStart = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));

      var ovulationDay = cycleLen - 14;
      var ovulationDate = addDays(periodStart, ovulationDay);
      var fertileStart = addDays(ovulationDate, -5);
      var fertileEnd = addDays(ovulationDate, 1);
      var nextPeriod = addDays(periodStart, cycleLen);

      // Display results
      document.getElementById('ovulation-date').textContent = formatDate(ovulationDate);
      document.getElementById('fertile-window').textContent = formatShort(fertileStart) + ' – ' + formatShort(fertileEnd);
      document.getElementById('next-period').textContent = formatDate(nextPeriod);

      var daysUntil = daysBetween(today, nextPeriod);
      document.getElementById('next-period-days').textContent = daysUntil > 0 ? daysUntil + ' days from today' : daysUntil === 0 ? 'Today' : Math.abs(daysUntil) + ' days ago';

      // Phase bar widths
      var menstrualPct = (5 / cycleLen * 100).toFixed(1);
      var follicularPct = ((ovulationDay - 5) / cycleLen * 100).toFixed(1);
      var ovulationPct = (3 / cycleLen * 100).toFixed(1);
      var lutealPct = ((cycleLen - ovulationDay - 1) / cycleLen * 100).toFixed(1);

      document.getElementById('phase-menstrual').style.width = menstrualPct + '%';
      document.getElementById('phase-follicular').style.width = follicularPct + '%';
      document.getElementById('phase-ovulation').style.width = ovulationPct + '%';
      document.getElementById('phase-luteal').style.width = lutealPct + '%';

      // Phase labels
      var follicularEndEls = document.querySelectorAll('.follicular-end');
      for (var i = 0; i < follicularEndEls.length; i++) follicularEndEls[i].textContent = ovulationDay;
      var ovDayEls = document.querySelectorAll('.ov-day');
      for (var i = 0; i < ovDayEls.length; i++) ovDayEls[i].textContent = ovulationDay;
      var lutealStartEls = document.querySelectorAll('.luteal-start');
      for (var i = 0; i < lutealStartEls.length; i++) lutealStartEls[i].textContent = ovulationDay + 1;
      var cycleEndEls = document.querySelectorAll('.cycle-end');
      for (var i = 0; i < cycleEndEls.length; i++) cycleEndEls[i].textContent = cycleLen;

      // Build calendars for current + next 2 cycles
      var cycles = [];
      for (var c = 0; c < 3; c++) {
        var cStart = addDays(periodStart, c * cycleLen);
        var cOv = addDays(cStart, ovulationDay);
        cycles.push({
          periodStart: cStart,
          periodEnd: addDays(cStart, 4),
          fertileStart: addDays(cOv, -5),
          fertileEnd: addDays(cOv, 1),
          ovulation: cOv,
          nextPeriod: addDays(cStart, cycleLen)
        });
      }

      renderCalendars(cycles);
      renderUpcomingTable(cycles);

      resultsSection.style.display = 'block';
      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function renderCalendars(cycles) {
      var container = document.getElementById('calendars');
      container.innerHTML = '';

      // Determine the month range to show
      var allMonths = {};
      for (var c = 0; c < cycles.length; c++) {
        var cy = cycles[c];
        var dates = [cy.periodStart, cy.periodEnd, cy.fertileStart, cy.fertileEnd, cy.ovulation, cy.nextPeriod];
        for (var d = 0; d < dates.length; d++) {
          var key = dates[d].getFullYear() + '-' + dates[d].getMonth();
          allMonths[key] = { year: dates[d].getFullYear(), month: dates[d].getMonth() };
        }
      }

      var monthList = Object.values(allMonths).sort(function(a, b) {
        return a.year !== b.year ? a.year - b.year : a.month - b.month;
      });

      var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      var dayNames = ['Su','Mo','Tu','We','Th','Fr','Sa'];

      for (var mi = 0; mi < monthList.length; mi++) {
        var m = monthList[mi];
        var cal = document.createElement('div');
        cal.className = 'calendar-month';

        var header = document.createElement('div');
        header.className = 'cal-header';
        header.textContent = monthNames[m.month] + ' ' + m.year;
        cal.appendChild(header);

        var dayRow = document.createElement('div');
        dayRow.className = 'cal-days';
        for (var di = 0; di < 7; di++) {
          var dh = document.createElement('div');
          dh.className = 'cal-day-name';
          dh.textContent = dayNames[di];
          dayRow.appendChild(dh);
        }
        cal.appendChild(dayRow);

        var grid = document.createElement('div');
        grid.className = 'cal-grid';

        var firstDay = new Date(m.year, m.month, 1).getDay();
        var daysInMonth = new Date(m.year, m.month + 1, 0).getDate();

        for (var b = 0; b < firstDay; b++) {
          var blank = document.createElement('div');
          blank.className = 'cal-cell empty';
          grid.appendChild(blank);
        }

        for (var day = 1; day <= daysInMonth; day++) {
          var cell = document.createElement('div');
          cell.className = 'cal-cell';
          cell.textContent = day;

          var thisDate = new Date(m.year, m.month, day);
          var cls = getDateClass(thisDate, cycles);
          if (cls) cell.classList.add(cls);
          if (sameDay(thisDate, today)) cell.classList.add('cal-today');

          grid.appendChild(cell);
        }

        cal.appendChild(grid);
        container.appendChild(cal);
      }
    }

    function getDateClass(date, cycles) {
      for (var c = 0; c < cycles.length; c++) {
        var cy = cycles[c];
        if (sameDay(date, cy.ovulation)) return 'cal-ovulation';
        if (date >= cy.fertileStart && date <= cy.fertileEnd) return 'cal-fertile';
        if (date >= cy.periodStart && date <= cy.periodEnd) return 'cal-period';
      }
      return null;
    }

    function renderUpcomingTable(cycles) {
      var tbody = document.getElementById('upcoming-tbody');
      tbody.innerHTML = '';
      for (var c = 0; c < cycles.length; c++) {
        var cy = cycles[c];
        var tr = document.createElement('tr');
        tr.innerHTML =
          '<td>Cycle ' + (c + 1) + '</td>' +
          '<td>' + formatDate(cy.periodStart) + '</td>' +
          '<td>' + formatShort(cy.fertileStart) + ' – ' + formatShort(cy.fertileEnd) + '</td>' +
          '<td><strong>' + formatDate(cy.ovulation) + '</strong></td>' +
          '<td>' + formatDate(cy.nextPeriod) + '</td>';
        tbody.appendChild(tr);
      }
    }
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; }

    .disclaimer { background: #fef3c7; border: 1px solid #f59e0b; border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 2rem; font-size: 0.92rem; color: #92400e; line-height: 1.5; }
    @media (prefers-color-scheme: dark) {
      .disclaimer { background: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.3); color: #fbbf24; }
    }

