---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the 5 love languages?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The five love languages, developed by Dr. Gary Chapman, are Words of Affirmation (verbal expressions of love), Acts of Service (doing helpful things for your partner), Receiving Gifts (thoughtful presents and gestures), Quality Time (giving undivided attention), and Physical Touch (physical closeness and affection). Everyone has a primary love language that makes them feel most loved."
      }
    },
    {
      "@type": "Question",
      "name": "How do I find out my love language?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Take a love language quiz that presents pairs of statements representing different love languages and choose which resonates more with you. After answering all questions, the quiz tallies your responses across the five categories. Your highest-scoring category is your primary love language, and your second-highest is your secondary love language."
      }
    },
    {
      "@type": "Question",
      "name": "Can my love language change over time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, your love language can shift over time due to life experiences, relationship changes, personal growth, or different life stages. For example, someone who valued Quality Time may later prioritize Acts of Service after becoming a busy parent. It is a good idea to retake the quiz periodically and communicate any changes with your partner."
      }
    },
    {
      "@type": "Question",
      "name": "What if my partner and I have different love languages?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Having different love languages is very common and completely normal. The key is learning your partner's love language and making an effort to express love in the way they receive it best, even if it does not come naturally to you. Open communication about each other's needs and consistent small efforts in your partner's love language can significantly strengthen your relationship."
      }
    },
    {
      "@type": "Question",
      "name": "Is one love language better than another?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No love language is better or worse than another. Each is a valid way of giving and receiving love. Most people have a primary and secondary love language, and all five languages play some role in a healthy relationship. The goal is not to rank the languages but to understand which ones matter most to you and your partner so you can love each other more effectively."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate is a love language quiz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Love language quizzes are helpful self-reflection tools, but they are not clinical assessments. Your results depend on honest self-evaluation and may vary based on your mood or current relationship context. Use your results as a conversation starter with your partner rather than a definitive label. Retaking the quiz over time gives a more complete picture of your preferences."
      }
    },
    {
      "@type": "Question",
      "name": "Do love languages apply to non-romantic relationships?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, love languages apply to all close relationships including friendships, parent-child relationships, and family bonds. Understanding how the people in your life prefer to give and receive love can improve communication and deepen connection across all types of relationships, not just romantic ones."
      }
    }
  ]
};

export const meta = {
  title: "Love Language Quiz — Discover Your Love Language",
  description: "Free love language quiz with 20 questions. Find your primary and secondary love language from the 5 love languages, see your scores, and get tips for your relationship.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="nookienook"
  title="Love Language Quiz — Discover Your Love Language"
  description="Free love language quiz with 20 questions. Find your primary and secondary love language from the 5 love languages, see your scores, and get tips for your relationship."
  canonical="https://thenookienook.com/love-language-quiz"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Love Language Quiz</h1>
      <p>Answer 20 questions to discover how you prefer to give and receive love. Find your primary love language and learn how to strengthen your relationships.</p>
    </div>

    <section class="content-section">

      <h2>What Is My Love Language?</h2>
      <p>The five love languages — Words of Affirmation, Acts of Service, Receiving Gifts, Quality Time, and Physical Touch — describe the ways people prefer to express and experience love. This quiz helps you identify which love language resonates most with you by presenting 20 pairs of statements. Choose the one that feels more meaningful in each pair.</p>

      <div id="quiz-section">
        <div class="quiz-progress">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">Question 1 of 20</div>
        </div>

        <div class="quiz-card" id="quiz-card">
          <div class="question-number" id="question-number">1</div>
          <p class="question-prompt">Which statement feels more meaningful to you?</p>
          <button class="choice-btn" id="choice-a"></button>
          <button class="choice-btn" id="choice-b"></button>
        </div>
      </div>

      <div id="results-section" style="display:none;">

        <h2>Your Love Language Results</h2>

        <div class="results-summary">
          <div class="result-primary">
            <div class="result-badge">Primary Love Language</div>
            <div class="result-lang" id="primary-lang"></div>
            <p class="result-desc" id="primary-desc"></p>
          </div>
          <div class="result-secondary">
            <div class="result-badge secondary-badge">Secondary Love Language</div>
            <div class="result-lang" id="secondary-lang"></div>
            <p class="result-desc" id="secondary-desc"></p>
          </div>
        </div>

        <h2>Your Score Breakdown</h2>
        <div class="chart-container" id="chart-container"></div>

        <h2>Understanding the 5 Love Languages</h2>

        <div class="lang-grid">
          <div class="lang-card">
            <div class="lang-icon">💬</div>
            <h3>Words of Affirmation</h3>
            <p>You feel most loved when your partner expresses affection verbally — compliments, "I love you," encouragement, and appreciation. Words carry real emotional weight for you.</p>
            <div class="lang-tips">
              <h4>Tips for Partners</h4>
              <ul>
                <li>Leave unexpected notes or texts expressing what you love about them</li>
                <li>Verbalize your appreciation for specific things they do</li>
                <li>Offer genuine compliments regularly, not just on special occasions</li>
                <li>Use encouraging words when they face challenges</li>
              </ul>
            </div>
          </div>

          <div class="lang-card">
            <div class="lang-icon">🤝</div>
            <h3>Acts of Service</h3>
            <p>Actions speak louder than words for you. When your partner helps with tasks, takes something off your plate, or does thoughtful things without being asked, you feel deeply cared for.</p>
            <div class="lang-tips">
              <h4>Tips for Partners</h4>
              <ul>
                <li>Take over a chore or task they normally handle without being asked</li>
                <li>Cook a meal or prepare something they enjoy</li>
                <li>Follow through on promises and commitments</li>
                <li>Notice when they are overwhelmed and offer concrete help</li>
              </ul>
            </div>
          </div>

          <div class="lang-card">
            <div class="lang-icon">🎁</div>
            <h3>Receiving Gifts</h3>
            <p>Thoughtful gifts make you feel loved — not because of their price, but because they show your partner was thinking of you. The effort, symbolism, and thoughtfulness behind a gift matter most.</p>
            <div class="lang-tips">
              <h4>Tips for Partners</h4>
              <ul>
                <li>Bring home small, thoughtful surprises (their favorite snack, a book they mentioned)</li>
                <li>Remember dates and milestones with meaningful gifts</li>
                <li>Pick up souvenirs when traveling to show you thought of them</li>
                <li>Create handmade or personalized items for extra meaning</li>
              </ul>
            </div>
          </div>

          <div class="lang-card">
            <div class="lang-icon">⏰</div>
            <h3>Quality Time</h3>
            <p>Undivided attention is what makes you feel most connected. When your partner puts away distractions and focuses entirely on being present with you, it fills your emotional tank.</p>
            <div class="lang-tips">
              <h4>Tips for Partners</h4>
              <ul>
                <li>Put your phone away during conversations and meals together</li>
                <li>Plan regular date nights or dedicated one-on-one time</li>
                <li>Engage in activities you both enjoy together</li>
                <li>Make eye contact and actively listen when they are talking</li>
              </ul>
            </div>
          </div>

          <div class="lang-card">
            <div class="lang-icon">🤗</div>
            <h3>Physical Touch</h3>
            <p>Physical closeness is how you feel most connected — hugs, hand-holding, a touch on the shoulder, or sitting close together. Physical affection communicates love, safety, and belonging for you.</p>
            <div class="lang-tips">
              <h4>Tips for Partners</h4>
              <ul>
                <li>Greet them and say goodbye with a hug or kiss</li>
                <li>Hold hands while walking or sit close on the couch</li>
                <li>Offer a back rub or shoulder massage after a long day</li>
                <li>Initiate casual physical contact throughout the day</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="action-buttons">
          <button class="action-btn share-btn" id="share-btn">Share Results</button>
          <button class="action-btn retake-btn" id="retake-btn">Retake Quiz</button>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>

      <div class="card">
        <h3>What are the 5 love languages?</h3>
        <p>The five love languages, developed by Dr. Gary Chapman, are Words of Affirmation (verbal expressions of love), Acts of Service (doing helpful things), Receiving Gifts (thoughtful presents and gestures), Quality Time (giving undivided attention), and Physical Touch (physical closeness and affection). Everyone has a primary love language that makes them feel most loved, and understanding it can transform your relationships.</p>
      </div>

      <div class="card">
        <h3>How do I find out my love language?</h3>
        <p>The best way is to take a love language quiz like the one above. It presents pairs of statements representing different love languages, and you choose which resonates more with you. After 20 questions, your scores are tallied across the five categories. Your highest-scoring category is your primary love language, and your second-highest is your secondary love language.</p>
      </div>

      <div class="card">
        <h3>Can my love language change over time?</h3>
        <p>Yes. Your love language can shift due to life experiences, relationship changes, personal growth, or new life stages. A person who valued Quality Time may later prioritize Acts of Service after becoming a busy parent. Retake the quiz every year or so and discuss any changes with your partner to keep your relationship in sync.</p>
      </div>

      <div class="card">
        <h3>What if my partner and I have different love languages?</h3>
        <p>This is very common and completely normal. The key is learning your partner's love language and making a genuine effort to express love in the way they receive it best, even if it doesn't come naturally to you. Share your quiz results with each other and discuss specific ways you can meet each other's needs.</p>
      </div>

      <div class="card">
        <h3>Is one love language better than another?</h3>
        <p>No love language is better or worse than another. Each is a valid way of giving and receiving love. Most people have a primary and secondary love language, and all five play some role in a healthy relationship. The goal isn't to rank the languages but to understand which ones matter most to you and your partner.</p>
      </div>

      <div class="card">
        <h3>How accurate is a love language quiz?</h3>
        <p>Love language quizzes are useful self-reflection tools, but they aren't clinical assessments. Your results may vary depending on your mood, current relationship context, or life stage. Use your results as a conversation starter rather than a fixed label. Retaking the quiz periodically gives a more complete picture of how your preferences evolve.</p>
      </div>

      <div class="card">
        <h3>Do love languages apply to non-romantic relationships?</h3>
        <p>Absolutely. Love languages apply to friendships, parent-child bonds, and family relationships too. Understanding how the people in your life prefer to give and receive love can improve communication and deepen connection across all relationship types, not just romantic partnerships.</p>
      </div>

      <h2>Related Tools &amp; Guides</h2>
      <ul>
        <li><a href="/best-date-ideas">Best Date Ideas</a> — Creative and fun date night inspiration for every love language</li>
        <li><a href="/birth-control-comparison-chart">Birth Control Comparison Chart</a> — Compare 15+ contraceptive methods side-by-side</li>
      </ul>
    </section>
  </div>

  <script is:inline>
  (function() {
    var questions = [
      { a: { text: "I feel loved when my partner tells me they appreciate me", lang: "words" }, b: { text: "I feel loved when my partner helps me with a task without being asked", lang: "service" } },
      { a: { text: "I feel loved when my partner gives me a thoughtful gift", lang: "gifts" }, b: { text: "I feel loved when my partner gives me their full, undivided attention", lang: "time" } },
      { a: { text: "I feel loved when my partner holds my hand or puts their arm around me", lang: "touch" }, b: { text: "I feel loved when my partner says something encouraging to me", lang: "words" } },
      { a: { text: "I feel loved when my partner takes care of something I've been dreading", lang: "service" }, b: { text: "I feel loved when my partner surprises me with a small present", lang: "gifts" } },
      { a: { text: "I feel loved when my partner and I spend uninterrupted time together", lang: "time" }, b: { text: "I feel loved when my partner hugs me or shows physical affection", lang: "touch" } },
      { a: { text: "I feel loved when my partner gives me a genuine compliment", lang: "words" }, b: { text: "I feel loved when my partner plans a special outing just for us", lang: "time" } },
      { a: { text: "I feel loved when my partner brings me a surprise that shows they were thinking of me", lang: "gifts" }, b: { text: "I feel loved when my partner cuddles with me on the couch", lang: "touch" } },
      { a: { text: "I feel loved when my partner does the dishes or cleans up without me asking", lang: "service" }, b: { text: "I feel loved when my partner writes me a heartfelt note or message", lang: "words" } },
      { a: { text: "I feel loved when my partner sits close to me and we physically connect", lang: "touch" }, b: { text: "I feel loved when my partner handles errands so I can relax", lang: "service" } },
      { a: { text: "I feel loved when my partner and I have a deep, meaningful conversation", lang: "time" }, b: { text: "I feel loved when my partner remembers a special occasion with a gift", lang: "gifts" } },
      { a: { text: "I feel loved when my partner says 'I love you' and means it", lang: "words" }, b: { text: "I feel loved when my partner gives me a long, warm hug", lang: "touch" } },
      { a: { text: "I feel loved when my partner cooks a meal or makes me coffee", lang: "service" }, b: { text: "I feel loved when my partner puts away distractions and listens to me", lang: "time" } },
      { a: { text: "I feel loved when my partner picks out a gift that is perfect for me", lang: "gifts" }, b: { text: "I feel loved when my partner verbally supports me in front of others", lang: "words" } },
      { a: { text: "I feel loved when my partner and I take a walk together, just the two of us", lang: "time" }, b: { text: "I feel loved when my partner fixes something around the house for me", lang: "service" } },
      { a: { text: "I feel loved when my partner gives me a back rub after a long day", lang: "touch" }, b: { text: "I feel loved when my partner brings home a little something just because", lang: "gifts" } },
      { a: { text: "I feel loved when my partner speaks kindly about me to friends and family", lang: "words" }, b: { text: "I feel loved when my partner runs an errand I was going to do", lang: "service" } },
      { a: { text: "I feel loved when my partner sets aside time for just the two of us each week", lang: "time" }, b: { text: "I feel loved when my partner reaches for my hand when we're walking", lang: "touch" } },
      { a: { text: "I feel loved when my partner wraps a gift with thought and care", lang: "gifts" }, b: { text: "I feel loved when my partner takes over bedtime or morning routines", lang: "service" } },
      { a: { text: "I feel loved when my partner tells me exactly what they love about me", lang: "words" }, b: { text: "I feel loved when my partner and I enjoy a shared hobby or activity", lang: "time" } },
      { a: { text: "I feel loved when my partner greets me with a kiss or embrace", lang: "touch" }, b: { text: "I feel loved when my partner gives me a meaningful gift on my birthday", lang: "gifts" } }
    ];

    var descriptions = {
      words: "Words of Affirmation",
      service: "Acts of Service",
      gifts: "Receiving Gifts",
      time: "Quality Time",
      touch: "Physical Touch"
    };

    var longDescriptions = {
      words: "You feel most loved through verbal expressions — compliments, words of encouragement, frequent \"I love you\"s, and hearing what your partner appreciates about you. Harsh or careless words can hurt you deeply.",
      service: "Actions speak louder than words for you. When someone helps with tasks, takes care of responsibilities, or goes out of their way to make your life easier, it fills your emotional tank. Laziness or broken promises feel especially hurtful.",
      gifts: "Thoughtful gifts make you feel seen and remembered. It's not about the price tag — it's the thought, effort, and symbolism behind the gesture. A forgotten birthday or thoughtless gift can feel like a lack of care.",
      time: "Undivided attention is what makes you feel most connected. Being truly present — putting away phones, making eye contact, sharing experiences — is how you know your partner values you. Distractions or canceled plans feel like a rejection.",
      touch: "Physical closeness — hugs, hand-holding, a reassuring touch, sitting together — is how you feel safe and loved. Physical presence and affection communicate what words cannot for you. Physical neglect or distance can leave you feeling unloved."
    };

    var colors = {
      words: "#3b82f6",
      service: "#22c55e",
      gifts: "#eab308",
      time: "#a855f7",
      touch: "#ef4444"
    };

    var scores = { words: 0, service: 0, gifts: 0, time: 0, touch: 0 };
    var currentQ = 0;

    var quizSection = document.getElementById('quiz-section');
    var resultsSection = document.getElementById('results-section');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var questionNumber = document.getElementById('question-number');
    var choiceA = document.getElementById('choice-a');
    var choiceB = document.getElementById('choice-b');

    function showQuestion() {
      var q = questions[currentQ];
      progressFill.style.width = (currentQ / questions.length * 100) + '%';
      progressText.textContent = 'Question ' + (currentQ + 1) + ' of ' + questions.length;
      questionNumber.textContent = currentQ + 1;
      choiceA.textContent = q.a.text;
      choiceB.textContent = q.b.text;
      choiceA.className = 'choice-btn';
      choiceB.className = 'choice-btn';
    }

    function selectAnswer(lang) {
      scores[lang]++;
      currentQ++;
      if (currentQ < questions.length) {
        showQuestion();
      } else {
        showResults();
      }
    }

    choiceA.addEventListener('click', function() {
      selectAnswer(questions[currentQ].a.lang);
    });
    choiceB.addEventListener('click', function() {
      selectAnswer(questions[currentQ].b.lang);
    });

    function showResults() {
      quizSection.style.display = 'none';
      resultsSection.style.display = 'block';
      progressFill.style.width = '100%';

      var sorted = Object.keys(scores).sort(function(a, b) { return scores[b] - scores[a]; });
      var primary = sorted[0];
      var secondary = sorted[1];

      document.getElementById('primary-lang').textContent = descriptions[primary];
      document.getElementById('primary-desc').textContent = longDescriptions[primary];
      document.getElementById('secondary-lang').textContent = descriptions[secondary];
      document.getElementById('secondary-desc').textContent = longDescriptions[secondary];

      // Build bar chart
      var maxScore = Math.max.apply(null, Object.values(scores));
      if (maxScore === 0) maxScore = 1;
      var chartContainer = document.getElementById('chart-container');
      chartContainer.innerHTML = '';

      var langOrder = ['words', 'service', 'gifts', 'time', 'touch'];
      for (var i = 0; i < langOrder.length; i++) {
        var lang = langOrder[i];
        var row = document.createElement('div');
        row.className = 'chart-row';

        var label = document.createElement('div');
        label.className = 'chart-label';
        label.textContent = descriptions[lang];

        var barWrap = document.createElement('div');
        barWrap.className = 'chart-bar-wrap';

        var bar = document.createElement('div');
        bar.className = 'chart-bar';
        bar.style.width = (scores[lang] / 8 * 100) + '%';
        bar.style.background = colors[lang];
        bar.style.minWidth = scores[lang] > 0 ? '2rem' : '0';

        var scoreLabel = document.createElement('span');
        scoreLabel.className = 'chart-score';
        scoreLabel.textContent = scores[lang] + '/8';
        bar.appendChild(scoreLabel);

        barWrap.appendChild(bar);

        row.appendChild(label);
        row.appendChild(barWrap);
        chartContainer.appendChild(row);
      }

      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Share button
    document.getElementById('share-btn').addEventListener('click', function() {
      var sorted = Object.keys(scores).sort(function(a, b) { return scores[b] - scores[a]; });
      var text = "My Love Language Results:\n\n";
      text += "Primary: " + descriptions[sorted[0]] + " (" + scores[sorted[0]] + "/8)\n";
      text += "Secondary: " + descriptions[sorted[1]] + " (" + scores[sorted[1]] + "/8)\n\n";
      text += "All scores:\n";
      for (var i = 0; i < sorted.length; i++) {
        text += descriptions[sorted[i]] + ": " + scores[sorted[i]] + "/8\n";
      }
      text += "\nTake the quiz: " + window.location.href;

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
          var btn = document.getElementById('share-btn');
          btn.textContent = 'Copied to Clipboard!';
          setTimeout(function() { btn.textContent = 'Share Results'; }, 2000);
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        var btn = document.getElementById('share-btn');
        btn.textContent = 'Copied to Clipboard!';
        setTimeout(function() { btn.textContent = 'Share Results'; }, 2000);
      }
    });

    // Retake button
    document.getElementById('retake-btn').addEventListener('click', function() {
      scores = { words: 0, service: 0, gifts: 0, time: 0, touch: 0 };
      currentQ = 0;
      resultsSection.style.display = 'none';
      quizSection.style.display = 'block';
      showQuestion();
      quizSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    showQuestion();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; }

    .content-section { margin-top: 1rem; color: var(--text-primary); line-height: 1.6; }
    .content-section h2 { font-size: 1.8rem; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--accent-color); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    .content-section h3 { font-size: 1.4rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
    .content-section p { margin-bottom: 1rem; }
    .content-section ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .content-section li { margin-bottom: 0.5rem; }
    .content-section a { color: var(--accent-color); text-decoration: underline; text-underline-offset: 3px; font-weight: 500; }
    .content-section a:hover { color: var(--text-primary); }

    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); }
    .card h3 { margin-top: 0; color: var(--text-primary); }

    /* Quiz */
    .quiz-progress { margin-bottom: 1.5rem; }
    .progress-bar { height: 8px; background: var(--border-color); border-radius: 4px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--accent-color); border-radius: 4px; transition: width 0.3s ease; }
    .progress-text { text-align: center; font-size: 0.88rem; color: var(--text-secondary); margin-top: 0.5rem; font-weight: 600; }

    .quiz-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 14px; padding: 2rem; text-align: center; }
    .question-number { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%; background: var(--accent-color); color: #fff; font-weight: 800; font-size: 1.1rem; margin-bottom: 1rem; }
    .question-prompt { font-size: 1.05rem; color: var(--text-secondary); margin-bottom: 1.5rem; font-weight: 500; }

    .choice-btn { display: block; width: 100%; padding: 1rem 1.25rem; margin-bottom: 0.75rem; background: var(--page-bg, #fff); border: 2px solid var(--border-color); border-radius: 10px; font-size: 1rem; color: var(--text-primary); cursor: pointer; text-align: left; line-height: 1.5; transition: border-color 0.2s, background 0.2s; }
    .choice-btn:hover { border-color: var(--accent-color); background: rgba(99, 102, 241, 0.05); }
    .choice-btn:last-child { margin-bottom: 0; }

    /* Results */
    .results-summary { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin: 1rem 0 1.5rem; }
    .result-primary, .result-secondary { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 14px; padding: 1.5rem; }
    .result-primary { border-top: 4px solid var(--accent-color); }
