      {
        "@type": "Question",
        "name": "Can consent be withdrawn after it's been given?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, absolutely. Consent is ongoing and reversible. Anyone can stop a sexual activity at any point, even if they previously agreed to it."
        }
