---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is consent?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Consent is an enthusiastic, clear, and freely given agreement to engage in specific sexual activity."
      }
    },
    {
      "@type": "Question",
      "name": "What are STIs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "STIs, or sexually transmitted infections, are infections spread primarily through sexual contact."
      }
    },
    {
      "@type": "Question",
      "name": "What is the pelvic floor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The pelvic floor is a group of muscles that support the pelvic organs, including the bladder, uterus, and bowel."
      }
    },
    {
      "@type": "Question",
      "name": "What is libido?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Libido is the term used to describe a person's overall sexual drive or desire for sexual activity."
      }
    },
    {
      "@type": "Question",
      "name": "What is gender identity?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gender identity is a person's internal, deeply held sense of their gender, which may or may not align with the sex they were assigned at birth."
      }
    }
  ]
};

export const meta = {
  title: "The Complete Sexual Health Glossary — The Nookie Nook",
  description: "A comprehensive glossary of sexual health terms covering anatomy, STIs, contraception, gender identity, relationships, and more.",
  category: "list",
  published: "2026-03-15",
};
---

<SiteLayout
  site="nookienook"
  title="The Complete Sexual Health Glossary — The Nookie Nook"
  description="A comprehensive glossary of sexual health terms covering anatomy, STIs, contraception, gender identity, relationships, and more."
  canonical="https://thenookienook.com/sexual-health-glossary"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>The Complete Sexual Health Glossary</h1>
      <p>Your definitive guide to understanding sexual health terminology, from anatomy and STIs to identity and pleasure.</p>
    </div>

    <section>
      <h2>A Guide to Sexual Health Terms</h2>
      <p>Understanding sexual health starts with knowing the right terms. This comprehensive glossary covers the most important concepts related to human sexuality, reproductive health, and healthy relationships. Whether you are looking to understand your own body better, communicate more effectively with your partner, or stay informed about your health, this guide provides evidence-based definitions.</p>

      <p>We've broken down these terms into key areas of sexual health. You can explore our deep dives into specific topics through the links provided below.</p>
    </section>

    <section class="card">
      <h3>Explore Our Deep Dives</h3>
      <ul>
        <li><a href="/sites/nookienook/what-is-consent">What is Consent?</a> - Legal definitions, enthusiastic consent, and communication.</li>
        <li><a href="/sites/nookienook/what-are-stis">What are STIs?</a> - An overview of sexually transmitted infections, testing, and treatment.</li>
        <li><a href="/sites/nookienook/what-is-pelvic-floor">What is the Pelvic Floor?</a> - Anatomy, exercises, dysfunction, and treatments.</li>
        <li><a href="/sites/nookienook/what-is-libido">What is Libido?</a> - Understanding sexual desire, factors that affect it, and mismatched libidos.</li>
        <li><a href="/sites/nookienook/what-is-vaginismus">What is Vaginismus?</a> - Causes, treatments, and finding help for this condition.</li>
        <li><a href="/sites/nookienook/what-is-erectile-dysfunction">What is Erectile Dysfunction (ED)?</a> - Causes, treatments, myths, and when to see a doctor.</li>
        <li><a href="/sites/nookienook/what-is-gender-identity">What is Gender Identity?</a> - Terminology, the gender spectrum, and affirming care.</li>
        <li><a href="/sites/nookienook/what-is-sexual-orientation">What is Sexual Orientation?</a> - Understanding the spectrum of attraction and identity.</li>
      </ul>
    </section>

    <section>
      <h2>Anatomy & Physiology</h2>
      <dl>
        <dt>Cervix</dt>
        <dd>The lower, narrow end of the uterus that forms a canal between the uterus and vagina.</dd>

        <dt>Clitoris</dt>
        <dd>A small, highly sensitive organ located at the top of the vulva, primarily responsible for sexual pleasure in people with vaginas.</dd>

        <dt>Erectile Dysfunction (ED)</dt>
        <dd>The inability to get or keep an erection firm enough for sexual intercourse. Learn more in our <a href="/sites/nookienook/what-is-erectile-dysfunction">deep dive on ED</a>.</dd>

        <dt>Pelvic Floor</dt>
        <dd>A group of muscles forming a sling across the base of the pelvis, supporting the bladder, uterus, and rectum. Read our <a href="/sites/nookienook/what-is-pelvic-floor">complete guide to the pelvic floor</a>.</dd>

        <dt>Vaginismus</dt>
        <dd>A condition involving an involuntary muscle spasm of the pelvic floor muscles, making vaginal penetration painful or impossible. Find out more in our <a href="/sites/nookienook/what-is-vaginismus">guide to vaginismus</a>.</dd>

        <dt>Vulva</dt>
        <dd>The external female genitalia, including the labia, clitoris, and vaginal opening.</dd>
      </dl>
    </section>

    <section>
      <h2>Desire, Pleasure, and Relationships</h2>
      <dl>
        <dt>Consent</dt>
        <dd>An enthusiastic, freely given, reversible, informed, and specific agreement to engage in sexual activity. Explore the <a href="/sites/nookienook/what-is-consent">nuances of consent</a>.</dd>

        <dt>Libido</dt>
        <dd>A person's overall sexual drive or desire for sexual activity, which can fluctuate over time. Learn about the factors affecting it in our <a href="/sites/nookienook/what-is-libido">libido guide</a>.</dd>

        <dt>Spontaneous Desire</dt>
        <dd>Sexual desire that arises seemingly out of nowhere, without preceding sexual arousal.</dd>

        <dt>Responsive Desire</dt>
        <dd>Sexual desire that emerges in response to sexual stimuli or arousal, rather than preceding it.</dd>
      </dl>
    </section>

    <section>
      <h2>Identity and Orientation</h2>
      <dl>
        <dt>Asexual</dt>
        <dd>A sexual orientation describing someone who experiences little to no sexual attraction to others.</dd>

        <dt>Bisexual</dt>
        <dd>A person who is emotionally, romantically, or sexually attracted to more than one sex, gender, or gender identity.</dd>

        <dt>Cisgender</dt>
        <dd>A term for someone whose gender identity aligns with the sex they were assigned at birth.</dd>

        <dt>Gender Identity</dt>
        <dd>A person's internal, deeply held sense of their gender. Read more in our <a href="/sites/nookienook/what-is-gender-identity">gender identity guide</a>.</dd>

        <dt>Sexual Orientation</dt>
        <dd>An inherent or immutable enduring emotional, romantic, or sexual attraction to other people. Learn about the spectrum in our <a href="/sites/nookienook/what-is-sexual-orientation">sexual orientation guide</a>.</dd>

        <dt>Transgender</dt>
        <dd>An umbrella term for people whose gender identity and/or expression is different from cultural expectations based on the sex they were assigned at birth.</dd>
      </dl>
    </section>

    <section>
      <h2>Infections and Health</h2>
      <dl>
        <dt>HIV/AIDS</dt>
        <dd>Human Immunodeficiency Virus (HIV) is a virus that attacks the body's immune system. Acquired Immunodeficiency Syndrome (AIDS) is the most advanced stage of HIV infection.</dd>

        <dt>HPV</dt>
        <dd>Human Papillomavirus, the most common sexually transmitted infection in the US. Some types can cause health problems including genital warts and cancers.</dd>

        <dt>Pre-Exposure Prophylaxis (PrEP)</dt>
        <dd>Medicine taken to prevent getting HIV. PrEP is highly effective for preventing HIV when taken as prescribed.</dd>

        <dt>Sexually Transmitted Infections (STIs)</dt>
        <dd>Infections passed from one person to another through sexual contact. Get the facts in our <a href="/sites/nookienook/what-are-stis">comprehensive STI guide</a>.</dd>
      </dl>
    </section>

    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        <div class="faq-item">
          <h4>What is the difference between gender identity and sexual orientation?</h4>
          <p>Gender identity refers to who you are—your internal sense of being male, female, neither, or a combination of genders. Sexual orientation refers to who you are attracted to romantically, emotionally, or sexually.</p>
        </div>
        <div class="faq-item">
          <h4>How do I know if my libido is normal?</h4>
          <p>"Normal" libido varies widely from person to person. It is only considered a medical concern if a lack of desire causes you personal distress or significant relationship difficulties.</p>
        </div>
        <div class="faq-item">
          <h4>Why is enthusiastic consent important?</h4>
          <p>Enthusiastic consent ensures that all parties are not just saying "yes" to avoid conflict, but are actively and eagerly participating in the activity. It prioritizes mutual pleasure and respect.</p>
        </div>
        <div class="faq-item">
          <h4>Can you have an STI without any symptoms?</h4>
          <p>Yes. Many STIs, including chlamydia, gonorrhea, and herpes, can be completely asymptomatic. This is why regular testing is crucial if you are sexually active.</p>
        </div>
        <div class="faq-item">
          <h4>What causes erectile dysfunction?</h4>
          <p>Erectile dysfunction can be caused by a combination of physical and psychological factors, including cardiovascular disease, diabetes, stress, anxiety, and certain medications.</p>
        </div>
      </div>
    </section>

    <section>
      <h2>Continue Learning</h2>
      <p>Sexual health is a lifelong journey of learning and understanding. We encourage you to explore the links throughout this glossary to deepen your knowledge of these critical topics. If you have specific medical concerns, always consult with a qualified healthcare professional.</p>
    </section>
  </div>

  <script is:inline>
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelector(this.getAttribute('href')).scrollIntoView({
          behavior: 'smooth'
        });
      });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    section { margin-bottom: 2.5rem; }
    h2 { color: var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 0.5rem; margin-bottom: 1.5rem; }
    h3 { color: var(--text-primary); margin-top: 1.5rem; margin-bottom: 1rem; }
    h4 { color: var(--text-primary); margin-bottom: 0.5rem; }

    p, li { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    ul { padding-left: 1.5rem; margin-bottom: 1.5rem; }
    li { margin-bottom: 0.5rem; }

    a { color: var(--accent-color); text-decoration: none; font-weight: 500; }
    a:hover { text-decoration: underline; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }

    dl { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    dt { font-weight: 700; color: var(--accent-color); font-size: 1.1rem; margin-top: 1rem; }
    dt:first-child { margin-top: 0; }
    dd { color: var(--text-secondary); margin-left: 0; margin-top: 0.25rem; margin-bottom: 1rem; line-height: 1.5; padding-bottom: 1rem; border-bottom: 1px dashed var(--border-color); }
    dd:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

    .faq-container { display: flex; flex-direction: column; gap: 1.5rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; }
    .faq-item h4 { color: var(--accent-color); font-size: 1.1rem; margin-top: 0; }
    .faq-item p { margin-bottom: 0; }
  </style>
</SiteLayout>
