    var answers = {};
    var currentQ = 0;

    var quizSection = document.getElementById('quiz-section');
    var resultsSection = document.getElementById('results-section');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var questionNumber = document.getElementById('question-number');
    var questionPrompt = document.getElementById('question-prompt');
    var choicesContainer = document.getElementById('choices-container');

    function showQuestion() {
      var q = questions[currentQ];
      progressFill.style.width = (currentQ / questions.length * 100) + '%';
      progressText.textContent = 'Question ' + (currentQ + 1) + ' of ' + questions.length;
      questionNumber.textContent = currentQ + 1;
      questionPrompt.textContent = q.prompt;

      choicesContainer.innerHTML = '';
      for (var i = 0; i < q.choices.length; i++) {
        var btn = document.createElement('button');
        btn.className = 'choice-btn';
        btn.textContent = q.choices[i].text;
        btn.setAttribute('data-score', q.choices[i].score);
        btn.addEventListener('click', (function(score, milestone) {
          return function() {
            answers[milestone] = score;
            currentQ++;
            if (currentQ < questions.length) {
              showQuestion();
            } else {
              showResults();
            }
          };
        })(q.choices[i].score, q.milestone));
        choicesContainer.appendChild(btn);
      }
    }

    function showResults() {
      quizSection.style.display = 'none';
      resultsSection.style.display = 'block';
      progressFill.style.width = '100%';

      var totalScore = 0;
      var keys = Object.keys(answers);
      for (var i = 0; i < keys.length; i++) {
        totalScore += answers[keys[i]];
      }

      var avgScore = totalScore / 15;
      var paceLabel, paceDesc;

      if (avgScore <= 1.7) {
        paceLabel = "Fast-Paced Lover";
        paceDesc = "You dive into relationships with enthusiasm and confidence. You trust your instincts, make decisions quickly, and aren't afraid to be vulnerable early. Your energy is magnetic, and you bring excitement to every relationship stage. Just make sure your partner can match your pace — checking in regularly helps ensure you're both comfortable.";
      } else if (avgScore <= 2.5) {
        paceLabel = "Moderate Mover";
        paceDesc = "You balance heart and head beautifully. You give relationships enough time to develop naturally while still moving forward with intention. You're neither rushed nor overly cautious — you let milestones happen when the moment feels right. Most partners find your pace comfortable and reassuring.";
      } else if (avgScore <= 3.2) {
        paceLabel = "Thoughtful Planner";
        paceDesc = "You take a deliberate, considered approach to relationships. Each milestone means something to you, and you want to be sure before taking the next step. You value stability and security, and your patience often builds incredibly strong foundations. Partners who appreciate depth over speed thrive with you.";
