      document.getElementById('pace-label').textContent = paceLabel;
      document.getElementById('pace-desc').textContent = paceDesc;
      document.getElementById('score-display').textContent = totalScore + ' / 60';
      document.getElementById('score-context').textContent = 'Lower scores indicate a faster pace. Higher scores mean you prefer to take your time. Your average per question was ' + avgScore.toFixed(1) + ' out of 4.';

      // Build timeline visualization
      var timelineViz = document.getElementById('timeline-viz');
      timelineViz.innerHTML = '';

      var timelineOrder = ['becomeExclusive', 'meetFriends', 'sayILoveYou', 'leaveItems', 'meetParents', 'firstTrip', 'talkFinances', 'talkFuture', 'moveIn', 'shareAccess', 'talkChildren', 'talkMarriage', 'getPet', 'mergeFinances', 'getEngaged'];

      // Sort by their chosen months
      var sorted = timelineOrder.slice().sort(function(a, b) {
        var mA = scoreToMonths[a][answers[a] - 1];
        var mB = scoreToMonths[b][answers[b] - 1];
        return mA - mB;
      });

      var maxMonths = 0;
      for (var i = 0; i < sorted.length; i++) {
        var m = scoreToMonths[sorted[i]][answers[sorted[i]] - 1];
        if (m < 999 && m > maxMonths) maxMonths = m;
      }
      if (maxMonths === 0) maxMonths = 36;

      for (var i = 0; i < sorted.length; i++) {
        var ms = sorted[i];
        var months = scoreToMonths[ms][answers[ms] - 1];
        var pct = months < 999 ? Math.min((months / maxMonths) * 85 + 5, 95) : 95;

        var item = document.createElement('div');
        item.className = 'timeline-item';

        var label = document.createElement('div');
        label.className = 'timeline-label';
        label.textContent = milestoneIcons[ms] + ' ' + milestoneLabels[ms];

        var track = document.createElement('div');
        track.className = 'timeline-track';

        var dot = document.createElement('div');
        dot.className = 'timeline-dot';
        dot.style.left = pct + '%';

        var timeLabel = document.createElement('span');
        timeLabel.className = 'timeline-time';
        if (months >= 999) {
          timeLabel.textContent = 'In my own time';
        } else if (months < 1) {
          timeLabel.textContent = 'Weeks';
        } else if (months === 1) {
          timeLabel.textContent = '1 mo';
        } else if (months < 12) {
          timeLabel.textContent = Math.round(months) + ' mo';
        } else {
          var years = months / 12;
          timeLabel.textContent = years % 1 === 0 ? years + ' yr' : years.toFixed(1) + ' yr';
        }
        dot.appendChild(timeLabel);

        track.appendChild(dot);
        item.appendChild(label);
        item.appendChild(track);
        timelineViz.appendChild(item);
      }

      // Build comparison grid
      var comparisonGrid = document.getElementById('comparison-grid');
      comparisonGrid.innerHTML = '';

      var comparisonMilestones = ['sayILoveYou', 'meetParents', 'moveIn', 'talkFinances', 'talkMarriage', 'getEngaged'];
      for (var i = 0; i < comparisonMilestones.length; i++) {
        var ms = comparisonMilestones[i];
        var yourMonths = scoreToMonths[ms][answers[ms] - 1];
        var avgMonths = surveyAverages[ms];

        var card = document.createElement('div');
        card.className = 'comparison-card';

        var diff;
        if (yourMonths >= 999) {
          diff = 'personal';
        } else if (yourMonths < avgMonths * 0.7) {
          diff = 'faster';
        } else if (yourMonths > avgMonths * 1.3) {
          diff = 'slower';
        } else {
          diff = 'average';
        }

        var diffText;
        if (diff === 'personal') {
          diffText = '<span class="comp-tag comp-personal">Personal Choice</span>';
        } else if (diff === 'faster') {
          diffText = '<span class="comp-tag comp-fast">Faster Than Average</span>';
        } else if (diff === 'slower') {
          diffText = '<span class="comp-tag comp-slow">Slower Than Average</span>';
        } else {
          diffText = '<span class="comp-tag comp-avg">Right On Average</span>';
        }

        var yourText = yourMonths >= 999 ? 'Prefer not to' : (yourMonths < 12 ? Math.round(yourMonths) + ' months' : (yourMonths / 12).toFixed(1) + ' years');
        var avgText = avgMonths < 12 ? avgMonths + ' months' : (avgMonths / 12).toFixed(1) + ' years';

        card.innerHTML = '<div class="comp-icon">' + milestoneIcons[ms] + '</div>' +
          '<h4>' + milestoneLabels[ms] + '</h4>' +
          '<div class="comp-row"><span class="comp-label">You:</span> <strong>' + yourText + '</strong></div>' +
          '<div class="comp-row"><span class="comp-label">Average:</span> ' + avgText + '</div>' +
          diffText;

        comparisonGrid.appendChild(card);
      }

      // Build advice grid
      var adviceGrid = document.getElementById('advice-grid');
      adviceGrid.innerHTML = '';

      var adviceMilestones = ['sayILoveYou', 'meetParents', 'talkFinances', 'moveIn', 'talkMarriage', 'getEngaged'];
      for (var i = 0; i < adviceMilestones.length; i++) {
        var ms = adviceMilestones[i];
        var score = answers[ms];
        var advice = milestoneAdvice[ms][score];

        var card = document.createElement('div');
        card.className = 'advice-card';
        card.innerHTML = '<div class="advice-icon">' + milestoneIcons[ms] + '</div>' +
          '<h4>' + milestoneLabels[ms] + '</h4>' +
          '<p>' + advice + '</p>';

        adviceGrid.appendChild(card);
      }

      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Share button
    document.getElementById('share-btn').addEventListener('click', function() {
      var totalScore = 0;
      var keys = Object.keys(answers);
      for (var i = 0; i < keys.length; i++) {
        totalScore += answers[keys[i]];
      }

      var avgScore = totalScore / 15;
      var paceLabel;
      if (avgScore <= 1.7) paceLabel = "Fast-Paced Lover";
      else if (avgScore <= 2.5) paceLabel = "Moderate Mover";
      else if (avgScore <= 3.2) paceLabel = "Thoughtful Planner";
      else paceLabel = "Slow and Steady";

      var text = "My Relationship Timeline Quiz Results:\n\n";
      text += "Pace: " + paceLabel + " (" + totalScore + "/60)\n\n";
      text += "Key milestones:\n";
      var highlights = ['sayILoveYou', 'meetParents', 'moveIn', 'talkMarriage', 'getEngaged'];
      for (var i = 0; i < highlights.length; i++) {
        var ms = highlights[i];
        var months = scoreToMonths[ms][answers[ms] - 1];
        var timeText = months >= 999 ? 'In my own time' : (months < 12 ? Math.round(months) + ' months' : (months / 12).toFixed(1) + ' years');
        text += milestoneLabels[ms] + ": " + timeText + "\n";
      }
      text += "\nTake the quiz: " + window.location.href;

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
          var btn = document.getElementById('share-btn');
          btn.textContent = 'Copied to Clipboard!';
          setTimeout(function() { btn.textContent = 'Share Results'; }, 2000);
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        var btn = document.getElementById('share-btn');
        btn.textContent = 'Copied to Clipboard!';
        setTimeout(function() { btn.textContent = 'Share Results'; }, 2000);
      }
    });

    // Retake button
    document.getElementById('retake-btn').addEventListener('click', function() {
      answers = {};
      currentQ = 0;
      resultsSection.style.display = 'none';
      quizSection.style.display = 'block';
      showQuestion();
      quizSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    showQuestion();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; }

    .content-section { margin-top: 1rem; color: var(--text-primary); line-height: 1.6; }
    .content-section h2 { font-size: 1.8rem; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--accent-color); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    .content-section h3 { font-size: 1.4rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
    .content-section p { margin-bottom: 1rem; }
    .content-section ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .content-section li { margin-bottom: 0.5rem; }
    .content-section a { color: var(--accent-color); text-decoration: underline; text-underline-offset: 3px; font-weight: 500; }
    .content-section a:hover { color: var(--text-primary); }

    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); }
    .card h3 { margin-top: 0; color: var(--text-primary); }

    /* Quiz */
    .quiz-progress { margin-bottom: 1.5rem; }
    .progress-bar { height: 8px; background: var(--border-color); border-radius: 4px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--accent-color); border-radius: 4px; transition: width 0.3s ease; }
    .progress-text { text-align: center; font-size: 0.88rem; color: var(--text-secondary); margin-top: 0.5rem; font-weight: 600; }

    .quiz-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 14px; padding: 2rem; text-align: center; }
    .question-number { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%; background: var(--accent-color); color: #fff; font-weight: 800; font-size: 1.1rem; margin-bottom: 1rem; }
    .question-prompt { font-size: 1.05rem; color: var(--text-secondary); margin-bottom: 1.5rem; font-weight: 500; }

    .choice-btn { display: block; width: 100%; padding: 1rem 1.25rem; margin-bottom: 0.75rem; background: var(--page-bg, #fff); border: 2px solid var(--border-color); border-radius: 10px; font-size: 1rem; color: var(--text-primary); cursor: pointer; text-align: left; line-height: 1.5; transition: border-color 0.2s, background 0.2s; }
    .choice-btn:hover { border-color: var(--accent-color); background: rgba(99, 102, 241, 0.05); }
    .choice-btn:last-child { margin-bottom: 0; }

    /* Results */
    .results-summary { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin: 1rem 0 1.5rem; }
    .result-primary, .result-secondary { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 14px; padding: 1.5rem; }
    .result-primary { border-top: 4px solid var(--accent-color); }
    .result-secondary { border-top: 4px solid var(--text-secondary); }
    .result-badge { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); margin-bottom: 0.5rem; }
    .secondary-badge { color: var(--text-secondary); }
    .result-lang { font-size: 1.5rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.5rem; }
    .result-desc { font-size: 0.92rem; color: var(--text-secondary); line-height: 1.6; margin: 0; }

    /* Timeline visualization */
    .timeline-viz { margin: 1rem 0 2rem; }
    .timeline-item { display: flex; align-items: center; margin-bottom: 0.6rem; gap: 1rem; }
    .timeline-label { width: 200px; flex-shrink: 0; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .timeline-track { flex: 1; height: 28px; background: var(--border-color); border-radius: 14px; position: relative; overflow: visible; }
    .timeline-dot { position: absolute; top: 50%; transform: translate(-50%, -50%); width: 16px; height: 16px; background: var(--accent-color); border-radius: 50%; border: 3px solid var(--card-bg); box-shadow: 0 0 0 2px var(--accent-color); transition: left 0.5s ease; }
    .timeline-time { position: absolute; top: -22px; left: 50%; transform: translateX(-50%); font-size: 0.72rem; font-weight: 700; color: var(--accent-color); white-space: nowrap; }

    /* Comparison grid */
    .comparison-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1rem 0 2rem; }
    .comparison-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem; text-align: center; }
    .comp-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
    .comparison-card h4 { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.75rem; color: var(--text-primary); }
    .comp-row { font-size: 0.88rem; color: var(--text-secondary); margin-bottom: 0.25rem; }
    .comp-label { font-weight: 600; }
    .comp-tag { display: inline-block; font-size: 0.75rem; font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 20px; margin-top: 0.5rem; }
    .comp-fast { background: #dbeafe; color: #1d4ed8; }
    .comp-slow { background: #fef3c7; color: #92400e; }
    .comp-avg { background: #d1fae5; color: #065f46; }
    .comp-personal { background: #ede9fe; color: #5b21b6; }

    /* Advice grid */
    .advice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1rem 0 2rem; }
    .advice-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem; }
    .advice-icon { font-size: 1.5rem; margin-bottom: 0.4rem; }
    .advice-card h4 { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.5rem; color: var(--text-primary); }
    .advice-card p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.55; margin: 0; }

    /* Action buttons */
    .action-buttons { display: flex; gap: 1rem; margin: 2rem 0; justify-content: center; flex-wrap: wrap; }
    .action-btn { padding: 0.8rem 2rem; border-radius: 10px; font-size: 1rem; font-weight: 700; cursor: pointer; border: none; transition: opacity 0.2s; }
    .action-btn:hover { opacity: 0.85; }
    .share-btn { background: var(--accent-color); color: #fff; }
    .retake-btn { background: var(--card-bg); color: var(--text-primary); border: 2px solid var(--border-color); }

    @media (max-width: 768px) {
      .page-content { padding: 1rem; }
      .hero h1 { font-size: 1.6rem; }
      .hero p { font-size: 1rem; }
      .results-summary { grid-template-columns: 1fr; }
      .timeline-item { flex-direction: column; align-items: stretch; gap: 0.25rem; }
      .timeline-label { width: auto; text-align: left; font-size: 0.82rem; }
      .timeline-track { height: 24px; }
      .comparison-grid { grid-template-columns: 1fr 1fr; }
      .advice-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
      .quiz-card { padding: 1.25rem; }
      .choice-btn { font-size: 0.92rem; padding: 0.85rem 1rem; }
      .comparison-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>
