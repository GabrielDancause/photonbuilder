---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Relationship Timeline Quiz",
      "description": "Interactive quiz about relationship milestones and timing. Discover your relationship pace profile and get personalized advice on when to hit key milestones.",
      "url": "https://thenookienook.com/relationship-timeline-quiz",
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "When is the right time to say 'I love you' in a relationship?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There is no universal right time. Surveys show an average of about 3 to 6 months, but the best time is when you genuinely feel it and are not saying it to get a specific reaction. Pay attention to emotional readiness rather than the calendar."
          }
        },
        {
          "@type": "Question",
          "name": "How long should you date before moving in together?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most relationship experts suggest dating for at least one year before moving in together so you experience different seasons, stressors, and routines with your partner. However, what matters most is having open conversations about finances, chores, personal space, and long-term goals before sharing a home."
          }
        },
        {
          "@type": "Question",
          "name": "When should you meet each other's parents?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Meeting the parents typically happens once both partners feel the relationship is serious and has long-term potential. This can range from a few months to over a year. The key is that both people feel ready and that the introduction is not forced by outside pressure."
          }
        },
        {
          "@type": "Question",
          "name": "Is there a normal pace for relationship milestones?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There is no single normal pace. Every couple moves at their own speed based on individual comfort levels, life circumstances, and relationship dynamics. What matters is that both partners feel comfortable with the pace and communicate openly about expectations."
          }
        },
        {
          "@type": "Question",
          "name": "When should couples start talking about finances?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Financial conversations should begin before any major shared commitment like moving in together. Many experts recommend starting basic money talks within the first 6 to 12 months, covering topics like debt, spending habits, savings goals, and financial values. Early transparency prevents surprises later."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Relationship Timeline Quiz — What's Your Pace?",
  description: "Free 15-question quiz to discover your relationship pace. Find out if you move fast, moderate, or slow through milestones like saying I love you and moving in.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="nookienook"
  title="Relationship Timeline Quiz — What's Your Pace?"
  description="Free 15-question quiz to discover your relationship pace. Find out if you move fast, moderate, or slow through milestones like saying I love you and moving in."
  canonical="https://thenookienook.com/relationship-timeline-quiz"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Relationship Timeline Quiz</h1>
      <p>Answer 15 questions about relationship milestones to discover your ideal pace. There are no right or wrong answers — just honest reflection on how you approach love.</p>
    </div>

    <section class="content-section">

      <h2>What's Your Relationship Pace?</h2>
      <p>Every couple moves through milestones differently. Some people say "I love you" within weeks while others wait a year or more. This quiz explores your instincts around 15 key relationship milestones — from the first "I love you" to conversations about marriage and finances — and builds a picture of your ideal relationship timeline.</p>

      <div id="quiz-section">
        <div class="quiz-progress">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">Question 1 of 15</div>
        </div>

        <div class="quiz-card" id="quiz-card">
          <div class="question-number" id="question-number">1</div>
          <p class="question-prompt" id="question-prompt"></p>
          <div id="choices-container"></div>
        </div>
      </div>

      <div id="results-section" style="display:none;">

        <h2>Your Relationship Pace Profile</h2>

        <div class="results-summary">
          <div class="result-primary">
            <div class="result-badge">Your Pace</div>
            <div class="result-lang" id="pace-label"></div>
            <p class="result-desc" id="pace-desc"></p>
          </div>
          <div class="result-secondary">
            <div class="result-badge secondary-badge">Your Score</div>
            <div class="result-lang" id="score-display"></div>
            <p class="result-desc" id="score-context"></p>
          </div>
        </div>

        <h2>Your Ideal Timeline</h2>
        <div class="timeline-viz" id="timeline-viz"></div>

        <h2>How You Compare</h2>
        <div class="comparison-grid" id="comparison-grid"></div>

        <h2>Personalized Milestone Advice</h2>
        <div class="advice-grid" id="advice-grid"></div>

        <div class="action-buttons">
          <button class="action-btn share-btn" id="share-btn">Share Results</button>
          <button class="action-btn retake-btn" id="retake-btn">Retake Quiz</button>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>

      <div class="card">
        <h3>When is the right time to say "I love you"?</h3>
        <p>There is no universal right time. Surveys show an average of about 3 to 6 months, but the best time is when you genuinely feel it and are not saying it to get a specific reaction. Pay attention to emotional readiness rather than the calendar. If it feels right and you are prepared for any response, go for it.</p>
      </div>

      <div class="card">
        <h3>How long should you date before moving in together?</h3>
        <p>Most relationship experts suggest dating for at least one year before moving in together so you experience different seasons, stressors, and routines with your partner. However, what matters most is having open conversations about finances, chores, personal space, and long-term goals before sharing a home.</p>
      </div>

      <div class="card">
        <h3>When should you meet each other's parents?</h3>
        <p>Meeting the parents typically happens once both partners feel the relationship is serious and has long-term potential. This can range from a few months to over a year. The key is that both people feel ready and that the introduction is not forced by outside pressure or arbitrary timelines.</p>
      </div>

      <div class="card">
        <h3>Is there a "normal" pace for relationship milestones?</h3>
        <p>There is no single normal pace. Every couple moves at their own speed based on individual comfort levels, life circumstances, and relationship dynamics. What matters most is that both partners feel comfortable with the pace and communicate openly about expectations and boundaries.</p>
      </div>

      <div class="card">
        <h3>When should couples start talking about finances?</h3>
        <p>Financial conversations should begin before any major shared commitment like moving in together. Many experts recommend starting basic money talks within the first 6 to 12 months, covering topics like debt, spending habits, savings goals, and financial values. Early transparency prevents surprises and conflict later on.</p>
      </div>

      <h2>Related Tools &amp; Guides</h2>
      <ul>
        <li><a href="/love-language-quiz">Love Language Quiz</a> — Discover your primary love language with our free 20-question quiz</li>
        <li><a href="/best-date-ideas">Best Date Ideas</a> — Creative and fun date night inspiration for every stage of your relationship</li>
      </ul>
    </section>
  </div>

