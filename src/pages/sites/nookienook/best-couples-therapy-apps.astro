              <button class="quiz-option" data-value="intimacy">Intimacy</button>
              <button class="quiz-option" data-value="trust">Trust</button>
              <button class="quiz-option" data-value="logistics">Daily logistics</button>
              <button class="quiz-option" data-value="long-distance">Long distance</button>
            </div>
          </div>

