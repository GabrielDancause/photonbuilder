              <button class="quiz-option" data-value="low">Under $15/mo</button>
              <button class="quiz-option" data-value="mid">Under $100 for 6 months</button>
              <button class="quiz-option" data-value="high">Willing to pay for real therapy</button>
            </div>
          </div>

          <div class="quiz-step" data-step="2">
