  <script is:inline>
  (function() {
    // Quiz logic
    const answers = [];
    const steps = document.querySelectorAll('.quiz-step');
    const progressBar = document.getElementById('quiz-progress-bar');
    const resultDiv = document.getElementById('quiz-result');
    const questionsDiv = document.getElementById('quiz-questions');

    document.querySelectorAll('.quiz-option').forEach(btn => {
      btn.addEventListener('click', function() {
        const step = this.closest('.quiz-step');
        const stepIndex = parseInt(step.dataset.step);

        // Mark selected
        step.querySelectorAll('.quiz-option').forEach(b => b.classList.remove('selected'));
        this.classList.add('selected');

        answers[stepIndex] = this.dataset.value;
        progressBar.style.width = ((stepIndex + 1) / 4 * 100) + '%';

        setTimeout(() => {
          if (stepIndex < 3) {
            step.classList.remove('active');
            steps[stepIndex + 1].classList.add('active');
          } else {
            showResult();
          }
        }, 300);
      });
    });

    function showResult() {
      const [challenge, budget, therapist, style] = answers;
      let rec = getRecommendation(challenge, budget, therapist, style);

      questionsDiv.style.display = 'none';
      document.querySelector('.quiz-progress').style.display = 'none';
      resultDiv.style.display = 'block';

      document.getElementById('quiz-result-badge').textContent = rec.rating;
      document.getElementById('quiz-result-name').textContent = rec.name;
      document.getElementById('quiz-result-explanation').textContent = rec.reason;
    }

    function getRecommendation(challenge, budget, therapist, style) {
      // Therapist + high budget → real therapy apps
      if (therapist === 'yes' && budget === 'high') {
        if (style === 'deep') return { name: 'Ours', rating: '9.0', reason: 'You want deep, structured work with a real licensed therapist and you\'re willing to invest. Ours offers the highest quality video couples therapy with between-session tools to reinforce your progress.' };
        return { name: 'ReGain', rating: '8.7', reason: 'You want professional therapist access with flexible session formats. ReGain connects you with licensed marriage & family therapists via video, phone, or text — real therapy at a fraction of in-office costs.' };
      }
      if (therapist === 'yes' && budget === 'mid') {
        return { name: 'Relish', rating: '8.8', reason: 'You want human guidance without full therapy pricing. Relish pairs you with a dedicated relationship coach for text-based support plus customized weekly lesson plans — the best coaching value available.' };
      }
      if (therapist === 'yes') {
        return { name: 'Relish', rating: '8.8', reason: 'You want therapist-like guidance on a budget. Relish gives you a dedicated human coach and personalized lesson plans for about $17/month — the most accessible coached option.' };
      }

      // Challenge-specific
      if (challenge === 'long-distance') {
        return { name: 'Between', rating: '7.8', reason: 'For long-distance couples, Between is purpose-built: private encrypted messaging, shared calendars, photo albums, and free voice calls. It keeps you connected when you can\'t be together physically.' };
      }
      if (challenge === 'intimacy') {
        if (budget === 'free') return { name: 'Gottman Card Decks', rating: '8.0', reason: 'The Gottman Card Decks include "Mild to Spicy" intimacy decks backed by decades of research — completely free. A great starting point for reconnecting physically and emotionally.' };
        return { name: 'Coral', rating: '8.6', reason: 'Coral is the leading sexual wellness app designed by actual sex therapists. Its guided exercises and educational content help couples improve physical and emotional intimacy in a shame-free environment.' };
      }
      if (challenge === 'logistics') {
        if (style === 'practical') return { name: 'OurHome', rating: '7.0', reason: 'Household conflicts are real relationship stressors. OurHome gamifies chore tracking and task management, making the mental load visible and shared — practical tools that reduce daily friction.' };
        return { name: 'Honeydue', rating: '7.6', reason: 'Money fights are the #1 source of relationship conflict. Honeydue gives you a shared financial dashboard, bill splitting, and the ability to chat about specific transactions — and it\'s completely free.' };
      }
      if (challenge === 'trust' && style === 'deep') {
        return { name: 'Lasting', rating: '9.2', reason: 'Trust repair requires deep, structured work — exactly what Lasting excels at. Its EFT and Gottman-based programs walk you through guided sessions on rebuilding trust, improving communication, and healing emotional wounds.' };
      }

      // Style-based
      if (style === 'deep') {
        if (budget === 'free') return { name: 'Gottman Card Decks', rating: '8.0', reason: 'For deep conversations without spending a dime, the Gottman Card Decks are unmatched. 14 research-backed decks covering everything from Love Maps to intimacy — the best free relationship tool available.' };
        return { name: 'Lasting', rating: '9.2', reason: 'Lasting offers the deepest, most research-backed couples therapy curriculum available in an app. Its EFT and Gottman-based audio sessions feel like real therapy and cover every major relationship topic.' };
      }
      if (style === 'light') {
        if (budget === 'free') return { name: 'Love Nudge', rating: '7.5', reason: 'Love Nudge is free, light, and built around the popular 5 Love Languages framework. Daily nudges remind you to show love in the way your partner actually receives it best.' };
        return { name: 'Flamme', rating: '8.3', reason: 'Flamme turns relationship building into a fun daily game. Quick challenges, quizzes, and conversation prompts keep things playful — perfect for couples who find traditional therapy apps too heavy.' };
      }
      if (style === 'practical') {
        if (budget === 'free') return { name: 'Honeydue', rating: '7.6', reason: 'Honeydue is a practical, free tool that tackles money — the #1 thing couples argue about. Shared budgets, bill splitting, and transaction-level conversations remove financial guesswork from your relationship.' };
        return { name: 'Paired', rating: '8.5', reason: 'Paired combines daily conversation prompts with practical milestone-specific exercises (new baby, moving, etc.). Its gamified streaks keep both partners engaged with just 5 minutes a day.' };
      }

      // Default fallback
      if (budget === 'free') return { name: 'Gottman Card Decks', rating: '8.0', reason: 'For a free, research-backed starting point, you can\'t beat the Gottman Card Decks. 14 card decks based on decades of relationship science give you hundreds of conversation starters and intimacy prompts.' };
      return { name: 'Lasting', rating: '9.2', reason: 'Lasting is our #1 overall pick. With the deepest research-backed curriculum, guided audio sessions, and comprehensive coverage of every relationship topic, it\'s the best all-around couples therapy app available.' };
    }

    document.getElementById('quiz-restart').addEventListener('click', function() {
      answers.length = 0;
      resultDiv.style.display = 'none';
      questionsDiv.style.display = 'block';
      document.querySelector('.quiz-progress').style.display = 'block';
      progressBar.style.width = '0%';
      steps.forEach(s => s.classList.remove('active'));
      steps[0].classList.add('active');
      document.querySelectorAll('.quiz-option').forEach(b => b.classList.remove('selected'));
    });

    // Table sorting
    const table = document.getElementById('comparison-table');
    if (table) {
      let currentSort = '';
      let currentDir = 'asc';

      table.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', function() {
          const key = this.dataset.sort;
          if (currentSort === key) {
            currentDir = currentDir === 'asc' ? 'desc' : 'asc';
          } else {
            currentSort = key;
            currentDir = key === 'rating' || key === 'appStore' ? 'desc' : 'asc';
          }

          // Update arrows
          table.querySelectorAll('.sort-arrow').forEach(a => { a.className = 'sort-arrow'; });
          this.querySelector('.sort-arrow').classList.add(currentDir);

          const tbody = table.querySelector('tbody');
          const rows = Array.from(tbody.querySelectorAll('tr'));
          rows.sort((a, b) => {
            let aVal, bVal;
            if (key === 'name') {
              aVal = a.dataset.name;
              bVal = b.dataset.name;
              return currentDir === 'asc' ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
            }
            if (key === 'price') { aVal = parseFloat(a.dataset.price); bVal = parseFloat(b.dataset.price); }
            if (key === 'appStore') { aVal = parseFloat(a.dataset.appstore); bVal = parseFloat(b.dataset.appstore); }
            if (key === 'rating') { aVal = parseFloat(a.dataset.rating); bVal = parseFloat(b.dataset.rating); }
            return currentDir === 'asc' ? aVal - bVal : bVal - aVal;
          });
          rows.forEach(r => tbody.appendChild(r));
        });
      });
    }
  })();
  </script>
</SiteLayout>
