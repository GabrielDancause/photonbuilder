---
import SiteLayout from '../../../layouts/SiteLayout.astro';


export const meta = {
  title: 'Consent & Boundaries Guide: Navigating Relationships',
  description: 'A comprehensive guide to understanding enthusiastic consent, communicating boundaries, the FRIES framework, and navigating consent in modern relationships.',
  category: 'guide',
};

const meta = {
  title: 'Consent & Boundaries Guide: Navigating Relationships',
  description: 'A comprehensive guide to understanding enthusiastic consent, communicating boundaries, the FRIES framework, and navigating consent in modern relationships.',
  category: 'guide',
  publishedDate: new Date().toISOString()
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.publishedDate,
    "author": {
      "@type": "Organization",
      "name": "The Nookie Nook",
      "url": "https://thenookienook.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does enthusiastic consent mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Enthusiastic consent means actively looking for the presence of a 'yes' rather than just the absence of a 'no'. It's about clear, excited, and ongoing agreement to participate in an activity."
        }
      },
      {
        "@type": "Question",
        "name": "What is the FRIES framework?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "FRIES stands for Freely given, Reversible, Informed, Enthusiastic, and Specific. It's a widely used framework to help understand and practice healthy, comprehensive consent."
        }
      },
      {
        "@type": "Question",
        "name": "Does consent apply to long-term relationships?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, absolutely. Being in a relationship or having consented to an activity in the past does not imply ongoing consent. Every new interaction requires fresh consent."
        }
      },
      {
        "@type": "Question",
        "name": "How does alcohol or substances affect consent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If someone is intoxicated or incapacitated by alcohol or drugs, they cannot legally or ethically give valid consent. Consent must always be freely and consciously given."
        }
      },
      {
        "@type": "Question",
        "name": "How do I communicate my boundaries?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Communicate boundaries clearly and early, ideally before being in a sexual situation. Use 'I' statements, be direct about your comfort levels, and remember that setting boundaries is a healthy part of any relationship."
        }
      }
    ]
  }
];

const understandingConsent = [
  {
    name: "Enthusiastic Consent Model",
    desc: "Move away from 'no means no' to 'yes means yes'. Enthusiastic consent looks for eager, voluntary participation. If it's not a clear 'yes', it's a 'no'."
  },
  {
    name: "The FRIES Framework",
    desc: "Consent must be Freely given, Reversible (you can change your mind anytime), Informed, Enthusiastic, and Specific (consenting to one thing doesn't mean consenting to another)."
  },
  {
    name: "Verbal and Non-Verbal Cues",
    desc: "While explicit verbal 'yes' is best, pay attention to body language. Pulling away, silence, or hesitation are strong non-verbal signs that consent is missing or has been withdrawn."
  },
  {
    name: "Consent and Substances",
    desc: "Alcohol and drugs impair judgment. A person who is intoxicated cannot give clear, informed consent. When in doubt, always wait until everyone is sober."
  }
];

const settingBoundaries = [
  {
    name: "Setting Personal Boundaries",
    desc: "Take time to reflect on your physical and emotional limits. Knowing what you are comfortable with beforehand makes it easier to communicate those limits to a partner."
  },
  {
    name: "Communicating Boundaries",
    desc: "Have open discussions about boundaries outside the bedroom. Be direct and clear. A good partner will appreciate the clarity and respect your limits without pressure."
  },
  {
    name: "Consent in Long-Term Relationships",
    desc: "Marriage or long-term commitment doesn't bypass consent. Regular check-ins ensure both partners are still comfortable, as desires and boundaries can change over time."
  },
  {
    name: "Violations vs. Misunderstandings",
    desc: "A misunderstanding involves accidental crossed lines followed by immediate respect and correction. A violation is a deliberate disregard for established boundaries or a 'no'."
  }
];

const digitalAndEducation = [
  {
    name: "Digital Consent",
    desc: "Consent applies online too. Sharing texts, explicit photos (sexting), or forwarding private messages without explicit permission is a serious violation of digital boundaries."
  },
  {
    name: "Age of Consent Variations",
    desc: "The legal age of consent varies significantly by state and country. It's crucial to understand the legal definitions and age requirements in your specific jurisdiction."
  },
  {
    name: "Teaching Consent at Different Ages",
    desc: "Consent education starts early, like teaching toddlers bodily autonomy (e.g., they don't have to hug relatives). As kids grow, conversations evolve into digital safety and relationship boundaries."
  },
  {
    name: "Resources for Survivors",
    desc: "If your boundaries have been violated, it is not your fault. Reach out to local support groups, hotlines like RAINN, or professional counselors for guidance and healing."
  }
];
---

<SiteLayout site="nookienook" title={meta.title} description={meta.description} canonical="https://thenookienook.com/consent-boundaries-guide" schema={JSON.stringify(jsonLd)}>
  <div class="page-content">
    <div class="hero">
      <h1>Consent & Boundaries Guide</h1>
      <p>A complete guide to enthusiastic consent, setting healthy boundaries, and navigating communication in modern relationships safely.</p>
    </div>

    <div class="category-section">
      <h2>Understanding Consent</h2>
      <p class="section-intro">The foundational frameworks of healthy, consensual interactions.</p>
      <div class="ideas-grid">
        {understandingConsent.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>Navigating Boundaries</h2>
      <p class="section-intro">How to set, communicate, and maintain personal limits.</p>
      <div class="ideas-grid">
        {settingBoundaries.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>Modern Contexts & Education</h2>
      <p class="section-intro">Applying consent to digital spaces, legalities, and healing.</p>
      <div class="ideas-grid">
        {digitalAndEducation.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {jsonLd[1].mainEntity.map((faq: any) => (
        <div class="card faq-card">
          <h3>{faq.name}</h3>
          <p>{faq.acceptedAnswer.text}</p>
        </div>
      ))}
    </div>
  </div>

  <style>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .hero p { color: var(--text-secondary); font-size: 1.2rem; max-width: 700px; margin: 0 auto; line-height: 1.6; }

    .category-section { margin-bottom: 3.5rem; }
    .category-section h2 { font-size: 1.8rem; margin-bottom: 0.5rem; color: var(--accent-color); border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; }
    .section-intro { color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 1.05rem; }

    .ideas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
    .idea-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; }
    .idea-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
    .idea-card h3 { font-size: 1.25rem; margin-top: 0; margin-bottom: 0.75rem; color: var(--text-primary); }
    .idea-desc { color: var(--text-secondary); margin-bottom: 1rem; flex-grow: 1; font-size: 0.95rem; line-height: 1.5; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 2rem; margin-bottom: 2rem; text-align: center; color: var(--accent-color); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); }
    .card h3 { margin-top: 0; margin-bottom: 0.75rem; color: var(--text-primary); }
    .card p { margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/what-is-consent" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">What is Consent? Enthusiastic Consent & Boundaries</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">An evidence-based guide to understanding sexual consent, including legal definitions, enthusiastic consent, gray areas, ...</p>
      </a>
    </div>
  </div>
</SiteLayout>
