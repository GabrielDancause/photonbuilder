---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Contraception Comparison Tool",
  "description": "Interactive tool to compare contraception methods side-by-side, including effectiveness, hormonal status, and pros/cons.",
  "author": {
    "@type": "Organization",
    "name": "The Nookie Nook"
  },
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the most effective birth control method?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Long-Acting Reversible Contraceptives (LARCs) such as the IUD and implant are over 99% effective, largely because they eliminate user error."
        }
      },
      {
        "@type": "Question",
        "name": "Do all birth control methods protect against STIs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Only barrier methods like internal and external condoms provide protection against Sexually Transmitted Infections."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between perfect use and typical use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Perfect use means the method is used exactly as directed every single time. Typical use accounts for human error, like forgetting a pill or a condom slipping."
        }
      }
    ]
  }
};

export const meta = {
  title: "Interactive Contraception Comparison Tool | The Nookie Nook",
  description: "Compare contraception methods side-by-side: pill, IUD, implant, condoms, and more. Filter by effectiveness, hormones, and STI protection.",
  category: "guide",
  published: "2026-03-15",
};
---
<SiteLayout
  site="nookienook"
  title="Interactive Contraception Comparison Tool | The Nookie Nook"
  description="Compare contraception methods side-by-side: pill, IUD, implant, condoms, and more. Filter by effectiveness, hormones, and STI protection."
  canonical="https://thenookienook.com/contraception-comparison"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Contraception Comparison Tool</h1>
      <p>Compare methods side-by-side to find what might work best for your body and lifestyle.</p>
    </div>

    <div class="content-section">
      <p>Choosing the right contraception is highly personal. What works perfectly for a friend might not be the right fit for you. This interactive tool allows you to filter and compare various methods based on what matters most to you—whether that's avoiding hormones, maximizing effectiveness, or ensuring STI protection.</p>
      <p>Learn more about how contraception fits into your overall well-being in our <a href="/sites/nookienook/sexual-health-guide">Comprehensive Sexual Health Guide</a>.</p>

      <div class="tool-container">
        <div class="filters">
          <h3>Filter Methods</h3>
          <div class="filter-group">
            <label><input type="checkbox" id="filter-hormonal" value="hormonal"> Non-Hormonal Only</label>
            <label><input type="checkbox" id="filter-sti" value="sti"> STI Protection Only</label>
            <label><input type="checkbox" id="filter-effective" value="effective"> >99% Effective (Typical Use)</label>
          </div>
        </div>

        <div class="methods-grid" id="methods-grid">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const methods = [
      {
        id: 'hormonal-iud',
        name: 'Hormonal IUD',
        effectiveness: '>99%',
        hormonal: true,
        stiProtection: false,
        duration: '3-8 years',
        pros: ['Highly effective', 'Can lighten periods', 'Low maintenance'],
        cons: ['Requires clinic visit for insertion/removal', 'Possible irregular bleeding initially', 'Insertion can be painful']
      },
      {
        id: 'copper-iud',
        name: 'Copper IUD',
        effectiveness: '>99%',
        hormonal: false,
        stiProtection: false,
        duration: 'Up to 10-12 years',
        pros: ['Highly effective', 'No hormones', 'Can be used as emergency contraception'],
        cons: ['Can make periods heavier/crampier', 'Requires clinic visit', 'Insertion can be painful']
      },
      {
        id: 'implant',
        name: 'The Implant (Nexplanon)',
        effectiveness: '>99%',
        hormonal: true,
        stiProtection: false,
        duration: 'Up to 3 years',
        pros: ['Most effective reversible method', 'Low maintenance', 'Can lighten periods'],
        cons: ['Requires minor procedure for insertion/removal', 'Can cause unpredictable spotting']
      },
      {
        id: 'the-pill',
        name: 'The Pill (Combined or Mini)',
        effectiveness: '93% (Typical), 99% (Perfect)',
        hormonal: true,
        stiProtection: false,
        duration: 'Daily',
        pros: ['Can regulate periods', 'May reduce acne', 'Easy to stop using'],
        cons: ['Must remember to take daily', 'Effectiveness relies on user', 'Possible side effects like nausea or mood changes']
      },
      {
        id: 'external-condom',
        name: 'External Condom',
        effectiveness: '87% (Typical), 98% (Perfect)',
        hormonal: false,
        stiProtection: true,
        duration: 'Single use',
        pros: ['Protects against STIs', 'Cheap and easily available', 'No hormones'],
        cons: ['Must be used every time', 'Can break or slip', 'May interrupt the moment']
      },
      {
        id: 'internal-condom',
        name: 'Internal Condom',
        effectiveness: '79% (Typical), 95% (Perfect)',
        hormonal: false,
        stiProtection: true,
        duration: 'Single use',
        pros: ['Protects against STIs', 'Can be inserted ahead of time', 'No hormones'],
        cons: ['More expensive than external condoms', 'Can take practice to insert', 'May make noise during sex']
      },
      {
        id: 'the-shot',
        name: 'The Shot (Depo-Provera)',
        effectiveness: '96% (Typical), 99% (Perfect)',
        hormonal: true,
        stiProtection: false,
        duration: 'Every 3 months',
        pros: ['Only have to remember every 3 months', 'Often stops periods entirely'],
        cons: ['Clinic visit required for injections', 'May cause bone density loss over time', 'Delay in return to fertility after stopping']
      },
      {
        id: 'the-ring',
        name: 'The Ring (NuvaRing/Annovera)',
        effectiveness: '93% (Typical), 99% (Perfect)',
        hormonal: true,
        stiProtection: false,
        duration: 'Monthly / Yearly',
        pros: ['Only have to remember once a month', 'Can regulate periods'],
        cons: ['Requires comfort with inserting into vagina', 'Possible vaginal irritation', 'Prescription needed']
      },
      {
        id: 'fertility-awareness',
        name: 'Fertility Awareness (FAM)',
        effectiveness: '77-98% (Highly variable)',
        hormonal: false,
        stiProtection: false,
        duration: 'Daily tracking',
        pros: ['No hormones', 'Completely free', 'Increases body literacy'],
        cons: ['Requires rigorous daily tracking (temp, mucus)', 'Effectiveness heavily dependent on user dedication', 'Requires abstaining or backup method during fertile window']
      }
    ];

    function renderMethods(filteredMethods) {
      const grid = document.getElementById('methods-grid');
      grid.innerHTML = '';

      filteredMethods.forEach(method => {
        const card = document.createElement('div');
        card.className = 'method-card';

        const tagsHtml = [];
        if (!method.hormonal) tagsHtml.push('<span class="tag tag-nonhormonal">Non-Hormonal</span>');
        if (method.stiProtection) tagsHtml.push('<span class="tag tag-sti">STI Protection</span>');
        if (method.effectiveness.includes('>99%')) tagsHtml.push('<span class="tag tag-effective">Highly Effective</span>');

        card.innerHTML = `
          <div class="method-header">
            <h3>${method.name}</h3>
            <div class="method-tags">${tagsHtml.join('')}</div>
          </div>
          <div class="method-details">
            <div class="detail-row"><strong>Effectiveness:</strong> ${method.effectiveness}</div>
            <div class="detail-row"><strong>Duration:</strong> ${method.duration}</div>
          </div>
          <div class="pros-cons">
            <div class="pros">
              <strong>Pros:</strong>
              <ul>${method.pros.map(p => `<li>${p}</li>`).join('')}</ul>
            </div>
            <div class="cons">
              <strong>Cons:</strong>
              <ul>${method.cons.map(c => `<li>${c}</li>`).join('')}</ul>
            </div>
          </div>
        `;
        grid.appendChild(card);
      });
    }

    function applyFilters() {
      const nonHormonalOnly = document.getElementById('filter-hormonal').checked;
      const stiProtectionOnly = document.getElementById('filter-sti').checked;
      const highlyEffectiveOnly = document.getElementById('filter-effective').checked;

      const filtered = methods.filter(m => {
        if (nonHormonalOnly && m.hormonal) return false;
        if (stiProtectionOnly && !m.stiProtection) return false;
        if (highlyEffectiveOnly && !m.effectiveness.includes('>99%')) return false;
        return true;
      });

      renderMethods(filtered);
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('filter-hormonal').addEventListener('change', applyFilters);
      document.getElementById('filter-sti').addEventListener('change', applyFilters);
      document.getElementById('filter-effective').addEventListener('change', applyFilters);
      renderMethods(methods);
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .hero p { color: var(--text-secondary); font-size: 1.2rem; }

    .content-section { margin-bottom: 3rem; }
    .content-section p { margin-bottom: 1.2rem; font-size: 1.1rem; line-height: 1.7; }
    .content-section a { color: var(--accent-color); text-decoration: underline; }
    .content-section a:hover { color: var(--text-primary); }

    .tool-container { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }

    .filters { background: var(--card-bg); padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; border: 1px solid var(--border-color); }
    .filters h3 { margin-top: 0; margin-bottom: 1rem; color: var(--text-primary); }
    .filter-group { display: flex; flex-wrap: wrap; gap: 1.5rem; }
    .filter-group label { display: flex; align-items: center; gap: 0.5rem; color: var(--text-secondary); cursor: pointer; font-size: 1.05rem; }
    .filter-group input[type="checkbox"] { width: 1.2rem; height: 1.2rem; accent-color: var(--accent-color); cursor: pointer; }

    .methods-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }

    .method-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; transition: transform 0.2s, border-color 0.2s; }
    .method-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }

    .method-header { border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 1rem; }
    .method-header h3 { margin: 0 0 0.8rem 0; color: var(--accent-color); font-size: 1.4rem; }

    .method-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tag { font-size: 0.8rem; padding: 0.3rem 0.6rem; border-radius: 4px; font-weight: 600; font-family: var(--font-mono); }
    .tag-nonhormonal { background: rgba(45, 184, 154, 0.15); color: #2DB89A; }
    .tag-sti { background: rgba(59, 130, 246, 0.15); color: #3B82F6; }
    .tag-effective { background: rgba(139, 92, 246, 0.15); color: #8B5CF6; }

    .method-details { margin-bottom: 1.5rem; font-size: 1rem; }
    .detail-row { margin-bottom: 0.5rem; color: var(--text-secondary); }
    .detail-row strong { color: var(--text-primary); }

    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 600px) { .pros-cons { grid-template-columns: 1fr; } }

    .pros strong { color: #2DB89A; display: block; margin-bottom: 0.5rem; }
    .cons strong { color: #E05A5A; display: block; margin-bottom: 0.5rem; }

    .pros ul, .cons ul { margin: 0; padding-left: 1.2rem; color: var(--text-secondary); font-size: 0.95rem; }
    .pros li, .cons li { margin-bottom: 0.3rem; }
  </style>
</SiteLayout>
