---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const meta = {
  title: 'Attachment Styles in Relationships Guide',
  description: 'Understand the 4 attachment styles: secure, anxious-preoccupied, dismissive-avoidant, and fearful-avoidant. Learn their origins, triggers, and how to achieve earned secure attachment.',
  category: 'guide',
  publishedDate: new Date().toISOString()
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.publishedDate,
    "author": {
      "@type": "Organization",
      "name": "The Nookie Nook",
      "url": "https://thenookienook.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I identify my attachment style?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Identify your style by examining your behavior in relationships. Do you crave constant reassurance (anxious), value independence over intimacy (dismissive-avoidant), fear both closeness and abandonment (fearful-avoidant), or feel comfortable with both intimacy and autonomy (secure)? You can also take self-assessment quizzes or seek therapy for professional insight."
        }
      },
      {
        "@type": "Question",
        "name": "What is the anxious-avoidant trap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The anxious-avoidant trap occurs when an anxious partner's need for closeness triggers an avoidant partner's need for space. The avoidant pulls away, causing the anxious partner to pursue harder, which in turn makes the avoidant withdraw further, creating a painful, repeating cycle."
        }
      },
      {
        "@type": "Question",
        "name": "Can attachment styles change?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, attachment styles can change over time. Through self-awareness, personal growth, healthy relationships, and therapy, individuals with insecure attachment styles can develop what is known as 'earned secure attachment'."
        }
      },
      {
        "@type": "Question",
        "name": "What therapies help with attachment issues?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Emotionally Focused Therapy (EFT) is highly effective for couples working through attachment issues. For individuals, Schema Therapy and Cognitive Behavioral Therapy (CBT) can help address underlying beliefs and core wounds stemming from childhood."
        }
      },
      {
        "@type": "Question",
        "name": "What is earned secure attachment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Earned secure attachment is a secure attachment style developed later in life by someone who originally had an insecure attachment style. This is achieved by processing childhood experiences, forming healthy adult relationships, and working through relational trauma, often with professional help."
        }
      }
    ]
  }
];

const secureStyle = [
  {
    name: "Characteristics & Origins",
    desc: "Comfortable with intimacy and autonomy. Typically originates from caregivers who were consistently responsive, attuned, and emotionally available during childhood."
  },
  {
    name: "Relationship Patterns",
    desc: "Builds trusting, long-lasting relationships. Able to draw boundaries without anxiety and supports their partner's independence."
  },
  {
    name: "Texting, Conflict & Intimacy",
    desc: "Communicates openly. During conflict, seeks resolution rather than winning or withdrawing. Intimacy is a space of comfort, not anxiety."
  }
];

const anxiousPreoccupiedStyle = [
  {
    name: "Characteristics & Origins",
    desc: "Craves high levels of intimacy, approval, and responsiveness. Often stems from caregivers who were inconsistently responsive—sometimes warm, sometimes distant."
  },
  {
    name: "Relationship Patterns & Triggers",
    desc: "May become overly dependent and worry about abandonment. Triggered by perceived distance, unreturned messages, or ambiguous communication."
  },
  {
    name: "Texting, Conflict & Intimacy",
    desc: "May double-text or seek constant reassurance. Conflict can trigger emotional flooding and fear of breakup. Uses intimacy to feel secure."
  }
];

const dismissiveAvoidantStyle = [
  {
    name: "Characteristics & Origins",
    desc: "Desires a high level of independence and self-sufficiency. Often stems from caregivers who were emotionally unavailable, dismissive, or discouraging of emotional expression."
  },
  {
    name: "Relationship Patterns & Triggers",
    desc: "Tends to distance themselves when things get too serious. Triggered by emotional demands, perceived clinginess, or feeling their independence is threatened."
  },
  {
    name: "Texting, Conflict & Intimacy",
    desc: "May take a long time to reply to texts or ignore emotional topics. Often stonewalls during conflict. May separate physical intimacy from emotional intimacy."
  }
];

const fearfulAvoidantStyle = [
  {
    name: "Characteristics & Origins",
    desc: "Also known as disorganized. Craves intimacy but fears it simultaneously. Often stems from childhood trauma, abuse, or caregivers who were themselves a source of fear."
  },
  {
    name: "Relationship Patterns & Triggers",
    desc: "Experiences a push-pull dynamic, drawing partners in and then pushing them away. Triggered by both intense closeness (feeling engulfed) and distance (fearing abandonment)."
  },
  {
    name: "Texting, Conflict & Intimacy",
    desc: "Communication can be erratic or unpredictable. Conflict triggers intense anxiety and defensive mechanisms. Intimacy feels unsafe despite a deep desire for connection."
  }
];

const healingAndGrowth = [
  {
    name: "Pairing Dynamics: Anxious-Avoidant Trap",
    desc: "A common dynamic where an anxious partner pursues intimacy, causing the avoidant partner to withdraw, which triggers more anxiety and pursuit in a painful cycle."
  },
  {
    name: "Earned Secure Attachment",
    desc: "You can change your attachment style! 'Earned secure' is achieved through self-reflection, consistent self-soothing practices, and forming relationships with secure partners."
  },
  {
    name: "Therapy Approaches",
    desc: "Emotionally Focused Therapy (EFT) helps couples restructure their emotional bond. Schema Therapy helps individuals heal core childhood wounds driving insecure styles."
  },
  {
    name: "Self-Assessment & Identification",
    desc: "Notice your emotional reactions: Do you panic when your partner asks for space? Do you pull away when things get serious? Recognizing these patterns is the first step to healing."
  }
];
---

<SiteLayout site="nookienook" title={meta.title} description={meta.description} canonical="https://thenookienook.com/attachment-styles-guide" schema={JSON.stringify(jsonLd)}>
  <div class="page-content">
    <div class="hero">
      <h1>Attachment Styles in Relationships Guide</h1>
      <p>Understand the foundations of how you connect. Learn about the four attachment styles, how they influence your relationships, and the path to earned security.</p>
    </div>

    <div class="category-section">
      <h2>Secure Attachment</h2>
      <p class="section-intro">Comfortable with both intimacy and independence, forming healthy, trusting bonds.</p>
      <div class="ideas-grid">
        {secureStyle.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>Anxious-Preoccupied Attachment</h2>
      <p class="section-intro">Deeply desires connection but fears abandonment, often needing high levels of reassurance.</p>
      <div class="ideas-grid">
        {anxiousPreoccupiedStyle.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>Dismissive-Avoidant Attachment</h2>
      <p class="section-intro">Values independence and self-sufficiency over emotional closeness, often keeping partners at arm's length.</p>
      <div class="ideas-grid">
        {dismissiveAvoidantStyle.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>Fearful-Avoidant (Disorganized) Attachment</h2>
      <p class="section-intro">Craves intimacy but fears it simultaneously, leading to a confusing push-pull dynamic.</p>
      <div class="ideas-grid">
        {fearfulAvoidantStyle.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>Healing, Growth & Dynamics</h2>
      <p class="section-intro">Learn about common relationship patterns, how to identify your style, and the therapies that foster secure connections.</p>
      <div class="ideas-grid">
        {healingAndGrowth.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="card faq-card">
        <h3>How do I identify my attachment style?</h3>
        <p>Identify your style by examining your behavior in relationships. Do you crave constant reassurance (anxious), value independence over intimacy (dismissive-avoidant), fear both closeness and abandonment (fearful-avoidant), or feel comfortable with both intimacy and autonomy (secure)? You can also take self-assessment quizzes or seek therapy for professional insight.</p>
      </div>
      <div class="card faq-card">
        <h3>What is the anxious-avoidant trap?</h3>
        <p>The anxious-avoidant trap occurs when an anxious partner's need for closeness triggers an avoidant partner's need for space. The avoidant pulls away, causing the anxious partner to pursue harder, which in turn makes the avoidant withdraw further, creating a painful, repeating cycle.</p>
      </div>
      <div class="card faq-card">
        <h3>Can attachment styles change?</h3>
        <p>Yes, attachment styles can change over time. Through self-awareness, personal growth, healthy relationships, and therapy, individuals with insecure attachment styles can develop what is known as 'earned secure attachment'.</p>
      </div>
      <div class="card faq-card">
        <h3>What therapies help with attachment issues?</h3>
        <p>Emotionally Focused Therapy (EFT) is highly effective for couples working through attachment issues. For individuals, Schema Therapy and Cognitive Behavioral Therapy (CBT) can help address underlying beliefs and core wounds stemming from childhood.</p>
      </div>
      <div class="card faq-card">
        <h3>What is earned secure attachment?</h3>
        <p>Earned secure attachment is a secure attachment style developed later in life by someone who originally had an insecure attachment style. This is achieved by processing childhood experiences, forming healthy adult relationships, and working through relational trauma, often with professional help.</p>
      </div>
    </div>
  </div>

  <style>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .hero p { color: var(--text-secondary); font-size: 1.2rem; max-width: 700px; margin: 0 auto; line-height: 1.6; }

    .category-section { margin-bottom: 3.5rem; }
    .category-section h2 { font-size: 1.8rem; margin-bottom: 0.5rem; color: var(--accent-color); border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; }
    .section-intro { color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 1.05rem; }

    .ideas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
    .idea-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; }
    .idea-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
    .idea-card h3 { font-size: 1.25rem; margin-top: 0; margin-bottom: 0.75rem; color: var(--text-primary); }
    .idea-desc { color: var(--text-secondary); margin-bottom: 1rem; flex-grow: 1; font-size: 0.95rem; line-height: 1.5; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 2rem; margin-bottom: 2rem; text-align: center; color: var(--accent-color); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); }
    .card h3 { margin-top: 0; margin-bottom: 0.75rem; color: var(--text-primary); }
    .card p { margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
