---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const meta = {
  title: 'Complete First Date Guide & Tips',
  description: 'Master your first date with our complete guide. Learn about choosing the right activity, conversation starters, body language cues, and managing first date anxiety.',
  category: 'guide',
  publishedDate: new Date().toISOString()
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.publishedDate,
    "author": {
      "@type": "Organization",
      "name": "The Nookie Nook",
      "url": "https://thenookienook.com"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long should a first date last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good rule of thumb is 1 to 2 hours. This is enough time to get to know someone without the pressure of an overly long commitment. If things are going perfectly, you can always extend it or plan a second date."
        }
      },
      {
        "@type": "Question",
        "name": "Who should pay on the first date?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The common modern approach is that the person who asked for the date should offer to pay, but splitting the bill (going Dutch) is also highly acceptable and often preferred to keep things equal."
        }
      },
      {
        "@type": "Question",
        "name": "When should I schedule the second date?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If the first date went well, it's best to bring up the idea of a second date within a day or two. You can even mention a potential second date activity during the first date if the vibe is right."
        }
      },
      {
        "@type": "Question",
        "name": "What are some good first date conversation starters?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Move beyond small talk by asking open-ended questions like 'What are you most passionate about right now?' or 'What is your favorite travel memory?' Having a mental list of 50 questions can help if conversation lulls."
        }
      },
      {
        "@type": "Question",
        "name": "What are common red flags on a first date?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Watch out for people who are rude to service staff, constantly check their phone, talk excessively about their ex, or don't respect your boundaries. These are strong indicators of potential future issues."
        }
      }
    ]
  }
];

const planningAndPrep = [
  {
    name: "Choosing the Right Activity",
    desc: "Opt for coffee over dinner for a first date. It's low-pressure, affordable, and easy to leave if there's no spark. Activity dates like mini-golf or visiting a museum are also great for reducing awkward silences."
  },
  {
    name: "Texting Before the Date",
    desc: "Keep pre-date texting light and focused on logistics. Building too much rapport over text can lead to a false sense of intimacy or run out of conversation topics before you meet in person."
  },
  {
    name: "Video Call Pre-Dates",
    desc: "A quick 10-15 minute video call before the actual date can be a great vibe check. It helps verify identity, gauge basic chemistry, and ease first date anxiety."
  },
  {
    name: "Safety Tips",
    desc: "Always tell a trusted friend where you are going and who you are meeting. Arrange your own transportation to and from the date so you have complete control over when you leave."
  }
];

const duringTheDate = [
  {
    name: "Conversation Starters",
    desc: "Come prepared with at least 50 questions beyond basic small talk. Ask about their passions, favorite memories, or hypothetical scenarios to keep the conversation flowing naturally."
  },
  {
    name: "Body Language Cues to Watch For",
    desc: "Pay attention to non-verbal signals. Leaning in, sustained eye contact, and mirroring your movements usually indicate interest. Crossed arms or constant distraction might mean they aren't engaged."
  },
  {
    name: "The 'Who Pays' Debate",
    desc: "While traditional norms suggest the inviter pays, many prefer to split the bill on a first date to keep things equal. Always be prepared to pay your half, regardless of who asked who out."
  },
  {
    name: "How Long Should It Last?",
    desc: "Aim for 1 to 2 hours for a first date. This provides enough time to establish a connection but leaves them wanting more, while also offering an easy exit if the chemistry isn't there."
  }
];

const aftermathAndMindset = [
  {
    name: "First Date Anxiety Management",
    desc: "It's normal to feel nervous. Practice deep breathing, remind yourself that they are probably nervous too, and focus on whether you like them, rather than just hoping they like you."
  },
  {
    name: "Red Flags on First Dates",
    desc: "Be observant. Rudeness to waitstaff, talking only about themselves, complaining about exes, or pushing your boundaries are serious red flags that shouldn't be ignored."
  },
  {
    name: "When to Schedule the Second Date",
    desc: "If you had a great time, send a brief text later that day or the next morning saying you enjoyed it. If the feeling is mutual, try to schedule the second date within a week to maintain momentum."
  }
];
---

<SiteLayout site="nookienook" title={meta.title} description={meta.description} canonical="https://thenookienook.com/first-date-tips" schema={JSON.stringify(jsonLd)}>
  <div class="page-content">
    <div class="hero">
      <h1>Complete First Date Guide</h1>
      <p>Master your first date with actionable tips on planning, conversation, body language, and managing anxiety for a successful connection.</p>
    </div>

    <div class="category-section">
      <h2>Planning and Preparation</h2>
      <p class="section-intro">Set yourself up for success before you even meet.</p>
      <div class="ideas-grid">
        {planningAndPrep.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>During the Date</h2>
      <p class="section-intro">Navigating the conversation, reading cues, and handling logistics.</p>
      <div class="ideas-grid">
        {duringTheDate.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="category-section">
      <h2>Aftermath and Mindset</h2>
      <p class="section-intro">Evaluating the date, managing expectations, and planning next steps.</p>
      <div class="ideas-grid">
        {aftermathAndMindset.map(idea => (
          <div class="idea-card">
            <h3>{idea.name}</h3>
            <p class="idea-desc">{idea.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {jsonLd[1].mainEntity.map((faq: any) => (
        <div class="card faq-card">
          <h3>{faq.name}</h3>
          <p>{faq.acceptedAnswer.text}</p>
        </div>
      ))}
    </div>
  </div>

  <style>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .hero p { color: var(--text-secondary); font-size: 1.2rem; max-width: 700px; margin: 0 auto; line-height: 1.6; }

    .category-section { margin-bottom: 3.5rem; }
    .category-section h2 { font-size: 1.8rem; margin-bottom: 0.5rem; color: var(--accent-color); border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; }
    .section-intro { color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 1.05rem; }

    .ideas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
    .idea-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; }
    .idea-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
    .idea-card h3 { font-size: 1.25rem; margin-top: 0; margin-bottom: 0.75rem; color: var(--text-primary); }
    .idea-desc { color: var(--text-secondary); margin-bottom: 1rem; flex-grow: 1; font-size: 0.95rem; line-height: 1.5; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 2rem; margin-bottom: 2rem; text-align: center; color: var(--accent-color); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); }
    .card h3 { margin-top: 0; margin-bottom: 0.75rem; color: var(--text-primary); }
    .card p { margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
