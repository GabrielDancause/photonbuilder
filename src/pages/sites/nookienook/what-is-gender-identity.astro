        "@type": "Question",
        "name": "What is the difference between sex and gender?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sex refers to biological and physiological characteristics (chromosomes, anatomy, hormones) assigned at birth. Gender refers to the socially constructed roles, behaviors, and identities, as well as a person's internal sense of self."
        }
      },
      {
        "@type": "Question",
        "name": "What does non-binary mean?",
        "acceptedAnswer": {
          "@type": "Answer",
