---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does a relationship compatibility quiz measure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A relationship compatibility quiz measures how well two partners align across key relationship areas such as communication style, conflict resolution, lifestyle preferences, values and goals, and intimacy. Each partner answers the same set of questions independently, and the quiz compares their responses to calculate a compatibility percentage for each area and an overall score."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate is a couple compatibility quiz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Compatibility quizzes are useful conversation starters and self-reflection tools, but they are not clinical assessments. Results depend on honest answers from both partners and may vary based on mood or current relationship circumstances. Use your results to identify areas worth discussing together rather than treating the score as a definitive verdict on your relationship."
      }
    },
    {
      "@type": "Question",
      "name": "Can incompatible couples make a relationship work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. Compatibility is not destiny. Many successful couples have significant differences but thrive because they communicate openly, respect each other's perspectives, and are willing to compromise. Lower compatibility in an area simply means that area may require more intentional effort and conversation, not that the relationship is doomed."
      }
    },
    {
      "@type": "Question",
      "name": "Should both partners take the quiz at the same time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It is best for each partner to answer independently without seeing the other's responses. This ensures honest answers rather than matching what you think your partner wants to hear. The quiz is designed so Partner 1 answers all 15 questions first, then Partner 2 answers the same questions separately before results are revealed."
      }
    },
    {
      "@type": "Question",
      "name": "What areas does the relationship compatibility test cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The quiz covers five core relationship areas: Communication Style (how you express needs and listen), Conflict Resolution (how you handle disagreements), Lifestyle Preferences (daily habits, social life, and routines), Values and Goals (life direction, finances, and priorities), and Intimacy (emotional closeness, physical affection, and vulnerability). These five areas represent the most researched dimensions of relationship satisfaction."
      }
    },
    {
      "@type": "Question",
      "name": "How often should couples take a compatibility quiz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Taking a compatibility quiz once or twice a year can be a helpful relationship check-in. People grow and change over time, and revisiting these questions can reveal shifts in values, needs, or communication styles that are worth discussing. It can also be useful during major life transitions such as moving in together, getting engaged, or starting a family."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good compatibility score?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no single 'good' score. Scores above 75% suggest strong natural alignment in that area. Scores between 50% and 75% indicate some differences that benefit from open discussion. Scores below 50% highlight areas where intentional effort and compromise will help. What matters most is not the number itself but how willing both partners are to understand and work with their differences."
      }
    }
  ]
};

export const meta = {
  title: "Relationship Compatibility Quiz — Couples Test",
  description: "Free couple compatibility quiz. Both partners answer 15 questions across 5 key areas to see your compatibility score with a radar chart and growth tips.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="nookienook"
  title="Relationship Compatibility Quiz — Couples Test"
  description="Free couple compatibility quiz. Both partners answer 15 questions across 5 key areas to see your compatibility score with a radar chart and growth tips."
  canonical="https://thenookienook.com/relationship-compatibility-quiz"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(232,67,147,0.08);border:1px solid rgba(232,67,147,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      💑 <strong style="color:#E84393;">67% of couples argue about money.</strong> With costs rising everywhere, financial alignment matters more than ever. This quiz covers finances, communication, and 3 other key areas. <a href="https://gab.ae/news/grocery-prices-rising-raspberries-oil-costs-2026" style="color:#E84393;">Why budgets are tighter →</a>
    </div>
    <div class="hero">
      <h1>Relationship Compatibility Quiz</h1>
      <p>Both partners answer 15 questions independently across 5 key relationship areas. Compare your results, see your compatibility score, and discover your strengths and growth areas as a couple.</p>
    </div>

    <section class="content-section">

      <h2>How the Compatibility Test Works</h2>
      <p>This relationship compatibility test covers five core areas that research shows are most important for long-term relationship satisfaction: communication style, conflict resolution, lifestyle preferences, values and goals, and intimacy. Each partner answers the same 15 questions (3 per area) independently. The quiz then compares your answers to calculate a compatibility percentage for each area, plus an overall score displayed on a radar chart.</p>

      <div id="quiz-section">
        <div class="partner-indicator" id="partner-indicator">
          <div class="partner-badge" id="partner-badge">Partner 1</div>
          <p class="partner-instruction">Answer honestly based on your own preferences. Don't let your partner see your answers.</p>
        </div>

        <div class="quiz-progress">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          <div class="progress-text" id="progress-text">Question 1 of 15</div>
        </div>

        <div class="quiz-card" id="quiz-card">
          <div class="question-area" id="question-area"></div>
          <div class="question-number" id="question-number">1</div>
          <p class="question-prompt" id="question-prompt"></p>
          <div class="choices" id="choices"></div>
        </div>
      </div>

      <div id="handoff-section" style="display:none;">
        <div class="handoff-card">
          <div class="handoff-icon">&#9996;</div>
          <h2>Partner 1 is Done!</h2>
          <p>Now hand the device to Partner 2. They will answer the same 15 questions independently. Don't share your answers yet — the fun is in comparing them at the end.</p>
          <button class="action-btn share-btn" id="start-p2-btn">Start Partner 2's Quiz</button>
        </div>
      </div>

      <div id="results-section" style="display:none;">

        <h2>Your Compatibility Results</h2>

        <div class="overall-score-card">
          <div class="overall-label">Overall Compatibility</div>
          <div class="overall-number" id="overall-score">0%</div>
          <div class="overall-summary" id="overall-summary"></div>
        </div>

        <h2>Compatibility by Area</h2>
        <div class="radar-container">
          <canvas id="radar-canvas" width="400" height="400"></canvas>
        </div>

        <div class="area-scores" id="area-scores"></div>

        <h2>Your Strengths</h2>
        <div id="strengths-section"></div>

        <h2>Areas for Growth</h2>
        <div id="growth-section"></div>

        <h2>Tips for Improvement</h2>
        <div id="tips-section"></div>

        <div class="action-buttons">
          <button class="action-btn share-btn" id="share-btn">Share Results</button>
          <button class="action-btn retake-btn" id="retake-btn">Retake Quiz</button>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>

      <div class="card">
        <h3>What does a relationship compatibility quiz measure?</h3>
        <p>A relationship compatibility quiz measures how well two partners align across key relationship areas such as communication style, conflict resolution, lifestyle preferences, values and goals, and intimacy. Each partner answers the same questions independently, and the quiz compares responses to calculate compatibility for each area and overall.</p>
      </div>

      <div class="card">
        <h3>How accurate is a couple compatibility quiz?</h3>
        <p>Compatibility quizzes are useful conversation starters and self-reflection tools, but they are not clinical assessments. Results depend on honest answers from both partners and may vary based on mood or current circumstances. Use your results to identify areas worth discussing together rather than as a definitive relationship verdict.</p>
      </div>

      <div class="card">
        <h3>Can incompatible couples make a relationship work?</h3>
        <p>Absolutely. Compatibility is not destiny. Many successful couples have significant differences but thrive through open communication, mutual respect, and willingness to compromise. Lower compatibility in an area simply means it may need more intentional effort and conversation.</p>
      </div>

      <div class="card">
        <h3>Should both partners take the quiz at the same time?</h3>
        <p>Each partner should answer independently without seeing the other's responses. This ensures honest answers. Partner 1 completes all 15 questions first, then Partner 2 answers the same questions before results are revealed.</p>
      </div>

      <div class="card">
        <h3>What areas does the relationship compatibility test cover?</h3>
        <p>The quiz covers five core areas: Communication Style (how you express needs and listen), Conflict Resolution (how you handle disagreements), Lifestyle Preferences (daily habits and routines), Values and Goals (life direction and priorities), and Intimacy (emotional closeness and physical affection). These represent the most researched dimensions of relationship satisfaction.</p>
      </div>

      <div class="card">
        <h3>How often should couples take a compatibility quiz?</h3>
        <p>Taking a compatibility quiz once or twice a year is a helpful relationship check-in. People grow and change, and revisiting these questions can reveal shifts worth discussing — especially during major life transitions like moving in together, getting engaged, or starting a family.</p>
      </div>

      <div class="card">
        <h3>What is a good compatibility score?</h3>
        <p>There is no single "good" score. Above 75% suggests strong natural alignment. Between 50% and 75% indicates differences worth discussing. Below 50% highlights areas needing intentional effort. What matters most is not the number but how willing both partners are to understand and work with their differences.</p>
      </div>

      <h2>Related Tools &amp; Guides</h2>
      <ul>
        <li><a href="/love-language-quiz">Love Language Quiz</a> — Discover your primary love language and how to strengthen your relationship</li>
        <li><a href="/best-date-ideas">Best Date Ideas</a> — Creative and fun date night inspiration for every couple</li>
      </ul>
    </section>
  </div>

  <script is:inline>
  (function() {
    var areas = ['communication', 'conflict', 'lifestyle', 'values', 'intimacy'];
    var areaLabels = {
      communication: 'Communication Style',
      conflict: 'Conflict Resolution',
      lifestyle: 'Lifestyle Preferences',
      values: 'Values & Goals',
      intimacy: 'Intimacy'
    };
    var areaColors = {
      communication: '#3b82f6',
      conflict: '#ef4444',
      lifestyle: '#22c55e',
      values: '#a855f7',
      intimacy: '#f97316'
    };

    var questions = [
      // Communication (3)
      { area: 'communication', text: 'When something is bothering you in the relationship, you prefer to:', options: [
        { id: 'a', text: 'Talk about it right away, even if emotions are running high' },
        { id: 'b', text: 'Wait until you have calmed down, then bring it up' },
        { id: 'c', text: 'Drop hints and hope your partner picks up on it' },
        { id: 'd', text: 'Write it down or text about it rather than talking face to face' }
      ]},
      { area: 'communication', text: 'How do you prefer to receive important news or updates from your partner?', options: [
        { id: 'a', text: 'In person, face to face, so we can discuss it fully' },
        { id: 'b', text: 'A phone call so I can hear their tone of voice' },
        { id: 'c', text: 'A thoughtful text or message so I can process before responding' },
        { id: 'd', text: 'It does not matter as long as they tell me soon' }
      ]},
      { area: 'communication', text: 'When your partner shares a problem, your instinct is to:', options: [
        { id: 'a', text: 'Offer practical solutions and advice' },
        { id: 'b', text: 'Listen and empathize without trying to fix it' },
        { id: 'c', text: 'Share a similar experience of your own to show you understand' },
        { id: 'd', text: 'Ask questions to understand the full picture before responding' }
      ]},
      // Conflict Resolution (3)
      { area: 'conflict', text: 'During an argument, you are most likely to:', options: [
        { id: 'a', text: 'Stay and talk it through until it is resolved, even if it takes hours' },
        { id: 'b', text: 'Take a break to cool off and revisit the conversation later' },
        { id: 'c', text: 'Try to find a compromise as quickly as possible' },
        { id: 'd', text: 'Avoid the argument and hope things blow over on their own' }
      ]},
      { area: 'conflict', text: 'After a disagreement, you feel better when:', options: [
        { id: 'a', text: 'You both apologize and clearly state what you will do differently' },
        { id: 'b', text: 'Your partner shows affection, like a hug or kind gesture' },
        { id: 'c', text: 'You spend quality time together to reconnect' },
        { id: 'd', text: 'Some time passes and things naturally go back to normal' }
      ]},
      { area: 'conflict', text: 'When you and your partner disagree on a decision, you prefer to:', options: [
        { id: 'a', text: 'Debate the pros and cons until one person is convinced' },
        { id: 'b', text: 'Take turns — one person decides this time, the other next time' },
        { id: 'c', text: 'Find a middle-ground compromise, even if neither gets exactly what they want' },
        { id: 'd', text: 'Let the person who feels more strongly about it make the call' }
      ]},
      // Lifestyle Preferences (3)
      { area: 'lifestyle', text: 'Your ideal weekend together looks like:', options: [
        { id: 'a', text: 'Going out — restaurants, events, socializing with friends' },
        { id: 'b', text: 'A mix of activities and relaxation at home' },
        { id: 'c', text: 'An adventure — hiking, traveling, trying something new' },
        { id: 'd', text: 'A quiet day at home — movies, cooking, reading together' }
      ]},
      { area: 'lifestyle', text: 'When it comes to household responsibilities, you believe:', options: [
        { id: 'a', text: 'Tasks should be split equally down the middle' },
        { id: 'b', text: 'Each person should handle what they are best at or enjoy most' },
        { id: 'c', text: 'Whoever has more free time should pick up the slack' },
        { id: 'd', text: 'A clear schedule or chore chart keeps things fair' }
      ]},
      { area: 'lifestyle', text: 'How much time apart from your partner do you need?', options: [
        { id: 'a', text: 'Very little — I prefer doing most things together' },
        { id: 'b', text: 'Some alone time each week is healthy' },
        { id: 'c', text: 'I need significant personal space and independent hobbies' },
        { id: 'd', text: 'It depends on the week — I like flexibility' }
      ]},
      // Values & Goals (3)
      { area: 'values', text: 'When it comes to finances, your approach is:', options: [
        { id: 'a', text: 'Save as much as possible and spend conservatively' },
        { id: 'b', text: 'Budget carefully but enjoy experiences and treats along the way' },
        { id: 'c', text: 'Spend freely on what makes you happy — life is short' },
        { id: 'd', text: 'Invest aggressively and focus on long-term wealth building' }
      ]},
      { area: 'values', text: 'How important is career ambition to you in a relationship?', options: [
        { id: 'a', text: 'Very — I want both of us to be driven and career-focused' },
        { id: 'b', text: 'Somewhat — careers matter but should not overshadow the relationship' },
        { id: 'c', text: 'Not very — work-life balance and personal fulfillment matter more' },
        { id: 'd', text: 'I care more about shared values than career ambition specifically' }
      ]},
      { area: 'values', text: 'When you think about the future, you prioritize:', options: [
        { id: 'a', text: 'Family — building a home and possibly raising children' },
        { id: 'b', text: 'Experiences — traveling, learning, and exploring together' },
        { id: 'c', text: 'Stability — financial security, a comfortable routine, and peace' },
        { id: 'd', text: 'Growth — personal development, new challenges, and evolving together' }
      ]},
      // Intimacy (3)
      { area: 'intimacy', text: 'Emotional intimacy to you means:', options: [
        { id: 'a', text: 'Being able to share your deepest fears and insecurities without judgment' },
        { id: 'b', text: 'Feeling understood without having to explain yourself' },
        { id: 'c', text: 'Having regular deep conversations about feelings and the relationship' },
        { id: 'd', text: 'Showing vulnerability through actions more than words' }
      ]},
      { area: 'intimacy', text: 'How important is physical affection in your daily life?', options: [
        { id: 'a', text: 'Essential — I need hugs, kisses, and touch throughout the day' },
        { id: 'b', text: 'Important — regular affection, but I do not need it constantly' },
        { id: 'c', text: 'Nice but not critical — I show love in other ways' },
        { id: 'd', text: 'I prefer affection in private, not as a constant presence' }
      ]},
      { area: 'intimacy', text: 'When it comes to expressing love and appreciation, you tend to:', options: [
        { id: 'a', text: 'Say it often and directly — frequent "I love you" and compliments' },
        { id: 'b', text: 'Show it through actions — doing things that make their life easier' },
        { id: 'c', text: 'Plan special moments — dates, surprises, and quality time' },
        { id: 'd', text: 'Physical closeness — a touch, a look, or being near each other' }
      ]}
    ];

    var areaTips = {
      communication: {
        title: 'Communication Style',
        tips: [
          'Set aside 15 minutes daily to check in with each other without screens or distractions.',
          'Practice "I feel" statements instead of "you always" or "you never" during conversations.',
          'Ask your partner how they prefer to receive difficult news — matching their communication style reduces misunderstandings.',
          'When listening, repeat back what you heard before responding to make sure you understood correctly.'
        ]
      },
      conflict: {
        title: 'Conflict Resolution',
        tips: [
          'Agree on a "cool-down" signal either of you can use when emotions are too high to argue productively.',
          'Focus on the specific issue at hand — avoid bringing up past arguments or unrelated grievances.',
          'After resolving a conflict, acknowledge what you each did well and what you could improve next time.',
          'Remember you are on the same team — the goal is to solve the problem together, not to win.'
        ]
      },
      lifestyle: {
        title: 'Lifestyle Preferences',
        tips: [
          'Create a shared calendar to balance social events, adventures, and quiet time at home.',
          'Discuss household expectations openly — unspoken assumptions about chores cause more resentment than the chores themselves.',
          'Support each other\'s need for personal space and independent interests without taking it personally.',
          'Try each other\'s preferred activities regularly — you might discover new things you enjoy together.'
        ]
      },
      values: {
        title: 'Values & Goals',
        tips: [
          'Have regular "state of the union" conversations about your shared goals and how you are progressing toward them.',
          'Create a joint financial plan that respects both partners\' spending and saving philosophies.',
          'Discuss your vision for the future at least once a year — people\'s priorities evolve, and staying aligned requires ongoing conversation.',
          'Focus on understanding why your partner holds their values rather than trying to change them.'
        ]
      },
      intimacy: {
        title: 'Intimacy',
        tips: [
          'Ask your partner what makes them feel emotionally safe and do more of it consistently.',
          'Schedule regular one-on-one time that prioritizes connection over logistics or problem-solving.',
          'Be specific about your physical affection needs — your partner may not realize what matters most to you.',
          'Practice vulnerability by sharing one thing each week that you found difficult, even if it feels uncomfortable.'
        ]
      }
    };

    var p1Answers = [];
    var p2Answers = [];
    var currentQ = 0;
    var currentPartner = 1;

    var quizSection = document.getElementById('quiz-section');
    var handoffSection = document.getElementById('handoff-section');
    var resultsSection = document.getElementById('results-section');
    var progressFill = document.getElementById('progress-fill');
    var progressText = document.getElementById('progress-text');
    var questionNumber = document.getElementById('question-number');
    var questionPrompt = document.getElementById('question-prompt');
    var questionArea = document.getElementById('question-area');
    var choicesDiv = document.getElementById('choices');
    var partnerBadge = document.getElementById('partner-badge');

    function showQuestion() {
      var q = questions[currentQ];
      progressFill.style.width = (currentQ / questions.length * 100) + '%';
      progressText.textContent = 'Question ' + (currentQ + 1) + ' of ' + questions.length;
      questionNumber.textContent = currentQ + 1;
      questionPrompt.textContent = q.text;
      questionArea.textContent = areaLabels[q.area];
      questionArea.style.borderColor = areaColors[q.area];
      questionArea.style.color = areaColors[q.area];
      partnerBadge.textContent = 'Partner ' + currentPartner;

      choicesDiv.innerHTML = '';
      for (var i = 0; i < q.options.length; i++) {
        var btn = document.createElement('button');
        btn.className = 'choice-btn';
        btn.textContent = q.options[i].text;
        btn.setAttribute('data-id', q.options[i].id);
        btn.addEventListener('click', function() {
          selectAnswer(this.getAttribute('data-id'));
        });
        choicesDiv.appendChild(btn);
      }
    }

    function selectAnswer(answerId) {
      if (currentPartner === 1) {
        p1Answers.push(answerId);
      } else {
        p2Answers.push(answerId);
      }
      currentQ++;
      if (currentQ < questions.length) {
        showQuestion();
      } else if (currentPartner === 1) {
        showHandoff();
      } else {
        showResults();
      }
    }

    function showHandoff() {
      quizSection.style.display = 'none';
      handoffSection.style.display = 'block';
      handoffSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    document.getElementById('start-p2-btn').addEventListener('click', function() {
      currentPartner = 2;
      currentQ = 0;
      handoffSection.style.display = 'none';
      quizSection.style.display = 'block';
      showQuestion();
      quizSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    function calcAreaScores() {
      var areaScores = {};
      var qIndex = 0;
      for (var a = 0; a < areas.length; a++) {
        var area = areas[a];
        var matches = 0;
        var total = 0;
        for (var i = 0; i < questions.length; i++) {
          if (questions[i].area === area) {
            total++;
            if (p1Answers[i] === p2Answers[i]) {
              matches++;
            }
          }
        }
        areaScores[area] = Math.round(matches / total * 100);
      }
      return areaScores;
    }

    function drawRadar(areaScores) {
      var canvas = document.getElementById('radar-canvas');
      var ctx = canvas.getContext('2d');
      var dpr = window.devicePixelRatio || 1;
      var size = 400;
      canvas.width = size * dpr;
      canvas.height = size * dpr;
      canvas.style.width = size + 'px';
      canvas.style.height = size + 'px';
      ctx.scale(dpr, dpr);

      var cx = size / 2;
      var cy = size / 2;
      var maxR = 150;
      var levels = 4;
      var n = areas.length;
      var angleStep = (Math.PI * 2) / n;
      var startAngle = -Math.PI / 2;

      // Get computed styles for theme awareness
      var cs = getComputedStyle(document.documentElement);
      var textColor = cs.getPropertyValue('--text-primary').trim() || '#1e293b';
      var borderColor = cs.getPropertyValue('--border-color').trim() || '#e2e8f0';
      var accentColor = cs.getPropertyValue('--accent-color').trim() || '#6366f1';

      // Draw grid
      for (var l = 1; l <= levels; l++) {
        var r = maxR * l / levels;
        ctx.beginPath();
        for (var i = 0; i <= n; i++) {
          var angle = startAngle + i * angleStep;
          var x = cx + r * Math.cos(angle);
          var y = cy + r * Math.sin(angle);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = borderColor;
        ctx.lineWidth = 1;
        ctx.stroke();

        // Percentage labels on first axis
        ctx.fillStyle = textColor;
        ctx.font = '11px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText((l * 25) + '%', cx, cy - r + 14);
      }

      // Draw axes and labels
      for (var i = 0; i < n; i++) {
        var angle = startAngle + i * angleStep;
        var x = cx + maxR * Math.cos(angle);
        var y = cy + maxR * Math.sin(angle);
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.lineTo(x, y);
        ctx.strokeStyle = borderColor;
        ctx.lineWidth = 1;
        ctx.stroke();

        // Labels
        var lx = cx + (maxR + 30) * Math.cos(angle);
        var ly = cy + (maxR + 30) * Math.sin(angle);
        ctx.fillStyle = textColor;
        ctx.font = 'bold 12px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(areaLabels[areas[i]], lx, ly);
      }

      // Draw data polygon
      ctx.beginPath();
      for (var i = 0; i <= n; i++) {
        var idx = i % n;
        var angle = startAngle + idx * angleStep;
        var val = areaScores[areas[idx]] / 100;
        var x = cx + maxR * val * Math.cos(angle);
        var y = cy + maxR * val * Math.sin(angle);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.fillStyle = accentColor + '33';
      ctx.fill();
      ctx.strokeStyle = accentColor;
      ctx.lineWidth = 2.5;
      ctx.stroke();

      // Draw data points
      for (var i = 0; i < n; i++) {
        var angle = startAngle + i * angleStep;
        var val = areaScores[areas[i]] / 100;
        var x = cx + maxR * val * Math.cos(angle);
        var y = cy + maxR * val * Math.sin(angle);
        ctx.beginPath();
        ctx.arc(x, y, 5, 0, Math.PI * 2);
        ctx.fillStyle = accentColor;
        ctx.fill();
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 2;
        ctx.stroke();
      }
    }

    function showResults() {
      quizSection.style.display = 'none';
      handoffSection.style.display = 'none';
      resultsSection.style.display = 'block';
      progressFill.style.width = '100%';

      var areaScores = calcAreaScores();

      // Overall score
      var total = 0;
      for (var i = 0; i < areas.length; i++) {
        total += areaScores[areas[i]];
      }
      var overall = Math.round(total / areas.length);
      document.getElementById('overall-score').textContent = overall + '%';

      var summaryText;
      if (overall >= 80) summaryText = 'You two are strongly aligned across most areas. Your natural compatibility is a solid foundation — keep communicating openly to maintain it.';
      else if (overall >= 60) summaryText = 'You share a solid foundation with some areas where your perspectives differ. These differences are opportunities to learn from each other and grow together.';
      else if (overall >= 40) summaryText = 'You have meaningful differences in several areas. This is not a bad thing — couples who actively work on understanding each other\'s perspectives often build the strongest relationships.';
      else summaryText = 'You approach many areas of your relationship quite differently. This can actually bring balance and new perspectives to your partnership if you both commit to open, honest communication.';
      document.getElementById('overall-summary').textContent = summaryText;

      // Radar chart
      drawRadar(areaScores);

      // Area score bars
      var areaContainer = document.getElementById('area-scores');
      areaContainer.innerHTML = '';
      for (var i = 0; i < areas.length; i++) {
        var area = areas[i];
        var score = areaScores[area];
        var row = document.createElement('div');
        row.className = 'area-row';

        var label = document.createElement('div');
        label.className = 'area-label';
        label.textContent = areaLabels[area];

        var barWrap = document.createElement('div');
        barWrap.className = 'area-bar-wrap';

        var bar = document.createElement('div');
        bar.className = 'area-bar';
        bar.style.width = score + '%';
        bar.style.background = areaColors[area];
        bar.style.minWidth = score > 0 ? '2.5rem' : '0';

        var scoreLabel = document.createElement('span');
        scoreLabel.className = 'area-score-label';
        scoreLabel.textContent = score + '%';
        bar.appendChild(scoreLabel);

        barWrap.appendChild(bar);
        row.appendChild(label);
        row.appendChild(barWrap);
        areaContainer.appendChild(row);
      }

      // Strengths and growth areas
      var sorted = areas.slice().sort(function(a, b) { return areaScores[b] - areaScores[a]; });
      var strengthsDiv = document.getElementById('strengths-section');
      var growthDiv = document.getElementById('growth-section');
      var tipsDiv = document.getElementById('tips-section');
      strengthsDiv.innerHTML = '';
      growthDiv.innerHTML = '';
      tipsDiv.innerHTML = '';

      var strengths = [];
      var growthAreas = [];
      for (var i = 0; i < sorted.length; i++) {
        if (areaScores[sorted[i]] >= 67) {
          strengths.push(sorted[i]);
        } else {
          growthAreas.push(sorted[i]);
        }
      }
      if (strengths.length === 0) strengths.push(sorted[0]);
      if (growthAreas.length === 0) growthAreas.push(sorted[sorted.length - 1]);

      for (var i = 0; i < strengths.length; i++) {
        var area = strengths[i];
        var card = document.createElement('div');
        card.className = 'strength-card';
        card.innerHTML = '<div class="strength-icon" style="color:' + areaColors[area] + '">&#10003;</div>' +
          '<div><h3>' + areaLabels[area] + ' — ' + areaScores[area] + '%</h3>' +
          '<p>You and your partner are well-aligned in this area. You likely share similar expectations and approaches, which naturally reduces friction and builds trust.</p></div>';
        strengthsDiv.appendChild(card);
      }

      for (var i = 0; i < growthAreas.length; i++) {
        var area = growthAreas[i];
        var tips = areaTips[area];
        var card = document.createElement('div');
        card.className = 'growth-card';
        card.innerHTML = '<div class="growth-icon" style="color:' + areaColors[area] + '">&#9679;</div>' +
          '<div><h3>' + areaLabels[area] + ' — ' + areaScores[area] + '%</h3>' +
          '<p>You have different approaches in this area. This is an opportunity to learn from each other and establish shared expectations through open dialogue.</p></div>';
        growthDiv.appendChild(card);

        var tipCard = document.createElement('div');
        tipCard.className = 'tip-card';
        tipCard.style.borderLeftColor = areaColors[area];
        var tipHTML = '<h3>' + tips.title + '</h3><ul>';
        for (var j = 0; j < tips.tips.length; j++) {
          tipHTML += '<li>' + tips.tips[j] + '</li>';
        }
        tipHTML += '</ul>';
        tipCard.innerHTML = tipHTML;
        tipsDiv.appendChild(tipCard);
      }

      resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Share button
    document.getElementById('share-btn').addEventListener('click', function() {
      var areaScores = calcAreaScores();
      var total = 0;
      for (var i = 0; i < areas.length; i++) total += areaScores[areas[i]];
      var overall = Math.round(total / areas.length);

      var text = "Our Relationship Compatibility Results:\n\n";
      text += "Overall Compatibility: " + overall + "%\n\n";
      for (var i = 0; i < areas.length; i++) {
        text += areaLabels[areas[i]] + ": " + areaScores[areas[i]] + "%\n";
      }
      text += "\nTake the quiz: " + window.location.href;

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
          var btn = document.getElementById('share-btn');
          btn.textContent = 'Copied to Clipboard!';
          setTimeout(function() { btn.textContent = 'Share Results'; }, 2000);
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        var btn = document.getElementById('share-btn');
        btn.textContent = 'Copied to Clipboard!';
        setTimeout(function() { btn.textContent = 'Share Results'; }, 2000);
      }
    });

    // Retake button
    document.getElementById('retake-btn').addEventListener('click', function() {
      p1Answers = [];
      p2Answers = [];
      currentQ = 0;
      currentPartner = 1;
      resultsSection.style.display = 'none';
      quizSection.style.display = 'block';
      showQuestion();
      quizSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    showQuestion();
  })();
  </script>

