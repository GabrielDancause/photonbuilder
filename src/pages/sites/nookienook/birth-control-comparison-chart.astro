        durationCat: "short",
        hormones: "Yes",
        sti: "No",
        reversible: "Yes",
        cost: "$35–$90",
        tags: [],
        how: "Ulipristal acetate taken within 120 hours (5 days) of unprotected sex. Delays ovulation even when LH surge has begun. Requires a prescription.",
        pros: "Effective up to 5 days after unprotected sex, more effective than Plan B at higher body weights",
        cons: "Prescription required, may interact with hormonal contraceptives, may cause nausea and headache",
        bestFor: "Emergency backup especially when more than 72 hours have passed or for people over 155 lbs"
      }
    ];

    const tbody = document.getElementById('bc-tbody');
    let currentSort = { col: null, asc: true };
    let activeCategory = 'all';

    function getFilteredMethods() {
      const typeVal = document.getElementById('filter-type').value;
      const hormoneVal = document.getElementById('filter-hormones').value;
      const effVal = document.getElementById('filter-effectiveness').value;
      const durVal = document.getElementById('filter-duration').value;

      return methods.filter(m => {
        if (activeCategory !== 'all' && !m.tags.includes(activeCategory)) return false;
        if (typeVal !== 'all' && m.type !== typeVal) return false;
        if (hormoneVal === 'yes' && m.hormones !== 'Yes') return false;
        if (hormoneVal === 'no' && m.hormones !== 'No') return false;
        if (effVal !== 'all' && m.typical < parseInt(effVal)) return false;
        if (durVal !== 'all' && m.durationCat !== durVal) return false;
        return true;
      });
    }

    function sortMethods(list) {
      if (!currentSort.col) return list;
      return [...list].sort((a, b) => {
        let va = a[currentSort.col], vb = b[currentSort.col];
        if (typeof va === 'number') return currentSort.asc ? va - vb : vb - va;
        return currentSort.asc ? String(va).localeCompare(String(vb)) : String(vb).localeCompare(String(va));
      });
    }

    function effClass(val) {
      if (val >= 99) return 'eff-excellent';
      if (val >= 93) return 'eff-good';
      if (val >= 85) return 'eff-moderate';
      return 'eff-low';
    }

    function typeLabel(t) {
      return { hormonal: 'Hormonal', barrier: 'Barrier', behavioral: 'Behavioral', permanent: 'Permanent', emergency: 'Emergency' }[t] || t;
    }

    function render() {
      const filtered = sortMethods(getFilteredMethods());
      if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:2rem;color:var(--text-secondary);">No methods match your filters. Try adjusting your selection.</td></tr>';
        return;
      }
      tbody.innerHTML = filtered.map(m => `
        <tr class="bc-row" data-name="${m.name}">
          <td class="method-name">${m.name}</td>
          <td><span class="type-badge type-${m.type}">${typeLabel(m.type)}</span></td>
          <td><span class="eff-badge ${effClass(m.typical)}">${m.typical}%</span></td>
          <td><span class="eff-badge ${effClass(m.perfect)}">${m.perfect}%</span></td>
          <td>${m.duration}</td>
          <td>${m.hormones === 'Yes' ? '<span class="yes-badge">Yes</span>' : '<span class="no-badge">No</span>'}</td>
          <td>${m.sti === 'Yes' ? '<span class="yes-badge">Yes</span>' : '<span class="no-badge">No</span>'}</td>
          <td>${m.reversible}</td>
          <td>${m.cost}</td>
        </tr>
        <tr class="detail-row" id="detail-${m.name.replace(/[^a-z0-9]/gi,'-')}" style="display:none;">
          <td colspan="9">
            <div class="detail-card">
              <div class="detail-grid">
                <div><h4>How It Works</h4><p>${m.how}</p></div>
                <div><h4>Pros</h4><p>${m.pros}</p></div>
                <div><h4>Cons</h4><p>${m.cons}</p></div>
                <div><h4>Best For</h4><p>${m.bestFor}</p></div>
              </div>
            </div>
          </td>
        </tr>
      `).join('');

      tbody.querySelectorAll('.bc-row').forEach(row => {
        row.addEventListener('click', () => {
          const name = row.dataset.name;
          const detail = document.getElementById('detail-' + name.replace(/[^a-z0-9]/gi, '-'));
          if (detail) {
            const isOpen = detail.style.display !== 'none';
            tbody.querySelectorAll('.detail-row').forEach(d => d.style.display = 'none');
            tbody.querySelectorAll('.bc-row').forEach(r => r.classList.remove('expanded'));
            if (!isOpen) {
              detail.style.display = 'table-row';
              row.classList.add('expanded');
            }
          }
        });
      });
    }

    // Sorting
    document.querySelectorAll('.sortable').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (currentSort.col === col) {
          currentSort.asc = !currentSort.asc;
        } else {
          currentSort.col = col;
          currentSort.asc = col === 'typical' || col === 'perfect' ? false : true;
        }
        document.querySelectorAll('.sortable').forEach(h => h.classList.remove('sort-asc','sort-desc'));
        th.classList.add(currentSort.asc ? 'sort-asc' : 'sort-desc');
        render();
      });
    });

    // Filters
    document.querySelectorAll('.filters select').forEach(sel => {
      sel.addEventListener('change', render);
    });

    // Category picks
    document.querySelectorAll('.pick-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.pick-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.dataset.filter;
        render();
      });
    });

    render();
  })();
  </script>

  <style is:inline>
    .page-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .disclaimer { background: #fef3c7; border: 1px solid #f59e0b; border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 2rem; font-size: 0.92rem; color: #92400e; line-height: 1.5; }
    @media (prefers-color-scheme: dark) {
      .disclaimer { background: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.3); color: #fbbf24; }
    }

    .content-section { margin-top: 1rem; color: var(--text-primary); line-height: 1.6; }
    .content-section h2 { font-size: 1.8rem; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--accent-color); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    .content-section h3 { font-size: 1.4rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
    .content-section p { margin-bottom: 1rem; }
    .content-section ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .content-section li { margin-bottom: 0.5rem; }
    .content-section a { color: var(--accent-color); text-decoration: underline; text-underline-offset: 3px; font-weight: 500; }
    .content-section a:hover { color: var(--text-primary); }

    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05); }
    .card h3 { margin-top: 0; color: var(--text-primary); }

    .note { font-size: 0.9rem; color: var(--text-secondary); font-style: italic; }

    /* Category picks */
    .category-picks { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
    .pick-btn { padding: 0.5rem 1rem; border-radius: 20px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-primary); cursor: pointer; font-size: 0.9rem; font-weight: 500; transition: all 0.2s; }
    .pick-btn:hover { border-color: var(--accent-color); color: var(--accent-color); }
    .pick-btn.active { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }

    /* Filters */
    .filters { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-top: 0.5rem; }
    .filter-group label { display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--text-secondary); }
    .filter-group select { width: 100%; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-primary); font-size: 0.95rem; }

    /* Table */
    .table-wrap { overflow-x: auto; margin: 1rem 0; border-radius: 12px; border: 1px solid var(--border-color); }
    #bc-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
    #bc-table thead { background: var(--card-bg); }
    #bc-table th { padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; white-space: nowrap; border-bottom: 2px solid var(--border-color); color: var(--text-primary); }
    #bc-table td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); }
    .sortable { cursor: pointer; user-select: none; }
    .sortable:hover { color: var(--accent-color); }
    .sort-icon { font-size: 0.75rem; opacity: 0.4; }
    .sort-asc .sort-icon, .sort-desc .sort-icon { opacity: 1; }

    .bc-row { cursor: pointer; transition: background 0.15s; }
    .bc-row:hover { background: rgba(var(--accent-rgb, 99,102,241), 0.06); }
    .bc-row.expanded { background: rgba(var(--accent-rgb, 99,102,241), 0.08); }
    .method-name { font-weight: 600; color: var(--text-primary); }

    /* Badges */
    .type-badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 10px; font-size: 0.8rem; font-weight: 600; }
    .type-hormonal { background: #ede9fe; color: #6d28d9; }
    .type-barrier { background: #dbeafe; color: #1d4ed8; }
    .type-behavioral { background: #fef3c7; color: #b45309; }
    .type-permanent { background: #fee2e2; color: #dc2626; }
    .type-emergency { background: #ffedd5; color: #c2410c; }
    @media (prefers-color-scheme: dark) {
      .type-hormonal { background: rgba(109,40,217,0.2); color: #c4b5fd; }
      .type-barrier { background: rgba(29,78,216,0.2); color: #93c5fd; }
      .type-behavioral { background: rgba(180,83,9,0.2); color: #fcd34d; }
      .type-permanent { background: rgba(220,38,38,0.2); color: #fca5a5; }
      .type-emergency { background: rgba(194,65,12,0.2); color: #fdba74; }
    }

    .eff-badge { display: inline-block; padding: 0.15rem 0.45rem; border-radius: 8px; font-size: 0.82rem; font-weight: 700; }
    .eff-excellent { background: #d1fae5; color: #065f46; }
    .eff-good { background: #dbeafe; color: #1e40af; }
    .eff-moderate { background: #fef3c7; color: #92400e; }
    .eff-low { background: #fee2e2; color: #991b1b; }
    @media (prefers-color-scheme: dark) {
      .eff-excellent { background: rgba(6,95,70,0.3); color: #6ee7b7; }
      .eff-good { background: rgba(30,64,175,0.3); color: #93c5fd; }
      .eff-moderate { background: rgba(146,64,14,0.3); color: #fcd34d; }
      .eff-low { background: rgba(153,27,27,0.3); color: #fca5a5; }
    }

    .yes-badge { color: #059669; font-weight: 600; }
    .no-badge { color: var(--text-secondary); }
    @media (prefers-color-scheme: dark) {
      .yes-badge { color: #34d399; }
    }

    /* Detail row */
    .detail-row td { padding: 0 !important; background: var(--card-bg); }
    .detail-card { padding: 1.25rem 1rem; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .detail-grid h4 { margin: 0 0 0.35rem; font-size: 0.95rem; color: var(--accent-color); }
    .detail-grid p { margin: 0; font-size: 0.9rem; line-height: 1.5; }

    @media (max-width: 768px) {
      .page-content { padding: 1rem; }
      .hero h1 { font-size: 1.6rem; }
      .filters { grid-template-columns: 1fr 1fr; }
      .detail-grid { grid-template-columns: 1fr; }
      #bc-table { font-size: 0.82rem; }
      #bc-table th, #bc-table td { padding: 0.5rem 0.4rem; }
    }

    @media (max-width: 480px) {
      .filters { grid-template-columns: 1fr; }
      .category-picks { justify-content: center; }
    }
  </style>
</SiteLayout>
