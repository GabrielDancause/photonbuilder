    .input-wrapper input[id="initialPrice"],
    .input-wrapper input[id="annualDividend"] {
      padding-left: 2.5rem;
    }

    .input-wrapper input[id="dividendGrowthRate"] {
      padding-right: 2.5rem;
    }

    .input-group input {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 1rem;
      transition: border-color 0.2s;
    }

    .input-group input:focus {
      outline: none;
      border-color: var(--accent-color);
    }

    .results-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
    }

    .result-box {
      background: color-mix(in srgb, var(--bg-color) 50%, transparent);
      padding: 1.5rem;
      border-radius: 12px;
      text-align: center;
      border: 1px solid var(--border-color);
    }

    .result-box.highlight {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border-color: var(--accent-color);
    }

    .result-box h4 {
      margin: 0 0 0.5rem 0;
      font-size: 0.9rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .result-value {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .result-box.highlight .result-value {
      color: var(--accent-color);
    }

    .result-desc {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin: 0;
      line-height: 1.4;
    }

    .calc-note {
      text-align: center;
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-top: 2rem;
      font-style: italic;
    }

    /* FAQ Styles */
    .faq-section {
      margin-top: 4rem;
      border-top: 2px solid var(--border-color);
      padding-top: 2rem;
    }

    .faq-item {
      margin-bottom: 1.5rem;
      background: var(--card-bg);
      padding: 1.5rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .faq-item h3 {
      margin-top: 0;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-item p {
      margin: 0;
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <script>
    function initCalculator() {
      const initialPriceInput = document.getElementById('initialPrice') as HTMLInputElement;
      const annualDividendInput = document.getElementById('annualDividend') as HTMLInputElement;
      const dividendGrowthRateInput = document.getElementById('dividendGrowthRate') as HTMLInputElement;
      const yearsHeldInput = document.getElementById('yearsHeld') as HTMLInputElement;

      const initialYieldResult = document.getElementById('initialYieldResult');
      const futureDividendResult = document.getElementById('futureDividendResult');
      const yieldOnCostResult = document.getElementById('yieldOnCostResult');

      if (!initialPriceInput || !annualDividendInput || !dividendGrowthRateInput || !yearsHeldInput ||
          !initialYieldResult || !futureDividendResult || !yieldOnCostResult) return;

      function calculate() {
        const initialPrice = parseFloat(initialPriceInput.value) || 0;
        const currentDividend = parseFloat(annualDividendInput.value) || 0;
        const growthRate = parseFloat(dividendGrowthRateInput.value) || 0;
        const years = parseInt(yearsHeldInput.value) || 0;

        if (initialPrice <= 0) {
          initialYieldResult.textContent = '--%';
          futureDividendResult.textContent = '--';
          yieldOnCostResult.textContent = '--%';
          return;
        }

        // Initial Yield
        const initialYield = (currentDividend / initialPrice) * 100;
        initialYieldResult.textContent = initialYield.toFixed(2) + '%';

        // Future Dividend
        const futureDividend = currentDividend * Math.pow(1 + (growthRate / 100), years);
        futureDividendResult.textContent = '$' + futureDividend.toFixed(2);

        // Yield on Cost
        const yieldOnCost = (futureDividend / initialPrice) * 100;
        yieldOnCostResult.textContent = yieldOnCost.toFixed(2) + '%';
      }

      // Add event listeners
      [initialPriceInput, annualDividendInput, dividendGrowthRateInput, yearsHeldInput].forEach(input => {
        input.addEventListener('input', calculate);
      });

      // Initial calculation
      calculate();
    }

    // Initialize on load and view transitions
    document.addEventListener('astro:page-load', initCalculator);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCalculator);
    } else {
      initCalculator();
    }
  </script>
</SiteLayout>
