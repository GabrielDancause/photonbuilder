---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Coming Soon — Upcoming Research & Tools', description: 'See what investment research, stock analysis tools, and dividend guides are coming next to Westmount Fundamentals.', category: 'guides', published: '2026-03-15' };

const SITE_ID = 'westmount';

// Auto-discover existing pages
const allPages = import.meta.glob('./*.astro', { eager: true });
const publishedCount = Object.keys(allPages).filter(k => !k.includes('index') && !k.includes('coming-soon')).length;

const categories = [
  {
    icon: '🔧',
    title: 'Tools & Calculators',
    description: 'Interactive investment tools with real-time calculations',
    total: 52,
    items: [
      { name: 'Options Profit Calculator', searches: '26,500', status: 'building' },
      { name: 'Options Calculator', searches: '21,400', status: 'building' },
      { name: 'Stock Portfolio Tracker', searches: '13,050', status: 'building' },
      { name: 'DRIP Calculator', searches: '12,000', status: 'published', href: '/westmount/drip-calculator' },
      { name: 'Margin Calculator (Stocks)', searches: '8,000', status: 'published', href: '/westmount/margin-calculator-stocks' },
      { name: 'Position Size Calculator', searches: '6,500', status: 'building' },
      { name: 'Dividend Reinvestment Calculator', searches: '5,100', status: 'building' },
      { name: 'Stock Profit Calculator', searches: '6,700', status: 'building' },
    ]
  },
  {
    icon: '📊',
    title: 'Stock Analysis',
    description: 'Deep dives into individual stocks, sectors, and market trends',
    total: 626,
    items: [
      { name: 'Tesla Stock Analysis', searches: '84,000', status: 'building' },
      { name: 'Best Stocks to Buy Now', searches: '83,000', status: 'published', href: '/westmount/best-stocks-to-buy-now' },
      { name: 'Nvidia Stock Analysis', searches: '50,000', status: 'building' },
      { name: 'Quantum Computing Stocks', searches: '40,300', status: 'published', href: '/westmount/quantum-computing-stocks' },
      { name: 'Amazon Stock Analysis', searches: '31,000', status: 'building' },
      { name: 'Nuclear Energy Stocks', searches: '18,000', status: 'published', href: '/westmount/nuclear-energy-stocks' },
      { name: 'AI Stocks', searches: '15,000', status: 'published', href: '/westmount/ai-stocks' },
      { name: 'Penny Stocks Guide', searches: '14,000', status: 'published', href: '/westmount/penny-stocks' },
    ]
  },
  {
    icon: '📈',
    title: 'ETF Research',
    description: 'Comprehensive ETF analysis, comparisons, and dividend data',
    total: 207,
    items: [
      { name: 'SCHD Dividend Analysis', searches: '107,600', status: 'published', href: '/westmount/schd-dividend' },
      { name: 'VOO Dividend Guide', searches: '33,900', status: 'published', href: '/westmount/voo-dividend' },
      { name: 'QQQI Dividend History', searches: '28,000', status: 'published', href: '/westmount/qqqi-dividend-history' },
      { name: 'Bitcoin ETFs Guide', searches: '16,800', status: 'building' },
      { name: 'SPYI Dividend History', searches: '16,600', status: 'building' },
      { name: 'S&P 500 Index Fund Guide', searches: '15,300', status: 'building' },
      { name: 'SPY Dividend Analysis', searches: '13,700', status: 'building' },
      { name: 'Best ETFs for 2026', searches: '10,000', status: 'building' },
    ]
  },
  {
    icon: '💰',
    title: 'Dividend Guides',
    description: 'Dividend analysis, yield comparisons, and income strategies',
    total: 431,
    items: [
      { name: 'MSTY Dividend History', searches: '86,950', status: 'published', href: '/westmount/msty-dividend-history' },
      { name: 'Best Dividend Stocks', searches: '84,200', status: 'published', href: '/westmount/best-dividend-stocks' },
      { name: 'ULTY Dividend History', searches: '59,050', status: 'published', href: '/westmount/ulty-dividend-history' },
      { name: 'JEPQ Dividend', searches: '38,300', status: 'published', href: '/westmount/jepq-dividend' },
      { name: 'JEPI Dividend', searches: '35,400', status: 'published', href: '/westmount/jepi-dividend' },
      { name: 'What Is a Dividend', searches: '30,700', status: 'published', href: '/westmount/what-is-a-dividend' },
      { name: 'Highest Dividend Stocks', searches: '25,350', status: 'building' },
      { name: 'CONY Dividend', searches: '14,000', status: 'published', href: '/westmount/cony-dividend' },
    ]
  },
  {
    icon: '🎓',
    title: 'Investment Education',
    description: 'Guides for beginner and intermediate investors',
    total: 91,
    items: [
      { name: 'How to Invest in Stocks', searches: '113,000', status: 'building' },
      { name: 'How to Buy Stocks', searches: '18,000', status: 'published', href: '/westmount/how-to-buy-stocks' },
      { name: 'What Are Stocks', searches: '14,500', status: 'published', href: '/westmount/what-are-stocks' },
      { name: 'Best Stocks for Beginners', searches: '12,000', status: 'building' },
      { name: 'How to Invest in S&P 500', searches: '12,000', status: 'building' },
      { name: 'What Is the S&P 500', searches: '11,000', status: 'building' },
      { name: 'What Is a Portfolio', searches: '8,100', status: 'building' },
      { name: 'How to Start Investing', searches: '4,600', status: 'building' },
    ]
  },
];
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID}>
  <style is:inline>
    .coming-soon-hero {
      text-align: center;
      padding: 3rem 1rem 2rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .coming-soon-hero h1 {
      font-size: 2.2rem;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, var(--accent), #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .coming-soon-hero p {
      color: var(--text-secondary);
      font-size: 1.1rem;
      line-height: 1.6;
    }

    .stats-bar {
      display: flex;
      justify-content: center;
      gap: 2rem;
      padding: 1.5rem;
      margin: 0 auto 2rem;
      max-width: 700px;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
    }
    .stat { text-align: center; }
    .stat-number {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--accent);
    }
    .stat-label {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .category-section {
      max-width: 900px;
      margin: 0 auto 2.5rem;
      padding: 0 1rem;
    }
    .category-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .category-header h2 {
      font-size: 1.4rem;
      margin: 0;
    }
    .category-count {
      background: var(--card-bg);
      border: 1px solid var(--border);
      padding: 0.15rem 0.6rem;
      border-radius: 20px;
      font-size: 0.75rem;
      color: var(--text-secondary);
    }
    .category-desc {
      color: var(--text-secondary);
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .items-grid {
      display: grid;
      gap: 0.5rem;
    }
    .item-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1rem;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      transition: border-color 0.2s;
    }
    .item-row:hover { border-color: var(--accent); }
    .item-row a {
      color: var(--text-primary);
      text-decoration: none;
      font-weight: 500;
    }
    .item-row a:hover { color: var(--accent); }
    .item-name { font-weight: 500; }
    .item-right {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .item-searches {
      font-size: 0.8rem;
      color: var(--text-secondary);
    }
    .badge {
      font-size: 0.7rem;
      padding: 0.2rem 0.6rem;
      border-radius: 20px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .badge-published {
      background: rgba(34, 197, 94, 0.15);
      color: #22c55e;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }
    .badge-building {
      background: rgba(245, 158, 11, 0.15);
      color: #f59e0b;
      border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .more-coming {
      text-align: center;
      padding: 1rem;
      color: var(--text-secondary);
      font-size: 0.9rem;
      border-top: 1px solid var(--border);
      margin-top: 0.5rem;
    }

    @media (max-width: 640px) {
      .stats-bar { flex-wrap: wrap; gap: 1rem; }
      .item-searches { display: none; }
      .coming-soon-hero h1 { font-size: 1.6rem; }
    }
  </style>

  <div class="coming-soon-hero">
    <h1>📋 Content Roadmap</h1>
    <p>We're building the most comprehensive investment research library on the web. Here's what's published and what's coming next.</p>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-number">{publishedCount}</div>
      <div class="stat-label">Published</div>
    </div>
    <div class="stat">
      <div class="stat-number">1,407</div>
      <div class="stat-label">In Pipeline</div>
    </div>
    <div class="stat">
      <div class="stat-number">6</div>
      <div class="stat-label">Categories</div>
    </div>
  </div>

  {categories.map(cat => (
    <div class="category-section">
      <div class="category-header">
        <span style="font-size:1.5rem">{cat.icon}</span>
        <h2>{cat.title}</h2>
        <span class="category-count">{cat.total} planned</span>
      </div>
      <p class="category-desc">{cat.description}</p>
      <div class="items-grid">
        {cat.items.map(item => (
          <div class="item-row">
            {item.status === 'published' && item.href ? (
              <a href={item.href}>{item.name}</a>
            ) : (
              <span class="item-name">{item.name}</span>
            )}
            <div class="item-right">
              <span class="item-searches">{item.searches}/mo</span>
              <span class={`badge ${item.status === 'published' ? 'badge-published' : 'badge-building'}`}>
                {item.status === 'published' ? '✓ Live' : '🔨 Building'}
              </span>
            </div>
          </div>
        ))}
      </div>
      {cat.total > 8 && (
        <div class="more-coming">+ {cat.total - 8} more {cat.title.toLowerCase()} coming soon</div>
      )}
    </div>
  ))}
</SiteLayout>
