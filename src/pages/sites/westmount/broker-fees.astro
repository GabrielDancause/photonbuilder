// Render margin rate chart
function renderChart(){
  const withMargin=data.filter(d=>d.marginRate!==null).sort((a,b)=>a.marginRate-b.marginRate);
  const maxRate=Math.max(...withMargin.map(d=>d.marginRate));
  const container=document.getElementById('marginChart');
  container.innerHTML=withMargin.map(d=>{
    const pct=(d.marginRate/maxRate*100).toFixed(1);
    const bgGradient = d.marginRate < 7 ? 'bg-gradient-to-r from-[#1a6b3c] to-[#22c55e]' : d.marginRate < 10 ? 'bg-gradient-to-r from-[#7a5c1e] to-[#eab308]' : 'bg-gradient-to-r from-[#7a1e1e] to-[#ef4444]';
    return `<div class="flex items-center mb-2 gap-2.5">
      <div class="w-[180px] min-w-[180px] text-[0.78rem] text-[#8a96a8] text-right font-semibold sm:w-[110px] sm:min-w-[110px] sm:text-[0.7rem]">${d.name.replace(/ \(.*\)/,'')}</div>
      <div class="flex-1 h-[26px] bg-[#0d1428] rounded-md relative overflow-hidden"><div class="h-full rounded-md flex items-center justify-end pr-2 text-[0.7rem] font-bold text-white font-mono min-w-[40px] transition-[width] duration-500 ${bgGradient}" style="width:${pct}%">${d.marginRate.toFixed(2)}%</div></div>
    </div>`;
  }).join('');
}

// Render table
let sortCol='marginRate',sortDir='asc';
function renderTable(){
  const country=document.getElementById('countryFilter').value;
  const search=document.getElementById('searchInput').value.toLowerCase();
  let filtered=data.filter(d=>{
    if(country!=='all'&&d.country!==country)return false;
    if(search&&!d.name.toLowerCase().includes(search))return false;
    return true;
  });
  filtered.sort((a,b)=>{
    let av=a[sortCol],bv=b[sortCol];
    if(av===null)return 1;if(bv===null)return -1;
    if(typeof av==='string')return sortDir==='asc'?av.localeCompare(bv):bv.localeCompare(av);
    if(typeof av==='boolean'){av=av?1:0;bv=bv?1:0;}
    return sortDir==='asc'?av-bv:bv-av;
  });
  const tbody=document.getElementById('tableBody');
  tbody.innerHTML=filtered.map(d=>{
    const fmtFee=v=>v===0?'<span class="text-[#22c55e] font-bold">$0</span>':`<span class="text-[#eab308] font-semibold">$${v.toFixed(2)}</span>`;
    const fmtMargin=v=>v===null?'<span class="text-[#3a4a60]">N/A</span>':v<7?`<span class="text-[#22c55e] font-bold">${v.toFixed(2)}%</span>`:v<10?`<span class="text-[#eab308] font-semibold">${v.toFixed(2)}%</span>`:`<span class="text-[#ef4444] font-semibold">${v.toFixed(2)}%</span>`;
    const fmtBool=v=>v?'<span class="text-[#22c55e]">✓</span>':'<span class="text-[#3a4a60]">✗</span>';
    const stars=n=>'<span class="text-[#eab308]">'+'★'.repeat(n)+'☆'.repeat(5-n)+'</span>';
    const cBadge=`<span class="inline-block bg-[rgba(74,143,231,0.1)] text-[var(--accent-color)] text-[0.65rem] font-bold py-0.5 px-2 rounded-[10px] ml-1.5">${d.country}</span>`;
    return `<tr class="hover:bg-[rgba(74,143,231,0.04)]">
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap"><span class="font-bold text-[#e0e8f0]">${d.name}</span>${cBadge}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${fmtFee(d.stockCommission)}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${fmtFee(d.optionsPerContract)}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${fmtMargin(d.marginRate)}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${d.accountMinimum===0?'<span class="text-[#22c55e] font-bold">$0</span>':`$${d.accountMinimum.toLocaleString()}`}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${fmtBool(d.fractionalShares)}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${fmtBool(d.cryptoTrading)}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${fmtBool(d.internationalMarkets)}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${stars(d.researchRating)}</td>
      <td class="py-2.5 px-3.5 text-[0.82rem] border-b border-[#0d1428] whitespace-nowrap">${stars(d.mobileRating)}</td>
    </tr>`;
  }).join('');
  // Update header classes
  document.querySelectorAll('th').forEach(th=>{
    th.classList.remove('sorted-asc','sorted-desc');
    if(th.dataset.col===sortCol)th.classList.add(sortDir==='asc'?'sorted-asc':'sorted-desc');
  });
}

// Sort handler
document.querySelectorAll('th').forEach(th=>{
  th.addEventListener('click',()=>{
    const col=th.dataset.col;
    if(sortCol===col)sortDir=sortDir==='asc'?'desc':'asc';
    else{sortCol=col;sortDir=col==='name'?'asc':'asc';}
    renderTable();
  });
});

// Filter handlers
document.getElementById('countryFilter').addEventListener('change',renderTable);
document.getElementById('searchInput').addEventListener('input',renderTable);

// FAQ toggle
document.querySelectorAll('.faq-item').forEach(item=>{
  item.querySelector('.faq-q').addEventListener('click',()=>item.classList.toggle('open'));
});

// Init
renderChart();
renderTable();
  </script>
</SiteLayout>
