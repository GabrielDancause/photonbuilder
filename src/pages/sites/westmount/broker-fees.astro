const data = [
  {name:"Interactive Brokers (IBKR Pro)",country:"US",stockCommission:0,optionsPerContract:0.65,marginRate:5.14,accountMinimum:0,fractionalShares:true,cryptoTrading:true,internationalMarkets:true,researchRating:5,mobileRating:4,bestFor:"Advanced/professional traders, lowest margin rates"},
