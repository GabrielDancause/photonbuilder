  {name:"Merrill Edge",country:"US",stockCommission:0,optionsPerContract:0.65,marginRate:11.46,accountMinimum:0,fractionalShares:false,cryptoTrading:false,internationalMarkets:false,researchRating:4,mobileRating:4,bestFor:"Bank of America customers"},
  {name:"Vanguard",country:"US",stockCommission:0,optionsPerContract:1.00,marginRate:11.00,accountMinimum:0,fractionalShares:true,cryptoTrading:false,internationalMarkets:false,researchRating:3,mobileRating:3,bestFor:"Long-term buy-and-hold, index funds"},
