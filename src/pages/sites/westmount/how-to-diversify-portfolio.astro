<script>
  function initCalculator() {
    const inputs = [
      document.getElementById('calc-us-large'),
      document.getElementById('calc-us-small'),
      document.getElementById('calc-intl-dev'),
      document.getElementById('calc-emerging'),
      document.getElementById('calc-bonds'),
      document.getElementById('calc-alts')
    ];

    const errorEl = document.getElementById('calc-error');
    const scoreEl = document.getElementById('calc-score');
    const fillEl = document.getElementById('score-bar-fill');
    const gradeTitleEl = document.getElementById('calc-grade-title');
    const feedbackEl = document.getElementById('calc-feedback');

    function calculateScore() {
      // Validate inputs
      let total = 0;
      let values = {};

      inputs.forEach(input => {
        let val = parseFloat(input.value) || 0;
        if (val < 0) val = 0;
        input.value = val;
        values[input.id] = val;
        total += val;
      });

      if (Math.abs(total - 100) > 0.1) {
        errorEl.textContent = `Error: Total allocation must equal 100%. Current total: ${total.toFixed(1)}%`;
        scoreEl.textContent = "--";
        fillEl.style.width = "0%";
        gradeTitleEl.textContent = "Invalid Input";
        feedbackEl.textContent = "Please adjust your percentages to equal exactly 100%.";
        return;
      }

      errorEl.textContent = "";

      // Scoring logic based on institutional asset allocation
      // Max score 100.
      let score = 0;

      // Penalty for extreme concentration
      let maxAllocation = Math.max(...Object.values(values));
      if (maxAllocation > 90) {
        score += 20; // Highly concentrated
      } else if (maxAllocation > 70) {
        score += 40;
      } else if (maxAllocation > 50) {
        score += 60;
      } else {
        score += 80;
      }

      // Bonus for specific asset classes (max 20 points bonus)
      if (values['calc-us-small'] > 0 && values['calc-us-small'] <= 20) score += 5;
      if (values['calc-intl-dev'] > 0 && values['calc-intl-dev'] <= 30) score += 5;
      if (values['calc-emerging'] > 0 && values['calc-emerging'] <= 15) score += 5;
      if (values['calc-bonds'] > 0 && values['calc-bonds'] <= 40) score += 5;

      // Cap at 100
      score = Math.min(score, 100);

      // Update UI
      scoreEl.textContent = Math.round(score);
      fillEl.style.width = `${score}%`;

      if (score >= 90) {
        fillEl.style.backgroundColor = "#22c55e"; // Green
        gradeTitleEl.textContent = "Excellent Diversification";
        gradeTitleEl.style.color = "#22c55e";
        feedbackEl.textContent = "Your portfolio is highly diversified across multiple asset classes, significantly reducing unsystematic risk.";
      } else if (score >= 70) {
        fillEl.style.backgroundColor = "#eab308"; // Yellow
        gradeTitleEl.textContent = "Good Diversification";
        gradeTitleEl.style.color = "#eab308";
        feedbackEl.textContent = "A solid foundation. You might improve resilience slightly by adding more international or fixed-income exposure depending on your age.";
      } else if (score >= 40) {
        fillEl.style.backgroundColor = "#f97316"; // Orange
        gradeTitleEl.textContent = "Poor Diversification";
        gradeTitleEl.style.color = "#f97316";
        feedbackEl.textContent = "Your portfolio is highly concentrated. Consider spreading capital across different geographies or adding bonds to mitigate severe volatility.";
      } else {
        fillEl.style.backgroundColor = "#ef4444"; // Red
        gradeTitleEl.textContent = "Critically Concentrated";
        gradeTitleEl.style.color = "#ef4444";
        feedbackEl.textContent = "You are taking on extreme risk. A severe downturn in your primary asset class could cause catastrophic wealth destruction.";
      }
    }

    // Attach listeners
    inputs.forEach(input => {
      if (input) {
        input.addEventListener('input', calculateScore);
        input.addEventListener('change', calculateScore);
      }
    });

    // Initial calculation
    calculateScore();
  }

  // Initialize on load and on view transitions
  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>

