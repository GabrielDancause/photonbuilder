    document.addEventListener('DOMContentLoaded', () => {
      const data = window.__INITIAL_DATA__;
      const ers = data.map(d => d.er * 100).sort((a, b) => a - b);

      // Percentile Calculator
      const calcPercentileBtn = document.getElementById('calc-percentile-btn');
      calcPercentileBtn.addEventListener('click', () => {
        const inputVal = parseFloat(document.getElementById('user-er').value);
        if (isNaN(inputVal)) return;

        let countBelow = 0;
        for (let i = 0; i < ers.length; i++) {
          if (inputVal > ers[i]) {
            countBelow++;
          } else {
            break;
          }
        }

        const percentile = Math.round((countBelow / ers.length) * 100);

        const resBox = document.getElementById('percentile-result');
        const heading = document.getElementById('percentile-heading');
        const desc = document.getElementById('percentile-desc');

        heading.textContent = 'Your ETF is in the ' + percentile + 'th percentile.';

        if (percentile <= 25) {
          desc.textContent = 'Excellent! Your expense ratio is in the lowest quartile, making it highly competitive and cheap.';
        } else if (percentile <= 50) {
          desc.textContent = 'Good. Your expense ratio is below average. It is likely a standard passive index fund or a very cheap active fund.';
        } else if (percentile <= 75) {
          desc.textContent = 'Above Average. Your expense ratio is slightly high. This is typical for sector-specific, thematic, or actively managed ETFs.';
        } else {
          desc.textContent = 'Expensive. Your expense ratio is in the highest quartile. Unless this is a highly specialized or leveraged fund, you might be overpaying.';
        }

        resBox.classList.add('active');
      });

      // Impact Calculator
      const calcImpactBtn = document.getElementById('calc-impact-btn');
      calcImpactBtn.addEventListener('click', () => {
        const initial = parseFloat(document.getElementById('portfolio-size').value) || 0;
        const annualContrib = parseFloat(document.getElementById('annual-contribution').value) || 0;
        const returnRate = parseFloat(document.getElementById('expected-return').value) / 100 || 0;
        const years = parseInt(document.getElementById('years').value) || 0;
        const feeRate = parseFloat(document.getElementById('fee-er').value) / 100 || 0;

        if (years <= 0) return;

        let grossValue = initial;
        let netValue = initial;

        for (let i = 0; i < years; i++) {
          // Gross (No fees)
          grossValue = (grossValue + annualContrib) * (1 + returnRate);
          // Net (With fees)
          netValue = (netValue + annualContrib) * (1 + (returnRate - feeRate));
        }

        const lostGrowth = grossValue - netValue;

        document.getElementById('total-fees-paid').textContent = '$' + lostGrowth.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
        document.getElementById('impact-years').textContent = years;
        document.getElementById('lost-growth').textContent = '$' + lostGrowth.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});

        document.getElementById('impact-result').classList.add('active');
      });
    });
  </script>
