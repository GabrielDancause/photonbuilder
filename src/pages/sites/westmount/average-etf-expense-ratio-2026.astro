            <tr>
              <th class="p-4 text-left border-b border-[var(--border-color)] text-[var(--text-secondary)] font-sans font-semibold uppercase text-xs tracking-wider">Issuer</th>
              <th class="p-4 text-left border-b border-[var(--border-color)] text-[var(--text-secondary)] font-sans font-semibold uppercase text-xs tracking-wider">Avg Expense Ratio</th>
            </tr>
          </thead>
          <tbody>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">Charles Schwab</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.04%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">Vanguard</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.04%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">SPDR (State Street)</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.13%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">iShares (BlackRock)</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.17%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">Dimensional</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.24%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">JPMorgan</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.29%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">VanEck</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.47%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">Global X Funds</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.64%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">ARK Invest</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.64%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">Direxion</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">0.97%</td>
            </tr>

            <tr class="[&:last-child>td]:border-b-0">
              <td class="p-4 text-left border-b border-[var(--border-color)] text-white">ProShares</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] text-[var(--accent-color)] font-bold">1.09%</td>
            </tr>

          </tbody>
        </table>
      </div>

      <h2 class="text-[1.75rem] font-bold mt-12 mb-6 text-white">Interactive Tool: Is My Expense Ratio Good?</h2>
      <p class="mb-4 leading-relaxed text-white">Enter the expense ratio of an ETF you own (or are considering buying) to see how it compares to the broader market and what percentile it falls into.</p>

      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-8 mb-8 flex flex-col gap-4">
        <div class="flex flex-col gap-2">
          <label for="user-er" class="text-sm font-medium text-[var(--text-secondary)]">Your Expense Ratio (%)</label>
          <input type="number" id="user-er" placeholder="e.g. 0.15" step="0.01" min="0" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-md font-mono text-base focus:outline-none focus:border-[var(--accent-color)]">
        </div>
        <button id="calc-percentile-btn" class="bg-[var(--accent-color)] text-white border-none py-3 px-6 rounded-md text-base font-semibold cursor-pointer transition-colors hover:bg-opacity-80 font-sans">Calculate My Percentile</button>

        <div id="percentile-result" class="mt-6 p-6 bg-[rgba(74,143,231,0.1)] border border-[var(--accent-color)] rounded-lg hidden [&.active]:block">
          <h3 style="margin-top:0;" id="percentile-heading" class="text-[1.25rem] mt-0 mb-4 text-white font-bold"></h3>
          <p id="percentile-desc" class="text-white"></p>
        </div>
      </div>

      <h2 class="text-[1.75rem] font-bold mt-12 mb-6 text-white">Impact Calculator: The Cost of Fees</h2>
      <p class="mb-4 leading-relaxed text-white">See exactly how much your expense ratio is costing you over time.</p>

      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-8 mb-8 flex flex-col gap-4">
        <div class="flex flex-col gap-2">
          <label for="portfolio-size" class="text-sm font-medium text-[var(--text-secondary)]">Initial Portfolio Size ($)</label>
          <input type="number" id="portfolio-size" value="100000" step="1000" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-md font-mono text-base focus:outline-none focus:border-[var(--accent-color)]">
        </div>
        <div class="flex flex-col gap-2">
          <label for="annual-contribution" class="text-sm font-medium text-[var(--text-secondary)]">Annual Contribution ($)</label>
          <input type="number" id="annual-contribution" value="10000" step="500" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-md font-mono text-base focus:outline-none focus:border-[var(--accent-color)]">
        </div>
        <div class="flex flex-col gap-2">
          <label for="expected-return" class="text-sm font-medium text-[var(--text-secondary)]">Expected Annual Return (%)</label>
          <input type="number" id="expected-return" value="7.0" step="0.1" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-md font-mono text-base focus:outline-none focus:border-[var(--accent-color)]">
        </div>
        <div class="flex flex-col gap-2">
          <label for="years" class="text-sm font-medium text-[var(--text-secondary)]">Years to Grow</label>
          <input type="number" id="years" value="30" step="1" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-md font-mono text-base focus:outline-none focus:border-[var(--accent-color)]">
        </div>
        <div class="flex flex-col gap-2">
          <label for="fee-er" class="text-sm font-medium text-[var(--text-secondary)]">Expense Ratio (%)</label>
          <input type="number" id="fee-er" value="0.50" step="0.01" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-md font-mono text-base focus:outline-none focus:border-[var(--accent-color)]">
        </div>
        <button id="calc-impact-btn" class="bg-[var(--accent-color)] text-white border-none py-3 px-6 rounded-md text-base font-semibold cursor-pointer transition-colors hover:bg-opacity-80 font-sans mt-2">Calculate Total Fees Paid</button>

        <div id="impact-result" class="mt-6 p-6 bg-[rgba(74,143,231,0.1)] border border-[var(--accent-color)] rounded-lg hidden [&.active]:block">
          <h3 style="margin-top:0;" class="text-[1.25rem] mt-0 mb-4 text-white font-bold">Total Fees Paid: <span id="total-fees-paid" class="text-[var(--accent-color)] font-mono"></span></h3>
          <p class="text-white">Over <span id="impact-years" class="text-[var(--accent-color)] font-mono font-bold"></span> years, this expense ratio costs you <span id="lost-growth" class="text-[var(--accent-color)] font-bold"></span> in total fees and lost compounding growth compared to a zero-fee portfolio.</p>
        </div>
      </div>

      <div class="mt-16">
