    border-left: 4px solid var(--accent-color);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 0 8px 8px 0;
  }
  .faq-section {
    margin-top: 3rem;
  }
  .faq-item {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }
  .faq-item h3 {
    margin-bottom: 0.5rem;
  }

  .comparison-table-container {
    width: 100%;
  }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
    text-align: left;
    background-color: var(--bg-color);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-color);
  }
  .comparison-table th, .comparison-table td {
    padding: 1rem;
    border-bottom: 1px solid var(--border-color);
  }
  .comparison-table th {
    background-color: color-mix(in srgb, var(--card-bg) 80%, transparent);
    font-weight: 600;
    color: var(--text-primary);
  }
  .comparison-table td {
    color: var(--text-secondary);
  }
  .comparison-table tr:last-child td {
    border-bottom: none;
  }
  .comparison-table .highlight-row td {
    background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
    color: var(--text-primary);
  }
</style>


<script is:inline>
  
  function initCalculator() {
    console.log('initCalculator running...');
    // Only init once
    if (window.__dripCalcInitialized) return;
    window.__dripCalcInitialized = true;

    const initialInvestmentInput = document.getElementById('initial-investment');
    const annualContributionInput = document.getElementById('annual-contribution');
    const dividendYieldInput = document.getElementById('dividend-yield');
    const dividendGrowthInput = document.getElementById('dividend-growth');
    const priceAppreciationInput = document.getElementById('price-appreciation');
    const yearsToGrowInput = document.getElementById('years-to-grow');
    const reinvestDividendsCheckbox = document.getElementById('reinvest-dividends');

    const finalValueEl = document.getElementById('final-value');
    const totalContributionsEl = document.getElementById('total-contributions');
    const totalDividendsEl = document.getElementById('total-dividends');
    const totalCapitalGainsEl = document.getElementById('total-capital-gains');
    const dripAdvantageEl = document.getElementById('drip-advantage');
    const dripAdvantageContainer = document.getElementById('drip-advantage-container');

      // JS Table update replacements
      const tableNoDripContrib = document.getElementById('table-nodrip-contrib');
      const tableDripContrib = document.getElementById('table-drip-contrib');
      const tableNoDripDivs = document.getElementById('table-nodrip-divs');
      const tableDripDivs = document.getElementById('table-drip-divs');
      const tableNoDripGains = document.getElementById('table-nodrip-gains');
      const tableDripGains = document.getElementById('table-drip-gains');
      const tableNoDripFinal = document.getElementById('table-nodrip-final');
      const tableDripFinal = document.getElementById('table-drip-final');


    function formatCurrency(value) {
      if (isNaN(value) || value === null) return '$0.00';
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(value);
    }

    window.calculateDRIP = function calculateDRIP() {
      // Parse inputs
      const initialInvestment = parseFloat(initialInvestmentInput.value) || 0;
      const annualContribution = parseFloat(annualContributionInput.value) || 0;
      let divYield = parseFloat(dividendYieldInput.value) || 0;
      let divGrowth = parseFloat(dividendGrowthInput.value) || 0;
      let priceApp = parseFloat(priceAppreciationInput.value) || 0;
      let years = parseInt(yearsToGrowInput.value) || 0;
      const isDRIP = reinvestDividendsCheckbox.checked;

      // Handle edge cases
      if (initialInvestment < 0) return;
      if (years < 0) years = 0;
      if (years > 100) years = 100; // Sensible max

      // Convert percentages to decimals
      divYield = divYield / 100;
      divGrowth = divGrowth / 100;
      priceApp = priceApp / 100;

      // Initialize tracking variables
      const startSharePrice = 100; // arbitrary $100 starting share price for tracking
      let currentSharePrice = startSharePrice;
      let currentDivPerShare = currentSharePrice * divYield;

      let totalContributions = initialInvestment;

      // DRIP scenario tracking
      let dripShares = initialInvestment > 0 ? initialInvestment / startSharePrice : 0;
      let dripTotalDividends = 0;

      // Non-DRIP scenario tracking
      let noDripShares = dripShares;
      let noDripTotalDividends = 0;

      // Iterate year by year
      for (let i = 1; i <= years; i++) {
        // 1. Add annual contribution at the start of the year
        if (annualContribution > 0) {
          const sharesBought = annualContribution / currentSharePrice;
          dripShares += sharesBought;
          noDripShares += sharesBought;
          totalContributions += annualContribution;
        }

        // 2. Stock price appreciates
        currentSharePrice = currentSharePrice * (1 + priceApp);

        // 3. Dividends are paid
        const dripAnnualDividends = dripShares * currentDivPerShare;
        const noDripAnnualDividends = noDripShares * currentDivPerShare;

        dripTotalDividends += dripAnnualDividends;
        noDripTotalDividends += noDripAnnualDividends;

        // 4. Reinvest ONLY for the DRIP scenario (always calculated)
        const newShares = dripAnnualDividends / currentSharePrice;
        dripShares += newShares;

        // 5. Dividend payout grows for next year
        currentDivPerShare = currentDivPerShare * (1 + divGrowth);
      }

      // Final calculations
      const noDripFinalPortfolioValue = (noDripShares * currentSharePrice) + noDripTotalDividends;
      const dripFinalPortfolioValue = dripShares * currentSharePrice;

      // User selected scenario for the main cards
      const finalPortfolioValue = isDRIP ? dripFinalPortfolioValue : noDripFinalPortfolioValue;
      const finalTotalDividends = isDRIP ? dripTotalDividends : noDripTotalDividends;

      let finalCapitalGains = 0;
      if (isDRIP) {
        finalCapitalGains = finalPortfolioValue - totalContributions;
      } else {
        // For non-DRIP, capital gains is just share appreciation, since dividends are held as cash
        finalCapitalGains = (noDripShares * currentSharePrice) - totalContributions;
      }

      const dripAdvantage = dripFinalPortfolioValue - noDripFinalPortfolioValue;

      // Update UI
      finalValueEl.textContent = formatCurrency(finalPortfolioValue);
      totalContributionsEl.textContent = formatCurrency(totalContributions);
      totalDividendsEl.textContent = formatCurrency(finalTotalDividends);
      totalCapitalGainsEl.textContent = formatCurrency(finalCapitalGains);

      // Update Table (Populate BOTH sides independently of isDRIP toggle)
      if (tableNoDripContrib) {
        tableNoDripContrib.textContent = formatCurrency(totalContributions);
        tableDripContrib.textContent = formatCurrency(totalContributions);

        tableNoDripDivs.textContent = formatCurrency(noDripTotalDividends);
        tableDripDivs.textContent = formatCurrency(dripTotalDividends);

        const noDripGains = (noDripShares * currentSharePrice) - totalContributions;
        tableNoDripGains.textContent = formatCurrency(noDripGains);

        const dripGains = dripFinalPortfolioValue - totalContributions;
        tableDripGains.textContent = formatCurrency(dripGains);

        tableNoDripFinal.textContent = formatCurrency(noDripFinalPortfolioValue);
        tableDripFinal.textContent = formatCurrency(dripFinalPortfolioValue);
      }

      if (dripAdvantage > 0.01) {
        dripAdvantageContainer.style.display = 'block';
        dripAdvantageEl.textContent = '+' + formatCurrency(dripAdvantage);
      } else {
        dripAdvantageContainer.style.display = 'none';
      }
    }

    // Attach event listeners to all inputs
    const inputs = [
      initialInvestmentInput,
      annualContributionInput,
      dividendYieldInput,
      dividendGrowthInput,
      priceAppreciationInput,
      yearsToGrowInput,
      reinvestDividendsCheckbox
    ];

    inputs.forEach(input => {
      if (input) {
        input.addEventListener('input', calculateDRIP);
        input.addEventListener('change', calculateDRIP);
      }
    });

    // Initial calculation
    calculateDRIP();
  }

  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
