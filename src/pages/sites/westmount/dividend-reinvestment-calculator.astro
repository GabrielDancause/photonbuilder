    }

    @media (max-width: 600px) {
        .comparison-table th, .comparison-table td {
            padding: 0.5rem;
            font-size: 0.9rem;
        }
        .result-value {
            font-size: 1.5rem;
        }
        .page-content {
            padding: 1.5rem 1rem;
        }
        .calculator-card {
            padding: 1.5rem;
        }
    }
</style>

<script is:inline>
    function calculateDividendReinvestment() {
        // Inputs
        const initialInvestment = parseFloat(document.getElementById('initialInvestment').value) || 0;
        const annualContribution = parseFloat(document.getElementById('annualContribution').value) || 0;
        const dividendYieldPercent = parseFloat(document.getElementById('dividendYield').value) || 0;
        const expectedGrowthPercent = parseFloat(document.getElementById('expectedGrowth').value) || 0;
        const years = parseInt(document.getElementById('years').value, 10) || 0;
        const dripEnabled = document.getElementById('dripEnabled').checked;

        const dividendYield = dividendYieldPercent / 100;
        const expectedGrowth = expectedGrowthPercent / 100;

        // Base arbitrary share price to track shares correctly
        let currentPriceDrip = 100;
        let currentPriceNoDrip = 100;

        let sharesDrip = initialInvestment / currentPriceDrip;
        let sharesNoDrip = initialInvestment / currentPriceNoDrip;

        let totalDividendsDrip = 0;
        let totalDividendsNoDrip = 0;

        let totalContributions = initialInvestment;

        // Run independent simulation for the table to guarantee clean comparison
        let simPriceDrip = 100;
        let simPriceNoDrip = 100;
        let simSharesDrip = initialInvestment / simPriceDrip;
        let simSharesNoDrip = initialInvestment / simPriceNoDrip;
        let simTotalDividendsDrip = 0;
        let simTotalDividendsNoDrip = 0;

        for (let year = 1; year <= years; year++) {
            simPriceDrip *= (1 + expectedGrowth);
            simPriceNoDrip *= (1 + expectedGrowth);

            const divDrip = simSharesDrip * simPriceDrip * dividendYield;
            const divNoDrip = simSharesNoDrip * simPriceNoDrip * dividendYield;

            simTotalDividendsDrip += divDrip;
            simTotalDividendsNoDrip += divNoDrip;

            simSharesDrip += (divDrip / simPriceDrip); // reinvest

            if (annualContribution > 0) {
                simSharesDrip += (annualContribution / simPriceDrip);
                simSharesNoDrip += (annualContribution / simPriceNoDrip);
                totalContributions += annualContribution; // Only add once since it's the same for both
            }
        }
        // Correctly reset total contributions to not double count across the loop if we tracked it above.
        // Let's just calculate it independently:
        totalContributions = initialInvestment + (annualContribution * years);


        // Active results based on toggle
        const activeShares = dripEnabled ? simSharesDrip : simSharesNoDrip;
        const activePrice = dripEnabled ? simPriceDrip : simPriceNoDrip;
        const activeDividends = dripEnabled ? simTotalDividendsDrip : simTotalDividendsNoDrip;

        // Final Value
        let finalValue = activeShares * activePrice;
        if (!dripEnabled) {
            // If not DRIP, final value is shares value + accumulated cash from dividends
            finalValue += activeDividends;
        }

        const totalReturn = finalValue - totalContributions;

        // Formatting
        const currencyFormatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
        const numberFormatter = new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 });

        // Update UI
        document.getElementById('finalValue').textContent = currencyFormatter.format(finalValue);
        document.getElementById('totalPrincipal').textContent = currencyFormatter.format(totalContributions);
        document.getElementById('totalDividends').textContent = currencyFormatter.format(activeDividends);
        document.getElementById('totalReturn').textContent = currencyFormatter.format(totalReturn);

        // Update Comparison Table
        const simFinalValueDrip = simSharesDrip * simPriceDrip;
        const simFinalValueNoDrip = (simSharesNoDrip * simPriceNoDrip) + simTotalDividendsNoDrip;

        document.getElementById('compDripValue').textContent = currencyFormatter.format(simFinalValueDrip);
        document.getElementById('compNoDripValue').textContent = currencyFormatter.format(simFinalValueNoDrip);

        document.getElementById('compDripDividends').textContent = currencyFormatter.format(simTotalDividendsDrip);
        document.getElementById('compNoDripDividends').textContent = currencyFormatter.format(simTotalDividendsNoDrip);

        document.getElementById('compDripShares').textContent = numberFormatter.format(simSharesDrip);
        document.getElementById('compNoDripShares').textContent = numberFormatter.format(simSharesNoDrip);
    }

    // Initialize
    function initCalculator() {
        const inputs = [
            'initialInvestment', 'annualContribution', 'dividendYield',
            'expectedGrowth', 'years', 'dripEnabled'
        ];

        inputs.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                if(el.type === 'checkbox') {
                    el.addEventListener('change', calculateDividendReinvestment);
                } else {
                    el.addEventListener('input', calculateDividendReinvestment);
                }
            }
        });

        calculateDividendReinvestment();
    }

    // Setup for Astro view transitions and regular load
    document.addEventListener('astro:page-load', initCalculator);
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCalculator);
    } else {
        initCalculator();
    }
</script>
