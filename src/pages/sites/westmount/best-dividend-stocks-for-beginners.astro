const FAQ = [
  {q:"What is a dividend stock?",a:"A dividend stock is a share of a company that regularly returns a portion of its profits to investors in the form of cash payments. When you own these stocks, you get paid simply for holding them, providing a steady stream of passive income alongside potential stock price growth."},
  {q:"How often do dividend stocks pay?",a:"The vast majority of US companies pay dividends quarterly (four times a year). However, some companies, particularly Real Estate Investment Trusts (REITs) like Realty Income (O), pay dividends monthly. European companies often pay semi-annually or annually."},
  {q:"What is a good dividend yield for a beginner?",a:"For beginners, a \"sweet spot\" is usually between 2% and 4.5%. Yields below 2% might not provide enough income, while yields above 5% or 6% can sometimes indicate that the company is struggling and the dividend might be at risk of being cut (often called a \"yield trap\")."},
  {q:"What is the dividend payout ratio and why does it matter?",a:"The payout ratio is the percentage of a company's earnings paid out as dividends. A lower ratio (e.g., 40-60%) is safer because it means the company retains enough profit to reinvest in its business and can maintain the dividend even if earnings drop temporarily. Ratios near 100% are risky."},
  {q:"Should I reinvest my dividends?",a:"Yes, especially if you are years away from retirement. Reinvesting dividends (often done automatically through a DRIP - Dividend Reinvestment Plan) allows you to buy more shares, which then generate their own dividends. This creates a compounding effect that significantly boosts long-term returns."},
  {q:"What is a Dividend King or Dividend Aristocrat?",a:"A Dividend Aristocrat is an S&P 500 company that has increased its dividend payout for at least 25 consecutive years. A Dividend King has increased its dividend for 50 or more consecutive years. These titles represent companies with highly resilient business models."},
  {q:"Are dividend stocks safe?",a:"While no stock is completely safe, companies that pay consistent, growing dividends tend to be mature, profitable, and less volatile than growth stocks. However, if a company's profits collapse, it can cut or eliminate its dividend, which usually causes the stock price to drop significantly."},
  {q:"How are dividends taxed?",a:"Most dividends from US companies are \"qualified\" and taxed at lower capital gains rates (0%, 15%, or 20% depending on income). However, dividends from REITs and ordinary dividends are taxed at your regular income tax bracket. Holding these in a tax-advantaged account like a Roth IRA can shield them from taxes."},
  {q:"Should I buy dividend ETFs instead of individual stocks?",a:"For many beginners, dividend ETFs (like SCHD or VYM) are an excellent choice because they provide instant diversification across dozens or hundreds of dividend-paying companies. This eliminates the risk of a single company cutting its dividend and ruining your income stream."}
];

// Render stock table
function renderStocks(data){
  const tbody=document.getElementById('stock-tbody');
  tbody.innerHTML=data.map(s=>{
    const yc=s.yield>=5?'yield-high':s.yield>=3?'yield-mid':'yield-low';
    return `<tr>
      <td class="ticker">${s.ticker}</td>
      <td>${s.name}</td>
      <td>${s.category}</td>
      <td>${s.sector}</td>
      <td class="num ${yc}">${s.yield.toFixed(1)}%</td>
      <td class="num">${s.payoutRatio}%</td>
      <td class="num">${s.years}</td>
    </tr>`;
  }).join('');
}

// Render FAQ
function renderFAQ(){
  const container=document.getElementById('faq');
  container.innerHTML=FAQ.map(f=>`
    <div class="faq-item">
      <div class="faq-q">${f.q}</div>
      <div class="faq-a">${f.a}</div>
    </div>
  `).join('');
  container.querySelectorAll('.faq-q').forEach(q=>{
    q.addEventListener('click',()=>q.parentElement.classList.toggle('open'));
  });
}

// Sort
let stockSortKey='yield',stockSortDir='desc';
let stockData=[...STOCK_DATA];

function applySort() {
  stockData.sort((a,b)=>{
    let av=a[stockSortKey],bv=b[stockSortKey];
    if(typeof av==='string')av=av.toLowerCase();
    if(typeof bv==='string')bv=bv.toLowerCase();
    if(av<bv)return stockSortDir==='asc'?-1:1;
    if(av>bv)return stockSortDir==='asc'?1:-1;
    return 0;
  });
  document.querySelectorAll('#stock-table th').forEach(th=>{
    th.classList.remove('sorted-asc','sorted-desc');
    if(th.dataset.key===stockSortKey)th.classList.add('sorted-'+stockSortDir);
  });
  renderStocks(stockData);
}

function handleSortClick(key,type){
  if(stockSortKey===key){stockSortDir=stockSortDir==='asc'?'desc':'asc';}
  else{stockSortKey=key;stockSortDir=type==='num'?'desc':'asc';}
  applySort();
}

document.querySelectorAll('#stock-table th[data-key]').forEach(th=>{
  th.addEventListener('click',()=>handleSortClick(th.dataset.key,th.dataset.type));
});

// Search and Filter
function filterData() {
  const q = document.getElementById('stock-search').value.toLowerCase();
  const catVal = document.getElementById('categoryFilter').value;
  const filtered = STOCK_DATA.filter(s => {
    const matchSearch = !q || s.ticker.toLowerCase().includes(q) || s.name.toLowerCase().includes(q);
    const matchCat = !catVal || s.category === catVal;
    return matchSearch && matchCat;
  });
  stockData = filtered;
  applySort();
}

document.getElementById('stock-search').addEventListener('input', filterData);
document.getElementById('categoryFilter').addEventListener('change', filterData);

// Init
renderStocks(stockData);
// Default sort
sortStocks('yield', 'num');
renderFAQ();
  </script>
