  <!-- SQUEEZE TRACKER TABLE SCRIPT (from study data) -->
  <script define:vars={{ stocksJson: JSON.stringify(squeezeStocks) }}>
    (function() {
      const stocks = JSON.parse(stocksJson);
      const tableBody = document.getElementById('squeezeTrackerBody');
      const searchInput = document.getElementById('squeezeSearch');
      const sectorFilter = document.getElementById('squeezeSectorFilter');
      const resultCount = document.getElementById('squeezeResultCount');

      const sectors = [...new Set(stocks.map(s => s.sector))].sort();
      sectors.forEach(s => {
        const opt = document.createElement('option');
        opt.value = s; opt.textContent = s;
        sectorFilter.appendChild(opt);
      });

      let stSortCol = 'squeezeScore';
      let stSortDir = -1;

      function getShortClass(pct) {
        if (pct >= 30) return 'short-extreme';
        if (pct >= 20) return 'short-high';
        if (pct >= 10) return 'short-elevated';
        return 'short-normal';
      }
      function getSqueezeClass(rating) {
        switch (rating) {
          case 'High': return 'squeeze-high';
          case 'Moderate': return 'squeeze-moderate';
          case 'Low': return 'squeeze-low';
          default: return 'squeeze-minimal';
        }
      }
      function momStr(v) { return (v >= 0 ? '+' : '') + v.toFixed(1) + '%'; }
      function momClass(v) { return v >= 0 ? 'text-green' : 'text-red'; }

      function sortVal(stock) {
        switch (stSortCol) {
          case 'rank': return stock.shortPercentOfFloat;
          case 'company': return stock.company.toLowerCase();
          case 'shortPercent': return stock.shortPercentOfFloat;
          case 'shortRatio': return stock.shortRatio;
          case 'momentum1m': return stock.momentum1m;
          case 'momentum3m': return stock.momentum3m;
          case 'squeezeScore': return stock.squeezeScore;
          default: return 0;
        }
      }

      function render() {
        const query = searchInput.value.toLowerCase().trim();
        const sector = sectorFilter.value;

        let filtered = stocks.filter(s => {
          if (sector !== 'all' && s.sector !== sector) return false;
          if (query && !s.ticker.toLowerCase().includes(query) && !s.company.toLowerCase().includes(query)) return false;
          return true;
        });

        filtered.sort((a, b) => {
          const va = sortVal(a), vb = sortVal(b);
          if (typeof va === 'string') return stSortDir * va.localeCompare(vb);
          return stSortDir * (vb - va);
        });

        let html = '';
        filtered.forEach((s, i) => {
          html += `<tr>
            <td class="mono text-right">${i + 1}</td>
            <td>
              <div style="font-weight:600;font-size:0.9rem;">${s.company}</div>
              <div style="font-size:0.75rem;color:var(--text-dim);font-family:'JetBrains Mono',monospace;">${s.ticker} <span style="background:rgba(100,116,139,0.15);color:var(--text-dim);padding:1px 6px;border-radius:4px;font-size:0.65rem;font-family:'Inter',sans-serif;">${s.sector}</span></div>
            </td>
            <td class="mono text-right ${getShortClass(s.shortPercentOfFloat)}">${s.shortPercentOfFloat.toFixed(1)}%</td>
            <td class="mono text-right">${s.shortRatio.toFixed(1)}</td>
            <td class="mono text-right ${momClass(s.momentum1m)}">${momStr(s.momentum1m)}</td>
            <td class="mono text-right ${momClass(s.momentum3m)}">${momStr(s.momentum3m)}</td>
            <td><span class="squeeze-badge ${getSqueezeClass(s.squeezeRating)}">${s.squeezeScore.toFixed(0)}</span></td>
          </tr>`;
        });

        tableBody.innerHTML = html;
        resultCount.textContent = filtered.length + ' of ' + stocks.length + ' stocks';
      }

      document.querySelectorAll('#squeezeTrackerTable th[data-st-col]').forEach(th => {
        th.addEventListener('click', function() {
          const col = this.dataset.stCol;
          if (stSortCol === col) stSortDir *= -1;
          else { stSortCol = col; stSortDir = -1; }
          render();
        });
      });

      searchInput.addEventListener('input', render);
      sectorFilter.addEventListener('change', render);
      render();
    })();
  </script>

