---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import currentData from "../../../data/short-interest/current.json";
import sectorBreakdown from "../../../data/short-interest/sector-breakdown.json";

const { meta: studyMeta, stocks: squeezeStocks } = currentData;
const highSqueezeStocks = squeezeStocks.filter(s => s.squeezeScore >= 60);
const maxSectorAvg = Math.max(...sectorBreakdown.map(s => s.avgShortPercent));

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Most Shorted Stocks 2026: Short Interest Rankings & Squeeze Candidates",
      "description": "Complete short interest data for 100+ stocks. Rankings by % of float, squeeze scores, sector analysis. Updated monthly with real data.",
      "datePublished": "2026-03-09",
      "dateModified": "2026-03-20",
      "author": {
        "@type": "Organization",
        "name": "Westmount Research"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Research",
        "url": "https://westmountfundamentals.com"
      },
      "mainEntityOfPage": "https://westmountfundamentals.com/short-interest"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What stock has the highest short interest right now?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "As of early 2026, Groupon (GRPN) has the highest short interest at 46.06% of float, followed by Hertz Global Holdings (HTZ) at 44.41% and Better Home & Finance (BETR) at 43.93%."
          }
        },
        {
          "@type": "Question",
          "name": "What makes a stock a good short squeeze candidate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A good short squeeze candidate typically has a high short percentage of float (usually >20%), a high days to cover ratio, a relatively low public float, and a potential catalyst that could drive the price up unexpectedly."
          }
        },
        {
          "@type": "Question",
          "name": "How does a short squeeze happen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A short squeeze occurs when a heavily shorted stock rapidly increases in price. Short sellers are forced to buy shares back at higher prices to cover their positions, creating a feedback loop of upward price momentum."
          }
        },
        {
          "@type": "Question",
          "name": "What is Days to Cover (short ratio)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Days to cover is calculated by dividing the total shares shorted by the average daily trading volume. A ratio above 5 days is considered high — it means shorts need significant time to exit, increasing squeeze potential."
          }
        },
        {
          "@type": "Question",
          "name": "How often is short interest data updated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "FINRA requires broker-dealers to report short interest positions twice monthly. The data is typically published about 10 business days after the reporting date, meaning short interest data always has a 1-2 week lag."
          }
        },
        {
          "@type": "Question",
          "name": "What is considered a high short interest percentage?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The average S&P 500 stock has roughly 2-3% short interest. Above 10% is elevated, above 20% is high, and above 30% is extreme. In our study, stocks above 20% are in territory where short squeezes become a real risk."
          }
        },
        {
          "@type": "Question",
          "name": "Can short interest predict a short squeeze?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "High short interest is necessary but not sufficient for a squeeze. It also requires a high short ratio, a catalyst driving the price up, and limited available shares. Not every heavily shorted stock squeezes — many decline as bears predicted."
          }
        },
        {
          "@type": "Question",
          "name": "Do heavily shorted stocks outperform the market?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Not consistently. While short squeezes can produce dramatic short-term gains, most heavily shorted stocks underperform the broader market over 3-12 month periods. The exceptions tend to be stocks with improving fundamentals that the short thesis hasn't caught up to."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Most Shorted Stocks 2026: Short Interest Rankings & Squeeze Candidates",
  description: "Complete short interest data for 100+ stocks. Rankings by % of float, squeeze scores, sector analysis. Updated monthly with real data.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Most Shorted Stocks 2026: Short Interest Rankings & Squeeze Candidates"
  description="Complete short interest data for 100+ stocks. Rankings by % of float, squeeze scores, sector analysis. Updated monthly with real data."
  canonical="https://westmountfundamentals.com/short-interest" schema={schema}
>
  <style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --green: #22c55e; --red: #ef4444; --yellow: #eab308;
  --positive: #10b981; --negative: #ef4444; --warning: #f59e0b;
  --squeeze-high: #10b981; --squeeze-moderate: #f59e0b; --squeeze-low: #f97316; --squeeze-minimal: #6b7280;
  --up-color: #00c853; --down-color: #ff3d00;
}
body {
  background: var(--bg-color); color: var(--text-primary);
  font-family: 'Inter', -apple-system, sans-serif;
  line-height: 1.6; min-height: 100vh;
}
.container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
a { color: var(--accent-color); text-decoration: none; }
a:hover { text-decoration: underline; }

/* Hero */
.hero { padding: 60px 0 40px; }
.tag {
  display: inline-block; background: var(--accent-dim);
  color: var(--accent-color); font-size: 12px; font-weight: 600;
  padding: 4px 12px; border-radius: 4px; margin-bottom: 16px;
  letter-spacing: 0.5px; text-transform: uppercase;
}
.hero h1 {
  font-size: clamp(28px, 4vw, 44px); font-weight: 800;
  color: var(--text-bright); line-height: 1.15; margin-bottom: 12px;
  letter-spacing: -1px;
}
.hero .subtitle {
  font-size: 18px; color: var(--text-dim); max-width: 680px;
}
.hero .meta-line {
  margin-top: 16px; font-size: 13px; color: var(--text-dim);
  font-family: 'JetBrains Mono', monospace;
}

/* Stats Grid */
.stats-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px; margin: 40px 0;
}
.stat-card {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 24px; text-align: center;
}
.stat-card .value {
  font-size: 32px; font-weight: 800; color: var(--accent-color);
  font-family: 'JetBrains Mono', monospace;
}
.stat-card .label {
  font-size: 13px; color: var(--text-dim); margin-top: 4px;
}

/* Section headings */
.section-header {
  font-size: 20px; color: var(--text-bright); margin-bottom: 16px; font-weight: 700;
}
.section-desc {
  font-size: 14px; color: var(--text-dim); margin-bottom: 20px; max-width: 800px; line-height: 1.7;
}

/* Chart */
.chart-section {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.chart-section h2 {
  font-size: 20px; color: var(--text-bright); margin-bottom: 24px;
}
.bar-chart { display: flex; flex-direction: column; gap: 8px; }
.bar-row {
  display: flex; align-items: center; gap: 12px; font-size: 13px;
}
.bar-label {
  width: 80px; text-align: right; font-family: 'JetBrains Mono', monospace;
  font-weight: 500; color: var(--text-bright); flex-shrink: 0;
}
.bar-track {
  flex: 1; height: 28px; background: rgba(74,143,231,0.08);
  border-radius: 4px; overflow: hidden; position: relative;
}
.bar-fill {
  height: 100%; border-radius: 4px; display: flex; align-items: center;
  padding-left: 8px; font-size: 12px; font-weight: 600;
  font-family: 'JetBrains Mono', monospace; color: var(--text-bright);
  min-width: 45px; transition: width 0.6s ease;
}
.bar-company {
  width: 180px; font-size: 12px; color: var(--text-dim); overflow: hidden;
  text-overflow: ellipsis; white-space: nowrap; flex-shrink: 0;
}

/* Squeeze Screener */
.screener-card {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.warning-box {
  background-color: rgba(255, 61, 0, 0.1);
  border-left: 4px solid var(--down-color);
  padding: 1.25rem; margin: 1rem 0 1.5rem; border-radius: 0 8px 8px 0;
}
.warning-box h4 { color: var(--down-color); margin-bottom: 0.5rem; font-size: 1rem; }
.warning-box p { color: var(--text-dim); margin-bottom: 0; font-size: 14px; }

/* Squeeze badges */
.squeeze-badge {
  display: inline-block; padding: 3px 10px; border-radius: 20px;
  font-size: 0.75rem; font-weight: 600; font-family: 'JetBrains Mono', monospace; white-space: nowrap;
}
.squeeze-high { background: rgba(16,185,129,0.15); color: #10b981; border: 1px solid rgba(16,185,129,0.3); }
.squeeze-moderate { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); }
.squeeze-low { background: rgba(249,115,22,0.12); color: #f97316; border: 1px solid rgba(249,115,22,0.25); }
.squeeze-minimal { background: rgba(107,114,128,0.12); color: #9ca3af; border: 1px solid rgba(107,114,128,0.25); }

/* Filters */
.filters {
  display: flex; gap: 12px; flex-wrap: wrap; margin: 24px 0;
  align-items: center;
}
.filters label { font-size: 13px; color: var(--text-dim); font-weight: 500; }
.filters select, .filters input {
  background: var(--card-bg); border: 1px solid var(--border-color);
  color: var(--text-primary); padding: 8px 12px; border-radius: 8px;
  font-size: 13px; font-family: 'Inter', sans-serif;
}
.filters select:focus, .filters input:focus {
  outline: none; border-color: var(--accent-color);
}

/* Table */
.table-wrap {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; overflow: hidden; margin: 40px 0;
}
.table-scroll { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead th {
  background: rgba(74,143,231,0.08); padding: 12px 16px;
  text-align: left; font-weight: 600; color: var(--text-dim);
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;
  cursor: pointer; user-select: none; white-space: nowrap;
  border-bottom: 1px solid var(--border-color); position: sticky; top: 0;
}
thead th:hover { color: var(--accent-color); }
thead th.sorted-asc::after { content: ' ▲'; color: var(--accent-color); }
thead th.sorted-desc::after { content: ' ▼'; color: var(--accent-color); }
tbody td {
  padding: 10px 16px; border-bottom: 1px solid var(--border-color);
  white-space: nowrap;
}
tbody tr:hover { background: rgba(74,143,231,0.04); }
tbody tr:last-child td { border-bottom: none; }
.mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }
.text-right { text-align: right; }
.text-green { color: var(--green); }
.text-red { color: var(--red); }
.ticker-cell {
  font-weight: 700; color: var(--accent-color);
  font-family: 'JetBrains Mono', monospace;
}
.short-bar {
  display: inline-block; height: 8px; border-radius: 4px;
  margin-right: 8px; vertical-align: middle;
}

/* Short % color coding */
.short-extreme { color: #ef4444; font-weight: 600; }
.short-high { color: #f97316; font-weight: 600; }
.short-elevated { color: #f59e0b; }
.short-normal { color: var(--text-secondary); }

/* Sector breakdown */
.sector-chart { margin-bottom: 30px; }
.sector-bar-row {
  display: flex; align-items: center; margin-bottom: 12px; gap: 12px;
}
.sector-bar-label {
  width: 180px; font-size: 0.85rem; color: var(--text-dim);
  text-align: right; flex-shrink: 0; white-space: nowrap;
}
.sector-bar-track {
  flex: 1; height: 28px; background: rgba(255,255,255,0.03);
  border-radius: 6px; overflow: hidden;
}
.sector-bar-fill {
  height: 100%; border-radius: 6px;
  background: linear-gradient(90deg, var(--accent-color), #6db3f8);
  transition: width 0.6s ease; min-width: 2px;
}
.sector-bar-value {
  width: 60px; font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem; color: var(--text-bright); font-weight: 600; flex-shrink: 0;
}
.sector-bar-count {
  width: 70px; font-size: 0.75rem; color: var(--text-dim); flex-shrink: 0;
}

/* Scoring grid */
.scoring-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px; margin-bottom: 30px;
}
.score-component {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 10px; padding: 20px;
}
.score-component-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;
}
.score-component-name { font-size: 0.85rem; font-weight: 600; color: var(--text-bright); }
.score-component-pts { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--accent-color); font-weight: 600; }
.score-bar-bg { height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; margin-bottom: 8px; }
.score-bar-fg { height: 100%; background: var(--accent-color); border-radius: 3px; }
.score-component-desc { font-size: 0.78rem; color: var(--text-dim); line-height: 1.5; }

/* Content cards */
.content-card {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.content-card h2 {
  font-size: 20px; color: var(--text-bright); margin-bottom: 20px;
}
.content-card h3 {
  font-size: 16px; color: var(--text-bright); margin: 20px 0 8px;
}
.content-card p {
  font-size: 14px; color: var(--text-dim); line-height: 1.7; margin-bottom: 12px;
}
.content-card ul {
  margin-left: 20px; margin-bottom: 16px;
}
.content-card li {
  margin-bottom: 8px; color: var(--text-dim); font-size: 14px;
}
.content-card li strong { color: var(--text-bright); }

/* Findings */
.finding {
  display: flex; gap: 12px; margin-bottom: 16px;
  padding-bottom: 16px; border-bottom: 1px solid var(--border-color);
}
.finding:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.finding-num {
  width: 28px; height: 28px; background: var(--accent-dim);
  color: var(--accent-color); border-radius: 50%; display: flex;
  align-items: center; justify-content: center; font-size: 13px;
  font-weight: 700; flex-shrink: 0;
}
.finding-text { font-size: 15px; line-height: 1.5; }
.finding-text strong { color: var(--text-bright); }

/* FAQ */
.faq-section {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.faq-section h2 {
  font-size: 20px; color: var(--text-bright); margin-bottom: 24px;
}
.faq-item {
  border-bottom: 1px solid var(--border-color); padding: 16px 0;
}
.faq-item:last-child { border-bottom: none; }
.faq-q {
  font-weight: 600; color: var(--text-bright); font-size: 15px;
  cursor: pointer; display: flex; justify-content: space-between;
  align-items: center;
}
.faq-q::after { content: '+'; font-size: 20px; color: var(--accent-color); }
.faq-item.open .faq-q::after { content: '−'; }
.faq-a {
  max-height: 0; overflow: hidden; transition: max-height 0.3s ease;
  font-size: 14px; color: var(--text-dim); line-height: 1.7;
}
.faq-item.open .faq-a { max-height: 400px; padding-top: 12px; }

/* Methodology */
.methodology {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.methodology h2 {
  font-size: 20px; color: var(--text-bright); margin-bottom: 16px;
}
.methodology p {
  font-size: 14px; color: var(--text-dim); line-height: 1.7; margin-bottom: 12px;
}

/* Citation */
.citation {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 24px; margin: 40px 0;
}
.citation h3 { font-size: 14px; color: var(--text-dim); margin-bottom: 8px; }
.citation code {
  display: block; background: var(--bg-color); padding: 16px;
  border-radius: 8px; font-size: 13px; color: var(--text-primary);
  font-family: 'JetBrains Mono', monospace; white-space: pre-wrap;
  word-break: break-all;
}

/* Disclaimer */
.disclaimer {
  text-align: center; padding: 20px; font-size: 12px;
  color: var(--text-dim); font-style: italic;
  border-top: 1px solid var(--border-color); margin-top: 20px;
}

/* Responsive */
@media (max-width: 768px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .bar-company { display: none; }
  .bar-label { width: 60px; font-size: 11px; }
  .hero h1 { font-size: 24px; }
  .hero .subtitle { font-size: 15px; }
  .filters { flex-direction: column; align-items: stretch; }
  .scoring-grid { grid-template-columns: 1fr; }
  .sector-bar-label { width: 120px; font-size: 0.78rem; }
  .sector-bar-count { display: none; }
}
  </style>

<main class="container">
  <!-- HERO -->
  <section class="hero">
    <div class="tag">Original Research</div>
    <h1>Most Shorted Stocks 2026: Short Interest Rankings & Squeeze Candidates</h1>
    <p class="subtitle">Complete short interest rankings for 100+ stocks — sorted by % of float, with squeeze scores, sector analysis, and interactive screening tools. Find which heavily shorted stocks have real squeeze potential.</p>
    <p class="meta-line">Updated March 2026 · Data from FINRA/Exchange reports · {studyMeta.totalStocksAnalyzed}+ stocks analyzed</p>
  </section>

  <!-- STATS -->
  <section class="stats-grid" id="statsGrid"></section>

  <!-- TOP 20 BAR CHART -->
  <section class="chart-section" id="topChart">
    <h2>Top 20 Most Shorted Stocks by % of Float</h2>
    <div class="bar-chart" id="barChart"></div>
  </section>

  <!-- SHORT SQUEEZE SCREENER -->
  <section class="screener-card" id="squeeze-screener">
    <h2 class="section-header">Short Squeeze Screener</h2>
    <p class="section-desc">Filtered U.S. equities with market cap over $100M and average volume over 500K. The "Squeeze Prob" score multiplies Short % by Days to Cover — higher scores indicate more squeeze fuel.</p>

    <div class="warning-box">
      <h4>⚠️ Risk Warning</h4>
      <p>Short squeezes are incredibly rare events. Stocks that are heavily shorted are usually in that position because the underlying business is distressed or overvalued. Chasing short squeezes is highly speculative and risky. Data is for informational purposes only.</p>
    </div>

    <div class="table-scroll">
      <table id="squeezeTable">
        <thead>
          <tr>
            <th data-sq-col="ticker">Ticker</th>
            <th data-sq-col="name">Company</th>
            <th data-sq-col="shortPercent" data-sq-type="num">Short % of Float</th>
            <th data-sq-col="daysToCover" data-sq-type="num">Days to Cover</th>
            <th data-sq-col="marketCap" data-sq-type="num">Market Cap</th>
            <th data-sq-col="price1wk" data-sq-type="num">1W Perf</th>
            <th data-sq-col="price1mo" data-sq-type="num">1M Perf</th>
            <th data-sq-col="squeezeProbability" data-sq-type="num">Squeeze Prob</th>
          </tr>
        </thead>
        <tbody id="squeezeBody"></tbody>
      </table>
    </div>
  </section>

  <!-- COMPLETE RANKINGS TABLE -->
  <section id="complete-rankings">
    <h2 class="section-header">Complete Short Interest Rankings</h2>
    <p class="section-desc">Click any column header to sort. Use filters to narrow results.</p>

    <div class="filters">
      <label>Sector:</label>
      <select id="sectorFilter"><option value="">All Sectors</option></select>
      <label>Min Short %:</label>
      <input type="number" id="minShort" placeholder="20" style="width:80px;">
      <label>Search:</label>
      <input type="text" id="searchInput" placeholder="Ticker or company..." style="width:180px;">
    </div>

    <div class="table-wrap">
      <div class="table-scroll">
        <table id="dataTable">
          <thead>
            <tr>
              <th data-col="rank">#</th>
              <th data-col="ticker">Ticker</th>
              <th data-col="company">Company</th>
              <th data-col="sector">Sector</th>
              <th data-col="shortInterestPct" data-type="num">Short %</th>
              <th data-col="shortRatio" data-type="num">Days to Cover</th>
              <th data-col="sharesShortM" data-type="num">Shares Short (M)</th>
              <th data-col="floatM" data-type="num">Float (M)</th>
              <th data-col="marketCapB" data-type="num">Mkt Cap ($B)</th>
              <th data-col="peRatio" data-type="num">P/E</th>
              <th data-col="priceUSD" data-type="num">Price</th>
              <th data-col="change1mo" data-type="num">1M Chg</th>
              <th data-col="change3mo" data-type="num">3M Chg</th>
            </tr>
          </thead>
          <tbody id="tableBody"></tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- SECTOR BREAKDOWN -->
  <section class="content-card" id="sector-analysis">
    <h2>Short Interest by Sector</h2>
    <p>Average short interest as a percentage of float, broken down by sector. Sectors facing structural headwinds tend to attract the heaviest bearish bets.</p>

    <div class="sector-chart" style="margin-top:24px;">
      {sectorBreakdown.sort((a, b) => b.avgShortPercent - a.avgShortPercent).map(sector => (
        <div class="sector-bar-row">
          <div class="sector-bar-label">{sector.sector}</div>
          <div class="sector-bar-track">
            <div class="sector-bar-fill" style={`width: ${(sector.avgShortPercent / maxSectorAvg) * 100}%`}></div>
          </div>
          <div class="sector-bar-value">{sector.avgShortPercent.toFixed(1)}%</div>
          <div class="sector-bar-count">{sector.stockCount} stocks</div>
        </div>
      ))}
    </div>
  </section>

  <!-- SQUEEZE SCORE METHODOLOGY -->
  <section id="squeeze-methodology" style="margin: 40px 0;">
    <h2 class="section-header">How the Squeeze Score Works</h2>
    <p class="section-desc">Our Squeeze Score is a weighted composite of five measurable factors. Each contributes a maximum number of points, for a total possible score of 100.</p>

    <div class="scoring-grid">
      <div class="score-component">
        <div class="score-component-header">
          <span class="score-component-name">Short % of Float</span>
          <span class="score-component-pts">0–30 pts</span>
        </div>
        <div class="score-bar-bg"><div class="score-bar-fg" style="width: 30%"></div></div>
        <div class="score-component-desc">The foundation. Higher short interest means more shares that must eventually be bought back. Above 30% is extreme.</div>
      </div>
