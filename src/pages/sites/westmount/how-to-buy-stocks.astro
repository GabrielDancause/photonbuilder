<script>
  // Fully functional vanilla JS calculator
  function initCalculator() {
    const cashInput = document.getElementById('availableCash');
    const priceInput = document.getElementById('sharePrice');
    const fractionalOutput = document.getElementById('fractionalShares');
    const wholeSharesText = document.getElementById('wholeSharesText');

    if (!cashInput || !priceInput || !fractionalOutput || !wholeSharesText) return;

    function calculateShares() {
      const cash = parseFloat(cashInput.value);
      const price = parseFloat(priceInput.value);

      if (isNaN(cash) || isNaN(price) || cash <= 0 || price <= 0) {
        fractionalOutput.textContent = '0.00000 shares';
        wholeSharesText.innerHTML = 'Or <strong>0 whole shares</strong>';
        return;
      }

      // Calculate fractional shares (typically to 5 decimal places)
      const exactShares = cash / price;
      fractionalOutput.textContent = `${exactShares.toFixed(5)} shares`;

      // Calculate whole shares and remainder
      const wholeShares = Math.floor(exactShares);
      const remainder = cash - (wholeShares * price);

      wholeSharesText.innerHTML = `Or <strong>${wholeShares} whole share${wholeShares !== 1 ? 's' : ''}</strong> with $${remainder.toFixed(2)} cash remaining.`;
    }

    // Bind to input events for real-time calculation
    cashInput.addEventListener('input', calculateShares);
    priceInput.addEventListener('input', calculateShares);

    // Initial calculation
    calculateShares();
  }

  // Initialize immediately for standard loads
  initCalculator();
  // Initialize for Astro View Transitions
  document.addEventListener('astro:page-load', initCalculator);
</script>
