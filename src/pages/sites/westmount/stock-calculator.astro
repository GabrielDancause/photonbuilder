  <div class="page-content">
    <div class="container">
      <h1>Stock Calculator</h1>
      <p class="subtitle">Project your investment growth with capital appreciation and dividend reinvestment.</p>

      <div class="calculator-card">
        <form id="stock-calculator-form" onsubmit="event.preventDefault();">
          <div class="grid-2">
            <div class="input-group">
              <label for="initial-investment">Initial Investment</label>
