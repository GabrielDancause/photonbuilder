<script is:inline>
  function formatCurrency(value) {
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0
    }).format(value);
  }

  function calculateStockGrowth() {
    const initialInvestment = parseFloat(document.getElementById('initial-investment').value) || 0;
    const monthlyContribution = parseFloat(document.getElementById('monthly-contribution').value) || 0;
    const years = parseInt(document.getElementById('years').value) || 0;
    const priceGrowthRate = parseFloat(document.getElementById('price-growth').value) || 0;
    const dividendYield = parseFloat(document.getElementById('dividend-yield').value) || 0;
    const reinvestDividends = document.getElementById('reinvest-dividends').value === 'yes';

    if (years <= 0) return;

    const r_price = priceGrowthRate / 100;
    const r_div = dividendYield / 100;

    let currentPrincipal = initialInvestment;
    let currentBalance = initialInvestment;
    let totalDividendsReceived = 0;

    const breakdown = [];

    // The math: We simulate year by year, breaking it into monthly steps for contribution precision.
    // For simplicity but accuracy, we compound monthly contributions.
    // However, stock prices generally compound continuously or daily.
    // We'll use a monthly compounding approximation for both growth and dividends to be robust.

    const monthlyPriceGrowth = Math.pow(1 + r_price, 1/12) - 1;
    const monthlyDivYield = r_div / 12;

    for (let y = 1; y <= years; y++) {
      let yearlyDivs = 0;

      for (let m = 0; m < 12; m++) {
        // Growth on current balance
        currentBalance *= (1 + monthlyPriceGrowth);

        // Dividends generated this month based on the grown balance
        const monthlyDivs = currentBalance * monthlyDivYield;
        yearlyDivs += monthlyDivs;

        if (reinvestDividends) {
          // Reinvested dividends add to the balance immediately
          currentBalance += monthlyDivs;
        }

        // Add contribution at end of month
        currentPrincipal += monthlyContribution;
        currentBalance += monthlyContribution;
      }

      totalDividendsReceived += yearlyDivs;

      breakdown.push({
        year: y,
        invested: currentPrincipal,
        dividends: totalDividendsReceived,
        value: currentBalance
      });
    }


    let totalProfit = currentBalance - currentPrincipal;
    if (!reinvestDividends) {
      totalProfit += totalDividendsReceived; // Add cash dividends to total return if not reinvested
    }


    // Update UI
    document.getElementById('res-total-value').innerText = formatCurrency(currentBalance);
    document.getElementById('res-total-principal').innerText = formatCurrency(currentPrincipal);
    document.getElementById('res-total-profit').innerText = formatCurrency(totalProfit);

    // Render Table
    const tbody = document.getElementById('breakdown-body');
    tbody.innerHTML = '';

    // Show max 20 rows to prevent massive tables, sampling if needed
    let step = 1;
    if (years > 30) step = 5;
    else if (years > 20) step = 2;

    breakdown.forEach((data) => {
      if (data.year % step !== 0 && data.year !== years) return; // always show last year

      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>Year ${data.year}</td>
        <td>${formatCurrency(data.invested)}</td>
        <td>${formatCurrency(data.dividends)}</td>
        <td><strong>${formatCurrency(data.value)}</strong></td>
      `;
      tbody.appendChild(tr);
    });
  }

  function initCalculator() {
    const form = document.getElementById('stock-calculator-form');
    if (!form) return;

    const inputs = form.querySelectorAll('input, select');
    inputs.forEach(input => {
      input.addEventListener('input', calculateStockGrowth);
    });

    calculateStockGrowth();
  }

  // Astro page transitions support
  document.addEventListener('astro:page-load', initCalculator);

  // Standard load fallback
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
