---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import { sites } from '../../../../config/sites';

const SITE_ID = 'westmount';
const siteConfig = sites[SITE_ID];

const allPages = import.meta.glob('../*.astro', { eager: true });

interface PageEntry {
  slug: string;
  title: string;
  description: string;
  category: string;
}

const studies: PageEntry[] = Object.entries(allPages)
  .filter(([path]) => !path.includes('index'))
  .map(([path, mod]: [string, any]) => ({
    slug: path.replace('../', '').replace('.astro', ''),
    title: mod.meta?.title || path.replace('../', '').replace('.astro', '').replace(/-/g, ' '),
    description: mod.meta?.description || '',
    category: mod.meta?.category || 'tool',
  }))
  .filter(p => p.category === 'study')
  .sort((a, b) => a.title.localeCompare(b.title));

function getEmoji(slug: string): string {
  if (slug.includes('etf') || slug.includes('fund')) return '📈';
  if (slug.includes('sector') || slug.includes('industry')) return '🏭';
  if (slug.includes('market') || slug.includes('index')) return '📊';
  if (slug.includes('intrinsic') || slug.includes('valuation')) return '🎯';
  if (slug.includes('dividend') || slug.includes('yield')) return '💰';
  if (slug.includes('risk') || slug.includes('volatility')) return '⚠️';
  if (slug.includes('growth') || slug.includes('momentum')) return '🚀';
  if (slug.includes('bond') || slug.includes('fixed-income')) return '🔐';
  if (slug.includes('correlation') || slug.includes('regression')) return '🔗';
  if (slug.includes('backtest') || slug.includes('historical')) return '📅';
  return '🔬';
}

function truncate(text: string, max: number): string {
  if (!text || text.length <= max) return text || '';
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Market Studies & Research",
  "description": `${studies.length} original research studies covering market analysis, ETF deep dives, and data-driven investing insights.`,
  "url": `https://${siteConfig.domain}/studies/`,
  "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": `https://${siteConfig.domain}/` }
});
---

<SiteLayout
  site={SITE_ID}
  title={`Market Studies & Research — ${siteConfig.name}`}
  description={`${studies.length} original research studies. Market analysis, ETF deep dives, intrinsic value models, and data-driven investing insights.`}
  canonical={`https://westmountfundamentals.com/studies/`}
  schema={schema}
>
  <div class="hero">
    <div class="hero-content">
      <span class="hero-tag">🔬 STUDIES</span>
      <h1>Market Studies & Research</h1>
      <p>{studies.length} original research studies, market analyses, and ETF deep dives.</p>
      <div class="search-box">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        <input type="text" id="searchInput" placeholder="Search studies..." autocomplete="off" />
      </div>
    </div>
  </div>

  <div class="page-container">
    <div class="results-count" id="resultsCount">{studies.length} studies</div>
    <div class="studies-grid" id="studiesGrid">
      {studies.map(page => (
        <a class="study-card" href={`/${page.slug}`} data-title={page.title.toLowerCase()} data-desc={page.description.toLowerCase()}>
          <span class="study-emoji">{getEmoji(page.slug)}</span>
          <h2 class="study-name">{page.title}</h2>
          <p class="study-desc">{truncate(page.description, 130)}</p>
        </a>
      ))}
    </div>
    <div class="no-results" id="noResults">No studies found matching your search.</div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('searchInput');
      const grid = document.getElementById('studiesGrid');
      const cards = grid.querySelectorAll('.study-card');
      const count = document.getElementById('resultsCount');
      const noResults = document.getElementById('noResults');

      input.addEventListener('input', () => {
        const q = input.value.toLowerCase().trim();
        let visible = 0;
        cards.forEach(card => {
          const match = !q || card.dataset.title.includes(q) || card.dataset.desc.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        count.textContent = `${visible} stud${visible !== 1 ? 'ies' : 'y'}`;
        noResults.style.display = visible === 0 ? 'block' : 'none';
      });
    });
  </script>

  <style is:inline>
    .hero { text-align: center; padding: 4rem 1.5rem 2.5rem; }
    .hero-tag { display: inline-block; background: color-mix(in srgb, var(--accent-color) 10%, transparent); color: var(--accent-color); font-size: .7rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1px; margin-bottom: 1rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); font-size: 1.05rem; margin-bottom: 1.5rem; }

    .search-box { max-width: 420px; margin: 0 auto; position: relative; }
    .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; color: var(--text-secondary); }
    .search-box input { width: 100%; padding: 12px 16px 12px 42px; border: 1px solid var(--border-color); border-radius: 10px; font-size: 0.95rem; background: var(--card-bg); color: var(--text-primary); outline: none; box-sizing: border-box; }
    .search-box input:focus { border-color: var(--accent-color); }

    .page-container { max-width: 1100px; margin: 0 auto 3rem; padding: 0 1.5rem; }
    .results-count { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1rem; }

    .studies-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .study-card { display: block; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem; text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s; }
    .study-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }
    .study-emoji { font-size: 1.5rem; display: block; margin-bottom: 0.5rem; }
    .study-name { font-size: 1rem; font-weight: 700; margin: 0 0 0.35rem; line-height: 1.3; }
    .study-desc { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; margin: 0; }

    .no-results { display: none; text-align: center; color: var(--text-secondary); padding: 3rem 0; font-size: 1rem; }

    @media (max-width: 640px) {
      .hero h1 { font-size: 1.6rem; }
      .studies-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>
