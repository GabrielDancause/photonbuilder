import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is margin of safety in investing?","acceptedAnswer":{"@type":"Answer","text":"Margin of safety is a value investing principle pioneered by Benjamin Graham and popularized by Warren Buffett. It refers to the difference between a stock's intrinsic value (what it's actually worth) and its market price (what you pay). If you estimate a stock is worth $100 and buy it at $70, your margin of safety is 30%. The concept acts as a buffer against errors in your valuation, unexpected business deterioration, or market downturns. Graham recommended a minimum margin of safety of 33%, while many value investors target 25-50% depending on the quality and predictability of the business."}},
    {"@type":"Question","name":"How do you calculate margin of safety?","acceptedAnswer":{"@type":"Answer","text":"Margin of safety is calculated as: (Intrinsic Value − Market Price) ÷ Intrinsic Value × 100. For example, if you estimate a stock's intrinsic value at $120 and it trades at $90, the margin of safety is ($120 − $90) ÷ $120 × 100 = 25%. The buy price with a desired margin of safety is: Intrinsic Value × (1 − Desired Margin of Safety %). If you want a 30% margin on a $120 intrinsic value, your buy price target is $120 × 0.70 = $84. The upside potential is the percentage gain from current price to intrinsic value: ($120 − $90) ÷ $90 × 100 = 33.3%."}},
    {"@type":"Question","name":"What is the Graham Number and how is it calculated?","acceptedAnswer":{"@type":"Answer","text":"The Graham Number is a formula created by Benjamin Graham to estimate the maximum fair price for a stock based on its earnings and book value. The formula is: Graham Number = √(22.5 × EPS × Book Value Per Share). The 22.5 comes from Graham's belief that a stock's PE ratio should not exceed 15 and its price-to-book ratio should not exceed 1.5 (15 × 1.5 = 22.5). For example, a company with EPS of $5 and book value of $40 has a Graham Number of √(22.5 × 5 × 40) = √4500 = $67.08. If the stock trades below this number, it may be undervalued by Graham's conservative standards."}},
    {"@type":"Question","name":"What is the difference between DCF and Graham Number valuation?","acceptedAnswer":{"@type":"Answer","text":"DCF (Discounted Cash Flow) and the Graham Number approach intrinsic value from different angles. DCF projects future free cash flows and discounts them to present value using a required rate of return — it is forward-looking and sensitive to growth assumptions. The Graham Number uses current earnings and book value to set a conservative price ceiling — it is backward-looking and deliberately conservative. Earnings Power Value (EPV) is a middle ground that capitalizes current earnings at the cost of capital without assuming any growth. Most value investors use multiple methods and look for convergence — if DCF, Graham Number, and EPV all suggest a stock is cheap, the thesis is stronger."}},
    {"@type":"Question","name":"How much margin of safety should I require?","acceptedAnswer":{"@type":"Answer","text":"The required margin of safety depends on the quality and predictability of the business. Benjamin Graham recommended at least 33% for most stocks. Warren Buffett has said he wants to buy dollar bills for 50 cents. In practice: high-quality businesses with stable, predictable earnings (like Coca-Cola or Johnson & Johnson) might warrant a 20-25% margin of safety because your intrinsic value estimate is more reliable. Cyclical or turnaround companies with uncertain earnings need 40-50% margins because your estimate could be significantly wrong. The less confident you are in your valuation, the larger the margin of safety you should demand."}},
    {"@type":"Question","name":"What is intrinsic value and how is it estimated?","acceptedAnswer":{"@type":"Answer","text":"Intrinsic value is the true underlying worth of a business based on its fundamentals, independent of its current market price. There are several methods to estimate it: (1) Discounted Cash Flow (DCF) — projects future cash flows and discounts them to present value. (2) Graham Number — uses earnings and book value to set a conservative ceiling. (3) Earnings Power Value — capitalizes normalized earnings at the cost of capital. (4) Asset-based valuation — sums up net asset values. No single method gives a definitive answer. Professional value investors typically calculate intrinsic value using multiple methods and use the range to inform their buy/sell decisions."}},
    {"@type":"Question","name":"When should I buy, hold, or sell based on margin of safety?","acceptedAnswer":{"@type":"Answer","text":"A general framework: Buy when the stock trades at a significant discount to intrinsic value (margin of safety above your threshold, typically 25-50%). Hold when the stock is between your buy price and intrinsic value — it still has upside but the margin of safety has narrowed. Sell when the stock reaches or exceeds your intrinsic value estimate, as the margin of safety is gone and the risk-reward has flipped. Some investors sell at 90-95% of intrinsic value rather than waiting for full value. Warren Buffett's approach differs slightly — he prefers to hold wonderful businesses indefinitely unless the fundamentals deteriorate, rather than selling at fair value."}}
  ]
};

export const meta = {
  title: "Margin of Safety Calculator — Intrinsic Value Analysis for Value Investors",
  description: "Calculate margin of safety, buy price targets, and upside potential. Includes Graham Number calculator, DCF and Earnings Power methods, and buy/hold/sell recommendations.",
  category: "tool",
  published: "2026-03-21",
};
