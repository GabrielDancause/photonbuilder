    <div class="methodology">
      <h2>Methodology</h2>
      <p>Margin of safety is calculated as (Intrinsic Value − Market Price) ÷ Intrinsic Value × 100. The buy price target applies your desired margin of safety to the intrinsic value: Buy Price = Intrinsic Value × (1 − Desired MoS%). Upside potential measures the percentage gain from the current market price to intrinsic value.</p>
      <p>The Graham Number formula is √(22.5 × EPS × Book Value Per Share), derived from Graham's criteria that PE should not exceed 15 and P/B should not exceed 1.5. Earnings Power Value is calculated as Normalized Earnings ÷ Cost of Capital, representing the value of the company assuming no growth.</p>
    </div>

    <div class="disclaimer">This calculator is for informational and educational purposes only. Not investment advice. Intrinsic value estimates are inherently subjective. Always do your own research before making investment decisions.</div>
</div>

  <script is:inline>
// Method tab switching
const tabs = document.querySelectorAll('.method-tab');
const panels = document.querySelectorAll('.method-panel');
let activeMethod = 'manual';

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => t.classList.remove('active'));
    panels.forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    activeMethod = tab.dataset.method;
    document.getElementById('panel-' + activeMethod).classList.add('active');
  });
});

// Main calculator
document.getElementById('calcBtn').addEventListener('click', calculateMos);
document.querySelectorAll('.calc-inputs input').forEach(input => {
  input.addEventListener('keydown', e => { if (e.key === 'Enter') calculateMos(); });
});

function getIntrinsicValue() {
  if (activeMethod === 'manual') {
    return parseFloat(document.getElementById('intrinsicValue').value);
  } else if (activeMethod === 'graham') {
    const eps = parseFloat(document.getElementById('grahamEps').value);
    const bvps = parseFloat(document.getElementById('grahamBvps').value);
    if (eps > 0 && bvps > 0) {
      return Math.sqrt(22.5 * eps * bvps);
    }
    return NaN;
  } else if (activeMethod === 'epv') {
    const earnings = parseFloat(document.getElementById('epvEarnings').value);
    const coc = parseFloat(document.getElementById('epvCoc').value);
    if (earnings > 0 && coc > 0) {
      return earnings / (coc / 100);
    }
    return NaN;
  }
  return NaN;
}

function calculateMos() {
  const price = parseFloat(document.getElementById('marketPrice').value);
  const desiredMos = parseFloat(document.getElementById('desiredMos').value) || 30;
  const iv = getIntrinsicValue();

  if (!price || price <= 0) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid market price.</div>';
    return;
  }
  if (!iv || iv <= 0) {
    let msg = 'Please enter a valid intrinsic value.';
    if (activeMethod === 'graham') msg = 'Please enter positive EPS and Book Value Per Share.';
    if (activeMethod === 'epv') msg = 'Please enter positive normalized earnings and cost of capital.';
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">' + msg + '</div>';
    return;
  }

  const mos = ((iv - price) / iv) * 100;
  const buyPrice = iv * (1 - desiredMos / 100);
  const upside = ((iv - price) / price) * 100;

  const methodLabels = { manual: 'DCF / Manual', graham: 'Graham Number', epv: 'Earnings Power Value' };

  let html = '';

  html += '<div style="text-align:center;font-size:12px;color:var(--text-secondary);margin-bottom:12px;text-transform:uppercase;letter-spacing:1px">Valuation Method: <strong style="color:var(--accent-color)">' + methodLabels[activeMethod] + '</strong></div>';

  // Result boxes
  html += '<div class="result-grid">';
  const mosClass = mos >= desiredMos ? 'buy' : (mos >= 0 ? 'hold' : 'sell');
  html += '<div class="result-box ' + mosClass + ' highlight"><div class="val">' + mos.toFixed(1) + '%</div><div class="label">Margin of Safety</div></div>';
  html += '<div class="result-box"><div class="val">$' + buyPrice.toFixed(2) + '</div><div class="label">Buy Price (' + desiredMos + '% MoS)</div></div>';
  html += '<div class="result-box' + (upside > 0 ? ' buy' : ' sell') + '"><div class="val">' + (upside > 0 ? '+' : '') + upside.toFixed(1) + '%</div><div class="label">Upside Potential</div></div>';
  html += '</div>';

  // Price vs IV
  html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">';
  html += '<div class="result-box"><div class="val">$' + price.toFixed(2) + '</div><div class="label">Market Price</div></div>';
  html += '<div class="result-box"><div class="val">$' + iv.toFixed(2) + '</div><div class="label">Intrinsic Value</div></div>';
  html += '</div>';

  // Visual gauge
  html += '<div class="gauge-section">';
  html += '<div class="gauge-label">Price vs Intrinsic Value</div>';
  html += '<div class="gauge-wrap"><div class="gauge-bar">';
  html += '<div class="gauge-zone deep-value">Deep<br>Value</div>';
  html += '<div class="gauge-zone undervalued">Under-<br>valued</div>';
  html += '<div class="gauge-zone fair">Fair<br>Value</div>';
  html += '<div class="gauge-zone overvalued">Over-<br>valued</div>';
  html += '</div>';

  var maxVal = iv * 2;
  var pricePos = Math.max(0, Math.min(100, (price / maxVal) * 100));
  var ivPos = Math.max(0, Math.min(100, (iv / maxVal) * 100));

  html += '<div class="gauge-marker" style="left:' + pricePos + '%"><div class="gauge-marker-label">Price</div></div>';
  html += '<div class="gauge-iv-marker" style="left:' + ivPos + '%" title="Intrinsic Value"></div>';
  html += '</div>';
  html += '<div class="gauge-labels"><span>$0</span><span>$' + (iv * 0.5).toFixed(0) + '</span><span>$' + iv.toFixed(0) + ' (IV)</span><span>$' + (iv * 1.5).toFixed(0) + '</span><span>$' + maxVal.toFixed(0) + '</span></div>';
  html += '<div class="gauge-legend">';
  html += '<span><span class="dot" style="background:#fff;border:1px solid var(--border-color)"></span> Market Price</span>';
  html += '<span><span class="dot" style="background:var(--accent-color)"></span> Intrinsic Value</span>';
  html += '</div>';
  html += '</div>';

  // Recommendation
  html += buildRecommendation(mos, desiredMos, upside, price, iv, buyPrice);

  document.getElementById('calcResults').innerHTML = html;
}

function buildRecommendation(mos, desiredMos, upside, price, iv, buyPrice) {
  var recClass, action, reason;

  if (mos >= desiredMos) {
    recClass = 'buy-rec';
    action = 'BUY';
    reason = 'Price ($' + price.toFixed(2) + ') is ' + mos.toFixed(1) + '% below intrinsic value ($' + iv.toFixed(2) + '), exceeding your ' + desiredMos + '% margin of safety threshold. Strong value opportunity.';
  } else if (mos >= 0 && mos < desiredMos) {
    recClass = 'hold-rec';
    action = 'HOLD / WATCH';
    reason = 'Price ($' + price.toFixed(2) + ') is ' + mos.toFixed(1) + '% below intrinsic value but has not reached your ' + desiredMos + '% margin of safety target. Wait for price to drop to $' + buyPrice.toFixed(2) + ' or below.';
  } else {
    recClass = 'sell-rec';
    action = 'SELL / AVOID';
    reason = 'Price ($' + price.toFixed(2) + ') exceeds intrinsic value ($' + iv.toFixed(2) + ') by ' + Math.abs(upside).toFixed(1) + '%. No margin of safety exists — downside risk outweighs potential reward.';
  }

  return '<div class="recommendation ' + recClass + '">' +
    '<div class="rec-label">Recommendation</div>' +
    '<div class="rec-action">' + action + '</div>' +
    '<div class="rec-reason">' + reason + '</div>' +
  '</div>';
}

// Graham Number standalone calculator
document.getElementById('grahamCalcBtn').addEventListener('click', calcGraham);
document.querySelectorAll('.graham-inputs input').forEach(input => {
  input.addEventListener('keydown', e => { if (e.key === 'Enter') calcGraham(); });
});

function calcGraham() {
  const eps = parseFloat(document.getElementById('gCalcEps').value);
  const bvps = parseFloat(document.getElementById('gCalcBvps').value);
  const price = parseFloat(document.getElementById('gCalcPrice').value);

  if (!eps || eps <= 0 || !bvps || bvps <= 0) {
    document.getElementById('grahamCalcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter positive EPS and Book Value Per Share.</div>';
    return;
  }

  const grahamNum = Math.sqrt(22.5 * eps * bvps);
  const impliedPe = 15;
  const impliedPb = 1.5;
  const actualPe = price > 0 ? price / eps : null;
  const actualPb = price > 0 ? price / bvps : null;

  let html = '<div class="result-grid">';
  html += '<div class="result-box highlight"><div class="val">$' + grahamNum.toFixed(2) + '</div><div class="label">Graham Number</div></div>';

  if (price > 0) {
    const mos = ((grahamNum - price) / grahamNum) * 100;
    const mosClass = mos >= 25 ? 'buy' : (mos >= 0 ? 'hold' : 'sell');
    html += '<div class="result-box ' + mosClass + '"><div class="val">' + mos.toFixed(1) + '%</div><div class="label">Margin of Safety</div></div>';
    const upside = ((grahamNum - price) / price) * 100;
    html += '<div class="result-box' + (upside > 0 ? ' buy' : ' sell') + '"><div class="val">' + (upside > 0 ? '+' : '') + upside.toFixed(1) + '%</div><div class="label">Upside to Graham #</div></div>';
  } else {
    html += '<div class="result-box"><div class="val">' + impliedPe + 'x</div><div class="label">Max PE (Graham)</div></div>';
    html += '<div class="result-box"><div class="val">' + impliedPb + 'x</div><div class="label">Max P/B (Graham)</div></div>';
  }
  html += '</div>';

  // Breakdown
  html += '<div style="margin-top:16px;padding:12px;background:rgba(74,143,231,.04);border-radius:6px;font-size:13px;color:var(--text-secondary)">';
  html += '<div style="margin-bottom:6px"><strong>Formula:</strong> &radic;(22.5 &times; $' + eps.toFixed(2) + ' &times; $' + bvps.toFixed(2) + ') = <strong style="color:var(--accent-color)">$' + grahamNum.toFixed(2) + '</strong></div>';
  html += '<div style="margin-bottom:4px">Implied max PE: ' + impliedPe + 'x &nbsp;|&nbsp; Implied max P/B: ' + impliedPb + 'x</div>';
  if (actualPe) html += '<div>Actual PE: ' + actualPe.toFixed(1) + 'x &nbsp;|&nbsp; Actual P/B: ' + actualPb.toFixed(2) + 'x</div>';
  html += '</div>';

  if (price > 0) {
    const mos = ((grahamNum - price) / grahamNum) * 100;
    const upside = ((grahamNum - price) / price) * 100;
    html += buildRecommendation(mos, 25, upside, price, grahamNum, grahamNum * 0.75);
  }

  document.getElementById('grahamCalcResults').innerHTML = html;
}

// FAQ
const faqs = [
  {q:"What is margin of safety in investing?",a:"Margin of safety is a value investing principle pioneered by Benjamin Graham. It refers to the difference between a stock's intrinsic value (what it's actually worth based on fundamentals) and its market price. If you estimate a stock is worth $100 and buy at $70, your margin of safety is 30%. It acts as a buffer against valuation errors, business deterioration, or market downturns. Graham recommended at least 33%, while many value investors target 25-50%."},
  {q:"How do you calculate margin of safety?",a:"Margin of Safety = (Intrinsic Value \u2212 Market Price) \u00f7 Intrinsic Value \u00d7 100. For example, if intrinsic value is $120 and market price is $90: ($120 \u2212 $90) \u00f7 $120 \u00d7 100 = 25%. The buy price with a desired margin is: Intrinsic Value \u00d7 (1 \u2212 Desired MoS%). For a 30% margin on $120 intrinsic value: $120 \u00d7 0.70 = $84 buy target."},
  {q:"What is the Graham Number and how is it calculated?",a:"The Graham Number = \u221a(22.5 \u00d7 EPS \u00d7 Book Value Per Share). The 22.5 comes from Graham's criteria that PE should not exceed 15 and P/B should not exceed 1.5 (15 \u00d7 1.5 = 22.5). For a company with $5 EPS and $40 book value: \u221a(22.5 \u00d7 5 \u00d7 40) = \u221a4500 = $67.08. Stocks trading below their Graham Number may be undervalued by conservative standards."},
  {q:"What is the difference between DCF and Graham Number valuation?",a:"DCF projects future cash flows and discounts them to present value \u2014 it's forward-looking and growth-sensitive. The Graham Number uses current earnings and book value with no growth assumption \u2014 it's conservative and backward-looking. Earnings Power Value (EPV) capitalizes current earnings at the cost of capital without growth assumptions. Professional investors use multiple methods and look for convergence to strengthen their thesis."},
  {q:"How much margin of safety should I require?",a:"It depends on business quality and predictability. High-quality, stable businesses (like consumer staples leaders) might warrant 20-25% because your estimate is more reliable. Cyclical or turnaround companies need 40-50% margins due to higher uncertainty. Benjamin Graham recommended at least 33%. Warren Buffett has said he wants to buy dollar bills for 50 cents. The less confident you are in your valuation, the larger the margin you should demand."},
  {q:"What is intrinsic value and how is it estimated?",a:"Intrinsic value is the true underlying worth of a business based on fundamentals, independent of market price. Methods include: (1) DCF \u2014 projects future cash flows discounted to present value. (2) Graham Number \u2014 conservative ceiling using earnings and book value. (3) Earnings Power Value \u2014 capitalizes normalized earnings at cost of capital. (4) Asset-based \u2014 sums net asset values. No single method gives a definitive answer; professional investors use multiple methods and triangulate."},
  {q:"When should I buy, hold, or sell based on margin of safety?",a:"Buy when the stock trades at a significant discount to intrinsic value (margin of safety above your threshold, typically 25-50%). Hold when the stock is between your buy price and intrinsic value \u2014 it still has upside but the margin has narrowed. Sell when the stock reaches or exceeds intrinsic value, as the margin of safety is gone. Some investors sell at 90-95% of intrinsic value. Buffett prefers to hold wonderful businesses indefinitely unless fundamentals deteriorate."}
];

const faqEl = document.getElementById('faq');
faqs.forEach(f => {
  faqEl.innerHTML += '<div class="faq-item"><div class="faq-q">' + f.q + '</div><div class="faq-a">' + f.a + '</div></div>';
});
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});
  </script>
</SiteLayout>
