  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        {
            "@type": "Question",
            "name": "What is a dividend?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "A dividend is a distribution of a portion of a company's earnings to its shareholders, typically paid in cash. It is a reward to investors for providing capital to the business."
            }
        },
        {
            "@type": "Question",
            "name": "What is a dividend yield?",
            "acceptedAnswer": {
                "@type": "Answer",
                "text": "A dividend yield is a financial ratio that shows how much a company pays out in dividends each year relative to its stock price, expressed as a percentage. It is calculated by dividing the annual dividend per share by the current share price."
            }
        },
        {
            "@type": "Question",
            "name": "How often are dividends paid?",
            "acceptedAnswer": {
                "@type": "Answer",
