    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.75rem;
    border-radius: 6px;
    font-size: 1rem;
  }
  .input-group input:focus {
    outline: none;
    border-color: var(--accent-color);
  }
  .calculator-results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 600px) {
    .calculator-results {
      grid-template-columns: 1fr 1fr;
    }
  }
  .result-box h4 {
    color: var(--text-secondary);
    margin: 0 0 0.5rem 0;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .result-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent-color);
  }
  .result-value-secondary {
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--buy-color);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const inputs = ['initial-investment', 'annual-yield', 'annual-contribution', 'years', 'stock-growth'];

    const calculateDRIP = () => {
      let principal = parseFloat(document.getElementById('initial-investment').value) || 0;
      let divYield = (parseFloat(document.getElementById('annual-yield').value) || 0) / 100;
      let contribution = parseFloat(document.getElementById('annual-contribution').value) || 0;
      let years = parseInt(document.getElementById('years').value) || 0;
      let priceGrowth = (parseFloat(document.getElementById('stock-growth').value) || 0) / 100;

      let totalValue = principal;
      let totalDividends = 0;

      for (let i = 0; i < years; i++) {
        // Add contribution at start of year
        totalValue += contribution;

        // Calculate dividends for the year
        let dividendsThisYear = totalValue * divYield;
        totalDividends += dividendsThisYear;

        // Add dividends and growth
        totalValue = totalValue + dividendsThisYear + (totalValue * priceGrowth);
      }

      const formatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      });

      document.getElementById('total-value').textContent = formatter.format(totalValue);
      document.getElementById('total-dividends').textContent = formatter.format(totalDividends);
    };

    inputs.forEach(id => {
      document.getElementById(id).addEventListener('input', calculateDRIP);
    });

    // Initial calculation
    calculateDRIP();
  });
</script>
