---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "What is a Good EBITDA Margin? Benchmarks by Industry",
  description: "Discover what constitutes a good EBITDA margin across different sectors. Use our mini-tool to rate your own company's margin.",
  category: "guide",
  published: "2026-03-17",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "What is a Good EBITDA Margin? Benchmarks by Industry",
    "description": "Discover what constitutes a good EBITDA margin across different sectors. Use our mini-tool to rate your own company's margin.",
    "author": {
      "@type": "Organization",
      "name": "Westmount Fundamentals"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
            "@type": "Question",
            "name": "What is considered a 'good' EBITDA margin?",
            "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "While it varies by industry, an EBITDA margin of 10% is typically considered solid. Margins of 20% or more are usually considered excellent."
            }
      },
      {
            "@type": "Question",
            "name": "Why do software companies have such high EBITDA margins?",
            "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Software companies have very low marginal costs. Once the software is developed, selling an additional copy costs almost nothing, leading to high gross margins and high EBITDA margins."
            }
      },
      {
            "@type": "Question",
            "name": "Can a low EBITDA margin still be a good business?",
            "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Retailers like Walmart have very low EBITDA margins (often around 5-7%) but make up for it with massive volume and high asset turnover, generating significant absolute cash flow."
            }
      }
]
  }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/good-ebitda-margin" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>What is a Good EBITDA Margin? Benchmarks by Industry</h1>
      <p class="subtitle">Discover what constitutes a good EBITDA margin across different sectors. Use our mini-tool to rate your own company's margin.</p>
    </div>


    <div class="calculator-container card" style="max-width: 600px; margin: 0 auto 3rem auto;">
      <div class="calc-header">
        <h2>Rate Your EBITDA Margin</h2>
        <p>Enter your margin to see where it stands generally.</p>
      </div>
      <div class="input-group">
        <label for="user-margin">Your EBITDA Margin (%)</label>
        <input type="number" id="user-margin" value="15" step="1" />
      </div>
      <div class="result-card">
        <h3>Assessment</h3>
        <div class="result-value" id="margin-rating" style="font-size: 1.8rem;">Solid</div>
      </div>
    </div>

    <script is:inline>
      function rateMargin() {
        const m = parseFloat(document.getElementById('user-margin').value) || 0;
        const ratingEl = document.getElementById('margin-rating');
        if (m < 5) { ratingEl.textContent = 'Low (Common for Retail/Grocery)'; ratingEl.style.color = '#ef4444'; }
        else if (m < 10) { ratingEl.textContent = 'Below Average'; ratingEl.style.color = '#eab308'; }
        else if (m < 20) { ratingEl.textContent = 'Solid / Average'; ratingEl.style.color = '#10b981'; }
        else if (m < 35) { ratingEl.textContent = 'Very Good (Common for Tech/Pharma)'; ratingEl.style.color = '#3b82f6'; }
        else { ratingEl.textContent = 'Excellent / Elite'; ratingEl.style.color = '#8b5cf6'; }
      }
      document.getElementById('user-margin').addEventListener('input', rateMargin);
      rateMargin();
    </script>

    <div class="explainer">
      <h2>Factors Affecting EBITDA Margin</h2>
      <ul>
        <li><strong>Pricing Power:</strong> Companies with strong brands or monopolies can charge higher prices without increasing costs, directly boosting EBITDA margin.</li>
        <li><strong>Cost Structure:</strong> Fixed vs. variable costs. Software companies have mostly fixed costs, so every new sale almost entirely drops to the EBITDA line.</li>
        <li><strong>Economies of Scale:</strong> As companies grow, they spread their operating expenses (like HQ rent and management salaries) over a larger revenue base, improving margins.</li>
      </ul>

      <h2>Detailed Benchmarks by Industry</h2>
      <p>Below is a broader table of typical EBITDA margins. Keep in mind that sub-sectors can vary widely.</p>
      <table class="data-table">
        <thead>
          <tr>
            <th>Industry</th>
            <th>Benchmark Range</th>
            <th>Why?</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Software & SaaS</td><td>25% - 40%+</td><td>Near zero marginal cost per additional user.</td></tr>
          <tr><td>Pharmaceuticals</td><td>20% - 30%</td><td>High R&D costs but massive margins on patented drugs.</td></tr>
          <tr><td>Telecom & Cable</td><td>30% - 40%</td><td>Massive fixed infrastructure, but subscription recurring revenue.</td></tr>
          <tr><td>Restaurants</td><td>10% - 15%</td><td>High labor and food costs keep margins tight.</td></tr>
          <tr><td>Retail (Apparel)</td><td>8% - 12%</td><td>Inventory markdowns and store leases drag on profits.</td></tr>
          <tr><td>Grocery Supermarkets</td><td>2% - 5%</td><td>Intense competition and perishable goods; driven purely by volume.</td></tr>
        </tbody>
      </table>
    </div>
<section class="related-guides">
  <h2>Related EBITDA Guides</h2>
  <ul>
    <li><a href="/ebitda-calculator">EBITDA Calculator</a></li>
    <li><a href="/what-is-ebitda-margin">What is EBITDA Margin?</a></li>
    <li><a href="/ebitda-vs-net-income">EBITDA vs Net Income</a></li>
    <li><a href="/ebitda-vs-revenue">EBITDA vs Revenue</a></li>
    <li><a href="/adjusted-ebitda">Adjusted EBITDA Explained</a></li>
    <li><a href="/debt-to-ebitda-ratio">Debt to EBITDA Ratio</a></li>
    <li><a href="/ev-ebitda-sectors">EV/EBITDA by Sector</a></li>
  </ul>
</section>    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is considered a 'good' EBITDA margin?</summary>
        <p>While it varies by industry, an EBITDA margin of 10% is typically considered solid. Margins of 20% or more are usually considered excellent.</p>
      </details>
      <details>
        <summary>Why do software companies have such high EBITDA margins?</summary>
        <p>Software companies have very low marginal costs. Once the software is developed, selling an additional copy costs almost nothing, leading to high gross margins and high EBITDA margins.</p>
      </details>
      <details>
        <summary>Can a low EBITDA margin still be a good business?</summary>
        <p>Yes. Retailers like Walmart have very low EBITDA margins (often around 5-7%) but make up for it with massive volume and high asset turnover, generating significant absolute cash flow.</p>
      </details>
    </section>

    <style is:inline>
      .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
      .hero { text-align: center; padding: 3rem 0 2rem; }
      .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
      .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

      .calculator-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; margin: 2rem 0; }
      @media (min-width: 768px) { .calculator-grid { grid-template-columns: 1fr 1fr; } }

      .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; }
      .calc-header { margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; }
      .calc-header h2 { font-size: 1.4rem; margin: 0 0 0.25rem 0; }
      .calc-header p { margin: 0; color: var(--text-secondary); font-size: 0.9rem; }

      .input-group { margin-bottom: 1.25rem; }
      .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; }
      input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
      input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

      .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin-top: 2rem; text-align: center; }
      .result-card.secondary { background: color-mix(in srgb, #10b981 10%, transparent); border-color: #10b981; }
      .result-card h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-secondary); }
      .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
      .secondary .result-value { color: #10b981; }

      .explainer { margin: 3rem 0; line-height: 1.6; }
      .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; }
      .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 0.75rem; }
      .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
      .explainer ul { margin-bottom: 1rem; color: var(--text-secondary); padding-left: 1.5rem; }
      .explainer li { margin-bottom: 0.5rem; }

      .data-table { width: 100%; border-collapse: collapse; margin: 2rem 0; background: var(--card-bg); border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
      .data-table th, .data-table td { padding: 1rem; text-align: left; border-bottom: 1px solid var(--border-color); }
      .data-table th { background: color-mix(in srgb, var(--accent-color) 10%, transparent); font-weight: bold; }
      .data-table tr:last-child td { border-bottom: none; }

      .related-guides { margin: 4rem 0; padding: 2rem; background: var(--card-bg); border-radius: 12px; border: 1px solid var(--border-color); }
      .related-guides h2 { margin-top: 0; margin-bottom: 1.5rem; font-size: 1.5rem; }
      .related-guides ul { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr; gap: 1rem; }
      @media (min-width: 600px) { .related-guides ul { grid-template-columns: 1fr 1fr; } }
      .related-guides a { color: var(--accent-color); text-decoration: none; font-weight: 600; padding: 0.5rem; display: block; border-radius: 6px; transition: background 0.2s; }
      .related-guides a:hover { background: color-mix(in srgb, var(--accent-color) 10%, transparent); }

      .faq-section { margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 2rem; }
      .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; }
      .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
      .faq-section summary { font-weight: 600; cursor: pointer; }
      .faq-section details p { margin: 1rem 0 0 0; color: var(--text-secondary); line-height: 1.5; }

      .formula-visual { text-align: center; margin: 3rem 0; }
      .visual-boxes { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 1rem; margin: 1rem 0; }
      .visual-boxes .box { background: var(--card-bg); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); font-weight: bold; min-width: 100px; }
      .visual-boxes .box.highlight { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border-color: var(--accent-color); color: var(--accent-color); }
      .visual-boxes .math-op { font-size: 1.5rem; font-weight: bold; }
    </style>
  </div>
</SiteLayout>
