---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the BND expense ratio for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "As of early 2026, the Vanguard Total Bond Market ETF (BND) has an official expense ratio of 0.03%. This makes it extremely competitive among total bond market funds."
      }
    },
    {
      "@type": "Question",
      "name": "Is the IUSB expense ratio competitive with AGG and BND?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The iShares Core Universal USD Bond ETF (IUSB) has an expense ratio of 0.06%. While slightly higher than BND and AGG (both at 0.03%), IUSB includes a broader spectrum of bonds, including high-yield debt, which generally carries slightly higher management costs."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Vanguard BND expense ratio official 2026 figure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The official 2026 expense ratio for the Vanguard Total Bond Market ETF (BND) is 0.03%. Vanguard is known for maintaining some of the lowest fees in the industry."
      }
    },
    {
      "@type": "Question",
      "name": "Are there cheaper bond ETFs than BND?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Several total bond market ETFs, including AGG (iShares) and SCHZ (Schwab), match BND's 0.03% expense ratio. It is rare to find broad total bond market ETFs lower than 0.03%, but some short-term or specific Treasury ETFs (like VGSH or VGIT) also hit that bottom-tier pricing of 0.03%."
      }
    },
    {
      "@type": "Question",
      "name": "Why does SPLG ETF expense ratio 2026 matter for bond portfolios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "While SPLG (SPDR Portfolio S&P 500 ETF) is an equity fund, investors often pair ultra-low-cost stock funds like SPLG (0.02% expense ratio) with ultra-low-cost bond funds like SPAB (0.03%) or BND to build an incredibly cheap two-fund core portfolio."
      }
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title="Bond ETF Expense Ratios Compared: BND vs IUSB vs AGG vs SCHZ"
  description="Comparing 2026 expense ratios for total bond market ETFs, government bond ETFs, and corporate bond ETFs. Which one is the absolute cheapest? Check out our cost breakdown to find out."
  canonical="https://westmountfundamentals.com/bond-etf-expense-ratio-comparison" schema={schema}
>
  <main class="max-w-[1200px] mx-auto px-4 py-12">
        <h1 class="text-4xl font-bold mb-2 text-white">Bond ETF Expense Ratios Compared</h1>
        <p class="text-[var(--text-secondary)] text-[1.1rem] mb-12">BND vs IUSB vs AGG vs SCHZ and other major bond ETFs in 2026.</p>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-8 mb-12">
            <h2 class="text-2xl font-bold mb-4 text-white mt-0">Annual Cost Calculator</h2>
            <p class="text-[var(--text-secondary)] mb-4">Enter an investment amount to see how much you would pay in fees per year for each ETF.</p>
            <div class="flex items-center gap-4 mb-6 flex-wrap">
                <label for="investmentAmount" class="font-semibold text-white">Investment Amount ($):</label>
                <input type="number" id="investmentAmount" value="10000" min="0" step="1000" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-md font-mono text-[1.1rem] w-[200px] focus:outline-none focus:border-[var(--accent-color)]">
            </div>
        </div>

        <div class="overflow-x-auto mb-12 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl">
            <table id="etfTable" class="w-full border-collapse text-left">
                <thead>
                    <tr>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(0)">Ticker ↕</th>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(1)">Name ↕</th>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(2)">Expense Ratio ↕</th>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(3)">Annual Cost ↕</th>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(4)">Yield ↕</th>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(5)">Duration ↕</th>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(6)">AUM ↕</th>
                        <th class="bg-[rgba(255,255,255,0.02)] font-semibold text-[var(--text-secondary)] p-4 border-b border-[var(--border-color)] cursor-pointer whitespace-nowrap select-none hover:text-white" onclick="sortTable(7)">Inception ↕</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- Data injected via JS -->
                </tbody>
            </table>
        </div>

        <div class="mt-16">
            <h2 class="text-2xl font-bold mb-4 text-white">Frequently Asked Questions</h2>
            <div>
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 mb-4">
                    <div class="font-semibold mb-2 text-[1.1rem] text-white">What is the BND expense ratio for 2026?</div>
                    <div class="text-[var(--text-secondary)]">As of early 2026, the Vanguard Total Bond Market ETF (BND) has an official expense ratio of 0.03%. This makes it extremely competitive among total bond market funds.</div>
                </div>
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 mb-4">
                    <div class="font-semibold mb-2 text-[1.1rem] text-white">Is the IUSB expense ratio competitive with AGG and BND?</div>
                    <div class="text-[var(--text-secondary)]">The iShares Core Universal USD Bond ETF (IUSB) has an expense ratio of 0.06%. While slightly higher than BND and AGG (both at 0.03%), IUSB includes a broader spectrum of bonds, including high-yield debt, which generally carries slightly higher management costs.</div>
                </div>
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 mb-4">
                    <div class="font-semibold mb-2 text-[1.1rem] text-white">What is the Vanguard BND expense ratio official 2026 figure?</div>
                    <div class="text-[var(--text-secondary)]">The official 2026 expense ratio for the Vanguard Total Bond Market ETF (BND) is 0.03%. Vanguard is known for maintaining some of the lowest fees in the industry.</div>
                </div>
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 mb-4">
                    <div class="font-semibold mb-2 text-[1.1rem] text-white">Are there cheaper bond ETFs than BND?</div>
                    <div class="text-[var(--text-secondary)]">Several total bond market ETFs, including AGG (iShares) and SCHZ (Schwab), match BND's 0.03% expense ratio. It is rare to find broad total bond market ETFs lower than 0.03%, but some short-term or specific Treasury ETFs (like VGSH or VGIT) also hit that bottom-tier pricing of 0.03%.</div>
                </div>
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 mb-4">
                    <div class="font-semibold mb-2 text-[1.1rem] text-white">Why does SPLG ETF expense ratio 2026 matter for bond portfolios?</div>
                    <div class="text-[var(--text-secondary)]">While SPLG (SPDR Portfolio S&P 500 ETF) is an equity fund, investors often pair ultra-low-cost stock funds like SPLG (0.02% expense ratio) with ultra-low-cost bond funds like SPAB (0.03%) or BND to build an incredibly cheap two-fund core portfolio.</div>
                </div>
            </div>
        </div>
    </main>
  <script is:inline>
{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is the BND expense ratio for 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "As of early 2026, the Vanguard Total Bond Market ETF (BND) has an official expense ratio of 0.03%. This makes it extremely competitive among total bond market funds."
        }
      },{
        "@type": "Question",
        "name": "Is the IUSB expense ratio competitive with AGG and BND?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The iShares Core Universal USD Bond ETF (IUSB) has an expense ratio of 0.06%. While slightly higher than BND and AGG (both at 0.03%), IUSB includes a broader spectrum of bonds, including high-yield debt, which generally carries slightly higher management costs."
        }
      },{
        "@type": "Question",
        "name": "What is the Vanguard BND expense ratio official 2026 figure?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The official 2026 expense ratio for the Vanguard Total Bond Market ETF (BND) is 0.03%. Vanguard is known for maintaining some of the lowest fees in the industry."
        }
      },{
        "@type": "Question",
        "name": "Are there cheaper bond ETFs than BND?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Several total bond market ETFs, including AGG (iShares) and SCHZ (Schwab), match BND's 0.03% expense ratio. It is rare to find broad total bond market ETFs lower than 0.03%, but some short-term or specific Treasury ETFs (like VGSH or VGIT) also hit that bottom-tier pricing of 0.03%."
        }
      },{
        "@type": "Question",
        "name": "Why does SPLG ETF expense ratio 2026 matter for bond portfolios?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While SPLG (SPDR Portfolio S&P 500 ETF) is an equity fund, investors often pair ultra-low-cost stock funds like SPLG (0.02% expense ratio) with ultra-low-cost bond funds like SPAB (0.03%) or BND to build an incredibly cheap two-fund core portfolio."
        }
      }]
    }
  </script>
  <script is:inline>
const etfData = [{"symbol":"BND","name":"Vanguard Total Bond Market ETF","category":"Total Bond Market","expenseRatio":0.03,"aum":395346084000,"yield":3.82,"duration":6,"inceptionDate":"2007-04-10","issuer":"Vanguard"},{"symbol":"AGG","name":"iShares Core U.S. Aggregate Bon","category":"Total Bond Market","expenseRatio":0.03,"aum":141223150000,"yield":3.83,"duration":6.1,"inceptionDate":"2003-09-29","issuer":"iShares"},{"symbol":"SCHZ","name":"Schwab US Aggregate Bond ETF","category":"Total Bond Market","expenseRatio":0.03,"aum":10090637300,"yield":3.98,"duration":6,"inceptionDate":"2011-07-14","issuer":"Schwab ETFs"},{"symbol":"IUSB","name":"iShares Core Universal USD Bond","category":"Total Bond Market","expenseRatio":0.06,"aum":36208423000,"yield":4.14,"duration":5.8,"inceptionDate":"2014-06-12","issuer":"iShares"},{"symbol":"FBND","name":"Fidelity Total Bond ETF","category":"Total Bond Market","expenseRatio":0.36,"aum":25090857000,"yield":4.64,"duration":5.7,"inceptionDate":"2014-10-09","issuer":"Fidelity Investments"},{"symbol":"SPAB","name":"State Street SPDR Portfolio Agg","category":"Total Bond Market","expenseRatio":0.03,"aum":9258687500,"yield":3.89,"duration":6,"inceptionDate":"2007-05-30","issuer":"State Street Investment Management"},{"symbol":"SHV","name":"iShares 0-1 Year Treasury Bond ","category":"Government Bonds","expenseRatio":0.15,"aum":20244172800,"yield":4.02,"duration":0.3,"inceptionDate":"2007-01-11","issuer":"iShares"},{"symbol":"SHY","name":"iShares 1-3 Year Treasury Bond ","category":"Government Bonds","expenseRatio":0.15,"aum":24914546700,"yield":3.76,"duration":1.9,"inceptionDate":"2002-07-30","issuer":"iShares"},{"symbol":"IEF","name":"iShares 7-10 Year Treasury Bond","category":"Government Bonds","expenseRatio":0.15,"aum":48742822000,"yield":3.72,"duration":7.5,"inceptionDate":"2002-07-30","issuer":"iShares"},{"symbol":"TLT","name":"iShares 20+ Year Treasury Bond ","category":"Government Bonds","expenseRatio":0.15,"aum":45428621000,"yield":4.28,"duration":16.5,"inceptionDate":"2002-07-30","issuer":"iShares"},{"symbol":"GOVT","name":"iShares U.S. Treasury Bond ETF","category":"Government Bonds","expenseRatio":0.05,"aum":36179087000,"yield":3.45,"duration":5.9,"inceptionDate":"2012-02-24","issuer":"iShares"},{"symbol":"VGSH","name":"Vanguard Short-Term Treasury ET","category":"Government Bonds","expenseRatio":0.03,"aum":32674918400,"yield":3.95,"duration":1.9,"inceptionDate":"2009-11-23","issuer":"Vanguard"},{"symbol":"VGIT","name":"Vanguard Intermediate-Term Trea","category":"Government Bonds","expenseRatio":0.03,"aum":48798519000,"yield":3.74,"duration":5.2,"inceptionDate":"2009-11-23","issuer":"Vanguard"},{"symbol":"VGLT","name":"Vanguard Long-Term Treasury ETF","category":"Government Bonds","expenseRatio":0.03,"aum":15813399600,"yield":4.3,"duration":15.3,"inceptionDate":"2010-01-04","issuer":"Vanguard"},{"symbol":"LQD","name":"iShares iBoxx $ Investment Grad","category":"Corporate Bonds","expenseRatio":0.14,"aum":31986212900,"yield":4.44,"duration":8.2,"inceptionDate":"2002-07-30","issuer":"iShares"},{"symbol":"VCIT","name":"Vanguard Intermediate-Term Corp","category":"Corporate Bonds","expenseRatio":0.03,"aum":68527530000,"yield":4.59,"duration":6,"inceptionDate":"2009-11-23","issuer":"Vanguard"},{"symbol":"VCSH","name":"Vanguard Short-Term Corporate B","category":"Corporate Bonds","expenseRatio":0.03,"aum":48297554000,"yield":4.34,"duration":2.6,"inceptionDate":"2009-11-23","issuer":"Vanguard"},{"symbol":"HYG","name":"iShares iBoxx $ High Yield Corp","category":"Corporate Bonds","expenseRatio":0.49,"aum":16744919000,"yield":5.77,"duration":3.1,"inceptionDate":"2007-04-11","issuer":"iShares"},{"symbol":"JNK","name":"State Street SPDR Bloomberg Hig","category":"Corporate Bonds","expenseRatio":0.4,"aum":7783684100,"yield":6.57,"duration":3.2,"inceptionDate":"2007-12-04","issuer":"State Street Investment Management"},{"symbol":"USIG","name":"iShares Broad USD Investment Gr","category":"Corporate Bonds","expenseRatio":0.04,"aum":16993595400,"yield":4.56,"duration":6.4,"inceptionDate":"2007-01-11","issuer":"iShares"}];

        let currentSortCol = 2; // Default sort by expense ratio
        let currentSortAsc = true;

        function formatMoney(num) {
            if (num >= 1e9) return "$" + (num / 1e9).toFixed(1) + "B";
            if (num >= 1e6) return "$" + (num / 1e6).toFixed(1) + "M";
            return num ? "$" + num.toLocaleString() : "-";
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody');
            const investment = parseFloat(document.getElementById('investmentAmount').value) || 0;
            tbody.innerHTML = '';

            // Group by category to find minimums
            const categories = [...new Set(etfData.map(e => e.category))];
            const cheapestByCategory = {};

            categories.forEach(cat => {
                const catEtfs = etfData.filter(e => e.category === cat && e.expenseRatio !== null);
                if (catEtfs.length > 0) {
                    const minExp = Math.min(...catEtfs.map(e => e.expenseRatio));
                    cheapestByCategory[cat] = minExp;
                }
            });

            // Rebuild rows grouped by category if not explicitly sorting differently,
            // or just render all if sorted. For simplicity and standard table behavior,
            // we will group by category ALWAYS, and sort within categories.

            // Actually, flat sorting is usually better for comparison tables.
            // But requirement says "Highlight the cheapest option in each category".
            // So flat sorting is fine, we just add the "cheapest" class if its expense ratio matches the category min.

            // Sort data
            let sortedData = [...etfData].sort((a, b) => {
                let valA, valB;
                switch(currentSortCol) {
                    case 0: valA = a.symbol; valB = b.symbol; break;
                    case 1: valA = a.name; valB = b.name; break;
                    case 2: valA = a.expenseRatio ?? 999; valB = b.expenseRatio ?? 999; break;
                    case 3: valA = (a.expenseRatio ?? 999); valB = (b.expenseRatio ?? 999); break; // same as ER
                    case 4: valA = a.yield ?? -999; valB = b.yield ?? -999; break;
                    case 5: valA = a.duration ?? -999; valB = b.duration ?? -999; break;
                    case 6: valA = a.aum ?? -999; valB = b.aum ?? -999; break;
                    case 7: valA = a.inceptionDate || ''; valB = b.inceptionDate || ''; break;
                }

                if (valA < valB) return currentSortAsc ? -1 : 1;
                if (valA > valB) return currentSortAsc ? 1 : -1;
                return 0;
            });

            // Grouping by category
            const grouped = {};
            categories.forEach(c => grouped[c] = []);
            sortedData.forEach(e => grouped[e.category].push(e));

            for (const cat of categories) {
                // Add category header
                const trHead = document.createElement('tr');
                trHead.className = 'bg-[rgba(255,255,255,0.05)] font-bold';
                trHead.innerHTML = `<td colspan="8" class="p-4 border-b border-[var(--border-color)] text-white">${cat}</td>`;
                tbody.appendChild(trHead);

                grouped[cat].forEach(etf => {
                    const isCheapest = etf.expenseRatio !== null && etf.expenseRatio === cheapestByCategory[cat];
                    const tr = document.createElement('tr');
                    if (isCheapest) {
                        tr.className = 'bg-[rgba(74,143,231,0.1)] border-l-[3px] border-[var(--accent-color)]';
                    }

                    const annualCost = etf.expenseRatio !== null ? (investment * (etf.expenseRatio / 100)) : null;

                    tr.innerHTML = `
                        <td class="p-4 border-b border-[var(--border-color)] font-mono text-white font-bold">${etf.symbol}</td>
                        <td class="p-4 border-b border-[var(--border-color)] text-white">${etf.name} <span class="text-[0.8rem] text-[var(--text-secondary)] ml-1">(${etf.issuer || '-'})</span>${isCheapest ? '<span class="bg-[var(--accent-color)] text-white text-[0.7rem] px-1.5 py-0.5 rounded ml-2 font-bold inline-block align-middle">Lowest Cost</span>' : ''}</td>
                        <td class="p-4 border-b border-[var(--border-color)] font-mono text-white">${etf.expenseRatio !== null ? etf.expenseRatio.toFixed(2) + '%' : 'N/A'}</td>
                        <td class="p-4 border-b border-[var(--border-color)] font-mono text-[var(--accent-color)] font-medium">${annualCost !== null ? '$' + annualCost.toFixed(2) : 'N/A'}</td>
                        <td class="p-4 border-b border-[var(--border-color)] font-mono text-white">${etf.yield !== null ? etf.yield.toFixed(2) + '%' : 'N/A'}</td>
                        <td class="p-4 border-b border-[var(--border-color)] font-mono text-white">${etf.duration !== null ? etf.duration.toFixed(1) + ' yrs' : 'N/A'}</td>
                        <td class="p-4 border-b border-[var(--border-color)] font-mono text-white">${formatMoney(etf.aum)}</td>
                        <td class="p-4 border-b border-[var(--border-color)] font-mono text-[var(--text-secondary)]">${etf.inceptionDate || 'N/A'}</td>
                    `;
                    tbody.appendChild(tr);
                });
            }
        }

        window.sortTable = function(colIndex) {
            if (currentSortCol === colIndex) {
                currentSortAsc = !currentSortAsc;
            } else {
                currentSortCol = colIndex;
                currentSortAsc = true;
            }
            renderTable();
        };

        document.getElementById('investmentAmount').addEventListener('input', renderTable);

        // Initial render
        renderTable();
  </script>
</SiteLayout>
