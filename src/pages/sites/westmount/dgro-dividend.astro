    // Initialize charts on load
    document.addEventListener('DOMContentLoaded', function() {
      createDividendChart();
      animateHoldings();
      animateSectors();
      setupTableSorting();
    });

    function createDividendChart() {
      const chartContainer = document.getElementById('dividendChart');
      const maxDividend = Math.max(...dividendData.map(d => d.amount));
      
      dividendData.forEach(data => {
        const bar = document.createElement('div');
        bar.className = 'dividend-bar';
        const height = (data.amount / maxDividend) * 100;
        bar.style.height = height + '%';
        
        const tooltip = document.createElement('div');
        tooltip.className = 'bar-tooltip';
        tooltip.textContent = `${data.quarter}: $${data.amount.toFixed(2)}`;
        
        bar.appendChild(tooltip);
        chartContainer.appendChild(bar);
      });
    }

    function animateHoldings() {
      setTimeout(() => {
        document.querySelectorAll('.holding-fill').forEach(fill => {
          const width = fill.getAttribute('data-width');
          fill.style.width = width + '%';
        });
      }, 500);
    }

    function animateSectors() {
      setTimeout(() => {
        document.querySelectorAll('.sector-fill').forEach(fill => {
          const width = fill.getAttribute('data-width');
          fill.style.width = width + '%';
        });
      }, 800);
    }

    function setupTableSorting() {
      const table = document.getElementById('comparisonTable');
      const headers = table.querySelectorAll('th[data-sort]');
      
      headers.forEach(header => {
        header.addEventListener('click', () => sortTable(header));
      });
    }

    function sortTable(header) {
      const table = header.closest('table');
      const tbody = table.querySelector('tbody');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      const column = header.dataset.sort;
      const isNumeric = ['yield', 'expense', 'holdings'].includes(column);
      
      // Clear all sort indicators
      table.querySelectorAll('.sort-indicator').forEach(indicator => {
        indicator.textContent = '↕';
      });
      
      // Determine sort direction
      const currentDirection = header.dataset.direction || 'asc';
      const newDirection = currentDirection === 'asc' ? 'desc' : 'asc';
      header.dataset.direction = newDirection;
      
      // Update sort indicator
      const indicator = header.querySelector('.sort-indicator');
      indicator.textContent = newDirection === 'asc' ? '↑' : '↓';
      
      // Sort rows
      rows.sort((a, b) => {
        let aValue, bValue;
        
        if (column === 'etf') {
          aValue = a.cells[0].textContent.trim();
          bValue = b.cells[0].textContent.trim();
        } else if (column === 'yield' || column === 'expense') {
          aValue = parseFloat(a.cells[column === 'yield' ? 1 : 2].textContent.replace('%', ''));
          bValue = parseFloat(b.cells[column === 'yield' ? 1 : 2].textContent.replace('%', ''));
        } else if (column === 'aum') {
          aValue = parseFloat(a.cells[3].textContent.replace(/[$B]/g, ''));
          bValue = parseFloat(b.cells[3].textContent.replace(/[$B]/g, ''));
        } else if (column === 'holdings') {
          aValue = parseInt(a.cells[4].textContent);
          bValue = parseInt(b.cells[4].textContent);
        } else if (column === 'strategy') {
          aValue = a.cells[5].textContent.trim();
          bValue = b.cells[5].textContent.trim();
        }
        
        if (isNumeric) {
          return newDirection === 'asc' ? aValue - bValue : bValue - aValue;
        } else {
          return newDirection === 'asc' ? 
            aValue.localeCompare(bValue) : 
            bValue.localeCompare(aValue);
        }
      });
      
      // Reorder rows
      rows.forEach(row => tbody.appendChild(row));
    }

    function calculateReturns() {
      const amount = parseFloat(document.getElementById('amount').value);
      const years = parseInt(document.getElementById('years').value);
      
      // Historical returns (approximate)
      const returns = {
        1: 0.12,  // 12% in last year
        2: 0.085, // 8.5% average over 2 years
        3: 0.09,  // 9% average over 3 years
        5: 0.10,  // 10% average over 5 years
        7: 0.095, // 9.5% average over 7 years
        10: 0.11  // 11% average over 10 years (since inception)
      };
      
      const annualReturn = returns[years] || 0.10;
      const totalReturnMultiplier = Math.pow(1 + annualReturn, years);
      const currentValue = amount * totalReturnMultiplier;
      
      // Estimate dividends (roughly 2.2% average yield over time)
      const avgDividendYield = 0.022;
      const totalDividends = amount * avgDividendYield * years;
      
      const totalReturn = ((currentValue - amount) / amount) * 100;
      
      // Update display
      document.getElementById('currentValue').textContent = `$${currentValue.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      document.getElementById('totalDividends').textContent = `$${totalDividends.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      document.getElementById('totalReturn').textContent = `${totalReturn.toFixed(1)}%`;
      document.getElementById('annualReturn').textContent = `${(annualReturn * 100).toFixed(1)}%`;
      
      document.getElementById('calcResult').style.display = 'block';
    }

    function toggleFaq(element) {
      const faqItem = element.parentElement;
      const isActive = faqItem.classList.contains('active');
      
      // Close all other FAQs
      document.querySelectorAll('.faq-item.active').forEach(item => {
        if (item !== faqItem) {
          item.classList.remove('active');
        }
      });
      
      // Toggle current FAQ
      if (isActive) {
        faqItem.classList.remove('active');
      } else {
        faqItem.classList.add('active');
      }
    }
  </script>

