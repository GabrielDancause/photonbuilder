    line-height: 1.6;
  }
</style>

<script is:inline>
  function initCalculator() {
    const ageInput = document.getElementById('age');
    if (!ageInput || ageInput.dataset.initialized) return;
    ageInput.dataset.initialized = 'true';

    const horizonInput = document.getElementById('timeHorizon');
    const riskInput = document.getElementById('riskTolerance');
    const currentStocksInput = document.getElementById('currentStocks');
    const currentBondsInput = document.getElementById('currentBonds');
    const currentCashInput = document.getElementById('currentCash');

    const stocksBar = document.getElementById('stocksBar');
    const bondsBar = document.getElementById('bondsBar');
    const cashBar = document.getElementById('cashBar');

    const stocksPercentageEl = document.getElementById('stocksPercentage');
    const bondsPercentageEl = document.getElementById('bondsPercentage');
    const cashPercentageEl = document.getElementById('cashPercentage');

    const stocksAmountEl = document.getElementById('stocksAmount');
    const bondsAmountEl = document.getElementById('bondsAmount');
    const cashAmountEl = document.getElementById('cashAmount');

    const recommendationText = document.getElementById('recommendationText');

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value);
    }

    function calculateAllocation() {
      let age = parseInt(ageInput.value) || 30;
      let horizon = parseInt(horizonInput.value) || 30;
      let risk = riskInput.value;
      let currentStocks = parseFloat(currentStocksInput.value) || 0;
      let currentBonds = parseFloat(currentBondsInput.value) || 0;
      let currentCash = parseFloat(currentCashInput.value) || 0;
      let portfolioValue = currentStocks + currentBonds + currentCash;

      // Base equity allocation rule: 110 - age (updated from 100 - age due to longer lifespans)
      let equityTarget = 110 - age;

      // Adjust based on time horizon
      if (horizon > 20) {
        equityTarget += 10;
      } else if (horizon < 5) {
        equityTarget -= 20;
      } else if (horizon < 10) {
        equityTarget -= 10;
      }

      // Adjust based on risk tolerance
      if (risk === 'aggressive') {
        equityTarget += 10;
      } else if (risk === 'conservative') {
        equityTarget -= 15;
      }

      // Constrain equity bounds
      let stocksPct = Math.max(10, Math.min(100, equityTarget));

      // Calculate bonds and cash
      let remaining = 100 - stocksPct;
      let cashPct = 0;
      let bondsPct = 0;

      if (risk === 'conservative' || horizon < 5) {
        cashPct = Math.min(remaining, 15); // Higher cash for short horizon/conservative
        bondsPct = remaining - cashPct;
      } else {
        cashPct = Math.min(remaining, 5); // Standard emergency buffer
        bondsPct = remaining - cashPct;
      }

      // Edge case cleanup
      if (stocksPct === 100) {
        bondsPct = 0;
        cashPct = 0;
      }

      // Calculate Dollar Amounts
      let stocksAmt = portfolioValue * (stocksPct / 100);
      let bondsAmt = portfolioValue * (bondsPct / 100);
      let cashAmt = portfolioValue * (cashPct / 100);

      // Update UI
      stocksBar.style.width = `${stocksPct}%`;
      bondsBar.style.width = `${bondsPct}%`;
      cashBar.style.width = `${cashPct}%`;

      stocksPercentageEl.textContent = `${stocksPct}%`;
      bondsPercentageEl.textContent = `${bondsPct}%`;
      cashPercentageEl.textContent = `${cashPct}%`;

      stocksAmountEl.textContent = formatCurrency(stocksAmt);
      bondsAmountEl.textContent = formatCurrency(bondsAmt);
      cashAmountEl.textContent = formatCurrency(cashAmt);

      const cStockPct = portfolioValue > 0 ? Math.round((currentStocks / portfolioValue) * 100) : 0;
      const cBondPct = portfolioValue > 0 ? Math.round((currentBonds / portfolioValue) * 100) : 0;
      const cCashPct = portfolioValue > 0 ? Math.round((currentCash / portfolioValue) * 100) : 0;

      function formatShortK(val) { return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val); }

      document.getElementById('compareCurrentStocks').textContent = `${cStockPct}% (${formatShortK(currentStocks)})`;
      document.getElementById('compareTargetStocks').textContent = `${stocksPct}% (${formatShortK(stocksAmt)})`;

      const stockDiff = stocksAmt - currentStocks;
      const stockActionEl = document.getElementById('compareActionStocks');
      stockActionEl.textContent = stockDiff > 0 ? `Buy ${formatShortK(stockDiff)}` : (stockDiff < 0 ? `Sell ${formatShortK(Math.abs(stockDiff))}` : 'Hold');
      stockActionEl.style.color = stockDiff > 0 ? 'var(--accent-color)' : (stockDiff < 0 ? 'var(--text-primary)' : 'var(--text-secondary)');

      document.getElementById('compareCurrentBonds').textContent = `${cBondPct}% (${formatShortK(currentBonds)})`;
      document.getElementById('compareTargetBonds').textContent = `${bondsPct}% (${formatShortK(bondsAmt)})`;

      const bondDiff = bondsAmt - currentBonds;
      const bondActionEl = document.getElementById('compareActionBonds');
      bondActionEl.textContent = bondDiff > 0 ? `Buy ${formatShortK(bondDiff)}` : (bondDiff < 0 ? `Sell ${formatShortK(Math.abs(bondDiff))}` : 'Hold');
      bondActionEl.style.color = bondDiff > 0 ? 'var(--accent-color)' : (bondDiff < 0 ? 'var(--text-primary)' : 'var(--text-secondary)');

      document.getElementById('compareCurrentCash').textContent = `${cCashPct}% (${formatShortK(currentCash)})`;
      document.getElementById('compareTargetCash').textContent = `${cashPct}% (${formatShortK(cashAmt)})`;

      const cashDiff = cashAmt - currentCash;
      const cashActionEl = document.getElementById('compareActionCash');
      cashActionEl.textContent = cashDiff > 0 ? `Buy ${formatShortK(cashDiff)}` : (cashDiff < 0 ? `Sell ${formatShortK(Math.abs(cashDiff))}` : 'Hold');
      cashActionEl.style.color = cashDiff > 0 ? 'var(--accent-color)' : (cashDiff < 0 ? 'var(--text-primary)' : 'var(--text-secondary)');

      // Update Recommendation Text
      let recText = "";
      if (stocksPct >= 80) {
        recText = "Based on your aggressive risk profile and/or long time horizon, this portfolio prioritizes long-term growth. It will experience higher volatility, but historically provides higher returns to outpace inflation.";
      } else if (stocksPct >= 50) {
        recText = "This balanced portfolio aims to provide a mix of moderate growth and income generation. It offers a cushion against severe stock market downturns while still participating in market upside.";
      } else {
        recText = "This conservative portfolio prioritizes capital preservation and stable income over growth. It is highly resilient to stock market crashes, suitable for shorter time horizons or lower risk tolerances.";
      }
      recommendationText.textContent = recText;
    }

    // Attach event listeners for real-time calculation
    [ageInput, horizonInput, riskInput, currentStocksInput, currentBondsInput, currentCashInput].forEach(input => {
      input.addEventListener('input', calculateAllocation);
    });

    // Initial calculation
    calculateAllocation();
  }

  // Handle Astro View Transitions and initial load
  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    // Only call directly if it's the very first load and not firing off astro:page-load
    if (!document.getElementById('age').dataset.initialized) {
        initCalculator();
    }
  }
</script>
