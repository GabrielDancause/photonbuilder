      }

      .status-valid { color: color-mix(in srgb, var(--text-primary) 50%, green); }
      .status-invalid { color: color-mix(in srgb, var(--text-primary) 50%, red); }

      .results-section {
        border-top: 1px solid var(--border-color);
        padding-top: 2rem;
      }

      .table-container {
        overflow-x: auto;
      }

      .results-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
      }

      .results-table th,
      .results-table td {
        padding: 1rem;
        border-bottom: 1px solid var(--border-color);
      }

      .results-table th {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: var(--text-secondary);
        background: var(--bg-color);
      }

      .amt-sub {
        display: block;
        font-size: 0.85rem;
        color: var(--text-secondary);
        font-weight: normal;
      }

      .text-positive { color: color-mix(in srgb, var(--text-primary) 50%, green); }
      .text-negative { color: color-mix(in srgb, var(--text-primary) 50%, red); }

      .action-buy { color: color-mix(in srgb, var(--text-primary) 50%, green); font-weight: bold; }
      .action-sell { color: color-mix(in srgb, var(--text-primary) 50%, red); font-weight: bold; }
      .action-hold { color: var(--text-secondary); }

      /* Content Styles */
      .page-content h2 {
        font-size: 2rem;
        margin-top: 3rem;
        margin-bottom: 1rem;
        color: var(--text-primary);
      }

      .page-content h3 {
        font-size: 1.5rem;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      .page-content p {
        margin-bottom: 1.5rem;
      }

      .page-content ul, .page-content ol {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
      }

      .page-content li {
        margin-bottom: 0.5rem;
      }

      .example-box {
        background: color-mix(in srgb, var(--accent-color) 10%, transparent);
        border-left: 4px solid var(--accent-color);
        padding: 1.5rem;
        margin: 2rem 0;
        border-radius: 0 8px 8px 0;
      }

      .faq-section {
        margin-top: 4rem;
        border-top: 1px solid var(--border-color);
        padding-top: 2rem;
      }

      details {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 1rem;
        overflow: hidden;
      }

      summary {
        padding: 1.25rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        list-style: none;
      }

      summary::-webkit-details-marker {
        display: none;
      }

      summary::after {
        content: '+';
        color: var(--accent-color);
        font-size: 1.5rem;
        line-height: 1;
      }

      details[open] summary::after {
        content: '−';
      }

      .faq-answer {
        padding: 0 1.25rem 1.25rem;
        color: var(--text-secondary);
      }
    </style>
  </div>
</SiteLayout>
