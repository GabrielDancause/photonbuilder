<script is:inline>
  function initCalculator() {
    const toggle = document.getElementById('toggleAdvanced');
    const advOpts = document.getElementById('advancedOptions');

    if (!toggle || !advOpts) return;

    // Toggle advanced options
    toggle.addEventListener('click', () => {
      const isHidden = advOpts.style.display === 'none';
      advOpts.style.display = isHidden ? 'block' : 'none';
      toggle.querySelector('.icon').innerHTML = isHidden ? '&#9652;' : '&#9662;';
    });

    // Formatting helpers
    const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
    const formatPct = (val) => new Intl.NumberFormat('en-US', { style: 'percent', minimumFractionDigits: 2 }).format(val / 100);

    const calculateReturn = () => {
      // Get inputs
      const initialPrice = parseFloat(document.getElementById('initialPrice').value) || 0;
      const shares = parseFloat(document.getElementById('sharesOwned').value) || 0;
      const finalPrice = parseFloat(document.getElementById('finalPrice').value) || 0;
      const divsPerShare = parseFloat(document.getElementById('dividendsPerShare').value) || 0;
      const years = parseFloat(document.getElementById('holdingPeriod').value) || 0.001; // Avoid divide by zero

      const buyComm = parseFloat(document.getElementById('buyCommission').value) || 0;
      const sellComm = parseFloat(document.getElementById('sellCommission').value) || 0;
      const taxRate = (parseFloat(document.getElementById('taxRate').value) || 0) / 100;
      const inflation = (parseFloat(document.getElementById('inflationRate').value) || 0) / 100;

      // Basic calculations
      const initialInvestment = initialPrice * shares;
      const endingStockValue = finalPrice * shares;
      const totalDividends = divsPerShare * shares;

      const finalGrossValue = endingStockValue + totalDividends;
      const grossProfit = finalGrossValue - initialInvestment;

      // Fees and Taxes
      const totalFees = buyComm + sellComm;

      // Capital gains tax only applies to the profit (if positive) minus commissions
      const taxableGain = Math.max(0, grossProfit - totalFees);
      const estimatedTaxes = taxableGain * taxRate;

      // Net values
      const netEndingCapital = finalGrossValue - totalFees - estimatedTaxes;
      const netProfit = netEndingCapital - initialInvestment;

      // Returns
      const totalReturnPct = initialInvestment > 0 ? (netProfit / initialInvestment) * 100 : 0;

      // Annualized Return (CAGR)
      // CAGR = (Ending Value / Beginning Value) ^ (1/years) - 1
      let annualizedPct = 0;
      if (initialInvestment > 0 && netEndingCapital > 0) {
        annualizedPct = (Math.pow(netEndingCapital / initialInvestment, 1 / years) - 1) * 100;
      } else if (netEndingCapital <= 0) {
        annualizedPct = -100;
      }

      // Real Annualized Return (Inflation adjusted)
      // Real = ((1 + Nominal) / (1 + Inflation)) - 1
      const realAnnualizedPct = ((1 + (annualizedPct / 100)) / (1 + inflation) - 1) * 100;

      // Update UI
      document.getElementById('resTotalReturnPct').textContent = formatPct(totalReturnPct);
      document.getElementById('resNetProfit').textContent = formatCurrency(netProfit);
      document.getElementById('resAnnualizedPct').textContent = formatPct(annualizedPct);
      document.getElementById('resRealAnnualizedPct').textContent = formatPct(realAnnualizedPct);

      document.getElementById('resInitialInvestment').textContent = formatCurrency(initialInvestment);
      document.getElementById('resFinalValue').textContent = formatCurrency(finalGrossValue);
      document.getElementById('resTotalFees').textContent = formatCurrency(totalFees);
      document.getElementById('resTaxes').textContent = formatCurrency(estimatedTaxes);
      document.getElementById('resEndingCapital').textContent = formatCurrency(netEndingCapital);

      // Dynamic coloring for results
      const highlightColor = netProfit >= 0 ? 'var(--text-primary)' : 'var(--accent-color)';
      document.getElementById('resTotalReturnPct').style.color = highlightColor;
      document.getElementById('resNetProfit').style.color = highlightColor;
      document.getElementById('resAnnualizedPct').style.color = highlightColor;
      document.getElementById('resRealAnnualizedPct').style.color = highlightColor;
    };

    const inputs = [
      'initialPrice', 'finalPrice', 'sharesOwned', 'dividendsPerShare',
      'buyCommission', 'sellCommission', 'holdingPeriod',
      'taxRate', 'inflationRate'
    ];

    inputs.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('input', calculateReturn);
        el.addEventListener('change', calculateReturn);
      }
    });

    // Initial calculation
    calculateReturn();
  }

  // Support View Transitions
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for direct load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
