  }

  .breakdown-title {
    font-size: 1rem;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .breakdown-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .breakdown-table td {
    padding: 0.75rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--border-color) 50%, transparent);
    color: var(--text-secondary);
  }

  .breakdown-table tr:last-child td {
    border-bottom: none;
  }

  .text-right {
    text-align: right;
  }

  .text-green {
    color: color-mix(in srgb, var(--accent-color) 80%, white);
  }

  .text-red {
    color: color-mix(in srgb, var(--text-secondary) 80%, red);
  }

  .total-row td {
    color: var(--text-primary);
    font-weight: bold;
    border-top: 2px solid var(--border-color);
    padding-top: 1rem;
  }

  .mt-12 {
    margin-top: 3rem;
  }

  details {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    margin-bottom: 1rem;
    padding: 1rem;
  }

  summary {
    font-weight: bold;
    color: var(--text-primary);
    cursor: pointer;
    font-size: 1.1rem;
  }

  summary::-webkit-details-marker {
    color: var(--accent-color);
  }

  details p {
    margin-top: 1rem;
    margin-bottom: 0;
  }
</style>

<script is:inline>
  function initStockReturnCalculator() {
    const inputs = {
      shares: document.getElementById('shares'),
      buyPrice: document.getElementById('buyPrice'),
      sellPrice: document.getElementById('sellPrice'),
      buyFee: document.getElementById('buyFee'),
      sellFee: document.getElementById('sellFee'),
      dividends: document.getElementById('dividends'),
      holdingYears: document.getElementById('holdingYears')
    };

    const outputs = {
      totalReturnResult: document.getElementById('totalReturnResult'),
      cagrResult: document.getElementById('cagrResult'),
      netProfitResult: document.getElementById('netProfitResult'),
      endingValueResult: document.getElementById('endingValueResult'),

      initialInvestmentBreakdown: document.getElementById('initialInvestmentBreakdown'),
      capitalGainsBreakdown: document.getElementById('capitalGainsBreakdown'),
      totalDividendsBreakdown: document.getElementById('totalDividendsBreakdown'),
      totalFeesBreakdown: document.getElementById('totalFeesBreakdown'),
      netProfitBreakdown: document.getElementById('netProfitBreakdown')
    };

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value);
    }

    function formatPercent(value) {
      return new Intl.NumberFormat('en-US', { style: 'percent', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(value / 100);
    }

    function calculate() {
      // Parse inputs
      const shares = parseFloat(inputs.shares.value) || 0;
      const buyPrice = parseFloat(inputs.buyPrice.value) || 0;
      const sellPrice = parseFloat(inputs.sellPrice.value) || 0;
      const buyFee = parseFloat(inputs.buyFee.value) || 0;
      const sellFee = parseFloat(inputs.sellFee.value) || 0;
      const dividendsPerShare = parseFloat(inputs.dividends.value) || 0;
      const holdingYears = parseFloat(inputs.holdingYears.value) || 0;

      // Ensure no negative fundamental inputs where it doesn't make sense
      if (shares <= 0 || buyPrice <= 0 || holdingYears <= 0) {
        resetOutputs();
        return;
      }

      // Calculations
      const initialInvestment = shares * buyPrice;
      const endingValue = shares * sellPrice;
      const totalDividends = shares * dividendsPerShare;
      const totalFees = buyFee + sellFee;

      const capitalGains = endingValue - initialInvestment;
      const netProfit = capitalGains + totalDividends - totalFees;
      const finalAssetValue = initialInvestment + netProfit; // Represents total money in pocket (capital + profit)

      const totalReturn = (netProfit / initialInvestment) * 100;

      let cagr = 0;
      if (finalAssetValue > 0) {
        cagr = (Math.pow(finalAssetValue / initialInvestment, 1 / holdingYears) - 1) * 100;
      } else {
        cagr = -100; // Complete loss
      }

      // Update UI
      outputs.totalReturnResult.textContent = formatPercent(totalReturn);
      outputs.cagrResult.textContent = formatPercent(cagr);
      outputs.netProfitResult.textContent = formatCurrency(netProfit);
      outputs.endingValueResult.textContent = formatCurrency(finalAssetValue);

      // Color coding for results
      if (totalReturn >= 0) {
        outputs.totalReturnResult.style.color = 'color-mix(in srgb, var(--accent-color) 80%, white)';
        outputs.cagrResult.style.color = 'color-mix(in srgb, var(--accent-color) 80%, white)';
        outputs.netProfitResult.style.color = 'color-mix(in srgb, var(--accent-color) 80%, white)';
      } else {
        outputs.totalReturnResult.style.color = 'color-mix(in srgb, var(--text-secondary) 80%, red)';
        outputs.cagrResult.style.color = 'color-mix(in srgb, var(--text-secondary) 80%, red)';
        outputs.netProfitResult.style.color = 'color-mix(in srgb, var(--text-secondary) 80%, red)';
      }

      outputs.initialInvestmentBreakdown.textContent = formatCurrency(initialInvestment);
      outputs.capitalGainsBreakdown.textContent = formatCurrency(capitalGains);
      outputs.totalDividendsBreakdown.textContent = '+' + formatCurrency(totalDividends);
      outputs.totalFeesBreakdown.textContent = '-' + formatCurrency(totalFees);
      outputs.netProfitBreakdown.textContent = formatCurrency(netProfit);

      // Breakdown colors
      outputs.capitalGainsBreakdown.className = capitalGains >= 0 ? 'text-right text-green' : 'text-right text-red';
      outputs.netProfitBreakdown.className = netProfit >= 0 ? 'text-right text-green' : 'text-right text-red';
    }

    function resetOutputs() {
      const emptyPercent = '--%';
      const emptyCurrency = '$--';

      outputs.totalReturnResult.textContent = emptyPercent;
      outputs.cagrResult.textContent = emptyPercent;
      outputs.netProfitResult.textContent = emptyCurrency;
      outputs.endingValueResult.textContent = emptyCurrency;

      outputs.totalReturnResult.style.color = '';
      outputs.cagrResult.style.color = '';
      outputs.netProfitResult.style.color = '';

      outputs.initialInvestmentBreakdown.textContent = emptyCurrency;
      outputs.capitalGainsBreakdown.textContent = emptyCurrency;
      outputs.totalDividendsBreakdown.textContent = emptyCurrency;
      outputs.totalFeesBreakdown.textContent = emptyCurrency;
      outputs.netProfitBreakdown.textContent = emptyCurrency;

      outputs.capitalGainsBreakdown.className = 'text-right';
      outputs.netProfitBreakdown.className = 'text-right';
    }

    // Attach event listeners
    Object.values(inputs).forEach(input => {
      if (input) {
        input.addEventListener('input', calculate);
      }
    });

    // Initial calculation
    calculate();
  }

  // Setup execution based on Astro's View Transitions or normal load
  document.addEventListener('astro:page-load', initStockReturnCalculator);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStockReturnCalculator);
  } else {
    initStockReturnCalculator();
  }
</script>
