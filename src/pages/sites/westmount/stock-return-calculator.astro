---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Stock Return Calculator: Analyze Your True Investment Gains",
  description: "Are you actually making money after fees and inflation? This stock return calculator reveals the hidden math most investors ignore until it's too late.",
  category: "tool",
  published: "2026-03-17"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      },
      "datePublished": meta.published
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How is the total stock return calculated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Total stock return is calculated by adding the capital appreciation (ending value minus beginning value) and any dividends received during the holding period, then dividing by the initial investment amount."
          }
        },
        {
          "@type": "Question",
          "name": "Does the stock return calculator account for taxes and fees?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, our stock return calculator includes optional inputs for commissions and tax rates, allowing you to calculate your net return after these expenses."
          }
        },
        {
          "@type": "Question",
          "name": "What is annualized return and why is it important?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Annualized return converts your total return into a yearly rate, making it easier to compare investments held for different lengths of time. It shows what you earned on average per year."
          }
        },
        {
          "@type": "Question",
          "name": "How do dividends affect my stock return?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dividends are cash payments made by companies to shareholders. They contribute significantly to your total return, especially over long periods when reinvested, due to the power of compounding."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my real return lower than my nominal return?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Real return accounts for inflation, which erodes the purchasing power of your money over time. If your nominal return is 8% but inflation is 3%, your real return is approximately 5%."
          }
        }
      ]
    }
  ]
};
