  <script is:inline>
    // Search and filter functionality
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('searchInput');
      const stockRows = document.querySelectorAll('.stock-row');

      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();

          stockRows.forEach(row => {
            const name = row.getAttribute('data-name') || '';
            const ticker = row.getAttribute('data-ticker') || '';
            const sector = row.getAttribute('data-sector') || '';

            if (name.includes(query) || ticker.includes(query) || sector.includes(query)) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          });
        });
      }
    });

    // Sort table functionality
    let sortDirection = {};

    function sortTable(columnIndex, type) {
      const table = document.getElementById("stockTable");
      const tbody = document.getElementById("tableBody");
      const rows = Array.from(tbody.querySelectorAll("tr.stock-row"));

      // Toggle sort direction
      sortDirection[columnIndex] = !sortDirection[columnIndex];
      const isAscending = sortDirection[columnIndex];

      rows.sort((a, b) => {
        let valA, valB;

        if (type === 'num') {
          valA = parseFloat(a.cells[columnIndex].getAttribute('data-value')) || 0;
          valB = parseFloat(b.cells[columnIndex].getAttribute('data-value')) || 0;
          return isAscending ? valA - valB : valB - valA;
        } else {
          valA = a.cells[columnIndex].textContent.trim().toLowerCase();
          valB = b.cells[columnIndex].textContent.trim().toLowerCase();
          return isAscending ? valA.localeCompare(valB) : valB.localeCompare(valA);
        }
      });

      // Update table
      rows.forEach(row => tbody.appendChild(row));
    }
  </script>

