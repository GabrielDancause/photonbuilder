const schema = {"@context": "https://schema.org", "@graph": [{"@type": "Article", "headline": "What to Do When Stocks Are Crashing: A Beginner's Guide", "author": {"@type": "Organization", "name": "Westmount Fundamentals"}, "publisher": {"@type": "Organization", "name": "Westmount Fundamentals"}, "datePublished": "2026-03-15"}, {"@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Should I sell my stocks when the market crashes?", "acceptedAnswer": {"@type": "Answer", "text": "Generally, no. Selling during a crash locks in your losses. Historically, markets recover over time, so holding quality investments is usually the better strategy."}}, {"@type": "Question", "name": "How long does a stock market crash last?", "acceptedAnswer": {"@type": "Answer", "text": "It varies. Some crashes, like in 2020, recover in months. Others, like the 2008 financial crisis, can take years to reach previous highs."}}, {"@type": "Question", "name": "Is a market crash a good time to buy?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, crashes can provide opportunities to buy quality companies at discounted prices, provided you have a long-term time horizon."}}, {"@type": "Question", "name": "What is the difference between a correction and a crash?", "acceptedAnswer": {"@type": "Answer", "text": "A correction is typically defined as a drop of 10% to 20% from a recent peak, while a crash or bear market involves a rapid, severe drop of 20% or more."}}, {"@type": "Question", "name": "How can I protect my portfolio from a crash?", "acceptedAnswer": {"@type": "Answer", "text": "Diversification across different asset classes, holding an emergency cash fund, and investing in high-quality, dividend-paying stocks can help mitigate losses."}}]}]};
