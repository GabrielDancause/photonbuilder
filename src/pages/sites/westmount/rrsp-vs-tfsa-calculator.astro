---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "RRSP vs TFSA Calculator: Which Account Saves You More Tax?",
  description: "Compare RRSP and TFSA side by side with this Canadian tax calculator. See after-tax retirement values, breakeven tax rates, and year-by-year growth for both accounts.",
  category: "tool",
  published: "2026-03-21"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": meta.title,
      "description": meta.description,
      "url": "https://westmountfundamentals.com/rrsp-vs-tfsa-calculator",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "CAD"
      },
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "datePublished": meta.published
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the main difference between an RRSP and a TFSA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The RRSP gives you a tax deduction when you contribute but you pay tax when you withdraw in retirement. The TFSA uses after-tax dollars for contributions but all withdrawals — including investment growth — are completely tax-free. The RRSP defers tax; the TFSA eliminates it."
          }
        },
        {
          "@type": "Question",
          "name": "When is an RRSP better than a TFSA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An RRSP is better when your marginal tax rate today is higher than what it will be in retirement. The tax refund you receive now is worth more than the tax you will pay later on withdrawals. This is common for high-income earners who expect a lower income in retirement."
          }
        },
        {
          "@type": "Question",
          "name": "When is a TFSA better than an RRSP?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A TFSA is better when your tax rate in retirement will be the same as or higher than your current rate. This often applies to lower-income earners, those who expect significant pension income, or anyone who wants withdrawal flexibility without affecting government benefits like OAS or GIS."
          }
        },
        {
          "@type": "Question",
          "name": "What is the breakeven tax rate for RRSP vs TFSA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The breakeven tax rate is the retirement tax rate at which the RRSP and TFSA produce exactly the same after-tax outcome. If your actual retirement tax rate is below the breakeven rate, the RRSP wins. If it is above, the TFSA wins. When contribution amounts are equal, the breakeven rate equals your current marginal tax rate."
          }
        },
        {
          "@type": "Question",
          "name": "Can I contribute to both an RRSP and a TFSA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Most Canadian financial planners recommend maximizing both accounts. A common strategy is to contribute to your RRSP first for the tax deduction, then invest the tax refund into your TFSA. This way you benefit from the RRSP's upfront deduction and the TFSA's tax-free growth simultaneously."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/rrsp-vs-tfsa-calculator"
  schema={schema}
>
  <div class="page-content">

    <div style="text-align: center; margin-bottom: 2rem;">
      <h1>RRSP vs TFSA Calculator</h1>
      <p style="font-size: 1.2rem; max-width: 640px; margin: 0 auto;">Compare the after-tax retirement value of RRSP and TFSA contributions side by side. Find out which account saves you more.</p>
    </div>

    <div class="calculator-card">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
        <div class="input-group">
          <label for="annualIncome">Annual Income</label>
          <div class="input-wrapper">
            <span style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
            <input type="number" id="annualIncome" value="85000" min="0" step="1000" style="padding-left: 2rem;">
          </div>
        </div>

        <div class="input-group">
          <label for="currentTaxRate">Current Marginal Tax Rate</label>
          <div class="input-wrapper">
            <input type="number" id="currentTaxRate" value="33" min="0" max="54" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="contribution">Annual Contribution</label>
          <div class="input-wrapper">
            <span style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
            <input type="number" id="contribution" value="10000" min="100" step="500" style="padding-left: 2rem;">
          </div>
        </div>

        <div class="input-group">
          <label for="returnRate">Expected Annual Return</label>
          <div class="input-wrapper">
            <input type="number" id="returnRate" value="7" min="0" max="30" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="years">Years to Retirement</label>
          <div class="input-wrapper">
            <input type="number" id="years" value="25" min="1" max="50" step="1">
            <span class="suffix">years</span>
          </div>
        </div>

        <div class="input-group">
          <label for="retirementTaxRate">Expected Retirement Tax Rate</label>
          <div class="input-wrapper">
            <input type="number" id="retirementTaxRate" value="25" min="0" max="54" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>
      </div>

      <div style="text-align: center; margin-top: 1.5rem;">
        <button id="calculateBtn" style="padding: 0.75rem 2rem; background: var(--accent-color); color: #fff; border: none; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer;">Calculate</button>
      </div>
    </div>

    <!-- Results -->
    <div id="resultsSection" style="display: none;">
      <div class="stats-grid" style="margin-top: 2rem;">
        <div class="stat-card">
          <span class="calc-result-label">RRSP After-Tax Value</span>
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--accent-color);" id="rrspValue">$0</div>
          <div style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.25rem;" id="rrspGross"></div>
        </div>
        <div class="stat-card">
          <span class="calc-result-label">TFSA Value</span>
          <div style="font-size: 1.5rem; font-weight: 700; color: #2ecc71;" id="tfsaValue">$0</div>
          <div style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.25rem;" id="tfsaNote">Fully tax-free</div>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <span class="calc-result-label">Winner</span>
          <div style="font-size: 1.3rem; font-weight: 700;" id="winner">—</div>
          <div style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.25rem;" id="winnerDiff"></div>
        </div>
        <div class="stat-card">
          <span class="calc-result-label">Breakeven Retirement Tax Rate</span>
          <div style="font-size: 1.3rem; font-weight: 700; color: var(--text-primary);" id="breakeven">0%</div>
          <div style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.25rem;" id="breakevenNote"></div>
        </div>
        <div class="stat-card">
          <span class="calc-result-label">RRSP Tax Refund Invested</span>
          <div style="font-size: 1.3rem; font-weight: 700; color: var(--text-primary);" id="refundValue">$0</div>
          <div style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.25rem;" id="refundNote"></div>
        </div>
        <div class="stat-card">
          <span class="calc-result-label">Total Contributions</span>
          <div style="font-size: 1.3rem; font-weight: 700; color: var(--text-primary);" id="totalContrib">$0</div>
        </div>
      </div>

      <!-- Scenarios -->
      <div class="chart-container" style="margin-top: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem;">Tax Bracket Scenarios</h3>
        <div class="stats-grid">
          <div class="stat-card" id="scenarioSame">
            <span class="calc-result-label">Same Bracket</span>
            <div style="font-size: 1.1rem; font-weight: 700; margin-top: 0.5rem;" id="scenarioSameResult">—</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;" id="scenarioSameDetail"></div>
          </div>
          <div class="stat-card" id="scenarioLower">
            <span class="calc-result-label">Lower Bracket in Retirement</span>
            <div style="font-size: 1.1rem; font-weight: 700; margin-top: 0.5rem;" id="scenarioLowerResult">—</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;" id="scenarioLowerDetail"></div>
          </div>
          <div class="stat-card" id="scenarioHigher">
            <span class="calc-result-label">Higher Bracket in Retirement</span>
            <div style="font-size: 1.1rem; font-weight: 700; margin-top: 0.5rem;" id="scenarioHigherResult">—</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;" id="scenarioHigherDetail"></div>
          </div>
        </div>
      </div>

      <!-- Chart -->
      <div class="chart-container" style="margin-top: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem;">Growth Comparison</h3>
        <canvas id="growthChart" style="width: 100%; height: 320px;"></canvas>
      </div>

      <!-- Table -->
      <div class="chart-container" style="margin-top: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem;">Year-by-Year Comparison</h3>
        <div class="table-container" style="max-height: 450px; overflow-y: auto;">
          <table id="comparisonTable">
            <thead style="position: sticky; top: 0; z-index: 1;">
              <tr>
                <th>Year</th>
                <th>Contribution</th>
                <th>RRSP Balance</th>
                <th>TFSA Balance</th>
                <th>RRSP After-Tax</th>
                <th>Difference</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>

      <div class="info-box" style="margin-top: 2rem; padding: 1.25rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;">
        <p style="margin: 0; color: var(--text-secondary); font-size: 0.95rem;"><strong>Important:</strong> This calculator assumes the RRSP tax refund is reinvested each year. It also assumes constant tax rates and returns for simplicity. In practice, your marginal rate may change as your income grows, and RRSP withdrawals can affect OAS clawbacks and other government benefits. Consult a financial advisor for personalized advice.</p>
      </div>
    </div>

    <script is:inline>
      const fmt = (n) => new Intl.NumberFormat('en-CA', { style: 'currency', currency: 'CAD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
      const fmtPct = (n) => n.toFixed(1) + '%';

      function calculate() {
        const annualIncome = parseFloat(document.getElementById('annualIncome').value) || 85000;
        const currentTaxRate = Math.min(54, Math.max(0, parseFloat(document.getElementById('currentTaxRate').value) || 33)) / 100;
        const contribution = Math.max(100, parseFloat(document.getElementById('contribution').value) || 10000);
        const returnRate = Math.min(30, Math.max(0, parseFloat(document.getElementById('returnRate').value) || 7)) / 100;
        const years = Math.min(50, Math.max(1, parseInt(document.getElementById('years').value) || 25));
        const retirementTaxRate = Math.min(54, Math.max(0, parseFloat(document.getElementById('retirementTaxRate').value) || 25)) / 100;

        // RRSP: contribution is pre-tax, you get a tax refund which we reinvest
        // The effective RRSP contribution = contribution (goes into RRSP)
        // Tax refund = contribution * currentTaxRate (reinvested into RRSP)
        // Total going into RRSP each year = contribution + refund = contribution / (1 - currentTaxRate) ...
        // Actually: you contribute $contribution, get refund of contribution * currentTaxRate, reinvest that too
        // So total annual RRSP contribution = contribution + contribution * currentTaxRate = contribution * (1 + currentTaxRate)
        // Wait, more standard approach:
        // You have $contribution of pre-tax money to allocate.
        // RRSP: put $contribution in, get refund of contribution * currentTaxRate, reinvest refund
        // TFSA: you pay tax first, so you invest contribution * (1 - currentTaxRate) into TFSA
        // But the user is specifying "annual contribution" — let's treat it as the same dollar amount going into each account
        // and show the RRSP advantage of the refund being reinvested.

        // Simpler standard comparison:
        // Both get the same $contribution per year
        // RRSP: grows tax-deferred, taxed at retirementTaxRate on withdrawal
        // TFSA: grows tax-free, no tax on withdrawal
        // RRSP also generates a tax refund of contribution * currentTaxRate each year, which is reinvested in a taxable or TFSA account
        // For fairness, we reinvest the refund at the same return rate (in RRSP for simplicity)

        const rrspAnnual = contribution;
        const refundAnnual = contribution * currentTaxRate;
        const tfsaAnnual = contribution;

        // Year-by-year
        let rrspBalance = 0;
        let refundBalance = 0; // refund invested separately (taxable, but we simplify as same growth)
        let tfsaBalance = 0;
        const tableData = [];

        for (let y = 1; y <= years; y++) {
          // Add contribution at start of year, then grow
          rrspBalance = (rrspBalance + rrspAnnual) * (1 + returnRate);
          refundBalance = (refundBalance + refundAnnual) * (1 + returnRate);
          tfsaBalance = (tfsaBalance + tfsaAnnual) * (1 + returnRate);

          const rrspAfterTax = rrspBalance * (1 - retirementTaxRate);
          // Refund balance: if invested in taxable account, gains taxed. Simplified: after-tax = refundBalance * (1 - retirementTaxRate on gains)
          // For simplicity, we treat refund as reinvested into the RRSP
          const totalRRSPafterTax = (rrspBalance + refundBalance) * (1 - retirementTaxRate);
          const diff = totalRRSPafterTax - tfsaBalance;

          tableData.push({
            year: y,
            contributed: contribution * y,
            rrspBal: rrspBalance + refundBalance,
            tfsaBal: tfsaBalance,
            rrspAfterTax: totalRRSPafterTax,
            diff: diff
          });
        }

        const finalData = tableData[tableData.length - 1];
        const rrspGrossTotal = finalData.rrspBal;
        const rrspAfterTaxTotal = finalData.rrspAfterTax;
        const tfsaTotal = finalData.tfsaBal;
        const difference = rrspAfterTaxTotal - tfsaTotal;

        // Breakeven tax rate: rate where RRSP after-tax = TFSA
        // RRSP after-tax = rrspGrossTotal * (1 - breakevenRate) = tfsaTotal
        // breakevenRate = 1 - tfsaTotal / rrspGrossTotal
        const breakevenRate = 1 - tfsaTotal / rrspGrossTotal;

        // Display results
        document.getElementById('resultsSection').style.display = '';
        document.getElementById('rrspValue').textContent = fmt(rrspAfterTaxTotal);
        document.getElementById('rrspGross').textContent = 'Pre-tax: ' + fmt(rrspGrossTotal);
        document.getElementById('tfsaValue').textContent = fmt(tfsaTotal);
        document.getElementById('refundValue').textContent = fmt(refundBalance);
        document.getElementById('refundNote').textContent = 'Annual refund: ' + fmt(refundAnnual);
        document.getElementById('totalContrib').textContent = fmt(contribution * years);
        document.getElementById('breakeven').textContent = fmtPct(breakevenRate * 100);
        document.getElementById('breakevenNote').textContent = retirementTaxRate < breakevenRate
          ? 'Your retirement rate is below this — RRSP wins'
          : retirementTaxRate > breakevenRate
            ? 'Your retirement rate is above this — TFSA wins'
            : 'Your retirement rate equals this — they are tied';

        const winnerEl = document.getElementById('winner');
        const winnerDiffEl = document.getElementById('winnerDiff');
        if (difference > 0) {
          winnerEl.textContent = 'RRSP Wins';
          winnerEl.style.color = 'var(--accent-color)';
          winnerDiffEl.textContent = 'By ' + fmt(difference);
        } else if (difference < 0) {
          winnerEl.textContent = 'TFSA Wins';
          winnerEl.style.color = '#2ecc71';
          winnerDiffEl.textContent = 'By ' + fmt(Math.abs(difference));
        } else {
          winnerEl.textContent = 'Tie';
          winnerEl.style.color = 'var(--text-primary)';
          winnerDiffEl.textContent = '';
        }

        // Scenarios
        function scenarioResult(retRate) {
          const afterTax = rrspGrossTotal * (1 - retRate);
          const diff = afterTax - tfsaTotal;
          return { afterTax, diff };
        }

        // Same bracket
        const same = scenarioResult(currentTaxRate);
        document.getElementById('scenarioSameResult').textContent = same.diff >= 0 ? 'RRSP: ' + fmt(same.afterTax) : 'TFSA: ' + fmt(tfsaTotal);
        document.getElementById('scenarioSameResult').style.color = same.diff >= 0 ? 'var(--accent-color)' : '#2ecc71';
        document.getElementById('scenarioSameDetail').textContent = 'Retirement rate: ' + fmtPct(currentTaxRate * 100) + ' — Diff: ' + fmt(Math.abs(same.diff));

        // Lower bracket
        const lowerRate = Math.max(0, currentTaxRate - 0.10);
        const lower = scenarioResult(lowerRate);
        document.getElementById('scenarioLowerResult').textContent = 'RRSP: ' + fmt(lower.afterTax);
        document.getElementById('scenarioLowerResult').style.color = 'var(--accent-color)';
        document.getElementById('scenarioLowerDetail').textContent = 'Retirement rate: ' + fmtPct(lowerRate * 100) + ' — RRSP ahead by ' + fmt(lower.diff);

        // Higher bracket
        const higherRate = Math.min(0.54, currentTaxRate + 0.10);
        const higher = scenarioResult(higherRate);
        document.getElementById('scenarioHigherResult').textContent = higher.diff >= 0 ? 'RRSP: ' + fmt(higher.afterTax) : 'TFSA: ' + fmt(tfsaTotal);
        document.getElementById('scenarioHigherResult').style.color = higher.diff >= 0 ? 'var(--accent-color)' : '#2ecc71';
        document.getElementById('scenarioHigherDetail').textContent = 'Retirement rate: ' + fmtPct(higherRate * 100) + ' — ' + (higher.diff >= 0 ? 'RRSP ahead by ' : 'TFSA ahead by ') + fmt(Math.abs(higher.diff));

        // Table
        const tbody = document.querySelector('#comparisonTable tbody');
        let html = '';
        for (let i = 0; i < tableData.length; i++) {
          const d = tableData[i];
          const diffColor = d.diff >= 0 ? 'var(--accent-color)' : '#2ecc71';
          const diffLabel = d.diff >= 0 ? 'RRSP +' + fmt(d.diff) : 'TFSA +' + fmt(Math.abs(d.diff));
          html += '<tr>' +
            '<td>' + d.year + '</td>' +
            '<td>' + fmt(d.contributed) + '</td>' +
            '<td>' + fmt(d.rrspBal) + '</td>' +
            '<td>' + fmt(d.tfsaBal) + '</td>' +
            '<td>' + fmt(d.rrspAfterTax) + '</td>' +
            '<td style="color: ' + diffColor + ';">' + diffLabel + '</td>' +
          '</tr>';
        }
        tbody.innerHTML = html;

        drawChart(tableData);
      }

      function drawChart(tableData) {
        const canvas = document.getElementById('growthChart');
        const ctx = canvas.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width * dpr;
        canvas.height = 320 * dpr;
        canvas.style.height = '320px';
        ctx.scale(dpr, dpr);
        const W = rect.width;
        const H = 320;

        ctx.clearRect(0, 0, W, H);

        const pad = { top: 20, right: 20, bottom: 40, left: 80 };
        const cw = W - pad.left - pad.right;
        const ch = H - pad.top - pad.bottom;

        const years = tableData.length;
        const maxVal = Math.max.apply(null, tableData.map(function(d) { return Math.max(d.rrspBal, d.tfsaBal, d.rrspAfterTax); })) * 1.05;

        var xScale = function(i) { return pad.left + (i / years) * cw; };
        var yScale = function(v) { return pad.top + ch - (v / maxVal) * ch; };

        // Grid
        var styles = getComputedStyle(document.documentElement);
        var textColor = styles.getPropertyValue('--text-secondary').trim() || '#888';
        var borderColor = styles.getPropertyValue('--border-color').trim() || '#333';
        var accentColor = styles.getPropertyValue('--accent-color').trim() || '#4a9eff';

        ctx.strokeStyle = borderColor;
        ctx.lineWidth = 0.5;
        ctx.font = '11px system-ui, sans-serif';
        ctx.fillStyle = textColor;

        var gridLines = 5;
        for (var g = 0; g <= gridLines; g++) {
          var y = pad.top + (g / gridLines) * ch;
          var val = maxVal - (g / gridLines) * maxVal;
          ctx.beginPath();
          ctx.moveTo(pad.left, y);
          ctx.lineTo(W - pad.right, y);
          ctx.stroke();
          ctx.textAlign = 'right';
          ctx.fillText('$' + Math.round(val).toLocaleString(), pad.left - 8, y + 4);
        }

        // X labels
        ctx.textAlign = 'center';
        var step = years <= 15 ? 1 : years <= 30 ? 5 : 10;
        for (var xi = 0; xi <= years; xi += step) {
          if (xi === 0) continue;
          ctx.fillText('Y' + xi, xScale(xi), H - pad.bottom + 20);
        }

        // Draw lines
        function drawLine(data, accessor, color, lineWidth) {
          ctx.strokeStyle = color;
          ctx.lineWidth = lineWidth;
          ctx.lineJoin = 'round';
          ctx.beginPath();
          for (var i = 0; i < data.length; i++) {
            var x = xScale(i + 1);
            var yy = yScale(accessor(data[i]));
            if (i === 0) ctx.moveTo(x, yy);
            else ctx.lineTo(x, yy);
          }
          ctx.stroke();
        }

        // RRSP gross (dashed)
        ctx.setLineDash([6, 4]);
        drawLine(tableData, function(d) { return d.rrspBal; }, accentColor, 1.5);
        ctx.setLineDash([]);

        // RRSP after-tax (solid)
        drawLine(tableData, function(d) { return d.rrspAfterTax; }, accentColor, 2.5);

        // TFSA
        drawLine(tableData, function(d) { return d.tfsaBal; }, '#2ecc71', 2.5);

        // Legend
        ctx.font = '12px system-ui, sans-serif';
        var legendY = H - 8;
        var lx = pad.left;

        ctx.setLineDash([6, 4]);
        ctx.strokeStyle = accentColor;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(lx, legendY - 6);
        ctx.lineTo(lx + 16, legendY - 6);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = textColor;
        ctx.textAlign = 'left';
        ctx.fillText('RRSP Pre-Tax', lx + 20, legendY);

        lx += 110;
        ctx.fillStyle = accentColor;
        ctx.fillRect(lx, legendY - 8, 16, 3);
        ctx.fillStyle = textColor;
        ctx.fillText('RRSP After-Tax', lx + 20, legendY);

        lx += 120;
        ctx.fillStyle = '#2ecc71';
        ctx.fillRect(lx, legendY - 8, 16, 3);
        ctx.fillStyle = textColor;
        ctx.fillText('TFSA', lx + 20, legendY);
      }

      document.getElementById('calculateBtn').addEventListener('click', calculate);
      calculate();
    </script>

    <style>
      .input-group {
        margin-bottom: 1.5rem;
      }
      .input-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--text-primary);
      }
      .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
      }
      .suffix {
        position: absolute;
        right: 0;
        color: var(--text-secondary);
        padding: 0 0.75rem;
        font-size: 1rem;
      }
      .input-group input, .input-group select {
        width: 100%;
        padding: 0.75rem;
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        color: var(--text-primary);
        font-size: 1rem;
      }
      .input-group input:focus, .input-group select:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 2px rgba(var(--accent-color-rgb), 0.2);
      }
      .stats-grid {
        display: grid;
