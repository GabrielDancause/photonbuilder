      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the largest stock in the Donald Trump stock portfolio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The vast majority of Donald Trump's stock portfolio is concentrated in Trump Media & Technology Group Corp (DJT), which operates Truth Social. At various times, this single position has accounted for over 90% of his public equity wealth."
          }
        },
        {
          "@type": "Question",
          "name": "Does the Donald Trump stock portfolio 2025 contain traditional index funds?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Historically, Trump's financial disclosures have shown holdings in broad mutual funds, index funds, and standard blue-chip stocks. However, his overall net worth remains overwhelmingly tied to real estate and his massive stake in DJT."
          }
        },
        {
          "@type": "Question",
          "name": "How often is the Donald Trump stock portfolio updated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "As a public figure and government official, Trump is required to file regular financial disclosures (such as the OGE Form 278e). These forms provide a snapshot of his holdings, though they report asset values in broad ranges rather than exact dollar amounts."
          }
        },
        {
          "@type": "Question",
          "name": "Can you buy the exact same stocks as the Donald Trump stock portfolio 2025?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, since his disclosed equity holdings are publicly traded companies and index funds, any investor can purchase the same assets. However, mirroring the exact portfolio is difficult because the disclosures only provide broad value ranges, not exact share counts."
          }
        },
        {
          "@type": "Question",
          "name": "How does Trump's portfolio compare to typical diversified investments?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A standard diversified portfolio relies on an even mix of stocks and bonds across many sectors. Trump's portfolio is heavily skewed toward a single media company (DJT) and private real estate, making it much more volatile and high-risk than traditional retirement portfolios."
          }
        }
