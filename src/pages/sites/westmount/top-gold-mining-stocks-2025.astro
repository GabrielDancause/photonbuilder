import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Are gold stocks a good investment for 2025?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gold stocks can be a solid hedge against inflation and economic uncertainty. When the price of physical gold rises, mining companies often see disproportionate gains in profitability due to operating leverage, making them attractive for 2025 portfolios. However, investors must recognize that mining companies carry operational risks that physical gold does not, such as geopolitical issues, labor strikes, and fluctuating energy costs. This makes diversification essential when building a resilient portfolio. Always consider your personal risk tolerance and time horizon before allocating a significant portion of your capital to the precious metals sector."
          }
        },
        {
          "@type": "Question",
          "name": "How do I choose the best gold mining stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Look for companies with low All-In Sustaining Costs (AISC), strong balance sheets, consistent production growth, and proven reserves. Companies operating in politically stable jurisdictions generally carry less risk. A history of strong management and capital allocation is also a major plus, as poor leadership can destroy shareholder value even in a bull market for gold. Additionally, reviewing dividend track records and the company's ability to generate free cash flow in various gold price environments will help ensure you are selecting a financially sound operator capable of withstanding market volatility."
          }
        },
        {
          "@type": "Question",
          "name": "Do gold mining stocks pay dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, many established gold miners pay dividends. Some even tie their dividend payouts directly to the price of gold, offering higher yields when gold prices are strong. This variable dividend policy allows shareholders to benefit directly during boom cycles while protecting the company's balance sheet during downturns. Reinvesting these dividends can significantly enhance total returns over a long investment horizon. Be sure to check the payout ratio to ensure the dividends are sustainable and not being funded by debt or the issuance of new shares, which dilutes existing shareholders."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between physical gold and gold stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Physical gold is a tangible asset that tracks the market price but produces no income. Gold stocks are shares in companies that mine gold, offering potential capital appreciation and dividends, but carrying operational and management risks. A primary advantage of gold stocks is operating leverage: a 10% increase in the price of gold can lead to a 30% or 40% increase in a miner's profit margin, driving the stock price up much faster than the underlying commodity. Conversely, this leverage works both ways, meaning gold stocks can drop precipitously if gold prices decline or if the company faces a catastrophic operational failure."
          }
        },
        {
          "@type": "Question",
          "name": "Why are some gold stocks more volatile than others?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Junior miners (exploration and development companies) are much more volatile than senior miners (established producers) because they have no current revenue and rely entirely on finding gold and securing financing. If a junior miner strikes a major deposit, the stock can skyrocket; if their exploration fails, the stock can go to zero. Senior miners, on the other hand, have diversified portfolios of producing mines, predictable cash flows, and established infrastructure, which insulates them from the failure of any single project. Market sentiment, geopolitical developments, and changes in the cost of capital also disproportionately affect junior miners."
          }
        }
      ]
    },
    {
