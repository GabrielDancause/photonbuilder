  <script is:inline>
    // Filter logic
    document.addEventListener('DOMContentLoaded', () => {
      const yieldFilter = document.getElementById('yieldFilter');
      const rows = document.querySelectorAll('.item-row');
      const cards = document.querySelectorAll('.item-card');

      function filterItems() {
        const minYield = parseFloat(yieldFilter.value);

        rows.forEach(row => {
          const rYield = parseFloat(row.getAttribute('data-yield'));
          const match = rYield >= minYield;
          row.style.display = match ? '' : 'none';
        });

        cards.forEach(card => {
          const cYield = parseFloat(card.getAttribute('data-yield'));
          const match = cYield >= minYield;
          card.style.display = match ? 'block' : 'none';
        });
      }

      if(yieldFilter) yieldFilter.addEventListener('change', filterItems);
    });

    // Sort logic
    function sortTable(tableId, n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById(tableId);
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let valX = x.innerHTML.replace(/[^0-9.-]+/g,"");
          let valY = y.innerHTML.replace(/[^0-9.-]+/g,"");

          if(valX && valY && !isNaN(valX) && !isNaN(valY)) {
             if (dir == "asc") {
              if (parseFloat(valX) > parseFloat(valY)) { shouldSwitch = true; break; }
            } else {
              if (parseFloat(valX) < parseFloat(valY)) { shouldSwitch = true; break; }
            }
          } else {
            if (dir == "asc") {
              if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            } else {
              if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }
  </script>
