---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "How to Start Investing in Stocks (A No-Nonsense Guide)",
  description: "Everyone tells you to invest, but nobody tells you exactly how it works. We break down the exact mechanics, the real numbers, and the one crucial step beginners overlook.",
  category: "guide",
  published: "2026-03-17"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Westmount Fundamentals"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/how-to-start-investing"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much money do I need to start investing in stocks?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Thanks to fractional shares, you can start investing in stocks with as little as $1 to $5 through most major brokerages like Fidelity, Charles Schwab, or Interactive Brokers."
        }
      },
      {
        "@type": "Question",
        "name": "What is the best way to start investing in stocks for beginners?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most effective way for beginners to start investing is by opening a brokerage account and purchasing broad-market index funds, such as an S&P 500 ETF (like VOO or SPY). This provides instant diversification across hundreds of top companies."
        }
      },
      {
        "@type": "Question",
        "name": "Is it safe to invest in stocks right now?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While the stock market experiences short-term volatility, it has historically grown over the long term. The key is to invest money you won't need for at least 3-5 years, rather than trying to time short-term market movements."
        }
      },
      {
        "@type": "Question",
        "name": "Do I have to pay taxes on my stocks?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In a standard taxable brokerage account, you pay capital gains tax only when you sell a stock for a profit, and you pay taxes on any dividends you receive. If you use tax-advantaged accounts like an IRA or 401(k), your taxes are either deferred or eliminated depending on the account type."
        }
      },
      {
        "@type": "Question",
        "name": "Can I lose all my money in the stock market?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you invest all your money in a single company and it goes bankrupt, you can lose your entire investment. However, if you invest in a broadly diversified index fund like the S&P 500, the chance of it going to zero is effectively nonexistent, as that would mean all 500 major U.S. corporations failed simultaneously."
        }
      }
    ]
  }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/how-to-start-investing" schema={schema}>
  <div class="page-content">
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">How to Start Investing in Stocks: The Fundamentals</h1>
      <p class="text-lg md:text-xl text-[var(--text-secondary)] mb-6">Discover how to invest in stocks for the long term—without jargon. We break down exactly what you're buying and the math behind compounding growth.</p>

      <div class="flex items-center gap-4 text-sm text-[var(--text-secondary)] mb-8 pb-8 border-b border-[var(--border-color)]">
        <div>Published: {meta.published}</div>
        <div>Category: {meta.category.toUpperCase()}</div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">1. What Exactly Are You Buying?</h2>
          <p class="mb-4">
            Most people hear "the stock market" and think of rapidly moving red and green numbers on a screen. But you are not buying a blinking light; you are buying partial ownership of a real business. When you learn <a href="/how-to-invest-in-stocks">how to invest in stocks</a>, you are literally acquiring fractions of corporations.
          </p>
          <p class="mb-4">
            Let's use a real example: <strong>Apple Inc. (AAPL)</strong>. Apple has roughly 15 billion shares outstanding. When you buy just 1 share, you become a 1/15,000,000,000th owner of Apple. You own a tiny fraction of every iPhone sold, every Macbook produced, and every Apple Music subscription. If Apple's profits increase, the value of your tiny slice theoretically increases too.
          </p>
          <p class="mb-6">
            In our <a href="/stocks-for-beginners">stocks for beginners</a> guide, we emphasize this simple truth: investing is the act of putting your money into assets that have a historical probability of generating income or appreciating in value.
          </p>

          <div class="p-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg mb-8 shadow-sm">
            <h3 class="text-xl font-bold mb-3 flex items-center gap-2">
              <span class="bg-[var(--accent-color)] text-white w-6 h-6 rounded-full inline-flex items-center justify-center text-sm font-bold">!</span>
              The Theory vs. The Reality
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-4">
              <div>
                <h4 class="font-bold text-[var(--accent-color)] mb-2">The Theory</h4>
                <p class="text-sm">You buy a stock, the company makes more money over time, and the stock price goes up smoothly year over year.</p>
              </div>
              <div>
                <h4 class="font-bold text-[var(--accent-color)] mb-2">The Reality</h4>
                <p class="text-sm">Stock prices fluctuate wildly day-to-day based on human emotion, interest rates, and headlines—but over decades, the price ultimately follows the company's earnings trajectory.</p>
              </div>
            </div>
          </div>
        </section>

        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">2. Step-by-Step: Getting Set Up</h2>
          <p class="mb-4">
            For decades, buying stocks required calling a broker on the phone and paying a massive commission (often $50 or more per trade). Today, thanks to heavy competition, you can start investing with $5 and zero commission fees right from your smartphone.
          </p>

          <ol class="list-decimal pl-6 space-y-6 mb-8">
            <li class="pl-2">
              <strong class="text-xl block mb-2">Open a Brokerage Account</strong>
              <p>A brokerage account is simply a specialized bank account designed to hold investments rather than just cash. In the US, the major established players are Vanguard, Fidelity, and Charles Schwab. These platforms are heavily regulated and offer zero-commission trading for US stocks and Exchange Traded Funds (ETFs).</p>
            </li>
            <li class="pl-2">
              <strong class="text-xl block mb-2">Fund the Account</strong>
              <p>Link your checking account and transfer money over. Until you actually buy a stock or fund, this money just sits in the account as "cash" (though many brokers now automatically place uninvested cash in a money market fund yielding 4-5% interest).</p>
            </li>
            <li class="pl-2">
              <strong class="text-xl block mb-2">Choose Your Strategy (Individual Stocks vs. Index Funds)</strong>
              <p>This is where most beginners freeze. Do you buy Microsoft? Tesla? McDonald's? The data shows that picking individual winning stocks is incredibly difficult over decades. Instead, Warren Buffett and most financial professionals recommend buying an <strong>S&P 500 Index Fund</strong>. The S&P 500 tracks the 500 largest publicly traded companies in the United States. By buying a single share of an S&P 500 ETF (like VOO or SPY), you instantly own a microscopic piece of Apple, Microsoft, Amazon, Nvidia, and 496 others.</p>
            </li>
            <li class="pl-2">
              <strong class="text-xl block mb-2">Place the Order</strong>
              <p>Search the ticker symbol (e.g., "VOO" for Vanguard S&P 500 ETF), click "Buy," enter how much money you want to invest, and submit. Congratulations—you are now an investor.</p>
            </li>
          </ol>
        </section>

        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">3. The Power of Compounding (Real Numbers)</h2>
          <p class="mb-4">
            The secret weapon of investing isn't picking the perfect stock; it is time. Compound interest is when the money your investments generate starts generating its own money. If you want to understand <a href="/investing-for-beginners">how to invest in stocks for beginners</a>, you must understand compounding.
          </p>
          <p class="mb-6">
            Historically, the U.S. stock market (measured by the S&P 500) has returned an average of about 10% per year over the last century, before inflation. Let's look at the <a href="/average-stock-market-return">average stock market return</a> in action using real historical averages.
          </p>

          <div class="p-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg mb-8">
            <h3 class="text-xl font-bold mb-4">Interactive Compounding Calculator</h3>
            <p class="text-sm text-[var(--text-secondary)] mb-6">Enter your initial investment and monthly contribution to see how a historical 10% average annual return compounds over decades.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
              <div>
                <label class="block text-sm font-bold mb-2">Initial Investment ($)</label>
                <input type="number" id="initial-investment" value="1000" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded p-2 text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-color)]" />
              </div>
              <div>
                <label class="block text-sm font-bold mb-2">Monthly Contribution ($)</label>
                <input type="number" id="monthly-contribution" value="500" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded p-2 text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-color)]" />
              </div>
              <div>
                <label class="block text-sm font-bold mb-2">Years to Invest</label>
                <input type="number" id="investment-years" value="30" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded p-2 text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-color)]" />
              </div>
              <div>
                <label class="block text-sm font-bold mb-2">Estimated Annual Return (%)</label>
                <input type="number" id="annual-return" value="10" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded p-2 text-[var(--text-primary)] focus:outline-none focus:border-[var(--accent-color)]" />
              </div>
            </div>

            <div class="mt-6 text-center">
              <button id="calc-compound-btn" class="bg-[var(--accent-color)] text-white px-6 py-2 rounded font-bold hover:opacity-90 transition-opacity w-full md:w-auto">Calculate Future Value</button>
            </div>

            <div id="calculator-results" class="hidden mt-8 pt-6 border-t border-[var(--border-color)]">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-center">
                <div class="bg-[var(--bg-color)] p-4 rounded border border-[var(--border-color)]">
                  <div class="text-sm text-[var(--text-secondary)] mb-1">Total Contributions</div>
                  <div id="result-principal" class="text-xl font-bold">$0</div>
                </div>
                <div class="bg-[var(--bg-color)] p-4 rounded border border-[var(--border-color)]">
                  <div class="text-sm text-[var(--text-secondary)] mb-1">Total Interest Earned</div>
                  <div id="result-interest" class="text-xl font-bold text-[var(--accent-color)]">$0</div>
                </div>
                <div class="bg-[var(--bg-color)] p-4 rounded border border-[var(--accent-color)]">
                  <div class="text-sm text-[var(--text-secondary)] mb-1">Future Total Value</div>
                  <div id="result-total" class="text-2xl font-bold text-[var(--accent-color)]">$0</div>
                </div>
              </div>
              <p class="text-xs text-[var(--text-secondary)] mt-4 text-center">*This is a hypothetical illustration using a fixed rate of return. Real markets fluctuate, and past performance is no guarantee of future results.</p>
            </div>
          </div>

          <p class="mb-4">
            Notice how the "Total Interest Earned" eventually dwarfs the "Total Contributions"? That is the mathematical snowball effect. By year 20 or 30, the portfolio is generating more money in growth than you are actively contributing from your paycheck.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">4. Common Misconceptions & Pitfalls</h2>
          <p class="mb-4">
            If our <a href="/stocks-101">stocks 101</a> curriculum stresses anything, it's that human psychology is the investor's greatest enemy. Here are the three most dangerous myths:
          </p>

          <ul class="space-y-6 mb-8">
            <li class="flex items-start gap-4">
              <div class="mt-1 bg-[var(--card-bg)] text-[var(--text-primary)] p-2 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <strong class="text-lg">Myth 1: "I need to time the market."</strong>
                <p class="text-[var(--text-secondary)] mt-1">Beginners often try to wait for a "dip" or a crash before buying. The reality? Markets hit all-time highs constantly. The data proves conclusively that "time in the market beats timing the market." If you miss just the 10 best days in the market over a 20-year period, your total returns are cut in half.</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="mt-1 bg-[var(--card-bg)] text-[var(--text-primary)] p-2 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <strong class="text-lg">Myth 2: "Stock splits make me richer."</strong>
                <p class="text-[var(--text-secondary)] mt-1">If a stock undergoes a 2-for-1 split, the price is cut in half, but you get twice as many shares. The total value remains exactly the same. It's like cutting a pizza into 8 slices instead of 4; you don't magically have more food. You can verify this math yourself using our <a href="/stock-split-calculator">stock split calculator</a>.</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="mt-1 bg-[var(--card-bg)] text-[var(--text-primary)] p-2 rounded-full">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <strong class="text-lg">Myth 3: "I should check my portfolio every day."</strong>
                <p class="text-[var(--text-secondary)] mt-1">The stock market is a volatile voting machine in the short term, but a weighing machine in the long term. Checking your account daily exposes you to unnecessary stress and the temptation to panic-sell during routine 5% market corrections.</p>
              </div>
            </li>
          </ul>
        </section>

        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">5. The "Pros vs. Cons" Reality Check</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <div class="p-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg">
              <h3 class="text-xl font-bold mb-4 text-[var(--accent-color)] flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                The Advantages
              </h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-[var(--accent-color)] mt-1">•</span>
                  <span><strong>Highest Historical Returns:</strong> Stocks have vastly outperformed bonds, gold, and real estate over the last 100 years.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--accent-color)] mt-1">•</span>
                  <span><strong>Liquidity:</strong> Unlike real estate, you can sell stocks and have cash in your bank account in 48 hours.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--accent-color)] mt-1">•</span>
                  <span><strong>Total Passivity:</strong> Index funds require zero maintenance. Set up automatic monthly transfers and ignore it.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--accent-color)] mt-1">•</span>
                  <span><strong>Inflation Protection:</strong> As prices rise, corporate revenues generally rise with them, making equities a structural hedge against fiat devaluation.</span>
                </li>
              </ul>
            </div>

            <div class="p-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg">
              <h3 class="text-xl font-bold mb-4 text-[var(--text-primary)] flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                The Risks
              </h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-[var(--text-primary)] mt-1">•</span>
                  <span><strong>Volatility:</strong> 20% drops happen frequently. 40%+ drops (like 2008 or 2020) happen once or twice a decade.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--text-primary)] mt-1">•</span>
                  <span><strong>Individual Bankruptcy:</strong> Specific companies (like Enron or Lehman Brothers) can and do go to zero.</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--text-primary)] mt-1">•</span>
                  <span><strong>Psychological Testing:</strong> It takes immense discipline not to sell when the news cycle is screaming that the financial system is collapsing.</span>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">6. What Experienced Investors Know That Beginners Don't</h2>
          <p class="mb-4">
            If you want to move beyond the basics, you have to understand the underlying mechanics that drive market returns. It's not magic; it's math and macroeconomics.
          </p>
          <p class="mb-4">
            <strong>Earnings drive everything.</strong> Over a 1-year period, the stock market is driven almost entirely by shifts in valuation multiples (P/E ratios) triggered by interest rate expectations and emotional sentiment. But over a 10-year period, nearly 100% of a stock's return is correlated to its earnings growth. If a company doubles its profits over a decade, its stock price will almost certainly follow suit, regardless of recessions along the way.
          </p>
          <p class="mb-4">
            <strong>Dividends matter drastically.</strong> Historically, reinvested dividends have accounted for roughly 40% of the total return of the S&P 500. When a company pays you cash just for owning the stock, and you use that cash to buy <em>more</em> stock, you trigger an accelerated compounding loop.
          </p>
          <p class="mb-8">
            <strong>Taxes will kill your returns.</strong> Experienced investors obsess over asset location. They place tax-inefficient assets (like bonds or high-yield dividend stocks) inside tax-advantaged accounts (like a Roth IRA or TFSA in Canada), while leaving tax-efficient broad-market index funds in standard taxable accounts.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="text-3xl font-bold mb-6">The Bottom Line</h2>
          <p class="mb-4 text-xl font-medium">
            Starting to invest is the most mathematically important financial decision you will ever make.
          </p>
          <p class="mb-4">
            Every day your money sits in a checking account yielding 0.01%, it is losing purchasing power to inflation. The stock market is not a casino—it is the engine of global capitalism. By buying a broad index fund, you are betting that human innovation and productivity will continue to increase over the next 50 years. Given the entire history of the human race, that is a bet worth taking.
          </p>
          <p>
            Start small. Automate your deposits. Buy index funds. And most importantly, do not panic when the market goes down. That is the exact blueprint for long-term wealth.
          </p>
        </section>
      </div>

      <div class="lg:col-span-1">
        <div class="sticky top-24 p-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg">
          <h3 class="text-xl font-bold mb-4">Related Guides</h3>
          <ul class="space-y-4">
            <li>
              <a href="/how-to-invest-in-stocks" class="group flex items-center justify-between">
                <span class="group-hover:text-[var(--accent-color)] transition-colors">How to Invest in Stocks</span>
                <span class="text-[var(--text-secondary)]">→</span>
              </a>
            </li>
            <li>
              <a href="/investing-for-beginners" class="group flex items-center justify-between">
                <span class="group-hover:text-[var(--accent-color)] transition-colors">Investing for Beginners</span>
                <span class="text-[var(--text-secondary)]">→</span>
              </a>
            </li>
            <li>
              <a href="/stocks-for-beginners" class="group flex items-center justify-between">
                <span class="group-hover:text-[var(--accent-color)] transition-colors">Stocks for Beginners</span>
                <span class="text-[var(--text-secondary)]">→</span>
              </a>
            </li>
            <li>
              <a href="/stocks-101" class="group flex items-center justify-between">
                <span class="group-hover:text-[var(--accent-color)] transition-colors">Stocks 101 Curriculum</span>
                <span class="text-[var(--text-secondary)]">→</span>
              </a>
            </li>
            <li class="pt-4 border-t border-[var(--border-color)]">
              <a href="/stock-split-calculator" class="group flex items-center justify-between">
                <span class="group-hover:text-[var(--accent-color)] transition-colors">Stock Split Calculator</span>
                <span class="text-[var(--text-secondary)]">→</span>
              </a>
            </li>
            <li>
              <a href="/average-stock-market-return" class="group flex items-center justify-between">
                <span class="group-hover:text-[var(--accent-color)] transition-colors">Average Market Returns</span>
                <span class="text-[var(--text-secondary)]">→</span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</SiteLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const calcBtn = document.getElementById("calc-compound-btn");
    if (calcBtn) {
      calcBtn.addEventListener("click", () => {
        const principalInput = parseFloat(document.getElementById("initial-investment").value) || 0;
        const monthlyInput = parseFloat(document.getElementById("monthly-contribution").value) || 0;
        const yearsInput = parseInt(document.getElementById("investment-years").value) || 0;
        const rateInput = parseFloat(document.getElementById("annual-return").value) || 0;

        const r = rateInput / 100;
        const n = 12;
        const t = yearsInput;

        let futureValuePrincipal = principalInput * Math.pow(1 + r/n, n*t);

        let futureValueContributions = 0;
        if (r > 0) {
          futureValueContributions = monthlyInput * ((Math.pow(1 + r/n, n*t) - 1) / (r/n));
        } else {
          futureValueContributions = monthlyInput * n * t;
        }

        const totalValue = futureValuePrincipal + futureValueContributions;
        const totalContributions = principalInput + (monthlyInput * n * t);
        const totalInterest = totalValue - totalContributions;

        // Fix floating point errors
        const fixedTotal = parseFloat(totalValue.toPrecision(14));
        const finalTotalValue = (Math.abs(fixedTotal - Math.round(fixedTotal)) < 1e-14) ? Math.round(fixedTotal) : fixedTotal;

        const fixedInterest = parseFloat(totalInterest.toPrecision(14));
        const finalTotalInterest = (Math.abs(fixedInterest - Math.round(fixedInterest)) < 1e-14) ? Math.round(fixedInterest) : fixedInterest;

        const fixedContributions = parseFloat(totalContributions.toPrecision(14));
        const finalTotalContributions = (Math.abs(fixedContributions - Math.round(fixedContributions)) < 1e-14) ? Math.round(fixedContributions) : fixedContributions;

        document.getElementById("result-principal").textContent = "$" + finalTotalContributions.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
        document.getElementById("result-interest").textContent = "$" + finalTotalInterest.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
        document.getElementById("result-total").textContent = "$" + finalTotalValue.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});

        document.getElementById("calculator-results").classList.remove("hidden");
      });
    }
  });
</script>
