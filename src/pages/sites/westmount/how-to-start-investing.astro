            </div>
          </div>
          <div class="input-group">
            <label for="monthly-contribution">Monthly Contribution ($)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="monthly-contribution" min="0" value="200" step="50" />
            </div>
          </div>
          <div class="input-group">
            <label for="years-to-grow">Years to Grow</label>
            <input type="range" id="years-to-grow" min="1" max="50" value="20" step="1" />
            <span id="years-display">20 years</span>
          </div>
        </div>

        <div class="calc-results">
          <div class="result-box">
            <h3>Future Value</h3>
            <div class="result-value" id="future-value">$0.00</div>
          </div>
