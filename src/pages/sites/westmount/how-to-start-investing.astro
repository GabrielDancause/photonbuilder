    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    color: var(--accent-color);
    font-size: 1.5rem;
    line-height: 1;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-answer {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid var(--border-color);
    margin-top: 0.5rem;
    padding-top: 1rem;
  }

  @media (max-width: 768px) {
    .calculator-card, .comparison-grid {
      grid-template-columns: 1fr;
    }

    .guide-header h1 {
      font-size: 2rem;
    }
  }
</style>

<script>
  function initCalculator() {
    const initialInput = document.getElementById('initial-investment') as HTMLInputElement;
    const monthlyInput = document.getElementById('monthly-contribution') as HTMLInputElement;
    const yearsInput = document.getElementById('years-to-grow') as HTMLInputElement;
    const yearsDisplay = document.getElementById('years-display');
    const futureValueDisplay = document.getElementById('future-value');
    const totalPrincipalDisplay = document.getElementById('total-principal');
    const totalInterestDisplay = document.getElementById('total-interest');

    if (!initialInput || !monthlyInput || !yearsInput) return;

    const ANNUAL_RATE = 0.08; // 8% hypothetical return

    function calculate() {
      const p = parseFloat(initialInput.value) || 0;
      const pmt = parseFloat(monthlyInput.value) || 0;
      const t = parseFloat(yearsInput.value) || 0;
      const r = ANNUAL_RATE;
      const n = 12; // Monthly compounding

      // Compound interest for principal: A = P(1 + r/n)^(nt)
      const principalFutureValue = p * Math.pow(1 + r/n, n*t);

      // Future value of a series (monthly contributions): FV = PMT * (((1 + r/n)^(nt) - 1) / (r/n))
      const contributionsFutureValue = pmt * ((Math.pow(1 + r/n, n*t) - 1) / (r/n));

      const totalFutureValue = principalFutureValue + contributionsFutureValue;
      const totalPrincipal = p + (pmt * 12 * t);
      const totalInterest = totalFutureValue - totalPrincipal;

      const formatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      });

      if (yearsDisplay) yearsDisplay.textContent = `${t} year${t !== 1 ? 's' : ''}`;
      if (futureValueDisplay) futureValueDisplay.textContent = formatter.format(totalFutureValue);
      if (totalPrincipalDisplay) totalPrincipalDisplay.textContent = formatter.format(totalPrincipal);
      if (totalInterestDisplay) totalInterestDisplay.textContent = formatter.format(totalInterest);
    }

    initialInput.addEventListener('input', calculate);
    monthlyInput.addEventListener('input', calculate);
    yearsInput.addEventListener('input', calculate);

    calculate(); // Initial calculation
  }

  // Support Astro View Transitions
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for initial load if View Transitions aren't active or load differently
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
