    <section class="calculator-section">
      <h2>MSTY Income Calculator</h2>
      <div class="calculator-card">
        <div class="calc-input">
          <label for="investment">Investment Amount ($)</label>
          <input type="number" id="investment" value="10000" min="100" step="100">
        </div>
        
        <div class="calc-results">
          <div class="calc-row">
            <span>Shares (@ $21.00):</span>
            <span id="shares">476</span>
          </div>
          <div class="calc-row">
            <span>Weekly Income:</span>
            <span id="weeklyIncome" class="money">$164.11</span>
          </div>
          <div class="calc-row">
            <span>Monthly Income:</span>
            <span id="monthlyIncome" class="money">$712.48</span>
          </div>
