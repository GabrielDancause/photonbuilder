            <div class="holding-percent">15.6%</div>
          </div>
          <div class="holding-item">
            <div class="holding-name">US Treasury Bill 06/11/2026</div>
            <div class="holding-percent">11.5%</div>
          </div>
          <div class="holding-item">
            <div class="holding-name">US Treasury Bill 09/03/2026</div>
            <div class="holding-percent">8.9%</div>
          </div>
