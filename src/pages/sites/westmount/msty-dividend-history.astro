---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": [
    "Article",
    "FAQPage"
  ],
  "headline": "MSTY Dividend History: Complete Distribution Analysis & Real Data",
  "description": "Complete MSTY dividend history with all distributions from inception to 2026. Weekly payouts, NAV erosion analysis, and income calculator.",
  "author": {
    "@type": "Organization", 
    "name": "Westmount Fundamentals"
  },
  "datePublished": "2026-03-28",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is MSTY's dividend yield?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MSTY's current annualized yield is approximately 67.6% based on recent weekly distributions of $0.34-0.44. However, most distributions are return of capital (90-100% ROC), not true income."
      }
    },
    {
      "@type": "Question", 
      "name": "How often does MSTY pay dividends?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MSTY switched to weekly distributions in 2026, paying every Tuesday. Previously it paid monthly from inception in February 2024 through 2025."
      }
    },
    {
      "@type": "Question",
      "name": "Is MSTY a good investment?", 
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MSTY is extremely risky due to NAV erosion. While it pays high distributions, the fund has declined from ~$25 to $21 since inception despite +67% NAV return, as distributions are mostly return of capital."
      }
    },
    {
      "@type": "Question",
      "name": "What is return of capital in MSTY?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Return of capital (ROC) means distributions come from your invested principal, not earnings. Recent MSTY distributions show 90-100% ROC, meaning you're essentially getting your own money back."
      }
    },
    {
      "@type": "Question",
      "name": "Why is MSTY's NAV declining?",
      "acceptedAnswer": {
        "@type": "Answer", 
        "text": "MSTY's synthetic covered call strategy caps upside while exposing to full downside risk. The high distributions come at the cost of principal erosion over time."
      }
    }
  ]
};

export const meta = {
  title: "MSTY Dividend History: Complete Distribution Analysis & Real Data",
  description: "Complete MSTY dividend history with all distributions from inception to 2026. Weekly payouts, NAV erosion analysis, and income calculator.",
  category: "tool",
  published: "2026-03-28",
};
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/msty-dividend-history" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>MSTY Dividend History: Complete Distribution Analysis</h1>
      <p class="subtitle">Real data from YieldMax MSTR Option Income Strategy ETF - Weekly distributions, NAV erosion analysis, and income calculator</p>
    </div>

    <!-- Key Stats Dashboard -->
    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Current Weekly Distribution</div>
        <div class="stat-value">$0.3448</div>
        <div class="stat-change">Latest: 03/25/2026</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Annualized Yield</div>
        <div class="stat-value">67.6%</div>
