          <p>Analyze profit and loss for covered call and option strategies</p>
        </a>
      </div>
    </section>

    <!-- Enhanced FAQ Section -->
    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>What is MSTY's dividend yield?</summary>
        <p>MSTY's current annualized yield is approximately 67.6% based on recent weekly distributions averaging $0.34-0.44. However, investors must understand that most distributions (90-100%) are classified as return of capital (ROC), not true income from earnings.</p>
      </details>

      <details>
        <summary>How often does MSTY pay dividends?</summary>
        <p>MSTY switched to weekly distributions in 2026, typically paying every Tuesday. From inception in February 2024 through 2025, it paid monthly. This change to weekly payments provides more consistent cash flow but doesn't change the underlying risks.</p>
      </details>

      <details>
        <summary>Is MSTY a good investment?</summary>
        <p>MSTY is an extremely risky investment suitable only for sophisticated investors who understand covered call strategies. While it pays high distributions, the fund experiences NAV erosion over time due to its asymmetric risk profile. The high yields come at the cost of principal preservation.</p>
      </details>

      <details>
        <summary>What is return of capital in MSTY?</summary>
        <p>Return of capital (ROC) means distributions come from your invested principal rather than earnings or profits. Recent MSTY distributions show 90-100% ROC, meaning you're essentially receiving your own invested money back, which reduces the fund's NAV over time.</p>
      </details>

      <details>
        <summary>Why is MSTY's NAV declining?</summary>
        <p>MSTY uses a synthetic covered call strategy that caps upside potential while exposing investors to full downside risk. When the underlying MSTR stock rises, gains are limited by the sold call options. When it falls, the fund absorbs the full loss. This asymmetric payoff profile inevitably leads to NAV erosion over multiple market cycles.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    // Distribution data
    const distributionData = [
      // 2026 Weekly
      { date: '2026-03-25', amount: 0.3448, year: 2026, roc: 14.41 },
      { date: '2026-03-18', amount: 0.4383, year: 2026, roc: 98.82 },
      { date: '2026-03-11', amount: 0.3847, year: 2026, roc: 98.58 },
      { date: '2026-03-04', amount: 0.3500, year: 2026, roc: 14.65 },
      { date: '2026-02-25', amount: 0.3017, year: 2026, roc: 100.0 },
      { date: '2026-02-18', amount: 0.3607, year: 2026, roc: 97.91 },
      { date: '2026-02-11', amount: 0.2980, year: 2026, roc: 98.59 },
      { date: '2026-02-04', amount: 0.3083, year: 2026, roc: 93.12 },
      { date: '2026-01-28', amount: 0.3725, year: 2026, roc: 95.0 },
      { date: '2026-01-21', amount: 0.4300, year: 2026, roc: 92.5 },
      { date: '2026-01-14', amount: 0.4137, year: 2026, roc: 88.7 },
      { date: '2026-01-07', amount: 0.3741, year: 2026, roc: 91.2 },
      
      // 2025 Monthly  
      { date: '2025-12-31', amount: 0.4091, year: 2025, roc: 85.0 },
      { date: '2025-12-24', amount: 0.5106, year: 2025, roc: 78.3 },
      { date: '2025-12-17', amount: 0.3869, year: 2025, roc: 92.1 },
      { date: '2025-12-10', amount: 0.5859, year: 2025, roc: 67.4 },
      { date: '2025-12-03', amount: 0.1388, year: 2025, roc: 100.0 },
      { date: '2025-11-26', amount: 0.1352, year: 2025, roc: 100.0 },
      { date: '2025-11-19', amount: 0.1475, year: 2025, roc: 100.0 },
      { date: '2025-11-12', amount: 0.1620, year: 2025, roc: 100.0 },
      { date: '2025-11-05', amount: 0.1688, year: 2025, roc: 100.0 },
      { date: '2025-10-29', amount: 0.1924, year: 2025, roc: 98.5 },
      { date: '2025-10-22', amount: 0.2122, year: 2025, roc: 95.2 },
      { date: '2025-10-15', amount: 0.6074, year: 2025, roc: 72.1 },
      { date: '2025-09-24', amount: 1.0105, year: 2025, roc: 45.3 },
      { date: '2025-08-27', amount: 1.0899, year: 2025, roc: 42.1 },
      { date: '2025-07-30', amount: 1.1835, year: 2025, roc: 38.7 },
      { date: '2025-07-02', amount: 1.2382, year: 2025, roc: 35.9 },
      { date: '2025-06-04', amount: 1.4707, year: 2025, roc: 28.4 },
      { date: '2025-05-07', amount: 2.3734, year: 2025, roc: 15.2 },
      { date: '2025-04-09', amount: 1.3356, year: 2025, roc: 32.1 },
      { date: '2025-03-12', amount: 1.3775, year: 2025, roc: 30.5 },
      { date: '2025-02-12', amount: 2.0216, year: 2025, roc: 18.7 },
      { date: '2025-01-15', amount: 2.2792, year: 2025, roc: 16.3 },
      
      // 2024 Monthly
      { date: '2024-12-18', amount: 3.0821, year: 2024, roc: 8.5 },
      { date: '2024-11-20', amount: 4.4213, year: 2024, roc: 5.2 },
      { date: '2024-10-23', amount: 4.1981, year: 2024, roc: 6.1 },
      { date: '2024-09-05', amount: 1.8541, year: 2024, roc: 22.3 },
      { date: '2024-08-06', amount: 1.9405, year: 2024, roc: 20.8 },
      { date: '2024-07-03', amount: 2.3320, year: 2024, roc: 16.9 },
      { date: '2024-06-05', amount: 3.0300, year: 2024, roc: 9.1 },
      { date: '2024-05-03', amount: 2.5239, year: 2024, roc: 14.7 },
      { date: '2024-04-03', amount: 4.1286, year: 2024, roc: 6.3 }
    ];

    // Initialize page
    document.addEventListener('DOMContentLoaded', function() {
      initializeDistributionTable();
      initializeDistributionChart();
      initializeHoldingsChart();
      initializeCalculator();
      setupYearFilter();
    });

    function initializeDistributionTable() {
      updateTable('all');
    }

    function updateTable(year) {
      const tbody = document.getElementById('distributionTableBody');
      const filteredData = year === 'all' ? distributionData : distributionData.filter(d => d.year == year);
      
      tbody.innerHTML = filteredData.map(distribution => `
        <tr>
          <td>${distribution.date}</td>
          <td class="amount ${getAmountClass(distribution.amount)}">$${distribution.amount.toFixed(4)}</td>
          <td>${distribution.date}</td>
          <td class="roc">${distribution.roc.toFixed(1)}%</td>
        </tr>
      `).join('');
    }

    function getAmountClass(amount) {
      if (amount >= 2.0) return 'high';
      if (amount >= 0.5) return 'medium';
      return 'low';
    }

    function setupYearFilter() {
      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          updateTable(this.dataset.year);
        });
      });
    }

    function initializeDistributionChart() {
      const ctx = document.getElementById('distributionChart').getContext('2d');
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: distributionData.map(d => d.date.slice(0, 7)),
          datasets: [{
            label: 'Distribution Amount ($)',
            data: distributionData.map(d => d.amount),
            backgroundColor: distributionData.map(d => d.amount >= 2.0 ? '#48bb78' : d.amount >= 0.5 ? '#f59e0b' : '#ef4444'),
            borderColor: '#152040',
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          plugins: {
            title: {
              display: true,
              text: 'MSTY Distribution History',
              color: '#ffffff'
            },
            legend: {
              labels: {
                color: '#ffffff'
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                color: '#ffffff',
                callback: function(value) {
                  return '$' + value.toFixed(2);
                }
              },
              grid: {
                color: '#152040'
              }
            },
            x: {
              ticks: {
                color: '#ffffff'
              },
              grid: {
                color: '#152040'
              }
            }
          }
        }
      });
    }

    function initializeHoldingsChart() {
      const ctx = document.getElementById('holdingsChart').getContext('2d');
      new Chart(ctx, {
        type: 'pie',
        data: {
          labels: ['Cash & Other', 'Treasury Bills', 'MSTR Options'],
          datasets: [{
            data: [47.0, 52.4, 0.6],
            backgroundColor: ['#4a8fe7', '#48bb78', '#f59e0b'],
            borderColor: '#152040',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          plugins: {
            title: {
              display: true,
              text: 'Holdings Breakdown',
              color: '#ffffff'
            },
            legend: {
              labels: {
                color: '#ffffff'
              }
            }
          }
        }
      });
    }

    function initializeCalculator() {
      const investmentInput = document.getElementById('investment');
      investmentInput.addEventListener('input', updateCalculator);
      updateCalculator();
    }

    function updateCalculator() {
      const investment = parseFloat(document.getElementById('investment').value) || 0;
      const price = 21.00;
      const weeklyDividend = 0.3448;
      
      const shares = Math.floor(investment / price);
      const weeklyIncome = shares * weeklyDividend;
      const monthlyIncome = weeklyIncome * 4.33;
      const annualIncome = weeklyIncome * 52;
      
      document.getElementById('shares').textContent = shares.toLocaleString();
      document.getElementById('weeklyIncome').textContent = '$' + weeklyIncome.toFixed(2);
      document.getElementById('monthlyIncome').textContent = '$' + monthlyIncome.toFixed(2);
      document.getElementById('annualIncome').textContent = '$' + annualIncome.toFixed(2);
      
      // Scenarios based on investment amount
      const currentYield = investment * 0.676;
      document.getElementById('currentScenario').textContent = '$' + currentYield.toFixed(0);
      document.getElementById('conservativeScenario').textContent = '$' + (currentYield * 0.5).toFixed(0);
      document.getElementById('optimisticScenario').textContent = '$' + (currentYield * 1.5).toFixed(0);
    }
  </script>

  <style>
    /* Global Styles */
    .page-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
      background: #060a12;
      color: #ffffff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    /* Hero Section */
    .hero {
      text-align: center;
      padding: 3rem 0 2rem;
      border-bottom: 1px solid #152040;
      margin-bottom: 2rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
      color: #ffffff;
    }

    .subtitle {
      color: #8fa2b7;
      font-size: 1.2rem;
      line-height: 1.4;
    }

