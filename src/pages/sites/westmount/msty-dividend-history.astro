    </section>

    <!-- YieldMax ETF Comparison -->
    <section class="comparison-section">
      <h2>YieldMax ETF Comparison</h2>
      <div class="comparison-table">
        <table>
          <thead>
            <tr>
              <th>ETF</th>
              <th>Strategy</th>
              <th>Yield</th>
