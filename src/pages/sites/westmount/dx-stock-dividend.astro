  title: "DX Stock Dividend Analysis: Yield, Safety, and Payout History",
  description: "Is Dynex Capital's massive double-digit yield too good to be true? We break down the mechanics of the DX stock dividend and the hidden risks investors often ignore.",
  category: "study",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How often does DX stock pay dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dynex Capital (DX) pays dividends on a monthly basis. This monthly payout schedule makes it an attractive option for income-focused investors looking for regular cash flow, rather than waiting for traditional quarterly payments."
          }
        },
        {
          "@type": "Question",
          "name": "Is the DX stock dividend safe?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The safety of the DX dividend depends heavily on macroeconomic factors, specifically interest rates and the yield curve. As a mortgage REIT, its profitability is sensitive to interest rate volatility. Historically, mREITs are known for fluctuating dividend payments, so it carries higher risk than traditional blue-chip dividends."
          }
        },
        {
          "@type": "Question",
          "name": "Why is the DX dividend yield so high?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DX's high yield is typical for mortgage REITs (mREITs). By law, REITs must distribute at least 90% of their taxable income to shareholders. Furthermore, the high yield often reflects the market pricing in the inherent risks associated with their leveraged mortgage-backed securities portfolio."
          }
        },
        {
          "@type": "Question",
          "name": "Does DX stock issue a K-1 tax form?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, Dynex Capital (DX) is structured as a Real Estate Investment Trust (REIT), not a Master Limited Partnership (MLP). Therefore, it issues a standard Form 1099-DIV for tax reporting purposes, not a Schedule K-1."
          }
        },
        {
          "@type": "Question",
          "name": "What exactly does Dynex Capital (DX) do to generate income?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dynex Capital is a mortgage real estate investment trust (mREIT). It generates income not by owning physical real estate, but by investing in mortgage-backed securities (MBS) on a leveraged basis. It profits from the spread between the interest it earns on those mortgages and the cost of the short-term debt it uses to finance them."
