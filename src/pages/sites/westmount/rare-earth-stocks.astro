  category: "guide",
  published: "2026-03-15",
};

const faqQuestions = [
  {
    question: "What are rare earth stocks?",
    answer: "Rare earth stocks represent shares in companies involved in the mining, processing, or refining of rare earth elements (REEs)—a set of 17 metals crucial for modern technologies like smartphones, electric vehicles, and renewable energy systems."
  },
  {
    question: "Why are rare earth elements important?",
    answer: "These elements are essential components in high-tech devices. For example, they are used to create the powerful permanent magnets found in electric vehicle motors and wind turbine generators, making them vital for the global transition to clean energy."
  },
  {
    question: "Are rare earth elements actually rare?",
    answer: "No, despite their name, rare earth elements are relatively abundant in the Earth's crust. They are called 'rare' because they are rarely found in concentrated deposits, making the mining and extraction process difficult, expensive, and environmentally intensive."
  },
  {
    question: "Where are most rare earth elements produced?",
