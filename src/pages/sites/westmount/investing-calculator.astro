---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Investing Calculator",
  description: "Discover the true potential of your investments. Our powerful calculator reveals how small changes today create massive wealth tomorrow...",
  category: "tool",
  published: "2026-03-17"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Westmount Fundamentals"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much should I invest each month to retire comfortably?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The amount you should invest depends on your current age, target retirement age, expected lifestyle costs, and existing savings. As a general rule of thumb, professionals often recommend investing 15% to 20% of your gross income."
        }
      },
      {
        "@type": "Question",
        "name": "What is a realistic annual return for an investing calculator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Historically, the U.S. stock market has returned an average of 9% to 10% annually before inflation. For long-term planning, conservative estimates often use 6% to 7% to account for inflation (real return) and potential periods of underperformance."
        }
      },
      {
        "@type": "Question",
        "name": "How does inflation affect my investment returns?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Inflation reduces the purchasing power of your money over time. If your portfolio grows by 8% but inflation is 3%, your 'real' or inflation-adjusted return is approximately 5%. When forecasting future wealth, it's crucial to distinguish between nominal and real returns."
        }
      },
      {
        "@type": "Question",
        "name": "Should I invest a lump sum or use dollar-cost averaging?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Statistically, investing a lump sum immediately tends to outperform dollar-cost averaging (investing smaller amounts over time) about two-thirds of the time, because markets generally go up. However, dollar-cost averaging can reduce the psychological risk of investing right before a market drop."
        }
      },
      {
        "@type": "Question",
        "name": "Why is starting early more important than the amount invested?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Starting early allows compound interest to work its magic over a longer period. An investor who starts at 25 and invests a small amount monthly will often accumulate more wealth by 65 than someone who starts at 40 and invests significantly more per month."
        }
      }
    ]
  }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/investing-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Investing Calculator</h1>
      <p class="subtitle">Forecast your portfolio growth and optimize your investment strategy.</p>
    </div>


    <div class="calculator-container">
      <div class="input-group">
        <label for="initial-investment">Starting Amount ($)</label>
        <input type="number" id="initial-investment" value="10000" min="0" step="100" />
      </div>

      <div class="input-group">
        <label for="monthly-contribution">Monthly Contribution ($)</label>
        <input type="number" id="monthly-contribution" value="500" min="0" step="50" />
      </div>

      <div class="input-group">
        <label for="annual-return">Estimated Annual Return (%)</label>
        <input type="number" id="annual-return" value="7" min="0" max="100" step="0.1" />
      </div>

      <div class="input-group">
        <label for="years-to-grow">Years to Grow</label>
        <input type="number" id="years-to-grow" value="20" min="1" max="100" step="1" />
      </div>

      <div class="results-grid">
        <div class="result-card primary-result">
          <h3>Future Portfolio Value</h3>
          <div class="result-value" id="future-value">$0.00</div>
        </div>

        <div class="secondary-results">
          <div class="sub-result">
            <h4>Total Principal (Your Money)</h4>
            <div id="total-principal" class="sub-result-value">$0.00</div>
          </div>
          <div class="sub-result">
            <h4>Total Interest (Your Earnings)</h4>
            <div id="total-interest" class="sub-result-value">$0.00</div>
          </div>
        </div>
      </div>

      <div id="error-message" class="error-text" style="display: none;">Please enter valid positive numbers.</div>

      <div class="comparison-section" style="margin-top: 2.5rem; display: none;" id="comparison-section">
        <h3 style="margin-bottom: 1rem; color: var(--text-primary);">Growth Comparison</h3>
        <div class="table-responsive">
          <table class="comparison-table" id="comparison-table">
            <thead>
              <tr>
                <th>Year</th>
                <th>Total Contributed</th>
                <th>Without Investing</th>
                <th>With Investing</th>
                <th>Difference</th>
              </tr>
            </thead>
            <tbody>
              <!-- Populated by JS -->
            </tbody>
          </table>
        </div>
      </div>

    </div>



    <div class="content-section" style="margin-top: 4rem; line-height: 1.7;">
      <h2>The Mechanics of Wealth Creation: Understanding Investment Growth</h2>
      <p>
        Investing is often surrounded by complex jargon, charts, and seemingly unpredictable market movements. However, at its core, building wealth through investing relies on a very simple mathematical principle: compounding. An <strong>investing calculator</strong> is an essential tool for visualizing this principle and translating abstract numbers into a concrete financial roadmap.
      </p>
      <p>
        Whether you are planning for retirement, saving for a major purchase, or aiming to achieve financial independence, understanding how your money grows over time is critical. This guide breaks down the mechanics of investment growth, the mathematical formulas behind our calculator, and practical strategies used by professionals to optimize portfolio performance.
      </p>

      <h3>The Foundation: Compound Interest</h3>
      <p>
        Albert Einstein famously (and apocryphally) called compound interest the "eighth wonder of the world," stating, "He who understands it, earns it; he who doesn't, pays it." While simple interest only pays you on your initial deposit (your principal), compound interest pays you on your principal <em>and</em> on the accumulated interest from previous periods.
      </p>
      <p>
        In the context of investing, we often refer to "compound returns" rather than compound interest, as stock market returns fluctuate rather than providing a fixed interest rate. However, the mathematical mechanism is identical. Over long periods, compounding causes your wealth to grow exponentially, not linearly. The initial years of an investment journey might seem slow, but as the base of your wealth grows, the absolute dollar returns generated each year accelerate dramatically.
      </p>

      <h3>The Mathematical Formula</h3>
      <p>
        To truly grasp how an investing calculator works, it helps to look at the underlying math. The calculation for the future value of an investment involves two distinct components: the growth of a lump sum (your initial investment) and the growth of an annuity (your regular monthly contributions).
      </p>

      <div class="highlight-box" style="background: var(--card-bg); border: 1px solid var(--border-color); border-left: 4px solid var(--accent-color); padding: 1.5rem; border-radius: 8px; margin: 2rem 0;">
        <h4 style="margin-top: 0;">1. Future Value of a Lump Sum</h4>
        <p style="font-family: var(--font-mono); font-size: 1.1rem; background: var(--bg-color); padding: 1rem; border-radius: 6px;">FV = P × (1 + r/n)<sup>(n×t)</sup></p>
        <ul style="margin-bottom: 0;">
          <li><strong>FV</strong> = Future Value</li>
          <li><strong>P</strong> = Principal (Initial Investment)</li>
          <li><strong>r</strong> = Annual interest rate (in decimal form)</li>
          <li><strong>n</strong> = Number of times interest is compounded per year</li>
          <li><strong>t</strong> = Time in years</li>
        </ul>
      </div>

      <div class="highlight-box" style="background: var(--card-bg); border: 1px solid var(--border-color); border-left: 4px solid var(--accent-color); padding: 1.5rem; border-radius: 8px; margin: 2rem 0;">
        <h4 style="margin-top: 0;">2. Future Value of Regular Contributions (Annuity)</h4>
        <p style="font-family: var(--font-mono); font-size: 1.1rem; background: var(--bg-color); padding: 1rem; border-radius: 6px;">FVA = PMT × [ ((1 + r/n)<sup>(n×t)</sup> - 1) / (r/n) ]</p>
        <ul style="margin-bottom: 0;">
          <li><strong>FVA</strong> = Future Value of an Annuity</li>
          <li><strong>PMT</strong> = Regular Payment (Monthly Contribution)</li>
          <li><strong>r, n, t</strong> = Same as above</li>
        </ul>
      </div>

      <p>
        Our calculator adds these two components together. For instance, if you start with $10,000, add $500 monthly, and assume a 7% annual return over 20 years (compounded monthly):
      </p>
      <ul>
        <li>The $10,000 initial investment grows to approximately <strong>$40,387</strong>.</li>
        <li>The $500 monthly contributions grow to approximately <strong>$260,463</strong>.</li>
        <li><strong>Total Portfolio Value = $300,850</strong></li>
      </ul>
      <p>
        Notice that your total out-of-pocket contribution is $130,000 ($10,000 + ($500 × 12 months × 20 years)). The remaining $170,850 is pure investment earnings. That is the power of compounding. If you want to explore different scenarios, you can use our <a href="/investment-calculator">investment calculator</a> to see how different variables affect your outcome.
      </p>

      <h3>Real-World Context: When to Use This Calculator</h3>
      <p>
        An investing calculator is not just a theoretical tool; it has profound practical applications in real-world financial planning:
      </p>
      <ol>
        <li><strong>Retirement Planning:</strong> By estimating your target retirement number and your current age, you can reverse-engineer how much you need to save each month. If the required monthly contribution is too high, you must either increase your income, reduce your expenses, or plan to work longer. You might also want to look at a dedicated <a href="/investment-planner">investment planner</a> for a more comprehensive view.</li>
        <li><strong>Evaluating Financial Independence (FIRE):</strong> The Financial Independence, Retire Early movement relies heavily on calculating when your investment portfolio can generate enough passive income to cover your living expenses. Tools like our <a href="/roi-calculator">ROI calculator</a> can help assess the viability of different income-generating assets.</li>
        <li><strong>Assessing the Cost of Delay:</strong> One of the most powerful uses of this calculator is showing the cost of waiting to invest. Delaying investing by just five years can drastically reduce your final portfolio value due to the loss of compounding time.</li>
        <li><strong>Visualizing the Impact of Fees:</strong> A 1% management fee might sound small, but when applied to a compounding portfolio over 30 years, it can consume hundreds of thousands of dollars of your potential wealth. Changing the "Estimated Annual Return" by 1% in the calculator dramatically illustrates this point.</li>
      </ol>

      <h3>Common Mistakes When Projecting Investment Returns</h3>
      <p>
        While calculators are mathematically precise, the inputs you provide are often estimates. Failing to account for real-world friction can lead to wildly inaccurate expectations.
      </p>

      <h4>1. Ignoring Inflation (Nominal vs. Real Returns)</h4>
      <p>
        If a calculator shows you will have $2 million in 30 years, that sounds fantastic. However, due to inflation, $2 million in 2056 will not buy the same amount of goods and services as $2 million does today. Historically, inflation averages around 2-3% annually. Therefore, if you expect an 8% nominal return from the stock market, you should use a 5% or 6% <strong>real return</strong> in your calculator to understand your future purchasing power in today's dollars.
      </p>

      <h3>More Details on Calculating Your Real Return</h3>
      <p>
        The calculations we've shown above represent the <strong>nominal return</strong> on your investment—the actual dollar amount your portfolio generates before factoring in the silent tax of inflation. However, your true purchasing power is dictated by your <strong>real return</strong>. If you intend to use this investing calculator to plan for decades into the future, understanding this distinction is perhaps the most important lesson an investor can learn. Over a span of 30 or 40 years, inflation acts as an anchor on your portfolio's value, subtly eroding the amount of goods and services your money can buy. A million dollars today is not the same as a million dollars in 2056.
      </p>
      <p>
        To put this into perspective, if your nominal portfolio return is 8% over the next year, but the inflation rate is 3%, your real, inflation-adjusted return is approximately 5%. To properly calculate your future wealth, many professionals recommend inputting a lower "Estimated Annual Return" into an investing calculator. Instead of using the historical stock market average of 9% or 10%, you might use 6% or 7%. This effectively builds inflation into your calculation, outputting a future portfolio value that is stated in <em>today's dollars</em>. This simple adjustment ensures that the massive numbers you see on the screen align with your current understanding of what things cost, drastically reducing the chance of underfunding your retirement.
      </p>
      <p>
        Furthermore, when reviewing the before-and-after table comparisons, pay close attention to the sheer volume of "Total Interest" generated in the later years of your investment timeline. The first decade of investing often feels like a slog, where the majority of your portfolio's growth is simply the cash you are contributing. But as you cross the threshold into the second and third decades, the math flips. The earnings generated by your previous earnings start to dwarf your monthly contributions. This compounding snowball effect is why time in the market consistently beats timing the market, and why starting early is the ultimate cheat code for building lasting wealth. Whether you use a standard spreadsheet or our investing calculator to track your progress, the goal remains the same: harness time, respect inflation, and let compounding do the heavy lifting.
      </p>


      <h4>2. Assuming Linear Returns</h4>
      <p>
        The stock market does not return a smooth 7% every year. It might return 20% one year, lose 15% the next, and gain 5% the year after. An investing calculator assumes a fixed, linear return rate. While this is necessary for long-term averages, investors must be psychologically prepared for volatility. A portfolio that averages 7% over 20 years will experience terrifying drawdowns along the way. If you panic and sell during a downturn, your actual returns will deviate significantly from your calculator projections. Tools like a <a href="/average-stock-market-return">stock market return analyzer</a> can help you understand historical volatility.
      </p>

      <h4>3. Overestimating Returns</h4>
      <p>
        During bull markets, it is common for new investors to assume historical anomalies are the new normal. Projecting a 15% or 20% annual return over a multi-decade timeframe is highly unrealistic and will lead to severely underfunded retirement plans. It is safer to use conservative estimates (e.g., 5% to 7% real return) based on century-long market averages. If the market outperforms your conservative estimates, you will simply have a larger safety margin. If you want to see how a specific approach like Dave Ramsey's compares to historical averages, check out our <a href="/ramsey-investment-calculator">Ramsey investment calculator</a>.
      </p>

      <h3>Practical Rules of Thumb for Investors</h3>
      <p>
        Professionals use several heuristics alongside formal calculations to guide investment strategy:
      </p>
      <ul>
        <li><strong>The Rule of 72:</strong> Divide 72 by your expected annual rate of return to estimate how many years it will take for your investment to double. For example, at a 7% return, your money will double approximately every 10.3 years (72 / 7 = 10.28).</li>
        <li><strong>The 4% Rule:</strong> A rule of thumb for retirement withdrawal stating you can safely withdraw 4% of your initial portfolio value annually, adjusted for inflation, without exhausting your funds over a 30-year period. This helps you determine your target portfolio size. If you need $60,000 a year, you need approximately $1.5 million invested ($60,000 / 0.04).</li>
        <li><strong>Pay Yourself First:</strong> The easiest way to ensure you hit your monthly contribution goals is to automate them. Set up automatic transfers from your checking account to your brokerage account on the day you get paid. If you don't see the money, you can't spend it.</li>
      </ul>

      <h3>Maximizing Your Investment Growth</h3>
      <p>
        To get the most out of your investing journey, focus on the variables you can control. You cannot control what the stock market does in any given year, but you can control your savings rate, your investment timeline, and the fees you pay.
      </p>
      <p>
        Start by minimizing investment fees by utilizing low-cost index funds or ETFs. Even a difference of 0.5% in expense ratios can translate to tens of thousands of dollars over a lifetime. Furthermore, understand the tax implications of your investments. Utilizing tax-advantaged accounts like IRAs or 401(k)s can shield your gains from immediate taxation, allowing a larger base of capital to compound over time.
      </p>
      <p>
        Finally, if you are investing in individual companies, understand events that can affect share count and price, such as stock splits. You can use a <a href="/stock-split-calculator">stock split calculator</a> to understand how these corporate actions impact your holdings. Ultimately, the key to successful investing is consistency, patience, and a long-term perspective.
      </p>
    </div>

    <section class="faq-section" style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border-color);">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item" style="margin-bottom: 1.5rem; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;">
        <h3 style="margin-top: 0; font-size: 1.15rem;">How much should I invest each month to retire comfortably?</h3>
        <p style="margin-bottom: 0; color: var(--text-secondary); line-height: 1.6;">The amount you should invest depends on your current age, target retirement age, expected lifestyle costs, and existing savings. As a general rule of thumb, professionals often recommend investing 15% to 20% of your gross income.</p>
      </div>

      <div class="faq-item" style="margin-bottom: 1.5rem; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;">
        <h3 style="margin-top: 0; font-size: 1.15rem;">What is a realistic annual return for an investing calculator?</h3>
        <p style="margin-bottom: 0; color: var(--text-secondary); line-height: 1.6;">Historically, the U.S. stock market has returned an average of 9% to 10% annually before inflation. For long-term planning, conservative estimates often use 6% to 7% to account for inflation (real return) and potential periods of underperformance.</p>
      </div>

      <div class="faq-item" style="margin-bottom: 1.5rem; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;">
        <h3 style="margin-top: 0; font-size: 1.15rem;">How does inflation affect my investment returns?</h3>
        <p style="margin-bottom: 0; color: var(--text-secondary); line-height: 1.6;">Inflation reduces the purchasing power of your money over time. If your portfolio grows by 8% but inflation is 3%, your 'real' or inflation-adjusted return is approximately 5%. When forecasting future wealth, it's crucial to distinguish between nominal and real returns.</p>
      </div>

      <div class="faq-item" style="margin-bottom: 1.5rem; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;">
        <h3 style="margin-top: 0; font-size: 1.15rem;">Should I invest a lump sum or use dollar-cost averaging?</h3>
        <p style="margin-bottom: 0; color: var(--text-secondary); line-height: 1.6;">Statistically, investing a lump sum immediately tends to outperform dollar-cost averaging (investing smaller amounts over time) about two-thirds of the time, because markets generally go up. However, dollar-cost averaging can reduce the psychological risk of investing right before a market drop.</p>
      </div>

      <div class="faq-item" style="margin-bottom: 1.5rem; padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;">
        <h3 style="margin-top: 0; font-size: 1.15rem;">Why is starting early more important than the amount invested?</h3>
        <p style="margin-bottom: 0; color: var(--text-secondary); line-height: 1.6;">Starting early allows compound interest to work its magic over a longer period. An investor who starts at 25 and invests a small amount monthly will often accumulate more wealth by 65 than someone who starts at 40 and invests significantly more per month.</p>
      </div>
    </section>

  </div>

  <script is:inline>
    function formatCurrency(value) {
      if (isNaN(value)) return '$0.00';
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      }).format(value);
    }

    function calculateInvestment() {
      const initialInput = document.getElementById('initial-investment');
      const monthlyInput = document.getElementById('monthly-contribution');
      const returnInput = document.getElementById('annual-return');
      const yearsInput = document.getElementById('years-to-grow');
      const errorMsg = document.getElementById('error-message');

      const initial = parseFloat(initialInput.value) || 0;
      const monthly = parseFloat(monthlyInput.value) || 0;
      const rate = parseFloat(returnInput.value) || 0;
      const years = parseFloat(yearsInput.value) || 0;

      if (initial < 0 || monthly < 0 || rate < 0 || years <= 0 || years > 150) {
        errorMsg.style.display = 'block';
        document.getElementById('future-value').textContent = '$0';
        document.getElementById('total-principal').textContent = '$0';
        document.getElementById('total-interest').textContent = '$0';
        return;
      }

      errorMsg.style.display = 'none';

      const months = years * 12;
      const monthlyRate = rate / 100 / 12;

      let futureValue = initial;

      if (monthlyRate > 0) {
          // Future value of lump sum
          futureValue = initial * Math.pow(1 + monthlyRate, months);

          // Future value of monthly contributions
          if (monthly > 0) {
              const futureValueOfContributions = monthly * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);
              // Assuming contributions are made at the end of the month
              futureValue += futureValueOfContributions;
          }
      } else {
          // 0% return
          futureValue = initial + (monthly * months);
      }

// Handle very large numbers safely
      if (futureValue > Number.MAX_SAFE_INTEGER) {
        futureValue = Number.MAX_SAFE_INTEGER;
      }

      // To avoid floating-point precision errors, round appropriately
      const fixedValue = parseFloat(futureValue.toPrecision(14));
      let finalValue = fixedValue;
      if (Math.abs(fixedValue - Math.round(fixedValue)) < 1e-14) {
          finalValue = Math.round(fixedValue);
      }

      const totalPrincipal = initial + (monthly * months);
      const totalInterest = Math.max(0, finalValue - totalPrincipal);

      document.getElementById('future-value').textContent = formatCurrency(finalValue);
      document.getElementById('total-principal').textContent = formatCurrency(totalPrincipal);
      document.getElementById('total-interest').textContent = formatCurrency(totalInterest);

      // Generate comparison table
      const tbody = document.querySelector('#comparison-table tbody');
      if (tbody) {
          tbody.innerHTML = '';
          document.getElementById('comparison-section').style.display = 'block';

          let milestoneYears = new Set([1, 5, 10, 15, 20, 25, 30]);
          milestoneYears.add(years);
          const milestones = Array.from(milestoneYears).filter(v => v <= years && v > 0).sort((a,b) => a - b);

          milestones.forEach(year => {
            const mMonths = year * 12;
            let mFutureValue = initial;
            if (monthlyRate > 0) {
                mFutureValue = initial * Math.pow(1 + monthlyRate, mMonths);
                if (monthly > 0) {
                    mFutureValue += monthly * ((Math.pow(1 + monthlyRate, mMonths) - 1) / monthlyRate);
                }
            } else {
                mFutureValue = initial + (monthly * mMonths);
            }

            const mContributed = initial + (monthly * mMonths);
            const withoutInvesting = mContributed;
            const difference = Math.max(0, mFutureValue - withoutInvesting);

            const tr = document.createElement('tr');

            const td1 = document.createElement('td');
            td1.textContent = 'Year ' + year;

            const td2 = document.createElement('td');
            td2.textContent = formatCurrency(mContributed);

            const td3 = document.createElement('td');
            td3.textContent = formatCurrency(withoutInvesting);

            const td4 = document.createElement('td');
            td4.style.color = 'var(--accent-color)';
            td4.style.fontWeight = 'bold';
            td4.textContent = formatCurrency(mFutureValue);

            const td5 = document.createElement('td');
            td5.style.color = '#10b981';
            td5.textContent = '+' + formatCurrency(difference);

            tr.appendChild(td1);
            tr.appendChild(td2);
            tr.appendChild(td3);
            tr.appendChild(td4);
            tr.appendChild(td5);
            tbody.appendChild(tr);
          });
      }

      // Generate comparison table
      const tbody = document.querySelector('#comparison-table tbody');
      tbody.innerHTML = '';
      document.getElementById('comparison-section').style.display = 'block';

      const milestones = [1, 5, 10, 15, 20, 25, 30, years].filter((v, i, a) => a.indexOf(v) === i && v <= years && v > 0).sort((a,b) => a - b);

      milestones.forEach(year => {
        const mMonths = year * 12;
        let mFutureValue = initial;
        if (monthlyRate > 0) {
            mFutureValue = initial * Math.pow(1 + monthlyRate, mMonths);
            if (monthly > 0) {
                mFutureValue += monthly * ((Math.pow(1 + monthlyRate, mMonths) - 1) / monthlyRate);
            }
        } else {
            mFutureValue = initial + (monthly * mMonths);
        }

        const mContributed = initial + (monthly * mMonths);
        const withoutInvesting = mContributed; // Cash saved with 0% return
        const difference = Math.max(0, mFutureValue - withoutInvesting);

        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>Year ${year}</td>
          <td>${formatCurrency(mContributed)}</td>
          <td>${formatCurrency(withoutInvesting)}</td>
          <td style="color: var(--accent-color); font-weight: bold;">${formatCurrency(mFutureValue)}</td>
          <td style="color: #10b981;">+${formatCurrency(difference)}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    const inputs = ['initial-investment', 'monthly-contribution', 'annual-return', 'years-to-grow'];
    inputs.forEach(id => {
      document.getElementById(id).addEventListener('input', calculateInvestment);
    });

    // Run initial calculation when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', calculateInvestment);
    } else {
      calculateInvestment();
    }
  </script>

  <style is:inline>
    .page-content {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .hero {
      text-align: center;
      padding: 2rem 0;
    }

    .hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
      color: var(--accent-color);
    }

    .subtitle {
      color: var(--text-secondary);
      font-size: 1.15rem;
    }

    .calculator-container {
      background: var(--card-bg);
