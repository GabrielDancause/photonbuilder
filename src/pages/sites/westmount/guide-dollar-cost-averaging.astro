      }
    },
    "datePublished": "2026-03-01",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/guide-dollar-cost-averaging.html"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
