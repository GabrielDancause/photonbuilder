  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        // Populate sector filter
        const rows = document.querySelectorAll('#tableBody tr');
        const sectors = new Set();
        rows.forEach(row => sectors.add(row.getAttribute('data-sector')));

        const sectorFilter = document.getElementById('sectorFilter');
        sectors.forEach(sector => {
            if(sector && sector !== "Unknown") {
                const opt = document.createElement('option');
                opt.value = sector;
                opt.textContent = sector;
                sectorFilter.appendChild(opt);
            }
        });

        // Filter logic
        function applyFilters() {
            const selectedSector = document.getElementById('sectorFilter').value;
            const minYield = parseFloat(document.getElementById('yieldFilter').value);

            rows.forEach(row => {
                const rowSector = row.getAttribute('data-sector');
                const rowYield = parseFloat(row.getAttribute('data-yield')) || 0;

                let show = true;
                if (selectedSector !== "All" && rowSector !== selectedSector) show = false;
                if (rowYield < minYield) show = false;

                row.style.display = show ? '' : 'none';
            });
        }

        document.getElementById('sectorFilter').addEventListener('change', applyFilters);
        document.getElementById('yieldFilter').addEventListener('change', applyFilters);
    });

    // Sorting Logic
    let sortAsc = false;
    function sortTable(n) {
        const table = document.getElementById("dataTable");
        let rows = Array.from(table.rows).slice(1);
        sortAsc = !sortAsc;

        rows.sort((r1, r2) => {
            let v1 = r1.cells[n].innerText.replace(/[^0-9.-]+/g, "");
            let v2 = r2.cells[n].innerText.replace(/[^0-9.-]+/g, "");

            if (v1 === "" || isNaN(v1)) v1 = r1.cells[n].innerText.toLowerCase();
            else v1 = parseFloat(v1);

            if (v2 === "" || isNaN(v2)) v2 = r2.cells[n].innerText.toLowerCase();
            else v2 = parseFloat(v2);

            if (v1 < v2) return sortAsc ? -1 : 1;
            if (v1 > v2) return sortAsc ? 1 : -1;
            return 0;
        });

        const tbody = document.getElementById("tableBody");
        rows.forEach(row => tbody.appendChild(row));
    }
  </script>

