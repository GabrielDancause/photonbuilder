    minimum: 0,
    accounts: "TFSA, RRSP, FHSA, RESP, LIRA, RRIF, Non-reg, Joint, Corporate",
    rebalancing: "Automatic",
    tlh: "Premium ($100k+)",
    sri: "Yes (SRI & Halal)",
    returns: "Matches benchmark (passive)",
    bestFor: "Best Overall & Best for Beginners"
  },
  {
    name: "Questwealth Portfolios",
    fee: "0.20–0.25%",
    minimum: 1000,
    accounts: "TFSA, RRSP, FHSA, RESP, LIRA, RRIF, Non-reg, Joint, Corporate",
    rebalancing: "Active/Automatic",
    tlh: "No",
    sri: "Yes",
    returns: "Actively managed ETFs",
    bestFor: "Lowest Fees"
  },
  {
    name: "BMO SmartFolio",
    fee: "0.40–0.70%",
    minimum: 1000,
    accounts: "TFSA, RRSP, RESP, RRIF, Non-reg, Joint",
    rebalancing: "Active/Automatic",
    tlh: "No",
    sri: "No",
    returns: "Actively managed BMO ETFs",
    bestFor: "Best Big Bank Option"
  },
  {
    name: "RBC InvestEase",
    fee: "0.50%",
    minimum: 100,
    accounts: "TFSA, RRSP, FHSA, Non-reg",
    rebalancing: "Automatic",
    tlh: "No",
    sri: "Yes",
    returns: "Matches benchmark (passive)",
    bestFor: "Best for Simple Indexing (RBC clients)"
  },
  {
    name: "CI Direct Investing",
    fee: "0.35–0.60%",
    minimum: 1000,
    accounts: "TFSA, RRSP, FHSA, RESP, LIRA, RRIF, Non-reg, Joint, Corporate",
    rebalancing: "Automatic",
    tlh: "No",
    sri: "Yes (Impact)",
