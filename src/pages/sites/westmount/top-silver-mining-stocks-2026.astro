  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const sectorFilter = document.getElementById('sector-filter');
      const sortBy = document.getElementById('sort-by');
      const cardsContainer = document.getElementById('cards-container');
      const cards = Array.from(cardsContainer.getElementsByClassName('card'));
      const tbody = document.getElementById('summary-tbody');
      const rows = Array.from(tbody.getElementsByTagName('tr'));

      // Populate sectors
      const sectors = new Set();
      cards.forEach(card => sectors.add(card.getAttribute('data-sector')));
      sectors.forEach(sector => {
        if(sector && sector !== 'N/A') {
          const option = document.createElement('option');
          option.value = sector;
          option.textContent = sector;
          sectorFilter.appendChild(option);
        }
      });

      function filterAndSort() {
        const sectorVal = sectorFilter.value;
        const sortVal = sortBy.value;

        // Filter and Sort Cards
        let visibleCards = cards.filter(card => {
          return sectorVal === 'all' || card.getAttribute('data-sector') === sectorVal;
        });

        visibleCards.sort((a, b) => {
          if (sortVal === 'mcap-desc') {
            return parseFloat(b.getAttribute('data-mcap')) - parseFloat(a.getAttribute('data-mcap'));
          } else if (sortVal === 'yield-desc') {
            return parseFloat(b.getAttribute('data-yield')) - parseFloat(a.getAttribute('data-yield'));
          } else {
            const rankA = parseInt(a.querySelector('.rank-badge').textContent);
            const rankB = parseInt(b.querySelector('.rank-badge').textContent);
            return rankA - rankB;
          }
        });

        cards.forEach(card => card.style.display = 'none');
        visibleCards.forEach(card => {
          card.style.display = 'block';
          cardsContainer.appendChild(card);
        });

        // Filter and Sort Table Rows
        let visibleRows = rows.filter(row => {
          return sectorVal === 'all' || row.getAttribute('data-sector') === sectorVal;
        });

        visibleRows.sort((a, b) => {
          if (sortVal === 'mcap-desc') {
            return parseFloat(b.getAttribute('data-mcap')) - parseFloat(a.getAttribute('data-mcap'));
          } else if (sortVal === 'yield-desc') {
            return parseFloat(b.getAttribute('data-yield')) - parseFloat(a.getAttribute('data-yield'));
          } else {
            const rankA = parseInt(a.querySelector('.row-rank').textContent);
            const rankB = parseInt(b.querySelector('.row-rank').textContent);
            return rankA - rankB;
          }
        });

        rows.forEach(row => row.style.display = 'none');
        visibleRows.forEach(row => {
          row.style.display = ''; // default table-row display
          tbody.appendChild(row);
        });
      }

      sectorFilter.addEventListener('change', filterAndSort);
      sortBy.addEventListener('change', filterAndSort);
    });
  </script>

