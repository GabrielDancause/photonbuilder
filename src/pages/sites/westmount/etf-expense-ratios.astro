const findingsData = [
  {title:"Vanguard and Schwab dominate the low-cost space", text:"Schwab's average expense ratio of 0.046% edges out Vanguard's 0.055%. Both providers have driven the industry fee war, with their cheapest funds at just 0.02-0.03%. For broad-market exposure, there's virtually no reason to pay more than 0.05%."},
