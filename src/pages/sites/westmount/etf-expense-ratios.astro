---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "ETF Expense Ratio Index 2026",
  "description": "Compare expense ratios of 86 major ETFs across all categories. Find the cheapest S&P 500, bond, international, and dividend ETFs.",
  "datePublished": "2026-03-09",
  "dateModified": "2026-03-09",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  }
};

export const meta = {
  title: "ETF Expense Ratio Index 2026 — Westmount Research",
  description: "Some popular ETFs charge 10x more than nearly identical alternatives. We ranked 86 funds to find out which ones are quietly overcharging you.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="ETF Expense Ratio Index 2026 — Westmount Research"
  description="Some popular ETFs charge 10x more than nearly identical alternatives. We ranked 86 funds to find out which ones are quietly overcharging you."
  canonical="https://westmountfundamentals.com/etf-expense-ratios" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

/* Header */
header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
header h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
header p.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.meta{color:var(--text-secondary);font-size:13px;margin-top:12px;font-family:'JetBrains Mono',monospace}

/* Stats row */
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:32px 0}
.stat{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.stat .val{font-size:32px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.stat .label{font-size:13px;color:var(--text-secondary);margin-top:4px}

/* Chart */
.chart-section{margin:32px 0}
.chart-section h2{font-size:22px;margin-bottom:16px}
.chart-wrap{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px;overflow-x:auto}
.bar-row{display:flex;align-items:center;margin-bottom:6px;font-size:13px}
.bar-label{width:55px;text-align:right;margin-right:10px;font-family:'JetBrains Mono',monospace;color:var(--text-secondary);flex-shrink:0}
.bar{height:22px;border-radius:3px;display:flex;align-items:center;padding-left:8px;font-size:11px;font-weight:600;min-width:2px;color:#fff;font-family:'JetBrains Mono',monospace;transition:opacity .2s}
.bar:hover{opacity:.85}
.bar-name{margin-left:8px;color:var(--text-secondary);font-size:11px;font-family:'Inter',sans-serif;white-space:nowrap}

/* Findings */
.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px}

/* Table */
.table-section{margin:32px 0}
.table-section h2{font-size:22px;margin-bottom:12px}
.controls{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.controls select,.controls input{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 12px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif}
.controls input{min-width:200px}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--border-color);user-select:none;position:sticky;top:0}
th:hover{color:var(--accent-color)}
th.sorted-asc::after{content:' ▲';color:var(--accent-color)}
th.sorted-desc::after{content:' ▼';color:var(--accent-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color);white-space:nowrap}
tr:hover{background:rgba(74,143,231,.06)}
.ticker{font-family:'JetBrains Mono',monospace;font-weight:600;color:var(--accent-color)}
.er-low{color:#22c55e}
.er-mid{color:#eab308}
.er-high{color:#ef4444}
.num{font-family:'JetBrains Mono',monospace;text-align:right}

/* Issuer comparison */
.issuer-section{margin:32px 0}
.issuer-section h2{font-size:22px;margin-bottom:16px}
.issuer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.issuer-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px}
.issuer-card h3{font-size:15px;margin-bottom:8px}
.issuer-card .avg{font-family:'JetBrains Mono',monospace;font-size:24px;font-weight:700}
.issuer-card .detail{font-size:12px;color:var(--text-secondary);margin-top:4px}

/* FAQ */
.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

/* Methodology */
.methodology{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.methodology h2{font-size:18px;margin-bottom:12px}
.methodology p{color:var(--text-secondary);font-size:14px;margin-bottom:10px;line-height:1.7}

/* Citation */
.citation{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px}
.citation h3{font-size:14px;margin-bottom:8px;color:var(--text-secondary)}
.citation code{display:block;background:var(--bg-color);padding:14px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-secondary);white-space:pre-wrap;word-break:break-all}

/* Disclaimer */
.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}

/* Footer */
footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:640px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .controls{flex-direction:column}
  .controls input,.controls select{width:100%}
}
  </style>

<div class="container">

<div class="stats" id="stats"></div>

<div class="chart-section">
  <h2>Expense Ratios: Cheapest to Most Expensive</h2>
  <div class="chart-wrap" id="chart"></div>
</div>

<div class="issuer-section">
  <h2>Average Expense Ratio by Provider</h2>
  <div class="issuer-grid" id="issuers"></div>
</div>

<div class="findings">
  <h2>Key Findings</h2>
  <div id="findings"></div>
</div>

<div class="table-section">
  <h2>Full ETF Comparison Table</h2>
  <div class="controls">
    <input type="text" id="search" placeholder="Search by ticker or name…">
    <select id="catFilter">
      <option value="">All Categories</option>
      <option value="US Equity">US Equity</option>
      <option value="International">International</option>
      <option value="Bond">Bond</option>
      <option value="Sector">Sector</option>
      <option value="Thematic">Thematic</option>
      <option value="Dividend">Dividend</option>
      <option value="Commodity">Commodity</option>
    </select>
    <select id="issuerFilter">
      <option value="">All Issuers</option>
    </select>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th data-key="ticker">Ticker</th>
          <th data-key="name">Fund Name</th>
          <th data-key="issuer">Issuer</th>
          <th data-key="expenseRatio" data-type="num">Expense Ratio</th>
          <th data-key="aumB" data-type="num">AUM ($B)</th>
          <th data-key="category">Category</th>
          <th data-key="dividendYield" data-type="num">Div Yield</th>
          <th data-key="index">Index Tracked</th>
          <th data-key="inceptionYear" data-type="num">Inception</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</div>

<div class="faq-section">
  <h2>Frequently Asked Questions</h2>
  <div id="faq"></div>
</div>

<div class="methodology">
  <h2>Methodology</h2>
  <p>Expense ratios were sourced from official fund prospectuses filed with the SEC and verified against issuer websites (Vanguard, iShares/BlackRock, SPDR/State Street, Schwab, Invesco, and others). AUM figures are approximate as of Q1 2026 and may fluctuate with market conditions and fund flows.</p>
  <p>This index covers 86 of the most widely held ETFs across seven categories: US Equity, International, Bond, Sector, Thematic, Dividend, and Commodity. ETFs were selected based on AUM, trading volume, and investor relevance. All data is publicly available from official fund documentation.</p>
  <p>Expense ratios represent the total annual fund operating expenses as a percentage of assets. They are deducted from fund returns automatically and reduce the net asset value over time. Lower expense ratios directly benefit long-term investors.</p>
</div>

<div class="citation">
  <h3>Cite this research</h3>
  <code>Westmount Research. "ETF Expense Ratio Index 2026." Published March 9, 2026. https://westmountfundamentals.com/etf-expense-ratios</code>
</div>

<div class="disclaimer">This site provides data for informational purposes only. Not investment advice.</div>

</div>
