// Table
const tbody = document.getElementById('tbody');
const searchEl = document.getElementById('search');
const catFilter = document.getElementById('catFilter');
const issuerFilterEl = document.getElementById('issuerFilter');

// Populate issuer filter
const uniqueIssuers = [...new Set(etfs.map(e=>e.issuer))].sort();
uniqueIssuers.forEach(i=>{issuerFilterEl.innerHTML+=`<option value="${i}">${i}</option>`});

let sortKey = 'expenseRatio', sortDir = 1;

function erClass(er){
  if(er==null) return '';
  if(er<=0.05) return 'er-low';
  if(er<=0.20) return 'er-mid';
  return 'er-high';
}

function renderTable(){
  const q = searchEl.value.toLowerCase();
  const cat = catFilter.value;
  const iss = issuerFilterEl.value;
  let filtered = etfs.filter(e=>{
    if(q && !e.ticker.toLowerCase().includes(q) && !e.name.toLowerCase().includes(q)) return false;
    if(cat && e.category!==cat) return false;
    if(iss && e.issuer!==iss) return false;
    return true;
  });
  filtered.sort((a,b)=>{
    let va=a[sortKey], vb=b[sortKey];
    if(va==null) return 1; if(vb==null) return -1;
    if(typeof va==='string') return va.localeCompare(vb)*sortDir;
    return (va-vb)*sortDir;
  });
  tbody.innerHTML = filtered.map(e=>`<tr>
    <td class="ticker">${e.ticker}</td>
    <td>${e.name}</td>
    <td>${e.issuer}</td>
    <td class="num ${erClass(e.expenseRatio)}">${e.expenseRatio!=null?e.expenseRatio.toFixed(e.expenseRatio<0.1?4:2)+'%':'—'}</td>
    <td class="num">${e.aumB!=null?'$'+e.aumB.toFixed(1):'—'}</td>
    <td>${e.category}</td>
    <td class="num">${e.dividendYield!=null?e.dividendYield.toFixed(1)+'%':'—'}</td>
    <td style="font-size:12px;color:var(--text-secondary);max-width:200px;overflow:hidden;text-overflow:ellipsis">${e.index||'—'}</td>
    <td class="num">${e.inceptionYear||'—'}</td>
  </tr>`).join('');
}

// Sort headers
document.querySelectorAll('th[data-key]').forEach(th=>{
  th.addEventListener('click',()=>{
    const key = th.dataset.key;
    if(sortKey===key) sortDir*=-1; else {sortKey=key;sortDir=1;}
    document.querySelectorAll('th').forEach(t=>t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir===1?'sorted-asc':'sorted-desc');
    renderTable();
  });
});

searchEl.addEventListener('input', renderTable);
catFilter.addEventListener('change', renderTable);
issuerFilterEl.addEventListener('change', renderTable);

// FAQ
