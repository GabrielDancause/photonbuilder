const etfs = DATA.results;

// Stats
const ers = etfs.map(e=>e.expenseRatio).filter(v=>v!=null);
const avgER = (ers.reduce((a,b)=>a+b,0)/ers.length);
const medER = [...ers].sort((a,b)=>a-b)[Math.floor(ers.length/2)];
const totalAUM = etfs.reduce((a,e)=>a+(e.aumB||0),0);
const cheapest = etfs[0];

document.getElementById('stats').innerHTML = `
  <div class="stat"><div class="val">${DATA.totalEtfs}</div><div class="label">ETFs Compared</div></div>
  <div class="stat"><div class="val">${avgER.toFixed(3)}%</div><div class="label">Average Expense Ratio</div></div>
  <div class="stat"><div class="val">${medER.toFixed(2)}%</div><div class="label">Median Expense Ratio</div></div>
  <div class="stat"><div class="val">$${totalAUM.toFixed(0)}B</div><div class="label">Total AUM Covered</div></div>
  <div class="stat"><div class="val">${cheapest.ticker}</div><div class="label">Cheapest ETF (${cheapest.expenseRatio}%)</div></div>
`;

// Chart — top 30 by expense ratio (sorted cheapest first)
const chartData = etfs.filter(e=>e.expenseRatio!=null).slice(0,30);
const maxER = Math.max(...chartData.map(e=>e.expenseRatio));
const chartEl = document.getElementById('chart');
chartData.forEach(e=>{
  const pct = (e.expenseRatio/maxER)*100;
  const color = e.expenseRatio <= 0.05 ? '#22c55e' : e.expenseRatio <= 0.20 ? 'var(--accent-color)' : e.expenseRatio <= 0.40 ? '#eab308' : '#ef4444';
  chartEl.innerHTML += `<div class="bar-row"><span class="bar-label">${e.ticker}</span><div class="bar" style="width:${Math.max(pct,3)}%;background:${color}">${e.expenseRatio}%</div><span class="bar-name">${e.name}</span></div>`;
});

// Issuer comparison
const issuerMap = {};
etfs.forEach(e=>{
  if(!issuerMap[e.issuer]) issuerMap[e.issuer]={sum:0,count:0,minER:Infinity,aum:0};
  const im = issuerMap[e.issuer];
  if(e.expenseRatio!=null){im.sum+=e.expenseRatio;im.count++;}
  if(e.expenseRatio!=null && e.expenseRatio<im.minER) im.minER=e.expenseRatio;
  im.aum+=(e.aumB||0);
});
const issuersArr = Object.entries(issuerMap).sort((a,b)=>(a[1].sum/a[1].count)-(b[1].sum/b[1].count));
const issuerEl = document.getElementById('issuers');
issuersArr.forEach(([name,d])=>{
  const avg = d.count?d.sum/d.count:0;
  const color = avg <= 0.06 ? '#22c55e' : avg <= 0.20 ? 'var(--accent-color)' : avg <= 0.40 ? '#eab308' : '#ef4444';
  issuerEl.innerHTML += `<div class="issuer-card"><h3>${name}</h3><div class="avg" style="color:${color}">${avg.toFixed(3)}%</div><div class="detail">${d.count} ETFs · Cheapest: ${d.minER.toFixed(2)}% · $${d.aum.toFixed(0)}B AUM</div></div>`;
});

// Table
const tbody = document.getElementById('tbody');
const searchEl = document.getElementById('search');
const catFilter = document.getElementById('catFilter');
const issuerFilterEl = document.getElementById('issuerFilter');

// Populate issuer filter
const uniqueIssuers = [...new Set(etfs.map(e=>e.issuer))].sort();
uniqueIssuers.forEach(i=>{issuerFilterEl.innerHTML+=`<option value="${i}">${i}</option>`});

let sortKey = 'expenseRatio', sortDir = 1;

function erClass(er){
  if(er==null) return '';
  if(er<=0.05) return 'er-low';
  if(er<=0.20) return 'er-mid';
  return 'er-high';
}

function renderTable(){
  const q = searchEl.value.toLowerCase();
  const cat = catFilter.value;
  const iss = issuerFilterEl.value;
  let filtered = etfs.filter(e=>{
    if(q && !e.ticker.toLowerCase().includes(q) && !e.name.toLowerCase().includes(q)) return false;
    if(cat && e.category!==cat) return false;
    if(iss && e.issuer!==iss) return false;
    return true;
  });
  filtered.sort((a,b)=>{
    let va=a[sortKey], vb=b[sortKey];
    if(va==null) return 1; if(vb==null) return -1;
    if(typeof va==='string') return va.localeCompare(vb)*sortDir;
    return (va-vb)*sortDir;
  });
  tbody.innerHTML = filtered.map(e=>`<tr>
    <td class="ticker">${e.ticker}</td>
    <td>${e.name}</td>
    <td>${e.issuer}</td>
    <td class="num ${erClass(e.expenseRatio)}">${e.expenseRatio!=null?e.expenseRatio.toFixed(e.expenseRatio<0.1?4:2)+'%':'—'}</td>
    <td class="num">${e.aumB!=null?'$'+e.aumB.toFixed(1):'—'}</td>
    <td>${e.category}</td>
    <td class="num">${e.dividendYield!=null?e.dividendYield.toFixed(1)+'%':'—'}</td>
    <td style="font-size:12px;color:var(--text-secondary);max-width:200px;overflow:hidden;text-overflow:ellipsis">${e.index||'—'}</td>
    <td class="num">${e.inceptionYear||'—'}</td>
  </tr>`).join('');
}

// Sort headers
document.querySelectorAll('th[data-key]').forEach(th=>{
  th.addEventListener('click',()=>{
    const key = th.dataset.key;
    if(sortKey===key) sortDir*=-1; else {sortKey=key;sortDir=1;}
    document.querySelectorAll('th').forEach(t=>t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir===1?'sorted-asc':'sorted-desc');
    renderTable();
  });
});

searchEl.addEventListener('input', renderTable);
catFilter.addEventListener('change', renderTable);
issuerFilterEl.addEventListener('change', renderTable);

// Fee Impact Calculator
document.getElementById('calc-impact-btn').addEventListener('click', () => {
  const initial = parseFloat(document.getElementById('portfolio-size').value) || 0;
  const annualContrib = parseFloat(document.getElementById('annual-contribution').value) || 0;
  const returnRate = parseFloat(document.getElementById('expected-return').value) / 100 || 0;
  const years = parseInt(document.getElementById('years').value) || 0;
  const feeRate = parseFloat(document.getElementById('fee-er').value) / 100 || 0;
  if (years <= 0) return;
  let grossValue = initial, netValue = initial;
  for (let i = 0; i < years; i++) {
    grossValue = (grossValue + annualContrib) * (1 + returnRate);
    netValue = (netValue + annualContrib) * (1 + (returnRate - feeRate));
  }
  const lostGrowth = grossValue - netValue;
  document.getElementById('total-fees-paid').textContent = '$' + lostGrowth.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
  document.getElementById('impact-years').textContent = years;
  document.getElementById('lost-growth').textContent = '$' + lostGrowth.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
  document.getElementById('impact-result').classList.add('active');
});

// Percentile Checker
document.getElementById('calc-percentile-btn').addEventListener('click', () => {
  const inputVal = parseFloat(document.getElementById('user-er').value);
  if (isNaN(inputVal)) return;
  const allERs = etfs.map(e=>e.expenseRatio).filter(v=>v!=null).sort((a,b)=>a-b);
  let countBelow = 0;
  for (let i = 0; i < allERs.length; i++) {
    if (inputVal > allERs[i]) countBelow++;
    else break;
  }
  const percentile = Math.round((countBelow / allERs.length) * 100);
  const heading = document.getElementById('percentile-heading');
  const desc = document.getElementById('percentile-desc');
  heading.textContent = 'Your ETF is in the ' + percentile + 'th percentile.';
  if (percentile <= 25) {
    desc.textContent = 'Excellent! Your expense ratio is in the lowest quartile — highly competitive and cheap. You\'re paying less than 75% of major ETFs.';
  } else if (percentile <= 50) {
    desc.textContent = 'Good. Your expense ratio is below average. Likely a standard passive index fund or a very cheap active fund.';
  } else if (percentile <= 75) {
    desc.textContent = 'Above average. Your expense ratio is slightly high — typical for sector-specific, thematic, or actively managed ETFs. Consider whether a cheaper alternative exists.';
  } else {
    desc.textContent = 'Expensive. Your expense ratio is in the highest quartile. Unless this is a highly specialized or leveraged fund, you might be overpaying. Check our table above for cheaper alternatives.';
  }
  document.getElementById('percentile-result').classList.add('active');
});

// FAQ
const faqData = [
  {q:"What is the cheapest S&P 500 ETF in 2026?",a:"SPLG (SPDR Portfolio S&P 500 ETF) is the cheapest S&P 500 ETF with an expense ratio of just 0.02%. VOO and IVV are tied at 0.03%. SPY, the original and most liquid S&P 500 ETF, charges 0.0945% — nearly 5× more than SPLG. For buy-and-hold investors, the cheaper options deliver virtually identical performance with lower drag."},
  {q:"What is the average ETF expense ratio in 2026?",a:"Across our index of 86 major ETFs, the average expense ratio is 0.164% and the median is 0.09%. However, averages vary dramatically by category: core US index funds average 0.03–0.05%, sector ETFs around 0.09%, international funds 0.05–0.32%, thematic ETFs 0.15–0.75%, and commodities 0.10–0.60%. The overall industry trend — including active, thematic, and leveraged ETFs — puts the broader average around 0.40%."},
  {q:"Does expense ratio really matter?",a:"Yes, significantly. On a $100,000 portfolio growing at 7% annually over 30 years, a 0.03% expense ratio costs ~$2,800 total, while a 0.50% ratio costs ~$17,000 — a difference of $14,200. For passive index funds tracking the same benchmark, a lower expense ratio directly translates to higher net returns. Use our <a href='#fee-calculator'>fee impact calculator</a> above to see the exact cost for your portfolio."},
  {q:"What is a good expense ratio for an ETF?",a:"For broad-market index ETFs (S&P 500, total stock market, total bond), a good expense ratio in 2026 is 0.03–0.05%. For international funds, 0.05–0.10% is reasonable. For sector ETFs, 0.09–0.12% is standard. For thematic or actively managed ETFs, 0.15–0.40% is typical. Use our <a href='#expense-ratio-checker'>percentile checker</a> to see where your fund falls."},
  {q:"VOO vs SPY: which is better?",a:"Both track the S&P 500 identically. VOO charges 0.03% vs SPY's 0.0945%, saving ~$65/year per $100,000 invested. Over 30 years at 7% growth, SPY costs ~$6,000 more than VOO. SPY has tighter bid-ask spreads and higher daily volume, making it preferred by day traders and options traders. For long-term investors, VOO or SPLG (0.02%) is the better choice."},
  {q:"Which ETF provider has the lowest fees?",a:"Schwab leads with an average expense ratio of 0.046% across 8 ETFs, followed by Vanguard at 0.055% across 17 ETFs. SPDR's Portfolio line (SPLG, SPTM, SPYG, SPYV) is extremely competitive at 0.02–0.04%, though legacy products like SPY (0.0945%) and GLD (0.40%) bring up their average. iShares Core series funds are also competitive at 0.03–0.09%."},
  {q:"How are ETF expense ratios paid?",a:"Expense ratios are not billed to you directly — they are deducted automatically from the fund's net asset value (NAV) on a daily basis. If an ETF has a 0.12% expense ratio, approximately 0.00033% is deducted each day. You will never see a line item on your brokerage statement for expense ratios. The cost is invisible but real: it reduces your total return over time. Learn more in our <a href='/guide-how-etf-expense-ratios-work'>complete guide to how ETF expense ratios work</a>."},
  {q:"What is considered a high expense ratio?",a:"Any broad-market ETF charging above 0.20% is high by 2026 standards. An expense ratio above 0.50% is high for any ETF category except niche commodities or highly specialized active strategies. The only ETFs in our index above 0.60% are USO (0.60% for oil futures), EEM (0.68% — use the cheaper IEMG at 0.09%), and ARKK (0.75% for active management)."},
  {q:"Why are Vanguard expense ratios so low?",a:"Vanguard operates with a unique corporate structure where the company is owned by its funds, which are in turn owned by the investors. This means profits are returned to investors in the form of lower expense ratios rather than being distributed to outside shareholders. This structural advantage has made Vanguard a consistent leader in low-cost investing."},
  {q:"Are zero expense ratio ETFs worth it?",a:"Zero expense ratio funds can be excellent for long-term investors, as every basis point saved compounds over time. However, also consider the fund's tracking error, bid-ask spread, and potential capital gains distributions — fees are not the only cost of ownership. BNY Mellon and Fidelity offer some zero-fee products worth evaluating."},
  {q:"Does a lower expense ratio guarantee better performance?",a:"Lower fees mean less drag on returns, but don't guarantee outperformance. Tracking error, index methodology, and market conditions also matter. However, for two funds tracking the same index, the lower-cost option will nearly always win over any meaningful time horizon."},
  {q:"How do ETF expense ratios differ from mutual funds?",a:"On average, ETFs have lower expense ratios than mutual funds because ETFs are more tax-efficient and have lower structural overhead. The ETF market has seen a far more aggressive 'fee war' over the past decade. The average equity mutual fund still charges around 0.50% or more, versus 0.164% for ETFs in our index."}
];
const faqEl = document.getElementById('faq');
faqData.forEach(f=>{
  const div = document.createElement('div');
  div.className='faq-item';
  div.innerHTML=`<div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div>`;
  div.querySelector('.faq-q').addEventListener('click',()=>div.classList.toggle('open'));
  faqEl.appendChild(div);
});

// Initial render
renderTable();
document.querySelector('th[data-key="expenseRatio"]').classList.add('sorted-asc');
