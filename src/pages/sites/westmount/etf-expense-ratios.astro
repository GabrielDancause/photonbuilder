const etfs = DATA.results;

// Stats
const ers = etfs.map(e=>e.expenseRatio).filter(v=>v!=null);
const avgER = (ers.reduce((a,b)=>a+b,0)/ers.length);
const medER = ers.sort((a,b)=>a-b)[Math.floor(ers.length/2)];
const totalAUM = etfs.reduce((a,e)=>a+(e.aumB||0),0);
const cheapest = etfs[0];

document.getElementById('stats').innerHTML = `
  <div class="stat"><div class="val">${DATA.totalEtfs}</div><div class="label">ETFs Compared</div></div>
  <div class="stat"><div class="val">${avgER.toFixed(3)}%</div><div class="label">Average Expense Ratio</div></div>
  <div class="stat"><div class="val">${medER.toFixed(2)}%</div><div class="label">Median Expense Ratio</div></div>
  <div class="stat"><div class="val">$${totalAUM.toFixed(0)}B</div><div class="label">Total AUM Covered</div></div>
  <div class="stat"><div class="val">${cheapest.ticker}</div><div class="label">Cheapest ETF (${cheapest.expenseRatio}%)</div></div>
`;

// Chart — top 30 by expense ratio (sorted cheapest first, show variety)
const chartData = etfs.filter(e=>e.expenseRatio!=null).slice(0,30);
const maxER = Math.max(...chartData.map(e=>e.expenseRatio));
const chartEl = document.getElementById('chart');
chartData.forEach(e=>{
  const pct = (e.expenseRatio/maxER)*100;
  const color = e.expenseRatio <= 0.05 ? '#22c55e' : e.expenseRatio <= 0.20 ? 'var(--accent-color)' : e.expenseRatio <= 0.40 ? '#eab308' : '#ef4444';
  chartEl.innerHTML += `<div class="bar-row"><span class="bar-label">${e.ticker}</span><div class="bar" style="width:${Math.max(pct,3)}%;background:${color}">${e.expenseRatio}%</div><span class="bar-name">${e.name}</span></div>`;
});

// Issuer comparison
const issuerMap = {};
etfs.forEach(e=>{
  if(!issuerMap[e.issuer]) issuerMap[e.issuer]={sum:0,count:0,minER:Infinity,aum:0};
  const im = issuerMap[e.issuer];
  if(e.expenseRatio!=null){im.sum+=e.expenseRatio;im.count++;}
  if(e.expenseRatio!=null && e.expenseRatio<im.minER) im.minER=e.expenseRatio;
  im.aum+=(e.aumB||0);
});
const issuers = Object.entries(issuerMap).sort((a,b)=>(a[1].sum/a[1].count)-(b[1].sum/b[1].count));
const issuerEl = document.getElementById('issuers');
issuers.forEach(([name,d])=>{
  const avg = d.count?d.sum/d.count:0;
  const color = avg <= 0.06 ? '#22c55e' : avg <= 0.20 ? 'var(--accent-color)' : avg <= 0.40 ? '#eab308' : '#ef4444';
  issuerEl.innerHTML += `<div class="issuer-card"><h3>${name}</h3><div class="avg" style="color:${color}">${avg.toFixed(3)}%</div><div class="detail">${d.count} ETFs · Cheapest: ${d.minER.toFixed(2)}% · $${d.aum.toFixed(0)}B AUM</div></div>`;
});

