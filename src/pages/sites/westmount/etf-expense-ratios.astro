---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the cheapest S&P 500 ETF in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "SPLG (SPDR Portfolio S&P 500 ETF) is the cheapest S&P 500 ETF with an expense ratio of just 0.02%. VOO and IVV are tied at 0.03%. SPY charges 0.0945% — nearly 5x more than SPLG."
      }
    },
    {
      "@type": "Question",
      "name": "What is the average ETF expense ratio in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Based on our analysis of 86 major ETFs, the simple average expense ratio is 0.164% and the median is 0.09%. By category: passive index funds average 0.03-0.05%, sector ETFs 0.09%, international 0.05-0.32%, thematic 0.15-0.75%, and commodities 0.10-0.60%."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good expense ratio for an ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For broad-market index ETFs (S&P 500, total stock market, total bond), a good expense ratio in 2026 is 0.03-0.05%. For international funds, 0.05-0.10%. For sector ETFs, 0.09-0.12%. For thematic or actively managed ETFs, 0.15-0.40%. If you're paying more than 0.10% for a core US index fund, cheaper alternatives exist."
      }
    },
    {
      "@type": "Question",
      "name": "Does expense ratio really matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. On a $100,000 portfolio growing at 7% annually over 30 years, a 0.03% expense ratio costs ~$2,800 total, while a 0.50% ratio costs ~$17,000 — a difference of $14,200. It's one of the few variables investors can fully control."
      }
    },
    {
      "@type": "Question",
      "name": "VOO vs SPY: which is better?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both track the S&P 500 identically. VOO charges 0.03% vs SPY's 0.0945%, saving ~$65/year per $100K invested. For long-term investors, VOO or SPLG (0.02%) is better. SPY is preferred by active traders for its tighter options spreads and higher liquidity."
      }
    },
    {
      "@type": "Question",
      "name": "How are ETF expense ratios paid?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Expense ratios are deducted automatically from the fund's net asset value (NAV) daily. You never see a line item on your brokerage statement — the cost is invisible but real, reducing your total return over time."
      }
    },
    {
      "@type": "Question",
      "name": "Why are Vanguard expense ratios so low?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vanguard operates with a unique corporate structure where the company is owned by its funds, which are in turn owned by the investors. Profits are returned to investors in the form of lower expense ratios."
      }
    },
    {
      "@type": "Question",
      "name": "Which ETF provider has the lowest fees?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Schwab leads with an average expense ratio of 0.046% across 8 ETFs, followed by Vanguard at 0.055% across 17 ETFs. SPDR's Portfolio line (SPLG, SPTM, SPYG, SPYV) is also extremely competitive at 0.02-0.04%."
      }
    },
    {
      "@type": "Question",
      "name": "Does a lower expense ratio guarantee better performance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lower fees mean less drag on returns, but don't guarantee outperformance. Tracking error, index methodology, and market conditions also matter. However, for funds tracking the same index, the lower-cost option will nearly always win over time."
      }
    },
    {
      "@type": "Question",
      "name": "Are zero expense ratio ETFs worth it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zero expense ratio funds can be excellent for long-term investors. However, also consider tracking error, bid-ask spreads, and potential capital gains distributions — fees are not the only cost of ownership."
      }
    }
  ]
};

export const meta = {
  title: "ETF Expense Ratios 2026: 86 ETFs Ranked + Average by Category",
  description: "Average ETF expense ratio: 0.44%. Cheapest: SPLG at 0.02%. Compare 86 ETFs by cost, see averages by category, and calculate the impact of fees on your portfolio.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="ETF Expense Ratios 2026: 86 ETFs Ranked + Average by Category"
  description="Average ETF expense ratio: 0.44%. Cheapest: SPLG at 0.02%. Compare 86 ETFs by cost, see averages by category, and calculate the impact of fees on your portfolio."
  canonical="https://westmountfundamentals.com/etf-expense-ratios" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

/* Header */
header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
header h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
header p.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.meta{color:var(--text-secondary);font-size:13px;margin-top:12px;font-family:'JetBrains Mono',monospace}

/* Stats row */
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:32px 0}
.stat{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.stat .val{font-size:32px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.stat .label{font-size:13px;color:var(--text-secondary);margin-top:4px}

/* Chart */
.chart-section{margin:32px 0}
.chart-section h2{font-size:22px;margin-bottom:16px}
.chart-wrap{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px;overflow-x:auto}
.bar-row{display:flex;align-items:center;margin-bottom:6px;font-size:13px}
.bar-label{width:55px;text-align:right;margin-right:10px;font-family:'JetBrains Mono',monospace;color:var(--text-secondary);flex-shrink:0}
.bar{height:22px;border-radius:3px;display:flex;align-items:center;padding-left:8px;font-size:11px;font-weight:600;min-width:2px;color:#fff;font-family:'JetBrains Mono',monospace;transition:opacity .2s}
.bar:hover{opacity:.85}
.bar-name{margin-left:8px;color:var(--text-secondary);font-size:11px;font-family:'Inter',sans-serif;white-space:nowrap}

/* Findings */
.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px}

/* Category averages table */
.category-section{margin:32px 0}
.category-section h2{font-size:22px;margin-bottom:12px}
.category-section .section-desc{color:var(--text-secondary);font-size:14px;margin-bottom:16px;line-height:1.6}
.category-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
.category-wrap table{width:100%;border-collapse:collapse;font-size:13px}
.category-wrap th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;border-bottom:1px solid var(--border-color)}
.category-wrap td{padding:10px 14px;border-bottom:1px solid var(--border-color)}
.category-wrap tr:hover{background:rgba(74,143,231,.06)}

/* Cheapest ETFs */
.cheapest-section{margin:32px 0}
.cheapest-section h2{font-size:22px;margin-bottom:12px}
.cheapest-section .section-desc{color:var(--text-secondary);font-size:14px;margin-bottom:16px;line-height:1.6}
.cheapest-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
.cheapest-wrap table{width:100%;border-collapse:collapse;font-size:13px}
.cheapest-wrap th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;border-bottom:1px solid var(--border-color);white-space:nowrap}
.cheapest-wrap td{padding:10px 14px;border-bottom:1px solid var(--border-color)}
.cheapest-wrap tr:hover{background:rgba(74,143,231,.06)}

/* Table */
.table-section{margin:32px 0}
.table-section h2{font-size:22px;margin-bottom:12px}
.controls{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.controls select,.controls input{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 12px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif}
.controls input{min-width:200px}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--border-color);user-select:none;position:sticky;top:0}
th:hover{color:var(--accent-color)}
th.sorted-asc::after{content:' ▲';color:var(--accent-color)}
th.sorted-desc::after{content:' ▼';color:var(--accent-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color);white-space:nowrap}
tr:hover{background:rgba(74,143,231,.06)}
.ticker{font-family:'JetBrains Mono',monospace;font-weight:600;color:var(--accent-color)}
.er-low{color:#22c55e}
.er-mid{color:#eab308}
.er-high{color:#ef4444}
.num{font-family:'JetBrains Mono',monospace;text-align:right}

