---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the best ETF in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 'best' ETF depends on your goals. For a globally diversified, all-in-one portfolio, XEQT and VEQT are top choices. For US exposure, VFV is highly popular."
      }
    },
    {
      "@type": "Question",
      "name": "Are Canadian ETFs a good investment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, ETFs offer instant diversification, low fees (MERs), and easy access to global and domestic markets, making them excellent long-term investments."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best Canadian dividend ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "VDY is consistently ranked as one of the best Canadian dividend ETFs, offering high yield from top Canadian banks and energy companies."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between XEQT and VEQT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both are 100% equity all-in-one ETFs. XEQT has slightly higher US exposure and a slightly lower MER, while VEQT holds more Canadian equities. Performance is historically very similar."
      }
    },
    {
      "@type": "Question",
      "name": "Which ETF tracks the S&P 500 in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "VFV is the most popular Canadian-listed ETF that tracks the S&P 500 (unhedged), offering direct exposure to the largest US companies."
      }
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title="Best ETFs in Canada (2026): Top Picks by Category"
  description="Discover the best ETFs in Canada for 2026. Compare XEQT, VFV, XIC and more by category, including MER, historical returns, and AUM to build your portfolio."
  canonical="https://westmountfundamentals.com/best-etfs-canada-2026" schema={schema}
>
  <div class="max-w-[1100px] mx-auto px-5 py-10">
        

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-5 mb-12">
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="text-[2rem] font-black text-[var(--accent-color)] font-mono">$122.4B</div>
                <div class="text-[0.85rem] text-[var(--text-secondary)] uppercase tracking-[1px] mt-2">Total AUM Analyzed</div>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="text-[2rem] font-black text-[var(--accent-color)] font-mono">0.15%</div>
                <div class="text-[0.85rem] text-[var(--text-secondary)] uppercase tracking-[1px] mt-2">Average MER</div>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="text-[2rem] font-black text-[var(--accent-color)] font-mono">VDY.TO</div>
                <div class="text-[0.85rem] text-[var(--text-secondary)] uppercase tracking-[1px] mt-2">Top Performer YTD (6.29%)</div>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="text-[2rem] font-black text-[var(--accent-color)] font-mono">7</div>
                <div class="text-[0.85rem] text-[var(--text-secondary)] uppercase tracking-[1px] mt-2">Top ETFs Ranked</div>
            </div>
        </div>

        <div class="flex gap-4 mb-6 flex-wrap">
            <input type="text" id="searchInput" placeholder="Search by ticker or name..." class="flex-1 min-w-[250px] bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg font-sans text-[0.95rem] focus:outline-none focus:border-[var(--accent-color)]">
            <select id="categoryFilter" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg font-sans text-[0.95rem] focus:outline-none focus:border-[var(--accent-color)]">
                <option value="all">All Categories</option>
                <option value="All-in-One / Asset Allocation">All-in-One</option>
                <option value="US Equity">US Equity</option>
                <option value="Canadian Equity">Canadian Equity</option>
                <option value="Canadian Dividend">Canadian Dividend</option>
                <option value="Canadian Bonds">Canadian Bonds</option>
            </select>
        </div>

        <div class="overflow-x-auto bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl mb-12">
            <table id="etfTable" class="w-full border-collapse text-left">
                <thead>
                    <tr>
                        <th class="p-4 border-b border-[var(--border-color)] font-semibold text-white text-[0.85rem] uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:text-[var(--accent-color)]" data-sort="ticker">Ticker ↕</th>
                        <th class="p-4 border-b border-[var(--border-color)] font-semibold text-white text-[0.85rem] uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:text-[var(--accent-color)]" data-sort="category">Category ↕</th>
                        <th class="p-4 border-b border-[var(--border-color)] font-semibold text-white text-[0.85rem] uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:text-[var(--accent-color)]" data-sort="mer">MER ↕</th>
                        <th class="p-4 border-b border-[var(--border-color)] font-semibold text-white text-[0.85rem] uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:text-[var(--accent-color)]" data-sort="dividendYield">Yield ↕</th>
                        <th class="p-4 border-b border-[var(--border-color)] font-semibold text-white text-[0.85rem] uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:text-[var(--accent-color)]" data-sort="ytdReturn">YTD Return ↕</th>
                        <th class="p-4 border-b border-[var(--border-color)] font-semibold text-white text-[0.85rem] uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:text-[var(--accent-color)]" data-sort="fiveYearReturn">5Y Return ↕</th>
                        <th class="p-4 border-b border-[var(--border-color)] font-semibold text-white text-[0.85rem] uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:text-[var(--accent-color)]" data-sort="aum">AUM ↕</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- Rows rendered via JS -->
                </tbody>
            </table>
        </div>

        <h2 class="text-[1.8rem] text-white mb-5 font-bold">Historical 5-Year Return Comparison</h2>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-12 h-[400px]">
            <canvas id="returnChart"></canvas>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-8 mb-10">
            <h2 class="text-[1.8rem] text-white mb-5 font-bold">Methodology</h2>
            <p class="mb-4 text-[var(--text-secondary)]">This study curates the best ETFs available to Canadian investors in 2026 across various core portfolio categories (All-in-One, US Equity, Canadian Equity, Dividend, and Bonds). We prioritize ETFs with high liquidity (Assets Under Management), low Management Expense Ratios (MER), and strong track records.</p>
            <p class="mb-4 text-[var(--text-secondary)]">Data is sourced in real-time from financial APIs and includes top Canadian listings from providers like Vanguard, iShares, and BMO. Returns shown are based on historical price changes.</p>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-8 mb-10">
            <h2 class="text-[1.8rem] text-white mb-5 font-bold">Frequently Asked Questions</h2>
            <div class="mb-6">
                <div class="font-bold text-white mb-2 text-[1.1rem]">What is the best ETF in Canada?</div>
                <div class="text-[var(--text-secondary)]">The "best" ETF depends on your goals. For a globally diversified, all-in-one portfolio, XEQT and VEQT are top choices. For US exposure, VFV is highly popular.</div>
            </div>
            <div class="mb-6">
                <div class="font-bold text-white mb-2 text-[1.1rem]">Are Canadian ETFs a good investment?</div>
                <div class="text-[var(--text-secondary)]">Yes, ETFs offer instant diversification, low fees (MERs), and easy access to global and domestic markets, making them excellent long-term investments.</div>
            </div>
            <div class="mb-6">
                <div class="font-bold text-white mb-2 text-[1.1rem]">What is the best Canadian dividend ETF?</div>
                <div class="text-[var(--text-secondary)]">VDY is consistently ranked as one of the best Canadian dividend ETFs, offering high yield from top Canadian banks and energy companies.</div>
            </div>
            <div class="mb-6">
                <div class="font-bold text-white mb-2 text-[1.1rem]">What is the difference between XEQT and VEQT?</div>
                <div class="text-[var(--text-secondary)]">Both are 100% equity all-in-one ETFs. XEQT has slightly higher US exposure and a slightly lower MER, while VEQT holds more Canadian equities. Performance is historically very similar.</div>
            </div>
            <div class="mb-6">
                <div class="font-bold text-white mb-2 text-[1.1rem]">Which ETF tracks the S&P 500 in Canada?</div>
                <div class="text-[var(--text-secondary)]">VFV is the most popular Canadian-listed ETF that tracks the S&P 500 (unhedged), offering direct exposure to the largest US companies.</div>
            </div>
        </div>

    </div>
  <script is:inline>
window.__INITIAL_DATA__ = [{"ticker":"XEQT.TO","name":"ISHARES CORE EQUITY ETF","price":39.97,"currency":"CAD","aum":14832646144,"mer":0.2,"category":"All-in-One / Asset Allocation","ytdReturn":-0.47310415196933275,"fiveYearReturn":72.32776447734935,"dividendYield":1.58,"trailingPE":21.48289},{"ticker":"VEQT.TO","name":"VANGUARD ALL EQUITY ETF PORTFOL","price":53.85,"currency":"CAD","aum":12165570560,"mer":0.24,"category":"All-in-One / Asset Allocation","ytdReturn":-0.4805066222466995,"fiveYearReturn":73.78722644642343,"dividendYield":1.34,"trailingPE":21.714373},{"ticker":"VFV.TO","name":"VANGUARD SP 500 INDEX ETF","price":161.58,"currency":"CAD","aum":28286175232,"mer":0.09,"category":"US Equity","ytdReturn":-3.291836210033923,"fiveYearReturn":87.27151247647679,"dividendYield":0.92,"trailingPE":26.864264},{"ticker":"XIC.TO","name":"iSHARES CORE SP TSX CAPPED COMP","price":52.56,"currency":"CAD","aum":26922676224,"mer":0.06,"category":"Canadian Equity","ytdReturn":3.3425103077829124,"fiveYearReturn":94.85405450354376,"dividendYield":2.05,"trailingPE":19.51086},{"ticker":"ZAG.TO","name":"BMO AGGREGATE BOND INDEX ETF","price":13.665,"currency":"CAD","aum":12312939520,"mer":0.09,"category":"Canadian Bonds","ytdReturn":0.08624348336779719,"fiveYearReturn":2.740314671450625,"dividendYield":3.41,"trailingPE":null},{"ticker":"VDY.TO","name":"VANGUARD FTSE CDN HIGH DIV YLD ","price":66,"currency":"CAD","aum":6604111872,"mer":0.22,"category":"Canadian Dividend","ytdReturn":6.289904780510461,"fiveYearReturn":109.35464055632187,"dividendYield":3.55,"trailingPE":16.681976},{"ticker":"XIU.TO","name":"iSHARES SP TSX 60 INDEX ETF","price":48.03,"currency":"CAD","aum":21275277312,"mer":0.18,"category":"Canadian Equity","ytdReturn":2.223877766288562,"fiveYearReturn":92.54212115428845,"dividendYield":2.27,"trailingPE":19.401686}];

        const formatMoneyJS = (val) => val != null ? '$' + (val / 1e9).toFixed(1) + 'B' : 'N/A';
        const formatPctJS = (val) => val != null ? val.toFixed(2) + '%' : 'N/A';
        const getColorClass = (val) => {
            if (val == null) return '';
            return val >= 0 ? 'text-[#4ade80]' : 'text-[#f87171]';
        };

        let currentSort = { col: 'aum', asc: false };

        const renderTable = () => {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const category = document.getElementById('categoryFilter').value;

            let filtered = window.__INITIAL_DATA__.filter(d => {
                const matchSearch = d.ticker.toLowerCase().includes(search) || d.name.toLowerCase().includes(search);
                const matchCat = category === 'all' || d.category === category;
                return matchSearch && matchCat;
            });

            filtered.sort((a, b) => {
                let valA = a[currentSort.col];
                let valB = b[currentSort.col];
                if (valA == null) valA = -Infinity;
                if (valB == null) valB = -Infinity;

                if (typeof valA === 'string') {
                    return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }
                return currentSort.asc ? valA - valB : valB - valA;
            });

            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = filtered.map(d => `
                <tr class="hover:bg-[rgba(74,143,231,0.05)] last:[&>td]:border-b-0">
                    <td class="p-4 border-b border-[var(--border-color)] text-[0.95rem]">
                        <span class="font-bold text-white">${d.ticker}</span>
                        <span class="text-[var(--text-secondary)] text-[0.8rem] block">${d.name}</span>
                    </td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[0.95rem] text-white">${d.category || 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[0.95rem] text-white font-mono">${formatPctJS(d.mer)}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[0.95rem] text-white font-mono">${formatPctJS(d.dividendYield)}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[0.95rem] font-mono ${getColorClass(d.ytdReturn)}">${d.ytdReturn != null ? (d.ytdReturn > 0 ? '+' : '') + formatPctJS(d.ytdReturn) : 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[0.95rem] font-mono ${getColorClass(d.fiveYearReturn)}">${d.fiveYearReturn != null ? (d.fiveYearReturn > 0 ? '+' : '') + formatPctJS(d.fiveYearReturn) : 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[0.95rem] text-white font-mono">${formatMoneyJS(d.aum)}</td>
                </tr>
            `).join('');
        };

        document.getElementById('searchInput').addEventListener('input', renderTable);
        document.getElementById('categoryFilter').addEventListener('change', renderTable);

        document.querySelectorAll('th').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (currentSort.col === col) {
                    currentSort.asc = !currentSort.asc;
                } else {
                    currentSort.col = col;
                    currentSort.asc = false;
                }
                renderTable();
            });
        });

        renderTable();

        // Chart
        const ctx = document.getElementById('returnChart').getContext('2d');

        // Only chart items with 5y returns
        const chartData = window.__INITIAL_DATA__.filter(d => d.fiveYearReturn != null).sort((a, b) => b.fiveYearReturn - a.fiveYearReturn);

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: chartData.map(d => d.ticker),
                datasets: [{
                    label: '5-Year Return (%)',
                    data: chartData.map(d => d.fiveYearReturn),
                    backgroundColor: '#4a8fe7',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        grid: { color: '#152040' },
                        ticks: { color: '#6a7a90' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#c8d0de', font: { family: "'JetBrains Mono', monospace" } }
                    }
                }
            }
        });
  </script>
</SiteLayout>
