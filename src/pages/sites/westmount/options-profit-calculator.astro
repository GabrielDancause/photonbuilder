    <div class="methodology">
      <h2>Methodology</h2>
      <p>This calculator computes option profit and loss at expiration using standard payoff formulas. For calls: payoff = max(0, underlying − strike) − premium. For puts: payoff = max(0, strike − underlying) − premium. Multi-leg strategies sum the payoffs of each individual leg across the price range.</p>
      <p>Greeks are estimated using a simplified Black-Scholes model assuming a risk-free rate of 5% and no dividends. Delta and gamma use the standard normal CDF/PDF, theta includes both time decay and risk-free rate components, and vega measures sensitivity to implied volatility. These are approximations for educational purposes — for real trading, use your broker's Greeks which incorporate volatility skew and term structure.</p>
    </div>

    <div class="disclaimer">This calculator is for informational and educational purposes only. Not financial or investment advice. Options involve significant risk and are not suitable for all investors. Greeks are simplified estimates. Always verify calculations with your broker before placing trades.</div>
</div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
// ===== Black-Scholes helpers =====
const RF = 0.05;

function normCDF(x) {
  var a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;
  var sign = x < 0 ? -1 : 1;
  x = Math.abs(x) / Math.SQRT2;
  var t = 1 / (1 + p * x);
  var y = 1 - (((((a5*t + a4)*t) + a3)*t + a2)*t + a1)*t * Math.exp(-x*x);
  return 0.5 * (1 + sign * y);
}

function normPDF(x) {
  return Math.exp(-0.5 * x * x) / Math.sqrt(2 * Math.PI);
}

function bsD1(S, K, T, sigma) {
  if (T <= 0 || sigma <= 0) return S > K ? 10 : -10;
  return (Math.log(S/K) + (RF + 0.5*sigma*sigma)*T) / (sigma*Math.sqrt(T));
}

function bsD2(S, K, T, sigma) {
  return bsD1(S, K, T, sigma) - sigma * Math.sqrt(T);
}

function bsGreeks(type, side, S, K, T, sigma) {
  var d1 = bsD1(S, K, T, sigma);
  var d2 = bsD2(S, K, T, sigma);
  var sqrtT = Math.sqrt(Math.max(T, 0.001));
  var mult = side === 'buy' ? 1 : -1;
  var delta, theta;
  if (type === 'call') {
    delta = normCDF(d1);
    theta = (-S * normPDF(d1) * sigma / (2 * sqrtT)) - RF * K * Math.exp(-RF*T) * normCDF(d2);
  } else {
    delta = normCDF(d1) - 1;
    theta = (-S * normPDF(d1) * sigma / (2 * sqrtT)) + RF * K * Math.exp(-RF*T) * normCDF(-d2);
  }
  var gamma = normPDF(d1) / (S * sigma * sqrtT);
  var vega = S * normPDF(d1) * sqrtT / 100;
  return {
    delta: (delta * mult).toFixed(4),
    gamma: (gamma * mult).toFixed(4),
    theta: (theta / 365 * mult).toFixed(4),
    vega: (vega * mult).toFixed(4)
  };
}

// ===== Legs state =====
var legs = [];
var plChart = null;
var activeStrategy = null;

function getInputLeg() {
  return {
    type: document.getElementById('optType').value,
    side: document.getElementById('optSide').value,
    strike: parseFloat(document.getElementById('strike').value) || 0,
    premium: parseFloat(document.getElementById('premium').value) || 0,
    contracts: parseInt(document.getElementById('contracts').value) || 1
  };
}

function getGlobalParams() {
  return {
    underlying: parseFloat(document.getElementById('underlying').value) || 100,
    dte: parseInt(document.getElementById('dte').value) || 30,
    iv: (parseFloat(document.getElementById('iv').value) || 30) / 100
  };
}

function legPayoff(leg, price) {
  var mult = leg.side === 'buy' ? 1 : -1;
  var intrinsic;
  if (leg.type === 'call') {
    intrinsic = Math.max(0, price - leg.strike);
  } else {
    intrinsic = Math.max(0, leg.strike - price);
  }
  return (intrinsic * mult - leg.premium * mult) * leg.contracts * 100;
}

function totalPayoff(allLegs, price) {
  return allLegs.reduce(function(sum, leg) { return sum + legPayoff(leg, price); }, 0);
}

function renderLegs() {
  var section = document.getElementById('legsSection');
  var tbody = document.getElementById('legsTbody');
  if (legs.length === 0) { section.style.display = 'none'; return; }
  section.style.display = 'block';
  tbody.innerHTML = legs.map(function(l, i) {
    return '<tr><td>' + l.type.toUpperCase() + '</td><td>' + (l.side === 'buy' ? 'BUY' : 'SELL') +
      '</td><td class="num">$' + l.strike.toFixed(2) + '</td><td class="num">$' + l.premium.toFixed(2) +
      '</td><td class="num">' + l.contracts + '</td><td><button class="btn-secondary" style="padding:4px 12px;font-size:12px" onclick="removeLeg(' + i + ')">Remove</button></td></tr>';
  }).join('');
}

window.removeLeg = function(i) {
  legs.splice(i, 1);
  renderLegs();
  if (legs.length > 0) calculate();
};

document.getElementById('addLegBtn').addEventListener('click', function() {
  legs.push(getInputLeg());
  renderLegs();
});

function findBreakevens(prices, payoffs, step) {
  var breakevens = [];
  for (var i = 1; i < payoffs.length; i++) {
    if ((payoffs[i-1] <= 0 && payoffs[i] >= 0) || (payoffs[i-1] >= 0 && payoffs[i] <= 0)) {
      var ratio = Math.abs(payoffs[i-1]) / (Math.abs(payoffs[i-1]) + Math.abs(payoffs[i]));
      breakevens.push(prices[i-1] + ratio * step);
    }
  }
  return breakevens;
}

function displayResults(maxProfit, maxLoss, breakevens, isUnlimitedProfit, isUnlimitedLoss) {
  document.getElementById('resultsSection').style.display = 'block';
  document.getElementById('chartSection').style.display = 'block';
  document.getElementById('greeksSection').style.display = 'block';

  var mpEl = document.getElementById('resMaxProfit');
  if (isUnlimitedProfit) { mpEl.textContent = 'Unlimited'; mpEl.className = 'val pos'; }
  else { mpEl.textContent = (maxProfit >= 0 ? '+' : '') + '$' + maxProfit.toFixed(0); mpEl.className = 'val ' + (maxProfit >= 0 ? 'pos' : 'neg'); }

  var mlEl = document.getElementById('resMaxLoss');
  if (isUnlimitedLoss) { mlEl.textContent = 'Unlimited'; mlEl.className = 'val neg'; }
  else { mlEl.textContent = (maxLoss >= 0 ? '+' : '') + '$' + maxLoss.toFixed(0); mlEl.className = 'val ' + (maxLoss < 0 ? 'neg' : 'pos'); }

  var beEl = document.getElementById('resBreakeven');
  beEl.textContent = breakevens.length ? breakevens.map(function(b){return '$'+b.toFixed(2)}).join(' / ') : 'N/A';
  beEl.className = 'val neutral';

  var rrEl = document.getElementById('resRiskReward');
  if (isUnlimitedLoss || isUnlimitedProfit || maxLoss === 0) {
    rrEl.textContent = isUnlimitedLoss ? '∞ risk' : isUnlimitedProfit ? '∞ reward' : 'N/A';
    rrEl.className = 'val warn';
  } else {
    rrEl.textContent = '1 : ' + (maxProfit / Math.abs(maxLoss)).toFixed(2);
    rrEl.className = 'val neutral';
  }
}

function displayGreeks(allLegs, underlying, T, iv, hasShares) {
  var totalDelta = hasShares ? 1 : 0, totalGamma = 0, totalTheta = 0, totalVega = 0;
  allLegs.forEach(function(leg) {
    var g = bsGreeks(leg.type, leg.side, underlying, leg.strike, T, iv);
    totalDelta += parseFloat(g.delta) * leg.contracts;
    totalGamma += parseFloat(g.gamma) * leg.contracts;
    totalTheta += parseFloat(g.theta) * leg.contracts;
    totalVega += parseFloat(g.vega) * leg.contracts;
  });
  document.getElementById('gDelta').textContent = totalDelta.toFixed(4);
  document.getElementById('gGamma').textContent = totalGamma.toFixed(4);
  document.getElementById('gTheta').textContent = totalTheta.toFixed(4) + ' /day';
  document.getElementById('gVega').textContent = totalVega.toFixed(4);
  document.getElementById('gDelta').className = 'greek-val ' + (totalDelta >= 0 ? 'pos' : 'neg');
  document.getElementById('gTheta').className = 'greek-val ' + (totalTheta >= 0 ? 'pos' : 'neg');
}

function calculate() {
  var allLegs = legs.length > 0 ? legs.slice() : [getInputLeg()];
  var params = getGlobalParams();
  var hasShares = activeStrategy && activeStrategy.hasShares;

  var center = params.underlying;
  var spread = Math.max(center * 0.3, 20);
  var lo = Math.max(0, center - spread);
  var hi = center + spread;
  var step = (hi - lo) / 200;

  var prices = [], payoffs = [];
  var maxProfit = -Infinity, maxLoss = Infinity;

  for (var p = lo; p <= hi; p += step) {
    var pnl = totalPayoff(allLegs, p);
    if (hasShares) pnl += (p - center) * 100;
    prices.push(p);
    payoffs.push(pnl);
    if (pnl > maxProfit) maxProfit = pnl;
    if (pnl < maxLoss) maxLoss = pnl;
  }

  var breakevens = findBreakevens(prices, payoffs, step);

  var pnlHigh = totalPayoff(allLegs, center * 3) + (hasShares ? (center*3 - center)*100 : 0);
  var pnlZero = totalPayoff(allLegs, 0) + (hasShares ? (0 - center)*100 : 0);
  var isUnlimitedProfit = pnlHigh > maxProfit * 2;
  var isUnlimitedLoss = pnlZero < maxLoss * 2 && Math.abs(pnlZero) > center * 50;

  displayResults(maxProfit, maxLoss, breakevens, isUnlimitedProfit, isUnlimitedLoss);
  displayGreeks(allLegs, center, params.dte / 365, params.iv, hasShares);
  renderChart(prices, payoffs, breakevens, center);
}

function renderChart(prices, payoffs, breakevens, underlying) {
  var ctx = document.getElementById('plChart').getContext('2d');
  if (plChart) plChart.destroy();

  var profitData = payoffs.map(function(v, i) { return {x: prices[i], y: v >= 0 ? v : 0}; });
  var lossData = payoffs.map(function(v, i) { return {x: prices[i], y: v < 0 ? v : 0}; });

  plChart = new Chart(ctx, {
    type: 'line',
    data: {
      datasets: [
        {
          label: 'Profit',
          data: profitData,
          borderColor: '#22c55e',
          backgroundColor: 'rgba(34,197,94,0.08)',
          fill: true, pointRadius: 0, borderWidth: 2, tension: 0
        },
        {
          label: 'Loss',
          data: lossData,
          borderColor: '#ef4444',
          backgroundColor: 'rgba(239,68,68,0.08)',
          fill: true, pointRadius: 0, borderWidth: 2, tension: 0
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: {mode: 'index', intersect: false},
      plugins: {
        legend: {display: true, labels: {color: '#94a3b8', font: {size: 12}}},
        tooltip: {
          callbacks: {
            title: function(items) { return 'Stock Price: $' + items[0].parsed.x.toFixed(2); },
            label: function(item) {
              var total = payoffs[item.dataIndex];
              return 'P&L: ' + (total >= 0 ? '+' : '') + '$' + total.toFixed(2);
            }
          }
        }
      },
      scales: {
        x: {
          type: 'linear',
          title: {display: true, text: 'Stock Price at Expiration ($)', color: '#94a3b8'},
          ticks: {color: '#94a3b8', callback: function(v){return '$'+v.toFixed(0)}},
          grid: {color: 'rgba(21,32,64,0.5)'}
        },
        y: {
          title: {display: true, text: 'Profit / Loss ($)', color: '#94a3b8'},
          ticks: {color: '#94a3b8', callback: function(v){return (v>=0?'+':'')+('$'+v.toFixed(0))}},
          grid: {color: 'rgba(21,32,64,0.5)'}
        }
      }
    }
  });
}

document.getElementById('calcBtn').addEventListener('click', function() {
  activeStrategy = null;
  if (legs.length === 0) { legs = [getInputLeg()]; renderLegs(); }
  calculate();
});

document.getElementById('resetBtn').addEventListener('click', function() {
  document.getElementById('optType').value = 'call';
  document.getElementById('optSide').value = 'buy';
  document.getElementById('strike').value = '105';
  document.getElementById('premium').value = '3.50';
  document.getElementById('contracts').value = '1';
  document.getElementById('underlying').value = '100';
  document.getElementById('dte').value = '30';
  document.getElementById('iv').value = '30';
  legs = [];
  activeStrategy = null;
  renderLegs();
  document.getElementById('resultsSection').style.display = 'none';
  document.getElementById('chartSection').style.display = 'none';
  document.getElementById('greeksSection').style.display = 'none';
  document.querySelectorAll('.strategy-card').forEach(function(c){c.classList.remove('active')});
  if (plChart) { plChart.destroy(); plChart = null; }
});

