import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How do you calculate options profit?","acceptedAnswer":{"@type":"Answer","text":"Options profit depends on whether you bought or sold the contract. For a long call: profit = (underlying price − strike price − premium paid) × 100 × contracts. For a long put: profit = (strike price − underlying price − premium paid) × 100 × contracts. The premium you paid is your maximum loss when buying options. Our calculator computes max profit, max loss, and breakeven price automatically for any single-leg or multi-leg strategy."}},
    {"@type":"Question","name":"What is breakeven price for an option?","acceptedAnswer":{"@type":"Answer","text":"Breakeven is the underlying stock price at which your option position neither makes nor loses money at expiration. For a long call: breakeven = strike price + premium paid. For a long put: breakeven = strike price − premium paid. For selling options, the breakeven formulas are reversed. Multi-leg strategies like spreads and iron condors have multiple breakeven points, which our calculator displays automatically."}},
    {"@type":"Question","name":"What are the Options Greeks?","acceptedAnswer":{"@type":"Answer","text":"The Greeks measure how an option's price changes in response to market factors. Delta (Δ) measures price sensitivity to a $1 move in the underlying — calls range 0 to 1, puts −1 to 0. Gamma (Γ) measures how fast delta changes. Theta (Θ) measures time decay — how much value the option loses per day. Vega (ν) measures sensitivity to a 1% change in implied volatility. Our calculator displays simplified Greek estimates for educational purposes."}},
    {"@type":"Question","name":"What is a covered call strategy?","acceptedAnswer":{"@type":"Answer","text":"A covered call involves owning 100 shares of a stock and selling a call option against them. Your max profit is capped at the strike price minus your stock purchase price, plus the premium received. Your max loss is the stock going to zero minus the premium received. It's a conservative income strategy: you collect premium in exchange for capping your upside. Best used when you're neutral-to-slightly-bullish on the underlying stock."}},
    {"@type":"Question","name":"What is an iron condor?","acceptedAnswer":{"@type":"Answer","text":"An iron condor is a four-leg neutral strategy that profits when the underlying stays within a range. You sell an out-of-the-money put and call, then buy a further out-of-the-money put and call for protection. Max profit is the total premium received. Max loss is the width of the wider spread minus premium received. Iron condors are popular for income generation and work best in low-volatility environments where the underlying trades sideways."}},
    {"@type":"Question","name":"How does time decay (theta) affect options?","acceptedAnswer":{"@type":"Answer","text":"Theta measures daily time decay — the amount an option loses in value each day, all else equal. Options lose value as expiration approaches because there's less time for the underlying to move favorably. Time decay accelerates in the final 30 days before expiration. Theta is negative for option buyers (hurts you) and positive for option sellers (helps you). At-the-money options have the highest theta, while deep in-the-money and far out-of-the-money options have lower theta."}},
    {"@type":"Question","name":"What is the difference between buying and selling options?","acceptedAnswer":{"@type":"Answer","text":"Buying options (going long) gives you the right but not obligation to buy (calls) or sell (puts) at the strike price. Your max loss is limited to the premium paid. Selling options (going short) obligates you to fulfill the contract if assigned. Sellers collect premium upfront but face potentially unlimited loss on naked calls or substantial loss on naked puts. Roughly 60-80% of options expire worthless, which statistically favors sellers — but the risk per trade is asymmetric."}},
    {"@type":"Question","name":"How accurate is an options profit calculator?","acceptedAnswer":{"@type":"Answer","text":"An options profit calculator is highly accurate for computing profit/loss at expiration based on the inputs you provide. However, real-world results may differ due to: bid-ask spreads (you rarely get the exact midpoint), early assignment risk for American-style options, changes in implied volatility, dividend payments, and commissions. The Greeks displayed are simplified estimates — for precise Greeks, use your broker's platform which uses real-time volatility surfaces. Use calculators for planning and education, not as exact predictions."}}
  ]
};

export const meta = {
  title: "Free Options Profit Calculator — Call & Put P&L Tool",
  description: "Calculate options profit, loss & breakeven for calls, puts & multi-leg strategies. Interactive P&L chart, Greeks display, and preset strategies including covered calls & iron condors.",
