</style>

<script>
  function setupCalculator() {
    const initialInput = document.getElementById('initialInvestment');
    const monthlyInput = document.getElementById('monthlyContribution');
    const yearsInput = document.getElementById('yearsInvested');
    const returnInput = document.getElementById('expectedReturn');
    const finalValueDisplay = document.getElementById('finalPortfolioValue');
    const totalContributionsDisplay = document.getElementById('totalContributionsValue');

    if (!initialInput || !monthlyInput || !yearsInput || !returnInput || !finalValueDisplay || !totalContributionsDisplay) return;

    function calculate() {
      const initial = parseFloat(initialInput.value) || 0;
      const monthly = parseFloat(monthlyInput.value) || 0;
      const years = parseFloat(yearsInput.value) || 0;
      const annualReturn = parseFloat(returnInput.value) || 0;

      const r = annualReturn / 100;
      const n = 12; // Compounded monthly
      const t = years;

      let balance = initial;
      let totalContributions = initial;

      for (let y = 0; y < t; y++) {
        for (let m = 0; m < 12; m++) {
          balance = balance * (1 + r / 12) + monthly;
          totalContributions += monthly;
        }
      }

      finalValueDisplay.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(balance);
      totalContributionsDisplay.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(totalContributions);
    }

    [initialInput, monthlyInput, yearsInput, returnInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    calculate(); // Initial calc
  }

  async function fetchMarketData() {
    const container = document.getElementById('market-data-container');
    if (!container) return;

    try {
      // Using a reliable public API for market data (Yahoo Finance via CORS proxy)
      // SPY ETF represents the S&P 500
      const symbol = 'SPY';
      const url = `https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1d`;
      const proxyUrl = `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`;

      const response = await fetch(proxyUrl);
      if (!response.ok) throw new Error('Failed to fetch proxy');

      const proxyData = await response.json();
      const data = JSON.parse(proxyData.contents);

      if (data.chart && data.chart.result && data.chart.result.length > 0) {
        const result = data.chart.result[0];
        const meta = result.meta;

        const price = meta.regularMarketPrice;
        const prevClose = meta.previousClose;
        const change = price - prevClose;
        const changePercent = (change / prevClose) * 100;

        const isPositive = change >= 0;
        const colorClass = isPositive ? 'color: #22c55e;' : 'color: #ef4444;';
        const sign = isPositive ? '+' : '';

        container.innerHTML = `
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <h3 style="margin: 0; color: var(--text-primary); font-size: 1.2rem;">S&P 500 ETF (SPY)</h3>
              <p style="margin: 0; color: var(--text-secondary); font-size: 0.9rem;">Real-time / Previous Close</p>
            </div>
            <div style="text-align: right;">
              <div style="font-family: var(--font-mono); font-size: 1.5rem; font-weight: 700; color: var(--text-primary);">
                $${price.toFixed(2)}
              </div>
              <div style="font-family: var(--font-mono); font-size: 1rem; font-weight: 600; ${colorClass}">
                ${sign}${change.toFixed(2)} (${sign}${changePercent.toFixed(2)}%)
              </div>
            </div>
          </div>
        `;
      } else {
        container.innerHTML = `<p style="margin: 0; color: var(--text-secondary);">Market data currently unavailable.</p>`;
      }
    } catch (error) {
      console.error("Failed to load market data:", error);
      container.innerHTML = `<p style="margin: 0; color: var(--text-secondary);">Live market data temporarily unavailable (null fallback).</p>`;
    }
  }

  // Use Astro's view transitions event if available, otherwise DOMContentLoaded
  document.addEventListener('astro:page-load', () => {
    setupCalculator();
    fetchMarketData();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setupCalculator();
      fetchMarketData();
    });
  } else {
    setupCalculator();
    fetchMarketData();
  }
</script>
