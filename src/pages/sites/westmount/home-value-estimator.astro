  {name:"Detroit",state:"MI",ppsf:130,median:195000,yoy:6.8}
];

// Populate metro dropdown
const fMetro = document.getElementById('fMetro');
METROS.forEach((m,i) => {
  fMetro.innerHTML += `<option value="${i}">${m.name}, ${m.state} — $${m.ppsf}/sqft</option>`;
});

// Metro table
let metroSort = 'ppsf', metroDir = -1;

function renderMetroTable(highlightIdx) {
  const sorted = METROS.map((m,i) => ({...m,idx:i}));
  sorted.sort((a,b) => {
    let va = a[metroSort], vb = b[metroSort];
    if (typeof va === 'string') return va.localeCompare(vb) * metroDir;
    return (va - vb) * metroDir;
  });
  const tbody = document.getElementById('metroBody');
  tbody.innerHTML = sorted.map(m => `<tr class="${m.idx === highlightIdx ? 'highlight-row' : ''}">
    <td>${m.name}</td>
    <td>${m.state}</td>
    <td class="num">$${m.ppsf}</td>
    <td class="num">$${m.median.toLocaleString()}</td>
    <td class="num ${m.yoy >= 0 ? 'pos' : 'neg'}">${m.yoy > 0 ? '+' : ''}${m.yoy.toFixed(1)}%</td>
  </tr>`).join('');
}

document.querySelectorAll('th[data-key]').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.key;
    if (metroSort === key) metroDir *= -1;
    else { metroSort = key; metroDir = th.dataset.type === 'num' ? -1 : 1; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(metroDir === 1 ? 'sorted-asc' : 'sorted-desc');
    renderMetroTable(parseInt(fMetro.value));
  });
});

renderMetroTable(-1);

// Estimation logic
function fmt(v) {
  if (v >= 1000000) return '$' + (v/1000000).toFixed(2) + 'M';
  return '$' + Math.round(v).toLocaleString();
}

function estimate() {
  const metroIdx = parseInt(fMetro.value);
  const metro = METROS[metroIdx];
  const sqft = parseFloat(document.getElementById('fSqft').value) || 2000;
  const beds = parseFloat(document.getElementById('fBeds').value) || 3;
  const baths = parseFloat(document.getElementById('fBaths').value) || 2;
  const year = parseInt(document.getElementById('fYear').value) || 1995;
  const lot = parseFloat(document.getElementById('fLot').value) || 0.25;
  const garage = parseInt(document.getElementById('fGarage').value) || 0;
  const pool = parseInt(document.getElementById('fPool').value) || 0;
  const condition = parseInt(document.getElementById('fCondition').value) || 3;

  let basePpsf = metro.ppsf;
  const drivers = [];

  // Size adjustment: larger homes have lower $/sqft (diminishing returns)
  let sizeAdj = 0;
  if (sqft > 2500) sizeAdj = -0.04 * Math.min((sqft - 2500) / 1000, 3);
  else if (sqft < 1200) sizeAdj = 0.06 * Math.min((1200 - sqft) / 400, 2);
  drivers.push({name:'Size Adjustment', impact: sizeAdj, desc: sqft > 2500 ? 'Larger homes have lower $/sqft' : sqft < 1200 ? 'Smaller homes have higher $/sqft' : 'Near-average size — no adjustment'});

  // Age adjustment: newer = premium, older = discount
  const age = 2026 - year;
  let ageAdj = 0;
  if (age <= 5) ageAdj = 0.10;
  else if (age <= 15) ageAdj = 0.05;
  else if (age <= 30) ageAdj = 0;
  else if (age <= 50) ageAdj = -0.05;
  else if (age <= 80) ageAdj = -0.10;
  else ageAdj = -0.15;
  drivers.push({name:'Age Premium/Discount', impact: ageAdj, desc: age <= 15 ? `Built ${year} — newer home premium` : age <= 30 ? `Built ${year} — no age adjustment` : `Built ${year} — older home discount`});

  // Bedroom adjustment (baseline = 3)
  const bedDiff = beds - 3;
  let bedAdj = 0;
  if (bedDiff > 0) bedAdj = bedDiff * 0.03; // diminishing returns built into flat 3%
  else if (bedDiff < 0) bedAdj = bedDiff * 0.05; // losing bedrooms hurts more
  drivers.push({name:'Bedroom Count', impact: bedAdj, desc: `${beds} bed${beds !== 1 ? 's' : ''} vs. 3-bed baseline`});

  // Bathroom adjustment (baseline = 2)
  const bathDiff = baths - 2;
  let bathAdj = 0;
  if (bathDiff > 0) bathAdj = Math.min(bathDiff * 0.04, 0.12);
  else if (bathDiff < 0) bathAdj = bathDiff * 0.06;
  drivers.push({name:'Bathroom Count', impact: bathAdj, desc: `${baths} bath${baths !== 1 ? 's' : ''} vs. 2-bath baseline`});

  // Lot size adjustment (baseline = 0.25 acres)
  let lotAdj = 0;
  if (lot > 0.5) lotAdj = 0.03 * Math.min((lot - 0.25) / 0.25, 4);
  else if (lot < 0.15) lotAdj = -0.04;
  drivers.push({name:'Lot Size', impact: lotAdj, desc: `${lot} acres vs. 0.25-acre baseline`});

  // Condition multiplier (baseline = 3)
  const condMap = {1: -0.20, 2: -0.10, 3: 0, 4: 0.10, 5: 0.20};
  const condAdj = condMap[condition];
  const condLabels = {1:'Poor',2:'Fair',3:'Average',4:'Good',5:'Excellent'};
  drivers.push({name:'Condition', impact: condAdj, desc: `${condLabels[condition]} condition (${condition}/5)`});

  // Garage bonus
  const garageAdj = garage * 0.025;
  drivers.push({name:'Garage', impact: garageAdj, desc: garage > 0 ? `${garage}-car garage` : 'No garage'});

  // Pool bonus
  const poolAdj = pool ? 0.04 : 0;
  drivers.push({name:'Pool', impact: poolAdj, desc: pool ? 'Pool adds value' : 'No pool'});

  // Calculate total adjustment
  const totalAdj = sizeAdj + ageAdj + bedAdj + bathAdj + lotAdj + condAdj + garageAdj + poolAdj;
  const adjPpsf = basePpsf * (1 + totalAdj);
  const midValue = adjPpsf * sqft;
  const lowValue = midValue * 0.90;
  const highValue = midValue * 1.10;

  // Show results
  document.getElementById('results').classList.add('visible');
  document.getElementById('valLow').textContent = fmt(lowValue);
  document.getElementById('valMid').textContent = fmt(midValue);
  document.getElementById('valHigh').textContent = fmt(highValue);
  document.getElementById('valLowSqft').textContent = `$${Math.round(adjPpsf * 0.9)}/sqft`;
  document.getElementById('valMidSqft').textContent = `$${Math.round(adjPpsf)}/sqft`;
  document.getElementById('valHighSqft').textContent = `$${Math.round(adjPpsf * 1.1)}/sqft`;

  // Comparison bars
  const maxPpsf = Math.max(adjPpsf, metro.ppsf) * 1.2;
  document.getElementById('compBars').innerHTML = `
    <div class="comp-row">
      <div class="comp-label">Your Estimate</div>
      <div class="comp-bar-bg"><div class="comp-bar yours" style="width:${(adjPpsf/maxPpsf)*100}%"></div></div>
      <div class="comp-val">$${Math.round(adjPpsf)}/sqft</div>
    </div>
    <div class="comp-row">
      <div class="comp-label">${metro.name} Median</div>
      <div class="comp-bar-bg"><div class="comp-bar median" style="width:${(metro.ppsf/maxPpsf)*100}%"></div></div>
      <div class="comp-val">$${metro.ppsf}/sqft</div>
    </div>
    <div class="comp-row">
      <div class="comp-label">Difference</div>
      <div class="comp-bar-bg"></div>
      <div class="comp-val ${adjPpsf >= metro.ppsf ? 'pos' : 'neg'}">${adjPpsf >= metro.ppsf ? '+' : ''}${((adjPpsf/metro.ppsf - 1)*100).toFixed(1)}%</div>
    </div>
  `;

  // Driver cards
  const dGrid = document.getElementById('driverGrid');
  dGrid.innerHTML = drivers.map(d => `<div class="driver-card">
    <div class="driver-name">${d.name}</div>
    <div class="driver-impact ${d.impact > 0 ? 'pos' : d.impact < 0 ? 'neg' : 'neutral'}">${d.impact > 0 ? '+' : ''}${(d.impact * 100).toFixed(1)}%</div>
    <div class="driver-desc">${d.desc}</div>
  </div>`).join('');

  // Highlight selected metro in table
  renderMetroTable(metroIdx);

  // Scroll to results
  document.getElementById('results').scrollIntoView({behavior:'smooth', block:'start'});
}

document.getElementById('estimateBtn').addEventListener('click', estimate);

document.getElementById('resetBtn').addEventListener('click', () => {
  document.getElementById('fSqft').value = 2000;
  document.getElementById('fBeds').value = '3';
  document.getElementById('fBaths').value = '2';
  document.getElementById('fYear').value = 1995;
  document.getElementById('fLot').value = 0.25;
  document.getElementById('fGarage').value = '1';
  document.getElementById('fPool').value = '0';
  document.getElementById('fCondition').value = '3';
  document.getElementById('fMetro').value = '0';
  document.getElementById('results').classList.remove('visible');
  renderMetroTable(-1);
});

// FAQ
const faqs = [
  {q:"How does this home value estimator work?",a:"Our estimator uses a comparable analysis approach. It starts with the median price per square foot for your metro area, then applies adjustments for property characteristics: square footage, bedroom/bathroom count, year built, lot size, garage, pool, and condition. The result is an estimated value range (low, mid, high) that reflects how these factors typically influence home prices in your region. It's educational — not a replacement for a professional appraisal."},
  {q:"How accurate is a home value estimate without an appraisal?",a:"Online estimators typically have a median error rate of 5–15% depending on data quality and property type. Our tool uses regional price-per-square-foot baselines for 30 major metro areas with adjustments for key value drivers. For the most accurate valuation, combine this estimate with recent comparable sales in your specific neighborhood and a licensed appraiser's assessment."},
  {q:"What factors most affect home value?",a:"Location is the single biggest factor — identical homes in different metros can vary by 300%+. After location, the top value drivers are: square footage, condition and updates (a fully renovated home commands 15–25% more), lot size, bedroom/bathroom count, and age. A 3rd bathroom adds more value than a 5th bedroom, and newer homes command a premium in most markets."},
  {q:"What is price per square foot and why does it matter?",a:"Price per square foot ($/sqft) is calculated by dividing a home's sale price by its livable square footage. It's the most common metric for comparing home values across sizes and neighborhoods. In 2026, US median $/sqft ranges from ~$130 in affordable metros like Detroit to $750+ in San Francisco. However, $/sqft decreases as homes get larger due to diminishing marginal returns on space."},
  {q:"Should I use this estimate for buying or selling decisions?",a:"Use this tool as a starting point for understanding approximate value, not as a definitive price. For buying, compare against the listing price and recent comps within 0.5 miles. For selling, get a comparative market analysis (CMA) from a local agent and consider a professional appraisal ($300–$500). This tool is best for quick ballpark estimates, understanding how features affect value, and comparing across metros."}
];

const faqEl = document.getElementById('faq');
faqs.forEach(f => {
  faqEl.innerHTML += `<div class="faq-item"><div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div></div>`;
});
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});
  </script>
</SiteLayout>