const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What makes a good growth stock in May 2025?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Strong growth stocks in May 2025 exhibit robust revenue expansion, expanding profit margins, and strong competitive moats, often driven by technological innovation."
          }
        },
        {
          "@type": "Question",
          "name": "Are tech stocks still the best growth investments?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While technology remains a dominant sector, opportunities also exist in healthcare and consumer discretionary sectors, depending on broader macroeconomic trends."
          }
        },
        {
          "@type": "Question",
          "name": "How does interest rate policy affect growth stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Higher interest rates generally compress the valuation multiples of growth stocks by discounting future cash flows more heavily, while lower rates act as a tailwind."
          }
        },
        {
          "@type": "Question",
          "name": "Should I look at P/E ratio for growth stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While P/E is useful, growth investors often focus more on metrics like Price-to-Sales (P/S), forward P/E, and PEG ratios to contextualize rapid earnings expansion."
          }
        },
        {
          "@type": "Question",
          "name": "Is May a historically good month to buy stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The adage 'Sell in May and go away' suggests seasonal weakness, but long-term investors benefit more from consistent dollar-cost averaging rather than trying to time seasonal dips."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": "Top Growth Stocks to Buy in May 2025",
      "description": "Are you missing out on the market's biggest movers? Discover the high-growth stocks quietly dominating May 2025 before the next major breakout.",
      "author": { "@type": "Organization", "name": "Westmount Fundamentals" }
    }
  ]
};
