  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const sectorFilter = document.getElementById('sectorFilter');
      const mcFilter = document.getElementById('mcFilter');
      const rows = document.querySelectorAll('.item-row');
      const cards = document.querySelectorAll('.item-card');

      function filterItems() {
        const sector = sectorFilter.value;
        const minMc = parseFloat(mcFilter.value);

        rows.forEach(row => {
          const rSector = row.getAttribute('data-sector');
          const rMc = parseFloat(row.getAttribute('data-mc'));
          const sectorMatch = sector === 'all' || rSector === sector;
          const mcMatch = rMc >= minMc;
          row.style.display = (sectorMatch && mcMatch) ? '' : 'none';
        });

        cards.forEach(card => {
          const cSector = card.getAttribute('data-sector');
          const cMc = parseFloat(card.getAttribute('data-mc'));
          const sectorMatch = sector === 'all' || cSector === sector;
          const mcMatch = cMc >= minMc;
          card.style.display = (sectorMatch && mcMatch) ? 'block' : 'none';
        });
      }

      if(sectorFilter) sectorFilter.addEventListener('change', filterItems);
      if(mcFilter) mcFilter.addEventListener('change', filterItems);
    });

    function sortTable(tableId, n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById(tableId);
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let valX = x.innerHTML.replace(/[^0-9.-]+/g,"");
          let valY = y.innerHTML.replace(/[^0-9.-]+/g,"");

          if(valX && valY && !isNaN(valX) && !isNaN(valY)) {
             if (dir == "asc") {
              if (parseFloat(valX) > parseFloat(valY)) { shouldSwitch = true; break; }
            } else {
              if (parseFloat(valX) < parseFloat(valY)) { shouldSwitch = true; break; }
            }
          } else {
            if (dir == "asc") {
              if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            } else {
              if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }
  </script>
