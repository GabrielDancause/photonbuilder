---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "EBITDA Calculator",
  description: "Calculate EBITDA and EBITDA Margin with this free interactive tool. Includes top-down and bottom-up reverse calculations.",
  category: "tool",
  published: "2026-03-17",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "EBITDA Calculator",
    "description": "Calculate EBITDA and EBITDA Margin with this free interactive tool. Includes top-down and bottom-up reverse calculations.",
    "author": {
      "@type": "Organization",
      "name": "Westmount Fundamentals"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
            "@type": "Question",
            "name": "What is EBITDA?",
            "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "EBITDA stands for Earnings Before Interest, Taxes, Depreciation, and Amortization. It is a measure of a company's overall financial performance and is used as an alternative to net income in some circumstances."
            }
      },
      {
            "@type": "Question",
            "name": "How do you calculate EBITDA?",
            "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "You can calculate it two ways: starting with Net Income and adding back Interest, Taxes, Depreciation, and Amortization (bottom-up), or starting with Revenue and subtracting COGS and Operating Expenses excluding D&A (top-down)."
            }
      },
      {
            "@type": "Question",
            "name": "What is a good EBITDA margin?",
            "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "A good EBITDA margin varies widely by industry, but generally, a margin above 10% is considered okay, while above 20% is considered very good. Software companies often have margins above 30%."
            }
      }
]
  }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/ebitda-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>EBITDA Calculator</h1>
      <p class="subtitle">Calculate EBITDA and EBITDA Margin with this free interactive tool. Includes top-down and bottom-up reverse calculations.</p>
    </div>


    <div class="calculator-grid">
      <!-- Top-down -->
      <div class="calculator-container card">
        <div class="calc-header">
          <h2>Top-Down EBITDA Calculator</h2>
          <p>Calculate from Revenue downwards.</p>
        </div>
        <div class="input-group">
          <label for="rev">Revenue ($)</label>
          <input type="number" id="rev" value="1000000" step="1000" />
        </div>
        <div class="input-group">
          <label for="cogs">Cost of Goods Sold (COGS) ($)</label>
          <input type="number" id="cogs" value="400000" step="1000" />
        </div>
        <div class="input-group">
          <label for="opex">Operating Expenses (Excluding D&A) ($)</label>
          <input type="number" id="opex" value="300000" step="1000" />
        </div>
        <div class="result-card">
          <h3>EBITDA</h3>
          <div class="result-value" id="top-ebitda">$0</div>
          <p>Margin: <span id="top-margin">0%</span></p>
        </div>
      </div>

      <!-- Bottom-up -->
      <div class="calculator-container card">
        <div class="calc-header">
          <h2>Bottom-Up (Reverse) EBITDA Calculator</h2>
          <p>Calculate from Net Income upwards.</p>
        </div>
        <div class="input-group">
          <label for="net">Net Income ($)</label>
          <input type="number" id="net" value="150000" step="1000" />
        </div>
        <div class="input-group">
          <label for="interest">Interest Expense ($)</label>
          <input type="number" id="interest" value="20000" step="1000" />
        </div>
        <div class="input-group">
          <label for="tax">Taxes ($)</label>
          <input type="number" id="tax" value="50000" step="1000" />
        </div>
        <div class="input-group">
          <label for="da">Depreciation & Amortization ($)</label>
          <input type="number" id="da" value="80000" step="1000" />
        </div>
        <div class="result-card secondary">
          <h3>EBITDA</h3>
          <div class="result-value" id="bot-ebitda">$0</div>
        </div>
      </div>
    </div>

    <div class="formula-visual">
      <h2>The EBITDA Formula</h2>
      <div class="visual-boxes">
        <div class="box">Revenue</div>
        <div class="math-op">-</div>
        <div class="box">COGS</div>
        <div class="math-op">-</div>
        <div class="box">OpEx</div>
        <div class="math-op">=</div>
        <div class="box highlight">EBITDA</div>
      </div>
      <p style="text-align: center; margin: 1rem 0;">OR</p>
      <div class="visual-boxes">
        <div class="box">Net Income</div>
        <div class="math-op">+</div>
        <div class="box">Interest</div>
        <div class="math-op">+</div>
        <div class="box">Taxes</div>
        <div class="math-op">+</div>
        <div class="box">D&A</div>
        <div class="math-op">=</div>
        <div class="box highlight">EBITDA</div>
      </div>
    </div>

    <script is:inline>
      function formatCurrency(val) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
      }
      function calcTop() {
        const rev = parseFloat(document.getElementById('rev').value) || 0;
        const cogs = parseFloat(document.getElementById('cogs').value) || 0;
        const opex = parseFloat(document.getElementById('opex').value) || 0;
        const ebitda = rev - cogs - opex;
        document.getElementById('top-ebitda').textContent = formatCurrency(ebitda);
        const margin = rev > 0 ? ((ebitda / rev) * 100).toFixed(1) + '%' : '0%';
        document.getElementById('top-margin').textContent = margin;
      }
      function calcBot() {
        const net = parseFloat(document.getElementById('net').value) || 0;
        const interest = parseFloat(document.getElementById('interest').value) || 0;
        const tax = parseFloat(document.getElementById('tax').value) || 0;
        const da = parseFloat(document.getElementById('da').value) || 0;
        const ebitda = net + interest + tax + da;
        document.getElementById('bot-ebitda').textContent = formatCurrency(ebitda);
      }
      ['rev','cogs','opex'].forEach(id => document.getElementById(id).addEventListener('input', calcTop));
      ['net','interest','tax','da'].forEach(id => document.getElementById(id).addEventListener('input', calcBot));
      calcTop(); calcBot();
    </script>
<section class="related-guides">
  <h2>Related EBITDA Guides</h2>
  <ul>
    <li><a href="/what-is-ebitda-margin">What is EBITDA Margin?</a></li>
    <li><a href="/ebitda-vs-net-income">EBITDA vs Net Income</a></li>
    <li><a href="/ebitda-vs-revenue">EBITDA vs Revenue</a></li>
    <li><a href="/adjusted-ebitda">Adjusted EBITDA Explained</a></li>
    <li><a href="/debt-to-ebitda-ratio">Debt to EBITDA Ratio</a></li>
    <li><a href="/good-ebitda-margin">What is a Good EBITDA Margin?</a></li>
    <li><a href="/ev-ebitda-sectors">EV/EBITDA by Sector</a></li>
  </ul>
</section>    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is EBITDA?</summary>
        <p>EBITDA stands for Earnings Before Interest, Taxes, Depreciation, and Amortization. It is a measure of a company's overall financial performance and is used as an alternative to net income in some circumstances.</p>
      </details>
      <details>
        <summary>How do you calculate EBITDA?</summary>
        <p>You can calculate it two ways: starting with Net Income and adding back Interest, Taxes, Depreciation, and Amortization (bottom-up), or starting with Revenue and subtracting COGS and Operating Expenses excluding D&A (top-down).</p>
      </details>
      <details>
        <summary>What is a good EBITDA margin?</summary>
        <p>A good EBITDA margin varies widely by industry, but generally, a margin above 10% is considered okay, while above 20% is considered very good. Software companies often have margins above 30%.</p>
      </details>
    </section>

    <style is:inline>
      .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
      .hero { text-align: center; padding: 3rem 0 2rem; }
      .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
      .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

      .calculator-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; margin: 2rem 0; }
      @media (min-width: 768px) { .calculator-grid { grid-template-columns: 1fr 1fr; } }

      .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; }
      .calc-header { margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; }
      .calc-header h2 { font-size: 1.4rem; margin: 0 0 0.25rem 0; }
      .calc-header p { margin: 0; color: var(--text-secondary); font-size: 0.9rem; }

      .input-group { margin-bottom: 1.25rem; }
      .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; }
      input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
      input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

      .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin-top: 2rem; text-align: center; }
      .result-card.secondary { background: color-mix(in srgb, #10b981 10%, transparent); border-color: #10b981; }
      .result-card h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-secondary); }
      .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
      .secondary .result-value { color: #10b981; }

      .explainer { margin: 3rem 0; line-height: 1.6; }
      .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; }
      .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 0.75rem; }
      .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
      .explainer ul { margin-bottom: 1rem; color: var(--text-secondary); padding-left: 1.5rem; }
      .explainer li { margin-bottom: 0.5rem; }

      .data-table { width: 100%; border-collapse: collapse; margin: 2rem 0; background: var(--card-bg); border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
      .data-table th, .data-table td { padding: 1rem; text-align: left; border-bottom: 1px solid var(--border-color); }
      .data-table th { background: color-mix(in srgb, var(--accent-color) 10%, transparent); font-weight: bold; }
      .data-table tr:last-child td { border-bottom: none; }

      .related-guides { margin: 4rem 0; padding: 2rem; background: var(--card-bg); border-radius: 12px; border: 1px solid var(--border-color); }
      .related-guides h2 { margin-top: 0; margin-bottom: 1.5rem; font-size: 1.5rem; }
      .related-guides ul { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr; gap: 1rem; }
      @media (min-width: 600px) { .related-guides ul { grid-template-columns: 1fr 1fr; } }
      .related-guides a { color: var(--accent-color); text-decoration: none; font-weight: 600; padding: 0.5rem; display: block; border-radius: 6px; transition: background 0.2s; }
      .related-guides a:hover { background: color-mix(in srgb, var(--accent-color) 10%, transparent); }

      .faq-section { margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 2rem; }
      .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; }
      .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
      .faq-section summary { font-weight: 600; cursor: pointer; }
      .faq-section details p { margin: 1rem 0 0 0; color: var(--text-secondary); line-height: 1.5; }

      .formula-visual { text-align: center; margin: 3rem 0; }
      .visual-boxes { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 1rem; margin: 1rem 0; }
      .visual-boxes .box { background: var(--card-bg); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); font-weight: bold; min-width: 100px; }
      .visual-boxes .box.highlight { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border-color: var(--accent-color); color: var(--accent-color); }
      .visual-boxes .math-op { font-size: 1.5rem; font-weight: bold; }
    </style>
  </div>
</SiteLayout>
