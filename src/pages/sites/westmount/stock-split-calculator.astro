        </a>
        <a class="related-card" href="/stock-screener">
          <h3>Stock Screener</h3>
          <p>Filter S&amp;P 500 stocks by PE ratio, dividend yield, market cap, sector, and 52-week performance.</p>
        </a>
      </div>
    </div>

    <div class="methodology">
      <h2>Methodology</h2>
      <p>Stock split calculations use the standard formula: New Shares = Old Shares × (Split Ratio). New Price = Old Price ÷ (Split Ratio). For reverse splits, the ratio is inverted. Total position value (Shares × Price) remains constant before and after the split. Cost basis per share is adjusted by the same ratio.</p>
      <p>Historical split data is sourced from public company records and SEC filings. Pre-split and post-split prices are approximate closing prices on the split date. All figures are for educational reference.</p>
    </div>

    <div class="disclaimer">This calculator is for informational and educational purposes only. Not investment advice. Stock splits do not change the total value of your investment. Always consult a tax professional regarding cost basis adjustments.</div>
</div>

  <script is:inline>
// Notable stock split history
const SPLITS = [
  {company:"Apple",ticker:"AAPL",date:"Jun 2020",ratio:"4:1",prePx:"~$500",postPx:"~$125",notes:"5th split in company history. Previous: 2014 (7:1), 2005, 2000, 1987 (all 2:1)"},
  {company:"Tesla",ticker:"TSLA",date:"Aug 2022",ratio:"3:1",prePx:"~$891",postPx:"~$297",notes:"Second split after 5:1 in Aug 2020. Made shares accessible to employees and retail investors"},
  {company:"Nvidia",ticker:"NVDA",date:"Jun 2024",ratio:"10:1",prePx:"~$1,200",postPx:"~$120",notes:"Driven by AI boom. Previous: 2021 (4:1), 2007 (3:2), 2006 (2:1), 2000 (2:1)"},
  {company:"Amazon",ticker:"AMZN",date:"Jun 2022",ratio:"20:1",prePx:"~$2,447",postPx:"~$122",notes:"First split since 1999. Enabled Dow Jones inclusion consideration"},
  {company:"Alphabet (Google)",ticker:"GOOG",date:"Jul 2022",ratio:"20:1",prePx:"~$2,256",postPx:"~$113",notes:"First-ever split for Google. Structured as a stock dividend of 19 additional shares"},
  {company:"Chipotle",ticker:"CMG",date:"Jun 2024",ratio:"50:1",prePx:"~$3,283",postPx:"~$66",notes:"Largest split ratio on NYSE at the time. Share price had climbed above $3,000"},
  {company:"Broadcom",ticker:"AVGO",date:"Jul 2024",ratio:"10:1",prePx:"~$1,730",postPx:"~$173",notes:"Split following strong growth driven by AI networking chips and VMware acquisition"},
  {company:"Walmart",ticker:"WMT",date:"Feb 2024",ratio:"3:1",prePx:"~$170",postPx:"~$57",notes:"First split since 1999. Done to make shares accessible for employee stock purchase plan"},
  {company:"Shopify",ticker:"SHOP",date:"Jun 2022",ratio:"10:1",prePx:"~$380",postPx:"~$38",notes:"Split coincided with creation of a founder share granting CEO extra voting power"},
  {company:"Berkshire Hathaway",ticker:"BRK.B",date:"Jan 2010",ratio:"50:1",prePx:"~$3,476",postPx:"~$70",notes:"Class B only. Class A (BRK.A) has never split, trades above $600,000"},
  {company:"Lam Research",ticker:"LRCX",date:"Oct 2024",ratio:"10:1",prePx:"~$817",postPx:"~$82",notes:"Semiconductor equipment maker split amid AI-driven demand surge"},
  {company:"Sony Group",ticker:"SONY",date:"Oct 2024",ratio:"5:1",prePx:"~$94",postPx:"~$19",notes:"Split to increase accessibility for Japanese and international retail investors"},
  {company:"Williams-Sonoma",ticker:"WSM",date:"Mar 2024",ratio:"2:1",prePx:"~$290",postPx:"~$145",notes:"First split in company history following strong e-commerce growth"},
  {company:"GE Aerospace",ticker:"GE",date:"Aug 2021",ratio:"1:8",prePx:"~$13",postPx:"~$104",notes:"Reverse split to boost share price after years of decline before restructuring"},
  {company:"Citigroup",ticker:"C",date:"May 2011",ratio:"1:10",prePx:"~$4.50",postPx:"~$45",notes:"Reverse split after financial crisis. Share price had fallen from pre-crisis highs above $500"}
];

// Render split history table
const histTbody = document.getElementById('historyTbody');
SPLITS.forEach(s => {
  histTbody.innerHTML += `<tr>
    <td style="font-weight:600">${s.company}</td>
    <td class="ticker">${s.ticker}</td>
    <td style="white-space:nowrap">${s.date}</td>
    <td style="font-family:'JetBrains Mono',monospace;font-weight:600">${s.ratio}</td>
    <td class="num">${s.prePx}</td>
    <td class="num">${s.postPx}</td>
    <td style="font-size:12px;color:var(--text-secondary);max-width:250px">${s.notes}</td>
  </tr>`;
});

// Mode toggle
let isReverse = false;
const modeForward = document.getElementById('modeForward');
const modeReverse = document.getElementById('modeReverse');
const splitRatioSelect = document.getElementById('splitRatio');
const ratioHint = document.getElementById('ratioHint');

const forwardRatios = [
  {value:"2:1",label:"2-for-1"},
  {value:"3:1",label:"3-for-1"},
  {value:"4:1",label:"4-for-1"},
  {value:"5:1",label:"5-for-1"},
  {value:"10:1",label:"10-for-1"},
  {value:"20:1",label:"20-for-1"},
  {value:"3:2",label:"3-for-2"},
  {value:"custom",label:"Custom ratio"}
];
const reverseRatios = [
  {value:"1:2",label:"1-for-2"},
  {value:"1:3",label:"1-for-3"},
  {value:"1:4",label:"1-for-4"},
  {value:"1:5",label:"1-for-5"},
  {value:"1:10",label:"1-for-10"},
  {value:"1:20",label:"1-for-20"},
  {value:"2:3",label:"2-for-3"},
  {value:"custom",label:"Custom ratio"}
];

function populateRatios(ratios) {
  splitRatioSelect.innerHTML = '';
  ratios.forEach(r => {
    const opt = document.createElement('option');
    opt.value = r.value;
    opt.textContent = r.label;
    splitRatioSelect.appendChild(opt);
  });
  updateHint();
}

function updateHint() {
  const v = splitRatioSelect.value;
  const customEl = document.getElementById('customRatio');
  if (v === 'custom') {
    customEl.classList.add('show');
    ratioHint.textContent = 'Enter your custom split ratio above';
    return;
  }
  customEl.classList.remove('show');
  const [newS, oldS] = v.split(':').map(Number);
  if (newS > oldS) {
    ratioHint.textContent = `Each share becomes ${newS} shares. Price divides by ${newS}${oldS > 1 ? '/' + oldS : ''}`;
  } else {
    ratioHint.textContent = `Every ${oldS} shares become ${newS} share${newS > 1 ? 's' : ''}. Price multiplies by ${oldS}${newS > 1 ? '/' + newS : ''}`;
  }
}

modeForward.addEventListener('click', () => {
  isReverse = false;
  modeForward.classList.add('active');
  modeReverse.classList.remove('active');
  populateRatios(forwardRatios);
});

modeReverse.addEventListener('click', () => {
  isReverse = true;
  modeReverse.classList.add('active');
  modeForward.classList.remove('active');
  populateRatios(reverseRatios);
});

splitRatioSelect.addEventListener('change', updateHint);

// Calculator
document.getElementById('calcBtn').addEventListener('click', calculate);
document.querySelectorAll('.calc-inputs input').forEach(input => {
  input.addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
});

function calculate() {
  const shares = parseFloat(document.getElementById('sharesOwned').value);
  const price = parseFloat(document.getElementById('pricePerShare').value);
  const costBasis = parseFloat(document.getElementById('costBasis').value);
  const ratioVal = splitRatioSelect.value;

  if (!shares || shares <= 0) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid number of shares.</div>';
    return;
  }
  if (!price || price <= 0) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid price per share.</div>';
    return;
  }

  let newFor, oldFor;
  if (ratioVal === 'custom') {
    newFor = parseFloat(document.getElementById('customNew').value);
    oldFor = parseFloat(document.getElementById('customOld').value);
    if (!newFor || !oldFor || newFor <= 0 || oldFor <= 0) {
      document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid custom ratio.</div>';
      return;
    }
  } else {
    [newFor, oldFor] = ratioVal.split(':').map(Number);
  }

  const multiplier = newFor / oldFor;
  const resultShares = shares * multiplier;
  const resultPrice = price / multiplier;
  const totalValue = shares * price;
  const resultCostBasis = costBasis > 0 ? costBasis / multiplier : null;

  // Format numbers
  const fmt = (n, d) => n.toLocaleString(undefined, {minimumFractionDigits: d, maximumFractionDigits: d});
  const fmtShares = resultShares % 1 === 0 ? resultShares.toLocaleString() : fmt(resultShares, 4);
  const fmtPrice = fmt(resultPrice, 2);
  const fmtTotal = fmt(totalValue, 2);
  const origShares = shares % 1 === 0 ? shares.toLocaleString() : fmt(shares, 4);
  const origPrice = fmt(price, 2);

  let html = `<div style="text-align:center;font-size:13px;color:var(--text-secondary);margin-bottom:16px">${isReverse ? 'Reverse' : 'Forward'} Split — <strong style="color:var(--text-primary)">${newFor}-for-${oldFor}</strong></div>`;

  html += '<div class="result-grid">';
  html += `<div class="result-box highlight"><div class="val">${fmtShares}</div><div class="label">New Shares</div></div>`;
  html += `<div class="result-box highlight"><div class="val">$${fmtPrice}</div><div class="label">New Price/Share</div></div>`;
  html += `<div class="result-box full"><div class="val">$${fmtTotal}</div><div class="label">Total Value (Unchanged)</div></div>`;
  if (resultCostBasis !== null) {
    const fmtCost = fmt(resultCostBasis, 2);
    html += `<div class="result-box full"><div class="val">$${fmtCost}</div><div class="label">New Cost Basis / Share</div></div>`;
  }
  html += '</div>';

  // Before/After comparison bars
  html += '<div class="comparison-bars">';
  html += '<div class="bar-label">Before vs After Comparison</div>';

  // Shares bar
  const sharesMax = Math.max(shares, resultShares);
  const sharesBPct = (shares / sharesMax) * 100;
  const sharesAPct = (resultShares / sharesMax) * 100;
  html += '<div class="bar-group">';
  html += '<div class="bar-group-label">Shares</div>';
  html += `<div class="bar-row"><span class="bar-tag">Before</span><div class="bar-track"><div class="bar-fill before" style="width:${sharesBPct}%">${origShares}</div></div></div>`;
  html += `<div class="bar-row"><span class="bar-tag">After</span><div class="bar-track"><div class="bar-fill after" style="width:${sharesAPct}%">${fmtShares}</div></div></div>`;
  html += '</div>';

  // Price bar
  const priceMax = Math.max(price, resultPrice);
  const priceBPct = (price / priceMax) * 100;
  const priceAPct = (resultPrice / priceMax) * 100;
  html += '<div class="bar-group">';
  html += '<div class="bar-group-label">Price per Share</div>';
  html += `<div class="bar-row"><span class="bar-tag">Before</span><div class="bar-track"><div class="bar-fill before" style="width:${priceBPct}%">$${origPrice}</div></div></div>`;
  html += `<div class="bar-row"><span class="bar-tag">After</span><div class="bar-track"><div class="bar-fill after" style="width:${priceAPct}%">$${fmtPrice}</div></div></div>`;
  html += '</div>';

  // Total value bar (same width — value unchanged)
  html += '<div class="bar-group">';
  html += '<div class="bar-group-label">Total Value</div>';
  html += `<div class="bar-row"><span class="bar-tag">Before</span><div class="bar-track"><div class="bar-fill before" style="width:100%">$${fmtTotal}</div></div></div>`;
  html += `<div class="bar-row"><span class="bar-tag">After</span><div class="bar-track"><div class="bar-fill after" style="width:100%">$${fmtTotal}</div></div></div>`;
  html += '</div>';

  html += '</div>';

  document.getElementById('calcResults').innerHTML = html;
}

// FAQ
const faqs = [
  {q:"What is a stock split and how does it work?",a:"A stock split increases the number of shares outstanding while proportionally reducing the price per share. In a 2-for-1 split, each share becomes two shares at half the price. Your total investment value remains exactly the same — you simply own more shares at a lower price. Companies split their stock to make shares more accessible to retail investors and to increase liquidity."},
  {q:"What is a reverse stock split?",a:"A reverse stock split reduces the number of shares while proportionally increasing the price per share. In a 1-for-10 reverse split, every 10 shares become 1 share at 10x the price. Total value remains unchanged. Companies typically do reverse splits to avoid exchange delisting, to appear more attractive to institutional investors, or to reduce shares outstanding. Reverse splits are often viewed negatively because they frequently signal a struggling company."},
  {q:"Does a stock split change the value of my investment?",a:"No. If you own 100 shares at $200 each ($20,000 total) and the company does a 2-for-1 split, you will own 200 shares at $100 each — still $20,000. However, splits can indirectly boost short-term sentiment and trading volume. Research shows stocks tend to slightly outperform in the 12 months following a split announcement."},
  {q:"How does a stock split affect my cost basis?",a:"Your cost basis per share is adjusted proportionally. If you bought 50 shares at $400 (cost basis $400/share) and there is a 4-for-1 split, your new cost basis becomes $100/share across 200 shares. Total cost basis stays at $20,000. Your brokerage automatically adjusts records, but you should verify the adjustment for tax purposes."},
  {q:"Why do companies like Apple and Tesla split their stock?",a:"To lower the share price and make it more accessible. Apple has split five times (most recently 4:1 in 2020), Tesla did 5:1 in 2020 and 3:1 in 2022. High prices deter retail investors, reduce options activity, and limit price-weighted index inclusion. While fractional shares reduce the accessibility argument, splits remain popular for signaling confidence and boosting retail interest."},
  {q:"What is the most common stock split ratio?",a:"The most common ratio is 2-for-1, followed by 3-for-1 and 3-for-2. Recently, large tech companies favor bigger ratios: Amazon 20:1 (2022), Google 20:1 (2022), Nvidia 10:1 (2024), Chipotle 50:1 (2024). The trend toward larger ratios reflects how high stock prices have climbed. Companies aim for a post-split price between $50 and $200."},
  {q:"How does a stock split affect options contracts?",a:"Options are adjusted proportionally by the Options Clearing Corporation. In a 2-for-1 split, each contract becomes 2 contracts with the strike price halved. Non-standard splits (like 3-for-2) can create adjusted contracts with non-standard deliverables (e.g., 150 shares per contract), which may have wider spreads and less liquidity. Total options position value stays the same."},
  {q:"Do stock splits affect dividend payments?",a:"The dividend per share adjusts proportionally, but total dividend income stays the same. A $2.00/share quarterly dividend becomes $1.00/share after a 2:1 split — but you own twice as many shares, so your total payout is identical. Dividend yield also stays unchanged since both price and per-share dividend adjust equally."}
];

const faqEl = document.getElementById('faq');
faqs.forEach(f => {
  faqEl.innerHTML += `<div class="faq-item"><div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div></div>`;
});
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});
  </script>

