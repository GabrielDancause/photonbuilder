---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is a stock split and how does it work?","acceptedAnswer":{"@type":"Answer","text":"A stock split increases the number of shares outstanding while proportionally reducing the price per share. In a 2-for-1 split, each share becomes two shares at half the price. Your total investment value remains exactly the same — you simply own more shares at a lower price. Companies split their stock to make shares more accessible to retail investors and to increase liquidity. A stock trading at $1,000 that does a 10-for-1 split would trade at $100 with 10x the shares outstanding."}},
    {"@type":"Question","name":"What is a reverse stock split?","acceptedAnswer":{"@type":"Answer","text":"A reverse stock split reduces the number of shares while proportionally increasing the price per share. In a 1-for-10 reverse split, every 10 shares become 1 share at 10x the price. Total value remains unchanged. Companies typically do reverse splits to avoid exchange delisting when their share price falls below the $1 minimum. Reverse splits are often viewed negatively because they frequently signal a struggling company, though some companies use them to attract institutional investors or reduce share count."}},
    {"@type":"Question","name":"Does a stock split change the value of my investment?","acceptedAnswer":{"@type":"Answer","text":"No, a stock split does not change the total value of your investment. If you own 100 shares at $200 each ($20,000 total) and the company does a 2-for-1 split, you will own 200 shares at $100 each — still $20,000. However, stock splits can indirectly affect value: they often boost short-term trading volume and sentiment, and lower share prices can attract retail investors. Research shows stocks tend to outperform slightly in the 12 months following a split announcement."}},
    {"@type":"Question","name":"How does a stock split affect my cost basis?","acceptedAnswer":{"@type":"Answer","text":"Your cost basis per share is adjusted proportionally after a split. If you bought 50 shares at $400 each (cost basis $400/share) and the stock does a 4-for-1 split, your new cost basis becomes $100 per share across 200 shares. Your total cost basis remains $20,000 — only the per-share amount changes. This is important for calculating capital gains taxes when you eventually sell. Your brokerage automatically adjusts cost basis records after splits."}},
    {"@type":"Question","name":"Why do companies like Apple and Tesla split their stock?","acceptedAnswer":{"@type":"Answer","text":"Companies split their stock primarily to lower the share price and make it more accessible. Apple has split five times (1987, 2000, 2005, 2014, 2020), with its most recent 4-for-1 split bringing shares from ~$500 to ~$125. Tesla did a 5-for-1 split in 2020 and a 3-for-1 in 2022. High share prices can deter retail investors, reduce options trading activity, and limit inclusion in price-weighted indices like the Dow Jones."}},
    {"@type":"Question","name":"What is the most common stock split ratio?","acceptedAnswer":{"@type":"Answer","text":"The most common stock split ratio is 2-for-1, followed by 3-for-1 and 3-for-2. In recent years, large tech companies have favored bigger ratios: Amazon did a 20-for-1 split in 2022, Alphabet (Google) did a 20-for-1 in 2022, and Nvidia did a 10-for-1 in 2024. The trend toward larger split ratios reflects how high stock prices have climbed. Companies choose ratios that bring the post-split price into a sweet spot typically between $50 and $200."}},
    {"@type":"Question","name":"How does a stock split affect options contracts?","acceptedAnswer":{"@type":"Answer","text":"When a stock splits, existing options contracts are adjusted proportionally by the Options Clearing Corporation. In a 2-for-1 split, each contract becomes 2 contracts with the strike price halved. Non-standard splits like 3-for-2 can create adjusted contracts with non-standard deliverables (150 shares per contract), which may have wider bid-ask spreads. The total value of your options position remains the same immediately after the split."}},
    {"@type":"Question","name":"Do stock splits affect dividend payments?","acceptedAnswer":{"@type":"Answer","text":"Stock splits adjust the dividend per share proportionally, but your total dividend income stays the same. If a company pays $2.00 per share quarterly and does a 2-for-1 split, the new dividend becomes $1.00 per share — but you own twice as many shares, so you receive the same total payout. The dividend yield also remains unchanged because both the share price and per-share dividend are adjusted by the same ratio."}}
  ]
};

export const meta = {
  title: "Stock Split Calculator — Forward & Reverse Split Tool",
  description: "Calculate new shares, price per share, and cost basis after any stock split or reverse split. Includes history of major splits from AAPL, TSLA, NVDA, AMZN, and GOOG.",
  category: "tool",
  published: "2026-03-21",
};
