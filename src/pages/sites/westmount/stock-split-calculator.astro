            </div>
            <div class="input-group">
              <label>Price Per Share ($)</label>
              <input type="number" id="pricePerShare" placeholder="e.g. 500.00" min="0" step="0.01">
              <div class="input-hint">Current or pre-split share price</div>
            </div>
          </div>

          <div class="input-group">
            <label>Split Ratio</label>
            <select id="splitRatio">
              <option value="2:1">2-for-1</option>
              <option value="3:1">3-for-1</option>
              <option value="4:1">4-for-1</option>
              <option value="5:1">5-for-1</option>
              <option value="10:1">10-for-1</option>
              <option value="20:1">20-for-1</option>
              <option value="3:2">3-for-2</option>
