        // Helper functions
        const formatPct = (val) => val != null ? `${(val * 100).toFixed(2)}%` : 'N/A';
        const formatCur = (val) => val != null ? `$${(val / 1e9).toFixed(1)}B` : 'N/A';
        const getNestedValue = (obj, path) => path.split('.').reduce((acc, part) => acc && acc[part], obj);

        // Populate dynamic stats cards
        const validFeeEtfs = etfData.filter(e => e.expenseRatio != null).sort((a,b) => a.expenseRatio - b.expenseRatio);
        if(validFeeEtfs.length > 0) {
            document.getElementById('stat-low-fee').innerText = `${validFeeEtfs[0].symbol} (${(validFeeEtfs[0].expenseRatio*100).toFixed(2)}%)`;
            document.getElementById('stat-low-fee').nextElementSibling.innerText = validFeeEtfs[0].name.split(' ')[0] + ' ' + validFeeEtfs[0].name.split(' ')[1];
        }

        const validReturnEtfs = etfData.filter(e => e.returns && e.returns.fiveYear != null).sort((a,b) => b.returns.fiveYear - a.returns.fiveYear);
        if(validReturnEtfs.length > 0) {
            document.getElementById('stat-high-return').innerText = `${validReturnEtfs[0].symbol} (${(validReturnEtfs[0].returns.fiveYear*100).toFixed(2)}%)`;
            document.getElementById('stat-high-return').nextElementSibling.innerText = validReturnEtfs[0].name.split(' ').slice(0, 3).join(' ');
        }

        const validAumEtfs = etfData.filter(e => e.aum != null).sort((a,b) => b.aum - a.aum);
        if(validAumEtfs.length > 0) {
            document.getElementById('stat-high-aum').innerText = `${validAumEtfs[0].symbol} ($${(validAumEtfs[0].aum/1e9).toFixed(0)}B)`;
            document.getElementById('stat-high-aum').nextElementSibling.innerText = validAumEtfs[0].name.split(' ').slice(0, 3).join(' ');
        }

        // Table logic
        const tbody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');
        const regionFilter = document.getElementById('regionFilter');
        const headers = document.querySelectorAll('th[data-sort]');

        let currentSort = { column: 'aum', asc: false };

        function renderTable() {
            const searchTerm = searchInput.value.toLowerCase();
            const filterCategory = regionFilter.value;

            let filtered = etfData.filter(etf => {
                const matchesSearch = etf.symbol.toLowerCase().includes(searchTerm) || (etf.name && etf.name.toLowerCase().includes(searchTerm));
                const matchesFilter = filterCategory === 'all' || etf.category === filterCategory;
                return matchesSearch && matchesFilter;
            });

            filtered.sort((a, b) => {
                let valA = getNestedValue(a, currentSort.column);
                let valB = getNestedValue(b, currentSort.column);

                if (valA == null) valA = currentSort.asc ? Infinity : -Infinity;
                if (valB == null) valB = currentSort.asc ? Infinity : -Infinity;

                if (typeof valA === 'string') {
                    return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }
                return currentSort.asc ? valA - valB : valB - valA;
            });

            tbody.innerHTML = filtered.map(etf => `
                <tr class="last:[&>td]:border-b-0">
                    <td class="p-4 border-b border-[var(--border-color)] text-left md:sticky md:left-0 md:bg-[var(--card-bg)] md:z-10 md:shadow-[2px_0_5px_rgba(0,0,0,0.5)]">
                        <div class="inline-block bg-[var(--bg-color)] border border-[var(--border-color)] px-2 py-1 rounded font-semibold text-[var(--accent-color)]">${etf.symbol}</div>
                        <div class="font-sans text-[0.8rem] text-[var(--text-secondary)] mt-1 whitespace-normal min-w-[150px]">${etf.name || 'N/A'}</div>
                    </td>
                    <td class="p-4 border-b border-[var(--border-color)] font-mono text-[0.95rem] text-white">${etf.category || 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] font-mono text-[0.95rem] text-white">${formatPct(etf.expenseRatio)}</td>
                    <td class="p-4 border-b border-[var(--border-color)] font-mono text-[0.95rem] text-white">${formatPct(etf.dividendYield)}</td>
                    <td class="p-4 border-b border-[var(--border-color)] font-mono text-[0.95rem] text-white">${formatCur(etf.aum)}</td>
                    <td class="p-4 border-b border-[var(--border-color)] font-mono text-[0.95rem] text-white">${formatPct(etf.returns?.oneYear)}</td>
                    <td class="p-4 border-b border-[var(--border-color)] font-mono text-[0.95rem] text-white">${formatPct(etf.returns?.threeYear)}</td>
                    <td class="p-4 border-b border-[var(--border-color)] font-mono text-[0.95rem] text-white">${formatPct(etf.returns?.fiveYear)}</td>
                </tr>
            `).join('');
        }

        searchInput.addEventListener('input', renderTable);
        regionFilter.addEventListener('change', renderTable);

        headers.forEach(th => {
            th.addEventListener('click', () => {
                const column = th.dataset.sort;
                if (currentSort.column === column) {
                    currentSort.asc = !currentSort.asc;
                } else {
                    currentSort.column = column;
                    currentSort.asc = false;
                }
                renderTable();
            });
        });

        // Initialize table
        renderTable();

        // Chart logic
        const vxus = etfData.find(e => e.symbol === 'VXUS');
        const vea = etfData.find(e => e.symbol === 'VEA');
        const vwo = etfData.find(e => e.symbol === 'VWO');

        if (vxus && vea && vwo && vxus.chart.length > 0) {
            // align dates
            const labels = vxus.chart.map(d => d.date);

            const normalize = (data) => {
                if(!data || data.length === 0) return [];
                const base = data[0].price;
                return data.map(d => ((d.price / base) - 1) * 100);
            };

            const ctx = document.getElementById('performanceChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'VXUS (Total Intl)',
                            data: normalize(vxus.chart),
                            borderColor: '#4a8fe7',
                            borderWidth: 2,
                            tension: 0.2,
                            pointRadius: 0
                        },
                        {
                            label: 'VEA (Developed)',
                            data: normalize(vea.chart),
                            borderColor: '#10b981',
                            borderWidth: 2,
                            tension: 0.2,
                            pointRadius: 0
                        },
                        {
                            label: 'VWO (Emerging)',
                            data: normalize(vwo.chart),
                            borderColor: '#f59e0b',
                            borderWidth: 2,
                            tension: 0.2,
                            pointRadius: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            labels: { color: '#9ca3af' }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + '%';
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: '#152040' },
                            ticks: { color: '#9ca3af', maxTicksLimit: 12 }
                        },
                        y: {
                            grid: { color: '#152040' },
                            ticks: {
                                color: '#9ca3af',
                                callback: function(value) { return value + '%'; }
                            }
                        }
                    }
                }
            });
        }
