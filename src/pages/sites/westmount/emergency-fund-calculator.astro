---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Emergency Fund Calculator | Westmount Fundamentals",
  description: "Calculate exactly how much you need in your emergency fund. Input your monthly expenses, savings goal, and current balance to find your target safety net.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an emergency fund?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An emergency fund is a bank account with money set aside to cover large, unexpected expenses, such as unforeseen medical bills, major home or car repairs, or financial buffers in case of job loss."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I have in my emergency fund?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Financial experts generally recommend keeping between three to six months' worth of living expenses in an emergency fund. Your specific target depends on your job stability and financial obligations."
      }
    },
    {
      "@type": "Question",
      "name": "Where should I keep my emergency fund?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your emergency fund should be easily accessible but separate from your daily checking account. A high-yield savings account (HYSA) is typically the best place, as it earns interest while keeping funds liquid."
      }
    },
    {
      "@type": "Question",
      "name": "What expenses should I include when calculating my emergency fund?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Include essential monthly expenses such as housing (rent or mortgage), utilities, groceries, transportation, insurance premiums, and minimum debt payments. Exclude discretionary spending like dining out or entertainment."
      }
    },
    {
      "@type": "Question",
      "name": "Should I pay off debt or build an emergency fund first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A common strategy is to first save a starter emergency fund (e.g., $1,000), then focus on paying off high-interest debt like credit cards. Once the toxic debt is cleared, you can fully fund your 3-6 month emergency reserve."
      }
    }
  ]
});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/emergency-fund-calculator" schema={schema}>
  <div class="page-content">
    <h1>Emergency Fund Calculator</h1>

    <p>Building a solid financial foundation starts with a fully funded emergency reserve. Use our emergency fund calculator below to determine exactly how much you need to save based on your monthly living expenses and financial security goals.</p>

    <div class="calculator-card">
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="input-group">
            <label for="monthlyExpenses">Monthly Essential Expenses</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="monthlyExpenses" value="3000" min="0" step="100" />
            </div>
            <p class="input-hint">Rent/mortgage, utilities, food, insurance, debt minimums.</p>
          </div>

          <div class="input-group">
            <label for="targetMonths">Target Coverage (Months)</label>
            <div class="input-wrapper">
              <input type="number" id="targetMonths" value="6" min="1" max="24" step="1" />
              <span class="suffix">Months</span>
            </div>
            <p class="input-hint">Aim for 3-6 months. Higher if self-employed or single income.</p>
          </div>

          <div class="input-group">
            <label for="currentSavings">Current Emergency Savings</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="currentSavings" value="5000" min="0" step="100" />
            </div>
          </div>
        </div>

        <div class="calc-outputs">
          <div class="result-box primary-result">
            <span class="result-label">Target Emergency Fund</span>
            <div class="result-value" id="targetFundDisplay">$18,000</div>
          </div>

          <div class="result-box secondary-result">
            <span class="result-label">Amount Remaining to Save</span>
            <div class="result-value" id="remainingToSaveDisplay">$13,000</div>
          </div>

          <div class="progress-container">
            <div class="progress-labels">
              <span>Funding Progress</span>
              <span id="progressPercentage">28%</span>
            </div>
            <div class="progress-bar-bg">
              <div class="progress-bar-fill" id="progressBarFill" style="width: 28%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <h2>How to Calculate Your Emergency Fund</h2>
    <p>A properly sized emergency fund acts as financial armor against life's unpredictable events—whether it's an unexpected medical bill, a sudden car repair, or a period of unemployment. While saving can seem daunting, breaking it down into a clear mathematical formula makes the goal achievable.</p>

    <h3>1. Identify Your Baseline Monthly Expenses</h3>
    <p>Your emergency fund shouldn't cover your current lavish lifestyle; it should cover your <strong>survival number</strong>. When calculating your target, tally up essential non-discretionary expenses:</p>
    <ul>
      <li>Housing (Rent, mortgage, HOA fees, property taxes)</li>
      <li>Utilities (Electricity, water, gas, internet)</li>
      <li>Transportation (Car payment, insurance, basic maintenance, gas)</li>
      <li>Food (Basic groceries, excluding dining out)</li>
      <li>Healthcare (Insurance premiums, regular medications)</li>
      <li>Debt (Minimum payments required on credit cards or loans)</li>
    </ul>

    <h3>2. Determine Your Multiplier (Months of Coverage)</h3>
    <p>Financial experts generally recommend saving between <strong>3 to 6 months</strong> of living expenses. However, this rule of thumb varies based on your personal risk profile:</p>
    <ul>
      <li><strong>3 Months:</strong> Ideal for dual-income households with secure jobs, minimal dependents, or easily replaceable income (like specialized nursing or teaching).</li>
      <li><strong>6 Months:</strong> The standard recommendation. Great for single-income households, homeowners, or those with dependents.</li>
      <li><strong>9-12+ Months:</strong> Recommended for freelance workers, independent contractors, business owners, or individuals working in highly cyclical industries.</li>
    </ul>

    <h3>3. Do the Math</h3>
    <p>Once you have your numbers, the calculation is simple:</p>
    <div class="highlight-box">
      <strong>Target Emergency Fund = (Monthly Essential Expenses) × (Target Coverage Months)</strong>
    </div>

    <h2>Where Should You Keep Your Emergency Fund?</h2>
    <p>Your emergency cash needs to be highly liquid—meaning you can access it immediately without penalty—but it shouldn't lose value to inflation while it sits there. The best places to store these funds include:</p>
    <ul>
      <li><strong>High-Yield Savings Accounts (HYSA):</strong> These offer significantly higher interest rates than traditional banks while remaining FDIC-insured and fully liquid.</li>
      <li><strong>Money Market Accounts (MMA):</strong> Similar to HYSAs, but often come with debit cards or check-writing privileges for faster access.</li>
      <li><strong>No-Penalty Certificates of Deposit (CDs):</strong> These lock in a specific interest rate, but "no-penalty" versions allow you to withdraw your money if a crisis strikes.</li>
    </ul>
    <p>Never invest your primary emergency fund in the stock market. Market volatility means your investments could plummet exactly when you lose your job and need the money most.</p>

    <div class="faq-section">
      <h2>Emergency Fund FAQs</h2>

      <details class="faq-item">
        <summary><h3>What is an emergency fund?</h3><span class="icon">+</span></summary>
        <div class="faq-content">
          <p>An emergency fund is a bank account with money set aside to cover large, unexpected expenses, such as unforeseen medical bills, major home or car repairs, or financial buffers in case of job loss.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary><h3>How much should I have in my emergency fund?</h3><span class="icon">+</span></summary>
        <div class="faq-content">
          <p>Financial experts generally recommend keeping between three to six months' worth of living expenses in an emergency fund. Your specific target depends on your job stability and financial obligations.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary><h3>Where should I keep my emergency fund?</h3><span class="icon">+</span></summary>
        <div class="faq-content">
          <p>Your emergency fund should be easily accessible but separate from your daily checking account. A high-yield savings account (HYSA) is typically the best place, as it earns interest while keeping funds liquid.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary><h3>What expenses should I include when calculating my emergency fund?</h3><span class="icon">+</span></summary>
        <div class="faq-content">
          <p>Include essential monthly expenses such as housing (rent or mortgage), utilities, groceries, transportation, insurance premiums, and minimum debt payments. Exclude discretionary spending like dining out or entertainment.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary><h3>Should I pay off debt or build an emergency fund first?</h3><span class="icon">+</span></summary>
        <div class="faq-content">
          <p>A common strategy is to first save a starter emergency fund (e.g., $1,000), then focus on paying off high-interest debt like credit cards. Once the toxic debt is cleared, you can fully fund your 3-6 month emergency reserve.</p>
        </div>
      </details>
    </div>
  </div>
</SiteLayout>

<style>
  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .calc-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-hint {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
    margin-bottom: 0;
  }

  .prefix {
    position: absolute;
    left: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  input[type="number"] {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: border-color 0.2s;
  }

  .input-wrapper:has(.prefix) input {
    padding-left: 2rem;
  }

  .calc-outputs {
    background-color: color-mix(in srgb, var(--bg-color) 50%, var(--card-bg));
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
  }

  .result-box {
    text-align: center;
  }

  .primary-result .result-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--accent-color);
    font-family: var(--font-mono);
    line-height: 1.2;
  }

  .secondary-result .result-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-mono);
    line-height: 1.2;
  }

  .result-label {
    color: var(--text-secondary);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    display: block;
    margin-bottom: 0.5rem;
  }

  .progress-container {
    margin-top: 1rem;
  }

  .progress-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  #progressPercentage {
    color: var(--accent-color);
    font-family: var(--font-mono);
  }

  .progress-bar-bg {
    width: 100%;
    height: 12px;
    background-color: var(--border-color);
    border-radius: 6px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background-color: var(--accent-color);
    border-radius: 6px;
    transition: width 0.3s ease-out;
  }

  /* Interactive FAQ Styles */
  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary h3 {
    margin: 0;
    font-size: 1.15rem;
    padding-right: 1rem;
  }

  .faq-item .icon {
    color: var(--accent-color);
    font-size: 1.5rem;
    font-weight: 300;
    transition: transform 0.2s;
  }

  .faq-item[open] .icon {
    transform: rotate(45deg);
  }

  .faq-content {
    padding-top: 1rem;
    color: var(--text-secondary);
  }
</style>

<script>
  function initCalculator() {
    const monthlyExpensesInput = document.getElementById('monthlyExpenses');
    const targetMonthsInput = document.getElementById('targetMonths');
    const currentSavingsInput = document.getElementById('currentSavings');
    const targetFundDisplay = document.getElementById('targetFundDisplay');
    const remainingToSaveDisplay = document.getElementById('remainingToSaveDisplay');
    const progressPercentageDisplay = document.getElementById('progressPercentage');
    const progressBarFill = document.getElementById('progressBarFill');

    if (!monthlyExpensesInput || !targetMonthsInput || !currentSavingsInput || !targetFundDisplay || !remainingToSaveDisplay || !progressPercentageDisplay || !progressBarFill) {
      return;
    }

    // Prevent duplicate initializations on view transitions
    const calcContainer = document.querySelector('.calculator-card');
    if (!calcContainer || calcContainer.dataset.calcInitialized === "true") return;
    calcContainer.dataset.calcInitialized = "true";

    function formatCurrency(amount) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(amount);
    }

    function calculate() {
      const expenses = parseFloat(monthlyExpensesInput.value) || 0;
      const months = parseFloat(targetMonthsInput.value) || 0;
      const current = parseFloat(currentSavingsInput.value) || 0;

      // Ensure minimum values for visual sanity
      const safeExpenses = Math.max(0, expenses);
      const safeMonths = Math.max(0, months);
      const safeCurrent = Math.max(0, current);

      const targetFund = safeExpenses * safeMonths;
      const remaining = Math.max(0, targetFund - safeCurrent);

      let percentage = 0;
      if (targetFund > 0) {
        percentage = (safeCurrent / targetFund) * 100;
        percentage = Math.min(100, percentage); // Cap at 100%
      }

      targetFundDisplay.textContent = formatCurrency(targetFund);
      remainingToSaveDisplay.textContent = formatCurrency(remaining);
      progressPercentageDisplay.textContent = `${percentage.toFixed(0)}%`;
      progressBarFill.style.width = `${percentage}%`;

      // Visual feedback if completed
      if (percentage >= 100) {
        progressBarFill.style.backgroundColor = "rgba(34, 197, 94, 0.8)"; // Green if complete
        remainingToSaveDisplay.textContent = "$0 (Fully Funded!)";
      } else {
        progressBarFill.style.backgroundColor = "var(--accent-color)";
      }
    }

    [monthlyExpensesInput, targetMonthsInput, currentSavingsInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Run initial calculation
    calculate();
  }

  document.addEventListener("DOMContentLoaded", initCalculator);
  document.addEventListener("astro:page-load", initCalculator);
</script>
