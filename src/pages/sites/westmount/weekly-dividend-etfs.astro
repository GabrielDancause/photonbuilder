---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Weekly Dividend ETFs List: Ultimate Cash Flow | Westmount Fundamentals",
  description: "Are there ETFs that pay you every single week? Discover the truth about weekly dividend ETFs, exploring their high yields, risks, and if they belong in your portfolio.",
  category: "list",
  published: "2025-05-01"
};

const schema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What are weekly dividend ETFs?", "acceptedAnswer": {"@type": "Answer", "text": "Weekly dividend ETFs are specialized exchange-traded funds designed to distribute income to shareholders on a weekly basis, rather than the traditional monthly or quarterly schedules."}}, {"@type": "Question", "name": "How do weekly dividend ETFs generate income so frequently?", "acceptedAnswer": {"@type": "Answer", "text": "They typically generate high yields through complex strategies involving fixed income, high-yield bonds, or derivative strategies like covered calls, allowing them to distribute cash flow more frequently."}}, {"@type": "Question", "name": "Are weekly dividend ETFs safe?", "acceptedAnswer": {"@type": "Answer", "text": "They often carry higher risk than broad market index funds. The underlying strategies (like covered calls) can cap upside potential, and the high yields may involve return of capital, which can deplete the ETF's net asset value over time."}}, {"@type": "Question", "name": "Who should invest in weekly dividend ETFs?", "acceptedAnswer": {"@type": "Answer", "text": "They are best suited for investors seeking immediate, highly frequent cash flow, and who are willing to accept the associated risks of capital depreciation and complex fund structures."}}, {"@type": "Question", "name": "Are there many weekly dividend ETFs available?", "acceptedAnswer": {"@type": "Answer", "text": "No, true weekly paying ETFs are extremely rare. The vast majority of income-focused ETFs pay monthly. The ones that do pay weekly are often highly specialized, such as the SoFi Weekly Dividend ETF."}}]};

const etfs = [
    { symbol: "WKLY", name: "SoFi Weekly Dividend ETF", yield: "3.2%", aum: "$12M", expense: "0.49%", analysis: "One of the very few ETFs designed specifically to pay every week. It tracks an index of globally diversified, dividend-paying companies. AUM remains relatively low." },
    { symbol: "TGIF", name: "SoFi Weekly Income ETF", yield: "4.8%", aum: "$15M", expense: "0.59%", analysis: "An actively managed fixed-income ETF focusing on high-yield and investment-grade corporate bonds to generate its weekly Friday distributions." },
    { symbol: "JEPI", name: "JPMorgan Equity Premium Income", yield: "7.5%", aum: "$33B", expense: "0.35%", analysis: "Note: Pays MONTHLY, not weekly. Included here because investors seeking weekly income often build 'weekly' schedules by buying 4 different monthly payers with staggered dates." },
    { symbol: "QYLD", name: "Global X NASDAQ 100 Covered Call", yield: "11.5%", aum: "$8B", expense: "0.60%", analysis: "Note: Pays MONTHLY. A staple for aggressive income investors looking to construct a synthetic weekly payout schedule using covered calls." },
    { symbol: "O", name: "Realty Income Corp", yield: "5.8%", aum: "N/A", expense: "N/A", analysis: "Note: Pays MONTHLY. The self-proclaimed 'Monthly Dividend Company'. Often combined with other monthly stocks/ETFs to create a weekly income stream." }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/weekly-dividend-etfs" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Weekly Dividend ETFs</h1>
      <p class="subtitle">Exploring the rarest breed of income investments.</p>
    </div>

    <div class="content-body">
      <p>The allure of getting paid every single week is strong for income investors. However, true weekly dividend ETFs are incredibly rare. The logistics and administrative costs of distributing cash 52 times a year make it an unpopular structure for fund managers. Below, we list the few true weekly payers available, alongside popular monthly ETFs that investors frequently use to construct their own "synthetic" weekly income portfolios.</p>

      <div class="card">
        <input type="text" id="searchInput" placeholder="Search ETFs..." style="width: 100%; padding: 0.75rem; margin-bottom: 1rem; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-primary); color: var(--text-primary);">
        <div style="overflow-x: auto;">
            <table id="stocksTable">
              <thead>
                <tr>
                  <th onclick="sortTable(0)" style="cursor: pointer;">Symbol ↕</th>
                  <th onclick="sortTable(1)" style="cursor: pointer;">Name ↕</th>
                  <th onclick="sortTable(2)" style="cursor: pointer;">Yield ↕</th>
                  <th onclick="sortTable(3)" style="cursor: pointer;">AUM ↕</th>
                  <th onclick="sortTable(4)" style="cursor: pointer;">Expense Ratio ↕</th>
                  <th>Analysis</th>
                </tr>
              </thead>
              <tbody>
                {etfs.map((etf) => (
                  <tr>
                    <td><strong><a href="/etf-comparison-tool/">{etf.symbol}</a></strong></td>
                    <td>{etf.name}</td>
                    <td>{etf.yield}</td>
                    <td>{etf.aum}</td>
                    <td>{etf.expense}</td>
                    <td>{etf.analysis}</td>
                  </tr>
                ))}
              </tbody>
            </table>
        </div>
      </div>

      <h2>The "Synthetic" Weekly Portfolio</h2>
      <p>Because true weekly ETFs like WKLY and TGIF have limited AUM and higher relative expenses, many experienced investors opt for a different strategy. By purchasing four high-quality <a href="/best-monthly-dividend-etfs/">monthly dividend ETFs</a> (or stocks) that have their ex-dividend and payout dates staggered across the four weeks of a month, you can effectively create your own weekly dividend machine without relying on niche products.</p>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {JSON.parse(JSON.stringify(schema)).mainEntity.map((faq: any) => (
          <details>
            <summary>{faq.name}</summary>
            <p>{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </section>
    </div>
  </div>

  <script is:inline>
    // Search functionality
    document.getElementById('searchInput')?.addEventListener('keyup', function(e) {
      const term = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('#stocksTable tbody tr');
      rows.forEach(row => {
        const symbol = row.cells[0].textContent.toLowerCase();
        const name = row.cells[1].textContent.toLowerCase();
        if (symbol.includes(term) || name.includes(term)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });

    // Sort functionality
    let sortDirections = [true, true, true, true, true];
    function sortTable(columnIndex) {
      const table = document.getElementById("stocksTable");
      const tbody = table.tBodies[0];
      const rows = Array.from(tbody.querySelectorAll("tr"));
      const isAscending = sortDirections[columnIndex];

      rows.sort((a, b) => {
        let aVal = a.cells[columnIndex].textContent.trim();
        let bVal = b.cells[columnIndex].textContent.trim();

        // Handle numeric columns
        if (columnIndex === 2 || columnIndex === 4) {
          aVal = parseFloat(aVal.replace(/[^0-9.-]+/g,"")) || 0;
          bVal = parseFloat(bVal.replace(/[^0-9.-]+/g,"")) || 0;
        } else if (columnIndex === 3) {
            // Very simple AUM sorting (M vs B)
            let aMult = aVal.includes('B') ? 1000 : (aVal.includes('M') ? 1 : 0);
            let bMult = bVal.includes('B') ? 1000 : (bVal.includes('M') ? 1 : 0);
            aVal = (parseFloat(aVal.replace(/[^0-9.-]+/g,"")) || 0) * aMult;
            bVal = (parseFloat(bVal.replace(/[^0-9.-]+/g,"")) || 0) * bMult;
        }

        if (aVal < bVal) return isAscending ? -1 : 1;
        if (aVal > bVal) return isAscending ? 1 : -1;
        return 0;
      });

      sortDirections[columnIndex] = !isAscending;
      tbody.append(...rows);
    }
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
    th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border-color); }
    th { background: rgba(0,0,0,0.05); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .content-body p { line-height: 1.6; color: var(--text-primary); margin-bottom: 1rem; }
    h2 { margin-top: 2rem; margin-bottom: 1rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</SiteLayout>
