  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      initCheapTable();
    });

    document.addEventListener('astro:page-load', () => {
      initCheapTable();
    });

    function initCheapTable() {
      const table = document.getElementById('cheap-table');
      if (!table || table.dataset.initialized) return;

      table.dataset.initialized = "true";

      const filter = document.getElementById('sector-filter');
      const tbody = table.querySelector('tbody');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      const headers = table.querySelectorAll('th');

      // Filtering logic
      if (filter) {
        filter.addEventListener('change', (e) => {
          const selectedSector = e.target.value;
          rows.forEach(row => {
            if (selectedSector === 'all' || row.dataset.sector === selectedSector) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          });
        });
      }

      // Sorting logic
      let currentSortColumn = -1;
      let sortAscending = true;

      headers.forEach((header, index) => {
        if (!header.dataset.sort) return;

        header.style.cursor = 'pointer';
        header.addEventListener('click', () => {
          if (currentSortColumn === index) {
            sortAscending = !sortAscending;
          } else {
            currentSortColumn = index;
            sortAscending = true;
          }

          rows.sort((a, b) => {
            let aText = a.cells[index].textContent.trim();
            let bText = b.cells[index].textContent.trim();

            // Handle numeric sort for Rank, Price, Market Cap
            if (header.dataset.sort === 'rank') {
              return sortAscending ? parseInt(aText) - parseInt(bText) : parseInt(bText) - parseInt(aText);
            }
            if (header.dataset.sort === 'price' || header.dataset.sort === 'marketcap') {
              // Extract the first number found
              let matchA = aText.match(/[\d.]+/);
              let matchB = bText.match(/[\d.]+/);
              let aVal = matchA ? parseFloat(matchA[0]) : 0;
              let bVal = matchB ? parseFloat(matchB[0]) : 0;

              if (header.dataset.sort === 'marketcap') {
                  if (aText.includes('B')) aVal *= 1000;
                  if (bText.includes('B')) bVal *= 1000;
              }

              return sortAscending ? aVal - bVal : bVal - aVal;
            }

            return sortAscending ? aText.localeCompare(bText) : bText.localeCompare(aText);
          });

          rows.forEach(row => tbody.appendChild(row));

          headers.forEach(h => h.textContent = h.textContent.replace(' ↑', ' ↕').replace(' ↓', ' ↕'));
          header.textContent = header.textContent.replace(' ↕', sortAscending ? ' ↑' : ' ↓');
        });
      });
    }
  </script>
