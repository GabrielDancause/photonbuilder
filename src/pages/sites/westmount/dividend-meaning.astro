<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const investmentInput = document.getElementById('investment');
    const yieldInput = document.getElementById('yield');
    const annualIncomeEl = document.getElementById('annual-income');
    const monthlyIncomeEl = document.getElementById('monthly-income');

    function calculateDividends() {
      const investment = parseFloat(investmentInput.value) || 0;
      const dividendYield = parseFloat(yieldInput.value) || 0;

      // Pure JS calculation, avoid floating point precision issues using cents
      const annualIncomeCents = Math.round(investment * 100 * (dividendYield / 100));
      const annualIncome = annualIncomeCents / 100;

      const monthlyIncomeCents = Math.round(annualIncomeCents / 12);
      const monthlyIncome = monthlyIncomeCents / 100;

      // Format currency
      const formatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
      });

      annualIncomeEl.textContent = formatter.format(annualIncome);
      monthlyIncomeEl.textContent = formatter.format(monthlyIncome);
    }

    investmentInput.addEventListener('input', calculateDividends);
    yieldInput.addEventListener('input', calculateDividends);

    // Initial calculation
    calculateDividends();
  });
</script>
