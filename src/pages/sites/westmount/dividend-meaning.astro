<script>
  function initCalculator() {
    const sharePriceInput = document.getElementById('sharePrice');
    const annualDividendInput = document.getElementById('annualDividend');
    const sharesOwnedInput = document.getElementById('sharesOwned');
    const yieldResult = document.getElementById('yieldResult');
    const incomeResult = document.getElementById('incomeResult');

    if (!sharePriceInput || !annualDividendInput || !sharesOwnedInput || !yieldResult || !incomeResult) return;

    function calculate() {
      const price = parseFloat(sharePriceInput.value) || 0;
      const dividend = parseFloat(annualDividendInput.value) || 0;
      const shares = parseFloat(sharesOwnedInput.value) || 0;

      if (price <= 0) {
        yieldResult.textContent = "0.00%";
        incomeResult.textContent = "$0.00";
        return;
      }

      const yieldPct = (dividend / price) * 100;
      const totalIncome = dividend * shares;

      yieldResult.textContent = yieldPct.toFixed(2) + "%";

      // Format as currency
      const formatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
      });
      incomeResult.textContent = formatter.format(totalIncome);
    }

    sharePriceInput.addEventListener('input', calculate);
    annualDividendInput.addEventListener('input', calculate);
    sharesOwnedInput.addEventListener('input', calculate);

    // Initial calculation
    calculate();
  }

  // Initialize on page load (handles Astro View Transitions)
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for direct loads without View Transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
