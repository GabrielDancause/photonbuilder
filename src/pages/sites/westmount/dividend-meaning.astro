<script>
  function initCalculator() {
    const inputs = ['initial-investment', 'dividend-yield', 'annual-contribution', 'dividend-growth', 'stock-appreciation', 'investment-years'];
    const elements = inputs.reduce((acc, id) => {
      acc[id] = document.getElementById(id) as HTMLInputElement;
      return acc;
    }, {} as Record<string, HTMLInputElement>);

    const displays = {
      yearsDisplay: document.getElementById('years-display'),
      reinvestTotal: document.getElementById('reinvest-total'),
      reinvestIncome: document.getElementById('reinvest-income'),
      noReinvestTotal: document.getElementById('no-reinvest-total'),
      noReinvestIncome: document.getElementById('no-reinvest-income'),
      yearVals: document.querySelectorAll('.year-val')
    };

    if (!elements['initial-investment'] || !displays.reinvestTotal) return;

    function formatCurrency(num: number) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(num);
    }

    function calculate() {
      const initial = parseFloat(elements['initial-investment'].value) || 0;
      const yieldPct = (parseFloat(elements['dividend-yield'].value) || 0) / 100;
      const annualContrib = parseFloat(elements['annual-contribution'].value) || 0;
      const divGrowth = (parseFloat(elements['dividend-growth'].value) || 0) / 100;
      const stockAppreciation = (parseFloat(elements['stock-appreciation'].value) || 0) / 100;
      const years = parseInt(elements['investment-years'].value) || 0;

      if (displays.yearsDisplay) displays.yearsDisplay.textContent = years.toString();
      displays.yearVals.forEach(el => el.textContent = years.toString());

      // Use an arbitrary $100 starting share price to accurately track shares and yields without double compounding
      let stockPrice = 100;
      let dps = stockPrice * yieldPct; // initial dividend per share

      let sharesReinvest = initial / stockPrice;
      let sharesNoReinvest = initial / stockPrice;

      let yearIncomeReinvest = 0;
      let yearIncomeNoReinvest = 0;
      let totalCashCollected = 0;

      for (let i = 1; i <= years; i++) {
        // Add contribution at the beginning of the year
        sharesReinvest += annualContrib / stockPrice;
        sharesNoReinvest += annualContrib / stockPrice;

        // Capital appreciation over the year
        stockPrice *= (1 + stockAppreciation);

        // Dividend per share grows over the year
        dps *= (1 + divGrowth);

        // Calculate income for the year (paid at end of year)
        yearIncomeReinvest = sharesReinvest * dps;
        yearIncomeNoReinvest = sharesNoReinvest * dps;

        // Reinvest the income at the end of year price
        sharesReinvest += yearIncomeReinvest / stockPrice;

        // Collect cash without reinvesting
        totalCashCollected += yearIncomeNoReinvest;
      }

      const reinvestBalance = sharesReinvest * stockPrice;
      const noReinvestBalance = sharesNoReinvest * stockPrice;
      const totalValueNoReinvest = noReinvestBalance + totalCashCollected;

      if (displays.reinvestTotal) displays.reinvestTotal.textContent = formatCurrency(reinvestBalance);
      if (displays.reinvestIncome) displays.reinvestIncome.textContent = formatCurrency(yearIncomeReinvest);

      if (displays.noReinvestTotal) displays.noReinvestTotal.textContent = formatCurrency(totalValueNoReinvest);
      if (displays.noReinvestIncome) displays.noReinvestIncome.textContent = formatCurrency(yearIncomeNoReinvest);
    }

    Object.values(elements).forEach(el => {
      el.addEventListener('input', calculate);
    });

    calculate();
  }

  // Support Astro View Transitions
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for direct loads without View Transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
