  <script>
    function formatCurrency(num) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(num);
    }

    function formatPercent(num) {
      const sign = num > 0 ? '+' : '';
      return sign + num.toFixed(2) + '%';
    }

    function calculateEfficiency() {
      const stockPrice = parseFloat(document.getElementById('stockPrice').value) || 0;
      const optionPremium = parseFloat(document.getElementById('optionPremium').value) || 0;
      const targetPrice = parseFloat(document.getElementById('targetPrice').value) || 0;
      const strikePrice = parseFloat(document.getElementById('strikePrice').value) || 0;

      // Calculate Stock Strategy
      const stockCapital = stockPrice * 100;
      const stockValueAtTarget = targetPrice * 100;
      const stockProfit = stockValueAtTarget - stockCapital;
      const stockROI = stockCapital > 0 ? (stockProfit / stockCapital) * 100 : 0;

      // Calculate Option Strategy
      const optionCapital = optionPremium * 100;
      // Option intrinsic value at expiration
      const intrinsicValue = Math.max(0, targetPrice - strikePrice);
      const optionValueAtTarget = intrinsicValue * 100;
      const optionProfit = optionValueAtTarget - optionCapital;
      const optionROI = optionCapital > 0 ? (optionProfit / optionCapital) * 100 : 0;

      // Update UI
      document.getElementById('stockCapital').textContent = formatCurrency(stockCapital);
      document.getElementById('optionCapital').textContent = formatCurrency(optionCapital);

      const stockRoIEl = document.getElementById('stockROI');
      stockRoIEl.textContent = formatPercent(stockROI);
      stockRoIEl.style.color = stockROI >= 0 ? 'var(--accent-color)' : 'var(--text-secondary)';

      const optionRoIEl = document.getElementById('optionROI');
      optionRoIEl.textContent = formatPercent(optionROI);
      optionRoIEl.style.color = optionROI >= 0 ? 'var(--accent-color)' : 'var(--text-secondary)';
    }

    function initCalculator() {
      const inputs = document.querySelectorAll('.calculator-card input');
      inputs.forEach(input => {
        input.addEventListener('input', calculateEfficiency);
      });
      calculateEfficiency();
    }

    // Initialize on load and View Transition changes
    document.addEventListener('astro:page-load', initCalculator);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCalculator);
    } else {
      initCalculator();
    }
  </script>
