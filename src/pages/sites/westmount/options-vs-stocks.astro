<script>
  function initCalculator() {
    const initialStockPriceInput = document.getElementById('initialStockPrice');
    const optionPremiumInput = document.getElementById('optionPremium');
    const strikePriceInput = document.getElementById('strikePrice');
    const finalStockPriceInput = document.getElementById('finalStockPrice');

    const calcStockCapital = document.getElementById('calcStockCapital');
    const calcStockFinal = document.getElementById('calcStockFinal');
    const calcStockProfit = document.getElementById('calcStockProfit');
    const calcStockROI = document.getElementById('calcStockROI');

    const calcOptionCapital = document.getElementById('calcOptionCapital');
    const calcOptionFinal = document.getElementById('calcOptionFinal');
    const calcOptionProfit = document.getElementById('calcOptionProfit');
    const calcOptionROI = document.getElementById('calcOptionROI');

    if (!initialStockPriceInput || !optionPremiumInput || !strikePriceInput || !finalStockPriceInput) return;

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value);
    }

    function formatPercent(value) {
      const sign = value > 0 ? '+' : '';
      return `${sign}${value.toFixed(2)}%`;
    }

    function updateColor(element, value) {
      if (value > 0) {
        element.style.color = 'color-mix(in srgb, var(--accent-color) 80%, var(--bg-color))';
      } else if (value < 0) {
        element.style.color = 'color-mix(in srgb, var(--text-primary) 50%, var(--accent-color))';
      } else {
        element.style.color = 'var(--text-primary)';
      }
    }

    function calculate() {
      const initialPrice = parseFloat(initialStockPriceInput.value) || 0;
      const premium = parseFloat(optionPremiumInput.value) || 0;
      const strike = parseFloat(strikePriceInput.value) || 0;
      const finalPrice = parseFloat(finalStockPriceInput.value) || 0;

      const shares = 100;

      // Stock Calculations
      const stockCapital = initialPrice * shares;
      const stockFinalValue = finalPrice * shares;
      const stockProfit = stockFinalValue - stockCapital;
      const stockROI = stockCapital > 0 ? (stockProfit / stockCapital) * 100 : 0;

      // Option Calculations (1 Contract = 100 shares)
      const optionCapital = premium * shares;

      // Call Option intrinsic value at expiration
      let optionFinalValue = 0;
      if (finalPrice > strike) {
        optionFinalValue = (finalPrice - strike) * shares;
      }

      const optionProfit = optionFinalValue - optionCapital;
      const optionROI = optionCapital > 0 ? (optionProfit / optionCapital) * 100 : 0;

      // Update UI - Stock
      calcStockCapital.textContent = formatCurrency(stockCapital);
      calcStockFinal.textContent = formatCurrency(stockFinalValue);
      calcStockProfit.textContent = (stockProfit > 0 ? '+' : '') + formatCurrency(stockProfit);
      calcStockROI.textContent = formatPercent(stockROI);
      updateColor(calcStockProfit, stockProfit);
      updateColor(calcStockROI, stockROI);

      // Update UI - Option
      calcOptionCapital.textContent = formatCurrency(optionCapital);
      calcOptionFinal.textContent = formatCurrency(optionFinalValue);
      calcOptionProfit.textContent = (optionProfit > 0 ? '+' : '') + formatCurrency(optionProfit);
      calcOptionROI.textContent = formatPercent(optionROI);
      updateColor(calcOptionProfit, optionProfit);
      updateColor(calcOptionROI, optionROI);
    }

    [initialStockPriceInput, optionPremiumInput, strikePriceInput, finalStockPriceInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    calculate();
  }

  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
