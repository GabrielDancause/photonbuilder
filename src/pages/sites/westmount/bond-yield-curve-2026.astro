                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">5.53%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">2 Mo</strong></td>
