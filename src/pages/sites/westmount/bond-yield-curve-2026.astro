                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.73%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">2 Yr</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">3.52%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.22%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.27%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">3 Yr</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">3.60%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.27%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.05%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">5 Yr</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">3.79%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.36%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">3.91%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">7 Yr</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.01%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.47%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">3.95%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">10 Yr</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.26%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.58%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">3.99%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">20 Yr</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.82%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.88%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.34%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">30 Yr</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.87%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.83%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.22%</td>
                        </tr>

                    </tbody>
                </table>
            </div>
        </section>

        <section class="mb-12">
            <h2 class="text-[1.75rem] font-bold text-white mb-6 border-b border-[var(--border-color)] pb-2">Analysis & Methodology</h2>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6">
                <p class="text-white mb-4">The US Treasury Yield Curve plots the interest rates of government bonds across different maturities, from 1 month to 30 years. Data is sourced directly from the U.S. Department of the Treasury.</p>
                <p class="text-white"><strong class="font-bold">Yield Curve Inversion 2026:</strong> Historically, a normal yield curve slopes upward, compensating investors for the risk of tying up their money for longer periods. When the curve inverts (short-term rates exceed long-term rates, typically measured by the 2-year and 10-year spread), it indicates that bond investors expect interest rates to fall in the future, often as a result of central bank intervention to combat a slowing economy or recession.</p>
            </div>
        </section>

        <section class="mb-12">
            <h2 class="text-[1.75rem] font-bold text-white mb-6 border-b border-[var(--border-color)] pb-2">Frequently Asked Questions</h2>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6">
                <div class="mb-6 last:mb-0">
                    <h3 class="text-[1.1rem] font-bold text-[var(--accent-color)] mb-2 mt-0">What is the yield curve 2026 signaling about the economy?</h3>
                    <p class="text-[var(--text-secondary)] m-0">The yield curve in 2026 provides critical signals about economic health. An inverted curve, where short-term rates exceed long-term rates, often signals a potential recession, while a normal curve points to economic expansion. You can observe the current shape on our interactive chart to see its current state.</p>
                </div>
                <div class="mb-6 last:mb-0">
                    <h3 class="text-[1.1rem] font-bold text-[var(--accent-color)] mb-2 mt-0">How do I check the treasury yield curve today?</h3>
                    <p class="text-[var(--text-secondary)] m-0">You can check the treasury yield curve today by reviewing our live-updated chart that pulls the latest data directly from the U.S. Department of the Treasury. The chart maps out yields from 1-month bills up to 30-year bonds.</p>
                </div>
                <div class="mb-6 last:mb-0">
                    <h3 class="text-[1.1rem] font-bold text-[var(--accent-color)] mb-2 mt-0">Is there a yield curve inversion 2026?</h3>
                    <p class="text-[var(--text-secondary)] m-0">To determine if there is a yield curve inversion in 2026, you look at the spread between the 2-year and 10-year Treasury notes. If the 2-year yield is higher than the 10-year yield, the curve is considered inverted.</p>
                </div>
                <div class="mb-6 last:mb-0">
                    <h3 class="text-[1.1rem] font-bold text-[var(--accent-color)] mb-2 mt-0">What are the current treasury rates for short-term and long-term bonds?</h3>
                    <p class="text-[var(--text-secondary)] m-0">Current treasury rates vary across the maturity spectrum. Short-term rates (like 1-month or 6-month) reflect near-term monetary policy, while long-term rates (like 10-year or 30-year) reflect long-term growth and inflation expectations. Check our data table for the exact latest percentages.</p>
                </div>
                <div class="mb-6 last:mb-0">
                    <h3 class="text-[1.1rem] font-bold text-[var(--accent-color)] mb-2 mt-0">Why is the 2-year/10-year spread important?</h3>
                    <p class="text-[var(--text-secondary)] m-0">The 2-year/10-year spread is the most closely watched part of the yield curve. A negative spread (inversion) has historically been one of the most reliable leading indicators of an impending economic recession.</p>
                </div>
            </div>
        </section>

    </div>
  <script is:inline>
// Native Canvas Chart implementation
        window.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('yieldChart');
            const ctx = canvas.getContext('2d');

            // Data injected from build
            const terms = ["1 Mo","2 Mo","3 Mo","4 Mo","6 Mo","1 Yr","2 Yr","3 Yr","5 Yr","7 Yr","10 Yr","20 Yr","30 Yr"];
            const datasetNow = [3.72,3.75,3.67,3.69,3.61,3.48,3.52,3.6,3.79,4.01,4.26,4.82,4.87];
            const dataset1y = [4.37,4.37,4.31,4.33,4.28,4.17,4.22,4.27,4.36,4.47,4.58,4.88,4.83];
            const dataset2y = [5.53,5.46,5.42,5.4,5.18,4.73,4.27,4.05,3.91,3.95,3.99,4.34,4.22];

            function resize() {
                const parent = canvas.parentElement;
                canvas.width = parent.clientWidth;
                canvas.height = parent.clientHeight;
                drawChart();
            }

            window.addEventListener('resize', resize);

            function drawChart() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                const padding = { top: 20, right: 20, bottom: 40, left: 40 };
                const width = canvas.width - padding.left - padding.right;
                const height = canvas.height - padding.top - padding.bottom;

                // Find min and max
                let allVals = [...datasetNow, ...dataset1y, ...dataset2y].filter(v => v !== null);
                let maxVal = Math.max(...allVals) + 0.5;
                let minVal = Math.max(0, Math.min(...allVals) - 0.5); // ensure >= 0 unless actual negative

                // Draw grid lines and Y axis labels
                ctx.strokeStyle = '#152040';
                ctx.fillStyle = '#a0a8b8';
                ctx.font = '12px "JetBrains Mono"';
                ctx.textAlign = 'right';
                ctx.textBaseline = 'middle';

                const ySteps = 5;
                for(let i=0; i<=ySteps; i++) {
                    const val = minVal + (maxVal - minVal) * (i / ySteps);
                    const y = canvas.height - padding.bottom - (height * (i / ySteps));

                    ctx.beginPath();
                    ctx.moveTo(padding.left, y);
                    ctx.lineTo(canvas.width - padding.right, y);
                    ctx.stroke();

                    ctx.fillText(val.toFixed(1) + '%', padding.left - 5, y);
                }

                // Draw X axis labels
                ctx.textAlign = 'center';
                ctx.textBaseline = 'top';
                for(let i=0; i<terms.length; i++) {
                    const x = padding.left + (width * (i / (terms.length - 1)));

                    // only show some labels on mobile to prevent overlap
                    if (window.innerWidth < 600 && i % 2 !== 0 && i !== terms.length -1) continue;

                    ctx.fillText(terms[i], x, canvas.height - padding.bottom + 10);
                }

                // Draw lines
                function drawLine(dataset, color, fillAlpha) {
                    ctx.beginPath();
                    let started = false;
                    for(let i=0; i<terms.length; i++) {
                        if (dataset[i] === null) continue;

                        const x = padding.left + (width * (i / (terms.length - 1)));
                        const y = canvas.height - padding.bottom - (height * ((dataset[i] - minVal) / (maxVal - minVal)));

                        if (!started) {
                            ctx.moveTo(x, y);
                            started = true;
                        } else {
                            ctx.lineTo(x, y);
                        }
                    }

                    ctx.strokeStyle = color;
                    ctx.lineWidth = 3;
                    ctx.lineJoin = 'round';
                    ctx.stroke();

                    // Optional fill (like area chart)
                    if (fillAlpha && started) {
                        ctx.lineTo(canvas.width - padding.right, canvas.height - padding.bottom);
                        ctx.lineTo(padding.left, canvas.height - padding.bottom);
                        ctx.fillStyle = color.replace('rgb', 'rgba').replace(')', `, ${fillAlpha})`);
                        ctx.fill();
                    }
                }

                drawLine(dataset2y, 'rgb(46, 204, 113)', 0.0);
                drawLine(dataset1y, 'rgb(231, 76, 60)', 0.0);
                drawLine(datasetNow, 'rgb(74, 143, 231)', 0.1);
            }

            // Initial draw
            resize();
        });
  </script>
</SiteLayout>
