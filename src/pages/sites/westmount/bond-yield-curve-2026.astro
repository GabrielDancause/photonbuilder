                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">5.46%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
                            <td class="p-3 text-left border-b border-[var(--border-color)] text-white"><strong class="font-bold">3 Mo</strong></td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">3.67%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">4.31%</td>
                            <td class="p-3 text-right border-b border-[var(--border-color)] text-white">5.42%</td>
                        </tr>

                        <tr class="last:[&>td]:border-b-0">
