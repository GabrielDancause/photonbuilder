// Filtering
const fMcap = document.getElementById('fMcap');
const fPe = document.getElementById('fPe');
const fYield = document.getElementById('fYield');
const fPerf = document.getElementById('fPerf');
const searchEl = document.getElementById('search');

function resetFilters() {
  fMcap.value = '';
  fPe.value = '';
  fYield.value = '';
  fSector.value = '';
  fPerf.value = '';
  searchEl.value = '';
  activePreset = -1;
  document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
}

document.getElementById('resetBtn').addEventListener('click', () => {
  resetFilters();
  renderTable();
});

document.getElementById('applyBtn').addEventListener('click', () => {
  activePreset = -1;
  document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
  renderTable();
});

searchEl.addEventListener('input', renderTable);

function parseRange(val) {
  if (!val) return null;
  const parts = val.split('-');
  if (parts.length === 3 && parts[0] === '') {
    return [-parseFloat(parts[1]), parts[2] === '' ? Infinity : parseFloat(parts[2])];
  }
  const lo = parts[0] === '' ? -Infinity : parseFloat(parts[0]);
  const hi = parts.length < 2 || parts[1] === '' ? Infinity : parseFloat(parts[1]);
  return [lo, hi];
}

function inRange(val, range) {
  if (!range) return true;
  return val >= range[0] && val <= range[1];
}

let sortKey = 'mcap', sortDir = -1;

function filterStocks() {
  const q = searchEl.value.toLowerCase();
  let filtered = STOCKS;

  if (activePreset >= 0) {
    const p = presets[activePreset];
    const c = p.criteria;
    filtered = filtered.filter(s => {
      if (c.pe) {
        const r = parseRange(c.pe);
        if (s.pe <= 0 || !inRange(s.pe, r)) return false;
      }
      if (c.peMin && (s.pe <= 0 || s.pe < parseFloat(c.peMin))) return false;
      if (c.yield) {
        const r = parseRange(c.yield);
        if (!inRange(s.yield, r)) return false;
      }
      if (c.perf) {
        const r = parseRange(c.perf);
        if (!inRange(s.w52, r)) return false;
      }
      if (c.mcap) {
        const r = parseRange(c.mcap);
        if (!inRange(s.mcap, r)) return false;
      }
      if (c.divYears && s.divYears < c.divYears) return false;
      return true;
    });
  } else {
    const rMcap = parseRange(fMcap.value);
    const rPe = parseRange(fPe.value);
    const rYield = parseRange(fYield.value);
    const sector = fSector.value;
    const rPerf = parseRange(fPerf.value);

    filtered = filtered.filter(s => {
      if (q && !s.ticker.toLowerCase().includes(q) && !s.name.toLowerCase().includes(q)) return false;
      if (rMcap && !inRange(s.mcap, rMcap)) return false;
      if (rPe) {
        if (s.pe <= 0 || !inRange(s.pe, rPe)) return false;
      }
      if (rYield) {
        if (rYield[0] === 0 && rYield[1] === 0 && s.yield > 0) return false;
        else if (rYield[1] !== 0 && !inRange(s.yield, rYield)) return false;
      }
      if (sector && s.sector !== sector) return false;
      if (rPerf && !inRange(s.w52, rPerf)) return false;
      return true;
    });
  }

  if (q && activePreset >= 0) {
    filtered = filtered.filter(s => s.ticker.toLowerCase().includes(q) || s.name.toLowerCase().includes(q));
  }

  filtered.sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (va == null || va === 0 && sortKey === 'pe') return 1;
    if (vb == null || vb === 0 && sortKey === 'pe') return -1;
    if (typeof va === 'string') return va.localeCompare(vb) * sortDir;
    return (va - vb) * sortDir;
  });

  return filtered;
}

function fmtMcap(v) {
  if (v >= 1000) return '$' + (v/1000).toFixed(1) + 'T';
  return '$' + v + 'B';
}

function renderTable() {
  const filtered = filterStocks();
  document.getElementById('resultCount').textContent = `Showing ${filtered.length} of ${STOCKS.length} stocks`;

  const tbody = document.getElementById('tbody');
  tbody.innerHTML = filtered.map(s => `<tr>
    <td class="ticker">${s.ticker}</td>
    <td>${s.name}</td>
    <td class="num">$${s.price.toFixed(2)}</td>
    <td class="num">${fmtMcap(s.mcap)}</td>
    <td class="num">${s.pe > 0 ? s.pe.toFixed(1) : 'N/A'}</td>
    <td class="num">${s.yield > 0 ? s.yield.toFixed(1) + '%' : '—'}</td>
    <td>${s.sector}</td>
    <td class="num ${s.w52 >= 0 ? 'pos' : 'neg'}">${s.w52 > 0 ? '+' : ''}${s.w52.toFixed(1)}%</td>
  </tr>`).join('');
}

// Sortable headers
document.querySelectorAll('th[data-key]').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.key;
    if (sortKey === key) sortDir *= -1;
    else { sortKey = key; sortDir = th.dataset.type === 'num' ? -1 : 1; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
    renderTable();
  });
});

renderTable();

