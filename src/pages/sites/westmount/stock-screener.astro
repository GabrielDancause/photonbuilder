              <th data-key="name">Company</th>
              <th data-key="price" data-type="num">Price</th>
              <th data-key="mcap" data-type="num">Market Cap</th>
              <th data-key="pe" data-type="num">PE Ratio</th>
              <th data-key="yield" data-type="num">Div Yield</th>
              <th data-key="sector">Sector</th>
