---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Nancy Pelosi Stock Tracker: Congressional Trading Analysis & Copy-Trade Performance",
  description: "Track Nancy Pelosi's stock portfolio, analyze congressional trades, and calculate copy-trade returns. The definitive resource for following political stock trading with 37+ years of market data.",
  category: "tool",
  published: "2026-03-28",
};

// Static price data (last updated: March 2026)
const staticPrices = {
  NVDA: 874.50,
  AAPL: 172.30,
  MSFT: 420.15,
  GOOGL: 138.25,
  AMZN: 155.80,
  PANW: 342.90,
  AVGO: 1285.70,
  CRM: 278.40,
  RBLX: 45.20,
  DIS: 112.80
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Westmont Fundamentals",
      "url": "https://westmountfundamentals.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Westmont Fundamentals",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "datePublished": meta.published,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/nancy-pelosi-stock-tracker"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What stocks does Nancy Pelosi own?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nancy Pelosi's portfolio is primarily managed by her husband Paul Pelosi and includes major holdings in NVDA, AAPL, MSFT, GOOGL, AVGO, and other big tech companies. The estimated portfolio value exceeds $50M based on public disclosures."
        }
      },
      {
        "@type": "Question",
        "name": "How do I track Nancy Pelosi's stock trades?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can track congressional trades through Capitol Trades, Quiver Quantitative, House Stock Watcher, EDGAR filings at sec.gov, and social media trackers. The STOCK Act requires disclosure within 45 days of trades."
        }
      },
      {
        "@type": "Question",
        "name": "Has Nancy Pelosi outperformed the S&P 500?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, analysis shows the Pelosi portfolio has consistently outperformed the S&P 500 over multiple time periods, largely due to strategic big tech call options and leveraged positions in growth stocks."
        }
      },
      {
        "@type": "Question",
        "name": "What is the STOCK Act?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Stop Trading on Congressional Knowledge Act of 2012 requires members of Congress to disclose stock trades within 45 days and prohibits insider trading based on non-public information from official duties."
        }
      },
      {
        "@type": "Question",
        "name": "Can Congress members trade stocks?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Congress members can legally trade stocks under current law, but must disclose trades via the STOCK Act. Multiple proposals to ban congressional trading have been introduced but not passed as of 2026."
        }
      },
      {
        "@type": "Question",
        "name": "Should congressional stock trading be banned?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Polling shows 70%+ of Americans support banning congressional stock trading. Bipartisan proposals like the TRUST Act and ETHICS Act have been introduced but face implementation challenges regarding enforcement and exceptions."
        }
      }
    ]
  }
];
