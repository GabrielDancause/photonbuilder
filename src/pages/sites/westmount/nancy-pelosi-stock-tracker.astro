  <script id="price-data" type="application/json" set:html={JSON.stringify(staticPrices)}></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Price data
      let prices = {};
      try {
        const dataElement = document.getElementById('price-data');
        if (dataElement) {
          prices = JSON.parse(dataElement.textContent);
        }
      } catch (e) {
        console.error("Failed to parse price data", e);
      }

      // Trade history filtering
      const filterButtons = document.querySelectorAll('.filter-btn');
      const tradesTable = document.getElementById('trades-tbody');
      
      filterButtons.forEach(button => {
        button.addEventListener('click', () => {
          // Update active button
          filterButtons.forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');
          
          const filter = button.getAttribute('data-filter');
          const rows = tradesTable.querySelectorAll('tr');
          
          rows.forEach(row => {
            if (filter === 'all') {
              row.style.display = '';
            } else if (filter === 'options') {
              row.style.display = row.textContent.includes('Call Options') ? '' : 'none';
            } else {
              const type = row.getAttribute('data-type');
              row.style.display = type === filter ? '' : 'none';
            }
          });
        });
      });

      // Copy-trade calculator
      const tradeSelect = document.getElementById('trade-select');
      const investmentInput = document.getElementById('investment-amount');
      const entryPriceEl = document.getElementById('entry-price');
      const currentPriceEl = document.getElementById('current-price');
      const currentValueEl = document.getElementById('current-value');
      const totalReturnEl = document.getElementById('total-return');

      function calculateReturns() {
        const selectedOption = tradeSelect.options[tradeSelect.selectedIndex];
        const ticker = selectedOption.getAttribute('data-ticker');
        const entryPrice = parseFloat(selectedOption.getAttribute('data-price'));
        const investment = parseFloat(investmentInput.value) || 0;
        
        const currentPrice = prices[ticker] || 0;
        
        entryPriceEl.textContent = '$' + entryPrice.toFixed(2);
        currentPriceEl.textContent = '$' + currentPrice.toFixed(2);
        
        if (investment > 0 && currentPrice > 0) {
          const shares = investment / entryPrice;
          const currentValue = shares * currentPrice;
          const returnPercent = ((currentPrice - entryPrice) / entryPrice) * 100;
          
          currentValueEl.textContent = '$' + currentValue.toLocaleString('en-US', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
          });
          
          totalReturnEl.textContent = (returnPercent >= 0 ? '+' : '') + returnPercent.toFixed(1) + '%';
          totalReturnEl.className = 'big-number ' + (returnPercent >= 0 ? 'positive' : 'negative');
        }
      }

      tradeSelect.addEventListener('change', calculateReturns);
      investmentInput.addEventListener('input', calculateReturns);
      calculateReturns();

      // Portfolio allocation chart
      const canvas = document.getElementById('allocation-chart');
      const ctx = canvas.getContext('2d');
      canvas.width = 300;
      canvas.height = 300;

      const data = [
        { label: 'Technology', value: 65, color: '#4a8fe7' },
        { label: 'Communication', value: 15, color: '#48bb78' },
        { label: 'Financials', value: 10, color: '#ed8936' },
        { label: 'Other', value: 10, color: '#9f7aea' }
      ];

      let currentAngle = 0;
      const centerX = canvas.width / 2;
      const centerY = canvas.height / 2;
      const radius = 120;

      data.forEach(segment => {
        const sliceAngle = (segment.value / 100) * 2 * Math.PI;
        
        ctx.beginPath();
        ctx.moveTo(centerX, centerY);
        ctx.arc(centerX, centerY, radius, currentAngle, currentAngle + sliceAngle);
        ctx.closePath();
        ctx.fillStyle = segment.color;
        ctx.fill();
        
        currentAngle += sliceAngle;
      });
    });
  </script>

