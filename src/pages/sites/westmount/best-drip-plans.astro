      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div id="faq"></div>
    </div>
  </div>

  <script is:inline>
    const FAQ = [
      {q:"What is a Dividend Reinvestment Plan (DRIP)?",a:"A Dividend Reinvestment Plan (DRIP) is a program that allows investors to automatically reinvest their cash dividends into additional shares or fractional shares of the underlying stock on the dividend payment date, often commission-free."},
      {q:"Are reinvested dividends still taxed?",a:"Yes. Even though you don't receive the cash in hand, the IRS treats reinvested dividends exactly the same as cash dividends. You will owe taxes on them in the year they are distributed unless they are held in a tax-advantaged account like an IRA."},
      {q:"What is the difference between a broker DRIP and a company DRIP?",a:"A broker DRIP (synthetic DRIP) is offered by your brokerage, purchasing shares on the open market. A company DRIP (direct DRIP) is offered directly by the issuing company or its transfer agent, sometimes allowing you to buy shares at a slight discount to the market price."},
      {q:"What are the pros and cons of using a DRIP versus manual reinvesting?",a:"DRIPs offer automation, compounding growth without effort, and often fractional share purchases. The main con is a lack of control; dividends are reinvested into the same stock regardless of valuation, whereas manual reinvesting lets you allocate cash to your best current ideas."},
      {q:"Which brokerages are best for DRIP investing?",a:"Top brokerages for DRIP investing include Fidelity, Charles Schwab, and Vanguard, as they offer free and automatic dividend reinvestment into fractional shares for most stocks and ETFs."}
    ];

    function renderFAQ(){
      const container=document.getElementById('faq');
      container.innerHTML=FAQ.map(f=>`
        <div class="faq-item">
          <div class="faq-q">${f.q}</div>
          <div class="faq-a">${f.a}</div>
        </div>
      `).join('');
      container.querySelectorAll('.faq-q').forEach(q=>{
        q.addEventListener('click',()=>q.parentElement.classList.toggle('open'));
      });
    }

    renderFAQ();
  </script>
