  <div class="stat"><div class="val">5</div><div class="label">Risk Profiles</div></div>
  <div class="stat"><div class="val">~2 min</div><div class="label">Time to Complete</div></div>
  <div class="stat"><div class="val">5</div><div class="label">Model Portfolios</div></div>
</div>

<!-- Quiz -->
