    </a>
  </div>
</div>

<div class="methodology">
  <h2>Methodology</h2>
  <p>This risk tolerance questionnaire evaluates two dimensions: your emotional willingness to accept volatility (risk tolerance) and your financial ability to absorb losses (risk capacity). Each of the 10 questions is scored 1–4 points, producing a total score of 10–40 that maps to one of five risk profiles.</p>
  <p>Recommended asset allocations are based on modern portfolio theory and reflect widely-used institutional models. Model ETF portfolios use low-cost Vanguard funds as representative examples — similar funds from Schwab, Fidelity, or iShares can substitute. Expected returns are based on long-term historical averages and are not guarantees.</p>
</div>

<div class="disclaimer">This quiz is for educational purposes only and does not constitute investment advice. Your actual risk tolerance may differ based on factors not captured here. Consult a qualified financial advisor before making investment decisions.</div>

</div>
  <script is:inline>
const QUESTIONS = [
  {
    q: "What is your investment time horizon?",
    opts: [
      { text: "Less than 3 years", pts: 1 },
      { text: "3 to 5 years", pts: 2 },
      { text: "6 to 10 years", pts: 3 },
      { text: "More than 10 years", pts: 4 }
    ]
  },
  {
    q: "If your portfolio dropped 20% in one month, what would you do?",
    opts: [
      { text: "Sell everything to prevent further losses", pts: 1 },
      { text: "Sell some holdings to reduce risk", pts: 2 },
      { text: "Hold and wait for recovery", pts: 3 },
      { text: "Buy more at the lower prices", pts: 4 }
    ]
  },
  {
    q: "How stable is your current income?",
    opts: [
      { text: "Unstable — freelance, commission-based, or between jobs", pts: 1 },
      { text: "Somewhat stable — employed but in a volatile industry", pts: 2 },
      { text: "Stable — steady salary with good job security", pts: 3 },
      { text: "Very stable — multiple income sources or guaranteed income", pts: 4 }
    ]
  },
  {
    q: "How much investment experience do you have?",
    opts: [
      { text: "None — I have never invested before", pts: 1 },
      { text: "Beginner — I have a savings account or basic index fund", pts: 2 },
      { text: "Intermediate — I actively manage a diversified portfolio", pts: 3 },
      { text: "Advanced — I understand options, alternatives, and complex strategies", pts: 4 }
    ]
  },
  {
    q: "What is the primary goal for this investment?",
    opts: [
      { text: "Preserve my capital — I cannot afford to lose money", pts: 1 },
      { text: "Generate steady income with minimal growth", pts: 2 },
      { text: "Balanced growth and income over time", pts: 3 },
      { text: "Maximize long-term growth — I accept short-term losses", pts: 4 }
    ]
  },
  {
    q: "How large is your emergency fund relative to your monthly expenses?",
    opts: [
      { text: "Less than 1 month of expenses", pts: 1 },
      { text: "1 to 3 months of expenses", pts: 2 },
      { text: "3 to 6 months of expenses", pts: 3 },
      { text: "More than 6 months of expenses", pts: 4 }
    ]
  },
  {
    q: "What percentage of your total savings are you investing?",
    opts: [
      { text: "More than 75% — this is most of my savings", pts: 1 },
      { text: "50% to 75% — a significant portion", pts: 2 },
      { text: "25% to 50% — a moderate portion", pts: 3 },
      { text: "Less than 25% — a small portion of my total wealth", pts: 4 }
    ]
  },
  {
    q: "How would you feel if your portfolio was flat (0% return) for 3 years?",
    opts: [
      { text: "Very uncomfortable — I would switch strategies immediately", pts: 1 },
      { text: "Somewhat uncomfortable — I would start looking for alternatives", pts: 2 },
      { text: "Neutral — I understand markets go through cycles", pts: 3 },
      { text: "Fine — I am focused on 10+ year performance", pts: 4 }
    ]
  },
  {
    q: "Which statement best describes your attitude toward investment risk?",
    opts: [
      { text: "I want to avoid losses even if it means lower returns", pts: 1 },
      { text: "I prefer stability but accept small fluctuations for modest growth", pts: 2 },
      { text: "I am comfortable with moderate ups and downs for better long-term returns", pts: 3 },
      { text: "I embrace volatility — higher risk means higher potential reward", pts: 4 }
    ]
  },
  {
    q: "At what age do you plan to start withdrawing from this investment?",
    opts: [
      { text: "Within 5 years", pts: 1 },
      { text: "In 5 to 15 years", pts: 2 },
      { text: "In 15 to 25 years", pts: 3 },
      { text: "25+ years from now or no specific date", pts: 4 }
    ]
  }
];

const PROFILES = [
  {
    name: "Conservative",
    range: "10–16",
    min: 10, max: 16,
    desc: "You prioritize capital preservation and income stability over growth. You prefer predictable, low-volatility investments and are uncomfortable with significant portfolio swings. This allocation emphasizes bonds and fixed-income, with modest stock exposure for inflation protection.",
    stocks: 20, bonds: 65, alts: 15,
    expectedReturn: "4–5%",
    maxDrawdown: "~8–12%",
