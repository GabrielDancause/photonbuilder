// State
let currentQ = 0;
const answers = new Array(QUESTIONS.length).fill(-1);

const questionContainer = document.getElementById('questionContainer');
const progressFill = document.getElementById('progressFill');
const progressText = document.getElementById('progressText');
const btnNext = document.getElementById('btnNext');
const btnBack = document.getElementById('btnBack');

function renderQuestion() {
  const q = QUESTIONS[currentQ];
  progressText.textContent = `Question ${currentQ + 1} of ${QUESTIONS.length}`;
  progressFill.style.width = ((currentQ + 1) / QUESTIONS.length * 100) + '%';
  btnBack.style.visibility = currentQ === 0 ? 'hidden' : 'visible';
  btnNext.textContent = currentQ === QUESTIONS.length - 1 ? 'See Results' : 'Next';
  btnNext.disabled = answers[currentQ] === -1;

  questionContainer.innerHTML = `
    <div class="question-card">
      <div class="question-num">Question ${currentQ + 1} of ${QUESTIONS.length}</div>
      <div class="question-text">${q.q}</div>
      <div class="options">
        ${q.opts.map((o, i) => `
          <div class="option${answers[currentQ] === i ? ' selected' : ''}" data-idx="${i}">
            <div class="radio"></div>
            <span>${o.text}</span>
          </div>
        `).join('')}
      </div>
    </div>
  `;

  questionContainer.querySelectorAll('.option').forEach(el => {
    el.addEventListener('click', () => {
      answers[currentQ] = parseInt(el.dataset.idx);
      btnNext.disabled = false;
      questionContainer.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
    });
  });
}

btnNext.addEventListener('click', () => {
  if (answers[currentQ] === -1) return;
  if (currentQ < QUESTIONS.length - 1) {
    currentQ++;
    renderQuestion();
  } else {
    showResults();
  }
});

btnBack.addEventListener('click', () => {
  if (currentQ > 0) {
    currentQ--;
    renderQuestion();
  }
});

function getScore() {
  return answers.reduce((sum, a, i) => sum + QUESTIONS[i].opts[a].pts, 0);
}

function getProfile(score) {
  return PROFILES.find(p => score >= p.min && score <= p.max) || PROFILES[2];
}

function showResults() {
  document.getElementById('quizSection').style.display = 'none';
  const resultsEl = document.getElementById('resultsSection');
  resultsEl.style.display = 'block';

  const score = getScore();
  const profile = getProfile(score);

  document.getElementById('profileName').textContent = profile.name;
  document.getElementById('profileScore').textContent = `Score: ${score} / 40 (range: ${profile.range})`;
  document.getElementById('profileDesc').textContent = profile.desc;

  // Gauge needle
  const pct = (score - 10) / 30; // 0 to 1
  const angle = -90 + (pct * 180); // -90 to 90
  document.getElementById('gaugeNeedle').setAttribute('transform', `rotate(${angle},100,100)`);

  // Pie chart
  drawPie(profile);

  // Allocation details
  const allocColors = { stocks: '#4a8fe7', bonds: '#22c55e', alts: '#eab308' };
  const allocLabels = {
    stocks: { name: 'Stocks', sub: 'Equities — US & International' },
    bonds: { name: 'Bonds', sub: 'Fixed income & inflation-protected' },
    alts: { name: 'Alternatives', sub: 'Real estate, commodities, gold' }
  };
  const allocEl = document.getElementById('allocDetails');
  allocEl.innerHTML = '';
  ['stocks', 'bonds', 'alts'].forEach(key => {
    allocEl.innerHTML += `
      <div class="alloc-item">
        <div class="alloc-dot" style="background:${allocColors[key]}"></div>
        <div class="alloc-info">
          <div class="alloc-name">${allocLabels[key].name}</div>
          <div class="alloc-sub">${allocLabels[key].sub}</div>
        </div>
        <div class="alloc-pct">${profile[key]}%</div>
      </div>
    `;
  });

  // ETF portfolio
  const portfolioEl = document.getElementById('portfolioGrid');
  portfolioEl.innerHTML = '';
  profile.etfs.forEach(e => {
    portfolioEl.innerHTML += `
      <div class="etf-card">
        <div class="etf-ticker">${e.ticker}</div>
        <div class="etf-name">${e.name}</div>
        <div class="etf-stats">
          <div><strong>Allocation:</strong> ${e.pct}%</div>
          <div><strong>Expense Ratio:</strong> ${e.er}</div>
          <div><strong>Role:</strong> ${e.role}</div>
        </div>
      </div>
    `;
  });

  // Profiles table
  const profilesBody = document.getElementById('profilesBody');
  profilesBody.innerHTML = '';
  PROFILES.forEach(p => {
    const isActive = p.name === profile.name;
    profilesBody.innerHTML += `
      <tr class="${isActive ? 'active-row' : ''}">
        <td style="font-weight:600;${isActive ? 'color:var(--accent-color)' : ''}">${p.name}${isActive ? ' ←' : ''}</td>
        <td class="num">${p.range}</td>
        <td class="num">${p.stocks}%</td>
        <td class="num">${p.bonds}%</td>
        <td class="num">${p.alts}%</td>
        <td class="num">${p.expectedReturn}</td>
        <td class="num">${p.maxDrawdown}</td>
      </tr>
    `;
  });

  resultsEl.scrollIntoView({ behavior: 'smooth' });
}

function drawPie(profile) {
  const canvas = document.getElementById('pieChart');
  const ctx = canvas.getContext('2d');
  const size = 280;
  canvas.width = size * 2;
  canvas.height = size * 2;
  ctx.scale(2, 2);

  const cx = size / 2, cy = size / 2, r = 110, inner = 70;
  const slices = [
    { pct: profile.stocks / 100, color: '#4a8fe7' },
    { pct: profile.bonds / 100, color: '#22c55e' },
    { pct: profile.alts / 100, color: '#eab308' }
  ];

  let startAngle = -Math.PI / 2;
  slices.forEach(s => {
    const endAngle = startAngle + s.pct * 2 * Math.PI;
    ctx.beginPath();
    ctx.arc(cx, cy, r, startAngle, endAngle);
    ctx.arc(cx, cy, inner, endAngle, startAngle, true);
    ctx.closePath();
    ctx.fillStyle = s.color;
    ctx.fill();
    startAngle = endAngle;
  });

  // Center text
  ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-primary') || '#e2e8f0';
  ctx.font = 'bold 32px JetBrains Mono, monospace';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(profile.stocks + '%', cx, cy - 8);
  ctx.font = '12px Inter, sans-serif';
  ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary') || '#94a3b8';
  ctx.fillText('Stocks', cx, cy + 14);
}

// Retake
document.getElementById('btnRetake').addEventListener('click', () => {
  currentQ = 0;
  answers.fill(-1);
  document.getElementById('resultsSection').style.display = 'none';
  document.getElementById('quizSection').style.display = 'block';
  renderQuestion();
  document.getElementById('quizSection').scrollIntoView({ behavior: 'smooth' });
});

