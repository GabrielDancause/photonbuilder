              <stop offset="25%" stop-color="#86efac"/>
              <stop offset="50%" stop-color="#eab308"/>
              <stop offset="75%" stop-color="#f97316"/>
              <stop offset="100%" stop-color="#ef4444"/>
            </linearGradient>
