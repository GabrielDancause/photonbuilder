// Sector colors
const SECTOR_COLORS = {
  "Information Technology":"#4A8FE7","Health Care":"#22c55e","Financials":"#f59e0b",
  "Consumer Discretionary":"#ef4444","Communication Services":"#8b5cf6","Industrials":"#06b6d4",
  "Consumer Staples":"#ec4899","Energy":"#f97316","Materials":"#14b8a6",
  "Utilities":"#6366f1","Real Estate":"#84cc16"
};

const GICS_SECTORS = ["Information Technology","Health Care","Financials","Consumer Discretionary",
  "Communication Services","Industrials","Consumer Staples","Energy","Materials","Utilities","Real Estate"];

// Compute total weight for normalization
const totalWeight = SP500.reduce((a,s)=>a+s.weight,0);
const totalMcap = SP500.reduce((a,s)=>a+s.mcap,0);

// Stats bar
document.getElementById('stats').innerHTML = `
  <div class="stat"><div class="val">${SP500.length}</div><div class="label">Companies Listed</div></div>
  <div class="stat"><div class="val">11</div><div class="label">GICS Sectors</div></div>
  <div class="stat"><div class="val">$${(totalMcap/1000).toFixed(1)}T</div><div class="label">Total Market Cap</div></div>
  <div class="stat"><div class="val">${totalWeight.toFixed(1)}%</div><div class="label">Weight Coverage</div></div>
`;

// Sector filter
const fSector = document.getElementById('fSector');
GICS_SECTORS.forEach(s => {
  fSector.innerHTML += `<option value="${s}">${s}</option>`;
});

// Top 10 by weight
const top10 = [...SP500].sort((a,b)=>b.weight-a.weight).slice(0,10);
const top10El = document.getElementById('top10');
top10.forEach((s,i) => {
  top10El.innerHTML += `<div class="top10-card">
    <div class="top10-rank">#${i+1}</div>
    <div class="top10-ticker">${s.ticker}</div>
    <div class="top10-name">${s.name}</div>
    <div class="top10-stats">
      <span>Cap: <strong>${s.mcap>=1000?'$'+(s.mcap/1000).toFixed(1)+'T':'$'+s.mcap+'B'}</strong></span>
      <span>Weight: <strong>${s.weight.toFixed(2)}%</strong></span>
    </div>
  </div>`;
});

// Pie chart
function drawPie() {
  const canvas = document.getElementById('pieChart');
  const ctx = canvas.getContext('2d');
  const cx = 140, cy = 140, r = 130;
  const sectorWeights = {};
  GICS_SECTORS.forEach(sec => { sectorWeights[sec] = 0; });
  SP500.forEach(s => { if(sectorWeights[s.sector]!==undefined) sectorWeights[s.sector] += s.weight; });

  // Normalize to 100%
  const total = Object.values(sectorWeights).reduce((a,v)=>a+v,0);
  let startAngle = -Math.PI/2;

  const legendEl = document.getElementById('pieLegend');
  const entries = GICS_SECTORS.map(sec => ({sec, w: sectorWeights[sec]})).sort((a,b)=>b.w-a.w);

  entries.forEach(({sec, w}) => {
    const sliceAngle = (w / total) * 2 * Math.PI;
    const color = SECTOR_COLORS[sec] || '#666';

    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, startAngle, startAngle + sliceAngle);
    ctx.closePath();
    ctx.fillStyle = color;
    ctx.fill();
    ctx.strokeStyle = '#0a0f1e';
    ctx.lineWidth = 2;
    ctx.stroke();

    startAngle += sliceAngle;

    const pct = ((w / total) * 100).toFixed(1);
    legendEl.innerHTML += `<div class="legend-item">
      <div class="legend-dot" style="background:${color}"></div>
      <span>${sec}</span>
      <span class="legend-pct">${pct}%</span>
    </div>`;
  });
}
drawPie();

// Table
let sortKey = 'weight', sortDir = -1;
const searchEl = document.getElementById('search');

function filterData() {
  const q = searchEl.value.toLowerCase();
  const sector = fSector.value;
  return SP500.filter(s => {
    if (q && !s.ticker.toLowerCase().includes(q) && !s.name.toLowerCase().includes(q)) return false;
    if (sector && s.sector !== sector) return false;
    return true;
  }).sort((a,b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (typeof va === 'string') return va.localeCompare(vb) * sortDir;
    return (va - vb) * sortDir;
  });
}

function fmtMcap(v) {
  if (v >= 1000) return '$' + (v/1000).toFixed(1) + 'T';
  return '$' + v + 'B';
}

function renderTable() {
  const filtered = filterData();
  document.getElementById('resultCount').textContent = `Showing ${filtered.length} of ${SP500.length} companies`;
  const tbody = document.getElementById('tbody');
  tbody.innerHTML = filtered.map(s => `<tr>
    <td class="ticker">${s.ticker}</td>
    <td>${s.name}</td>
    <td>${s.sector}</td>
    <td>${s.subIndustry}</td>
    <td class="num">${fmtMcap(s.mcap)}</td>
    <td class="num">${s.weight.toFixed(2)}%</td>
    <td class="num">${s.dateAdded}</td>
  </tr>`).join('');
}

searchEl.addEventListener('input', renderTable);
fSector.addEventListener('change', renderTable);

document.querySelectorAll('th[data-key]').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.key;
    if (sortKey === key) sortDir *= -1;
    else { sortKey = key; sortDir = th.dataset.type === 'num' ? -1 : 1; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
    renderTable();
  });
});

renderTable();

// Sector stats table
const sectorStatsBody = document.getElementById('sectorStatsBody');
const maxSectorWeight = Math.max(...GICS_SECTORS.map(sec => SP500.filter(s=>s.sector===sec).reduce((a,s)=>a+s.weight,0)));

GICS_SECTORS.map(sec => {
  const companies = SP500.filter(s => s.sector === sec);
  const count = companies.length;
  const totalW = companies.reduce((a,s) => a + s.weight, 0);
  const avgMcap = companies.reduce((a,s) => a + s.mcap, 0) / (count || 1);
  return {sec, count, totalW, avgMcap};
}).sort((a,b) => b.totalW - a.totalW).forEach(({sec, count, totalW, avgMcap}) => {
  const barWidth = (totalW / maxSectorWeight) * 100;
  sectorStatsBody.innerHTML += `<tr>
    <td style="font-weight:600;color:${SECTOR_COLORS[sec]||'var(--text-primary)'}">${sec}</td>
    <td class="num">${count}</td>
    <td class="num">${fmtMcap(Math.round(avgMcap))}</td>
    <td class="num">${totalW.toFixed(2)}%</td>
    <td style="min-width:120px"><div class="sector-bar" style="width:${barWidth}%;background:${SECTOR_COLORS[sec]||'var(--accent-color)'}"></div></td>
  </tr>`;
});

