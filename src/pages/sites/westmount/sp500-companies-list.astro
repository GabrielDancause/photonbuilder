---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How many companies are in the S&P 500?","acceptedAnswer":{"@type":"Answer","text":"The S&P 500 contains approximately 503 stocks despite its name, because some companies like Alphabet (GOOGL/GOOG) and Berkshire Hathaway (BRK.A/BRK.B) have multiple share classes that are each listed separately. The index is maintained by the S&P Dow Jones Indices committee, which adds and removes companies based on market cap, liquidity, domicile, public float, sector classification, financial viability, and trading history. Reconstitutions happen quarterly but changes can occur at any time."}},
    {"@type":"Question","name":"What are the requirements to be included in the S&P 500?","acceptedAnswer":{"@type":"Answer","text":"To be added to the S&P 500, a company must: (1) be a U.S. company, (2) have a market cap of at least $18 billion (as of 2026), (3) be highly liquid with an annual trading volume of at least 250,000 shares in each of the six months before evaluation, (4) have at least 50% of shares available to the public, (5) have positive earnings in the most recent quarter and over the most recent four quarters combined, and (6) have been publicly listed for at least 12 months. The S&P committee has some discretion beyond these criteria."}},
    {"@type":"Question","name":"Which sector has the largest weight in the S&P 500?","acceptedAnswer":{"@type":"Answer","text":"Information Technology is by far the largest sector in the S&P 500, representing approximately 32% of the index weight as of early 2026. This is driven by mega-cap tech companies like Apple ($3.5T), Microsoft ($3.4T), and NVIDIA ($3.5T). The next largest sectors are Healthcare (~12%), Financials (~13%), and Consumer Discretionary (~10%). The tech sector's dominance has led to concentration concerns, as the top 10 stocks alone represent roughly 35% of the entire index."}},
    {"@type":"Question","name":"What is the difference between the S&P 500 and the Dow Jones Industrial Average?","acceptedAnswer":{"@type":"Answer","text":"The S&P 500 includes ~500 large-cap U.S. stocks weighted by market capitalization, while the Dow Jones Industrial Average (DJIA) contains only 30 blue-chip stocks weighted by share price. The S&P 500 is considered a better representation of the U.S. stock market because it covers approximately 80% of total market capitalization. The Dow's price-weighting means a $500 stock has more influence than a $50 stock regardless of company size, which can create distortions. Most institutional investors benchmark against the S&P 500, not the Dow."}},
    {"@type":"Question","name":"How often does the S&P 500 change its constituents?","acceptedAnswer":{"@type":"Answer","text":"The S&P 500 is rebalanced quarterly (March, June, September, December) and the committee can make changes at any time between scheduled rebalances. On average, 20–25 companies are added or removed per year, typically due to mergers, acquisitions, spinoffs, or companies falling below the minimum market cap threshold. Recent notable additions include companies from AI and tech sectors, while removals often involve companies acquired in M&A deals or those whose market caps have declined significantly."}},
    {"@type":"Question","name":"What is the average annual return of the S&P 500?","acceptedAnswer":{"@type":"Answer","text":"The S&P 500 has delivered an average annual return of approximately 10.5% since its inception in 1957, or about 7% after adjusting for inflation. However, returns vary dramatically by decade: the 1990s returned 18.2% annually, while the 2000s returned just 1.2% annually. Over any 20-year rolling period in history, the S&P 500 has never delivered a negative total return, which is why most financial advisors recommend a long-term buy-and-hold approach through low-cost index funds like VOO, SPY, or IVV."}},
    {"@type":"Question","name":"What does S&P 500 index weight mean?","acceptedAnswer":{"@type":"Answer","text":"S&P 500 index weight represents how much of the total index value a single stock accounts for, calculated as (company market cap ÷ total index market cap × 100). A higher weight means the stock has more influence on the index's daily movement. For example, Apple at ~7% weight means a 1% move in Apple shifts the S&P 500 by about 0.07%. The index is float-adjusted, meaning only publicly tradable shares count toward weight calculation, which can differ from total market cap. This market-cap weighting means larger companies naturally have more influence on performance."}},
    {"@type":"Question","name":"Can I invest directly in the S&P 500?","acceptedAnswer":{"@type":"Answer","text":"You cannot buy the S&P 500 index directly, but you can invest in index funds and ETFs that track it almost perfectly. The three most popular options are: SPY (SPDR S&P 500 ETF, $500B+ in assets, 0.09% expense ratio), VOO (Vanguard S&P 500 ETF, $400B+ in assets, 0.03% expense ratio), and IVV (iShares Core S&P 500 ETF, $380B+ in assets, 0.03% expense ratio). For taxable accounts, VOO or IVV are preferable due to lower expense ratios. Fidelity's FXAIX and Schwab's SWPPX are popular mutual fund alternatives with similarly low fees."}}
  ]
};

export const meta = {
  title: "S&P 500 Companies List — Complete Index Guide (2026)",
  description: "Complete list of all S&P 500 companies with ticker, sector, market cap & index weight. Sortable table, sector breakdown, and top holdings by weight.",
  category: "guide",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="S&P 500 Companies List: All Stocks in the Index (2026)"
  description="Complete list of all S&P 500 companies with ticker, sector, sub-industry, market cap, and index weight. Filter by sector, search by name, and explore sector breakdowns."
  canonical="https://westmountfundamentals.com/sp500-companies-list" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
header h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
header p.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.meta{color:var(--text-secondary);font-size:13px;margin-top:12px;font-family:'JetBrains Mono',monospace}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:32px 0}
.stat{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.stat .val{font-size:32px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.stat .label{font-size:13px;color:var(--text-secondary);margin-top:4px}

/* Top 10 */
.top10-section{margin:32px 0}
.top10-section h2{font-size:22px;margin-bottom:16px}
.top10-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
.top10-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:18px;position:relative;transition:border-color .2s}
.top10-card:hover{border-color:var(--accent-color)}
.top10-rank{position:absolute;top:10px;right:14px;font-size:28px;font-weight:800;color:var(--border-color);font-family:'JetBrains Mono',monospace}
.top10-ticker{font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--accent-color);font-size:16px}
.top10-name{font-size:13px;color:var(--text-secondary);margin:2px 0 10px}
.top10-stats{display:flex;gap:16px;font-size:12px;font-family:'JetBrains Mono',monospace}
.top10-stats span{color:var(--text-secondary)}
.top10-stats strong{color:var(--text-primary)}

/* Pie chart */
.chart-section{margin:32px 0}
.chart-section h2{font-size:22px;margin-bottom:16px}
.chart-container{display:flex;gap:32px;align-items:center;flex-wrap:wrap}
.pie-wrap{flex-shrink:0}
.pie-legend{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:6px;flex:1}
.legend-item{display:flex;align-items:center;gap:8px;font-size:13px}
.legend-dot{width:12px;height:12px;border-radius:3px;flex-shrink:0}
.legend-pct{font-family:'JetBrains Mono',monospace;color:var(--text-secondary);min-width:45px;text-align:right}

/* Filters */
.filter-section{margin:32px 0}
.filter-section h2{font-size:22px;margin-bottom:12px}
.filter-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px}
.filter-group{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:12px 16px;flex:1;min-width:200px}
.filter-group label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:6px}
.filter-group select,.filter-group input{width:100%;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 10px;border-radius:6px;font-size:13px;font-family:'Inter',sans-serif;box-sizing:border-box}
.result-count{color:var(--text-secondary);font-size:13px;font-family:'JetBrains Mono',monospace;margin-bottom:12px}

/* Table */
.table-section{margin:32px 0}
.table-section h2{font-size:22px;margin-bottom:12px}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--border-color);user-select:none;position:sticky;top:0}
th:hover{color:var(--accent-color)}
th.sorted-asc::after{content:' ▲';color:var(--accent-color)}
th.sorted-desc::after{content:' ▼';color:var(--accent-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color);white-space:nowrap}
tr:hover{background:rgba(74,143,231,.06)}
.ticker{font-family:'JetBrains Mono',monospace;font-weight:600;color:var(--accent-color)}
.num{font-family:'JetBrains Mono',monospace;text-align:right}

/* Sector stats */
.sector-stats-section{margin:32px 0}
.sector-stats-section h2{font-size:22px;margin-bottom:16px}
.sector-stats-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
.sector-stats-wrap table th{cursor:default}
.sector-stats-wrap table th:hover{color:var(--text-secondary)}
.sector-bar{height:8px;background:var(--accent-color);border-radius:4px;min-width:4px}

/* FAQ */
.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

/* Content */
.content-section{margin:32px 0}
.content-section h2{font-size:22px;margin-bottom:12px}
.content-section p{color:var(--text-secondary);font-size:14px;line-height:1.7;margin-bottom:14px;max-width:800px}

/* Related */
.related-section{margin:32px 0}
.related-section h2{font-size:22px;margin-bottom:16px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.related-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px;text-decoration:none;transition:border-color .2s}
.related-card:hover{border-color:var(--accent-color);text-decoration:none}
.related-card h3{font-size:15px;margin-bottom:4px;color:var(--text-primary)}
.related-card p{font-size:13px;color:var(--text-secondary)}

.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}
.updated-badge{display:inline-block;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-secondary);font-size:12px;padding:4px 10px;border-radius:4px;margin-top:8px;font-family:'JetBrains Mono',monospace}

footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:640px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .top10-grid{grid-template-columns:1fr}
  .chart-container{flex-direction:column}
  .pie-legend{grid-template-columns:1fr}
  .filter-row{flex-direction:column}
  .related-grid{grid-template-columns:1fr}
}
