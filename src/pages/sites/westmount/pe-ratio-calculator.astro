.result-box .label{font-size:11px;color:var(--text-secondary);margin-top:4px;text-transform:uppercase;letter-spacing:.5px}
.result-box.highlight{border-color:var(--accent-color);background:rgba(74,143,231,.08)}
.result-placeholder{text-align:center;padding:40px 20px;color:var(--text-secondary);font-size:14px}

/* Gauge */
.gauge-section{margin-top:20px}
.gauge-label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:10px}
.gauge-wrap{position:relative;height:40px;border-radius:6px;overflow:hidden;background:var(--card-bg);border:1px solid var(--border-color)}
.gauge-bar{display:flex;height:100%;width:100%}
.gauge-zone{display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:rgba(255,255,255,.9);letter-spacing:.5px}
.gauge-zone.under{background:#22c55e;flex:1.5}
.gauge-zone.fair{background:#f59e0b;flex:1}
.gauge-zone.over{background:#ef4444;flex:1}
.gauge-zone.very-over{background:#991b1b;flex:.5}
.gauge-marker{position:absolute;top:-2px;bottom:-2px;width:3px;background:#fff;border-radius:2px;box-shadow:0 0 6px rgba(0,0,0,.5);transition:left .4s ease}
.gauge-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--text-secondary);margin-top:4px;font-family:'JetBrains Mono',monospace}
.gauge-verdict{text-align:center;margin-top:10px;font-size:14px;font-weight:600}

/* Comparison */
.comparison-section{margin:32px 0}
.comparison-section h2{font-size:22px;margin-bottom:16px}
.comp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
