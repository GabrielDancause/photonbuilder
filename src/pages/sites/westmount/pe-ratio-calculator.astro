// Render sector table
const sectorTbody = document.getElementById('sectorTbody');
SECTORS.forEach(s => {
  sectorTbody.innerHTML += `<tr>
    <td style="font-weight:600">${s.name}</td>
    <td class="num">${s.avgPe.toFixed(1)}</td>
    <td class="num">${s.medPe.toFixed(1)}</td>
    <td class="num">${s.lo} – ${s.hi}</td>
    <td style="font-size:12px;color:var(--text-secondary)">${s.examples}</td>
    <td style="font-size:12px;color:var(--text-secondary);max-width:200px">${s.notes}</td>
  </tr>`;
});

// Render historical chart
const histBars = document.getElementById('histBars');
const maxPe = 45; // cap for display (2008 was an outlier)
HIST_PE.forEach(h => {
  const displayPe = Math.min(h.pe, maxPe);
  const pct = (displayPe / maxPe) * 100;
  let color = '#f59e0b';
  if (h.pe < 17) color = '#22c55e';
  else if (h.pe > 25) color = '#ef4444';
  const label = h.pe > maxPe ? `${h.pe.toFixed(0)}*` : h.pe.toFixed(1);
  histBars.innerHTML += `<div class="hist-bar-wrap">
    <div class="hist-val">${label}</div>
    <div class="hist-bar" style="height:${pct}%;background:${color}" title="${h.year}: PE ${h.pe.toFixed(1)}"></div>
    <div class="hist-year">${h.year}</div>
  </div>`;
});

// Calculator logic
document.getElementById('calcBtn').addEventListener('click', calculate);

// Also calculate on Enter key
document.querySelectorAll('.calc-inputs input').forEach(input => {
  input.addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
});

function calculate() {
  const price = parseFloat(document.getElementById('stockPrice').value);
  const trailingEps = parseFloat(document.getElementById('trailingEps').value);
  const forwardEps = parseFloat(document.getElementById('forwardEps').value);
  const growth = parseFloat(document.getElementById('growthRate').value);
  const sector = document.getElementById('sectorSelect').value;

  if (!price || price <= 0) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid stock price.</div>';
    return;
  }
  if ((!trailingEps || trailingEps <= 0) && (!forwardEps || forwardEps <= 0)) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter at least one EPS value (trailing or forward).</div>';
    return;
  }

  const trailingPe = trailingEps > 0 ? price / trailingEps : null;
  const forwardPe = forwardEps > 0 ? price / forwardEps : null;
  const peg = (trailingPe && growth > 0) ? trailingPe / growth : null;
  const primaryPe = trailingPe || forwardPe;

  // Build results HTML
  let html = '<div class="result-grid">';
  html += `<div class="result-box${trailingPe ? ' highlight' : ''}"><div class="val">${trailingPe ? trailingPe.toFixed(1) : '—'}</div><div class="label">Trailing PE</div></div>`;
  html += `<div class="result-box${!trailingPe && forwardPe ? ' highlight' : ''}"><div class="val">${forwardPe ? forwardPe.toFixed(1) : '—'}</div><div class="label">Forward PE</div></div>`;
  html += `<div class="result-box"><div class="val">${peg ? peg.toFixed(2) : '—'}</div><div class="label">PEG Ratio</div></div>`;
  html += '</div>';

  // Earnings yield
  if (trailingPe) {
    const earningsYield = (1 / trailingPe * 100).toFixed(2);
    html += `<div style="text-align:center;font-size:13px;color:var(--text-secondary);margin-bottom:16px">Earnings Yield: <strong style="color:var(--text-primary)">${earningsYield}%</strong> — the inverse of PE, comparable to bond yields</div>`;
  }

  // PEG interpretation
  if (peg) {
    let pegColor, pegText;
    if (peg < 1) { pegColor = '#22c55e'; pegText = 'Potentially Undervalued'; }
    else if (peg <= 1.5) { pegColor = '#22c55e'; pegText = 'Fairly Valued'; }
    else if (peg <= 2.5) { pegColor = '#f59e0b'; pegText = 'Moderately Priced'; }
    else { pegColor = '#ef4444'; pegText = 'Potentially Overvalued'; }
    html += `<div style="text-align:center;font-size:13px;margin-bottom:16px">PEG Assessment: <strong style="color:${pegColor}">${pegText}</strong> (PEG ${peg.toFixed(2)})</div>`;
  }

  // Valuation gauge
  if (primaryPe) {
    const sp500Pe = 22;
    html += '<div class="gauge-section">';
    html += '<div class="gauge-label">Valuation Gauge vs S&amp;P 500</div>';
    html += '<div class="gauge-wrap"><div class="gauge-bar">';
    html += '<div class="gauge-zone under">Undervalued</div>';
    html += '<div class="gauge-zone fair">Fair</div>';
    html += '<div class="gauge-zone over">Overvalued</div>';
    html += '<div class="gauge-zone very-over">Very High</div>';
    html += '</div>';

    // Map PE to position: 0 = PE 0, 100% = PE 60
    const pos = Math.max(0, Math.min(100, (primaryPe / 60) * 100));
    html += `<div class="gauge-marker" style="left:${pos}%"></div>`;
    html += '</div>';
    html += '<div class="gauge-labels"><span>0</span><span>15</span><span>25</span><span>40</span><span>60+</span></div>';

    // Verdict
    let verdict, verdictColor;
    if (primaryPe < 15) { verdict = 'Below market average — value territory'; verdictColor = '#22c55e'; }
    else if (primaryPe < 22) { verdict = 'Below S&P 500 average (~22)'; verdictColor = '#22c55e'; }
    else if (primaryPe < 30) { verdict = 'Near or above S&P 500 average'; verdictColor = '#f59e0b'; }
    else if (primaryPe < 45) { verdict = 'Growth premium — verify with PEG ratio'; verdictColor = '#f59e0b'; }
    else { verdict = 'Very high PE — strong growth expectations priced in'; verdictColor = '#ef4444'; }
    html += `<div class="gauge-verdict" style="color:${verdictColor}">${verdict}</div>`;
    html += '</div>';
  }

  document.getElementById('calcResults').innerHTML = html;

  // Comparison section
  if (primaryPe) {
    const compSection = document.getElementById('compSection');
    compSection.style.display = '';
    const compGrid = document.getElementById('compGrid');
    const sp500 = 22.0;

    let compHtml = `<div class="comp-card your-pe"><div class="comp-name">Your Stock</div><div class="comp-pe">${primaryPe.toFixed(1)}</div><div class="comp-diff" style="color:var(--accent-color)">Calculated</div></div>`;
    compHtml += `<div class="comp-card"><div class="comp-name">S&amp;P 500 Average</div><div class="comp-pe">${sp500.toFixed(1)}</div><div class="comp-diff ${primaryPe < sp500 ? 'pos' : 'neg'}">${primaryPe < sp500 ? '' : '+'}${((primaryPe/sp500 - 1)*100).toFixed(0)}% vs yours</div></div>`;

    if (sector) {
      const sectorData = SECTORS.find(s => s.name === sector);
      if (sectorData) {
        const diff = ((primaryPe / sectorData.avgPe - 1) * 100).toFixed(0);
        compHtml += `<div class="comp-card"><div class="comp-name">${sector} Avg</div><div class="comp-pe">${sectorData.avgPe.toFixed(1)}</div><div class="comp-diff ${primaryPe < sectorData.avgPe ? 'pos' : 'neg'}">${primaryPe < sectorData.avgPe ? '' : '+'}${diff}% vs yours</div></div>`;
      }
    }

    // Additional benchmarks
    compHtml += `<div class="comp-card"><div class="comp-name">Historical Avg (LT)</div><div class="comp-pe">16.5</div><div class="comp-diff ${primaryPe < 16.5 ? 'pos' : 'neg'}">${primaryPe < 16.5 ? '' : '+'}${((primaryPe/16.5 - 1)*100).toFixed(0)}% vs yours</div></div>`;

    compGrid.innerHTML = compHtml;

    // Highlight user's PE in sector table
    document.querySelectorAll('#sectorTbody tr').forEach(row => {
      row.classList.remove('your-row');
      if (sector && row.children[0].textContent === sector) {
        row.classList.add('your-row');
      }
    });
  }
}

// FAQ
const faqs = [
  {q:"What is PE ratio and how is it calculated?",a:"The price-to-earnings (PE) ratio is calculated by dividing a company's stock price by its earnings per share (EPS). For example, a stock trading at $150 with EPS of $5 has a PE ratio of 30. This means investors are paying $30 for every $1 of annual earnings. PE ratio is the most widely used valuation metric in stock analysis because it provides a quick way to gauge whether a stock is cheap or expensive relative to its earnings power."},
  {q:"What is the difference between trailing PE and forward PE?",a:"Trailing PE uses the last 12 months of actual reported earnings (TTM EPS), while forward PE uses analyst estimates of future earnings over the next 12 months. Trailing PE is factual but backward-looking. Forward PE is predictive and often lower than trailing PE for growing companies. Most investors look at both: trailing PE for proven performance, and forward PE for market expectations."},
  {q:"What is a good PE ratio for a stock?",a:"There is no single 'good' PE ratio — it depends on sector, growth rate, and market conditions. The S&P 500 historical average PE is about 15-17, currently trading around 22. Generally: PE under 15 is value territory, 15-25 is fair value, and above 25 suggests growth pricing. The PEG ratio (PE ÷ growth rate) normalizes across growth rates — PEG under 1 is considered undervalued."},
  {q:"What is the PEG ratio and why does it matter?",a:"The PEG ratio divides PE by the expected annual earnings growth rate. PEG of 1.0 is considered fairly valued by Peter Lynch's framework. PEG under 1.0 suggests undervaluation, while PEG above 2.0 suggests overvaluation. PEG matters because raw PE ignores growth — a PE of 50 might be reasonable for 60% annual growth (PEG 0.83) but expensive for 10% growth (PEG 5.0)."},
  {q:"Why do PE ratios vary so much between sectors?",a:"PE ratios differ by sector primarily because of growth expectations and risk profiles. Technology averages PE 30-35 due to AI and cloud growth expectations. Utilities average 15-18 with slow but stable growth. Financials average 12-15 due to cyclical risks. The key: compare a stock's PE to its sector average, not the overall market."},
  {q:"Can PE ratio be negative and what does it mean?",a:"PE ratio is technically negative when a company has losses, but most platforms display 'N/A' instead. A negative PE is not meaningful for comparison. For unprofitable companies, use alternative metrics like price-to-sales (PS ratio), price-to-book (PB), or EV/Revenue. Many high-growth tech companies had negative PEs during their growth phase."},
  {q:"How does PE ratio relate to the stock market overall?",a:"The S&P 500 PE has averaged 15-17 historically, with wide swings. During the dot-com bubble it reached 44. During the 2008 crisis it briefly hit 70+. As of 2026, the S&P 500 PE is approximately 22, above the long-term average but supported by strong earnings growth from technology mega-caps."},
  {q:"What are the limitations of using PE ratio alone?",a:"PE has several limitations: (1) It ignores debt — EV/EBITDA is more comprehensive. (2) Earnings can be manipulated through accounting. (3) Cyclical companies have misleading PEs at peak earnings. (4) It doesn't account for cash. (5) One-time charges distort trailing PE. (6) Useless for unprofitable companies. Combine PE with PEG, free cash flow yield, and sector comparisons for a complete picture."}
];

const faqEl = document.getElementById('faq');
faqs.forEach(f => {
  faqEl.innerHTML += `<div class="faq-item"><div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div></div>`;
});
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});
  </script>
