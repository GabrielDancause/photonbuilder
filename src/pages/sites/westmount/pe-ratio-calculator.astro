import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is PE ratio and how is it calculated?","acceptedAnswer":{"@type":"Answer","text":"The price-to-earnings (PE) ratio is calculated by dividing a company's stock price by its earnings per share (EPS). For example, a stock trading at $150 with EPS of $5 has a PE ratio of 30. This means investors are paying $30 for every $1 of annual earnings. PE ratio is the most widely used valuation metric in stock analysis because it provides a quick way to gauge whether a stock is cheap or expensive relative to its earnings power."}},
    {"@type":"Question","name":"What is the difference between trailing PE and forward PE?","acceptedAnswer":{"@type":"Answer","text":"Trailing PE uses the last 12 months of actual reported earnings (TTM EPS), while forward PE uses analyst estimates of future earnings over the next 12 months. Trailing PE is factual but backward-looking — it reflects past performance. Forward PE is predictive and often lower than trailing PE for growing companies because expected future earnings are higher. Most investors look at both: trailing PE for what the company has proven, and forward PE for what the market expects."}},
    {"@type":"Question","name":"What is a good PE ratio for a stock?","acceptedAnswer":{"@type":"Answer","text":"There is no single 'good' PE ratio — it depends heavily on sector, growth rate, and market conditions. The S&P 500 historical average PE is about 15-17. Currently it trades around 22. Generally: PE under 15 is considered value territory, 15-25 is fair value, and above 25 suggests growth pricing. However, a tech company growing earnings 30% annually might justify a PE of 40, while a utility growing 3% might be overpriced at PE 20. The PEG ratio (PE ÷ growth rate) normalizes this — a PEG under 1 is considered undervalued."}},
    {"@type":"Question","name":"What is the PEG ratio and why does it matter?","acceptedAnswer":{"@type":"Answer","text":"The PEG ratio divides the PE ratio by the expected annual earnings growth rate. A PEG of 1.0 means the PE ratio equals the growth rate — considered fairly valued by Peter Lynch's framework. PEG under 1.0 suggests undervaluation (PE is lower than growth would justify), while PEG above 2.0 suggests overvaluation. PEG matters because raw PE ignores growth — a PE of 50 might be reasonable for a company growing 60% annually (PEG 0.83) but expensive for one growing 10% (PEG 5.0)."}},
    {"@type":"Question","name":"Why do PE ratios vary so much between sectors?","acceptedAnswer":{"@type":"Answer","text":"PE ratios differ by sector primarily because of growth expectations and risk profiles. Technology stocks average PE 30-35 because investors expect rapid earnings growth from AI, cloud computing, and digital transformation. Utilities average PE 15-18 because growth is slow but stable. Financials average PE 12-15 due to cyclical risks and regulatory constraints. Healthcare ranges widely (15-40) depending on pipeline potential. Energy trades at low PEs (10-15) due to commodity price volatility. The key insight: compare a stock's PE to its sector average, not the overall market average."}},
    {"@type":"Question","name":"Can PE ratio be negative and what does it mean?","acceptedAnswer":{"@type":"Answer","text":"A PE ratio can technically be negative when a company has negative earnings (losses), but most financial platforms display 'N/A' instead of a negative number because a negative PE is not meaningful for comparison. A company with losses has no useful PE ratio — you cannot compare it to profitable companies using PE. For unprofitable companies, analysts use alternative metrics like price-to-sales (PS ratio), price-to-book (PB ratio), or enterprise value to revenue (EV/Revenue). Many high-growth tech companies had negative PE ratios during their growth phase before becoming profitable."}},
    {"@type":"Question","name":"How does PE ratio relate to the stock market overall?","acceptedAnswer":{"@type":"Answer","text":"The S&P 500 PE ratio has historically averaged around 15-17, with wide swings during bull and bear markets. During the dot-com bubble (2000), it reached 44. During the 2008 financial crisis, it briefly hit 70+ due to collapsed earnings. In early 2020, the COVID crash pushed it to 14 before massive stimulus sent it above 30. As of 2026, the S&P 500 PE is approximately 22, which is above the long-term average but supported by strong corporate earnings growth, particularly from technology mega-caps."}},
    {"@type":"Question","name":"What are the limitations of using PE ratio alone?","acceptedAnswer":{"@type":"Answer","text":"PE ratio has several limitations: (1) It ignores debt — two companies with the same PE can have vastly different debt loads, making EV/EBITDA more comprehensive. (2) Earnings can be manipulated through accounting choices. (3) Cyclical companies have misleading PEs — their PE looks lowest at peak earnings (right before a downturn). (4) It does not account for cash on the balance sheet. (5) One-time charges or gains distort trailing PE. (6) It is useless for unprofitable companies. Sophisticated investors combine PE with PEG ratio, free cash flow yield, EV/EBITDA, and sector-relative comparisons for a complete picture."}}
  ]
};

export const meta = {
  title: "PE Ratio Calculator — Price to Earnings Analysis Tool",
  description: "Calculate trailing PE, forward PE, and PEG ratio instantly. Visual gauge shows undervalued vs overvalued ranges. Compare PE against S&P 500 and sector averages.",
  category: "tool",
  published: "2026-03-21",
};
