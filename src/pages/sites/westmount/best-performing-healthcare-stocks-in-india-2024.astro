  <script is:inline>
    // Sorting Function
    function sortTable(n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById("summaryTable");
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          function parseValue(str) {
            let s = str.toUpperCase();
            let mult = 1;
            if (s.includes('T')) mult = 1e12;
            else if (s.includes('B')) mult = 1e9;
            else if (s.includes('M')) mult = 1e6;
            else if (s.includes('K')) mult = 1e3;
            else if (s.includes('CR')) mult = 1e7;

            let numStr = str.replace(/[^0-9.-]+/g,"");
            if (numStr === "" || numStr === "-" || numStr === ".") return null;
            let num = parseFloat(numStr);
            return isNaN(num) ? null : num * mult;
          }

          let numX = parseValue(x.innerHTML);
          let numY = parseValue(y.innerHTML);
          let isNum = numX !== null && numY !== null;

          if (dir == "asc") {
            if (isNum) {
                if (numX > numY) { shouldSwitch = true; break; }
            } else {
                if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            }
          } else if (dir == "desc") {
             if (isNum) {
                if (numX < numY) { shouldSwitch = true; break; }
            } else {
                if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }

    // Filtering Function
    document.getElementById('searchInput').addEventListener('keyup', filterData);
    document.getElementById('yieldFilter').addEventListener('change', filterData);

    function filterData() {
      let searchFilter = document.getElementById('searchInput').value.toLowerCase();
      let yieldFilter = document.getElementById('yieldFilter').value;

      let tableRows = document.getElementById("summaryTable").getElementsByTagName("tbody")[0].getElementsByTagName("tr");
      let listCards = document.getElementById("rankedList").getElementsByClassName("card");

      for (let i = 0; i < tableRows.length; i++) {
        let name = tableRows[i].getElementsByTagName("td")[0].textContent.toLowerCase();
        let ticker = tableRows[i].getElementsByTagName("td")[1].textContent.toLowerCase();
        let yieldStr = tableRows[i].getElementsByTagName("td")[4].textContent;
        let yieldVal = parseFloat(yieldStr.replace('%',''));

        let matchSearch = name.includes(searchFilter) || ticker.includes(searchFilter);
        let matchYield = true;

        if (yieldFilter === 'high') {
             matchYield = yieldVal > 1.0;
        } else if (yieldFilter === 'low') {
             matchYield = yieldVal <= 1.0;
        }

        if (matchSearch && matchYield) {
          tableRows[i].style.display = "";
          if(listCards[i]) listCards[i].style.display = "";
        } else {
          tableRows[i].style.display = "none";
          if(listCards[i]) listCards[i].style.display = "none";
        }
      }
    }
  </script>

