ayoutRatio":"34.3","marketCap":214319448064},{"ticker":"PBH.TO","name":"Premium Brands Holdings Corporation","sector":"Consumer Defensive","price":92.63,"yield":"3.67","streak":17,"cagr5Y":"8.02","payoutRatio":"231.3","marketCap":4137730048},{"ticker":"PPL.TO","name":"Pembina Pipeline Corporation","sector":"Energy","price":60.7,"yield":"4.68","streak":16,"cagr5Y":"2.28","payoutRatio":"106.0","marketCap":35280719872},{"ticker":"RCI-B.TO","name":"Rogers Communications Inc.","sector":"Communication Services","price":52.77,"yield":"3.79","streak":16,"cagr5Y":"0.00","payoutRatio":"15.7","marketCap":28507688960},{"ticker":"TFII.TO","name":"TFI International Inc.","sector":"Industrials","price":140.34,"yield":"1.86","streak":16,"cagr5Y":"18.79","payoutRatio":"48.9","marketCap":11548270592},{"ticker":"MFC.TO","name":"Manulife Financial Corporation","sector":"Financial Services","price":45.69,"yield":"3.95","streak":15,"cagr5Y":"9.46","payoutRatio":"57.3","marketCap":76586967040},{"ticker":"CGY.TO","name":"Calian Group Ltd.","sector":"Industrials","price":78.7,"yield":"1.42","streak":15,"cagr5Y":"0.00","payoutRatio":"49.1","marketCap":898294592},{"ticker":"KEY.TO","name":"Keyera Corp.","sector":"Energy","price":53.76,"yield":"3.98","streak":15,"cagr5Y":"2.00","payoutRatio":"112.2","marketCap":12326243328},{"ticker":"MRU.TO","name":"Metro Inc.","sector":"Consumer Defensive","price":93.61,"yield":"1.74","streak":13,"cagr5Y":"10.46","payoutRatio":"32.7","marketCap":19953158144},{"ticker":"TIH.TO","name":"Toromont Industries Ltd.","sector":"Industrials","price":196.69,"yield":"1.08","streak":13,"cagr5Y":"10.90","payoutRatio":"34.3","marketCap":16020768768},{"ticker":"STN.TO","name":"Stantec Inc.","sector":"Industrials","price":121.06,"yield":"0.81","streak":13,"cagr5Y":"7.74","payoutRatio":"21.4","marketCap":13808950272},{"ticker":"GEI.TO","name":"Gibson Energy Inc.","sector":"Energy","price":29.31,"yield":"5.94","streak":13,"cagr5Y":"4.81","payoutRatio":"143.3","marketCap":5041319936},{"ticker":"SLF.TO","name":"Sun Life Financial Inc.","sector":"Financial Services","price":85.68,"yield":"4.20","streak":11,"cagr5Y":"9.86","payoutRatio":"57.2","marketCap":47458398208},{"ticker":"WN.TO","name":"George Weston Limited","sector":"Consumer Defensive","price":95.88,"yield":"1.24","streak":11,"cagr5Y":"10.51","payoutRatio":"44.5","marketCap":36657291264},{"ticker":"WCN.TO","name":"Waste Connections, Inc.","sector":"Industrials","price":227.51,"yield":"0.81","streak":6,"cagr5Y":"12.14","payoutRatio":"31.1","marketCap":58369703936}];
        let currentData = [...INITIAL_DATA];
        let sortCol = 'streak';
        let sortAsc = false;

        const tbody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');
        const sectorFilter = document.getElementById('sectorFilter');
        const headers = document.querySelectorAll('th');

        function renderTable() {
            tbody.innerHTML = '';
            currentData.forEach(row => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="p-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[0.95rem]"><span class="inline-block bg-[rgba(74,143,231,0.1)] text-[var(--accent-color)] py-1 px-2 rounded font-bold text-[0.85rem]">${row.ticker}</span></td>
                    <td class="p-4 border-b border-[var(--border-color)] whitespace-normal min-w-[200px] font-sans font-medium text-[0.95rem]">${row.name}</td>
                    <td class="p-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[0.95rem]">${row.sector}</td>
                    <td class="p-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[0.95rem]"><span class="inline-block bg-[rgba(16,185,129,0.1)] text-[#10b981] py-1 px-2 rounded font-bold">${row.streak}</span></td>
                    <td class="p-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[0.95rem]">${row.yield}%</td>
                    <td class="p-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[0.95rem]">${row.cagr5Y !== 'N/A' && row.cagr5Y !== '0.00' ? row.cagr5Y + '%' : 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[0.95rem]">${row.payoutRatio !== 'N/A' ? row.payoutRatio + '%' : 'N/A'}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterData() {
            const term = searchInput.value.toLowerCase();
            const sector = sectorFilter.value;

            currentData = INITIAL_DATA.filter(row => {
                const matchesSearch = row.ticker.toLowerCase().includes(term) || row.name.toLowerCase().includes(term);
                const matchesSector = sector === 'all' || row.sector === sector;
                return matchesSearch && matchesSector;
            });

            sortData();
        }

        function sortData() {
            currentData.sort((a, b) => {
                let valA = a[sortCol];
                let valB = b[sortCol];

                if (['streak', 'yield', 'cagr5Y', 'payoutRatio'].includes(sortCol)) {
                    valA = parseFloat(valA) || 0;
                    valB = parseFloat(valB) || 0;
                } else {
                    valA = String(valA).toLowerCase();
                    valB = String(valB).toLowerCase();
                }

                if (valA < valB) return sortAsc ? -1 : 1;
                if (valA > valB) return sortAsc ? 1 : -1;
                return 0;
            });
            renderTable();
        }

        headers.forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (sortCol === col) {
                    sortAsc = !sortAsc;
                } else {
                    sortCol = col;
                    sortAsc = false; // default desc for numbers
                    if (['ticker', 'name', 'sector'].includes(col)) sortAsc = true;
                }
                sortData();
            });
        });

        searchInput.addEventListener('input', filterData);
        sectorFilter.addEventListener('change', filterData);

        // Init Chart
        const ctx = document.getElementById('sectorChart').getContext('2d');
        const sectorLabels = ["Financial Services","Energy","Consumer Defensive","Consumer Cyclical","Industrials","Communication Services","Utilities"];
        const sectorCounts = [11,5,6,3,7,3,1];

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: sectorLabels,
                datasets: [{
                    data: sectorCounts,
                    backgroundColor: [
                        '#4a8fe7', '#10b981', '#f59e0b', '#ef4444',
                        '#8b5cf6', '#ec4899', '#06b6d4', '#64748b', '#22c55e', '#3b82f6'
                    ],
                    borderColor: '#0a1020',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: { color: '#c8d0de', font: { family: 'Inter' } }
                    }
                }
            }
        });

        // Initial render
        sortData();
  </script>
</SiteLayout>
