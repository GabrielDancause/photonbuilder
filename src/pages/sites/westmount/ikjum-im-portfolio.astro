  category: "study",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the Ikjum Im portfolio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Ikjum Im portfolio refers to the specific collection of financial assets, stocks, and investments managed or studied under the strategies associated with institutional investor Ikjum Im, known for distinct sectoral focuses and risk management techniques."
          }
        },
        {
          "@type": "Question",
          "name": "How does the Ikjum Im portfolio manage risk?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Risk management in this portfolio style typically relies on heavy diversification across uncorrelated asset classes and strict position sizing, ensuring no single equity down-swing catastrophic impacts the broader fund."
