  <script is:inline>
    // FAQ Render
    const schemaData = JSON.parse(document.querySelector('script[type="application/ld+json"]').textContent);
    const faqs = schemaData.mainEntity;
    const container = document.getElementById('faq-container');

    if (faqs && container) {
      faqs.forEach(faq => {
        const details = document.createElement('details');
        const summary = document.createElement('summary');
        summary.textContent = faq.name;
        const p = document.createElement('p');
        p.textContent = faq.acceptedAnswer.text;
        details.appendChild(summary);
        details.appendChild(p);
        container.appendChild(details);
      });
    }

    // Sort Table
    function sortTable(tableId, n, isNumeric=false) {
      let table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById(tableId);
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let valX = x.innerHTML.replace(/[^0-9.-]+/g,"");
          let valY = y.innerHTML.replace(/[^0-9.-]+/g,"");

          if(!isNumeric) {
            valX = x.innerHTML.toLowerCase();
            valY = y.innerHTML.toLowerCase();
          } else {
            valX = parseFloat(valX);
            valY = parseFloat(valY);
          }

          if (dir == "asc") {
            if (valX > valY) {
              shouldSwitch = true;
              break;
            }
          } else if (dir == "desc") {
            if (valX < valY) {
              shouldSwitch = true;
              break;
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }

    // Filter Logic
    const sectorFilter = document.getElementById('june-table-sector-filter');
    const yieldFilter = document.getElementById('june-table-yield-filter');
    const mcapFilter = document.getElementById('june-table-mcap-filter');

    function applyFilters() {
      const sVal = sectorFilter.value;
      const yVal = parseFloat(yieldFilter.value) || 0;
      const mVal = parseFloat(mcapFilter.value) || 0;

      const rows = document.querySelectorAll('#june-table tbody tr');
      rows.forEach(row => {
        const rs = row.getAttribute('data-sector');
        const ry = parseFloat(row.getAttribute('data-yield'));
        const rm = parseFloat(row.getAttribute('data-mcap'));

        let show = true;
        if(sVal !== 'all' && rs !== sVal) show = false;
        if(ry < yVal) show = false;
        if(rm < mVal) show = false;

        row.style.display = show ? '' : 'none';
      });

      const cards = document.querySelectorAll('.item-card');
      cards.forEach(card => {
        const cs = card.getAttribute('data-sector');
        const cy = parseFloat(card.getAttribute('data-yield'));
        const cm = parseFloat(card.getAttribute('data-mcap'));

        let show = true;
        if(sVal !== 'all' && cs !== sVal) show = false;
        if(cy < yVal) show = false;
        if(cm < mVal) show = false;

        card.style.display = show ? '' : 'none';
      });
    }

    if(sectorFilter) sectorFilter.addEventListener('change', applyFilters);
    if(yieldFilter) yieldFilter.addEventListener('input', applyFilters);
    if(mcapFilter) mcapFilter.addEventListener('input', applyFilters);

  </script>

