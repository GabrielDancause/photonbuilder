---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { title: "What Are REITs and How to Invest: Complete Guide", description: "Learn what Real Estate Investment Trusts (REITs) are, the different types and sectors, how to evaluate them using FFO and AFFO, tax implications, and the top REITs for investors.", category: "guide", published: "2026-03-18" };

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "What Are REITs and How to Invest: Complete Guide",
  "description": "Learn what Real Estate Investment Trusts (REITs) are, the different types and sectors, how to evaluate them using FFO and AFFO, tax implications, and the top REITs for investors.",
  "author": {
    "@type": "Organization",
    "name": "Westmount Fundamentals"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a REIT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Real Estate Investment Trust (REIT) is a company that owns, operates, or finances income-generating real estate. Modeled after mutual funds, REITs pool the capital of numerous investors to purchase and manage property."
      }
    },
    {
      "@type": "Question",
      "name": "How do REITs pay dividends?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "By law, REITs must distribute at least 90% of their taxable income to shareholders annually in the form of dividends. This makes them popular among income-seeking investors."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between FFO and Net Income?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Funds From Operations (FFO) is the standard metric used to evaluate a REIT's operating performance. Unlike Net Income, FFO adds back depreciation and amortization, providing a more accurate picture of a REIT's cash flow from its core operations."
      }
    },
    {
      "@type": "Question",
      "name": "Are REIT dividends taxed differently?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Most REIT dividends are treated as ordinary income rather than qualified dividends, meaning they are taxed at your marginal tax rate, though they may qualify for the 20% Qualified Business Income (QBI) deduction."
      }
    },
    {
      "@type": "Question",
      "name": "Should I buy individual REITs or a REIT ETF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A REIT ETF offers instant diversification across various real estate sectors and reduces individual company risk. Buying individual REITs allows you to target specific high-performing sectors (like data centers) or higher yields, but requires more research."
      }
    }
  ]
};

const schema = [articleSchema, faqSchema];
