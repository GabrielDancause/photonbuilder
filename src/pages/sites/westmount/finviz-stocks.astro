    {
      "@type": "Question",
      "name": "How do I screen for breakout stocks on Finviz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To screen for breakouts, look for stocks with high relative volume (over 1.5), price near a 52-week high, and a technical pattern like a wedge or channel breakout using the 'Pattern' filter."
      }
    },
    {
      "@type": "Question",
      "name": "What does 'Relative Volume' mean on Finviz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Relative volume compares a stock's current trading volume to its average historical volume. A relative volume over 1 indicates the stock is trading more heavily than usual, often a sign of institutional interest or news."
      }
