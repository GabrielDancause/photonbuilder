  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
    {
      "@type": "Question",
      "name": "Is Finviz free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, Finviz offers a robust free tier that includes delayed quotes, basic screening tools, and charting capabilities. However, real-time data and advanced features require a premium subscription."
