---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Cost Basis Calculator | Average Down or Up Strategies",
  description: "Find out how your next trade changes your break-even point. Our cost basis calculator reveals the math behind averaging down—before you risk capital.",
  category: "tool",
  published: "2026-03-17"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "url": "https://westmountfundamentals.com/cost-basis-calculator"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a cost basis calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A cost basis calculator helps investors determine the average price per share of an investment after making multiple purchases at different prices. It factors in the original shares, new shares, and any associated trading fees to provide a true break-even point."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate average cost basis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To calculate the average cost basis, you divide the total amount of money invested (including any trading fees) by the total number of shares owned. The formula is: (Total Cost of All Shares) / (Total Number of Shares)."
          }
        },
        {
          "@type": "Question",
          "name": "Should I average down on a losing stock?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Averaging down lowers your overall cost basis, which means the stock doesn't need to rise as much for you to break even. However, it also increases your exposure to that specific asset. It can be a viable strategy if your fundamental investment thesis remains intact, but it shouldn't be used blindly to rescue a bad trade."
          }
        },
        {
          "@type": "Question",
          "name": "Do trading fees affect my cost basis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, trading fees and commissions should always be added to your total investment cost when calculating your cost basis. For tax and profit purposes, your true cost basis is the total capital deployed, including all transaction costs."
          }
        },
        {
          "@type": "Question",
          "name": "How does averaging up work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Averaging up involves buying more shares of a winning stock as its price rises. While this increases your overall average cost per share, it allows you to allocate more capital to an investment that is demonstrating strong momentum and proving your initial thesis correct."
          }
        }
      ]
    }
  ]
};
