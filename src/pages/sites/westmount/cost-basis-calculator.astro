    const tableAdjCps = document.getElementById("table-adj-cps");
    const tableBaseShares = document.getElementById("table-base-shares");
    const tableAdjShares = document.getElementById("table-adj-shares");

    let lotCount = 0;

    const formatter = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 4
    });

    const standardFormatter = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });

    function createLotHtml(id) {
        return `
            <div class="lot-container" id="lot-${id}">
                ${id > 1 ? `<button class="remove-lot-btn" onclick="removeLot(${id})">&times;</button>` : ''}
                <h5 style="margin-top:0; margin-bottom: 1rem; color: var(--accent-color);">Purchase Lot ${id}</h5>
                <div class="calc-inputs-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem;">

                    <div class="input-group">
                        <label for="shares-${id}">Shares</label>
                        <div class="input-wrapper" style="position: relative;">
                            <input type="number" id="shares-${id}" class="lot-shares" value="100" min="0.0001" step="any">
                            <span class="suffix" style="position: absolute; right: 1rem; color: var(--text-secondary); font-family: var(--font-mono); pointer-events: none;">Shares</span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="price-${id}">Price per Share</label>
                        <div class="input-wrapper" style="position: relative;">
                            <span class="prefix" style="position: absolute; left: 1rem; color: var(--text-secondary); font-family: var(--font-mono); pointer-events: none;">$</span>
                            <input type="number" id="price-${id}" class="lot-price" value="50.00" min="0.01" step="0.01" style="padding-left: 2rem;">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="commissions-${id}">Commissions</label>
                        <div class="input-wrapper" style="position: relative;">
                            <span class="prefix" style="position: absolute; left: 1rem; color: var(--text-secondary); font-family: var(--font-mono); pointer-events: none;">$</span>
                            <input type="number" id="commissions-${id}" class="lot-commissions" value="4.95" min="0" step="0.01" style="padding-left: 2rem;">
                        </div>
                    </div>

                </div>
            </div>
        `;
    }

    function addLot() {
        lotCount++;
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = createLotHtml(lotCount);
        const newLot = tempDiv.firstElementChild;
        lotsContainer.appendChild(newLot);

        // Add event listeners to new inputs
        newLot.querySelectorAll('input').forEach(input => {
            input.addEventListener('input', calculate);
        });

        calculate();
    }

    // Attach to window so onclick works
    window.removeLot = function(id) {
        const lot = document.getElementById(`lot-${id}`);
        if (lot) {
            lot.remove();
            calculate();
        }
    };

    function calculate() {
        let totalBaseShares = 0;
        let totalBaseCapital = 0;

        const lotContainers = document.querySelectorAll('.lot-container');

        lotContainers.forEach(container => {
            const sharesInput = container.querySelector('.lot-shares');
            const priceInput = container.querySelector('.lot-price');
            const commInput = container.querySelector('.lot-commissions');

            const shares = parseFloat(sharesInput.value) || 0;
            const price = parseFloat(priceInput.value) || 0;
            const commissions = parseFloat(commInput.value) || 0;

            if (shares > 0 && price > 0) {
                totalBaseShares += shares;
                totalBaseCapital += (shares * price) + commissions;
            }
        });

        const dividends = parseFloat(dividendsInput.value) || 0;
        const roc = parseFloat(returnOfCapitalInput.value) || 0;
        const currentPrice = parseFloat(currentPriceInput.value) || 0;

        const validShares = Math.max(totalBaseShares, 0.000001);

        // Adjustments
        let adjustedCostBasis = totalBaseCapital + dividends - roc;
        const costBasisPerShare = adjustedCostBasis / validShares;
        const baseCostPerShare = totalBaseCapital / validShares;

        const marketValue = validShares * currentPrice;
        const unrealizedGain = marketValue - adjustedCostBasis;

        // UI Updates
        cbPerShareDisplay.textContent = formatter.format(costBasisPerShare);
        totalCbDisplay.textContent = standardFormatter.format(adjustedCostBasis);
        marketValueDisplay.textContent = standardFormatter.format(marketValue);

        if (unrealizedGain > 0) {
            unrealizedGainDisplay.textContent = "+" + standardFormatter.format(unrealizedGain);
            unrealizedGainDisplay.style.color = "#22c55e";
        } else if (unrealizedGain < 0) {
            unrealizedGainDisplay.textContent = standardFormatter.format(unrealizedGain);
            unrealizedGainDisplay.style.color = "#ef4444";
        } else {
            unrealizedGainDisplay.textContent = standardFormatter.format(0);
            unrealizedGainDisplay.style.color = "var(--text-primary)";
        }

        // Update Table
        tableBaseCapital.textContent = standardFormatter.format(totalBaseCapital);
        tableAdjCapital.textContent = standardFormatter.format(adjustedCostBasis);

        tableBaseCps.textContent = formatter.format(baseCostPerShare);
        tableAdjCps.textContent = formatter.format(costBasisPerShare);

        // Assuming dividends don't automatically increase share count here unless they explicitly added a lot,
        // so total shares remain the same for base and adjusted in this specific model.
        // If they did DRIP, they should have added a "lot" for the drip.
        tableBaseShares.textContent = totalBaseShares.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 4});
        tableAdjShares.textContent = totalBaseShares.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 4});

    }

    addLotBtn.addEventListener('click', addLot);

    [dividendsInput, returnOfCapitalInput, currentPriceInput].forEach(input => {
        input.addEventListener('input', calculate);
    });

    // Initialize with one lot
    addLot();
  });
</script>
