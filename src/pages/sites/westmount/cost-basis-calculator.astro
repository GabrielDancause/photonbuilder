---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Cost Basis Calculator: Find Your True Breakeven & Tax Liability",
  description: "Are you overpaying capital gains taxes because you missed a hidden adjustment? Discover how to calculate your exact adjusted cost basis before you sell...",
  category: "tool",
  published: "2026-03-17"
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
      "name": "What is the formula for calculating cost basis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The basic formula for cost basis is: (Number of Shares × Purchase Price) + Commissions and Fees. To find the adjusted cost basis, you must also add reinvested dividends and subtract any return of capital distributions."
      }
    },
    {
      "@type": "Question",
      "name": "Do reinvested dividends increase my cost basis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, reinvested dividends increase your cost basis. Because you are using those dividends to purchase additional shares, and you are likely paying taxes on those dividends in the year they are distributed, adding them to your cost basis prevents you from being double-taxed when you eventually sell the stock."
      }
    },
    {
      "@type": "Question",
      "name": "How do stock splits affect my cost basis per share?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A stock split does not change your total overall cost basis, but it does change your cost basis per share. In a 2-for-1 split, your number of shares doubles, so your cost basis per share is cut in half. The total capital invested remains exactly the same."
      }
    },
    {
      "@type": "Question",
      "name": "Are brokerage commissions included in cost basis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, any fees or commissions paid to a brokerage to execute the purchase of an asset should be added to your total cost basis. This effectively reduces your taxable capital gain when you eventually sell the asset."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I calculate my cost basis wrong?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you calculate your cost basis too low, you will report artificially high capital gains and pay more taxes than necessary. If you calculate it too high, you will underreport your gains, which could lead to penalties and interest if audited by tax authorities."
      }
        }
      ]
    }
  ]
});
