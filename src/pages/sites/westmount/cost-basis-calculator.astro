<script is:inline>
  function initCostBasisCalculator() {
    const lotContainer = document.getElementById('lotContainer');
    const addLotBtn = document.getElementById('addLotBtn');

    if (!lotContainer || !addLotBtn) return;

    const resTotalShares = document.getElementById('resTotalShares');
    const resTotalCost = document.getElementById('resTotalCost');
    const resAvgCost = document.getElementById('resAvgCost');

    let lotCount = 0;

    function createLotRow() {
      lotCount++;
      const id = lotCount;
      const row = document.createElement('div');
      row.className = 'lot-row';
      row.id = `lot-${id}`;

      row.innerHTML = `
        <div class="input-group">
          <label>Shares</label>
          <div class="input-wrapper">
            <input type="number" class="lot-shares" step="any" min="0" value="100">
          </div>
        </div>
        <div class="input-group">
          <label>Price per Share</label>
          <div class="input-wrapper has-prefix">
            <span class="prefix">$</span>
            <input type="number" class="lot-price" step="any" min="0" value="50.00">
          </div>
        </div>
        <div class="input-group">
          <label>Commission / Fees</label>
          <div class="input-wrapper has-prefix">
            <span class="prefix">$</span>
            <input type="number" class="lot-fees" step="any" min="0" value="0.00">
          </div>
        </div>
        <button class="btn-remove" onclick="document.getElementById('lot-${id}').remove(); window.calculateCostBasis();" title="Remove Lot">X</button>
      `;

      lotContainer.appendChild(row);

      // Add event listeners to new inputs
      const inputs = row.querySelectorAll('input');
      inputs.forEach(input => {
        input.addEventListener('input', window.calculateCostBasis);
      });

      window.calculateCostBasis();
    }

    window.calculateCostBasis = function() {
      const rows = document.querySelectorAll('.lot-row');
      let totalShares = 0;
      let totalCostBasis = 0;

      rows.forEach(row => {
        const shares = parseFloat(row.querySelector('.lot-shares').value) || 0;
        const price = parseFloat(row.querySelector('.lot-price').value) || 0;
        const fees = parseFloat(row.querySelector('.lot-fees').value) || 0;

        if (shares > 0) {
          totalShares += shares;
          totalCostBasis += (shares * price) + fees;
        }
      });

      let avgCost = 0;
      if (totalShares > 0) {
        avgCost = totalCostBasis / totalShares;
      }

      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      const formatNumber = (val) => new Intl.NumberFormat('en-US', { maximumFractionDigits: 4 }).format(val);

      resTotalShares.textContent = formatNumber(totalShares);
      resTotalCost.textContent = formatCurrency(totalCostBasis);
      resAvgCost.textContent = formatCurrency(avgCost);
    };

    // Clear any existing lots in case of view transition reloading
    lotContainer.innerHTML = '';
    lotCount = 0;

    // Initialize with two lots for demonstration
    createLotRow();

    // Modify second lot to look like a realistic scenario
    setTimeout(() => {
      createLotRow();
      const secondRow = lotContainer.lastElementChild;
      if (secondRow) {
        secondRow.querySelector('.lot-shares').value = "50";
        secondRow.querySelector('.lot-price').value = "45.00";
        window.calculateCostBasis();
      }
    }, 10);

    addLotBtn.addEventListener('click', createLotRow);
  }

  // Robust initialization for Astro View Transitions and standard loads
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCostBasisCalculator);
  } else {
    initCostBasisCalculator();
  }

  document.addEventListener('astro:page-load', initCostBasisCalculator);
</script>
