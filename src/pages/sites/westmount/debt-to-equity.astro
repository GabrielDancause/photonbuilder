---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Debt-to-Equity Rankings — 150 Most Leveraged S&P 500 Companies",
  description: "Some S&P 500 companies have D/E ratios above 20x. Others have negative equity. Search, filter, and sort 150 companies by leverage, sector, and risk.",
  category: "guide",
  published: "2026-03-28",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a good debt-to-equity ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Generally, D/E ratios below 1 are considered low risk, 1-2 moderate, 2-5 high leverage, and above 5 very risky. However, this varies significantly by sector - utilities naturally carry more debt than tech companies."
      }
    },
    {
      "@type": "Question", 
      "name": "What does negative equity mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Negative equity occurs when a company's total liabilities exceed its assets. This is often due to large share buybacks, acquisitions, or accumulated losses. While concerning, it's not always fatal if cash flows remain positive."
      }
    },
    {
      "@type": "Question",
      "name": "Which sectors typically have the highest debt-to-equity ratios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Utilities, Real Estate, and Consumer Cyclical companies typically carry more debt due to their capital-intensive business models and stable cash flows that can service debt."
      }
    },
    {
      "@type": "Question",
      "name": "Is high leverage always bad for investors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not necessarily. Leverage can amplify returns during good times and companies with stable cash flows can safely carry more debt. However, high leverage increases risk during economic downturns and reduces financial flexibility."
      }
    },
    {
      "@type": "Question",
      "name": "How often should debt-to-equity ratios be monitored?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For active investors, quarterly monitoring during earnings season is recommended. For long-term investors, annual or semi-annual reviews are sufficient unless there are major corporate actions or market stress."
      }
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Debt-to-Equity Rankings — 150 Most Leveraged S&P 500 Companies",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research"
  },
  "datePublished": "2026-03-28",
  "dateModified": "2026-03-28"
};
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  schema={[faqSchema, articleSchema]}
>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background: #060a12;
    color: #e2e8f0;
    font-family: system-ui, -apple-system, sans-serif;
    line-height: 1.6;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #f8fafc;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #94a3b8;
    margin-bottom: 2rem;
  }

  .controls {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr auto;
  }

  @media (max-width: 768px) {
    .controls {
      grid-template-columns: 1fr;
    }
  }

  .search-input {
    background: #060a12;
    border: 1px solid #152040;
    border-radius: 8px;
    color: #e2e8f0;
    font-size: 1rem;
    padding: 0.75rem 1rem;
    width: 100%;
  }

  .search-input:focus {
    outline: none;
    border-color: #4a8fe7;
    box-shadow: 0 0 0 2px rgba(74, 143, 231, 0.1);
  }

  .sector-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sector-btn {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 6px;
    color: #94a3b8;
    cursor: pointer;
    font-size: 0.875rem;
    padding: 0.5rem 0.75rem;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .sector-btn:hover,
  .sector-btn.active {
    background: #4a8fe7;
    border-color: #4a8fe7;
    color: white;
  }

  .summary-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
  }

  .stat-value {
    color: #4a8fe7;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: bold;
  }

  .stat-label {
    color: #94a3b8;
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  .risk-gauge {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    margin-bottom: 2rem;
    padding: 1rem;
  }

  .gauge-bar {
    background: #152040;
    border-radius: 4px;
    height: 8px;
    margin: 0.75rem 0;
    overflow: hidden;
    position: relative;
  }

  .gauge-segments {
    display: flex;
    height: 100%;
  }

  .segment {
    flex: 1;
  }

  .segment.low { background: #22c55e; }
  .segment.moderate { background: #eab308; }
  .segment.high { background: #f97316; }
  .segment.very-high { background: #ef4444; }
  .segment.extreme { background: #991b1b; }

  .gauge-labels {
    display: flex;
    font-size: 0.75rem;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .chart-container {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    margin-bottom: 2rem;
    padding: 1rem;
  }

  .chart-title {
    color: #f8fafc;
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .chart-bar {
    align-items: center;
    display: flex;
    margin-bottom: 0.75rem;
  }

  .chart-label {
    flex: 0 0 120px;
    font-size: 0.875rem;
  }

  .chart-track {
    background: #152040;
    border-radius: 4px;
    flex: 1;
    height: 20px;
    margin: 0 0.75rem;
    overflow: hidden;
    position: relative;
  }

  .chart-fill {
    background: #4a8fe7;
    height: 100%;
    transition: width 0.3s ease;
  }

  .chart-value {
    color: #94a3b8;
    flex: 0 0 60px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    text-align: right;
  }

  .table-container {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    overflow: hidden;
  }

  .table {
    border-collapse: collapse;
    font-size: 0.875rem;
    width: 100%;
  }

  .table th {
    background: #152040;
    color: #f8fafc;
    cursor: pointer;
    font-weight: 600;
    padding: 0.75rem;
    text-align: left;
    transition: background-color 0.2s;
    user-select: none;
  }

  .table th:hover {
    background: #1e293b;
  }

  .table th.sortable::after {
    content: ' ↕';
    opacity: 0.5;
  }

  .table th.sort-asc::after {
    content: ' ↑';
    opacity: 1;
  }

  .table th.sort-desc::after {
    content: ' ↓';
    opacity: 1;
  }

  .table td {
    border-top: 1px solid #152040;
    padding: 0.75rem;
  }

  .table tr.negative-equity {
    background: rgba(239, 68, 68, 0.1);
  }

  .negative-flag {
    background: #ef4444;
    border-radius: 4px;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
  }

  .mono {
    font-family: 'JetBrains Mono', monospace;
  }

  .content-section {
    margin: 3rem 0;
  }

  .content-section h2 {
    color: #f8fafc;
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .content-section p {
    color: #cbd5e1;
    margin-bottom: 1rem;
  }

  .faq {
    margin: 3rem 0;
  }

  .faq-item {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    margin-bottom: 1rem;
    padding: 1.5rem;
  }

  .faq-question {
    color: #f8fafc;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .faq-answer {
    color: #cbd5e1;
  }

  .related-links {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 8px;
    margin-top: 3rem;
    padding: 1.5rem;
  }

  .related-links h3 {
    color: #f8fafc;
    margin-bottom: 1rem;
  }

  .related-links ul {
    list-style: none;
  }

  .related-links li {
    margin-bottom: 0.5rem;
  }

  .related-links a {
    color: #4a8fe7;
    text-decoration: none;
  }

  .related-links a:hover {
    text-decoration: underline;
  }

  .table-responsive {
    overflow-x: auto;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }
    
    .summary-stats {
      grid-template-columns: 1fr 1fr;
    }
    
    .table {
      font-size: 0.75rem;
    }
    
    .table th,
    .table td {
      padding: 0.5rem 0.25rem;
    }
  }
</style>

