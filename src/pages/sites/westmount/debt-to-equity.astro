  // State management
  let filteredData = [...DATA];
  let currentSector = 'all';
  let currentSort = { field: 'rank', direction: 'asc' };
  let searchTerm = '';

  // Helper functions
  function parseNumber(value) {
    if (value === 'N/A' || value === 'N/A (Neg)' || !value) return 0;
    return parseFloat(value.replace(/[$,B,M]/g, '').replace('B', '').replace('M', ''));
  }

  function getRiskLevel(deRatio) {
    const ratio = parseNumber(deRatio);
    if (ratio === 0 || deRatio === 'N/A (Neg)') return 'extreme';
    if (ratio < 1) return 'low';
    if (ratio < 2) return 'moderate';
    if (ratio < 5) return 'high';
    if (ratio < 10) return 'very-high';
    return 'extreme';
  }

  function calculateStats() {
    const validRatios = filteredData
      .filter(item => item.deRatio !== 'N/A (Neg)' && item.deRatio !== 'N/A')
      .map(item => parseNumber(item.deRatio));
    
    const avgRatio = validRatios.length > 0 
      ? (validRatios.reduce((a, b) => a + b, 0) / validRatios.length).toFixed(2)
      : '0.00';

    const negEquityCount = filteredData.filter(item => item.negativeEquity).length;

    // Find sector with most leverage
    const sectorAvg = {};
    const sectorCounts = {};
    
    DATA.forEach(item => {
      if (item.deRatio !== 'N/A (Neg)' && item.deRatio !== 'N/A') {
        if (!sectorAvg[item.sector]) {
          sectorAvg[item.sector] = 0;
          sectorCounts[item.sector] = 0;
        }
        sectorAvg[item.sector] += parseNumber(item.deRatio);
        sectorCounts[item.sector]++;
      }
    });

    let highestSector = '';
    let highestAvg = 0;
    for (const sector in sectorAvg) {
      const avg = sectorAvg[sector] / sectorCounts[sector];
      if (avg > highestAvg) {
        highestAvg = avg;
        highestSector = sector;
      }
    }

    return {
      total: filteredData.length,
      avgRatio,
      negEquityCount,
      highestSector
    };
  }

  function getSectorData() {
    const sectors = {};
    DATA.forEach(item => {
      if (!sectors[item.sector]) {
        sectors[item.sector] = { total: 0, sum: 0, count: 0 };
      }
      sectors[item.sector].total++;
      if (item.deRatio !== 'N/A (Neg)' && item.deRatio !== 'N/A') {
        sectors[item.sector].sum += parseNumber(item.deRatio);
        sectors[item.sector].count++;
      }
    });

    return Object.entries(sectors)
      .map(([sector, data]) => ({
        sector,
        average: data.count > 0 ? data.sum / data.count : 0
      }))
      .sort((a, b) => b.average - a.average);
  }

  function applyFilters() {
    filteredData = DATA.filter(item => {
      const matchesSearch = searchTerm === '' || 
        item.name.toLowerCase().includes(searchTerm.toLowerCase()) ||
        item.ticker.toLowerCase().includes(searchTerm.toLowerCase());
      
      const matchesSector = currentSector === 'all' || item.sector === currentSector;
      
      return matchesSearch && matchesSector;
    });

    // Apply sorting
    filteredData.sort((a, b) => {
      let aVal, bVal;
      
      if (currentSort.field === 'deRatio') {
        aVal = parseNumber(a.deRatio);
        bVal = parseNumber(b.deRatio);
        // Handle negative equity specially
        if (a.negativeEquity) aVal = 999;
        if (b.negativeEquity) bVal = 999;
      } else if (currentSort.field === 'currentRatio') {
        aVal = parseNumber(a.currentRatio);
        bVal = parseNumber(b.currentRatio);
      } else if (currentSort.field === 'rank') {
        aVal = a.rank;
        bVal = b.rank;
      } else {
        aVal = a[currentSort.field];
        bVal = b[currentSort.field];
      }

      if (currentSort.direction === 'asc') {
        return aVal < bVal ? -1 : aVal > bVal ? 1 : 0;
      } else {
        return aVal > bVal ? -1 : aVal < bVal ? 1 : 0;
      }
    });

    updateDisplay();
  }

  function updateDisplay() {
    const stats = calculateStats();
    const sectorData = getSectorData();

    // Update summary stats
    document.getElementById('total-companies').textContent = stats.total;
    document.getElementById('avg-ratio').textContent = stats.avgRatio;
    document.getElementById('negative-equity').textContent = stats.negEquityCount;
    document.getElementById('highest-sector').textContent = stats.highestSector;

    // Update sector chart
    updateSectorChart(sectorData);

    // Update table
    updateTable();
  }

  function updateSectorChart(sectorData) {
    const chartContainer = document.getElementById('sector-chart');
    const maxAvg = Math.max(...sectorData.map(d => d.average));

    chartContainer.innerHTML = sectorData.map(data => `
      <div class="chart-bar">
        <div class="chart-label">${data.sector.replace(/([A-Z])/g, ' $1').trim()}</div>
        <div class="chart-track">
          <div class="chart-fill" style="width: ${(data.average / maxAvg * 100)}%"></div>
        </div>
        <div class="chart-value">${data.average.toFixed(1)}</div>
      </div>
    `).join('');
  }

  function updateTable() {
    const tbody = document.getElementById('companies-tbody');
    tbody.innerHTML = filteredData.map(company => `
      <tr class="${company.negativeEquity ? 'negative-equity' : ''}">
        <td class="mono">${company.rank}</td>
        <td>
          <strong>${company.name}</strong>
          <div style="color: #94a3b8; font-size: 0.8rem;">${company.ticker}</div>
        </td>
        <td>${company.sector}</td>
        <td class="mono">
          ${company.negativeEquity ? 
            '<span class="negative-flag">NEG</span>' : 
            company.deRatio
          }
        </td>
        <td class="mono">${company.totalDebt}</td>
        <td class="mono">${company.equity}</td>
        <td class="mono">${company.currentRatio}</td>
      </tr>
    `).join('');
  }

  // Event listeners
  function initializeEventListeners() {
    // Search input
    const searchInput = document.getElementById('search');
    searchInput.addEventListener('input', (e) => {
      searchTerm = e.target.value;
      applyFilters();
    });

    // Sector filters
    const sectorButtons = document.querySelectorAll('.sector-btn');
    sectorButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        sectorButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentSector = btn.dataset.sector;
        applyFilters();
      });
    });

    // Table sorting
    const sortableHeaders = document.querySelectorAll('.table th.sortable');
    sortableHeaders.forEach(header => {
      header.addEventListener('click', () => {
        const field = header.dataset.field;
        
        if (currentSort.field === field) {
          currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
        } else {
          currentSort.field = field;
          currentSort.direction = 'asc';
        }

        // Update header styles
        sortableHeaders.forEach(h => {
          h.classList.remove('sort-asc', 'sort-desc');
        });
        header.classList.add(currentSort.direction === 'asc' ? 'sort-asc' : 'sort-desc');

        applyFilters();
      });
    });
  }

  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    // Create sector filter buttons
    const sectors = [...new Set(DATA.map(item => item.sector))].sort();
    const sectorContainer = document.getElementById('sector-filters');
    sectorContainer.innerHTML = `
      <button class="sector-btn active" data-sector="all">All Sectors</button>
      ${sectors.map(sector => `
        <button class="sector-btn" data-sector="${sector}">${sector}</button>
      `).join('')}
    `;

    initializeEventListeners();
    applyFilters();
  });
</script>

