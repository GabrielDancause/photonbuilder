    // PFD Historical Data
    const pfdData = [
      {year: 1999, amount: 1769.84},
      {year: 2000, amount: 1963.86},
      {year: 2001, amount: 1850.28},
      {year: 2002, amount: 1540.76},
      {year: 2003, amount: 1107.56},
      {year: 2004, amount: 919.84},
      {year: 2005, amount: 845.76},
      {year: 2006, amount: 1106.96},
      {year: 2007, amount: 1654},
      {year: 2008, amount: 2069, note: "Includes $1,200 energy rebate"},
      {year: 2009, amount: 1305},
      {year: 2010, amount: 1281},
      {year: 2011, amount: 1174},
      {year: 2012, amount: 878},
      {year: 2013, amount: 900},
      {year: 2014, amount: 1884},
      {year: 2015, amount: 2072},
      {year: 2016, amount: 1022},
      {year: 2017, amount: 1100},
      {year: 2018, amount: 1600},
      {year: 2019, amount: 1606},
      {year: 2020, amount: 992},
      {year: 2021, amount: 1114},
      {year: 2022, amount: 3284},
      {year: 2023, amount: 1312},
      {year: 2024, amount: 1702},
      {year: 2025, amount: 1702}
    ];

    // Initialize chart
    function initChart() {
      const chart = document.getElementById('pfdChart');
      const maxAmount = Math.max(...pfdData.map(d => d.amount));
      
      pfdData.forEach(data => {
        const bar = document.createElement('div');
        bar.className = 'chart-bar';
        bar.style.height = `${(data.amount / maxAmount) * 250}px`;
        
        const label = document.createElement('div');
        label.className = 'chart-bar-label';
        label.textContent = data.year;
        
        const tooltip = document.createElement('div');
        tooltip.className = 'chart-tooltip';
        tooltip.textContent = `$${data.amount.toLocaleString()}${data.note ? ' *' : ''}`;
        
        bar.appendChild(label);
        bar.appendChild(tooltip);
        chart.appendChild(bar);
      });
    }

    // Initialize calculator
    function initCalculator() {
      const select = document.getElementById('residencyYear');
      for (let year = 1999; year <= 2025; year++) {
        const option = document.createElement('option');
        option.value = year;
        option.textContent = year;
        select.appendChild(option);
      }
      
      select.addEventListener('change', calculatePFD);
    }

    function calculatePFD() {
      const startYear = parseInt(document.getElementById('residencyYear').value);
      if (!startYear) return;
      
      const eligibleData = pfdData.filter(d => d.year >= startYear);
      const totalPfd = eligibleData.reduce((sum, d) => sum + d.amount, 0);
      const years = eligibleData.length;
      
      // Calculate S&P 500 investment value (simplified 10% annual return)
      let investedValue = 0;
      eligibleData.forEach((data, index) => {
        const yearsToGrow = eligibleData.length - index - 1;
        investedValue += data.amount * Math.pow(1.10, yearsToGrow);
      });
      
      document.getElementById('totalPfd').textContent = `$${totalPfd.toLocaleString()}`;
      document.getElementById('investedValue').textContent = `$${Math.round(investedValue).toLocaleString()}`;
      document.getElementById('yearsEligible').textContent = years;
      document.getElementById('calcResults').style.display = 'block';
    }

    // Eligibility checker
    let eligibilityAnswers = {};

    function nextQuestion(questionNum, answer) {
      eligibilityAnswers[questionNum] = answer;
      
      // Hide current question
      document.getElementById(`q${questionNum}`).style.display = 'none';
      
      // If answer is no to any question, show ineligible result
      if (!answer) {
        document.getElementById('ineligibleResult').style.display = 'block';
        document.getElementById('resetBtn').style.display = 'inline-block';
        return;
      }
      
      // Show next question or result
      if (questionNum < 4) {
        document.getElementById(`q${questionNum + 1}`).style.display = 'block';
      } else {
        // All questions answered yes
        document.getElementById('eligibleResult').style.display = 'block';
        document.getElementById('resetBtn').style.display = 'inline-block';
      }
    }

    function resetChecker() {
      eligibilityAnswers = {};
      
      // Hide all questions except first
      for (let i = 2; i <= 4; i++) {
        document.getElementById(`q${i}`).style.display = 'none';
      }
      
      // Hide results and reset button
      document.getElementById('eligibleResult').style.display = 'none';
      document.getElementById('ineligibleResult').style.display = 'none';
      document.getElementById('resetBtn').style.display = 'none';
      
      // Show first question
      document.getElementById('q1').style.display = 'block';
    }

    // FAQ functionality
    function toggleFaq(num) {
      const answer = document.getElementById(`faq${num}`);
      const question = answer.parentElement.querySelector('.faq-question');
      const isOpen = answer.classList.contains('open');
      
      // Close all FAQ items
      document.querySelectorAll('.faq-answer').forEach(el => {
        el.classList.remove('open');
      });
      document.querySelectorAll('.faq-question').forEach(el => {
        el.classList.remove('active');
      });
      
      // Open clicked item if it wasn't already open
      if (!isOpen) {
        answer.classList.add('open');
        question.classList.add('active');
      }
    }

    // Initialize everything when DOM loads
    document.addEventListener('DOMContentLoaded', function() {
      initChart();
      initCalculator();
    });
  </script>

