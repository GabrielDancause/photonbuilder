  html += `<div>Total coupon payments: <strong style="color:var(--text-primary)">$${r.totalCoupons.toFixed(2)}</strong> over ${years} years</div>`;
  html += `<div>Capital ${r.isDiscount ? 'gain' : r.isPremium ? 'loss' : 'change'}: <strong style="color:var(--text-primary)">$${(fv - price).toFixed(2)}</strong></div>`;
  html += `<div>Total return: <strong style="color:var(--text-primary)">$${r.totalReturn.toFixed(2)}</strong> (${r.totalReturnPct.toFixed(1)}% on investment)</div>`;
  html += `<div>Duration interpretation: A 1% rate increase would decrease price by ~<strong style="color:var(--text-primary)">${r.modified.toFixed(2)}%</strong></div>`;
  html += '</div>';

  document.getElementById('calcResults').innerHTML = html;

