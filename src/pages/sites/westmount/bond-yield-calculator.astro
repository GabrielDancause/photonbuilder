function calculateFairPrice() {
  const fv = parseFloat(document.getElementById('pFaceValue').value);
  const coupon = parseFloat(document.getElementById('pCouponRate').value);
  const targetYtm = parseFloat(document.getElementById('pTargetYtm').value);
  const years = parseFloat(document.getElementById('pYears').value);
  const freq = parseInt(document.getElementById('pFreq').value);

  if (!fv || fv <= 0 || isNaN(coupon) || coupon < 0 || !targetYtm || targetYtm <= 0 || !years || years <= 0) {
    document.getElementById('priceResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please fill in all fields with valid values.</div>';
    return;
  }

  const fairPrice = calcBondPrice(fv, coupon, targetYtm / 100, years, freq);
  const annualCoupon = (coupon / 100) * fv;
  const currentYieldAtFair = (annualCoupon / fairPrice) * 100;
  const premDisc = fairPrice > fv ? 'Premium' : fairPrice < fv ? 'Discount' : 'Par';
  const premDiscPct = ((fairPrice / fv - 1) * 100).toFixed(2);
  const premDiscColor = fairPrice > fv ? '#ef4444' : fairPrice < fv ? '#22c55e' : 'var(--text-secondary)';

  let html = '<div class="result-grid" style="grid-template-columns:1fr 1fr">';
  html += `<div class="result-box highlight"><div class="val">$${fairPrice.toFixed(2)}</div><div class="label">Fair Price</div></div>`;
  html += `<div class="result-box"><div class="val">${currentYieldAtFair.toFixed(3)}%</div><div class="label">Current Yield at Fair Price</div></div>`;
  html += '</div>';
  html += `<div style="text-align:center;font-size:13px;color:var(--text-secondary);margin:8px 0">`;
  html += `Bond trades at a <strong style="color:${premDiscColor}">${premDisc}</strong> (${premDiscPct > 0 ? '+' : ''}${premDiscPct}% vs face value)`;
  html += `</div>`;

  // Price sensitivity table
  const steps = [-2, -1, -0.5, 0, 0.5, 1, 2];
  html += '<div style="font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin:16px 0 8px;font-size:11px">Price at Different Yields</div>';
  html += '<div class="price-sensitivity">';
  steps.forEach(s => {
    const y = targetYtm + s;
    if (y <= 0) { html += '<div class="price-cell"><div class="pc-yield">—</div><div class="pc-price">—</div></div>'; return; }
    const p = calcBondPrice(fv, coupon, y / 100, years, freq);
    const isCurrent = s === 0;
    html += `<div class="price-cell${isCurrent ? ' current' : ''}">`;
    html += `<div class="pc-yield">${y.toFixed(1)}%</div>`;
    html += `<div class="pc-price" style="color:${isCurrent ? 'var(--accent-color)' : 'var(--text-primary)'}">$${p.toFixed(0)}</div>`;
    html += '</div>';
  });
  html += '</div>';

  document.getElementById('priceResults').innerHTML = html;
}

// ===== FAQ =====
const faqs = [
  {q:"What is yield to maturity (YTM) and how is it calculated?",a:"Yield to maturity (YTM) is the total annualized return an investor earns if they hold a bond until it matures, assuming all coupon payments are reinvested at the same rate. YTM accounts for the bond's current market price, face value, coupon rate, and time to maturity. It is calculated using an iterative numerical method (Newton-Raphson) because there is no closed-form algebraic solution. YTM is the single most important metric for comparing bonds."},
  {q:"What is the difference between current yield and yield to maturity?",a:"Current yield is simply the annual coupon payment divided by the bond's current market price — it only measures income return and ignores capital gains or losses. YTM is more complete, factoring in the difference between purchase price and face value at maturity, plus the time value of money. Current yield overstates return for premium bonds and understates it for discount bonds."},
  {q:"What is bond duration and why does it matter?",a:"Bond duration measures sensitivity to interest rate changes. Macaulay duration is the weighted average time until cash flows are received. Modified duration estimates the percentage price change for a 1% change in yield. A bond with modified duration of 7 will lose approximately 7% of its value if yields rise by 1%. Duration quantifies interest rate risk and helps investors position portfolios for rate expectations."},
  {q:"What do bond ratings mean and how do they affect yield?",a:"Bond ratings assess creditworthiness — the ability to make payments and repay principal. Ratings range from AAA (lowest risk) to D (default). Investment-grade is BBB/Baa or higher. Higher-rated bonds offer lower yields. The spread between corporate and Treasury yields of the same maturity reflects the credit risk premium. BBB bonds might yield 1-2% more than Treasuries, while BB bonds yield 3-4% more."},
  {q:"How do interest rates affect bond prices?",a:"Bond prices and interest rates move inversely. When rates rise, existing bonds with lower coupons become less attractive, so prices fall. When rates fall, existing higher-coupon bonds gain value. The magnitude depends on duration — longer-term bonds are more sensitive. A 30-year Treasury loses far more from a 1% rate hike than a 2-year Treasury."},
  {q:"What is convexity and how does it improve on duration?",a:"Convexity measures the curvature in the price-yield relationship. Duration gives a linear approximation, but actual price changes follow a curve. For large yield changes, duration alone underestimates gains when yields fall and overestimates losses when yields rise. Higher convexity is favorable — the bond gains more when rates drop than it loses when rates rise."},
  {q:"What is the difference between a premium bond and a discount bond?",a:"A premium bond trades above face value when its coupon exceeds current market yields. A discount bond trades below par when its coupon is below market yields. Premium bonds have YTM lower than coupon rate; discount bonds have YTM higher than coupon rate. Neither is inherently better — YTM equalizes the tradeoffs between income and capital change."},
  {q:"How do I compare two bonds with different maturities and coupons?",a:"Use yield to maturity as the primary comparison — it normalizes different coupons and maturities into a single annualized return. Then examine modified duration for interest rate risk. A higher-YTM bond with much longer duration carries more risk. Also compare credit ratings to ensure you're comparing similar risk levels. Use side-by-side analysis like our bond comparison tool above."}
];

const faqEl = document.getElementById('faq');
faqs.forEach(f => {
  faqEl.innerHTML += `<div class="faq-item"><div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div></div>`;
});
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});
  </script>
