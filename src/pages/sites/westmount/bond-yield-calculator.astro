// ===== Bond calculation functions =====

function calcYTM(faceValue, price, couponRate, years, freq) {
  const C = (faceValue * couponRate / 100) / freq; // coupon per period
  const n = years * freq; // total periods
  let ytm = couponRate / 100; // initial guess
  if (ytm <= 0) ytm = 0.05;

  for (let i = 0; i < 200; i++) {
    let pv = 0, dpv = 0;
    for (let t = 1; t <= n; t++) {
      const df = Math.pow(1 + ytm / freq, -t);
      pv += C * df;
      dpv += -t / freq * C * df / (1 + ytm / freq);
    }
    const dfn = Math.pow(1 + ytm / freq, -n);
    pv += faceValue * dfn;
    dpv += -n / freq * faceValue * dfn / (1 + ytm / freq);

    const diff = pv - price;
    if (Math.abs(diff) < 1e-8) break;
    ytm -= diff / dpv;
    if (ytm < -0.5) ytm = 0.001;
    if (ytm > 2) ytm = 1.5;
  }
  return ytm;
}

function calcBondPrice(faceValue, couponRate, ytm, years, freq) {
  const C = (faceValue * couponRate / 100) / freq;
  const n = years * freq;
  let pv = 0;
  for (let t = 1; t <= n; t++) {
    pv += C / Math.pow(1 + ytm / freq, t);
  }
  pv += faceValue / Math.pow(1 + ytm / freq, n);
  return pv;
}

function calcDurationConvexity(faceValue, price, couponRate, ytm, years, freq) {
  const C = (faceValue * couponRate / 100) / freq;
  const n = years * freq;
  let macD = 0, conv = 0;

  for (let t = 1; t <= n; t++) {
    const df = Math.pow(1 + ytm / freq, -t);
    const pvcf = (t === n ? (C + faceValue) : C) * df;
    macD += (t / freq) * pvcf;
    conv += (t / freq) * ((t / freq) + 1 / freq) * pvcf;
  }

  macD /= price;
  conv /= (price * Math.pow(1 + ytm / freq, 2));
  const modD = macD / (1 + ytm / freq);

  return { macaulay: macD, modified: modD, convexity: conv };
}

function fullBondCalc(faceValue, price, couponRate, years, freq) {
  const annualCoupon = faceValue * couponRate / 100;
  const currentYield = annualCoupon / price;
  const ytm = calcYTM(faceValue, price, couponRate, years, freq);
  const dc = calcDurationConvexity(faceValue, price, couponRate, ytm, years, freq);
  const totalCoupons = annualCoupon * years;
  const totalReturn = totalCoupons + (faceValue - price);
  const totalReturnPct = (totalReturn / price) * 100;

  return {
    annualCoupon, currentYield, ytm,
    macaulay: dc.macaulay, modified: dc.modified, convexity: dc.convexity,
    totalCoupons, totalReturn, totalReturnPct,
    isPremium: price > faceValue, isDiscount: price < faceValue
  };
}

