  html += `<div class="result-box"><div class="val sm">${r.modified.toFixed(3)}</div><div class="label">Modified Duration</div></div>`;
  html += `<div class="result-box"><div class="val sm">${r.convexity.toFixed(2)}</div><div class="label">Convexity</div></div>`;
  html += `<div class="result-box"><div class="val sm">${r.totalReturnPct.toFixed(1)}%</div><div class="label">Total Return</div></div>`;
  html += '</div>';

