function compareBonds() {
  const a = {
    face: parseFloat(document.getElementById('compA_face').value),
    price: parseFloat(document.getElementById('compA_price').value),
    coupon: parseFloat(document.getElementById('compA_coupon').value),
    years: parseFloat(document.getElementById('compA_years').value),
    freq: parseInt(document.getElementById('compA_freq').value)
  };
  const b = {
    face: parseFloat(document.getElementById('compB_face').value),
    price: parseFloat(document.getElementById('compB_price').value),
    coupon: parseFloat(document.getElementById('compB_coupon').value),
    years: parseFloat(document.getElementById('compB_years').value),
    freq: parseInt(document.getElementById('compB_freq').value)
  };

  if (!a.face || !a.price || (!a.coupon && a.coupon !== 0) || !a.years || !b.face || !b.price || (!b.coupon && b.coupon !== 0) || !b.years) {
    document.getElementById('compResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444;margin-top:16px">Please fill in all fields for both bonds.</div>';
    return;
  }

  const ra = fullBondCalc(a.face, a.price, a.coupon, a.years, a.freq);
  const rb = fullBondCalc(b.face, b.price, b.coupon, b.years, b.freq);

  function better(va, vb, higherIsBetter) {
    if (Math.abs(va - vb) < 0.0001) return ['', ''];
    if (higherIsBetter) return [va > vb ? 'better' : 'worse', vb > va ? 'better' : 'worse'];
    return [va < vb ? 'better' : 'worse', vb < va ? 'better' : 'worse'];
  }

  const ytmB = better(ra.ytm, rb.ytm, true);
  const cyB = better(ra.currentYield, rb.currentYield, true);
  const durB = better(ra.modified, rb.modified, false);
  const convB = better(ra.convexity, rb.convexity, true);
  const retB = better(ra.totalReturnPct, rb.totalReturnPct, true);

  const freqLabel = f => f === 1 ? 'Annual' : f === 2 ? 'Semi-Annual' : 'Quarterly';

  let html = `<div class="comp-results">
    <table class="comp-table">
      <thead><tr><th>Metric</th><th>Bond A</th><th>Bond B</th></tr></thead>
      <tbody>
        <tr><td>Price / Face</td><td>$${a.price.toFixed(2)} / $${a.face}</td><td>$${b.price.toFixed(2)} / $${b.face}</td></tr>
        <tr><td>Coupon Rate</td><td>${a.coupon.toFixed(2)}%</td><td>${b.coupon.toFixed(2)}%</td></tr>
        <tr><td>Years / Frequency</td><td>${a.years}y / ${freqLabel(a.freq)}</td><td>${b.years}y / ${freqLabel(b.freq)}</td></tr>
        <tr><td>Yield to Maturity</td><td class="${ytmB[0]}">${(ra.ytm*100).toFixed(3)}%</td><td class="${ytmB[1]}">${(rb.ytm*100).toFixed(3)}%</td></tr>
        <tr><td>Current Yield</td><td class="${cyB[0]}">${(ra.currentYield*100).toFixed(3)}%</td><td class="${cyB[1]}">${(rb.currentYield*100).toFixed(3)}%</td></tr>
        <tr><td>Annual Coupon</td><td>$${ra.annualCoupon.toFixed(2)}</td><td>$${rb.annualCoupon.toFixed(2)}</td></tr>
        <tr><td>Macaulay Duration</td><td>${ra.macaulay.toFixed(3)}</td><td>${rb.macaulay.toFixed(3)}</td></tr>
        <tr><td>Modified Duration</td><td class="${durB[0]}">${ra.modified.toFixed(3)}</td><td class="${durB[1]}">${rb.modified.toFixed(3)}</td></tr>
        <tr><td>Convexity</td><td class="${convB[0]}">${ra.convexity.toFixed(2)}</td><td class="${convB[1]}">${rb.convexity.toFixed(2)}</td></tr>
        <tr><td>Total Return</td><td class="${retB[0]}">${ra.totalReturnPct.toFixed(1)}%</td><td class="${retB[1]}">${rb.totalReturnPct.toFixed(1)}%</td></tr>
        <tr><td>Bond Type</td><td>${ra.isDiscount ? 'Discount' : ra.isPremium ? 'Premium' : 'Par'}</td><td>${rb.isDiscount ? 'Discount' : rb.isPremium ? 'Premium' : 'Par'}</td></tr>
      </tbody>
    </table>
    <div style="margin-top:12px;font-size:12px;color:var(--text-secondary);text-align:center">
      <span class="pos">Green</span> = favorable &nbsp; <span class="neg">Red</span> = less favorable (lower duration = less rate risk)
    </div>
  </div>`;

  document.getElementById('compResults').innerHTML = html;
}

