function buildCashFlowTable(fv, couponRate, ytm, years, freq) {
  const section = document.getElementById('cashflowSection');
  section.style.display = '';
  const tbody = document.getElementById('cashflowTbody');
  const couponPerPeriod = (fv * couponRate / 100) / freq;
  const n = Math.round(years * freq);
  let runningTotal = 0;
  let rows = '';

  for (let t = 1; t <= n; t++) {
    const isLast = t === n;
    const cashFlow = couponPerPeriod + (isLast ? fv : 0);
    runningTotal += couponPerPeriod;
    const pv = cashFlow / Math.pow(1 + ytm / freq, t);
    const periodLabel = freq === 1 ? `Year ${t}` : freq === 2 ? `Period ${t} (${Math.ceil(t/2)}${t % 2 === 1 ? 'a' : 'b'})` : `Q${((t-1)%4)+1} Year ${Math.ceil(t/4)}`;

    rows += `<tr${isLast ? ' style="font-weight:600"' : ''}>
      <td>${periodLabel}${isLast ? ' (maturity)' : ''}</td>
      <td class="num">$${couponPerPeriod.toFixed(2)}</td>
      <td class="num">$${runningTotal.toFixed(2)}</td>
      <td class="num" style="color:var(--accent-color)">$${pv.toFixed(2)}</td>
    </tr>`;
  }

  // Summary row
  const totalPV = parseFloat([...Array(n)].reduce((sum, _, i) => {
    const t = i + 1;
    const cf = couponPerPeriod + (t === n ? fv : 0);
    return sum + cf / Math.pow(1 + ytm / freq, t);
  }, 0).toFixed(2));

  rows += `<tr style="border-top:2px solid var(--accent-color);font-weight:700">
    <td>Total</td>
    <td class="num">$${(couponPerPeriod * n).toFixed(2)}</td>
    <td class="num">$${runningTotal.toFixed(2)}</td>
    <td class="num" style="color:var(--accent-color)">$${totalPV.toFixed(2)}</td>
  </tr>`;

  tbody.innerHTML = rows;
}

// ===== Price-Yield Chart =====
function drawPriceYieldChart(fv, coupon, ytm, years, freq, currentPrice) {
  const section = document.getElementById('chartSection');
  section.style.display = '';
  const canvas = document.getElementById('priceYieldCanvas');
  const ctx = canvas.getContext('2d');

  const dpr = window.devicePixelRatio || 1;
  const rect = canvas.parentElement.getBoundingClientRect();
  canvas.width = rect.width * dpr;
  canvas.height = rect.height * dpr;
  canvas.style.width = rect.width + 'px';
  canvas.style.height = rect.height + 'px';
  ctx.scale(dpr, dpr);

  const W = rect.width, H = rect.height;
  const pad = { top: 20, right: 30, bottom: 50, left: 70 };
  const cw = W - pad.left - pad.right;
  const ch = H - pad.top - pad.bottom;

  // Generate data points
  const minY = Math.max(0.001, ytm - 0.06);
  const maxY = ytm + 0.06;
  const points = [];
  for (let y = minY; y <= maxY; y += 0.002) {
    const p = calcBondPrice(fv, coupon, y, years, freq);
    points.push({ yield: y, price: p });
  }

  const minPrice = Math.min(...points.map(p => p.price));
  const maxPrice = Math.max(...points.map(p => p.price));
  const priceRange = maxPrice - minPrice || 1;

  function toX(y) { return pad.left + ((y - minY) / (maxY - minY)) * cw; }
  function toY(p) { return pad.top + ch - ((p - minPrice) / priceRange) * ch; }

  ctx.clearRect(0, 0, W, H);

  // Grid
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 5; i++) {
    const y = pad.top + (ch / 5) * i;
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W - pad.right, y); ctx.stroke();
  }
  for (let i = 0; i <= 6; i++) {
    const x = pad.left + (cw / 6) * i;
    ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H - pad.bottom); ctx.stroke();
  }

  // Curve
  ctx.strokeStyle = '#4a8fe7';
  ctx.lineWidth = 2.5;
  ctx.beginPath();
  points.forEach((pt, i) => {
    const x = toX(pt.yield), y = toY(pt.price);
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.stroke();

  // Current point
  const cx = toX(ytm), cy = toY(currentPrice);
  ctx.fillStyle = '#ef4444';
  ctx.beginPath(); ctx.arc(cx, cy, 6, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = '#fff';
  ctx.beginPath(); ctx.arc(cx, cy, 2.5, 0, Math.PI * 2); ctx.fill();

  // Label
  ctx.fillStyle = '#ef4444';
  ctx.font = '11px JetBrains Mono, monospace';
  ctx.textAlign = 'left';
  ctx.fillText(`YTM: ${(ytm*100).toFixed(2)}%  Price: $${currentPrice.toFixed(0)}`, cx + 10, cy - 8);

  // Par line
  if (fv >= minPrice && fv <= maxPrice) {
    ctx.strokeStyle = 'rgba(245,158,11,0.4)';
    ctx.setLineDash([4, 4]);
    ctx.lineWidth = 1;
    const parY = toY(fv);
    ctx.beginPath(); ctx.moveTo(pad.left, parY); ctx.lineTo(W - pad.right, parY); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = '#f59e0b';
    ctx.font = '10px Inter, sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText('Par ($' + fv + ')', W - pad.right, parY - 4);
  }

  // Axes labels
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.font = '11px JetBrains Mono, monospace';
  ctx.textAlign = 'center';
  for (let i = 0; i <= 6; i++) {
    const yieldVal = minY + (maxY - minY) * (i / 6);
    ctx.fillText((yieldVal * 100).toFixed(1) + '%', pad.left + (cw / 6) * i, H - pad.bottom + 20);
  }
  ctx.textAlign = 'right';
  for (let i = 0; i <= 5; i++) {
    const priceVal = minPrice + priceRange * (1 - i / 5);
    ctx.fillText('$' + priceVal.toFixed(0), pad.left - 8, pad.top + (ch / 5) * i + 4);
  }

  // Axis titles
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.font = '12px Inter, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('Yield', W / 2, H - 8);
  ctx.save();
  ctx.translate(16, H / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillText('Bond Price', 0, 0);
  ctx.restore();
}

