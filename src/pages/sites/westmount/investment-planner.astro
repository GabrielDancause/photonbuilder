---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Investment Planner: Calculate Future Wealth & Growth",
  description: "Discover how your money can grow over time. Explore compounding returns, inflation impacts, and long-term strategies...",
  category: "tool",
  published: "2026-03-17"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an investment planner?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An investment planner is a tool that helps you project the future value of your investments by accounting for your initial principal, regular contributions, expected rate of return, and the compounding period."
          }
        },
        {
          "@type": "Question",
          "name": "How does compounding work in investing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Compounding occurs when the returns you earn on your investments begin to generate their own returns. Over long periods, this creates an exponential growth curve that can significantly increase your wealth."
          }
        },
        {
          "@type": "Question",
          "name": "What is a realistic expected rate of return?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Historically, the stock market (like the S&P 500) has returned around 7% to 10% annually, depending on whether you adjust for inflation. However, your actual return depends on your asset allocation and risk tolerance."
          }
        },
        {
          "@type": "Question",
          "name": "Why should I factor inflation into my investment plan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Inflation reduces the purchasing power of money over time. By adjusting your projected returns for expected inflation (typically 2-3% per year), you get a more accurate picture of what your future wealth will actually buy."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I contribute to my investments?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Contributing regularly (such as monthly or per paycheck) is often more effective than trying to time the market. This approach, known as dollar-cost averaging, can help smooth out market volatility over time."
          }
        }
      ]
    }
  ]
};
