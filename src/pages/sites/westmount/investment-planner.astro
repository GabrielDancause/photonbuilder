<script is:inline>
  function initInvestmentPlanner() {
    // Elements
    const initialInput = document.getElementById('initial-investment');
    const monthlyInput = document.getElementById('monthly-contribution');
    const yearsInput = document.getElementById('years-to-grow');
    const returnInput = document.getElementById('expected-return');
    const inflationInput = document.getElementById('inflation-rate');

    const resultFV = document.getElementById('result-future-value');
    const resultContrib = document.getElementById('result-contributions');
    const resultInterest = document.getElementById('result-interest');
    const resultAdjusted = document.getElementById('result-adjusted-value');

    const chartContainer = document.getElementById('chart-container');

    // Table Elements
    const tableContrib = document.getElementById('table-contributions');
    const tableNoInvest = document.getElementById('table-no-investing');
    const tableWithInvest = document.getElementById('table-with-investing');

    if (!initialInput || !resultFV) return;

    // Formatting utility
    const formatCurrency = (value) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(value);
    };

    function calculate() {
      // Parse inputs
      const P = parseFloat(initialInput.value) || 0;
      const PMT = parseFloat(monthlyInput.value) || 0;
      const t = parseFloat(yearsInput.value) || 0;
      const r = (parseFloat(returnInput.value) || 0) / 100;
      const inflation = (parseFloat(inflationInput.value) || 0) / 100;

      // Handle edge cases
      if (P < 0 || PMT < 0 || t <= 0) {
         resultFV.textContent = "$0";
         resultContrib.textContent = "$0";
         resultInterest.textContent = "$0";
         resultAdjusted.textContent = "$0";
         if (tableContrib) tableContrib.textContent = "$0";
         if (tableNoInvest) tableNoInvest.textContent = "$0";
         if (tableWithInvest) tableWithInvest.textContent = "$0";
         if (chartContainer) chartContainer.innerHTML = '';
         return;
      }

      const n = 12; // Monthly compounding for contributions
      const annualCompounding = 1; // Annual compounding for lump sum

      // Total Contributions
      const totalContributions = P + (PMT * 12 * t);

      let futureValue = 0;
      let yearlyData = [];

      // Calculate year by year for chart and final FV
      let currentBalance = P;
      for (let year = 1; year <= t; year++) {
         // Add interest on current balance (compounding monthly over the year)
         currentBalance = currentBalance * Math.pow(1 + r/n, n);

         // Add 12 months of contributions, assuming end of month deposits growing for that year
         // A simpler approximation for yearly discrete steps: add PMT * 12
         // More accurate: future value of an annuity for 1 year
         const yearlyContributionFV = PMT * ((Math.pow(1 + r/n, n) - 1) / (r/n));
         currentBalance += (r === 0 ? PMT * 12 : yearlyContributionFV);

         yearlyData.push(currentBalance);
      }

      futureValue = currentBalance;

      // Total Interest
      const totalInterest = futureValue - totalContributions;

      // Inflation Adjusted (Purchasing Power)
      // FV / (1 + i)^t
      const adjustedValue = futureValue / Math.pow(1 + inflation, t);

      // Update UI
      resultFV.textContent = formatCurrency(futureValue);
      resultContrib.textContent = formatCurrency(totalContributions);
      resultInterest.textContent = Math.max(0, totalInterest) === 0 && totalInterest < 0 ? "$0" : formatCurrency(totalInterest);
      resultAdjusted.textContent = formatCurrency(adjustedValue);

      // Update Table
      if (tableContrib && tableNoInvest && tableWithInvest) {
        tableContrib.textContent = formatCurrency(totalContributions);
        tableNoInvest.textContent = formatCurrency(totalContributions);
        tableWithInvest.textContent = formatCurrency(futureValue);
      }

      // Render Chart
      if (chartContainer && yearlyData.length > 0) {
        chartContainer.innerHTML = '';
        const maxVal = Math.max(...yearlyData);

        yearlyData.forEach((val) => {
          const bar = document.createElement('div');
          bar.className = 'chart-bar';
          const heightPct = maxVal > 0 ? (val / maxVal) * 100 : 0;
          bar.style.height = `${Math.max(1, heightPct)}%`;
          bar.title = formatCurrency(val);
          chartContainer.appendChild(bar);
        });
      }
    }

    // Event Listeners
    [initialInput, monthlyInput, yearsInput, returnInput, inflationInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  }

  // Handle Astro View Transitions
  document.addEventListener('astro:page-load', initInvestmentPlanner);

  // Fallback for standard load if view transitions aren't ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initInvestmentPlanner);
  } else {
    initInvestmentPlanner();
  }
</script>
