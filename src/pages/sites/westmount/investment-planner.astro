---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Investment Planner & Calculator | Westmount Fundamentals",
  description: "Stop guessing about your financial future. Use our professional investment planner to project compound growth, test scenarios, and map out a bulletproof strategy.",
  category: "tool",
  published: "2026-03-17"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "datePublished": meta.published,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/investment-planner"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an investment planner?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An investment planner is a tool that helps you project the future value of your investments by calculating compound interest on your initial capital and ongoing regular contributions over a specific time horizon."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate compound interest with monthly contributions?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The formula involves two parts: calculating the compound interest on the principal sum (P(1+r/n)^(nt)) and calculating the future value of a series of payments (PMT × &#123;[(1 + r/n)^(nt) - 1] / (r/n)&#125;), then adding them together."
          }
        },
        {
          "@type": "Question",
          "name": "Why is the Rule of 72 important in investment planning?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Rule of 72 is a mental shortcut to estimate how long it will take to double your money. You simply divide 72 by your expected annual return rate. For example, at an 8% return, your money doubles in about 9 years."
          }
        },
        {
          "@type": "Question",
          "name": "What is a realistic expected return for an investment planner?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Historically, the S&P 500 has returned an average of 9-10% annually before inflation. For conservative planning, many professionals suggest using 6-8% to account for inflation and market volatility."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I review my investment plan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You should review your investment plan at least annually, or when major life events occur (like marriage, a new job, or inheritance). However, checking it daily can lead to emotional decisions; focus on the long-term trend."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/investment-planner" schema={schema}>
  <div class="page-content">
    <div class="container">
      <h1>Investment Planner</h1>
      <p style="text-align: center; max-width: 700px; margin: 0 auto 2rem auto; font-size: 1.15rem;">
        Map out your financial future with precision. See how initial capital, ongoing contributions, and compounding interest work together to build wealth over time.
      </p>

      <div class="calculator-card" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem;">
        <div class="calc-inputs">
          <h3>Your Plan</h3>

          <div class="input-group">
            <label for="initial-investment">Initial Investment</label>
            <div class="input-wrapper">
              <span class="suffix" style="left: 1rem; right: auto;">$</span>
              <input type="number" id="initial-investment" value="10000" min="0" step="100" style="padding-left: 2.5rem; padding-right: 1rem;">
            </div>
          </div>

          <div class="input-group">
            <label for="monthly-contribution">Monthly Contribution</label>
            <div class="input-wrapper">
              <span class="suffix" style="left: 1rem; right: auto;">$</span>
              <input type="number" id="monthly-contribution" value="500" min="0" step="50" style="padding-left: 2.5rem; padding-right: 1rem;">
            </div>
          </div>

          <div class="input-group">
            <label for="years-to-grow">Years to Grow</label>
            <div class="input-wrapper">
              <input type="number" id="years-to-grow" value="20" min="1" max="100" step="1">
              <span class="suffix">YRS</span>
            </div>
          </div>

          <div class="input-group">
            <label for="expected-return">Expected Annual Return</label>
            <div class="input-wrapper">
              <input type="number" id="expected-return" value="8" step="0.1">
              <span class="suffix">%</span>
            </div>
          </div>
        </div>

        <div class="calc-outputs" style="display: flex; flex-direction: column; justify-content: center;">
          <div class="calc-result" style="margin-top: 0; border-top: none; padding-top: 0;">
            <span class="calc-result-label">Future Portfolio Value</span>
            <div id="future-value" class="calc-result-value" style="font-size: 3rem; margin-bottom: 1.5rem;">$325,432</div>
          </div>

          <div style="background: var(--card-bg); border-radius: 8px; padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
              <span style="color: var(--text-secondary);">Total Contributions</span>
              <span id="total-contributions" style="font-family: var(--font-mono); font-weight: 600; color: var(--text-primary);">$130,000</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
              <span style="color: var(--text-secondary);">Total Interest Earned</span>
              <span id="total-interest" style="font-family: var(--font-mono); font-weight: 600; color: var(--accent-color);">$195,432</span>
            </div>
            <div style="display: flex; justify-content: space-between; padding-top: 0.75rem; border-top: 1px solid var(--border-color);">
              <span style="color: var(--text-secondary);">Total Profit Multiple</span>
              <span id="profit-multiple" style="font-family: var(--font-mono); font-weight: 600; color: var(--text-primary);">2.5x</span>
            </div>
          </div>
        </div>
      </div>

      <h3 style="margin-top: 3rem; margin-bottom: 1.5rem; text-align: center;">The Power of Compounding</h3>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Strategy</th>
              <th>Total Invested</th>
              <th>Final Value</th>
              <th>Wealth Created</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td style="color: var(--text-primary); font-weight: 500;">Cash Under Mattress (0%)</td>
              <td id="table-mattress-invested">$130,000</td>
              <td id="table-mattress-final">$130,000</td>
              <td>$0</td>
            </tr>
            <tr style="background-color: var(--card-bg);">
              <td style="color: var(--accent-color); font-weight: 600;">Invested Portfolio</td>
              <td id="table-portfolio-invested">$130,000</td>
              <td id="table-portfolio-final" style="color: var(--text-primary); font-weight: 600;">$325,432</td>
              <td id="table-portfolio-created" style="color: var(--accent-color); font-weight: 600;">$195,432</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="content-section" style="max-width: 800px; margin: 4rem auto 0 auto;">
        <h2>How an Investment Planner Builds Your Future</h2>
        <p>If you have ever stared at your savings account balance and wondered how you are going to afford retirement, you need an <strong>investment planner</strong>. It is the single most important tool for translating vague financial hopes into a mathematical reality.</p>
        <p>At its core, an investment planner is a calculator that projects the future value of your money by accounting for three critical variables: your initial capital, your ongoing regular contributions, and the power of compound interest over time. By adjusting these variables, you can literally design your financial future.</p>

        <div class="highlight-box">
          <p style="margin-bottom: 0;"><strong>The Core Concept:</strong> Money makes money. And the money that money makes, makes more money. That is the essence of compound interest.</p>
        </div>

        <h3>The Mathematics of Compounding</h3>
        <p>To truly understand how your wealth grows, you need to understand the math under the hood. When you use our planner, it is actually combining two separate mathematical formulas into one seamless calculation.</p>
        <p>The first part calculates the growth of your <em>Initial Investment</em> (also known as the Principal):</p>

        <div style="background: var(--card-bg); border-left: 4px solid var(--border-color); padding: 1.5rem; margin: 1.5rem 0; border-radius: 0 8px 8px 0;">
          <p style="font-family: 'JetBrains Mono', monospace; margin-bottom: 0.5rem; color: var(--accent-color);"><strong>A = P(1 + r/n)^(nt)</strong></p>
          <ul style="margin-left: 1.5rem; margin-bottom: 0; font-size: 0.95rem;">
            <li><strong>A</strong> = The future value of the investment</li>
            <li><strong>P</strong> = The principal investment amount</li>
            <li><strong>r</strong> = The annual interest rate (in decimal form)</li>
            <li><strong>n</strong> = The number of times interest is compounded per year</li>
            <li><strong>t</strong> = The time the money is invested for (in years)</li>
          </ul>
        </div>

        <p>The second part calculates the future value of your <em>Monthly Contributions</em> (an annuity):</p>

        <div style="background: var(--card-bg); border-left: 4px solid var(--border-color); padding: 1.5rem; margin: 1.5rem 0; border-radius: 0 8px 8px 0;">
          <p style="font-family: 'JetBrains Mono', monospace; margin-bottom: 0.5rem; color: var(--accent-color);"><strong>FV = PMT × &#123;[(1 + r/n)^(nt) - 1] / (r/n)&#125;</strong></p>
          <ul style="margin-left: 1.5rem; margin-bottom: 0; font-size: 0.95rem;">
            <li><strong>FV</strong> = Future Value of the annuity</li>
            <li><strong>PMT</strong> = Monthly payment amount</li>
            <li><strong>r</strong>, <strong>n</strong>, and <strong>t</strong> are the same as above</li>
          </ul>
        </div>

        <p>The final number you see in the calculator is the sum of these two formulas.</p>

        <h3>A Worked Example: Showing the Math</h3>
        <p>Let's look at a realistic scenario. Suppose you are starting with a $10,000 initial investment, and you plan to contribute $500 every month for 20 years. You expect an average annual return of 8%, compounded monthly.</p>

        <p><strong>Part 1: The Initial $10,000</strong></p>
        <ul style="margin-left: 2rem; margin-bottom: 1.5rem;">
          <li>P = $10,000</li>
          <li>r = 0.08</li>
          <li>n = 12 (monthly compounding)</li>
          <li>t = 20 years</li>
          <li>Calculation: $10,000 × (1 + 0.08/12)^(12 × 20)</li>
          <li>Result: <strong>$49,268.03</strong></li>
        </ul>

        <p><strong>Part 2: The $500 Monthly Contributions</strong></p>
        <ul style="margin-left: 2rem; margin-bottom: 1.5rem;">
          <li>PMT = $500</li>
          <li>Calculation: $500 × &#123;[(1 + 0.08/12)^(12 × 20) - 1] / (0.08/12)&#125;</li>
          <li>Result: <strong>$294,510.21</strong></li>
        </ul>

        <p><strong>Total Future Value:</strong> $49,268.03 + $294,510.21 = <strong>$343,778.24</strong></p>

        <p>In this scenario, your total out-of-pocket contributions over 20 years were $130,000 ($10,000 initial + $500/month for 240 months). The remaining $213,778.24 is pure compound interest. This is why using an <a href="/investment-calculator">investment calculator</a> to visualize your timeline is so crucial for motivation.</p>

        <h2>Real-World Context: When Do Investors Use This?</h2>
        <p>An investment planner is not just a toy for theoretical math; it is a practical tool used to solve real-world problems.</p>

        <h4>1. Retirement Planning</h4>
        <p>The most common use case is mapping out retirement. If you know you need $1,500,000 to retire comfortably using the 4% rule (withdrawing 4% of your portfolio annually), you can work backwards. You plug in your current age, your target retirement age (which dictates the "Years to Grow"), and your expected return. The planner tells you exactly how much you need to contribute monthly to hit that target.</p>

        <h4>2. Saving for a Major Purchase</h4>
        <p>Perhaps you want to buy a house in 5 years or send a child to college in 15 years. You can use the planner to see if your current savings rate is adequate. If the projected future value falls short of your goal, you know immediately that you must either increase your contributions, extend your timeline, or take on more risk for a higher expected return.</p>

        <h4>3. Evaluating Opportunity Costs</h4>
        <p>When you are deciding whether to buy a new $40,000 car or a used $15,000 car, the planner helps you calculate the true cost. If you invested that $25,000 difference over 30 years at an 8% return, it would grow to over $250,000. Understanding this opportunity cost changes how you view large purchases.</p>

        <h2>Common Mistakes People Make with Investment Planning</h2>
        <p>While the math is straightforward, human psychology often gets in the way. When using our <a href="/investing-calculator">investing calculator</a> tools, try to avoid these common pitfalls:</p>

        <ol style="margin-left: 2rem; margin-bottom: 2rem; color: var(--text-secondary);">
          <li style="margin-bottom: 1rem;"><strong>Ignoring Inflation:</strong> A $1,000,000 portfolio in 30 years will not have the same purchasing power as $1,000,000 today. A simple trick is to subtract the expected inflation rate (historically around 2.5-3%) from your expected return. If you expect the market to return 10%, use 7% in your planner to see your results in "today's dollars."</li>
          <li style="margin-bottom: 1rem;"><strong>Chasing Unrealistic Returns:</strong> Beginners often plug in 15% or 20% annual returns because they had one good year trading individual stocks or crypto. Over long periods (20+ years), sustaining those returns is nearly impossible. Use conservative numbers. If you plan for 7% and get 10%, you'll be pleasantly surprised. If you plan for 15% and get 7%, your retirement plan fails.</li>
          <li style="margin-bottom: 1rem;"><strong>Underestimating the Power of Time:</strong> Waiting just 5 years to start investing can literally cut your final portfolio value in half. The heavy lifting of compound interest happens in the final years of the investment timeline.</li>
          <li style="margin-bottom: 1rem;"><strong>Forgetting About Taxes and Fees:</strong> If you are investing in a taxable brokerage account rather than a tax-advantaged account like an IRA or 401(k), taxes will drag down your net return. Similarly, high mutual fund fees or advisor fees will erode your compounding over time.</li>
        </ol>

        <h2>Professional Rules of Thumb</h2>
        <p>Financial advisors rely on several established benchmarks and shortcuts to quickly assess an investment plan. You can incorporate these into your own strategy:</p>

        <div class="card">
          <h4>The Rule of 72</h4>
          <p>This is a mathematical shortcut to estimate how long it will take to double your money. You divide 72 by your expected annual return rate. For example, if you project an 8% return, your money doubles in 9 years (72 / 8 = 9). If you want to double your money in 5 years, you need a 14.4% return (72 / 5 = 14.4). You can verify this math using our <a href="/roi-calculator">roi calculator</a>.</p>
        </div>

        <div class="card">
          <h4>Asset Allocation by Age</h4>
          <p>Your expected return depends entirely on what you invest in. A traditional rule of thumb is to hold your age in bonds as a percentage, and the rest in stocks. So a 30-year-old would hold 30% bonds and 70% stocks. A more modern, aggressive approach is "120 minus your age" in stocks, keeping younger investors heavily weighted in equities for maximum growth.</p>
        </div>

        <div class="card">
          <h4>The 4% Withdrawal Rule</h4>
          <p>How much do you actually need to save? The 4% rule suggests you can safely withdraw 4% of your portfolio's value in your first year of retirement, adjust for inflation annually, and likely not run out of money for 30 years. Therefore, your target portfolio size should be 25 times your annual expenses. If you need $60,000 a year, you need a $1,500,000 portfolio ($60,000 × 25 = $1,500,000).</p>
        </div>


        <h2>Deep Dive: The Mechanics of Compound Growth</h2>
        <p>Understanding the math is just the beginning. To truly harness the power of an investment planner, you must understand the underlying mechanics of compound growth and how different market environments impact your long-term results. Compounding is often called the "eighth wonder of the world" for a reason: it creates exponential wealth from linear inputs.</p>

        <h3>The Impact of Time Horizons</h3>
        <p>Your investment time horizon is the most critical factor in your planning. A 10-year horizon requires a vastly different strategy than a 30-year horizon. When you use our planner, you'll notice that the total interest earned doesn't grow linearly; it curves upward dramatically in the later years. This is the "hockey stick" effect of compounding.</p>
        <p>For example, if you invest $500 a month at an 8% return, it takes about 11 years to reach $100,000. But it only takes another 6 years to reach $200,000, and just 4 more years to hit $300,000. The longer you let your money work, the harder it works for you. This is why financial advisors constantly stress the importance of starting early, even with small amounts.</p>

        <h3>Risk Tolerance and Asset Allocation</h3>
        <p>When you input an "Expected Annual Return" into the calculator, you are implicitly making a decision about your risk tolerance and asset allocation. Higher returns require taking on more risk, typically by holding a higher percentage of equities (stocks) versus fixed income (bonds).</p>
        <p>Historically, aggressive portfolios composed mostly of stocks have offered higher potential returns (often 9-10% annualized) but come with significant short-term volatility. Conservative portfolios, heavily weighted in bonds, offer more stability but lower expected returns (often 4-6% annualized). Your job is to find the balance that allows you to sleep at night while still achieving your financial goals.</p>

        <h3>The Role of Dollar-Cost Averaging</h3>
        <p>When you make "Monthly Contributions" in our planner, you are practicing dollar-cost averaging (DCA). DCA involves investing a fixed amount of money at regular intervals, regardless of market conditions. This strategy naturally forces you to buy more shares when prices are low and fewer shares when prices are high, effectively lowering your average cost per share over time.</p>
        <p>More importantly, DCA removes the emotional burden of trying to "time the market." By automating your contributions, you ensure that your wealth-building process continues steadily, even during market downturns when human instinct often urges us to stop investing.</p>

        <h3>Adjusting for Inflation: Real vs. Nominal Returns</h3>
        <p>The numbers generated by our planner are "nominal" returns—they represent the actual dollar amount you will have in the future. However, because of inflation, a dollar in 30 years will buy less than a dollar today. To understand your true purchasing power, you must calculate your "real" return.</p>
        <p>To do this, simply subtract your expected inflation rate (historically around 2-3%) from your expected annual return in the calculator. If you expect a 9% return and 3% inflation, enter 6% as your expected return. The resulting future value will be expressed in today's purchasing power, giving you a much more accurate picture of your future wealth.</p>

        <h2>Advanced Investment Planning Strategies</h2>
        <p>Once you have mastered the basics of compounding and regular contributions, you can begin to incorporate more advanced strategies into your investment plan to optimize your results.</p>

        <h3>Tax-Advantaged Accounts</h3>
        <p>The type of account you use to invest can have a massive impact on your final portfolio value. By utilizing tax-advantaged accounts like IRAs, 401(k)s, or TFSAs (in Canada), you can shield your investments from annual taxes on dividends and capital gains. This allows your money to compound faster, as 100% of your gains remain invested.</p>
        <p>When using our planner, assume the results represent tax-advantaged growth unless you explicitly adjust your expected return downward to account for tax drag in a taxable brokerage account.</p>

        <h3>Rebalancing Your Portfolio</h3>
        <p>Over time, different assets in your portfolio will grow at different rates, causing your asset allocation to drift from your original target. For example, a prolonged bull market might cause your stock allocation to rise from 70% to 85%, unintentionally increasing your portfolio's risk profile.</p>
        <p>Periodic rebalancing—selling high-performing assets and buying underperforming ones to restore your target allocation—ensures that you maintain your desired risk level and forces you to naturally "sell high and buy low."</p>

        <h3>Sequence of Returns Risk</h3>
        <p>While our planner assumes a steady average annual return, the real world is volatile. If you experience a severe market downturn just as you begin to withdraw funds in retirement, the impact on your portfolio can be devastating. This is known as "sequence of returns risk."</p>
        <p>To mitigate this risk, retirees often shift a portion of their portfolio into safer, income-producing assets (like bonds or cash equivalents) in the years leading up to retirement, ensuring they don't have to sell stocks at depressed prices during a bear market.</p>

        <h2>Building Your Strategy</h2>
        <p>Your investment plan should not be a static document. It is a living strategy that adapts as your income, expenses, and life goals change. We recommend revisiting your plan annually or after major life events like marriage, a new job, or receiving an inheritance.</p>

        <p>If you are trying to calculate complex scenarios, such as paying down debt versus investing, or calculating the long-term impact of high-interest consumer debt, you may want to look into strategies modeled by a <a href="/ramsey-investment-calculator">ramsey investment calculator</a>, which emphasizes a structured, step-by-step approach to financial peace.</p>

        <p>Furthermore, if you hold individual stocks, remember that corporate actions can affect your portfolio structure without changing its value. If a company splits its shares, use a <a href="/stock-split-calculator">stock split calculator</a> to adjust your basis correctly so you do not accidentally distort your historical performance data.</p>

        <p>Ultimately, the most important metric to track is whether your portfolio's growth is outpacing the <a href="/average-stock-market-return">average stock market return</a> over a multi-year period. If it is not, you are likely taking on unnecessary risk or paying excessive fees, and you would be better served by simply buying low-cost index funds and letting the math work for you.</p>

        <div class="faq-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-item">
            <h3>What is an investment planner?</h3>
            <p>An investment planner is a tool that helps you project the future value of your investments by calculating compound interest on your initial capital and ongoing regular contributions over a specific time horizon.</p>
          </div>
          <div class="faq-item">
            <h3>How do you calculate compound interest with monthly contributions?</h3>
            <p>The formula involves two parts: calculating the compound interest on the principal sum (P(1+r/n)^(nt)) and calculating the future value of a series of payments (PMT × &#123;[(1 + r/n)^(nt) - 1] / (r/n)&#125;), then adding them together.</p>
          </div>
          <div class="faq-item">
            <h3>Why is the Rule of 72 important in investment planning?</h3>
            <p>The Rule of 72 is a mental shortcut to estimate how long it will take to double your money. You simply divide 72 by your expected annual return rate. For example, at an 8% return, your money doubles in about 9 years.</p>
          </div>
          <div class="faq-item">
            <h3>What is a realistic expected return for an investment planner?</h3>
            <p>Historically, the S&P 500 has returned an average of 9-10% annually before inflation. For conservative planning, many professionals suggest using 6-8% to account for inflation and market volatility.</p>
          </div>
          <div class="faq-item">
            <h3>How often should I review my investment plan?</h3>
            <p>You should review your investment plan at least annually, or when major life events occur (like marriage, a new job, or inheritance). However, checking it daily can lead to emotional decisions; focus on the long-term trend.</p>
          </div>
        </div>
      </div>
    </div>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
      const initialInput = document.getElementById('initial-investment');
      const monthlyInput = document.getElementById('monthly-contribution');
      const yearsInput = document.getElementById('years-to-grow');
      const returnInput = document.getElementById('expected-return');

      const futureValueEl = document.getElementById('future-value');
      const totalContributionsEl = document.getElementById('total-contributions');
      const totalInterestEl = document.getElementById('total-interest');
      const profitMultipleEl = document.getElementById('profit-multiple');

      const tableMattressInvested = document.getElementById('table-mattress-invested');
      const tableMattressFinal = document.getElementById('table-mattress-final');
      const tablePortfolioInvested = document.getElementById('table-portfolio-invested');
      const tablePortfolioFinal = document.getElementById('table-portfolio-final');
      const tablePortfolioCreated = document.getElementById('table-portfolio-created');

      function formatCurrency(num) {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 0,
          maximumFractionDigits: 0
        }).format(num);
      }

      function calculate() {
        const principal = parseFloat(initialInput.value) || 0;
        const pmt = parseFloat(monthlyInput.value) || 0;
        const years = parseFloat(yearsInput.value) || 0;
        const annualReturn = parseFloat(returnInput.value) || 0;

        const months = years * 12;
        const totalInvested = principal + (pmt * months);
        let futureValue = 0;

        if (annualReturn === 0 || Math.abs(annualReturn) < 1e-10) {
          futureValue = totalInvested;
        } else {
          const r = annualReturn / 100;
          const monthlyRate = r / 12;

          // Compound interest on principal
          const principalFV = principal * Math.pow(1 + monthlyRate, months);

          // Future value of a series of monthly contributions
          const contributionsFV = pmt * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);

          futureValue = principalFV + contributionsFV;
        }

        // Float precision fix
        let fixedFV = parseFloat(futureValue.toPrecision(14));
        if (Math.abs(fixedFV - Math.round(fixedFV)) < 1e-14) {
          futureValue = Math.round(fixedFV);
        } else {
          futureValue = fixedFV;
        }

        const totalInterest = futureValue - totalInvested;

        let multiple = 1;
        if (totalInvested > 0) {
          multiple = futureValue / totalInvested;
        }

        let fixedMultiple = parseFloat(multiple.toPrecision(14));
        if (Math.abs(fixedMultiple - Math.round(fixedMultiple)) < 1e-14) {
          multiple = Math.round(fixedMultiple);
        } else {
          multiple = fixedMultiple;
        }

        // Update UI
        futureValueEl.textContent = formatCurrency(futureValue);
        totalContributionsEl.textContent = formatCurrency(totalInvested);
        totalInterestEl.textContent = formatCurrency(totalInterest > 0 ? totalInterest : 0);
        profitMultipleEl.textContent = multiple.toFixed(1) + 'x';

        // Update Table
        tableMattressInvested.textContent = formatCurrency(totalInvested);
        tableMattressFinal.textContent = formatCurrency(totalInvested);

        tablePortfolioInvested.textContent = formatCurrency(totalInvested);
        tablePortfolioFinal.textContent = formatCurrency(futureValue);
        tablePortfolioCreated.textContent = formatCurrency(totalInterest > 0 ? totalInterest : 0);
      }

      // Add event listeners
      const inputs = [initialInput, monthlyInput, yearsInput, returnInput];
      inputs.forEach(input => {
        if (input) {
          input.addEventListener('input', calculate);
        }
      });

      // Initial calculation
      calculate();
    });
  </script>

