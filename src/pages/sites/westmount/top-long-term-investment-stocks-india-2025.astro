  { rank: 15, symbol: "KOTAKBANK.NS", name: "KOTAK MAHINDRA BANK LTD", price: 374.2, marketCap: 3721603317760, volume: 15176336, sector: "Financial Services", beta: 0.143, dividendYield: 0.14, pros: "Conservative underwriting; high ROA.", cons: "Trades at a premium valuation.", why: "Pristine asset quality makes it the safest long-term bet in the Indian financial sector." }
