---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const contentPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/westmount_guides.html');
const htmlContent = fs.readFileSync(contentPath, 'utf-8');

const cssPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/westmount_guides.css');
let cssContent = '';
try { cssContent = fs.readFileSync(cssPath, 'utf-8'); } catch {}
---

<SiteLayout
  site="westmount"
  title="Educational Guides — Westmount Fundamentals"
  description="Comprehensive educational guides and explainers on investing, stock analysis, ETFs, and market fundamentals."
  canonical="https://{}/guides/"
>
  <Fragment set:html={htmlContent} />
  {cssContent && <style is:inline set:html={cssContent} />}
</SiteLayout>
