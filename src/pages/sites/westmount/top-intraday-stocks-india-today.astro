  <script is:inline>
    // Search and Filter logic
    const searchInput = document.getElementById('searchInput');
    const sectorFilter = document.getElementById('sectorFilter');
    const rows = document.querySelectorAll('.data-row');

    function filterTable() {
      const searchTerm = searchInput.value.toLowerCase();
      const sectorTerm = sectorFilter.value;

      rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        const sector = row.getAttribute('data-sector');

        const matchesSearch = text.includes(searchTerm);
        const matchesSector = sectorTerm === 'All' || sector === sectorTerm;

        if (matchesSearch && matchesSector) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    }

    if (searchInput) searchInput.addEventListener('input', filterTable);
    if (sectorFilter) sectorFilter.addEventListener('change', filterTable);

    // Sorting logic
    let sortDirections = [true, true, true, true, true, true, true];
    function sortTable(columnIndex) {
      const table = document.getElementById("dataTable");
      const tbody = table.querySelector("tbody");
      const rowsArray = Array.from(tbody.querySelectorAll("tr"));
      const isAscending = sortDirections[columnIndex];

      rowsArray.sort((a, b) => {
        const cellA = a.children[columnIndex];
        const cellB = b.children[columnIndex];

        let valA = cellA.getAttribute('data-val') !== null ? parseFloat(cellA.getAttribute('data-val')) : cellA.innerText.toLowerCase();
        let valB = cellB.getAttribute('data-val') !== null ? parseFloat(cellB.getAttribute('data-val')) : cellB.innerText.toLowerCase();

        if (typeof valA === 'string' && typeof valB === 'string') {
            return isAscending ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else {
            return isAscending ? valA - valB : valB - valA;
        }
      });

      rowsArray.forEach(row => tbody.appendChild(row));
      sortDirections[columnIndex] = !isAscending;
    }
  </script>


