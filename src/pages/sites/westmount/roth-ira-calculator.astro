---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Roth IRA Calculator | Estimate Your Tax-Free Retirement Growth",
  description: "Use our free Roth IRA calculator to estimate your future tax-free retirement savings. Calculate compound growth based on your age, contributions, and expected returns.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a Roth IRA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Roth IRA is an individual retirement account that offers tax-free growth and tax-free withdrawals in retirement. Unlike a Traditional IRA, contributions are made with after-tax dollars, meaning you don't get a tax deduction now, but your future withdrawals are completely tax-free."
      }
    },
    {
      "@type": "Question",
      "name": "How much can I contribute to a Roth IRA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2024, the maximum contribution limit is $7,000 if you are under age 50, and $8,000 if you are age 50 or older (which includes a $1,000 catch-up contribution). These limits apply to your total contributions across all IRAs (Roth and Traditional)."
      }
    },
    {
      "@type": "Question",
      "name": "Are there income limits for contributing to a Roth IRA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. For 2024, your ability to contribute directly to a Roth IRA begins to phase out at a Modified Adjusted Gross Income (MAGI) of $146,000 for single filers ($230,000 for married filing jointly) and is completely eliminated at $161,000 for single filers ($240,000 for married filing jointly)."
      }
    },
    {
      "@type": "Question",
      "name": "When can I withdraw money from my Roth IRA without penalty?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can withdraw your contributions (but not earnings) at any time without taxes or penalties. To withdraw earnings tax-free and penalty-free, you must be at least 59½ years old, and the account must have been open for at least 5 years (the 5-year rule)."
      }
    },
    {
      "@type": "Question",
      "name": "Can I have both a Roth IRA and a 401(k)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, you can contribute to both a Roth IRA and an employer-sponsored retirement plan like a 401(k) in the same year, provided you meet the income requirements for the Roth IRA. This is a common strategy to maximize retirement savings and achieve tax diversification."
      }
    }
  ]
});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/roth-ira-calculator" schema={schema}>
  <div class="container page-content">
    <h1>Roth IRA Calculator</h1>

    <div class="calculator-container">
      <div class="calc-inputs">
        <div class="input-group">
          <label for="currentAge">Current Age</label>
          <div class="input-wrapper">
            <input type="number" id="currentAge" value="30" min="18" max="90" step="1">
            <span class="suffix">YRS</span>
          </div>
        </div>

        <div class="input-group">
          <label for="retirementAge">Retirement Age</label>
          <div class="input-wrapper">
            <input type="number" id="retirementAge" value="65" min="19" max="100" step="1">
            <span class="suffix">YRS</span>
          </div>
        </div>

        <div class="input-group">
          <label for="currentBalance">Current Balance</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="currentBalance" value="10000" min="0" step="1000">
          </div>
        </div>

        <div class="input-group">
          <label for="annualContribution">Annual Contribution</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="annualContribution" value="6000" min="0" step="500">
          </div>
          <small class="helper-text">Max contribution for 2024 is $7,000 ($8,000 if 50+).</small>
        </div>

        <div class="input-group">
          <label for="expectedReturn">Expected Annual Return</label>
          <div class="input-wrapper">
            <input type="number" id="expectedReturn" value="7" min="0" max="20" step="0.1">
            <span class="suffix">%</span>
          </div>
        </div>
      </div>

      <div class="calc-results">
        <div class="result-box primary">
          <span class="result-label">Estimated Future Balance</span>
          <span class="result-value" id="futureBalance">$0</span>
        </div>

        <div class="result-box secondary">
          <span class="result-label">Total Contributions</span>
          <span class="result-value" id="totalContributions">$0</span>
        </div>

        <div class="result-box secondary">
          <span class="result-label">Total Tax-Free Earnings</span>
          <span class="result-value" id="totalEarnings">$0</span>
        </div>
      </div>
    </div>

    <section class="educational-content">
      <h2>How to Use This Roth IRA Calculator</h2>
      <p>This Roth IRA calculator estimates the future value of your retirement savings. Enter your current age, the age you plan to retire, your current Roth IRA balance, your planned annual contribution, and an estimated annual return rate. The calculator will project your total tax-free balance at retirement, broken down into your direct contributions and your accumulated tax-free earnings.</p>

      <h2>What is a Roth IRA?</h2>
      <p>A Roth Individual Retirement Account (IRA) is a powerful retirement savings vehicle that offers tax-free growth and tax-free withdrawals in retirement. Unlike a Traditional IRA where contributions are often tax-deductible today, Roth IRA contributions are made with after-tax dollars.</p>
      <p>The primary benefit of a Roth IRA is that all future growth—including dividends, interest, and capital gains—accumulates completely tax-free. Furthermore, qualified withdrawals in retirement are also tax-free, protecting you from future tax rate increases.</p>

      <h3>Contribution Limits for 2024</h3>
      <ul>
        <li><strong>Under Age 50:</strong> $7,000 per year</li>
        <li><strong>Age 50 and Older:</strong> $8,000 per year (includes a $1,000 "catch-up" contribution)</li>
      </ul>
      <p>These limits apply across all your IRAs combined. Additionally, income limits dictate who can contribute directly to a Roth IRA. If your Modified Adjusted Gross Income (MAGI) is too high, your allowable direct contribution amount phases out to zero.</p>

      <h2>The Math Behind Compound Growth</h2>
      <p>This calculator uses standard compound interest formulas to project your retirement balance. The formula accounts for both the initial principal compound growth and the future value of an annuity for your ongoing annual contributions.</p>

      <p><strong>Compound Interest on Current Balance:</strong></p>
      <code>FV = P(1 + r)^n</code>

      <p><strong>Future Value of Annual Contributions:</strong></p>
      <code>FVA = PMT [ ((1 + r)^n - 1) / r ]</code>

      <p>Where:</p>
      <ul>
        <li><strong>FV</strong> = Future Value</li>
        <li><strong>P</strong> = Principal (Current Balance)</li>
        <li><strong>r</strong> = Expected Annual Return (expressed as a decimal)</li>
        <li><strong>n</strong> = Number of Years until Retirement</li>
        <li><strong>PMT</strong> = Annual Contribution Amount</li>
      </ul>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details class="faq-item">
        <summary>What is a Roth IRA?</summary>
        <p>A Roth IRA is an individual retirement account that offers tax-free growth and tax-free withdrawals in retirement. Unlike a Traditional IRA, contributions are made with after-tax dollars, meaning you don't get a tax deduction now, but your future withdrawals are completely tax-free.</p>
      </details>

      <details class="faq-item">
        <summary>How much can I contribute to a Roth IRA?</summary>
        <p>For 2024, the maximum contribution limit is $7,000 if you are under age 50, and $8,000 if you are age 50 or older (which includes a $1,000 catch-up contribution). These limits apply to your total contributions across all IRAs (Roth and Traditional).</p>
      </details>

      <details class="faq-item">
        <summary>Are there income limits for contributing to a Roth IRA?</summary>
        <p>Yes. For 2024, your ability to contribute directly to a Roth IRA begins to phase out at a Modified Adjusted Gross Income (MAGI) of $146,000 for single filers ($230,000 for married filing jointly) and is completely eliminated at $161,000 for single filers ($240,000 for married filing jointly).</p>
      </details>

      <details class="faq-item">
        <summary>When can I withdraw money from my Roth IRA without penalty?</summary>
        <p>You can withdraw your contributions (but not earnings) at any time without taxes or penalties. To withdraw earnings tax-free and penalty-free, you must be at least 59½ years old, and the account must have been open for at least 5 years (the 5-year rule).</p>
      </details>

      <details class="faq-item">
        <summary>Can I have both a Roth IRA and a 401(k)?</summary>
        <p>Yes, you can contribute to both a Roth IRA and an employer-sponsored retirement plan like a 401(k) in the same year, provided you meet the income requirements for the Roth IRA. This is a common strategy to maximize retirement savings and achieve tax diversification.</p>
      </details>
    </section>

  </div>
</SiteLayout>

<style>
  .calculator-container {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    margin: 2.5rem 0;
    box-shadow: 0 4px 6px -1px color-mix(in srgb, var(--text-primary) 10%, transparent);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .calculator-container {
      grid-template-columns: 1fr;
    }
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-group label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    pointer-events: none;
    font-size: 1rem;
  }

  .prefix {
    left: 1rem;
  }

  .suffix {
    right: 1rem;
  }

  .input-wrapper input {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: border-color 0.2s;
  }

  .input-wrapper input:focus {
    outline: none;
    border-color: var(--accent-color);
  }

  .input-wrapper:has(.prefix) input {
    padding-left: 2rem;
  }

  .input-wrapper:has(.suffix) input {
    padding-right: 2.5rem;
  }

  .helper-text {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .calc-results {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
  }

  .result-box {
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    text-align: center;
  }

  .result-box.primary {
    border-color: var(--accent-color);
    background-color: color-mix(in srgb, var(--accent-color) 5%, var(--bg-color));
  }

  .result-label {
    display: block;
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .result-value {
    display: block;
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .result-box.primary .result-value {
    color: var(--accent-color);
    font-size: 2.5rem;
  }

  /* Educational & FAQ styles reusing existing typography variables */
  .educational-content {
    margin-top: 3rem;
  }

  .educational-content code {
    display: block;
    padding: 1rem;
    margin: 1rem 0;
  }

  .faq-section {
    margin-top: 3rem;
  }

  .faq-item {
    margin-bottom: 1rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.5rem;
  }

  .faq-item summary {
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 1.5rem;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent-color);
    font-size: 1.5rem;
    line-height: 1;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    margin-top: 1rem;
    margin-bottom: 0;
  }
</style>

<script>
  function initCalculator() {
    const calcContainer = document.querySelector('.calculator-container');
    if (!calcContainer || calcContainer.dataset.initialized) return;

    const currentAgeInput = document.getElementById('currentAge');
    const retirementAgeInput = document.getElementById('retirementAge');
    const currentBalanceInput = document.getElementById('currentBalance');
    const annualContributionInput = document.getElementById('annualContribution');
    const expectedReturnInput = document.getElementById('expectedReturn');

    const futureBalanceDisplay = document.getElementById('futureBalance');
    const totalContributionsDisplay = document.getElementById('totalContributions');
    const totalEarningsDisplay = document.getElementById('totalEarnings');

    if (!currentAgeInput || !retirementAgeInput || !currentBalanceInput ||
        !annualContributionInput || !expectedReturnInput ||
        !futureBalanceDisplay || !totalContributionsDisplay || !totalEarningsDisplay) {
      return;
    }

    const formatCurrency = (value) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(value);
    };

    const calculate = () => {
      const currentAge = parseInt(currentAgeInput.value) || 0;
      const retirementAge = parseInt(retirementAgeInput.value) || 0;
      const currentBalance = parseFloat(currentBalanceInput.value) || 0;
      const annualContribution = parseFloat(annualContributionInput.value) || 0;
      const expectedReturn = parseFloat(expectedReturnInput.value) || 0;

      // Handle edge cases
      if (retirementAge <= currentAge) {
        futureBalanceDisplay.textContent = formatCurrency(currentBalance);
        totalContributionsDisplay.textContent = formatCurrency(currentBalance);
        totalEarningsDisplay.textContent = formatCurrency(0);
        return;
      }

      const yearsToGrow = retirementAge - currentAge;
      const r = expectedReturn / 100;

      let futureBalance = 0;
      let totalContributions = currentBalance + (annualContribution * yearsToGrow);

      if (r === 0) {
        futureBalance = totalContributions;
      } else {
        // Compound interest on principal
        const principalGrowth = currentBalance * Math.pow(1 + r, yearsToGrow);

        // Future value of an annuity (annual contributions)
        // Assuming contributions are made at the end of the year
        const contributionGrowth = annualContribution * ((Math.pow(1 + r, yearsToGrow) - 1) / r);

        futureBalance = principalGrowth + contributionGrowth;
      }

      const totalEarnings = futureBalance - totalContributions;

      futureBalanceDisplay.textContent = formatCurrency(futureBalance);
      totalContributionsDisplay.textContent = formatCurrency(totalContributions);
      totalEarningsDisplay.textContent = formatCurrency(Math.max(0, totalEarnings));
    };

    // Attach event listeners
    [currentAgeInput, retirementAgeInput, currentBalanceInput,
     annualContributionInput, expectedReturnInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
    calcContainer.dataset.initialized = 'true';
  }

  // Handle both initial load and Astro view transitions
  document.addEventListener('DOMContentLoaded', initCalculator);
  document.addEventListener('astro:page-load', initCalculator);
</script>