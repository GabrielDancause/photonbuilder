---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Roth IRA Calculator: Contribution & Growth Estimator (2026)",
  description: "Free Roth IRA calculator with Roth vs Traditional IRA comparison, growth projections, income eligibility checker, and 2026 contribution limits. See which IRA wins for you.",
  category: "tool",
  published: "2026-03-21"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "datePublished": meta.published,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/roth-ira-calculator"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a Roth IRA and how does it work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A Roth IRA is an individual retirement account where you contribute after-tax dollars. Your investments grow tax-free, and qualified withdrawals in retirement are completely tax-free. Unlike a Traditional IRA, you don't get a tax deduction on contributions, but you never pay taxes on the growth or withdrawals after age 59½ (as long as the account has been open for at least 5 years)."
          }
        },
        {
          "@type": "Question",
          "name": "What are the Roth IRA contribution limits for 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For 2026, the Roth IRA contribution limit is $7,000 per year if you are under age 50, and $8,000 per year if you are age 50 or older (the extra $1,000 is a catch-up contribution). These limits apply to your total combined contributions across all Traditional and Roth IRAs."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Roth IRA income limit for 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For 2026, single filers can contribute the full amount if their modified adjusted gross income (MAGI) is below $150,000. Contributions phase out between $150,000 and $165,000. For married filing jointly, full contributions are allowed below $236,000, with phase-out between $236,000 and $246,000."
          }
        },
        {
          "@type": "Question",
          "name": "Roth IRA vs Traditional IRA: which is better?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A Roth IRA is generally better if you expect your tax rate to be higher in retirement than it is now, which is common for younger earners. A Traditional IRA is better if you expect to be in a lower tax bracket in retirement. The Roth also has advantages like no required minimum distributions (RMDs), tax-free withdrawals, and the ability to withdraw contributions at any time without penalty."
          }
        },
        {
          "@type": "Question",
          "name": "What is a backdoor Roth IRA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A backdoor Roth IRA is a strategy for high-income earners who exceed the Roth IRA income limits. You contribute to a Traditional IRA (non-deductible) and then convert those funds to a Roth IRA. There is no income limit on Roth conversions. Be aware of the pro-rata rule if you have existing pre-tax IRA balances, as this can create a partial tax liability on the conversion."
          }
        },
        {
          "@type": "Question",
          "name": "Can I withdraw from my Roth IRA early?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can withdraw your original contributions (not earnings) from a Roth IRA at any time, at any age, without taxes or penalties. Earnings withdrawn before age 59½ may be subject to income tax and a 10% early withdrawal penalty unless you qualify for an exception (first-time home purchase up to $10,000, disability, etc.)."
          }
        },
        {
          "@type": "Question",
          "name": "How much will my Roth IRA be worth at retirement?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The final value depends on your contribution amount, years until retirement, and investment returns. For example, contributing $7,000 per year for 35 years at a 7% return would grow to approximately $1,030,000—all tax-free in retirement. Starting early and contributing consistently are the two biggest factors in Roth IRA growth."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/roth-ira-calculator"
  schema={schema}
>
  <div class="page-content">

    <div style="text-align: center; margin-bottom: 2rem;">
      <h1>Roth IRA Calculator</h1>
      <p style="font-size: 1.2rem; max-width: 650px; margin: 0 auto;">Estimate your Roth IRA growth, compare Roth vs Traditional IRA after taxes, and check your 2026 contribution eligibility.</p>
    </div>

    <div class="stats-grid" style="margin-bottom: 2rem;">
      <div class="stat-card">
        <span class="calc-result-label">Roth After-Tax Value</span>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--accent-color);" id="stat-roth">$0</div>
      </div>
      <div class="stat-card">
        <span class="calc-result-label">Traditional After-Tax Value</span>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary);" id="stat-trad">$0</div>
      </div>
      <div class="stat-card">
        <span class="calc-result-label">Total Contributions</span>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary);" id="stat-contributions">$0</div>
      </div>
      <div class="stat-card">
        <span class="calc-result-label">Roth Advantage</span>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--accent-color);" id="stat-advantage">$0</div>
      </div>
    </div>

    <div class="calculator-card">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">

        <div class="input-group">
          <label for="current-age">Current Age</label>
          <div class="input-wrapper">
            <input type="number" id="current-age" value="30" min="18" max="80" step="1">
            <span class="suffix">yrs</span>
          </div>
        </div>

        <div class="input-group">
          <label for="retirement-age">Retirement Age</label>
          <div class="input-wrapper">
            <input type="number" id="retirement-age" value="65" min="30" max="85" step="1">
            <span class="suffix">yrs</span>
          </div>
        </div>

        <div class="input-group">
          <label for="annual-contribution">Annual Contribution</label>
          <div class="input-wrapper">
            <span style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
            <input type="number" id="annual-contribution" value="7000" min="0" max="8000" step="100" style="padding-left: 2rem;">
          </div>
          <small style="color: var(--text-secondary); font-size: 0.8rem; margin-top: 0.25rem; display: block;" id="contrib-limit-note">2026 limit: $7,000 (under 50) · $8,000 (50+)</small>
        </div>

        <div class="input-group">
          <label for="current-balance">Current IRA Balance</label>
          <div class="input-wrapper">
            <span style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
            <input type="number" id="current-balance" value="15000" min="0" step="1000" style="padding-left: 2rem;">
          </div>
        </div>

        <div class="input-group">
          <label for="expected-return">Expected Annual Return</label>
          <div class="input-wrapper">
            <input type="number" id="expected-return" value="7" min="0" max="15" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="current-tax-rate">Current Tax Bracket</label>
          <div class="input-wrapper">
            <input type="number" id="current-tax-rate" value="24" min="0" max="50" step="1">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="retirement-tax-rate">Retirement Tax Bracket</label>
          <div class="input-wrapper">
            <input type="number" id="retirement-tax-rate" value="20" min="0" max="50" step="1">
            <span class="suffix">%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Roth vs Traditional Comparison -->
    <div class="chart-container" style="margin-top: 2rem;">
      <h3 style="margin-top: 0; margin-bottom: 1rem;">Roth vs Traditional IRA Growth</h3>
      <div style="position: relative; height: 350px; margin-bottom: 1.5rem;">
        <canvas id="growthChart"></canvas>
      </div>

      <div class="comparison-table">
        <div class="table-container">
          <table id="comparisonTable">
            <thead>
              <tr>
                <th style="text-align: left;"></th>
                <th style="color: var(--accent-color);">Roth IRA</th>
                <th>Traditional IRA</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td style="text-align: left;">Pre-Tax Value at Retirement</td>
                <td id="comp-roth-pretax">$0</td>
                <td id="comp-trad-pretax">$0</td>
              </tr>
              <tr>
                <td style="text-align: left;">Taxes Owed at Withdrawal</td>
                <td id="comp-roth-tax">$0</td>
                <td id="comp-trad-tax">$0</td>
              </tr>
              <tr>
                <td style="text-align: left;">After-Tax Value</td>
                <td id="comp-roth-after" style="font-weight: 700;">$0</td>
                <td id="comp-trad-after" style="font-weight: 700;">$0</td>
              </tr>
              <tr>
                <td style="text-align: left;">Annual Tax Savings</td>
                <td id="comp-roth-savings">$0</td>
                <td id="comp-trad-savings">$0</td>
              </tr>
              <tr>
                <td style="text-align: left;">Effective Cost of Contributions</td>
                <td id="comp-roth-cost">$0</td>
                <td id="comp-trad-cost">$0</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div id="verdict-box" style="padding: 1rem; border-radius: 8px; margin-top: 1rem; border: 1px solid var(--border-color); background: var(--card-bg);">
        <div style="font-weight: 600; margin-bottom: 0.25rem; color: var(--accent-color);" id="verdict-title">Calculating...</div>
        <p style="color: var(--text-secondary); margin: 0; line-height: 1.6;" id="verdict-desc">Enter your details to see the comparison.</p>
      </div>
    </div>

    <!-- Growth Schedule Table -->
    <div class="chart-container" style="margin-top: 2rem;">
      <h3 style="margin-top: 0; margin-bottom: 1rem;">Year-by-Year Breakdown</h3>
      <div class="table-container" style="max-height: 400px; overflow-y: auto;">
        <table id="scheduleTable">
          <thead style="position: sticky; top: 0; z-index: 1;">
            <tr>
              <th>Age</th>
              <th>Contribution</th>
              <th>Roth Value</th>
              <th>Traditional (After-Tax)</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <!-- Income Eligibility Checker -->
    <div class="calculator-card" style="margin-top: 2rem;">
      <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Roth IRA Income Eligibility Checker</h3>
      <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">Check if your income qualifies for direct Roth IRA contributions in 2026.</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; align-items: start;">
        <div>
          <div class="input-group">
            <label for="filing-status">Filing Status</label>
            <select id="filing-status" style="width: 100%; padding: 0.75rem; background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 6px; color: var(--text-primary); font-size: 1rem;">
              <option value="single">Single / Head of Household</option>
              <option value="married">Married Filing Jointly</option>
              <option value="married-separate">Married Filing Separately</option>
            </select>
          </div>
          <div class="input-group">
            <label for="magi-input">Modified Adjusted Gross Income (MAGI)</label>
            <div class="input-wrapper">
              <span style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
              <input type="number" id="magi-input" value="100000" min="0" step="1000" style="padding-left: 2rem;">
            </div>
          </div>
        </div>
        <div id="elig-result" style="padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-color);">
          <div style="font-weight: 600; margin-bottom: 0.25rem; color: var(--text-primary);" id="elig-title">Full Contribution Allowed</div>
          <p style="color: var(--text-secondary); margin: 0 0 0.5rem 0; font-size: 0.95rem; line-height: 1.5;" id="elig-desc">Your MAGI is below the phase-out range.</p>
          <div id="elig-amount" style="font-weight: 600; color: var(--accent-color);"></div>
        </div>
      </div>
    </div>

    <!-- 2026 Contribution Limits Table -->
    <div class="chart-container" style="margin-top: 2rem;">
      <h3 style="margin-top: 0; margin-bottom: 1rem;">Roth IRA Contribution Limits by Year</h3>
      <p style="color: var(--text-secondary); margin-bottom: 1rem;">IRA contribution limits are set by the IRS and adjusted periodically for inflation.</p>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Tax Year</th>
              <th>Under 50 Limit</th>
              <th>50+ Catch-Up</th>
              <th>Single Phase-Out</th>
              <th>Married (Joint) Phase-Out</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>2026</strong></td><td>$7,000</td><td>$8,000</td><td>$150,000 – $165,000</td><td>$236,000 – $246,000</td></tr>
            <tr><td>2025</td><td>$7,000</td><td>$8,000</td><td>$150,000 – $165,000</td><td>$236,000 – $246,000</td></tr>
            <tr><td>2024</td><td>$7,000</td><td>$8,000</td><td>$146,000 – $161,000</td><td>$230,000 – $240,000</td></tr>
            <tr><td>2023</td><td>$6,500</td><td>$7,500</td><td>$138,000 – $153,000</td><td>$218,000 – $228,000</td></tr>
            <tr><td>2022</td><td>$6,000</td><td>$7,000</td><td>$129,000 – $144,000</td><td>$204,000 – $214,000</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

    <script is:inline>
      const fmt = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);

      let growthChart;

      function initChart() {
        const ctx = document.getElementById('growthChart').getContext('2d');
        growthChart = new Chart(ctx, {
          type: 'line',
          data: {
            labels: [],
            datasets: [
              {
                label: 'Roth IRA (Tax-Free)',
                data: [],
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.08)',
                fill: true,
                tension: 0.3,
                borderWidth: 2.5,
                pointRadius: 0,
                pointHitRadius: 10
              },
              {
                label: 'Traditional IRA (After-Tax)',
                data: [],
                borderColor: '#f59e0b',
                backgroundColor: 'rgba(245, 158, 11, 0.08)',
                fill: true,
                tension: 0.3,
                borderWidth: 2.5,
                pointRadius: 0,
                pointHitRadius: 10
              },
              {
                label: 'Total Contributions',
                data: [],
                borderColor: 'rgba(150, 150, 150, 0.5)',
                backgroundColor: 'transparent',
                borderDash: [6, 3],
                tension: 0,
                borderWidth: 1.5,
                pointRadius: 0,
                pointHitRadius: 10
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: {
                position: 'bottom',
                labels: { padding: 16, usePointStyle: true, pointStyle: 'line' }
              },
              tooltip: {
                callbacks: {
                  label: function(context) {
                    return context.dataset.label + ': ' + fmt(context.parsed.y);
                  }
                }
              }
            },
            scales: {
              x: {
                grid: { color: 'rgba(150,150,150,0.1)' },
                title: { display: true, text: 'Age' }
              },
              y: {
                grid: { color: 'rgba(150,150,150,0.1)' },
                ticks: {
                  callback: function(value) {
                    if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                    if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'K';
                    return '$' + value;
                  }
                }
              }
            }
          }
        });
      }

      function calculate() {
        const currentAge = Math.max(18, Math.min(80, parseInt(document.getElementById('current-age').value) || 30));
        const retirementAge = Math.max(currentAge + 1, Math.min(85, parseInt(document.getElementById('retirement-age').value) || 65));
        const annualContribution = Math.max(0, parseFloat(document.getElementById('annual-contribution').value) || 0);
        const currentBalance = Math.max(0, parseFloat(document.getElementById('current-balance').value) || 0);
        const expectedReturn = (parseFloat(document.getElementById('expected-return').value) || 7) / 100;
        const currentTaxRate = (parseFloat(document.getElementById('current-tax-rate').value) || 24) / 100;
        const retirementTaxRate = (parseFloat(document.getElementById('retirement-tax-rate').value) || 20) / 100;

        const years = retirementAge - currentAge;

        const labels = [];
        const rothData = [];
        const tradData = [];
        const contribData = [];

        let rothBalance = currentBalance;
        let tradBalance = currentBalance;
        let totalContributions = currentBalance;

        labels.push(currentAge);
        rothData.push(rothBalance);
        tradData.push(tradBalance * (1 - retirementTaxRate));
        contribData.push(totalContributions);

        const tbody = document.querySelector('#scheduleTable tbody');
        let tableHtml = '';

        for (let y = 1; y <= years; y++) {
          const age = currentAge + y;
          const contribLimit = age >= 50 ? 8000 : 7000;
          const yearContrib = Math.min(annualContribution, contribLimit);

          rothBalance = (rothBalance + yearContrib) * (1 + expectedReturn);
          tradBalance = (tradBalance + yearContrib) * (1 + expectedReturn);
          totalContributions += yearContrib;

          labels.push(age);
          rothData.push(rothBalance);
          tradData.push(tradBalance * (1 - retirementTaxRate));
          contribData.push(totalContributions);

          if (y % 5 === 0 || y === years) {
            tableHtml += '<tr>' +
              '<td>' + age + '</td>' +
              '<td>' + fmt(totalContributions) + '</td>' +
              '<td style="color: var(--accent-color); font-weight: 600;">' + fmt(rothBalance) + '</td>' +
              '<td>' + fmt(tradBalance * (1 - retirementTaxRate)) + '</td>' +
              '</tr>';
          }
        }

        tbody.innerHTML = tableHtml;

        // Final values
        const rothFinal = rothBalance;
        const tradFinalPreTax = tradBalance;
        const tradTax = tradBalance * retirementTaxRate;
        const tradFinalAfterTax = tradBalance - tradTax;
        const rothAdvantage = rothFinal - tradFinalAfterTax;

        // Stats
        document.getElementById('stat-roth').textContent = fmt(rothFinal);
        document.getElementById('stat-trad').textContent = fmt(tradFinalAfterTax);
        document.getElementById('stat-contributions').textContent = fmt(totalContributions);
        const advEl = document.getElementById('stat-advantage');
        advEl.textContent = (rothAdvantage >= 0 ? '+' : '') + fmt(rothAdvantage);
        advEl.style.color = rothAdvantage >= 0 ? '#10b981' : '#f59e0b';

        // Comparison table
        document.getElementById('comp-roth-pretax').textContent = fmt(rothFinal);
        document.getElementById('comp-trad-pretax').textContent = fmt(tradFinalPreTax);
        document.getElementById('comp-roth-tax').textContent = '$0 (tax-free)';
        document.getElementById('comp-trad-tax').textContent = fmt(tradTax);

        const rothAfterEl = document.getElementById('comp-roth-after');
        const tradAfterEl = document.getElementById('comp-trad-after');
        rothAfterEl.innerHTML = fmt(rothFinal) + (rothAdvantage > 0 ? ' <span style="background: rgba(16,185,129,0.15); color: #10b981; padding: 0.1rem 0.4rem; border-radius: 4px; font-size: 0.75rem; font-weight: 700; margin-left: 0.4rem;">BETTER</span>' : '');
        tradAfterEl.innerHTML = fmt(tradFinalAfterTax) + (rothAdvantage < 0 ? ' <span style="background: rgba(245,158,11,0.15); color: #f59e0b; padding: 0.1rem 0.4rem; border-radius: 4px; font-size: 0.75rem; font-weight: 700; margin-left: 0.4rem;">BETTER</span>' : '');

        document.getElementById('comp-roth-savings').textContent = '$0 (post-tax dollars)';
        document.getElementById('comp-trad-savings').textContent = fmt(annualContribution * currentTaxRate) + '/yr';
        document.getElementById('comp-roth-cost').textContent = fmt(annualContribution) + '/yr';
        document.getElementById('comp-trad-cost').textContent = fmt(annualContribution * (1 - currentTaxRate)) + '/yr';

        // Verdict
        const verdictTitle = document.getElementById('verdict-title');
        const verdictDesc = document.getElementById('verdict-desc');
        const verdictBox = document.getElementById('verdict-box');

        if (rothAdvantage > 0) {
          verdictBox.style.borderColor = '#10b981';
          verdictTitle.style.color = '#10b981';
          verdictTitle.textContent = 'Roth IRA wins by ' + fmt(rothAdvantage);
          verdictDesc.textContent = 'With your current tax rate (' + (currentTaxRate * 100).toFixed(0) + '%) higher than your expected retirement rate (' + (retirementTaxRate * 100).toFixed(0) + '%), the Roth IRA comes out ahead. You pay taxes now at the lower effective rate and withdraw everything tax-free.';
        } else if (rothAdvantage < 0) {
          verdictBox.style.borderColor = '#f59e0b';
          verdictTitle.style.color = '#f59e0b';
          verdictTitle.textContent = 'Traditional IRA wins by ' + fmt(Math.abs(rothAdvantage));
          verdictDesc.textContent = 'With your expected retirement tax rate (' + (retirementTaxRate * 100).toFixed(0) + '%) higher than your current rate (' + (currentTaxRate * 100).toFixed(0) + '%), the Traditional IRA\'s upfront deduction provides more value. Consider a Traditional IRA or a mix of both.';
        } else {
          verdictBox.style.borderColor = 'var(--accent-color)';
          verdictTitle.style.color = 'var(--accent-color)';
          verdictTitle.textContent = 'It\'s a tie!';
          verdictDesc.textContent = 'With equal current and retirement tax rates, both accounts produce the same after-tax result. The Roth still offers advantages like no RMDs and tax-free withdrawal flexibility.';
        }

        // Chart
        if (growthChart) {
          growthChart.data.labels = labels;
          growthChart.data.datasets[0].data = rothData;
          growthChart.data.datasets[1].data = tradData;
          growthChart.data.datasets[2].data = contribData;
          growthChart.update();
        }
      }

      function checkEligibility() {
        const status = document.getElementById('filing-status').value;
        const magi = parseFloat(document.getElementById('magi-input').value) || 0;
        const currentAge = parseInt(document.getElementById('current-age').value) || 30;
        const maxContrib = currentAge >= 50 ? 8000 : 7000;

        let lower, upper;
        if (status === 'single') { lower = 150000; upper = 165000; }
        else if (status === 'married') { lower = 236000; upper = 246000; }
        else { lower = 0; upper = 10000; }

        const eligResult = document.getElementById('elig-result');
        const eligTitle = document.getElementById('elig-title');
        const eligDesc = document.getElementById('elig-desc');
        const eligAmount = document.getElementById('elig-amount');

        if (status === 'married-separate') {
          if (magi <= 0) {
            eligResult.style.borderColor = '#10b981';
            eligTitle.style.color = '#10b981';
            eligTitle.textContent = 'Full Contribution Allowed';
            eligDesc.textContent = 'Married filing separately with $0 MAGI can contribute the full amount.';
            eligAmount.textContent = 'Max contribution: ' + fmt(maxContrib);
          } else if (magi < upper) {
            eligResult.style.borderColor = '#f59e0b';
            eligTitle.style.color = '#f59e0b';
            const reducedLimit = Math.max(0, Math.floor(maxContrib * (1 - magi / upper)));
            eligTitle.textContent = 'Reduced Contribution';
            eligDesc.textContent = 'Married filing separately have a very low phase-out range ($0 – $10,000). Your contribution is reduced.';
            eligAmount.textContent = 'Estimated max contribution: ' + fmt(reducedLimit);
          } else {
            eligResult.style.borderColor = '#ef4444';
            eligTitle.style.color = '#ef4444';
            eligTitle.textContent = 'Not Eligible for Direct Contribution';
            eligDesc.textContent = 'Your MAGI exceeds the $10,000 limit for married filing separately. Consider a backdoor Roth IRA strategy.';
            eligAmount.textContent = '';
          }
        } else if (magi < lower) {
          eligResult.style.borderColor = '#10b981';
          eligTitle.style.color = '#10b981';
          eligTitle.textContent = 'Full Contribution Allowed';
          eligDesc.textContent = 'Your MAGI of ' + fmt(magi) + ' is below the ' + fmt(lower) + ' phase-out threshold. You can contribute the full amount.';
          eligAmount.textContent = 'Max contribution: ' + fmt(maxContrib);
        } else if (magi < upper) {
          eligResult.style.borderColor = '#f59e0b';
          eligTitle.style.color = '#f59e0b';
          const phaseOutRange = upper - lower;
          const amountOver = magi - lower;
          const reductionFraction = amountOver / phaseOutRange;
          const reducedLimit = Math.max(0, Math.round((maxContrib * (1 - reductionFraction)) / 10) * 10);
          eligTitle.textContent = 'Reduced Contribution (Phase-Out)';
          eligDesc.textContent = 'Your MAGI of ' + fmt(magi) + ' falls within the phase-out range (' + fmt(lower) + ' – ' + fmt(upper) + '). Your contribution is reduced.';
          eligAmount.textContent = 'Estimated max contribution: ' + fmt(reducedLimit);
        } else {
          eligResult.style.borderColor = '#ef4444';
          eligTitle.style.color = '#ef4444';
          eligTitle.textContent = 'Not Eligible for Direct Contribution';
          eligDesc.textContent = 'Your MAGI of ' + fmt(magi) + ' exceeds the ' + fmt(upper) + ' limit. You cannot contribute directly but can use the backdoor Roth strategy below.';
          eligAmount.textContent = '';
        }
      }

