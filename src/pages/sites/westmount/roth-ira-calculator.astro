---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Roth IRA Calculator: Contribution & Growth Estimator",
      "description": "Free Roth IRA calculator with Roth vs Traditional IRA comparison, growth projections, income eligibility checker, and contribution limits for 2024-2026.",
      "datePublished": "2026-03-21",
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Research",
        "url": "https://westmountfundamentals.com"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a Roth IRA and how does it work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A Roth IRA is an individual retirement account where you contribute after-tax dollars. Your investments grow tax-free, and qualified withdrawals in retirement are completely tax-free. Unlike a Traditional IRA, you don't get a tax deduction on contributions, but you never pay taxes on the growth or withdrawals after age 59½ (as long as the account has been open for at least 5 years)."
          }
        },
        {
          "@type": "Question",
          "name": "What are the Roth IRA contribution limits for 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For 2026, the Roth IRA contribution limit is $7,000 per year if you are under age 50, and $8,000 per year if you are age 50 or older (the extra $1,000 is a catch-up contribution). These limits apply to your total combined contributions across all Traditional and Roth IRAs."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Roth IRA income limit for 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For 2026, single filers can contribute the full amount if their modified adjusted gross income (MAGI) is below $150,000. Contributions phase out between $150,000 and $165,000. For married filing jointly, full contributions are allowed below $236,000, with phase-out between $236,000 and $246,000. Above these limits, you cannot contribute directly but may use a backdoor Roth strategy."
          }
        },
        {
          "@type": "Question",
          "name": "Roth IRA vs Traditional IRA: which is better?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A Roth IRA is generally better if you expect your tax rate to be higher in retirement than it is now, which is common for younger earners. A Traditional IRA is better if you expect to be in a lower tax bracket in retirement. The Roth also has advantages like no required minimum distributions (RMDs), tax-free withdrawals, and the ability to withdraw contributions (not earnings) at any time without penalty."
          }
        },
        {
          "@type": "Question",
          "name": "What is a backdoor Roth IRA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A backdoor Roth IRA is a strategy for high-income earners who exceed the Roth IRA income limits. You contribute to a Traditional IRA (non-deductible) and then convert those funds to a Roth IRA. There is no income limit on Roth conversions. Be aware of the pro-rata rule if you have existing pre-tax IRA balances, as this can create a partial tax liability on the conversion."
          }
        },
        {
          "@type": "Question",
          "name": "Can I withdraw from my Roth IRA early?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can withdraw your original contributions (not earnings) from a Roth IRA at any time, at any age, without taxes or penalties. Earnings withdrawn before age 59½ may be subject to income tax and a 10% early withdrawal penalty unless you qualify for an exception (first-time home purchase up to $10,000, disability, etc.)."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Roth IRA Calculator: Contribution & Growth Estimator",
  description: "Free Roth IRA calculator with Roth vs Traditional IRA comparison, growth projections, income eligibility checker, and contribution limits for 2024-2026.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="Roth IRA Calculator: Contribution & Growth Estimator"
  description="Free Roth IRA calculator with Roth vs Traditional IRA comparison, growth projections, income eligibility checker, and contribution limits for 2024-2026."
  canonical="https://westmountfundamentals.com/roth-ira-calculator" schema={schema}
>
  <style>
:root {
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
}

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
        }

        nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(6, 10, 18, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-brand {
            font-weight: 700;
            color: #fff;
            text-decoration: none;
            font-size: 1.25rem;
            letter-spacing: -0.5px;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            margin-left: 1.5rem;
            font-size: 0.95rem;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: #fff;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        h1 {
            font-size: 2.5rem;
            background: linear-gradient(90deg, var(--accent-color), #8bb4f5);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
            margin-bottom: 0.5rem;
            font-weight: 700;
            letter-spacing: -1px;
        }

        .subtitle {
            text-align: center;
            color: var(--text-muted);
            margin-bottom: 3rem;
            font-size: 1.1rem;
        }

        h2 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: #fff;
            font-weight: 600;
        }

        h3 {
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        p {
            margin-bottom: 1rem;
            color: var(--text-muted);
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            text-align: center;
            margin-bottom: 0;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            color: #fff;
            margin-top: 0.5rem;
        }

        .stat-label {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .calc-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .input-group {
            margin-bottom: 1.25rem;
            position: relative;
        }

        .input-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-main);
            font-weight: 500;
            font-size: 0.95rem;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .currency-symbol {
            position: absolute;
            left: 1rem;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
        }

        .suffix-symbol {
            position: absolute;
            right: 1rem;
            color: var(--text-muted);
            font-family: 'JetBrains Mono', monospace;
        }

        input[type="number"], input[type="text"] {
            width: 100%;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: #fff;
            padding: 0.75rem 1rem 0.75rem 2rem;
            border-radius: 8px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 1rem;
            transition: border-color 0.2s;
        }

        input.no-prefix {
            padding-left: 1rem;
        }

        input.has-suffix {
            padding-right: 2.5rem;
        }

        input:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .calc-section-title {
            margin-top: 1.5rem;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border-color);
            color: var(--accent-color);
        }

        .results-panel {
            display: flex;
            flex-direction: column;
        }

        .chart-container {
            position: relative;
            height: 350px;
            width: 100%;
            margin-bottom: 1.5rem;
        }

        /* Comparison Table */
        .comparison-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 0;
            margin-top: 1rem;
        }

        .comp-header {
            padding: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
            border-bottom: 2px solid var(--border-color);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .comp-cell {
            padding: 0.75rem;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.95rem;
            color: var(--text-main);
        }

        .comp-cell.label-cell {
            color: var(--text-muted);
            font-weight: 500;
        }

        .comp-cell.roth-cell {
            color: #10b981;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
        }

        .comp-cell.trad-cell {
            color: #f59e0b;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
        }

        .winner-badge {
            display: inline-block;
            padding: 0.15rem 0.5rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-left: 0.5rem;
            vertical-align: middle;
        }

        .winner-badge.roth { background: rgba(16, 185, 129, 0.15); color: #10b981; }
        .winner-badge.trad { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }

        /* Eligibility */
        .eligibility-card {
            margin-top: 1.5rem;
        }

        .elig-result {
            padding: 1rem;
            border-radius: 8px;
            margin-top: 1rem;
            border: 1px solid var(--border-color);
            background: var(--bg-color);
        }

        .elig-result.full { border-color: var(--success); }
        .elig-result.partial { border-color: var(--warning); }
        .elig-result.none { border-color: var(--danger); }

        .elig-title {
            font-weight: 600;
            margin-bottom: 0.25rem;
            color: #fff;
        }

        .elig-desc {
            font-size: 0.9rem;
            margin-bottom: 0;
        }

        select {
            width: 100%;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: #fff;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            transition: border-color 0.2s;
            cursor: pointer;
        }

        select:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        /* Table */
        .table-container {
            overflow-x: auto;
            margin-bottom: 1.5rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th, td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            background: var(--bg-color);
            color: var(--text-muted);
            font-weight: 500;
            white-space: nowrap;
        }

        td {
            color: var(--text-main);
        }

        .table-row:hover td {
            background: rgba(74, 143, 231, 0.05);
        }

        /* Content Sections */
        .content-section {
            margin-bottom: 3rem;
        }

        .backdoor-steps {
            counter-reset: step;
            list-style: none;
            padding: 0;
            margin-top: 1rem;
        }

        .backdoor-steps li {
            counter-increment: step;
            padding: 1rem 1rem 1rem 3.5rem;
            position: relative;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
        }

        .backdoor-steps li:last-child {
            border-bottom: none;
        }

        .backdoor-steps li::before {
            content: counter(step);
            position: absolute;
            left: 1rem;
            top: 1rem;
            width: 1.75rem;
            height: 1.75rem;
            background: var(--accent-color);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .backdoor-steps li strong {
            color: #fff;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1.5rem 0;
        }

        .faq-item:last-child {
            border-bottom: none;
        }

        .faq-q {
            font-size: 1.1rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .related-links {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 1rem;
        }

        .related-link {
            display: inline-block;
            padding: 0.5rem 1rem;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--accent-color);
            text-decoration: none;
            font-size: 0.9rem;
            transition: border-color 0.2s, background 0.2s;
        }

        .related-link:hover {
            border-color: var(--accent-color);
            background: rgba(74, 143, 231, 0.1);
        }

        footer {
            border-top: 1px solid var(--border-color);
            padding: 3rem 2rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.875rem;
            margin-top: 4rem;
        }

        @media (max-width: 768px) {
            .calc-container {
                grid-template-columns: 1fr;
            }
            .nav-links {
                display: none;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            .comparison-grid {
                font-size: 0.85rem;
            }
            .comp-cell, .comp-header {
                padding: 0.5rem;
            }
            h1 {
                font-size: 1.75rem;
            }
        }
  </style>

<div class="container">
        <h1>Roth IRA Calculator</h1>
        <p class="subtitle">Estimate your Roth IRA growth, compare Roth vs Traditional IRA, and check your contribution eligibility.</p>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="card stat-card">
                <div class="stat-label">Roth After-Tax Value</div>
                <div class="stat-value" id="stat-roth">$0</div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">Traditional After-Tax Value</div>
                <div class="stat-value" id="stat-trad">$0</div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">Total Contributions</div>
                <div class="stat-value" id="stat-contributions">$0</div>
            </div>
            <div class="card stat-card">
                <div class="stat-label">Roth Advantage</div>
                <div class="stat-value" id="stat-advantage">$0</div>
            </div>
        </div>

        <!-- Calculator -->
        <div class="calc-container">
            <div class="card">
                <h2>Your Details</h2>

                <h3 class="calc-section-title">Personal Info</h3>
                <div class="input-group">
                    <label for="current-age">Current Age</label>
                    <div class="input-wrapper">
                        <input type="number" id="current-age" class="no-prefix" value="30" min="18" max="80" step="1">
                    </div>
                </div>
                <div class="input-group">
                    <label for="retirement-age">Retirement Age</label>
                    <div class="input-wrapper">
                        <input type="number" id="retirement-age" class="no-prefix" value="65" min="30" max="85" step="1">
                    </div>
                </div>

                <h3 class="calc-section-title">Contributions & Balance</h3>
                <div class="input-group">
                    <label for="annual-contribution">Annual Contribution ($)</label>
                    <div class="input-wrapper">
                        <span class="currency-symbol">$</span>
                        <input type="number" id="annual-contribution" value="7000" min="0" max="8000" step="100">
                    </div>
                    <small style="color: var(--text-muted); font-size: 0.8rem; margin-top: 0.25rem; display: block;" id="contrib-limit-note">Max: $7,000 (under 50) · $8,000 (50+)</small>
                </div>
                <div class="input-group">
                    <label for="current-balance">Current Roth IRA Balance ($)</label>
                    <div class="input-wrapper">
                        <span class="currency-symbol">$</span>
                        <input type="number" id="current-balance" value="15000" min="0" step="1000">
                    </div>
                </div>

                <h3 class="calc-section-title">Assumptions</h3>
                <div class="input-group">
                    <label for="expected-return">Expected Annual Return (%)</label>
                    <div class="input-wrapper">
                        <input type="number" id="expected-return" class="no-prefix has-suffix" value="7" min="0" max="15" step="0.5">
                        <span class="suffix-symbol">%</span>
                    </div>
                </div>
                <div class="input-group">
                    <label for="current-tax-rate">Current Marginal Tax Rate (%)</label>
                    <div class="input-wrapper">
                        <input type="number" id="current-tax-rate" class="no-prefix has-suffix" value="24" min="0" max="50" step="1">
                        <span class="suffix-symbol">%</span>
                    </div>
                </div>
                <div class="input-group">
                    <label for="retirement-tax-rate">Expected Retirement Tax Rate (%)</label>
                    <div class="input-wrapper">
                        <input type="number" id="retirement-tax-rate" class="no-prefix has-suffix" value="20" min="0" max="50" step="1">
                        <span class="suffix-symbol">%</span>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="card results-panel">
                <h2>Growth Projection: Roth vs Traditional</h2>
                <div class="chart-container">
                    <canvas id="growthChart"></canvas>
                </div>

                <div class="comparison-grid">
                    <div class="comp-header"></div>
                    <div class="comp-header" style="color: #10b981;">Roth IRA</div>
                    <div class="comp-header" style="color: #f59e0b;">Traditional IRA</div>

                    <div class="comp-cell label-cell">Pre-Tax Value at Retirement</div>
                    <div class="comp-cell roth-cell" id="comp-roth-pretax">$0</div>
                    <div class="comp-cell trad-cell" id="comp-trad-pretax">$0</div>

                    <div class="comp-cell label-cell">Taxes Owed at Withdrawal</div>
                    <div class="comp-cell roth-cell" id="comp-roth-tax">$0</div>
                    <div class="comp-cell trad-cell" id="comp-trad-tax">$0</div>

                    <div class="comp-cell label-cell">After-Tax Value</div>
                    <div class="comp-cell roth-cell" id="comp-roth-after">$0</div>
                    <div class="comp-cell trad-cell" id="comp-trad-after">$0</div>

                    <div class="comp-cell label-cell">Tax Savings Today (Annual)</div>
                    <div class="comp-cell roth-cell" id="comp-roth-savings">$0</div>
                    <div class="comp-cell trad-cell" id="comp-trad-savings">$0</div>

                    <div class="comp-cell label-cell">Effective Cost of Contributions</div>
                    <div class="comp-cell roth-cell" id="comp-roth-cost">$0</div>
                    <div class="comp-cell trad-cell" id="comp-trad-cost">$0</div>
                </div>

                <div id="verdict-box" style="padding: 1rem; border-radius: 8px; margin-top: 1rem; border: 1px solid var(--border-color); background: var(--bg-color);">
                    <div class="elig-title" id="verdict-title">Calculating...</div>
                    <p class="elig-desc" id="verdict-desc">Enter your details to see the comparison.</p>
                </div>
            </div>
        </div>

        <!-- Eligibility Checker -->
        <div class="content-section">
            <h2>Roth IRA Income Eligibility Checker</h2>
            <p>Enter your modified adjusted gross income (MAGI) and filing status to determine if you can contribute directly to a Roth IRA.</p>

            <div class="card">
                <div class="calc-container" style="margin-bottom: 0;">
                    <div>
                        <div class="input-group">
                            <label for="filing-status">Filing Status</label>
                            <select id="filing-status">
                                <option value="single">Single / Head of Household</option>
                                <option value="married">Married Filing Jointly</option>
                                <option value="married-separate">Married Filing Separately</option>
                            </select>
                        </div>
                        <div class="input-group">
                            <label for="magi-input">Modified Adjusted Gross Income (MAGI)</label>
                            <div class="input-wrapper">
                                <span class="currency-symbol">$</span>
                                <input type="number" id="magi-input" value="100000" min="0" step="1000">
                            </div>
                        </div>
                    </div>
                    <div>
                        <div id="elig-result" class="elig-result full">
                            <div class="elig-title" id="elig-title">Full Contribution Allowed</div>
                            <p class="elig-desc" id="elig-desc">Your MAGI is below the phase-out range. You can contribute the full $7,000 (or $8,000 if 50+) to a Roth IRA.</p>
                            <p class="elig-desc" id="elig-amount" style="font-family: 'JetBrains Mono', monospace; font-weight: 600; color: #10b981; margin-top: 0.5rem;"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contribution Limits Table -->
        <div class="content-section">
            <h2>Roth IRA Contribution Limits by Year</h2>
            <p>IRA contribution limits are set by the IRS and adjusted periodically for inflation. The table below shows recent limits for both regular and catch-up contributions.</p>

            <div class="card table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Tax Year</th>
                            <th>Under 50 Limit</th>
                            <th>50+ Limit (Catch-Up)</th>
                            <th>Single MAGI Phase-Out</th>
                            <th>Married (Joint) MAGI Phase-Out</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="table-row">
                            <td><strong>2026</strong></td>
                            <td>$7,000</td>
                            <td>$8,000</td>
                            <td>$150,000 – $165,000</td>
                            <td>$236,000 – $246,000</td>
                        </tr>
                        <tr class="table-row">
                            <td><strong>2025</strong></td>
                            <td>$7,000</td>
                            <td>$8,000</td>
                            <td>$150,000 – $165,000</td>
                            <td>$236,000 – $246,000</td>
                        </tr>
                        <tr class="table-row">
                            <td><strong>2024</strong></td>
                            <td>$7,000</td>
                            <td>$8,000</td>
                            <td>$146,000 – $161,000</td>
                            <td>$230,000 – $240,000</td>
                        </tr>
                        <tr class="table-row">
                            <td><strong>2023</strong></td>
                            <td>$6,500</td>
                            <td>$7,500</td>
                            <td>$138,000 – $153,000</td>
                            <td>$218,000 – $228,000</td>
                        </tr>
                        <tr class="table-row">
                            <td><strong>2022</strong></td>
                            <td>$6,000</td>
                            <td>$7,000</td>
                            <td>$129,000 – $144,000</td>
                            <td>$204,000 – $214,000</td>
                        </tr>
                        <tr class="table-row">
                            <td><strong>2021</strong></td>
                            <td>$6,000</td>
                            <td>$7,000</td>
                            <td>$125,000 – $140,000</td>
                            <td>$198,000 – $208,000</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Backdoor Roth -->
        <div class="content-section card">
            <h2>Backdoor Roth IRA: A Strategy for High Earners</h2>
            <p>If your income exceeds the Roth IRA contribution limits, a <strong>backdoor Roth IRA</strong> lets you get money into a Roth account through an indirect route. This strategy is perfectly legal and has been used by high-income earners for years.</p>

            <ol class="backdoor-steps">
                <li><strong>Contribute to a Traditional IRA.</strong> Make a non-deductible contribution to a Traditional IRA. There is no income limit for non-deductible Traditional IRA contributions.</li>
                <li><strong>Convert to Roth IRA.</strong> Shortly after the contribution settles, convert the Traditional IRA balance to your Roth IRA. There is no income limit on Roth conversions.</li>
                <li><strong>Pay taxes on any gains.</strong> If the funds gained value between the contribution and conversion (usually minimal if done quickly), you will owe taxes on that small gain.</li>
                <li><strong>Report on your tax return.</strong> File Form 8606 with your tax return to report the non-deductible contribution and the Roth conversion.</li>
            </ol>

            <div style="margin-top: 1.5rem; padding: 1rem; border-radius: 8px; border: 1px solid var(--warning); background: rgba(245, 158, 11, 0.05);">
                <div style="font-weight: 600; color: #f59e0b; margin-bottom: 0.5rem;">Pro-Rata Rule Warning</div>
                <p style="margin-bottom: 0; font-size: 0.95rem;">If you have existing pre-tax money in any Traditional, SEP, or SIMPLE IRA, the IRS applies the <strong>pro-rata rule</strong>. This means your conversion will be partially taxable based on the ratio of pre-tax to after-tax money across all your IRAs. To avoid this, consider rolling pre-tax IRA balances into a 401(k) before executing a backdoor Roth.</p>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="content-section card">
            <h2>Frequently Asked Questions</h2>

            <div class="faq-item">
                <div class="faq-q">What is a Roth IRA and how does it work?</div>
                <p>A Roth IRA is an individual retirement account where you contribute after-tax dollars. Your investments grow tax-free, and qualified withdrawals in retirement are completely tax-free. Unlike a Traditional IRA, you don't get a tax deduction on contributions, but you never pay taxes on the growth or withdrawals after age 59½ (as long as the account has been open for at least 5 years).</p>
            </div>

            <div class="faq-item">
                <div class="faq-q">What are the Roth IRA contribution limits for 2026?</div>
                <p>For 2026, the Roth IRA contribution limit is $7,000 per year if you are under age 50, and $8,000 per year if you are age 50 or older (the extra $1,000 is a catch-up contribution). These limits apply to your total combined contributions across all Traditional and Roth IRAs.</p>
            </div>

            <div class="faq-item">
                <div class="faq-q">What is the Roth IRA income limit for 2026?</div>
                <p>For 2026, single filers can contribute the full amount if their modified adjusted gross income (MAGI) is below $150,000. Contributions phase out between $150,000 and $165,000. For married filing jointly, full contributions are allowed below $236,000, with phase-out between $236,000 and $246,000. Above these limits, you cannot contribute directly but may use a backdoor Roth strategy.</p>
            </div>

            <div class="faq-item">
                <div class="faq-q">Roth IRA vs Traditional IRA: which is better?</div>
                <p>A Roth IRA is generally better if you expect your tax rate to be higher in retirement than it is now, which is common for younger earners. A Traditional IRA is better if you expect to be in a lower tax bracket in retirement. The Roth also has advantages like no required minimum distributions (RMDs), tax-free withdrawals, and the ability to withdraw contributions (not earnings) at any time without penalty.</p>
            </div>

            <div class="faq-item">
                <div class="faq-q">What is a backdoor Roth IRA?</div>
                <p>A backdoor Roth IRA is a strategy for high-income earners who exceed the Roth IRA income limits. You contribute to a Traditional IRA (non-deductible) and then convert those funds to a Roth IRA. There is no income limit on Roth conversions. Be aware of the pro-rata rule if you have existing pre-tax IRA balances, as this can create a partial tax liability on the conversion.</p>
            </div>

            <div class="faq-item">
                <div class="faq-q">Can I withdraw from my Roth IRA early?</div>
                <p>You can withdraw your original contributions (not earnings) from a Roth IRA at any time, at any age, without taxes or penalties. Earnings withdrawn before age 59½ may be subject to income tax and a 10% early withdrawal penalty unless you qualify for an exception (first-time home purchase up to $10,000, disability, etc.).</p>
            </div>
        </div>

        <!-- Related Tools -->
        <div class="content-section">
            <h2>Related Tools</h2>
            <div class="related-links">
                <a href="/sites/westmount/savings-calculator" class="related-link">Retirement Savings Calculator</a>
                <a href="/sites/westmount/guide-sp500-index-funds" class="related-link">Best Index Funds Guide</a>
                <a href="/sites/westmount/guide-roth-vs-traditional-ira" class="related-link">Roth vs Traditional IRA Guide</a>
                <a href="/sites/westmount/future-value-calculator" class="related-link">Future Value Calculator</a>
            </div>
        </div>
    </div>

  <script is:inline>
        const fmt = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);

        let growthChart;

        function initChart() {
            const ctx = document.getElementById('growthChart').getContext('2d');
            Chart.defaults.color = '#a0aec0';
            Chart.defaults.font.family = "'Inter', sans-serif";

            growthChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [
                        {
                            label: 'Roth IRA (After-Tax)',
                            data: [],
                            borderColor: '#10b981',
                            backgroundColor: 'rgba(16, 185, 129, 0.1)',
                            fill: true,
                            tension: 0.3,
                            borderWidth: 2.5,
                            pointRadius: 0,
                            pointHitRadius: 10
                        },
                        {
                            label: 'Traditional IRA (After-Tax)',
                            data: [],
                            borderColor: '#f59e0b',
                            backgroundColor: 'rgba(245, 158, 11, 0.1)',
                            fill: true,
                            tension: 0.3,
                            borderWidth: 2.5,
                            pointRadius: 0,
                            pointHitRadius: 10
                        },
                        {
                            label: 'Total Contributions',
                            data: [],
                            borderColor: '#4a8fe7',
                            backgroundColor: 'transparent',
                            borderDash: [6, 3],
                            tension: 0,
                            borderWidth: 1.5,
                            pointRadius: 0,
                            pointHitRadius: 10
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        intersect: false,
                        mode: 'index'
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { padding: 16, usePointStyle: true, pointStyle: 'line' }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + fmt(context.parsed.y);
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            title: { display: true, text: 'Age' }
                        },
                        y: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: {
                                callback: function(value) {
                                    if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                                    if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'K';
                                    return '$' + value;
                                }
                            }
                        }
                    }
                }
            });
        }

        function calculate() {
            const currentAge = parseInt(document.getElementById('current-age').value) || 30;
            const retirementAge = parseInt(document.getElementById('retirement-age').value) || 65;
            const annualContribution = parseFloat(document.getElementById('annual-contribution').value) || 0;
            const currentBalance = parseFloat(document.getElementById('current-balance').value) || 0;
            const expectedReturn = (parseFloat(document.getElementById('expected-return').value) || 7) / 100;
            const currentTaxRate = (parseFloat(document.getElementById('current-tax-rate').value) || 24) / 100;
            const retirementTaxRate = (parseFloat(document.getElementById('retirement-tax-rate').value) || 20) / 100;

            const years = Math.max(0, retirementAge - currentAge);

            // Build year-by-year data
            const labels = [];
            const rothData = [];
            const tradData = [];
            const contribData = [];

            let rothBalance = currentBalance;
            let tradBalance = currentBalance;
            let totalContributions = currentBalance;

            labels.push(currentAge);
            rothData.push(rothBalance);
            tradData.push(tradBalance * (1 - retirementTaxRate));
            contribData.push(totalContributions);

            for (let y = 1; y <= years; y++) {
                const age = currentAge + y;
                const contribLimit = age >= 50 ? 8000 : 7000;
                const yearContrib = Math.min(annualContribution, contribLimit);

                // Roth: contributions are after-tax, growth is tax-free
                rothBalance = (rothBalance + yearContrib) * (1 + expectedReturn);

                // Traditional: contributions are pre-tax (deductible), growth is tax-deferred
                tradBalance = (tradBalance + yearContrib) * (1 + expectedReturn);

                totalContributions += yearContrib;

                labels.push(age);
                rothData.push(rothBalance);
                tradData.push(tradBalance * (1 - retirementTaxRate));
                contribData.push(totalContributions);
            }

            // Final values
            const rothFinal = rothBalance;
            const tradFinalPreTax = tradBalance;
            const tradTax = tradBalance * retirementTaxRate;
            const tradFinalAfterTax = tradBalance - tradTax;

            const rothAdvantage = rothFinal - tradFinalAfterTax;

            // Update stats
            document.getElementById('stat-roth').innerText = fmt(rothFinal);
            document.getElementById('stat-trad').innerText = fmt(tradFinalAfterTax);
            document.getElementById('stat-contributions').innerText = fmt(totalContributions);
            document.getElementById('stat-advantage').innerText = (rothAdvantage >= 0 ? '+' : '') + fmt(rothAdvantage);
            document.getElementById('stat-advantage').style.color = rothAdvantage >= 0 ? '#10b981' : '#f59e0b';

            // Update comparison
            document.getElementById('comp-roth-pretax').innerText = fmt(rothFinal);
            document.getElementById('comp-trad-pretax').innerText = fmt(tradFinalPreTax);
            document.getElementById('comp-roth-tax').innerText = '$0';
            document.getElementById('comp-trad-tax').innerText = fmt(tradTax);
            document.getElementById('comp-roth-after').innerHTML = fmt(rothFinal) + (rothAdvantage >= 0 ? '<span class="winner-badge roth">BETTER</span>' : '');
            document.getElementById('comp-trad-after').innerHTML = fmt(tradFinalAfterTax) + (rothAdvantage < 0 ? '<span class="winner-badge trad">BETTER</span>' : '');

            const annualTaxSavingsRoth = 0;
            const annualTaxSavingsTrad = annualContribution * currentTaxRate;
            document.getElementById('comp-roth-savings').innerText = '$0 (post-tax $)';
            document.getElementById('comp-trad-savings').innerText = fmt(annualTaxSavingsTrad) + '/yr';

            const rothEffectiveCost = annualContribution;
            const tradEffectiveCost = annualContribution * (1 - currentTaxRate);
            document.getElementById('comp-roth-cost').innerText = fmt(rothEffectiveCost) + '/yr';
            document.getElementById('comp-trad-cost').innerText = fmt(tradEffectiveCost) + '/yr';

            // Verdict
            const verdictTitle = document.getElementById('verdict-title');
            const verdictDesc = document.getElementById('verdict-desc');
            const verdictBox = document.getElementById('verdict-box');

            if (rothAdvantage > 0) {
                verdictBox.style.borderColor = '#10b981';
                verdictTitle.style.color = '#10b981';
                verdictTitle.innerText = 'Roth IRA wins by ' + fmt(rothAdvantage);
                verdictDesc.innerText = 'With your current tax rate (' + (currentTaxRate * 100).toFixed(0) + '%) higher than your expected retirement rate (' + (retirementTaxRate * 100).toFixed(0) + '%), the Roth IRA comes out ahead because you\'re paying taxes now at a lower effective rate on withdrawals.';
            } else if (rothAdvantage < 0) {
                verdictBox.style.borderColor = '#f59e0b';
                verdictTitle.style.color = '#f59e0b';
                verdictTitle.innerText = 'Traditional IRA wins by ' + fmt(Math.abs(rothAdvantage));
                verdictDesc.innerText = 'With your expected retirement tax rate (' + (retirementTaxRate * 100).toFixed(0) + '%) higher than your current rate (' + (currentTaxRate * 100).toFixed(0) + '%), the Traditional IRA\'s upfront deduction provides more value. Consider a Traditional IRA or a mix of both.';
            } else {
                verdictBox.style.borderColor = 'var(--accent-color)';
                verdictTitle.style.color = 'var(--accent-color)';
                verdictTitle.innerText = 'It\'s a tie!';
                verdictDesc.innerText = 'With equal current and retirement tax rates, both accounts produce the same after-tax result. The Roth still offers benefits like no RMDs and tax-free withdrawal flexibility.';
            }

            // Update chart
            if (growthChart) {
                growthChart.data.labels = labels;
                growthChart.data.datasets[0].data = rothData;
                growthChart.data.datasets[1].data = tradData;
                growthChart.data.datasets[2].data = contribData;
                growthChart.update();
            }
        }

        // Eligibility checker
        function checkEligibility() {
            const status = document.getElementById('filing-status').value;
            const magi = parseFloat(document.getElementById('magi-input').value) || 0;

            let lower, upper;
            if (status === 'single') {
                lower = 150000;
                upper = 165000;
            } else if (status === 'married') {
                lower = 236000;
                upper = 246000;
            } else {
                lower = 0;
                upper = 10000;
            }

            const eligResult = document.getElementById('elig-result');
            const eligTitle = document.getElementById('elig-title');
            const eligDesc = document.getElementById('elig-desc');
            const eligAmount = document.getElementById('elig-amount');

            eligResult.className = 'elig-result';

            const currentAge = parseInt(document.getElementById('current-age').value) || 30;
            const maxContrib = currentAge >= 50 ? 8000 : 7000;

            if (status === 'married-separate') {
                if (magi <= 0) {
                    eligResult.classList.add('full');
                    eligTitle.innerText = 'Full Contribution Allowed';
                    eligDesc.innerText = 'Married filing separately with $0 MAGI can contribute the full amount.';
                    eligAmount.innerText = 'Max contribution: ' + fmt(maxContrib);
                } else if (magi < upper) {
                    eligResult.classList.add('partial');
                    const reducedLimit = Math.max(0, Math.floor(maxContrib * (1 - magi / upper)));
                    eligTitle.innerText = 'Reduced Contribution';
                    eligDesc.innerText = 'Married filing separately have a very low phase-out range ($0 – $10,000). Your contribution is reduced.';
                    eligAmount.innerText = 'Estimated max contribution: ' + fmt(reducedLimit);
                } else {
                    eligResult.classList.add('none');
                    eligTitle.innerText = 'Not Eligible for Direct Contribution';
                    eligDesc.innerText = 'Your MAGI exceeds the $10,000 limit for married filing separately. Consider a backdoor Roth IRA strategy (see below).';
                    eligAmount.innerText = '';
                }
            } else if (magi < lower) {
                eligResult.classList.add('full');
                eligTitle.innerText = 'Full Contribution Allowed';
                eligDesc.innerText = 'Your MAGI of ' + fmt(magi) + ' is below the ' + fmt(lower) + ' phase-out threshold. You can contribute the full amount to a Roth IRA.';
                eligAmount.innerText = 'Max contribution: ' + fmt(maxContrib);
            } else if (magi < upper) {
                eligResult.classList.add('partial');
                const phaseOutRange = upper - lower;
                const amountOver = magi - lower;
                const reductionFraction = amountOver / phaseOutRange;
                const reducedLimit = Math.max(0, Math.round((maxContrib * (1 - reductionFraction)) / 10) * 10);
                eligTitle.innerText = 'Reduced Contribution (Phase-Out)';
                eligDesc.innerText = 'Your MAGI of ' + fmt(magi) + ' falls within the phase-out range (' + fmt(lower) + ' – ' + fmt(upper) + '). Your maximum contribution is reduced.';
                eligAmount.innerText = 'Estimated max contribution: ' + fmt(reducedLimit);
            } else {
                eligResult.classList.add('none');
                eligTitle.innerText = 'Not Eligible for Direct Contribution';
                eligDesc.innerText = 'Your MAGI of ' + fmt(magi) + ' exceeds the ' + fmt(upper) + ' limit. You cannot contribute directly to a Roth IRA, but you can use the backdoor Roth strategy described below.';
                eligAmount.innerText = '';
            }
        }

        // Init
        document.addEventListener('DOMContentLoaded', () => {
            initChart();
            calculate();
            checkEligibility();

            // Calculator inputs
            const calcInputs = document.querySelectorAll('.calc-container input[type="number"]');
            calcInputs.forEach(input => {
                input.addEventListener('input', () => {
                    calculate();
                    checkEligibility();
                });
            });

            // Eligibility-specific inputs
            document.getElementById('filing-status').addEventListener('change', checkEligibility);
            document.getElementById('magi-input').addEventListener('input', checkEligibility);
        });
  </script>
</SiteLayout>
