    padding: 0.5rem 0.75rem;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 0.375rem;
    color: var(--text-primary);
    font-size: 1rem;
    transition: border-color 0.2s;
  }

  /* Add padding for prefix/suffix to prevent text overlap */
  .input-wrapper:has(.prefix) input {
    padding-left: 1.5rem;
  }

  .input-wrapper:has(.suffix) input {
    padding-right: 2.5rem;
  }

  .input-wrapper input:focus {
    outline: none;
    border-color: var(--accent-color);
  }

  .calc-actions {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .calc-btn {
    background-color: var(--accent-color);
    color: white;
    border: none;
    border-radius: 0.375rem;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .calc-btn:hover {
    opacity: 0.9;
  }

  .results-container {
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    padding: 1.5rem;
  }

  .result-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem;
    background-color: var(--card-bg);
    border-radius: 0.375rem;
    border: 1px solid var(--border-color);
  }

  .result-box.primary {
    margin-bottom: 1.5rem;
    border-color: var(--accent-color);
    background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
  }

  .result-box .label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .result-box .value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .result-box.primary .value {
    font-size: 2rem;
    color: var(--accent-color);
  }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .calc-insight {
    font-size: 0.875rem;
    font-style: italic;
    text-align: center;
    margin: 0;
    color: var(--text-secondary);
  }

  .faq-section {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .faq-item {
    margin-bottom: 1.5rem;
  }

  .faq-item h3 {
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .faq-item p {
    color: var(--text-secondary);
    margin: 0;
  }
</style>

<script>
  function initCalculator() {
    const btn = document.getElementById('calculate-fees-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const initialEl = document.getElementById('initial-investment');
      const annualEl = document.getElementById('annual-contribution');
      const yearsEl = document.getElementById('time-horizon');
      const returnRateEl = document.getElementById('gross-return');
      const pmFeeRateEl = document.getElementById('pm-fee');
      const diyFeeRateEl = document.getElementById('diy-fee');

      if (!initialEl || !annualEl || !yearsEl || !returnRateEl || !pmFeeRateEl || !diyFeeRateEl) return;

      const initial = parseFloat(initialEl.value);
      const annual = parseFloat(annualEl.value);
      const years = parseInt(yearsEl.value, 10);
      const returnRate = parseFloat(returnRateEl.value) / 100;
      const pmFeeRate = parseFloat(pmFeeRateEl.value) / 100;
      const diyFeeRate = parseFloat(diyFeeRateEl.value) / 100;

      if (isNaN(initial) || isNaN(annual) || isNaN(years) || isNaN(returnRate) || isNaN(pmFeeRate) || isNaN(diyFeeRate)) {
        alert("Please enter valid numbers for all fields.");
        return;
      }

      // Calculate future value function
      const calculateFV = (P, PMT, r, n) => {
        if (r === 0) return P + (PMT * n);
        return P * Math.pow(1 + r, n) + PMT * ((Math.pow(1 + r, n) - 1) / r);
      };

      // PM returns (Gross - PM Fee)
      const pmNetReturn = returnRate - pmFeeRate;
      const pmFV = calculateFV(initial, annual, pmNetReturn, years);

      // DIY returns (Gross - DIY Fee)
      const diyNetReturn = returnRate - diyFeeRate;
      const diyFV = calculateFV(initial, annual, diyNetReturn, years);

      const wealthLost = diyFV - pmFV;

      // Format currency
      const formatCurrency = (val) => {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
      };

      const pmPortfolioEl = document.getElementById('result-pm-portfolio');
      const diyPortfolioEl = document.getElementById('result-diy-portfolio');
      const wealthLostEl = document.getElementById('result-wealth-lost');
      const insightEl = document.getElementById('result-insight');

      if (pmPortfolioEl) pmPortfolioEl.textContent = formatCurrency(pmFV);
      if (diyPortfolioEl) diyPortfolioEl.textContent = formatCurrency(diyFV);
      if (wealthLostEl) wealthLostEl.textContent = formatCurrency(wealthLost);

      if (insightEl) {
        insightEl.textContent = `Over ${years} years, the ${((pmFeeRate - diyFeeRate)*100).toFixed(2)}% difference in fees cost you ${formatCurrency(wealthLost)} in lost compounding growth.`;
      }

      const resultsContainer = document.getElementById('fee-results');
      if (resultsContainer) resultsContainer.style.display = 'block';
    });
  }

  // Support Astro View Transitions
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for direct loads without view transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
