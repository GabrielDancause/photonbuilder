---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "S&P 500 Index: Live Tracker, Holdings & Sector Breakdown",
      "description": "Track the S&P 500 index with real-time stats, sector weights, top 25 holdings, and a historical returns calculator going back to 1990.",
      "datePublished": "2026-03-29",
      "dateModified": "2026-03-29",
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Research",
        "url": "https://westmountfundamentals.com"
      },
      "author": {
        "@type": "Organization",
        "name": "Westmount Research"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the S&P 500 index?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The S&P 500 is a stock market index that tracks the performance of 500 of the largest publicly traded companies in the United States. Maintained by S&P Dow Jones Indices, it is widely regarded as the single best gauge of the U.S. large-cap equity market and covers approximately 80% of available U.S. market capitalization. The index is market-cap weighted, meaning larger companies like Apple, Microsoft, and NVIDIA have a proportionally greater influence on the index's value."
          }
        },
        {
          "@type": "Question",
          "name": "How can I invest in the S&P 500?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The most common way to invest in the S&P 500 is through index funds or ETFs that track it. Popular options include the Vanguard S&P 500 ETF (VOO, 0.03% expense ratio), SPDR S&P 500 ETF Trust (SPY, 0.0945%), and iShares Core S&P 500 ETF (IVV, 0.03%). You can also invest via mutual funds like the Vanguard 500 Index Fund (VFIAX, 0.04%). These funds hold all 500 stocks in proportion to their index weight, giving you instant diversification for a very low cost."
          }
        },
        {
          "@type": "Question",
          "name": "What is the average annual return of the S&P 500?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "From 1990 through 2025, the S&P 500 has delivered an average annualized return (CAGR) of approximately 10.4% including dividends. However, returns vary enormously year to year — from -37% in 2008 to +32.4% in 2013. Over any given 20-year rolling period since 1926, the S&P 500 has never produced a negative total return, which is why long-term holding is generally recommended."
          }
        },
        {
          "@type": "Question",
          "name": "What are the 11 sectors in the S&P 500?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The S&P 500 is divided into 11 GICS (Global Industry Classification Standard) sectors: Information Technology (~32%), Financials (~13%), Health Care (~12%), Consumer Discretionary (~10%), Communication Services (~9%), Industrials (~8%), Consumer Staples (~6%), Energy (~4%), Utilities (~2.5%), Real Estate (~2.5%), and Materials (~2%). Technology has dominated the index in recent years due to the growth of mega-cap companies like Apple, Microsoft, and NVIDIA."
          }
        },
        {
          "@type": "Question",
          "name": "How often is the S&P 500 rebalanced?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The S&P 500 is rebalanced quarterly on the third Friday of March, June, September, and December. However, the S&P Index Committee can make changes at any time if a company no longer meets the inclusion criteria (e.g., due to a merger, acquisition, bankruptcy, or significant decline in market cap). To be included, a company must be a U.S. company, have a market cap of at least $18 billion (as of 2026), be highly liquid, have a public float of at least 50%, and have positive earnings in the most recent quarter and over the trailing four quarters."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "S&P 500 Index: Live Tracker, Holdings & Sector Breakdown",
  description: "Track the S&P 500 index with sector weights, top 25 holdings, and a historical returns calculator. Real data from 1990–2025.",
  category: "tool",
  published: "2026-03-29",
};
---

<SiteLayout
  site="westmount"
  title="S&P 500 Index: Live Tracker, Holdings & Sector Breakdown"
  description="Track the S&P 500 index with sector weights, top 25 holdings, and a historical returns calculator. Real data from 1990–2025."
  canonical="https://westmountfundamentals.com/sp500-index-tracker" schema={schema}
>
  <style is:inline>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',-apple-system,sans-serif;background:var(--bg,#060a12);color:var(--text,#c8d0de);line-height:1.6}
a{color:var(--accent,#4a8fe7);text-decoration:none}
a:hover{text-decoration:underline}

:root{--bg:#060a12;--bg2:#0a1020;--bg3:#0d1428;--border:#152040;--text:#c8d0de;--text2:#6a7a90;--text3:#4a5568;--text4:#3a4a60;--head:#e0e8f0;--accent:#4a8fe7;--green:#22c55e;--red:#ef4444;--yellow:#eab308;--mono:'JetBrains Mono',ui-monospace,monospace}

.header{text-align:center;padding:80px 24px 50px;background:linear-gradient(180deg,#0a1628 0%,var(--bg) 100%);position:relative}
.header::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 30%,rgba(74,143,231,0.06) 0%,transparent 60%)}
.header-inner{position:relative;z-index:1;max-width:720px;margin:0 auto}
.back{display:inline-block;color:var(--text3);font-size:.8rem;font-weight:600;margin-bottom:20px;letter-spacing:1px;text-transform:uppercase}
.tag{display:inline-block;background:rgba(74,143,231,0.12);color:var(--accent);font-size:.65rem;font-weight:800;padding:4px 14px;border-radius:20px;letter-spacing:1.5px;margin-bottom:16px}
h1{font-size:2.6rem;font-weight:900;color:#fff;letter-spacing:-1.5px;margin-bottom:10px;line-height:1.1}
.subtitle{color:#5a6a80;font-size:1rem;max-width:560px;margin:0 auto 24px}
.meta-line{color:var(--text4);font-size:.78rem}
.freshness{display:inline-block;background:rgba(234,179,8,0.12);color:var(--yellow);font-size:.65rem;font-weight:700;padding:3px 10px;border-radius:12px;margin-top:8px}

/* Dashboard */
.dash{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px;margin-top:30px}
.dash-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center}
.dash-val{display:block;font-size:1.8rem;font-weight:900;font-family:var(--mono);letter-spacing:-1px}
.dash-val.up{color:var(--green)}
.dash-val.down{color:var(--red)}
.dash-val.neutral{color:var(--accent)}
.dash-label{display:block;font-size:.7rem;color:var(--text3);margin-top:4px;text-transform:uppercase;letter-spacing:.5px}

.container{max-width:1100px;margin:0 auto;padding:0 24px}
.section{margin:50px 0}
.section-title{font-size:1.5rem;font-weight:900;color:#fff;margin-bottom:6px;letter-spacing:-.5px}
.section-sub{color:var(--text3);font-size:.85rem;margin-bottom:20px}

/* Donut Chart */
.chart-area{display:flex;gap:30px;align-items:flex-start;flex-wrap:wrap}
.donut-wrap{position:relative;width:280px;height:280px;flex-shrink:0}
.donut-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.donut-center-val{font-size:1.4rem;font-weight:900;color:#fff;font-family:var(--mono)}
.donut-center-label{font-size:.7rem;color:var(--text3)}
.legend{flex:1;min-width:240px;display:grid;grid-template-columns:1fr 1fr;gap:6px}
.legend-item{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:8px;cursor:pointer;transition:background .15s;font-size:.82rem;color:var(--text)}
.legend-item:hover,.legend-item.active{background:rgba(74,143,231,0.08)}
.legend-dot{width:12px;height:12px;border-radius:3px;flex-shrink:0}
.legend-pct{margin-left:auto;font-family:var(--mono);font-size:.75rem;color:var(--text3)}

/* Table */
.table-controls{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.table-controls select,.table-controls input{background:var(--bg2);border:1px solid var(--border);color:var(--text);padding:8px 14px;border-radius:8px;font-size:.82rem;font-family:'Inter',sans-serif}
.table-controls input{min-width:200px}
.active-filter{display:inline-flex;align-items:center;gap:6px;background:rgba(74,143,231,0.15);color:var(--accent);padding:5px 12px;border-radius:8px;font-size:.78rem;font-weight:600}
.active-filter button{background:none;border:none;color:var(--accent);cursor:pointer;font-size:1rem;line-height:1;padding:0}
.table-wrap{overflow-x:auto;background:var(--bg2);border:1px solid var(--border);border-radius:16px}
table{width:100%;border-collapse:collapse;min-width:720px}
th{background:var(--bg3);color:#8a96a8;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.8px;padding:12px 14px;text-align:left;cursor:pointer;user-select:none;white-space:nowrap;border-bottom:1px solid var(--border);position:sticky;top:0}
th:hover{color:var(--accent)}
th.sorted-asc::after{content:' ▲';color:var(--accent)}
th.sorted-desc::after{content:' ▼';color:var(--accent)}
td{padding:10px 14px;font-size:.82rem;border-bottom:1px solid rgba(21,32,64,0.5);white-space:nowrap}
tr:hover td{background:rgba(74,143,231,0.04)}
tr.dim td{opacity:.25}
.ticker{font-family:var(--mono);font-weight:700;color:var(--accent);font-size:.8rem}
.company{font-weight:700;color:var(--head)}
.weight-bar{display:inline-block;height:6px;background:var(--accent);border-radius:3px;margin-right:8px;vertical-align:middle}
.sector-badge{display:inline-block;font-size:.65rem;font-weight:600;padding:2px 8px;border-radius:10px;white-space:nowrap}

/* Calculator */
.calc-card{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:28px;max-width:700px}
.calc-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px}
.calc-field{flex:1;min-width:140px}
.calc-field label{display:block;font-size:.75rem;color:var(--text3);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.calc-field select,.calc-field input{width:100%;background:var(--bg3);border:1px solid var(--border);color:#fff;padding:10px 14px;border-radius:8px;font-size:1rem;font-family:var(--mono)}
.calc-btn{background:var(--accent);color:#fff;border:none;padding:12px 28px;border-radius:8px;font-size:.9rem;font-weight:700;cursor:pointer;transition:background .15s}
.calc-btn:hover{background:#3a7fd7}
.calc-results{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:16px;margin-top:20px;padding-top:20px;border-top:1px solid var(--border)}
.calc-result{text-align:center}
.calc-result-val{display:block;font-size:1.6rem;font-weight:900;font-family:var(--mono);color:var(--green);letter-spacing:-1px}
.calc-result-val.neg{color:var(--red)}
.calc-result-label{display:block;font-size:.7rem;color:var(--text3);margin-top:4px}
.calc-note{font-size:.72rem;color:var(--text4);margin-top:12px;line-height:1.5}

/* FAQ */
.faq-item{background:var(--bg2);border:1px solid var(--border);border-radius:12px;margin-bottom:12px;overflow:hidden}
.faq-q{padding:18px 24px;font-size:.95rem;font-weight:700;color:var(--head);cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q::after{content:'+';font-size:1.3rem;color:var(--accent);font-weight:300;transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{padding:0 24px 18px;font-size:.85rem;color:var(--text2);display:none;line-height:1.7}
.faq-item.open .faq-a{display:block}

/* Methodology */
.methodology{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:28px;margin:40px 0}
.methodology h3{font-size:1.1rem;font-weight:800;color:var(--head);margin-bottom:10px}
.methodology p,.methodology li{font-size:.82rem;color:var(--text2);line-height:1.7}
.methodology ul{padding-left:20px;margin-top:8px}

.footer-sec{text-align:center;padding:50px 24px;font-size:.75rem;color:#253040;border-top:1px solid #101828}
.disclaimer{max-width:600px;margin:12px auto 0;color:#1e2a3a;font-size:.68rem;line-height:1.5}

@media(max-width:700px){
  h1{font-size:1.8rem}
  .header{padding:60px 20px 40px}
  .dash{grid-template-columns:repeat(2,1fr);gap:10px}
  .dash-val{font-size:1.4rem}
  .chart-area{flex-direction:column;align-items:center}
  .donut-wrap{width:240px;height:240px}
  .legend{grid-template-columns:1fr}
  .calc-row{flex-direction:column}
  .calc-results{grid-template-columns:1fr 1fr}
}
  </style>

<div class="header">
