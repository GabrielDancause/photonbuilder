  { rank:25, company:'Bank of America Corp.', ticker:'BAC', sector:'Financials', weight:0.60 }
];

/* ── Sector color map ── */
const sectorColorMap = {};
sectors.forEach(s => { sectorColorMap[s.name] = s.color; });

/* ── Donut chart (SVG) ── */
function drawDonut() {
  const svg = document.getElementById('donutChart');
  const cx = 100, cy = 100, R = 85, r = 55;
  let cumAngle = -90;
  let paths = '';
  const total = sectors.reduce((s, x) => s + x.weight, 0);
  sectors.forEach(sec => {
    const angle = (sec.weight / total) * 360;
    const startAngle = cumAngle;
    const endAngle = cumAngle + angle;
    const largeArc = angle > 180 ? 1 : 0;
    const toRad = a => (a * Math.PI) / 180;
    const x1o = cx + R * Math.cos(toRad(startAngle));
    const y1o = cy + R * Math.sin(toRad(startAngle));
    const x2o = cx + R * Math.cos(toRad(endAngle));
    const y2o = cy + R * Math.sin(toRad(endAngle));
    const x1i = cx + r * Math.cos(toRad(endAngle));
    const y1i = cy + r * Math.sin(toRad(endAngle));
    const x2i = cx + r * Math.cos(toRad(startAngle));
    const y2i = cy + r * Math.sin(toRad(startAngle));
    paths += `<path d="M${x1o},${y1o} A${R},${R} 0 ${largeArc},1 ${x2o},${y2o} L${x1i},${y1i} A${r},${r} 0 ${largeArc},0 ${x2i},${y2i} Z" fill="${sec.color}" data-sector="${sec.name}" style="cursor:pointer;opacity:0.85;transition:opacity .15s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.85"/>`;
    cumAngle = endAngle;
  });
  svg.innerHTML = paths;
  svg.querySelectorAll('path').forEach(p => {
    p.addEventListener('click', () => toggleSectorFilter(p.dataset.sector));
  });
}

/* ── Legend ── */
function drawLegend() {
  const el = document.getElementById('sectorLegend');
  el.innerHTML = sectors.map(s =>
    `<div class="legend-item" data-sector="${s.name}">
      <span class="legend-dot" style="background:${s.color}"></span>
      <span>${s.name}</span>
      <span class="legend-pct">${s.weight}%</span>
    </div>`
  ).join('');
  el.querySelectorAll('.legend-item').forEach(item => {
    item.addEventListener('click', () => toggleSectorFilter(item.dataset.sector));
  });
}

/* ── Sector filter state ── */
let activeSector = null;
function toggleSectorFilter(sector) {
  activeSector = activeSector === sector ? null : sector;
  renderTable();
  updateFilterBadge();
  document.querySelectorAll('.legend-item').forEach(li => {
    li.classList.toggle('active', li.dataset.sector === activeSector);
  });
}
function updateFilterBadge() {
  const el = document.getElementById('activeFilter');
  if (activeSector) {
    el.innerHTML = `<span class="active-filter">${activeSector} <button onclick="toggleSectorFilter('${activeSector}')">×</button></span>`;
  } else {
    el.innerHTML = '';
  }
}

/* ── Holdings table ── */
let sortCol = 'rank', sortDir = 'asc';
const maxWeight = Math.max(...holdings.map(h => h.weight));

function renderTable() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  let filtered = holdings.filter(h => {
    if (search && !h.company.toLowerCase().includes(search) && !h.ticker.toLowerCase().includes(search)) return false;
    return true;
  });
  filtered.sort((a, b) => {
    let av = a[sortCol], bv = b[sortCol];
    if (typeof av === 'string') return sortDir === 'asc' ? av.localeCompare(bv) : bv.localeCompare(av);
    return sortDir === 'asc' ? av - bv : bv - av;
  });
  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = filtered.map(h => {
    const barW = (h.weight / maxWeight * 80).toFixed(0);
    const sColor = sectorColorMap[h.sector] || '#4a8fe7';
    const dim = activeSector && h.sector !== activeSector ? ' class="dim"' : '';
    return `<tr${dim}>
      <td style="color:#4a5568;font-family:var(--mono);font-size:.75rem">${h.rank}</td>
      <td><span class="company">${h.company}</span></td>
      <td><span class="ticker">${h.ticker}</span></td>
      <td><span class="sector-badge" style="background:${sColor}22;color:${sColor}">${h.sector}</span></td>
      <td><span class="weight-bar" style="width:${barW}px;background:${sColor}"></span>${h.weight.toFixed(2)}%</td>
    </tr>`;
  }).join('');
  document.querySelectorAll('#holdingsTable th').forEach(th => {
    th.classList.remove('sorted-asc', 'sorted-desc');
    if (th.dataset.col === sortCol) th.classList.add(sortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
  });
}

document.querySelectorAll('#holdingsTable th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    if (sortCol === col) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    else { sortCol = col; sortDir = col === 'company' || col === 'ticker' || col === 'sector' ? 'asc' : 'asc'; }
    renderTable();
  });
});
document.getElementById('searchInput').addEventListener('input', renderTable);

/* ── Historical returns data (S&P 500 total return, year-end) ── */
const annualReturns = {
  1990: -3.10, 1991: 30.47, 1992: 7.62, 1993: 10.08, 1994: 1.32,
  1995: 37.58, 1996: 22.96, 1997: 33.36, 1998: 28.58, 1999: 21.04,
  2000: -9.10, 2001: -11.89, 2002: -22.10, 2003: 28.68, 2004: 10.88,
  2005: 4.91, 2006: 15.79, 2007: 5.49, 2008: -37.00, 2009: 26.46,
  2010: 15.06, 2011: 2.11, 2012: 16.00, 2013: 32.39, 2014: 13.69,
  2015: 1.38, 2016: 11.96, 2017: 21.83, 2018: -4.38, 2019: 31.49,
  2020: 18.40, 2021: 28.71, 2022: -18.11, 2023: 26.29, 2024: 25.02,
  2025: 10.50
};

/* Populate year dropdowns */
const years = Object.keys(annualReturns).map(Number).sort((a, b) => a - b);
const startSel = document.getElementById('startYear');
const endSel = document.getElementById('endYear');
years.forEach(y => {
  startSel.innerHTML += `<option value="${y}" ${y === 2000 ? 'selected' : ''}>${y}</option>`;
  endSel.innerHTML += `<option value="${y}" ${y === 2025 ? 'selected' : ''}>${y}</option>`;
});

document.getElementById('calcBtn').addEventListener('click', () => {
  const sy = parseInt(startSel.value);
  const ey = parseInt(endSel.value);
  const invest = parseFloat(document.getElementById('investAmt').value) || 10000;
  if (sy >= ey) { alert('Start year must be before end year.'); return; }
  let growth = 1;
  for (let y = sy; y <= ey; y++) {
    if (annualReturns[y] !== undefined) {
      growth *= (1 + annualReturns[y] / 100);
    }
  }
  const finalVal = invest * growth;
  const totalReturn = ((growth - 1) * 100);
  const numYears = ey - sy + 1;
  const cagr = (Math.pow(growth, 1 / numYears) - 1) * 100;
  const rEl = document.getElementById('calcResults');
  rEl.style.display = 'grid';
  const tEl = document.getElementById('resTotal');
  tEl.textContent = (totalReturn >= 0 ? '+' : '') + totalReturn.toFixed(1) + '%';
  tEl.className = 'calc-result-val' + (totalReturn < 0 ? ' neg' : '');
  const cEl = document.getElementById('resCagr');
  cEl.textContent = (cagr >= 0 ? '+' : '') + cagr.toFixed(2) + '%';
  cEl.className = 'calc-result-val' + (cagr < 0 ? ' neg' : '');
  document.getElementById('resFinal').textContent = '$' + finalVal.toLocaleString(undefined, { maximumFractionDigits: 0 });
  document.getElementById('resYears').textContent = numYears + ' yrs';
});

/* ── FAQ toggle ── */
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});

/* ── Init ── */
drawDonut();
drawLegend();
renderTable();
  </script>

