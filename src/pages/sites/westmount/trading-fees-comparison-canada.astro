// Table
const tbody = document.getElementById('tbody');
const searchEl = document.getElementById('search');
const typeFilter = document.getElementById('typeFilter');
let sortKey = 'stockFee', sortDir = 1;

function feeClass(val, thresholds) {
  if (val === 0) return 'free';
  if (val <= thresholds[0]) return 'cheap';
  if (val <= thresholds[1]) return 'mid';
  return 'pricey';
}

function renderTable() {
  const q = searchEl.value.toLowerCase();
  const type = typeFilter.value;
  let filtered = BROKERS.filter(b => {
    if (q && !b.name.toLowerCase().includes(q)) return false;
    if (type && b.type !== type) return false;
    return true;
  });
  filtered.sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (va == null) return 1;
    if (vb == null) return -1;
    if (typeof va === 'string') return va.localeCompare(vb) * sortDir;
    return (va - vb) * sortDir;
  });
  tbody.innerHTML = filtered.map(b => `<tr>
    <td class="broker-name">${b.name}</td>
    <td class="num ${feeClass(b.stockFee, [2, 8])}">${b.stockFeeLabel}</td>
    <td class="num">${b.optionBase != null ? '$' + b.optionBase.toFixed(2) : '—'}</td>
    <td class="num">${b.optionPerContract != null ? '$' + b.optionPerContract.toFixed(2) : '—'}</td>
    <td class="${b.etfBuyFee === 0 ? 'free' : 'pricey'}">${b.etfBuy}</td>
    <td class="num ${feeClass(b.fxFeeNum, [0.5, 1.2])}">${b.fxFee}</td>
    <td class="num">${b.accountMinLabel}</td>
    <td class="num ${b.inactivityFeeNum === 0 ? 'free' : 'pricey'}">${b.inactivityFee}</td>
    <td>${b.type}</td>
  </tr>`).join('');
}

// Sort headers
document.querySelectorAll('th[data-key]').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.key;
    if (sortKey === key) sortDir *= -1; else { sortKey = key; sortDir = 1; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted-asc', 'sorted-desc'));
    th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
    renderTable();
  });
});

searchEl.addEventListener('input', renderTable);
typeFilter.addEventListener('change', renderTable);

// Calculator
document.getElementById('calcBtn').addEventListener('click', () => {
  const amount = parseFloat(document.getElementById('calcAmount').value) || 10000;
  const type = document.getElementById('calcType').value;
  const freq = parseInt(document.getElementById('calcFreq').value) || 4;
  const monthly = freq;
  const yearly = freq * 12;

  const results = BROKERS.map(b => {
    let perTrade = 0;
    let fxCost = 0;
    let label = '';

    if (type === 'cad-stock') {
      perTrade = b.stockFee;
      label = `$${perTrade.toFixed(2)} commission`;
    } else if (type === 'usd-stock') {
      perTrade = b.stockFee;
      fxCost = amount * (b.fxFeeNum / 100);
      label = `$${perTrade.toFixed(2)} comm + $${fxCost.toFixed(0)} FX`;
    } else if (type === 'etf') {
      perTrade = b.etfBuyFee;
      label = `$${perTrade.toFixed(2)} per ETF buy`;
    } else if (type === 'options') {
      if (b.optionPerContract == null) {
        return { name: b.name, total: null, yearly: null, label: 'Options not available' };
      }
      perTrade = (b.optionBase || 0) + (b.optionPerContract * 10);
      label = `$${perTrade.toFixed(2)} per 10 contracts`;
    }

    const totalPerTrade = perTrade + fxCost;
    const yearlyTotal = totalPerTrade * yearly + (b.inactivityFeeNum * 4);

    return { name: b.name, total: totalPerTrade, yearly: yearlyTotal, label: label };
  }).filter(r => r.total !== null);

  results.sort((a, b) => a.yearly - b.yearly);
  const lowest = results[0]?.yearly || 0;

  const resultsEl = document.getElementById('calcResults');
  resultsEl.innerHTML = `<p style="font-size:13px;color:var(--text-secondary);">Annual cost based on ${freq} trades/month (${yearly} trades/year) of $${amount.toLocaleString()}:</p>
    <div class="calc-results-grid">
    ${results.map(r => `<div class="calc-result">
      <div class="broker">${r.name}</div>
      <div class="cost ${r.yearly === lowest ? 'lowest' : ''}">${r.yearly != null ? '$' + r.yearly.toFixed(0) : 'N/A'}</div>
      <div class="detail">${r.label}</div>
    </div>`).join('')}
    </div>`;
});

