---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Trading Fees Comparison Canada 2026: Compare 10 Brokers",
  "description": "Compare trading fees across 10 Canadian brokers including Wealthsimple, Questrade, and Interactive Brokers. Stock trades, options, ETFs, and currency conversion fees compared.",
  "datePublished": "2026-03-21",
  "dateModified": "2026-03-21",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the cheapest broker for trading stocks in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wealthsimple Trade and National Bank Direct Brokerage both offer $0 commission stock trades in Canada. Wealthsimple is the simplest option with no account minimums and a mobile-first experience. National Bank eliminated commissions in 2021 and offers a full-service platform. However, if you trade US stocks, watch for currency conversion fees — Wealthsimple charges 1.5% (0% with Plus at $13/month) and National Bank charges 1.5%."
      }
    },
    {
      "@type": "Question",
      "name": "What are options trading fees in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Options trading fees in Canada range from $0.75 to $9.99+ per contract depending on the broker. Interactive Brokers is the cheapest at $1.50 per contract with no base fee. Questrade charges $9.95 + $1 per contract. Wealthsimple does not currently offer options trading. Most bank brokers charge $9.99 + $1.25 per contract. For active options traders, Interactive Brokers offers the best value."
      }
    },
    {
      "@type": "Question",
      "name": "Which Canadian broker has the lowest currency conversion fees?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Interactive Brokers offers the lowest currency conversion fee at just 0.20% (USD/CAD). Questrade charges 1.5-2.0% on automatic conversions, but allows manual Norbert's Gambit to reduce costs. Wealthsimple charges 1.5% (or 0% with Plus subscription at $13/month). Most bank brokers charge 1.5-2.5%. For investors who frequently buy US stocks, IBKR's low FX fee can save hundreds or thousands per year."
      }
    },
    {
      "@type": "Question",
      "name": "Are there any free ETF brokers in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Wealthsimple Trade, Questrade, and National Bank Direct Brokerage all offer free ETF purchases. Questrade was the first major Canadian broker to offer commission-free ETF buying (you still pay commission when selling). Wealthsimple offers free ETF buying and selling. Most bank brokers charge their standard stock commission ($6.95–$9.99) for ETF trades."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best broker for beginners in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wealthsimple Trade is the best broker for beginners in Canada. It offers $0 commissions, no account minimums, fractional shares, a clean mobile app, and supports TFSA, RRSP, and non-registered accounts. The main limitation is the 1.5% currency conversion fee on US stocks (waived with Plus at $13/month) and the lack of options trading. For beginners who want options access, Questrade is the next best choice."
      }
    },
    {
      "@type": "Question",
      "name": "Do Canadian brokers charge inactivity fees?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Canadian bank brokers charge quarterly inactivity fees ($25/quarter is typical) if your account balance is below a threshold (usually $15,000–$25,000). Wealthsimple, Questrade, and National Bank Direct Brokerage do not charge inactivity fees. Interactive Brokers eliminated its inactivity fee in 2021. If you're a buy-and-hold investor with a smaller account, choose a broker with no inactivity fees."
      }
    },
    {
      "@type": "Question",
      "name": "Is Questrade or Wealthsimple better?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on your needs. Wealthsimple is better for beginners and passive investors — $0 commissions, no minimums, fractional shares, clean app. Questrade is better for active traders — it offers options trading, margin accounts, advanced order types, and free ETF purchases. For US stocks, Wealthsimple Plus ($13/month) eliminates FX fees, while Questrade charges 1.5-2.0% unless you use Norbert's Gambit. Both are strong choices — Wealthsimple for simplicity, Questrade for features."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to buy US stocks in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The total cost of buying US stocks in Canada includes the trading commission plus the currency conversion fee. At Wealthsimple, it's $0 commission + 1.5% FX (or $0 + 0% with Plus). At Questrade, it's $4.95–$9.95 commission + 1.5–2.0% FX. At Interactive Brokers, it's $0.01/share (min $1) + 0.20% FX. At TD Direct Investing, it's $9.99 commission + ~2.0% FX. For a $10,000 US stock purchase, total fees range from $0 (Wealthsimple Plus) to ~$300 (bank brokers)."
      }
    }
  ]
};

export const meta = {
  title: "Trading Fees Comparison Canada 2026",
  description: "Compare trading fees across 10 Canadian brokers — stocks, options, ETFs, currency conversion. Find the cheapest broker for your trading style.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="Trading Fees Comparison Canada 2026 — 10 Brokers Ranked"
  description="Wealthsimple charges $0. TD charges $9.99. Same stock, 100% more expensive. Compare trading fees across 10 major Canadian brokers and stop overpaying."
  canonical="https://westmountfundamentals.com/trading-fees-comparison-canada" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

/* Header */
header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
header h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
header p.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.meta{color:var(--text-secondary);font-size:13px;margin-top:12px;font-family:'JetBrains Mono',monospace}

/* Stats row */
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:32px 0}
.stat{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.stat .val{font-size:32px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.stat .label{font-size:13px;color:var(--text-secondary);margin-top:4px}

/* Table */
.table-section{margin:32px 0}
.table-section h2{font-size:22px;margin-bottom:12px}
.controls{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.controls select,.controls input{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 12px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif}
.controls input{min-width:200px}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--border-color);user-select:none;position:sticky;top:0}
th:hover{color:var(--accent-color)}
th.sorted-asc::after{content:' ▲';color:var(--accent-color)}
th.sorted-desc::after{content:' ▼';color:var(--accent-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color);white-space:nowrap}
tr:hover{background:rgba(74,143,231,.06)}
.num{font-family:'JetBrains Mono',monospace;text-align:right}
.free{color:#22c55e;font-weight:700}
.cheap{color:#22c55e}
.mid{color:#eab308}
.pricey{color:#ef4444}
.broker-name{font-weight:600;color:var(--accent-color)}

/* Findings */
.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px;line-height:1.6}

/* Comparison section */
.comparison-section{margin:32px 0}
.comparison-section h2{font-size:22px;margin-bottom:6px}
.comparison-section .section-desc{color:var(--text-secondary);font-size:14px;margin-bottom:16px;line-height:1.6}
.comparison-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
.comparison-wrap table{width:100%;border-collapse:collapse;font-size:13px}
.comparison-wrap th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;border-bottom:1px solid var(--border-color)}
.comparison-wrap td{padding:10px 14px;border-bottom:1px solid var(--border-color)}
.comparison-wrap tr:hover{background:rgba(74,143,231,.06)}
.winner{color:#22c55e;font-weight:700}
.highlight-row{background:rgba(34,197,94,.04)}

/* Options section */
.options-section{margin:32px 0}
.options-section h2{font-size:22px;margin-bottom:6px}
.options-section .section-desc{color:var(--text-secondary);font-size:14px;margin-bottom:16px;line-height:1.6}

/* Cost calculator */
.calc-section{margin:32px 0}
.calc-section h2{font-size:22px;margin-bottom:16px}
.calc-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.calc-row{display:flex;gap:16px;margin-bottom:16px;flex-wrap:wrap;align-items:end}
.calc-field{display:flex;flex-direction:column;gap:4px}
.calc-field label{font-size:12px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px}
.calc-field input,.calc-field select{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:10px 14px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif;min-width:160px}
.calc-btn{background:var(--accent-color);color:#fff;border:none;padding:10px 20px;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer}
.calc-btn:hover{opacity:.9}
.calc-results{margin-top:16px}
.calc-results-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-top:12px}
.calc-result{background:rgba(74,143,231,.06);border:1px solid var(--border-color);border-radius:8px;padding:16px;text-align:center}
.calc-result .broker{font-size:13px;font-weight:600;margin-bottom:4px}
.calc-result .cost{font-family:'JetBrains Mono',monospace;font-size:24px;font-weight:700}
.calc-result .cost.lowest{color:#22c55e}
.calc-result .detail{font-size:11px;color:var(--text-secondary);margin-top:4px}

/* FAQ */
.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

/* Methodology */
.methodology{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.methodology h2{font-size:18px;margin-bottom:12px}
.methodology p{color:var(--text-secondary);font-size:14px;margin-bottom:10px;line-height:1.7}

/* Citation */
.citation{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px}
.citation h3{font-size:14px;margin-bottom:8px;color:var(--text-secondary)}
.citation code{display:block;background:var(--bg-color);padding:14px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--text-secondary);white-space:pre-wrap;word-break:break-all}

.updated-badge{display:inline-block;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-secondary);font-size:12px;padding:4px 10px;border-radius:4px;margin-top:8px;font-family:'JetBrains Mono',monospace}

/* Disclaimer */
.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}

/* Footer */
footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:640px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .controls{flex-direction:column}
  .controls input,.controls select{width:100%}
  .calc-row{flex-direction:column}
  .calc-field input,.calc-field select{width:100%}
}
  </style>

<div class="container">
    <h1>Trading Fees Comparison Canada 2026: 10 Brokers Ranked</h1>

<div class="updated-badge">Last Updated: March 2026</div>

<div class="stats">
  <div class="stat"><div class="val">10</div><div class="label">Brokers Compared</div></div>
  <div class="stat"><div class="val">$0</div><div class="label">Lowest Stock Commission</div></div>
  <div class="stat"><div class="val">$1.50</div><div class="label">Cheapest Options Contract</div></div>
  <div class="stat"><div class="val">0.20%</div><div class="label">Lowest FX Fee (IBKR)</div></div>
  <div class="stat"><div class="val">3</div><div class="label">Brokers With Free ETFs</div></div>
</div>

<div class="findings">
  <h2>Key Findings</h2>
  <div id="findings"></div>
</div>

<div class="table-section">
  <h2>Full Broker Fee Comparison</h2>
  <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px;">Click any column header to sort. All fees are in CAD unless noted.</p>
  <div class="controls">
    <input type="text" id="search" placeholder="Search brokers…">
    <select id="typeFilter">
      <option value="">All Broker Types</option>
      <option value="Online">Online Broker</option>
      <option value="Bank">Bank Broker</option>
    </select>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th data-key="name">Broker</th>
          <th data-key="stockFee" data-type="num">Stock Trade</th>
          <th data-key="optionBase" data-type="num">Options Base</th>
          <th data-key="optionPerContract" data-type="num">Options /Contract</th>
          <th data-key="etfBuy">ETF Purchase</th>
          <th data-key="fxFeeNum" data-type="num">FX Fee (CAD/USD)</th>
          <th data-key="accountMin" data-type="num">Account Min</th>
          <th data-key="inactivityFeeNum" data-type="num">Inactivity Fee</th>
          <th data-key="type">Type</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</div>

<div class="comparison-section" id="zero-commission">
  <h2>$0 Commission Brokers: Wealthsimple vs National Bank vs IBKR</h2>
  <p class="section-desc">Three Canadian brokers now offer $0 stock commissions (or close to it). But the total cost depends on currency conversion, account minimums, and available features.</p>
  <div class="comparison-wrap">
    <table>
      <thead>
        <tr><th>Feature</th><th>Wealthsimple Trade</th><th>National Bank Direct</th><th>Interactive Brokers</th></tr>
      </thead>
      <tbody>
        <tr class="highlight-row"><td><strong>Stock Commission</strong></td><td class="winner">$0</td><td class="winner">$0</td><td>$0.01/share (min $1)</td></tr>
        <tr><td>Options Trading</td><td>Not available</td><td>$6.95 + $1.25/contract</td><td class="winner">$1.50/contract</td></tr>
        <tr><td>ETF Purchases</td><td class="winner">$0</td><td class="winner">$0</td><td>$0.01/share (min $1)</td></tr>
        <tr><td>FX Fee (CAD → USD)</td><td>1.5% (0% with Plus)</td><td>1.5%</td><td class="winner">0.20%</td></tr>
        <tr><td>Account Minimum</td><td class="winner">$0</td><td class="winner">$0</td><td class="winner">$0</td></tr>
        <tr><td>Inactivity Fee</td><td class="winner">None</td><td class="winner">None</td><td class="winner">None</td></tr>
        <tr><td>Fractional Shares</td><td class="winner">Yes</td><td>No</td><td>Yes (US stocks)</td></tr>
        <tr><td>Registered Accounts</td><td>TFSA, RRSP, FHSA</td><td>TFSA, RRSP, RESP, FHSA</td><td>TFSA, RRSP</td></tr>
        <tr><td>Mobile App Quality</td><td class="winner">Excellent</td><td>Good</td><td>Complex</td></tr>
        <tr><td>Best For</td><td>Beginners, passive investors</td><td>Fee-conscious bank clients</td><td>Active/advanced traders</td></tr>
      </tbody>
    </table>
  </div>
  <p class="section-desc" style="margin-top:12px"><strong>Bottom line:</strong> Wealthsimple is the simplest $0 commission option for beginners. National Bank offers $0 commissions with a full-service platform. IBKR is technically not $0 but its per-share pricing is negligible for most trades, and its 0.20% FX fee crushes the competition for US stock purchases. For a $10,000 USD purchase, Wealthsimple charges $150 in FX (or $0 with Plus), National Bank charges $150, and IBKR charges just $20.</p>
</div>

<div class="options-section" id="options-fees">
  <h2>Options Trading Fees in Canada: Complete Comparison</h2>
  <p class="section-desc">Options trading fees in Canada vary dramatically — from $1.50 per contract at Interactive Brokers to $9.99 + $1.25 at most bank brokers. Here's the full breakdown for 2026:</p>
  <div class="comparison-wrap">
    <table>
      <thead>
        <tr><th>Broker</th><th>Base Fee</th><th>Per Contract</th><th>Total (10 contracts)</th><th>Exercise/Assignment</th><th>Notes</th></tr>
      </thead>
      <tbody>
        <tr class="highlight-row"><td class="broker-name">Interactive Brokers</td><td class="winner">$0</td><td class="winner">$1.50</td><td class="winner">$15.00</td><td>$0</td><td>Cheapest by far. Tiered pricing available for high volume.</td></tr>
        <tr><td class="broker-name">Questrade</td><td>$9.95</td><td>$1.00</td><td>$19.95</td><td>$24.95</td><td>$4.95 minimum per trade. Good for larger orders.</td></tr>
        <tr><td class="broker-name">CI Direct Trading</td><td>$0</td><td>$0.75</td><td>$7.50</td><td>$24.95</td><td>Lowest per-contract fee. No base fee.</td></tr>
        <tr><td class="broker-name">National Bank Direct</td><td>$6.95</td><td>$1.25</td><td>$19.45</td><td>$28.95</td><td>Commissions eliminated for stocks but not options.</td></tr>
        <tr><td class="broker-name">TD Direct Investing</td><td>$9.99</td><td>$1.25</td><td>$22.49</td><td>$24.99</td><td>Reduced to $7.00 + $1.25 for 150+ trades/quarter.</td></tr>
        <tr><td class="broker-name">RBC Direct Investing</td><td>$9.99</td><td>$1.25</td><td>$22.49</td><td>$24.99</td><td>Reduced to $6.99 + $1.25 for 150+ trades/quarter.</td></tr>
        <tr><td class="broker-name">BMO InvestorLine</td><td>$9.99</td><td>$1.25</td><td>$22.49</td><td>$24.99</td><td>Active trader pricing available.</td></tr>
        <tr><td class="broker-name">Scotia iTRADE</td><td>$9.99</td><td>$1.25</td><td>$22.49</td><td>$24.99</td><td>FlightDesk platform for active traders.</td></tr>
        <tr><td class="broker-name">Desjardins Online</td><td>$9.95</td><td>$1.25</td><td>$22.45</td><td>$28.50</td><td>Disnat platform. French/English support.</td></tr>
        <tr><td class="broker-name">Wealthsimple Trade</td><td colspan="5" style="color:var(--text-secondary);font-style:italic">Options trading not available</td></tr>
      </tbody>
    </table>
  </div>
  <p class="section-desc" style="margin-top:12px"><strong>For options traders:</strong> CI Direct Trading has the lowest per-contract fee at $0.75 with no base fee — best for trading many contracts. Interactive Brokers at $1.50/contract with no base fee is the best overall value considering its superior platform, real-time data, and $0 exercise/assignment fee. Bank brokers cluster around $9.99 + $1.25/contract, making them 2-3x more expensive for a typical 10-contract trade.</p>
</div>

<div class="comparison-section" id="bank-brokers">
  <h2>Bank Broker Fees Compared: TD vs RBC vs BMO vs Scotia vs Desjardins</h2>
  <p class="section-desc">If you prefer keeping investments at your bank, here's how Canada's Big Five bank brokerages stack up in 2026:</p>
  <div class="comparison-wrap">
    <table>
      <thead>
        <tr><th>Fee Type</th><th>TD Direct</th><th>RBC Direct</th><th>BMO InvestorLine</th><th>Scotia iTRADE</th><th>Desjardins</th></tr>
      </thead>
      <tbody>
        <tr class="highlight-row"><td><strong>Stock Commission</strong></td><td>$9.99</td><td>$9.99</td><td>$9.99</td><td>$9.99</td><td>$9.95</td></tr>
        <tr><td>Active Trader Rate</td><td>$7.00</td><td>$6.99</td><td>$7.00</td><td>$4.99</td><td class="winner">$4.95</td></tr>
        <tr><td>Active Threshold</td><td>150/quarter</td><td>150/quarter</td><td>150/quarter</td><td>150/quarter</td><td>30+/quarter</td></tr>
        <tr><td>ETF Purchase</td><td>$9.99</td><td>$9.99</td><td>$9.99</td><td>$9.99</td><td>$9.95</td></tr>
        <tr><td>Options (base + /contract)</td><td>$9.99+$1.25</td><td>$9.99+$1.25</td><td>$9.99+$1.25</td><td>$9.99+$1.25</td><td>$9.95+$1.25</td></tr>
        <tr><td>FX Conversion</td><td>~1.5%</td><td>~1.5–2.0%</td><td>~1.5%</td><td>~1.5%</td><td>~1.5%</td></tr>
        <tr><td>Account Minimum</td><td>$0</td><td>$0</td><td>$0</td><td>$0</td><td>$0</td></tr>
        <tr><td>Inactivity Fee</td><td>$25/qtr</td><td>$25/qtr</td><td>$25/qtr</td><td>$25/qtr</td><td>$30/qtr</td></tr>
        <tr><td>Inactivity Waived If</td><td>&gt;$15K</td><td>&gt;$15K</td><td>&gt;$25K</td><td>&gt;$25K</td><td>&gt;$15K</td></tr>
        <tr><td>RESP Available</td><td class="winner">Yes</td><td class="winner">Yes</td><td class="winner">Yes</td><td class="winner">Yes</td><td class="winner">Yes</td></tr>
      </tbody>
    </table>
  </div>
  <p class="section-desc" style="margin-top:12px"><strong>Verdict:</strong> Bank brokers are nearly identical in pricing. The real differentiators are platform quality, research tools, and whether you value having investments at the same institution as your banking. TD's webBroker and GoalAssist are best-in-class among bank platforms. Scotia iTRADE's FlightDesk is strong for active traders. If fees are your priority, Desjardins has the lowest active trader threshold (30 trades/quarter vs 150 elsewhere) and slightly lower base commissions.</p>
