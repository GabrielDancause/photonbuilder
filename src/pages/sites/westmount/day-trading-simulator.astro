<script is:inline>
  function initSimulator() {
    const btn = document.getElementById('run-simulation');
    if (!btn) return;

    let chartInstance = null;

    btn.addEventListener('click', () => {
      // Inputs
      const startingCapital = parseFloat(document.getElementById('starting-capital').value) || 0;
      const winRatePercent = parseFloat(document.getElementById('win-rate').value) || 0;
      const riskReward = parseFloat(document.getElementById('risk-reward').value) || 0;
      const riskPerTradePercent = parseFloat(document.getElementById('risk-per-trade').value) || 0;

      // Validation
      if (startingCapital <= 0 || winRatePercent <= 0 || riskReward <= 0 || riskPerTradePercent <= 0) {
        alert("Please enter valid positive numbers for all fields.");
        return;
      }

      const winRate = winRatePercent / 100;
      const riskPerTrade = riskPerTradePercent / 100;
      const numTrades = 100;

      // Simulation State
      let balance = startingCapital;
      let maxBalance = startingCapital;
      let minBalance = startingCapital;
      const equityCurve = [startingCapital];
      let ruined = false;

      // Base EV calculation based on risking $1 for simplicity first
      const averageLossPercent = riskPerTrade;
      const averageWinPercent = riskPerTrade * riskReward;

      // Fixed fractional position sizing simulation
      for (let i = 0; i < numTrades; i++) {
        if (balance <= 0 || balance < startingCapital * 0.05) { // Ruin threshold
          ruined = true;
          break;
        }

        const riskAmount = balance * riskPerTrade;
        const winAmount = riskAmount * riskReward;

        const isWin = Math.random() < winRate;
        if (isWin) {
          balance += winAmount;
        } else {
          balance -= riskAmount;
        }

        if (balance > maxBalance) maxBalance = balance;
        if (balance < minBalance) minBalance = balance;

        equityCurve.push(balance);
      }

      // Fill remaining trades with 0 if ruined
      while(equityCurve.length <= numTrades) {
        equityCurve.push(balance > 0 ? balance : 0);
      }
      if(balance < 0) balance = 0;

      // EV calculation (Dollar amount based on initial capital)
      const initialRiskDollar = startingCapital * riskPerTrade;
      const initialWinDollar = initialRiskDollar * riskReward;
      const expectedValueDollar = (winRate * initialWinDollar) - ((1 - winRate) * initialRiskDollar);

      // Max Drawdown
      const maxDrawdownPercent = ((maxBalance - minBalance) / maxBalance) * 100;

      // Probability of Profitability (Monte Carlo approximation - 1000 runs)
      let profitableRuns = 0;
      for(let run=0; run<1000; run++){
        let tempBal = startingCapital;
        for(let i=0; i<numTrades; i++){
          if(tempBal <= 0) break;
          const rAmount = tempBal * riskPerTrade;
          const wAmount = rAmount * riskReward;
          if(Math.random() < winRate) tempBal += wAmount;
          else tempBal -= rAmount;
        }
        if(tempBal > startingCapital) profitableRuns++;
      }
      const probProfit = (profitableRuns / 1000) * 100;

      // Update UI
      document.getElementById('results-section').style.display = 'block';

      document.getElementById('ev-result').textContent = expectedValueDollar >= 0
        ? `+$${expectedValueDollar.toFixed(2)}`
        : `-$${Math.abs(expectedValueDollar).toFixed(2)}`;

      document.getElementById('ev-result').style.color = expectedValueDollar >= 0 ? 'var(--text-primary)' : 'var(--accent-color)';

      document.getElementById('final-balance').textContent = `$${balance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
      document.getElementById('max-drawdown').textContent = `${maxDrawdownPercent.toFixed(2)}%`;
      document.getElementById('prob-profit').textContent = `${probProfit.toFixed(1)}%`;

      const warningBanner = document.getElementById('ruin-warning');
      if (ruined || balance <= 0) {
        warningBanner.style.display = 'block';
        document.getElementById('final-balance').style.color = 'var(--accent-color)';
      } else {
        warningBanner.style.display = 'none';
        document.getElementById('final-balance').style.color = 'var(--text-primary)';
      }

      // Chart
      const ctx = document.getElementById('equityCurveChart').getContext('2d');
      if (chartInstance) {
        chartInstance.destroy();
      }

      const labels = Array.from({length: numTrades + 1}, (_, i) => `Trade ${i}`);
      labels[0] = "Start";

      // @ts-ignore
      chartInstance = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'Account Equity ($)',
            data: equityCurve,
            borderColor: 'var(--accent-color)',
            backgroundColor: 'color-mix(in srgb, var(--accent-color) 10%, transparent)',
            borderWidth: 2,
            pointRadius: 0,
            pointHitRadius: 10,
            fill: true,
            tension: 0.1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) {
                  return '$' + context.parsed.y.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
                }
              }
            }
          },
          scales: {
            x: {
              grid: { color: 'color-mix(in srgb, var(--text-secondary) 10%, transparent)' },
              ticks: { color: 'var(--text-secondary)' }
            },
            y: {
              grid: { color: 'color-mix(in srgb, var(--text-secondary) 10%, transparent)' },
              ticks: {
                color: 'var(--text-secondary)',
                callback: function(value) { return '$' + value; }
              }
            }
          }
        }
      });
    });
  }

  // Setup view transitions and regular load
  document.addEventListener('astro:page-load', initSimulator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSimulator);
  } else {
    initSimulator();
  }
</script>