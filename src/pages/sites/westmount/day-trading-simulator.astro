    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    display: block;
  }
  .calc-result-value {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 800;
  }
  .input-group {
    margin-bottom: 1.5rem;
  }
  .input-group label {
    display: block;
    margin-bottom: 0.5rem;
