<script>
  function initCalculator() {
    const btn = document.getElementById('calculateSaleBtn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const purchasePrice = parseFloat(document.getElementById('purchasePrice').value) || 0;
      const shares = parseInt(document.getElementById('sharesOwned').value) || 0;
      const sellPrice = parseFloat(document.getElementById('sellPrice').value) || 0;
      const commission = parseFloat(document.getElementById('commission').value) || 0;

      const costBasis = purchasePrice * shares;
      const grossProceeds = sellPrice * shares;
      const netProceeds = grossProceeds - commission;
      const netProfit = netProceeds - costBasis;
      const roi = costBasis > 0 ? (netProfit / costBasis) * 100 : 0;

      const resultsDiv = document.getElementById('saleResults');
      if(resultsDiv) resultsDiv.style.display = 'flex';

      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);

      const elCostBasis = document.getElementById('resCostBasis');
      const elGrossProceeds = document.getElementById('resGrossProceeds');
      const elNetProfit = document.getElementById('resNetProfit');
      const elRoi = document.getElementById('resRoi');

      if(elCostBasis) elCostBasis.textContent = formatCurrency(costBasis);
      if(elGrossProceeds) elGrossProceeds.textContent = formatCurrency(grossProceeds);

      if(elNetProfit) {
        elNetProfit.textContent = formatCurrency(netProfit);
        elNetProfit.className = netProfit >= 0 ? 'val-positive' : 'val-negative';
        elNetProfit.style.color = netProfit >= 0 ? 'var(--accent-color)' : 'var(--text-secondary)';
      }

      if(elRoi) {
        elRoi.textContent = roi.toFixed(2) + '%';
        elRoi.style.color = netProfit >= 0 ? 'var(--accent-color)' : 'var(--text-secondary)';
      }
    });
  }

  // Handle Astro view transitions and standard load
  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
