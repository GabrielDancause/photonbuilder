---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the average institutional ownership across all US public companies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Based on 2026 data, the average institutional ownership across US public companies is approximately 73.5%. This varies significantly by market capitalization and sector."
      }
    },
    {
      "@type": "Question",
      "name": "What does a high institutional ownership percentage signal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "High institutional ownership (typically >80%) signals strong confidence from major funds and banks, implying stability, rigorous analysis backing the stock, and liquidity. However, extremely high levels (>95%) can mean the stock is crowded, leaving fewer marginal buyers and increasing the risk of sharp selloffs if institutions simultaneously exit."
      }
    },
    {
      "@type": "Question",
      "name": "Which sectors have the highest institutional ownership?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our 2026 analysis shows that sectors like Healthcare (81.9%) and Consumer Cyclical (80.5%) tend to attract the highest institutional capital due to reliable cash flows or strong growth characteristics."
      }
    },
    {
      "@type": "Question",
      "name": "How does market cap affect institutional ownership?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is a direct correlation between market cap and institutional ownership. Mega-cap and large-cap stocks typically see higher average institutional ownership because large funds require massive liquidity to build positions without moving the market. Small and micro-cap stocks have noticeably lower institutional ownership."
      }
    },
    {
      "@type": "Question",
      "name": "What percentage of stocks are owned by institutions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In the modern U.S. stock market, institutions collectively own approximately 70-80% of the market value of publicly traded companies, a figure that continues to remain strong in 2026."
      }
    }
  ]
};

export const meta = {
  title: "Institutional Ownership Tracker: S&P 500 Average & Rankings (2026)",
  description: "Average institutional ownership in S&P 500: 72%. See every company ranked, plus sector breakdowns, historical trends, and what it means for your portfolio.",
  category: "guide",
  published: "2026-03-15",
};
