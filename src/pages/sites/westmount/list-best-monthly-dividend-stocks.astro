      <button class="filter-btn" data-filter="ETF">ETFs</button>
      <button class="filter-btn" data-filter="BDC">BDCs</button>
      <button class="filter-btn" data-filter="CEF">CEFs</button>
      <button class="filter-btn" data-filter="Stock">Stocks</button>
    </div>

    <div class="table-container">
      <table id="dataTable">
        <thead>
          <tr>
            <th data-sort="ticker">Asset</th>
            <th data-sort="type">Type</th>
            <th data-sort="price" class="num-val">Price</th>
            <th data-sort="dividend" class="num-val">Annual Div</th>
            <th data-sort="yield" class="num-val sort-desc">Yield</th>
