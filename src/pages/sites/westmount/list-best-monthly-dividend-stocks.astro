    const initCharts = () => {
      Chart.defaults.color = '#6a7a90';
      Chart.defaults.font.family = 'Inter, sans-serif';

      // Chart 1: Average Yield by Type
      const types = ['REIT', 'BDC', 'ETF', 'CEF', 'Stock'];
      const avgYieldsByType = types.map(t => {
        const items = rawData.filter(d => d.type === t && d.yield !== null);
        if(items.length === 0) return 0;
        return items.reduce((sum, item) => sum + item.yield, 0) / items.length;
      });

      const ctxType = document.getElementById('typeChart').getContext('2d');
      new Chart(ctxType, {
        type: 'bar',
        data: {
          labels: types,
          datasets: [{
            label: 'Avg Yield %',
            data: avgYieldsByType,
            backgroundColor: [
              'rgba(16, 185, 129, 0.7)', // REIT
              'rgba(245, 158, 11, 0.7)',  // BDC
              'rgba(139, 92, 246, 0.7)',  // ETF
              'rgba(236, 72, 153, 0.7)',  // CEF
