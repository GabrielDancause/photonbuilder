        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) { return context.raw.toFixed(2) + '%'; }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: 'rgba(21, 32, 64, 0.5)' }
            },
            x: {
              grid: { display: false }
            }
          }
        }
      });

      // Chart 2: Top 10 Yields
      const top10 = [...rawData].sort((a,b) => b.yield - a.yield).slice(0, 10);

      const ctxYield = document.getElementById('yieldChart').getContext('2d');
      new Chart(ctxYield, {
        type: 'bar',
        data: {
          labels: top10.map(d => d.ticker),
          datasets: [{
            label: 'Yield %',
            data: top10.map(d => d.yield),
            backgroundColor: 'rgba(74, 143, 231, 0.7)',
            borderColor: '#4a8fe7',
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          indexAxis: 'y',
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(context) { return context.raw.toFixed(2) + '%'; }
              }
            }
          },
          scales: {
            x: {
              beginAtZero: true,
              grid: { color: 'rgba(21, 32, 64, 0.5)' }
            },
            y: {
              grid: { display: false }
            }
          }
        }
      });
    };

    // Calculator functionality
    const investmentInput = document.getElementById('investmentAmount');
    const yieldAmountElements = document.querySelectorAll('[data-tier]');

    const updateCalculator = () => {
      const amount = parseFloat(investmentInput.value) || 0;
      
      yieldAmountElements.forEach(element => {
        const tier = parseFloat(element.dataset.tier);
        const monthlyIncome = (amount * tier / 100) / 12;
        element.textContent = '$' + monthlyIncome.toFixed(0);
      });
    };

    investmentInput.addEventListener('input', updateCalculator);
    investmentInput.addEventListener('keyup', updateCalculator);

    // Initial calculator render
    updateCalculator();

