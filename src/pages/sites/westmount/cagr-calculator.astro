---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "CAGR Calculator",
  description: "Calculate your Compound Annual Growth Rate to see the true smoothed return of your investments over time. See how much your portfolio actually grew.",
  category: "tool",
  published: "2026-03-17"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/cagr-calculator"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a good CAGR for a stock portfolio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Historically, the S&P 500 has returned a CAGR of about 7% to 10% per year after adjusting for inflation. Any return consistently above this benchmark over a long period is considered excellent."
          }
        },
        {
          "@type": "Question",
          "name": "Does CAGR account for inflation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, standard CAGR only calculates the nominal growth rate based on starting and ending values. To find the real return, you must manually subtract the inflation rate from your nominal CAGR."
          }
        },
        {
          "@type": "Question",
          "name": "Can a CAGR be negative?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, if the ending value of an investment is lower than its beginning value, the CAGR will be a negative percentage, indicating an average annual loss over that time period."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between ROI and CAGR?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ROI (Return on Investment) measures the total growth from start to finish without considering how long it took. CAGR smooths that total return into an annualized average, giving you a standardized rate per year."
          }
        },
        {
          "@type": "Question",
          "name": "Does CAGR assume you reinvest dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If the ending value you plug into the calculation includes reinvested dividends, then yes. CAGR simply measures the growth between two static numbers, so it depends entirely on what those numbers represent."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/cagr-calculator"
  schema={schema}
>
  <div class="page-content container">
    <h1>CAGR Calculator</h1>
    <p>Calculate your Compound Annual Growth Rate (CAGR) to find the smoothed annualized return of your investments over a specific time period.</p>

    <div class="calculator-card">
      <div class="input-grid">
        <div class="input-group">
          <label for="startValue">Beginning Value</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="startValue" value="10000" min="0.01" step="any" aria-label="Starting amount" />
          </div>
        </div>

        <div class="input-group">
          <label for="endValue">Ending Value</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="endValue" value="25000" min="0" step="any" aria-label="Ending amount" />
          </div>
        </div>

        <div class="input-group">
          <label for="years">Time Period (Years)</label>
          <div class="input-wrapper">
            <input type="number" id="years" value="10" min="0.1" step="any" aria-label="Number of years" />
            <span class="suffix">Yrs</span>
          </div>
        </div>
      </div>

      <div class="results-container">
        <div class="result-box primary-result">
          <div class="result-label">Compound Annual Growth Rate (CAGR)</div>
          <div class="result-value" id="cagrResult">9.60%</div>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-label">Total Return (ROI)</div>
            <div class="stat-value" id="roiResult">150.00%</div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Value Multiple</div>
            <div class="stat-value" id="multipleResult">2.50x</div>
          </div>
        </div>
      </div>
      <div id="errorMsg" class="error-msg" style="display: none;"></div>
    </div>

    <style>
      .calculator-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 2rem;
        margin: 2.5rem 0;
        /* No hardcoded shadow */
      }

      .input-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
      }

      .input-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--text-primary);
      }

      .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
      }

      .prefix {
        position: absolute;
        left: 1rem;
        color: var(--text-secondary);
        font-family: var(--font-mono);
        font-size: 1.1rem;
        pointer-events: none;
      }

      .suffix {
        position: absolute;
        right: 1rem;
        color: var(--text-secondary);
        font-family: var(--font-mono);
        font-size: 1rem;
        pointer-events: none;
      }

      input[type="number"] {
        width: 100%;
        background-color: var(--bg-color);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        font-family: var(--font-mono);
        font-size: 1.1rem;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        transition: border-color 0.2s;
        -moz-appearance: textfield;
      }

      #startValue, #endValue {
        padding-left: 2.5rem;
      }

      #years {
        padding-right: 3.5rem;
      }

      input[type="number"]::-webkit-outer-spin-button,
      input[type="number"]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
      }

      input[type="number"]:focus {
        outline: none;
        border-color: var(--accent-color);
      }

      .results-container {
        border-top: 1px solid var(--border-color);
        padding-top: 2rem;
      }

      .result-box.primary-result {
        text-align: center;
        margin-bottom: 2rem;
        background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
        border: 1px solid color-mix(in srgb, var(--accent-color) 20%, transparent);
        padding: 2rem;
        border-radius: 12px;
      }

      .result-label {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 0.5rem;
        font-weight: 500;
      }

      .result-value {
        font-family: var(--font-mono);
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--accent-color);
        line-height: 1;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
      }

      .stat-card {
        background-color: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1rem;
        text-align: center;
      }

      .stat-label {
        color: var(--text-secondary);
        font-size: 0.85rem;
        margin-bottom: 0.25rem;
      }

      .stat-value {
        font-family: var(--font-mono);
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
      }

      .error-msg {
        color: var(--accent-color); /* Note: Ideally use a theme negative variable, falling back to text-secondary or accent */
        background-color: color-mix(in srgb, var(--text-secondary) 10%, transparent);
        border: 1px solid var(--border-color);
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1rem;
        text-align: center;
        font-weight: 500;
      }

      .content-section {
        margin-top: 3rem;
      }

      @media (max-width: 600px) {
        .result-value {
          font-size: 2.5rem;
        }
        .calculator-card {
          padding: 1.5rem;
        }
        .input-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <div class="content-section">
      <h2>Understanding Compound Annual Growth Rate (CAGR)</h2>
      <p>When you invest your money over multiple years, your returns are rarely a straight, consistent line. One year your portfolio might be up 20%, the next year it might crash by 15%, and the following year it might crawl up by 4%. If you just add those numbers up and divide by three, you get an arithmetic mean of 3%. However, that number is dangerously misleading when dealing with compounded money.</p>

      <p>This is where the <strong>Compound Annual Growth Rate (CAGR)</strong> comes in. CAGR is not an actual rate of return that happened in reality. Instead, it is a mathematical smoothing mechanism. It represents the hypothetical, steady annual rate at which your investment would have needed to grow from its beginning balance to its ending balance, assuming the profits were reinvested at the end of each year.</p>

      <p>Imagine your investment journey as a bumpy car ride from New York to Los Angeles. You might drive 80 mph on open highways and sit in traffic at 5 mph around major cities. Your CAGR is the equivalent of asking: <em>"If I had locked in cruise control at one exact speed for the entire trip, what speed would have gotten me there at the exact same time?"</em></p>

      <p>By ironing out the volatile swings of the stock market, real estate, or business revenue, CAGR gives investors a standardized metric to compare wildly different assets on a level playing field.</p>

      <div class="highlight-box">
        <h3>How to Calculate CAGR: The Formula</h3>
        <p>You don't need a finance degree to calculate your CAGR. The mathematical formula only requires three basic inputs:</p>
        <p style="text-align: center; font-size: 1.5rem; font-family: var(--font-mono); color: var(--accent-color); padding: 1rem 0;">
          CAGR = (EV / BV)<sup>(1/n)</sup> - 1
        </p>
        <ul>
          <li><strong>EV (Ending Value):</strong> How much your investment is worth at the end of the period.</li>
          <li><strong>BV (Beginning Value):</strong> How much you originally invested.</li>
          <li><strong>n (Number of Years):</strong> The exact time period in years.</li>
        </ul>
      </div>

      <h3>A Worked Example: Showing the Math</h3>
      <p>Let's look at a practical example. Suppose you bought $10,000 worth of an index fund in January 2019. Over the next five years, the market goes on a wild ride. By January 2024, you check your brokerage account and see your balance is $16,500.</p>

      <p>To find out your true annualized return, we plug these numbers into the formula:</p>

      <ol>
        <li>First, divide your Ending Value by your Beginning Value: <code>16,500 / 10,000 = 1.65</code>. This is your total growth multiple (a 65% total return).</li>
        <li>Next, raise that result to the power of 1 divided by the number of years (5 years). Mathematically, this is <code>1 / 5 = 0.20</code>.</li>
        <li>So, we calculate: <code>1.65<sup>0.20</sup> = 1.1053</code></li>
        <li>Finally, subtract 1: <code>1.1053 - 1 = 0.1053</code></li>
        <li>Multiply by 100 to get a percentage: <strong>10.53%</strong></li>
      </ol>

      <p>Your CAGR for those five years was 10.53%. Even though the market may have tanked one year and surged the next, your money grew at the <em>equivalent</em> of a steady 10.53% per year, compounded annually. This smooth metric makes it incredibly easy to compare against other investments, or even tools like a <a href="/future-value-calculator">future value calculator</a> to estimate where your portfolio will be in retirement.</p>

      <h3>When Do Investors Actually Use CAGR?</h3>
      <p>Professionals don't just calculate CAGR for fun; it is an essential tool used daily in equity research, venture capital, and corporate finance. Here are the most common real-world applications:</p>

      <p><strong>1. Comparing Radically Different Assets:</strong> How do you compare the return of a sleepy dividend stock you've held for 8 years against a high-growth tech startup you invested in 3 years ago? By standardizing both returns to an annualized CAGR, you can instantly see which asset actually worked harder for your money, regardless of the holding timeframe.</p>

      <p><strong>2. Evaluating Mutual Funds and ETFs:</strong> When you read a prospectus for a mutual fund, the "5-Year Return" or "10-Year Return" listed on the fact sheet is almost always a CAGR. It strips away the marketing spin and gives you a cold, hard number to compare against a benchmark index like the S&P 500 or tools tracking the <a href="/average-stock-market-return">average stock market return</a>.</p>

      <p><strong>3. Tracking Business Growth:</strong> Corporate executives use CAGR to track fundamental business metrics. If a company's revenue grew from $50 million to $80 million over four years, analysts will calculate the revenue CAGR (12.4%) to see if the business is growing faster or slower than its competitors.</p>

      <p><strong>4. Discounting Cash Flows:</strong> When valuing a company, analysts project future cash flows and then discount them back to the present. Understanding historical CAGR helps analysts forecast realistic future growth rates for their <a href="/present-value-calculator">present value calculator</a> models.</p>

      <h2>Common Mistakes People Make With CAGR</h2>
      <p>While CAGR is incredibly useful, it isn't perfect. It is essential to understand its limitations because trusting it blindly can lead to poor financial decisions. Many amateur investors fail to recognize what CAGR is actually telling them and what it hides beneath the surface.</p>

      <h3>1. The "Volatility Illusion"</h3>
      <p>The most significant danger of CAGR is that it completely ignores volatility. Let's look at two hypothetical investment accounts over three years. Account A starts at $10,000, grows slowly to $11,000, then $12,100, and finishes at $13,310. Account B starts at $10,000, skyrockets to $25,000 in a massive bubble, crashes back down to $5,000, and miraculously recovers to finish at $13,310.</p>

      <p>What is the CAGR for both accounts? Exactly 10%. However, Investor A slept peacefully every night, while Investor B suffered heart palpitations and sheer panic for two years. CAGR mathematically smooths over that pain. This is why professionals never look at CAGR in isolation—they always pair it with risk metrics like standard deviation or the Sharpe ratio.</p>

      <h3>2. The "Point-to-Point" Trap</h3>
      <p>CAGR only cares about two numbers: the exact value on Day 1 and the exact value on the final day. It is completely blind to what happens in between. This means you can manipulate the results simply by picking convenient start or end dates.</p>

      <p>If you calculate the CAGR of the stock market starting at the absolute bottom of the 2008 financial crisis and ending at the peak of a bull market, you will get an astronomically high number. Conversely, if you start your measurement right before a crash, your CAGR will look dismal. Always measure CAGR over long timeframes—ideally 10+ years—to dilute the impact of an unlucky start date.</p>

      <h3>3. Ignoring Cash Flows (Deposits and Withdrawals)</h3>
      <p>The standard CAGR formula assumes you made one initial lump-sum investment and never touched the account again. But in reality, most people add money to their portfolios every month through their paychecks, or they withdraw money in retirement.</p>

      <p>If you start with $10,000, add $5,000 a year for five years, and end up with $40,000, plugging 10,000 as your Beginning Value and 40,000 as your Ending Value into the CAGR formula will spit out a falsely inflated 31.95% return. That isn't investment growth—that is mostly your own money being deposited. If you are making regular deposits or withdrawals, you need to use a more complex metric called the Internal Rate of Return (IRR), not CAGR.</p>

      <h2>Practical Tips for Using CAGR Like a Pro</h2>
      <p>To get the most out of your CAGR calculations, financial advisors and experienced investors stick to a few critical rules of thumb.</p>

      <p><strong>1. Always Adjust for Inflation (Real Return):</strong> A 10% CAGR looks fantastic on paper, but if inflation was running at 4% a year during that same decade, your actual purchasing power only grew by about 6%. The standard formula spits out your <em>nominal</em> return. Professionals always calculate the <em>real</em> return by subtracting the average inflation rate over the period to see if their wealth is genuinely increasing.</p>

      <p><strong>2. Account for Reinvested Dividends:</strong> The S&P 500's long-term historical average of around 10% is only true if you reinvest every single dividend. If you use a stock's historical price chart to find the beginning and ending value, you are only calculating capital appreciation. Always make sure your Ending Value includes all dividends, interest, or stock splits (see our <a href="/stock-split-calculator">stock split calculator</a>) if you want an accurate measure of total return.</p>

      <p><strong>3. Use the Rule of 72 as a Shortcut:</strong> If you don't have a calculator handy, use the Rule of 72. Divide 72 by your expected CAGR to estimate how many years it will take to double your money. If your portfolio has a 9% CAGR, <code>72 / 9 = 8</code>. It will take approximately 8 years to turn $10,000 into $20,000. It is a brilliant, quick mental check used by bankers worldwide.</p>

      <p><strong>4. Don't Extrapolate the Short Term:</strong> A common rookie mistake is taking a stellar 1-year or 2-year CAGR and assuming it will continue indefinitely. Just because your tech stock went from $50 to $100 in two years (a 41% CAGR) does not mean it will grow at 41% for the next decade. Reversion to the mean is a powerful force in finance. Always use conservative, long-term historical averages when projecting future wealth.</p>

      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>What is a good CAGR for a stock portfolio?</h3>
          <p>Historically, the S&P 500 has returned a CAGR of about 7% to 10% per year after adjusting for inflation. Any return consistently above this benchmark over a long period (10+ years) is considered excellent. However, a "good" CAGR also depends on your risk tolerance. A conservative portfolio heavy in bonds will naturally have a lower, but safer, CAGR than an aggressive all-equity portfolio.</p>
        </div>

        <div class="faq-item">
          <h3>Does CAGR account for inflation?</h3>
          <p>No, standard CAGR only calculates the nominal growth rate based on starting and ending values. To find the real return, you must manually subtract the inflation rate from your nominal CAGR. For example, a 9% nominal CAGR during a period of 3% inflation yields roughly a 6% real return.</p>
        </div>

        <div class="faq-item">
          <h3>Can a CAGR be negative?</h3>
          <p>Yes. If the ending value of an investment is lower than its beginning value, the CAGR will be a negative percentage. This indicates the average annual loss over that time period. For instance, if a $10,000 investment falls to $8,000 over 5 years, the CAGR is approximately -4.36%.</p>
        </div>

        <div class="faq-item">
          <h3>What is the difference between ROI and CAGR?</h3>
          <p>ROI (Return on Investment) measures the total growth from start to finish without considering how long it took. A 50% ROI over one year is vastly different from a 50% ROI over ten years. CAGR solves this by smoothing that total return into an annualized average, giving you a standardized rate per year, making it far superior for comparing investments over different time horizons.</p>
        </div>

        <div class="faq-item">
          <h3>Does CAGR assume you reinvest dividends?</h3>
          <p>It depends entirely on the "Ending Value" number you input. If the ending value includes reinvested dividends, then yes, the calculated CAGR reflects the total return. If you only input the stock price appreciation and exclude dividends, your CAGR will be artificially low. For accurate long-term calculations, always use total return values.</p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const startInput = document.getElementById('startValue');
      const endInput = document.getElementById('endValue');
      const yearsInput = document.getElementById('years');

      const cagrResult = document.getElementById('cagrResult');
      const roiResult = document.getElementById('roiResult');
      const multipleResult = document.getElementById('multipleResult');
      const errorMsg = document.getElementById('errorMsg');

      if (!startInput || !endInput || !yearsInput) return;

      function formatPercent(value) {
        return new Intl.NumberFormat('en-US', {
          style: 'percent',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
          signDisplay: 'auto'
        }).format(value);
      }

      function formatMultiple(value) {
        return new Intl.NumberFormat('en-US', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(value) + 'x';
      }

      function calculate() {
        const start = parseFloat(startInput.value);
        const end = parseFloat(endInput.value);
        const years = parseFloat(yearsInput.value);

        errorMsg.style.display = 'none';

        if (isNaN(start) || isNaN(end) || isNaN(years)) {
          showError("Please enter valid numbers for all fields.");
          return;
        }

        if (start <= 0) {
          showError("Beginning value must be greater than zero.");
          return;
        }

        if (years <= 0) {
          showError("Time period must be greater than zero.");
          return;
        }

        if (end < 0) {
          showError("Ending value cannot be negative.");
          return;
        }

        try {
          // Calculate CAGR: (End/Start)^(1/Years) - 1
          const cagr = Math.pow((end / start), (1 / years)) - 1;

          // Calculate ROI: (End - Start) / Start
          const roi = (end - start) / start;

          // Calculate Multiple: End / Start
          const multiple = end / start;

          cagrResult.textContent = formatPercent(cagr);
          roiResult.textContent = formatPercent(roi);
          multipleResult.textContent = formatMultiple(multiple);

          // Update colors based on positive/negative
          if (cagr >= 0) {
            cagrResult.style.color = 'var(--accent-color)';
            roiResult.style.color = 'var(--text-primary)';
          } else {
            cagrResult.style.color = 'var(--text-secondary)';
            roiResult.style.color = 'var(--text-secondary)';
          }
        } catch (e) {
          showError("Calculation error. Please check your inputs.");
        }
      }

      function showError(msg) {
        cagrResult.textContent = '---';
        roiResult.textContent = '---';
        multipleResult.textContent = '---';
        errorMsg.textContent = msg;
        errorMsg.style.display = 'block';
      }

      // Add event listeners for real-time calculation
      [startInput, endInput, yearsInput].forEach(input => {
        input.addEventListener('input', calculate);
      });

      // Initial calculation
      calculate();
    });
  </script>
</SiteLayout>
