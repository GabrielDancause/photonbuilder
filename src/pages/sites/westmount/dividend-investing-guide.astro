    const withdrawnResult = document.getElementById('withdrawnResult');
    const differenceResult = document.getElementById('differenceResult');

    if (!initialInvestmentInput) return;

    function calculate() {
      const initial = parseFloat(initialInvestmentInput.value) || 0;
      const contribution = parseFloat(annualContributionInput.value) || 0;
      const appRate = (parseFloat(stockPriceAppreciationInput.value) || 0) / 100;
      const yieldRate = (parseFloat(dividendYieldInput.value) || 0) / 100;
      const years = parseInt(yearsInput.value) || 0;

      // Arbitrary starting stock price to calculate explicit shares
      let stockPriceReinvest = 100;
      let stockPriceWithdrawn = 100;

      let sharesReinvest = initial / stockPriceReinvest;
      let sharesWithdrawn = initial / stockPriceWithdrawn;

      let cashWithdrawn = 0;

      for (let y = 1; y <= years; y++) {
        // Annual appreciation
        stockPriceReinvest *= (1 + appRate);
        stockPriceWithdrawn *= (1 + appRate);

        // Dividends are paid out based on current shares and price
        const dividendPerShareReinvest = stockPriceReinvest * yieldRate;
        const totalDividendReinvest = sharesReinvest * dividendPerShareReinvest;

        const dividendPerShareWithdrawn = stockPriceWithdrawn * yieldRate;
        const totalDividendWithdrawn = sharesWithdrawn * dividendPerShareWithdrawn;

        // DRIP: Reinvest dividends by buying more shares
        sharesReinvest += totalDividendReinvest / stockPriceReinvest;

        // No DRIP: Add to cash pile
        cashWithdrawn += totalDividendWithdrawn;

        // Add annual contribution at the end of the year, buying new shares
        sharesReinvest += contribution / stockPriceReinvest;
        sharesWithdrawn += contribution / stockPriceWithdrawn;
      }

      const finalReinvestedValue = sharesReinvest * stockPriceReinvest;
      // Total value = value of shares + cash pile from dividends
      const finalWithdrawnValue = (sharesWithdrawn * stockPriceWithdrawn) + cashWithdrawn;

      const difference = finalReinvestedValue - finalWithdrawnValue;

      reinvestedResult.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(finalReinvestedValue);
      withdrawnResult.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(finalWithdrawnValue);

      const diffFormatted = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(Math.abs(difference));
      differenceResult.textContent = difference >= 0 ? '+' + diffFormatted : '-' + diffFormatted;
    }

    // Attach event listeners
    [initialInvestmentInput, annualContributionInput, stockPriceAppreciationInput, dividendYieldInput, yearsInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  }

  // Astro view transitions support
  document.addEventListener('astro:page-load', initCalculator);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
