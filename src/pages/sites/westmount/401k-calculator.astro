---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "401k Calculator: See How Fast Your Retirement Savings Can Grow",
  description: "Calculate your 401(k) growth over time. Our free, interactive 401k calculator factors in your current balance, salary, employer match, and expected returns.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does a 401(k) match work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An employer match is when your company contributes money to your 401(k) based on how much you contribute. For example, a common match is 50% of your contributions up to 6% of your salary. If you earn $100,000 and contribute 6% ($6,000), your employer adds 50% of that ($3,000) for a total contribution of $9,000."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I contribute to my 401(k)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "At a minimum, you should try to contribute enough to get your full employer match, as this is essentially free money. Many financial advisors recommend saving 10% to 15% of your income for retirement, including any employer match."
      }
    },
    {
      "@type": "Question",
      "name": "What is the 401(k) contribution limit for 2024?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2024, the individual contribution limit for a 401(k) is $23,000. If you are age 50 or older, you can make an additional catch-up contribution of $7,500, bringing your total limit to $30,500. These limits do not include employer contributions."
      }
    },
    {
      "@type": "Question",
      "name": "Should I choose a Traditional or Roth 401(k)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Traditional 401(k) uses pre-tax dollars, lowering your current taxable income, but you pay taxes when you withdraw the money in retirement. A Roth 401(k) uses after-tax dollars, meaning no upfront tax break, but your withdrawals in retirement are tax-free. Choose Roth if you expect your tax rate to be higher in retirement, and Traditional if you expect it to be lower."
      }
    },
    {
      "@type": "Question",
      "name": "What happens to my 401(k) if I leave my job?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When you leave an employer, you generally have four options: leave the money in your old employer's plan (if permitted), roll it over to your new employer's 401(k), roll it over into an IRA, or cash it out. Cashing out is usually discouraged due to taxes and a 10% early withdrawal penalty if you are under age 59½."
      }
    }
  ]
});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/401k-calculator" schema={schema}>
  <div class="page-content">
    <h1>401(k) Retirement Calculator</h1>

    <div class="calculator-container">
      <div class="input-section">
        <div class="input-group">
          <label for="currentAge">Current Age</label>
          <div class="input-wrapper">
            <input type="number" id="currentAge" value="30" min="18" max="75">
            <span class="suffix">years</span>
          </div>
        </div>

        <div class="input-group">
          <label for="retirementAge">Retirement Age</label>
          <div class="input-wrapper">
            <input type="number" id="retirementAge" value="65" min="30" max="90">
            <span class="suffix">years</span>
          </div>
        </div>

        <div class="input-group">
          <label for="currentBalance">Current 401(k) Balance</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="currentBalance" value="50000" min="0" step="1000">
          </div>
        </div>

        <div class="input-group">
          <label for="annualSalary">Annual Salary</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="annualSalary" value="75000" min="0" step="1000">
          </div>
        </div>

        <div class="input-group">
          <label for="salaryIncrease">Expected Salary Increase</label>
          <div class="input-wrapper">
            <input type="number" id="salaryIncrease" value="2" min="0" max="20" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="contributionRate">Your Contribution Rate</label>
          <div class="input-wrapper">
            <input type="number" id="contributionRate" value="6" min="0" max="100" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="employerMatch">Employer Match</label>
          <div class="input-wrapper">
            <input type="number" id="employerMatch" value="50" min="0" max="200" step="1">
            <span class="suffix">%</span>
          </div>
          <p class="input-hint">Percentage matched on your contributions</p>
        </div>

        <div class="input-group">
          <label for="employerMaxMatch">Up to Salary Limit</label>
          <div class="input-wrapper">
            <input type="number" id="employerMaxMatch" value="6" min="0" max="20" step="0.5">
            <span class="suffix">%</span>
          </div>
          <p class="input-hint">Maximum salary % matched by employer</p>
        </div>

        <div class="input-group">
          <label for="annualReturn">Expected Annual Return</label>
          <div class="input-wrapper">
            <input type="number" id="annualReturn" value="7" min="0" max="20" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>
      </div>

      <div class="results-section">
        <div class="result-card primary-result">
          <h3>Total Estimated Balance</h3>
          <p class="big-number" id="totalBalanceDisplay">$0</p>
        </div>

        <div class="result-breakdown">
          <div class="breakdown-item">
            <span>Your Contributions</span>
            <span id="totalContributionsDisplay" class="value">$0</span>
          </div>
          <div class="breakdown-item">
            <span>Employer Match</span>
            <span id="totalMatchDisplay" class="value">$0</span>
          </div>
          <div class="breakdown-item">
            <span>Total Earnings</span>
            <span id="totalEarningsDisplay" class="value-highlight">$0</span>
          </div>
        </div>

        <div class="chart-container">
            <p style="text-align: center; font-size: 0.9em; opacity: 0.8; margin-bottom: 0.5rem;">Growth Over Time</p>
            <div id="growthChart" class="css-chart"></div>
        </div>
      </div>
    </div>

    <div class="educational-content">
      <h2>How the 401(k) Calculator Works</h2>
      <p>This 401(k) retirement calculator models the growth of your investments from your current age until retirement. It uses compound interest formulas alongside step-by-step annual increases to estimate your future balance. Here is a breakdown of the factors:</p>

      <ul>
        <li><strong>Current Balance:</strong> This is the foundation of your portfolio. The initial balance grows through compound interest each year even if no further contributions are made.</li>
        <li><strong>Salary & Contributions:</strong> Your contribution is a flat percentage of your gross annual salary. As your salary increases each year, the dollar amount you contribute increases automatically.</li>
        <li><strong>Employer Match:</strong> Many companies match a percentage of your contributions up to a certain percentage of your salary (e.g., matching 50% of what you put in, up to 6% of your salary). This "free money" is crucial for maximizing your return.</li>
        <li><strong>Expected Return:</strong> Historically, the stock market has returned about 7-10% per year before inflation. For conservative estimates, 6% to 8% is commonly used.</li>
      </ul>

      <h2>The Power of Compound Interest</h2>
      <p>The majority of a large 401(k) balance at retirement doesn't actually come from your contributions or your employer's match—it comes from investment earnings compounding over decades. When your initial investments earn a return, that larger balance earns a return the following year, creating an exponential growth curve.</p>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-section">
        <details>
          <summary>How does a 401(k) match work?</summary>
          <p>An employer match is when your company contributes money to your 401(k) based on how much you contribute. For example, a common match is 50% of your contributions up to 6% of your salary. If you earn $100,000 and contribute 6% ($6,000), your employer adds 50% of that ($3,000) for a total contribution of $9,000.</p>
        </details>
        <details>
          <summary>How much should I contribute to my 401(k)?</summary>
          <p>At a minimum, you should try to contribute enough to get your full employer match, as this is essentially free money. Many financial advisors recommend saving 10% to 15% of your income for retirement, including any employer match.</p>
        </details>
        <details>
          <summary>What is the 401(k) contribution limit for 2024?</summary>
          <p>For 2024, the individual contribution limit for a 401(k) is $23,000. If you are age 50 or older, you can make an additional catch-up contribution of $7,500, bringing your total limit to $30,500. These limits do not include employer contributions.</p>
        </details>
        <details>
          <summary>Should I choose a Traditional or Roth 401(k)?</summary>
          <p>A Traditional 401(k) uses pre-tax dollars, lowering your current taxable income, but you pay taxes when you withdraw the money in retirement. A Roth 401(k) uses after-tax dollars, meaning no upfront tax break, but your withdrawals in retirement are tax-free. Choose Roth if you expect your tax rate to be higher in retirement, and Traditional if you expect it to be lower.</p>
        </details>
        <details>
          <summary>What happens to my 401(k) if I leave my job?</summary>
          <p>When you leave an employer, you generally have four options: leave the money in your old employer's plan (if permitted), roll it over to your new employer's 401(k), roll it over into an IRA, or cash it out. Cashing out is usually discouraged due to taxes and a 10% early withdrawal penalty if you are under age 59½.</p>
        </details>
      </div>
    </div>
  </div>
</SiteLayout>

<style>
  .calculator-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin: 2rem 0;
  }

  @media (min-width: 768px) {
    .calculator-container {
      grid-template-columns: 1fr 1fr;
    }
  }

  .input-section, .results-section {
    background-color: var(--bg-card, #f9f9f9);
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid var(--border-color, #e5e7eb);
  }

  .input-group {
    margin-bottom: 1.25rem;
  }

  .input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    position: relative;
    background-color: var(--bg-input, #fff);
    border: 1px solid var(--border-color, #d1d5db);
    border-radius: 4px;
    overflow: hidden;
  }

  .input-wrapper:focus-within {
    border-color: var(--primary-color, #2563eb);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--primary-color, #2563eb) 20%, transparent);
  }

  .prefix, .suffix {
    padding: 0.5rem 0.75rem;
    color: var(--text-secondary);
    background-color: var(--bg-alt, #f3f4f6);
    font-size: 0.9rem;
  }

  .prefix {
    border-right: 1px solid var(--border-color, #d1d5db);
  }

  .suffix {
    border-left: 1px solid var(--border-color, #d1d5db);
  }

  .input-wrapper input {
    flex: 1;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: none;
    outline: none;
    background-color: transparent;
    color: var(--text-primary);
    font-size: 1rem;
    -moz-appearance: textfield;
  }

  .input-wrapper input::-webkit-outer-spin-button,
  .input-wrapper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .input-hint {
    margin-top: 0.25rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .result-card {
    background-color: var(--bg-alt, #f3f4f6);
    padding: 1.5rem;
    border-radius: 6px;
    text-align: center;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-color, #e5e7eb);
  }

  .primary-result {
    background-color: color-mix(in srgb, var(--primary-color, #2563eb) 10%, transparent);
    border-color: color-mix(in srgb, var(--primary-color, #2563eb) 30%, transparent);
  }

  .result-card h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
    color: var(--text-secondary);
  }

  .big-number {
    margin: 0;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--primary-color, #2563eb);
  }

  .result-breakdown {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .breakdown-item {
    display: flex;
    justify-content: space-between;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color, #e5e7eb);
    color: var(--text-primary);
  }

  .breakdown-item:last-child {
    border-bottom: none;
  }

  .value {
    font-weight: 600;
  }

  .value-highlight {
    font-weight: 700;
    color: var(--success-color, #16a34a);
  }

  .chart-container {
    margin-top: 1.5rem;
    height: 150px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .css-chart {
    display: flex;
    align-items: flex-end;
    height: 120px;
    gap: 2px;
    border-bottom: 1px solid var(--border-color, #d1d5db);
    border-left: 1px solid var(--border-color, #d1d5db);
    padding-left: 5px;
  }

  :global(.chart-bar) {
    flex: 1;
    background-color: var(--primary-color, #2563eb);
    min-width: 5px;
    border-radius: 2px 2px 0 0;
    transition: height 0.3s ease;
    opacity: 0.8;
  }

  :global(.chart-bar:hover) {
    opacity: 1;
  }

  .educational-content {
    margin-top: 3rem;
  }

  .educational-content h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .educational-content p, .educational-content ul {
    margin-bottom: 1rem;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .educational-content ul {
    padding-left: 1.5rem;
  }

  .educational-content li {
    margin-bottom: 0.5rem;
  }

  .faq-section {
    margin-top: 2rem;
  }

  details {
    margin-bottom: 1rem;
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 6px;
    background-color: var(--bg-card, #f9f9f9);
  }

  summary {
    padding: 1rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--text-primary);
    list-style: none;
    position: relative;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '+';
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.25rem;
    color: var(--text-secondary);
  }

  details[open] summary::after {
    content: '-';
  }

  details p {
    padding: 0 1rem 1rem 1rem;
    margin: 0;
    color: var(--text-secondary);
  }
</style>

<script>
  function init401kCalculator() {
    const inputs = [
      'currentAge', 'retirementAge', 'currentBalance',
      'annualSalary', 'salaryIncrease', 'contributionRate',
      'employerMatch', 'employerMaxMatch', 'annualReturn'
    ];

    const elements = {};
    let allFound = true;

    inputs.forEach(id => {
      elements[id] = document.getElementById(id);
      if (!elements[id]) allFound = false;
    });

    const displays = {
      totalBalance: document.getElementById('totalBalanceDisplay'),
      totalContributions: document.getElementById('totalContributionsDisplay'),
      totalMatch: document.getElementById('totalMatchDisplay'),
      totalEarnings: document.getElementById('totalEarningsDisplay'),
      chart: document.getElementById('growthChart')
    };

    if (!allFound || !displays.totalBalance) return;

    if (elements.currentAge.dataset.initialized) return;
    elements.currentAge.dataset.initialized = 'true';

    const formatCurrency = (val) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(val);
    };

    const calculate = () => {
      const currentAge = parseInt(elements.currentAge.value) || 0;
      const retirementAge = parseInt(elements.retirementAge.value) || 0;

      if (currentAge >= retirementAge) {
        displays.totalBalance.textContent = formatCurrency(parseFloat(elements.currentBalance.value) || 0);
        displays.totalContributions.textContent = formatCurrency(0);
        displays.totalMatch.textContent = formatCurrency(0);
        displays.totalEarnings.textContent = formatCurrency(0);
        displays.chart.innerHTML = '';
        return;
      }

      let balance = parseFloat(elements.currentBalance.value) || 0;
      let salary = parseFloat(elements.annualSalary.value) || 0;

      const salaryIncrease = (parseFloat(elements.salaryIncrease.value) || 0) / 100;
      const contributionRate = (parseFloat(elements.contributionRate.value) || 0) / 100;
      const employerMatchRate = (parseFloat(elements.employerMatch.value) || 0) / 100;
      const employerMaxMatch = (parseFloat(elements.employerMaxMatch.value) || 0) / 100;
      const returnRate = (parseFloat(elements.annualReturn.value) || 0) / 100;

      let totalContributions = 0;
      let totalMatch = 0;
      const initialBalance = balance;

      const years = retirementAge - currentAge;
      const chartData = [];

      for (let i = 0; i < years; i++) {
        // Contributions are spread throughout the year, so approximate by applying half a year's return
        const annualContribution = salary * contributionRate;
        totalContributions += annualContribution;

        // Calculate match
        const matchedContributionRate = Math.min(contributionRate, employerMaxMatch);
        const annualMatch = salary * matchedContributionRate * employerMatchRate;
        totalMatch += annualMatch;

        const totalAddition = annualContribution + annualMatch;

        // Compound interest: apply full return to beginning balance, half return to additions
        const earnings = (balance * returnRate) + (totalAddition * (returnRate / 2));
        balance += earnings + totalAddition;

        chartData.push(balance);

        // Increase salary for next year
        salary *= (1 + salaryIncrease);
      }

      const totalEarnings = balance - initialBalance - totalContributions - totalMatch;

      displays.totalBalance.textContent = formatCurrency(balance);
      displays.totalContributions.textContent = formatCurrency(totalContributions);
      displays.totalMatch.textContent = formatCurrency(totalMatch);
      displays.totalEarnings.textContent = formatCurrency(totalEarnings);

      // Update Chart
      displays.chart.innerHTML = '';
      if (chartData.length > 0) {
        const maxBalance = Math.max(...chartData);
        chartData.forEach(val => {
          const heightPercent = maxBalance > 0 ? (val / maxBalance) * 100 : 0;
          const bar = document.createElement('div');
          bar.className = 'chart-bar';
          bar.style.height = heightPercent + '%';
          displays.chart.appendChild(bar);
        });
      }
    };

    // Add event listeners
    Object.values(elements).forEach(el => {
      el.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  }

  document.addEventListener('DOMContentLoaded', init401kCalculator);
  document.addEventListener('astro:page-load', init401kCalculator);
</script>
