    .content-section h2 { font-size: 1.8rem; margin: 2rem 0 1rem; color: var(--text-primary); }
    .content-section p { margin-bottom: 1.2rem; line-height: 1.6; color: var(--text-secondary); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
