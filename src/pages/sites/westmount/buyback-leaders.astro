// Stats
function renderStats() {
  const r = DATA.results;
  const totalB = DATA.totalBuybacksB;
  const avgYield = DATA.avgBuybackYield;
  const medianReduction = DATA.medianSharesReduction;
  const topByYield = [...r].sort((a,b) => (b.buybackYield||0) - (a.buybackYield||0))[0];

  document.getElementById('statsGrid').innerHTML = `
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center"><div class="text-[32px] font-extrabold text-[var(--accent-color)] font-mono">$${totalB}B</div><div class="text-[13px] text-[#7a8ba8] mt-1">Total Buybacks (TTM)</div></div>
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center"><div class="text-[32px] font-extrabold text-[var(--accent-color)] font-mono">${r.length}</div><div class="text-[13px] text-[#7a8ba8] mt-1">Companies Tracked</div></div>
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center"><div class="text-[32px] font-extrabold text-[var(--accent-color)] font-mono">${avgYield}%</div><div class="text-[13px] text-[#7a8ba8] mt-1">Average Buyback Yield</div></div>
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center"><div class="text-[32px] font-extrabold text-[var(--accent-color)] font-mono">${medianReduction}%</div><div class="text-[13px] text-[#7a8ba8] mt-1">Median Share Reduction</div></div>
  `;
}

// Bar chart - Top 20 by amount
function renderBarChart() {
  const top20 = DATA.results.slice(0, 20);
  const maxVal = Math.max(...top20.map(s => s.buybackAmountB));
  const colors = ['#4a8fe7','#3b82f6','#2563eb','#1d4ed8','#6366f1','#818cf8','#22c55e','#14b8a6','#06b6d4','#0ea5e9','#8b5cf6','#a855f7','#ec4899','#f43f5e','#ef4444','#f97316','#eab308','#84cc16','#10b981','#06b6d4'];

  document.getElementById('barChart').innerHTML = top20.map((s, i) => {
    const pct = (s.buybackAmountB / maxVal * 100).toFixed(1);
    return `<div class="flex items-center gap-3 text-[13px]">
      <div class="w-[80px] sm:w-[60px] text-right font-mono font-medium text-white shrink-0 sm:text-[11px]">${s.ticker}</div>
      <div class="flex-1 h-[28px] bg-[rgba(74,143,231,0.08)] rounded relative overflow-hidden">
        <div class="h-full rounded flex items-center pl-2 text-[12px] font-semibold font-mono text-white min-w-[45px] transition-[width] duration-600 ease-out" style="width:${pct}%;background:${colors[i%colors.length]}">$${s.buybackAmountB}B</div>
      </div>
      <div class="w-[180px] text-[12px] text-[#7a8ba8] overflow-hidden text-ellipsis whitespace-nowrap shrink-0 sm:hidden">${s.company}</div>
    </div>`;
  }).join('');
}

