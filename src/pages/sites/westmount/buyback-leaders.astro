// Sector bars
function renderSectorBars() {
  const sectors = DATA.sectorSummary;
  const maxVal = Math.max(...sectors.map(s => s.totalBuybacksB));
  const sectorColors = {
    'Information Technology': '#4a8fe7',
    'Communication Services': '#8b5cf6',
    'Financials': '#22c55e',
    'Energy': '#f97316',
    'Health Care': '#ec4899',
    'Consumer Discretionary': '#06b6d4',
    'Industrials': '#eab308',
    'Consumer Staples': '#14b8a6',
  };

  document.getElementById('sectorBars').innerHTML = sectors.map(s => {
    const pct = (s.totalBuybacksB / maxVal * 100).toFixed(1);
    const color = sectorColors[s.sector] || '#4a8fe7';
    return `<div class="flex items-center gap-3">
      <div class="w-[200px] sm:w-[120px] text-[13px] sm:text-[12px] text-[#7a8ba8] shrink-0 text-right">${s.sector}</div>
      <div class="flex-1 h-[32px] bg-[rgba(74,143,231,0.06)] rounded overflow-hidden">
        <div class="h-full rounded flex items-center pl-2.5 text-[12px] font-semibold font-mono text-white min-w-[50px]" style="width:${pct}%;background:${color}">$${s.totalBuybacksB}B</div>
      </div>
      <div class="w-[100px] text-[12px] text-[#7a8ba8] sm:hidden">${s.companies} companies</div>
    </div>`;
  }).join('');
}

// Key findings
function renderFindings() {
  const r = DATA.results;
  const top3 = r.slice(0, 3);
  const top3Total = top3.reduce((a, s) => a + s.buybackAmountB, 0);
  const top3Pct = (top3Total / DATA.totalBuybacksB * 100).toFixed(0);
  
  const byYield = [...r].sort((a,b) => (b.buybackYield||0) - (a.buybackYield||0));
  const byReduction = [...r].sort((a,b) => (b.sharesReductionPct||0) - (a.sharesReductionPct||0));
  
  const topSector = DATA.sectorSummary[0];
  const highYield = r.filter(s => (s.buybackYield||0) > 5).length;
  const zeroDiv = r.filter(s => !s.dividendYield || s.dividendYield === 0).length;

  const findings = [
    `<strong>Apple dominates</strong> with $94B in buybacks — more than the GDP of many countries. The top 3 spenders (AAPL, GOOGL, META) account for $${top3Total}B, or ${top3Pct}% of the total $${DATA.totalBuybacksB}B tracked. Mega-cap tech's cash generation is in a league of its own.`,
    `<strong>Buyback yield tells a different story than raw dollars.</strong> Marathon Petroleum (MPC) leads with a 15.38% buyback yield despite spending "only" $10B — because its $65B market cap means each dollar of buybacks has outsized impact. GM (8.82%), Cigna (8.33%), and Synchrony (8.33%) also stand out as aggressive repurchasers relative to their size.`,
    `<strong>${topSector.sector} leads sector buybacks</strong> at $${topSector.totalBuybacksB}B across ${topSector.companies} companies. Tech companies generate enormous free cash flow but face a "return or invest" dilemma — buybacks signal confidence that the stock is undervalued, or simply that the company can't deploy capital at higher returns.`,
    `<strong>${highYield} companies have buyback yields above 5%</strong>, meaning they're repurchasing more than 5% of their market cap annually. At this pace, these companies could buy back all their shares within 20 years. The most aggressive — MPC at 12.5% share reduction — is literally shrinking its equity base at an extraordinary rate.`,
    `<strong>Buybacks now dwarf dividends for many companies.</strong> ${zeroDiv} companies in our study pay zero dividends, relying entirely on buybacks for capital return. Even among dividend payers, buyback yield often exceeds dividend yield — Comcast returns 6.52% via buybacks vs 3.55% in dividends, and Lowe's returns 6.03% vs 1.72%.`
  ];

  document.getElementById('findingsContainer').innerHTML = findings.map((f, i) =>
    `<div class="flex gap-3 mb-4 pb-4 border-b border-[var(--border-color)] last:border-b-0 last:mb-0 last:pb-0"><div class="w-7 h-7 bg-[rgba(74,143,231,0.15)] text-[var(--accent-color)] rounded-full flex items-center justify-center text-[13px] font-bold shrink-0">${i+1}</div><div class="text-[15px] leading-relaxed [&>strong]:text-white">${f}</div></div>`
  ).join('');
}

// Table
let sortCol = 'buybackAmountB';
let sortDir = 'desc';

function renderTable() {
  const r = [...DATA.results];
  const sectorVal = document.getElementById('sectorFilter').value;
  const search = document.getElementById('searchInput').value.toLowerCase();

  let filtered = r.filter(s => {
    if (sectorVal && s.sector !== sectorVal) return false;
    if (search && !s.ticker.toLowerCase().includes(search) && !(s.company||'').toLowerCase().includes(search)) return false;
    return true;
  });

  filtered.sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (va === null || va === undefined) va = sortDir === 'asc' ? Infinity : -Infinity;
    if (vb === null || vb === undefined) vb = sortDir === 'asc' ? Infinity : -Infinity;
    if (typeof va === 'string') return sortDir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
    return sortDir === 'asc' ? va - vb : vb - va;
  });

  const maxYield = Math.max(...filtered.map(s => s.buybackYield || 0));

  document.getElementById('tableBody').innerHTML = filtered.map((s, i) => {
    const yieldW = ((s.buybackYield||0) / maxYield * 60).toFixed(0);
    const yieldColor = (s.buybackYield||0) > 5 ? '#22c55e' : (s.buybackYield||0) > 2 ? 'var(--accent-color)' : '#7a8ba8';
    return `<tr class="hover:bg-[rgba(74,143,231,0.04)]">
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right">${i+1}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-bold text-[var(--accent-color)] font-mono">${s.ticker}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap">${s.company || '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap text-[12px] text-[#7a8ba8]">${s.sector || '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right">$${s.buybackAmountB}B</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right"><span class="inline-block h-2 rounded-full mr-2 align-middle" style="width:${yieldW}px;background:${yieldColor}"></span>${s.buybackYield !== null ? s.buybackYield + '%' : '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right">${s.sharesReductionPct !== null ? s.sharesReductionPct + '%' : '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right text-[#22c55e]">${s.totalReturnYield !== null ? s.totalReturnYield + '%' : '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right">${s.dividendYield !== null ? s.dividendYield + '%' : '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right">${s.marketCapB ? '$' + s.marketCapB.toLocaleString() + 'B' : '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right">${s.peRatio !== null ? s.peRatio : '—'}</td>
      <td class="py-2.5 px-4 border-b border-[var(--border-color)] whitespace-nowrap font-mono text-[12px] text-right text-[#22c55e]">${s.epsGrowth !== null ? '+' + s.epsGrowth + '%' : '—'}</td>
    </tr>`;
  }).join('');

  document.querySelectorAll('thead th').forEach(th => {
    th.classList.remove('sorted-asc', 'sorted-desc');
    if (th.dataset.col === sortCol) th.classList.add(sortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
  });
}

// Init filters
function initFilters() {
  const sectors = [...new Set(DATA.results.map(s => s.sector).filter(Boolean))].sort();
  const sel = document.getElementById('sectorFilter');
  sectors.forEach(s => {
    const opt = document.createElement('option');
    opt.value = s; opt.textContent = s;
    sel.appendChild(opt);
  });
}

// Sort handlers
document.querySelectorAll('thead th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    if (!col) return;
    if (sortCol === col) sortDir = sortDir === 'desc' ? 'asc' : 'desc';
    else { sortCol = col; sortDir = th.dataset.type === 'num' ? 'desc' : 'asc'; }
    renderTable();
  });
});

document.getElementById('sectorFilter').addEventListener('change', renderTable);
document.getElementById('searchInput').addEventListener('input', renderTable);
document.getElementById('sortPreset').addEventListener('change', function() {
  sortCol = this.value;
  sortDir = 'desc';
  renderTable();
});

// Init
initFilters();
renderStats();
renderBarChart();
renderYieldChart();
renderSectorBars();
renderFindings();
renderTable();
  </script>
</SiteLayout>
