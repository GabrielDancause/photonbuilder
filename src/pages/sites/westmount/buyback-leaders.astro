  const colors = ['#22c55e','#16a34a','#15803d','#14532d','#10b981','#059669','#047857','#065f46','#34d399','#6ee7b7','#a7f3d0','#84cc16','#65a30d','#4d7c0f','#22d3ee','#06b6d4','#0891b2','#0e7490','#155e75','#164e63'];

  document.getElementById('yieldChart').innerHTML = byYield.map((s, i) => {
