<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const slider = document.getElementById('revenue-slider');
    const revenueDisplay = document.getElementById('revenue-display');
    
    // Calculator elements
    const calcRevenue = document.getElementById('calc-revenue');
    const calcCogs = document.getElementById('calc-cogs');
    const calcGross = document.getElementById('calc-gross');
    const calcGrossMargin = document.getElementById('calc-gross-margin');
    const calcOpex = document.getElementById('calc-opex');
    const calcOperating = document.getElementById('calc-operating');
    const calcOperatingMargin = document.getElementById('calc-operating-margin');
    const calcTaxes = document.getElementById('calc-taxes');
    const calcNet = document.getElementById('calc-net');
    const calcNetMargin = document.getElementById('calc-net-margin');
    
    function updateCalculator() {
      const revenue = parseInt(slider.value);
      
      // Fixed percentages for calculation
      const cogsPercent = 0.4; // 40%
      const opexFixed = 25; // Fixed $25M
      const taxesFixed = 10; // Fixed $10M
      
      const cogs = Math.round(revenue * cogsPercent);
      const grossProfit = revenue - cogs;
      const grossMargin = Math.round((grossProfit / revenue) * 100);
      
      const operatingProfit = grossProfit - opexFixed;
      const operatingMargin = Math.round((operatingProfit / revenue) * 100);
      
      const netProfit = operatingProfit - taxesFixed;
      const netMargin = Math.round((netProfit / revenue) * 100);
      
      // Update display
      revenueDisplay.textContent = `$${revenue}M`;
      calcRevenue.textContent = `$${revenue}M`;
      calcCogs.textContent = `-$${cogs}M`;
      calcGross.textContent = `$${grossProfit}M`;
      calcGrossMargin.textContent = `(${grossMargin}%)`;
      calcOpex.textContent = `-$${opexFixed}M`;
      calcOperating.textContent = `$${operatingProfit}M`;
      calcOperatingMargin.textContent = `(${operatingMargin}%)`;
      calcTaxes.textContent = `-$${taxesFixed}M`;
      calcNet.textContent = `$${netProfit}M`;
      calcNetMargin.textContent = `(${netMargin}%)`;
    }
    
    slider.addEventListener('input', updateCalculator);
    
    // Initialize
    updateCalculator();
  });
</script>