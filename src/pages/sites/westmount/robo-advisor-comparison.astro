document.getElementById('h2hBtn').addEventListener('click',()=>{
  const picks=[ROBOS[h2h1.value],ROBOS[h2h2.value]];
  if(h2h3.value) picks.push(ROBOS[h2h3.value]);
  const metrics=[
    {label:"Management Fee",key:"feeNote",fmt:v=>v,best:null},
    {label:"Fee (numeric)",key:"fee",fmt:v=>v===0?'Free':v.toFixed(2)+'%',best:"min"},
    {label:"Account Minimum",key:"minimum",fmt:v=>v===0?'$0':'$'+v.toLocaleString(),best:"min"},
    {label:"Tax-Loss Harvesting",key:"tlh",fmt:v=>v,best:null},
    {label:"Human Advisor",key:"humanNote",fmt:v=>v,best:null},
    {label:"Direct Indexing",key:"directIndexing",fmt:v=>v,best:null},
    {label:"Rebalancing",key:"rebalancing",fmt:v=>v,best:null},
    {label:"ESG / SRI Options",key:"socResponsible",fmt:v=>v,best:null},
    {label:"Cash Management",key:"cashMgmt",fmt:v=>v,best:null},
    {label:"Account Types",key:"accountTypes",fmt:v=>v,best:null},
    {label:"Underlying ETF Costs",key:"etfER",fmt:v=>v,best:null},
    {label:"AUM ($B)",key:"aum",fmt:v=>"$"+v+"B",best:"max"},
    {label:"Founded",key:"founded",fmt:v=>v,best:"min"},
    {label:"Best For",key:"bestFor",fmt:v=>v,best:null}
  ];
  let html=`<div class="comparison-wrap"><table><thead><tr><th>Feature</th>${picks.map(p=>`<th>${p.name}</th>`).join('')}</tr></thead><tbody>`;
  metrics.forEach(m=>{
    const vals=picks.map(p=>p[m.key]);
    let bestIdx=-1;
    if(m.best&&vals.every(v=>v!=null&&!isNaN(Number(v)))){
      const numVals=vals.map(Number);
      bestIdx=m.best==='max'?numVals.indexOf(Math.max(...numVals)):numVals.indexOf(Math.min(...numVals));
    }
    const isHighlight=["fee","minimum","tlh"].includes(m.key);
    html+=`<tr${isHighlight?' class="highlight-row"':''}>`;
    html+=`<td><strong>${m.label}</strong></td>`;
    picks.forEach((p,i)=>{
      html+=`<td class="${i===bestIdx?'winner':''}">${m.fmt(p[m.key])}</td>`;
    });
    html+=`</tr>`;
  });
  html+=`</tbody></table></div>`;
  document.getElementById('h2hResult').innerHTML=html;
});
document.getElementById('h2hBtn').click();

