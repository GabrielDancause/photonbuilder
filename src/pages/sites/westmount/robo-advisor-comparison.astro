---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is the best robo-advisor in 2026?","acceptedAnswer":{"@type":"Answer","text":"Wealthfront and Betterment are the two best robo-advisors in 2026. Wealthfront charges 0.25% with a $500 minimum and offers excellent tax-loss harvesting plus direct indexing for accounts over $100K. Betterment charges 0.25% with no minimum and provides optional human advisor access. For hands-off investing with zero fees, Schwab Intelligent Portfolios is the best free option (requires $5,000 minimum)."}},
    {"@type":"Question","name":"Is Wealthsimple better than Betterment?","acceptedAnswer":{"@type":"Answer","text":"Wealthsimple and Betterment serve different markets. Wealthsimple is the top robo-advisor in Canada with no account minimum and a 0.40-0.50% management fee. Betterment focuses on the US market at 0.25% with more features like tax-loss harvesting on all taxable accounts. For US investors, Betterment offers better value. For Canadian investors, Wealthsimple is the clear leader with its integrated trading and banking platform."}},
    {"@type":"Question","name":"Wealthsimple vs Betterment: which should I choose?","acceptedAnswer":{"@type":"Answer","text":"Choose Wealthsimple if you are a Canadian investor — it is the dominant robo-advisor in Canada with commission-free trading, no minimum balance, and a comprehensive financial platform. Choose Betterment if you are a US investor — it charges 0.25%, has no minimum for the basic plan, offers robust tax-loss harvesting, and optional human advisor access. Both are excellent choices for their respective markets."}},
    {"@type":"Question","name":"Are robo-advisors worth the fees?","acceptedAnswer":{"@type":"Answer","text":"Robo-advisors are worth it for investors who want automated portfolio management, rebalancing, and tax optimization without having to do it themselves. At 0.25%, a robo-advisor costs $25/year per $10,000 invested. The tax-loss harvesting alone can offset the fee for taxable accounts. However, if you're comfortable managing a simple 3-fund portfolio yourself through Vanguard or Fidelity, you can save the management fee entirely."}},
    {"@type":"Question","name":"Which robo-advisor has the lowest fees?","acceptedAnswer":{"@type":"Answer","text":"Schwab Intelligent Portfolios charges $0 in management fees (requires $5,000 minimum). SoFi Automated Investing also charges 0% with no minimum. Among paid robo-advisors, Wealthfront and Betterment both charge 0.25%. Vanguard Digital Advisor charges 0.20% (approximately, after underlying fund fees). Note that all robo-advisors still have underlying ETF expense ratios averaging 0.05-0.15%."}},
    {"@type":"Question","name":"Do robo-advisors beat the S&P 500?","acceptedAnswer":{"@type":"Answer","text":"Most robo-advisors do not consistently beat the S&P 500 because they use diversified portfolios that include bonds, international stocks, and other asset classes that have underperformed US large caps recently. However, robo-advisors aim for risk-adjusted returns, not maximum returns. A 60/40 stock/bond portfolio will lag a pure S&P 500 fund in bull markets but lose less in downturns. The value is in disciplined asset allocation, not beating a single index."}},
    {"@type":"Question","name":"Can I lose money with a robo-advisor?","acceptedAnswer":{"@type":"Answer","text":"Yes, you can lose money with a robo-advisor. Robo-advisors invest in stocks and bonds which fluctuate in value. During market downturns, your portfolio will decline. However, robo-advisors are designed to manage risk through diversification and automatic rebalancing. Historically, diversified portfolios have always recovered from downturns given enough time. The key is choosing a risk level appropriate for your timeline and not panic-selling during declines."}},
    {"@type":"Question","name":"What is tax-loss harvesting and which robo-advisors offer it?","acceptedAnswer":{"@type":"Answer","text":"Tax-loss harvesting is a strategy that sells investments at a loss to offset capital gains taxes, then immediately buys a similar (but not identical) investment to maintain your allocation. It can save 0.5-1.5% annually in taxable accounts. Wealthfront, Betterment, Wealthsimple, and Vanguard Digital Advisor all offer automated tax-loss harvesting. Schwab Intelligent Portfolios offers it on accounts over $50,000. Fidelity Go and Acorns do not offer it."}}
  ]
};

export const meta = {
  title: "Robo-Advisor Comparison 2026",
  description: "Compare 10 robo-advisors side-by-side: Wealthsimple, Betterment, Wealthfront, Vanguard, Schwab & more. Fees, minimums, features, and category winners.",
  category: "list",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="Best Robo-Advisors 2026: 10 Platforms Compared by Fees, Features & Performance"
  description="Wealthfront and Betterment both charge 0.25% — but which is better? Compare 10 robo-advisors across management fees, account minimums, tax-loss harvesting, human advisor access, and more."
  canonical="https://westmountfundamentals.com/robo-advisor-comparison" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
header h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
header p.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.meta{color:var(--text-secondary);font-size:13px;margin-top:12px;font-family:'JetBrains Mono',monospace}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:32px 0}
.stat{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.stat .val{font-size:32px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.stat .label{font-size:13px;color:var(--text-secondary);margin-top:4px}

.table-section{margin:32px 0}
.table-section h2{font-size:22px;margin-bottom:12px}
.controls{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.controls select,.controls input{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 12px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif}
.controls input{min-width:200px}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--border-color);user-select:none;position:sticky;top:0}
th:hover{color:var(--accent-color)}
th.sorted-asc::after{content:' ▲';color:var(--accent-color)}
th.sorted-desc::after{content:' ▼';color:var(--accent-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color);white-space:nowrap}
tr:hover{background:rgba(74,143,231,.06)}
.name{font-weight:600;color:var(--accent-color)}
.num{font-family:'JetBrains Mono',monospace;text-align:right}
.fee-free{color:#22c55e}
.fee-low{color:#22c55e}
.fee-mid{color:#eab308}
.fee-high{color:#ef4444}
.yes{color:#22c55e;font-weight:600}
.no{color:#ef4444}
.partial{color:#eab308}
.best-for{font-size:12px;color:var(--text-secondary)}

.h2h-section{margin:32px 0}
.h2h-section h2{font-size:22px;margin-bottom:6px}
.h2h-section .section-desc{color:var(--text-secondary);font-size:14px;margin-bottom:16px}
.h2h-controls{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.h2h-controls select{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 12px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif}
.h2h-controls button{background:var(--accent-color);color:#fff;border:none;padding:8px 18px;border-radius:6px;font-size:14px;cursor:pointer;font-weight:600}
.h2h-controls button:hover{opacity:.9}
.comparison-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
.comparison-wrap table{width:100%;border-collapse:collapse;font-size:13px}
.comparison-wrap th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;border-bottom:1px solid var(--border-color)}
.comparison-wrap td{padding:10px 14px;border-bottom:1px solid var(--border-color)}
.comparison-wrap tr:hover{background:rgba(74,143,231,.06)}
.winner{color:#22c55e;font-weight:700}
.highlight-row{background:rgba(34,197,94,.04)}

.picks-section{margin:32px 0}
.picks-section h2{font-size:22px;margin-bottom:16px}
.picks-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px}
.pick-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px}
.pick-card .pick-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--accent-color);margin-bottom:8px}
.pick-card .pick-name{font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:800;margin-bottom:4px}
.pick-card .pick-sub{font-size:13px;color:var(--text-secondary);margin-bottom:10px}
.pick-card .pick-stats{font-size:12px;color:var(--text-secondary);line-height:1.8}
.pick-card .pick-stats strong{color:var(--text-primary)}

.guide-section{margin:32px 0}
.guide-section h2{font-size:22px;margin-bottom:16px}
.guide-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px}
.guide-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.guide-card h3{font-size:17px;margin-bottom:8px;color:var(--accent-color)}
.guide-card p{color:var(--text-secondary);font-size:14px;line-height:1.7;margin-bottom:10px}
.guide-card .pros-cons{font-size:13px;line-height:1.8}
.guide-card .pro{color:#22c55e}
.guide-card .con{color:#ef4444}

.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px}

.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

.related-section{margin:32px 0}
.related-section h2{font-size:22px;margin-bottom:16px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.related-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px;text-decoration:none;transition:border-color .2s}
.related-card:hover{border-color:var(--accent-color);text-decoration:none}
.related-card h3{font-size:15px;margin-bottom:4px;color:var(--text-primary)}
.related-card p{font-size:13px;color:var(--text-secondary)}

.methodology{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.methodology h2{font-size:18px;margin-bottom:12px}
.methodology p{color:var(--text-secondary);font-size:14px;margin-bottom:10px;line-height:1.7}

.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}
.updated-badge{display:inline-block;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-secondary);font-size:12px;padding:4px 10px;border-radius:4px;margin-top:8px;font-family:'JetBrains Mono',monospace}

footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:640px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .controls,.h2h-controls{flex-direction:column}
  .controls input,.controls select,.h2h-controls select{width:100%}
  .picks-grid{grid-template-columns:1fr}
  .guide-cards{grid-template-columns:1fr}
}
  </style>

<div class="container">
    <h1>Best Robo-Advisors 2026: 10 Platforms Compared by Fees, Features &amp; Performance</h1>

<div class="updated-badge">Last Updated: March 2026</div>

<div class="stats" id="stats"></div>

<div class="table-section">
  <h2>All 10 Robo-Advisors Compared</h2>
  <div class="controls">
    <input type="text" id="search" placeholder="Search by name…">
    <select id="feeFilter">
      <option value="">Any Fee</option>
      <option value="free">Free (0%)</option>
      <option value="low">Low (0.15–0.25%)</option>
      <option value="mid">Mid (0.25–0.50%)</option>
      <option value="high">High (0.50%+)</option>
    </select>
    <select id="tlhFilter">
      <option value="">Tax-Loss Harvesting</option>
      <option value="Yes">Yes</option>
      <option value="No">No</option>
    </select>
    <select id="humanFilter">
      <option value="">Human Advisor</option>
      <option value="Yes">Has Human Access</option>
      <option value="No">No Human Access</option>
    </select>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th data-key="name">Name</th>
          <th data-key="fee" data-type="num">Mgmt Fee</th>
          <th data-key="minimum" data-type="num">Account Min</th>
          <th data-key="tlh">Tax-Loss Harvesting</th>
          <th data-key="humanAdvisor">Human Advisor</th>
          <th data-key="accountTypes">Account Types</th>
          <th data-key="bestFor">Best For</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>
</div>

<div class="h2h-section">
  <h2>Head-to-Head Robo-Advisor Comparison</h2>
  <p class="section-desc">Select 2 or 3 robo-advisors to compare side-by-side across every feature.</p>
  <div class="h2h-controls">
    <select id="h2h1"></select>
    <select id="h2h2"></select>
    <select id="h2h3"><option value="">— Optional 3rd —</option></select>
    <button id="h2hBtn">Compare</button>
  </div>
  <div id="h2hResult"></div>
</div>

<div class="picks-section">
  <h2>2026 Robo-Advisor Category Winners</h2>
  <div class="picks-grid" id="picks"></div>
</div>

<div class="guide-section">
  <h2>Robo-Advisor Investor Guide</h2>
  <div class="guide-cards" id="guides"></div>
</div>

<div class="findings">
  <h2>Key Findings</h2>
  <div id="findingsContent"></div>
</div>

<div class="faq-section">
  <h2>Frequently Asked Questions</h2>
  <div id="faq"></div>
</div>

<div class="related-section">
  <h2>Related Tools &amp; Research</h2>
  <div class="related-grid">
    <a class="related-card" href="/best-index-funds">
      <h3>Best Index Funds 2026</h3>
      <p>Compare 20 index funds side-by-side: VOO, VTI, FXAIX & more by cost, returns, and category.</p>
    </a>
    <a class="related-card" href="/dividend-etf-comparison">
      <h3>Dividend ETF Comparison</h3>
      <p>Compare 21 dividend ETFs by yield, cost, and total returns side-by-side.</p>
    </a>
  </div>
</div>

<div class="methodology">
  <h2>Methodology</h2>
  <p>Management fees reflect current pricing as of Q1 2026 and do not include underlying ETF expense ratios (typically 0.05–0.15% additional). Account minimums and features are based on each platform's standard/basic tier unless noted otherwise.</p>
  <p>All 10 robo-advisors were selected based on assets under management, market share, and relevance to passive investors seeking automated portfolio management. Feature availability may vary by account type and balance.</p>
</div>

<div class="disclaimer">This site provides data for informational purposes only. Not investment advice. Past performance does not guarantee future results. Robo-advisor features and fees are subject to change.</div>

</div>
  <script is:inline>
const ROBOS = [
  {name:"Wealthsimple",fee:0.40,feeNote:"0.40% (Basic); 0.30% (Premium $100K+)",minimum:0,tlh:"Yes",humanAdvisor:"Premium only",humanNote:"Available on Premium tier ($100K+)",accountTypes:"TFSA, RRSP, RESP, taxable, joint",bestFor:"Canadian investors",directIndexing:"No",rebalancing:"Automatic",socResponsible:"Yes",cashMgmt:"Yes (Save account)",founded:2014,aum:40,country:"Canada",etfER:"0.15–0.25%"},
  {name:"Betterment",fee:0.25,feeNote:"0.25% (Digital); 0.65% (Premium w/ CFP)",minimum:0,tlh:"Yes",humanAdvisor:"Premium only",humanNote:"Unlimited CFP access on Premium ($100K+ or $65/mo)",accountTypes:"IRA, Roth IRA, taxable, joint, trust, 401(k)",bestFor:"US hands-off investors",directIndexing:"No",rebalancing:"Automatic",socResponsible:"Yes",cashMgmt:"Yes (Cash Reserve)",founded:2010,aum:42,country:"USA",etfER:"0.05–0.15%"},
  {name:"Wealthfront",fee:0.25,feeNote:"0.25% flat fee",minimum:500,tlh:"Yes",humanAdvisor:"No",humanNote:"No human advisor access",accountTypes:"IRA, Roth IRA, taxable, 529, trust",bestFor:"Tax optimization & direct indexing",directIndexing:"Yes ($100K+)",rebalancing:"Automatic",socResponsible:"Yes",cashMgmt:"Yes (Cash Account 4.5% APY)",founded:2011,aum:50,country:"USA",etfER:"0.05–0.12%"},
  {name:"Vanguard Digital Advisor",fee:0.20,feeNote:"~0.20% (net advisory fee after fund credits)",minimum:3000,tlh:"Yes",humanAdvisor:"No",humanNote:"Upgrade to Personal Advisor for human access ($50K)",accountTypes:"IRA, Roth IRA, taxable, rollover IRA",bestFor:"Vanguard fund investors",directIndexing:"No",rebalancing:"Automatic",socResponsible:"No",cashMgmt:"No",founded:2020,aum:300,country:"USA",etfER:"0.04–0.08%"},
  {name:"Schwab Intelligent Portfolios",fee:0,feeNote:"$0 (free); Premium $30/mo for CFP access",minimum:5000,tlh:"Yes ($50K+)",humanAdvisor:"Premium only",humanNote:"Unlimited CFP access on Premium ($30/month)",accountTypes:"IRA, Roth IRA, taxable, trust, custodial",bestFor:"Fee-conscious investors ($5K+)",directIndexing:"No",rebalancing:"Automatic",socResponsible:"No",cashMgmt:"Yes (Intelligent Income)",founded:2015,aum:75,country:"USA",etfER:"0.03–0.20%"},
  {name:"Fidelity Go",fee:0,feeNote:"$0 (under $25K); 0.35% ($25K+, includes CFP)",minimum:0,tlh:"No",humanAdvisor:"Yes ($25K+)",humanNote:"CFP access included at $25K+",accountTypes:"IRA, Roth IRA, taxable, HSA, rollover IRA",bestFor:"Fidelity customers & beginners",directIndexing:"No",rebalancing:"Automatic",socResponsible:"Yes",cashMgmt:"No",founded:2016,aum:18,country:"USA",etfER:"0.00% (Fidelity ZERO funds)"},
  {name:"SoFi Automated Investing",fee:0,feeNote:"$0 (free)",minimum:0,tlh:"No",humanAdvisor:"Yes (free)",humanNote:"Free CFP access for all members",accountTypes:"IRA, Roth IRA, taxable, rollover IRA",bestFor:"Beginners wanting free everything",directIndexing:"No",rebalancing:"Automatic (quarterly)",socResponsible:"No",cashMgmt:"Yes (SoFi Banking)",founded:2017,aum:5,country:"USA",etfER:"0.03–0.10%"},
  {name:"M1 Finance",fee:0,feeNote:"$0 (free); M1 Plus $125/yr for extras",minimum:100,tlh:"No",humanAdvisor:"No",humanNote:"No human advisor access",accountTypes:"IRA, Roth IRA, taxable, trust, joint",bestFor:"DIY investors wanting automation",directIndexing:"No",rebalancing:"Dynamic (on deposits/withdrawals)",socResponsible:"Yes",cashMgmt:"Yes (M1 Spend)",founded:2015,aum:8,country:"USA",etfER:"0.03–0.20%"},
  {name:"Ellevest",fee:0.25,feeNote:"$12/mo (membership model)",minimum:0,tlh:"No",humanAdvisor:"Yes",humanNote:"1:1 coaching sessions included in membership",accountTypes:"IRA, Roth IRA, taxable",bestFor:"Women-focused financial planning",directIndexing:"No",rebalancing:"Automatic",socResponsible:"Yes (impact portfolios)",cashMgmt:"No",founded:2016,aum:2,country:"USA",etfER:"0.05–0.15%"},
  {name:"Acorns",fee:0.25,feeNote:"$3–12/mo (flat subscription)",minimum:0,tlh:"No",humanAdvisor:"No",humanNote:"No human advisor access",accountTypes:"IRA, taxable, custodial (Early)",bestFor:"Micro-investing & round-ups",directIndexing:"No",rebalancing:"Automatic",socResponsible:"Yes",cashMgmt:"Yes (Acorns Checking)",founded:2014,aum:7,country:"USA",etfER:"0.05–0.15%"}
];

// Stats
const freeCount = ROBOS.filter(r=>r.fee===0).length;
const lowestPaid = Math.min(...ROBOS.filter(r=>r.fee>0).map(r=>r.fee));
const tlhCount = ROBOS.filter(r=>r.tlh==="Yes"||r.tlh.startsWith("Yes")).length;
const totalAUM = ROBOS.reduce((a,r)=>a+r.aum,0);
document.getElementById('stats').innerHTML = `
  <div class="stat"><div class="val">${ROBOS.length}</div><div class="label">Robo-Advisors Compared</div></div>
  <div class="stat"><div class="val">${freeCount}</div><div class="label">Free Platforms ($0 Fee)</div></div>
  <div class="stat"><div class="val">${lowestPaid}%</div><div class="label">Lowest Paid Fee</div></div>
  <div class="stat"><div class="val">$${totalAUM}B+</div><div class="label">Combined AUM</div></div>
`;

// Table
const tbody = document.getElementById('tbody');
const searchEl = document.getElementById('search');
const feeFilter = document.getElementById('feeFilter');
const tlhFilterEl = document.getElementById('tlhFilter');
const humanFilterEl = document.getElementById('humanFilter');

let sortKey = 'aum', sortDir = -1;

function feeClass(v){return v===0?'fee-free':v<=0.25?'fee-low':v<=0.50?'fee-mid':'fee-high'}
function boolClass(v){return v==='Yes'?'yes':v==='No'?'no':'partial'}

function renderTable(){
  const q = searchEl.value.toLowerCase();
  const feef = feeFilter.value;
  const tlhf = tlhFilterEl.value;
  const humanf = humanFilterEl.value;
  let filtered = ROBOS.filter(r=>{
    if(q && !r.name.toLowerCase().includes(q)) return false;
    if(feef==='free' && r.fee!==0) return false;
    if(feef==='low' && (r.fee<0.15||r.fee>0.25)) return false;
    if(feef==='mid' && (r.fee<0.25||r.fee>0.50)) return false;
    if(feef==='high' && r.fee<=0.50) return false;
    if(tlhf==='Yes' && r.tlh==='No') return false;
    if(tlhf==='No' && r.tlh!=='No') return false;
    if(humanf==='Yes' && r.humanAdvisor==='No') return false;
    if(humanf==='No' && r.humanAdvisor!=='No') return false;
    return true;
  });
  filtered.sort((a,b)=>{
    let va=a[sortKey],vb=b[sortKey];
    if(va==null) return 1;if(vb==null) return -1;
    if(typeof va==='string') return va.localeCompare(vb)*sortDir;
    return (va-vb)*sortDir;
  });
  tbody.innerHTML = filtered.map(r=>`<tr>
    <td class="name">${r.name}</td>
    <td class="num ${feeClass(r.fee)}">${r.fee===0?'Free':r.fee.toFixed(2)+'%'}</td>
    <td class="num">${r.minimum===0?'$0':'$'+r.minimum.toLocaleString()}</td>
