  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('calc-btn');
        const divInput = document.getElementById('annual-div');
        const priceInput = document.getElementById('stock-price');
        const resultSpan = document.getElementById('yield-result');

        btn.addEventListener('click', () => {
            const div = parseFloat(divInput.value);
            const price = parseFloat(priceInput.value);

            if (isNaN(div) || isNaN(price) || price <= 0) {
                resultSpan.textContent = 'Invalid Input';
                return;
            }

            const yieldVal = (div / price) * 100;
            let fixed = parseFloat(yieldVal.toPrecision(14));
            if (Math.abs(fixed - Math.round(fixed)) < 1e-14) {
                fixed = Math.round(fixed);
            }
            resultSpan.textContent = fixed.toFixed(2) + '%';
        });
    });
  </script>
