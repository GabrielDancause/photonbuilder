---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Student Loan Calculator | Estimate Monthly Payments & Interest",
  description: "Calculate your estimated monthly student loan payments, total interest costs, and payoff timelines with our free interactive student loan calculator.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How are student loan payments calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Student loan payments are typically calculated using a standard amortization formula. This factors in your total loan principal, the annual interest rate, and the repayment term (usually 10 to 25 years) to determine a fixed monthly payment that will pay off the loan entirely by the end of the term."
      }
    },
    {
      "@type": "Question",
      "name": "Can I pay off my student loans early?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, in most cases, you can pay off your student loans early without any prepayment penalties. Making extra payments directly to your principal can significantly reduce the total amount of interest you pay over the life of the loan and shorten your repayment timeline."
      }
    },
    {
      "@type": "Question",
      "name": "What is the standard repayment term for federal student loans?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard repayment plan for federal student loans is 10 years (120 monthly payments). However, other plans like extended repayment or income-driven repayment can extend the term up to 20 or 25 years."
      }
    },
    {
      "@type": "Question",
      "name": "How does interest accrue on student loans?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Interest on most student loans accrues daily based on your outstanding principal balance. The daily interest formula is: (Interest Rate ÷ 365) × Outstanding Principal Balance."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I make extra payments on my student loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Making extra payments reduces your principal balance faster than scheduled. Because interest is calculated on the remaining principal, a lower balance means less interest accrues over time, saving you money and helping you become debt-free sooner."
      }
    }
  ]
});
---
<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/student-loan-calculator"
  schema={schema}
>
  <div class="page-content">
    <h1>Student Loan Calculator</h1>

    <p>Use our free student loan calculator to estimate your monthly payments, see how much interest you will pay over the life of your loan, and determine how fast you can become debt-free. Adjust the loan amount, interest rate, term, and extra monthly payments to see real-time updates.</p>

    <div class="calculator-card">
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="input-group">
            <label for="loanAmount">Loan Amount</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="loanAmount" value="30000" min="0" step="1000" />
            </div>
          </div>

          <div class="input-group">
            <label for="interestRate">Annual Interest Rate</label>
            <div class="input-wrapper">
              <input type="number" id="interestRate" value="5.5" min="0" max="100" step="0.1" />
              <span class="suffix">%</span>
            </div>
          </div>

          <div class="input-group">
            <label for="loanTerm">Loan Term</label>
            <div class="input-wrapper">
              <input type="number" id="loanTerm" value="10" min="1" max="40" step="1" />
              <span class="suffix">Years</span>
            </div>
          </div>

          <div class="input-group">
            <label for="extraPayment">Extra Monthly Payment (Optional)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="extraPayment" value="0" min="0" step="50" />
            </div>
          </div>
        </div>

        <div class="calc-results">
          <div class="result-box primary">
            <span class="calc-result-label">Estimated Monthly Payment</span>
            <span class="calc-result-value" id="monthlyPaymentOut">$0</span>
            <span class="calc-result-sub" id="paymentDetails">Includes $0 extra</span>
          </div>

          <div class="stats-grid">
            <div class="stat-card">
              <span class="calc-result-label">Total Principal</span>
              <span class="stat-value" id="totalPrincipalOut">$0</span>
            </div>
            <div class="stat-card">
              <span class="calc-result-label">Total Interest</span>
              <span class="stat-value text-accent" id="totalInterestOut">$0</span>
            </div>
            <div class="stat-card">
              <span class="calc-result-label">Total Cost of Loan</span>
              <span class="stat-value" id="totalCostOut">$0</span>
            </div>
            <div class="stat-card">
              <span class="calc-result-label">Time to Payoff</span>
              <span class="stat-value" id="payoffTimeOut">0 Years</span>
              <span class="stat-sub" id="timeSaved">Saved 0 years</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <h2>How Student Loans Are Calculated</h2>
    <p>Most student loans use a simple daily interest formula and follow a standard amortization schedule. This means your monthly payment remains fixed, but the proportion going toward principal versus interest changes over time. Initially, a larger portion of your payment covers interest, but as the principal balance decreases, more of your payment goes toward paying down the debt.</p>

    <div class="highlight-box">
      <h3>The Amortization Formula</h3>
      <p>The core mathematical formula used to determine your fixed monthly payment (PMT) is:</p>
      <code>PMT = P × [r(1 + r)^n] / [(1 + r)^n - 1]</code>
      <ul>
        <li><strong>P</strong> = Principal loan amount</li>
        <li><strong>r</strong> = Monthly interest rate (Annual rate ÷ 12)</li>
        <li><strong>n</strong> = Total number of payments (Years × 12)</li>
      </ul>
    </div>

    <h2>The Power of Extra Payments</h2>
    <p>Because interest accrues daily on your outstanding principal balance, making extra payments can dramatically reduce the total cost of your loan. Every extra dollar you pay goes directly toward reducing the principal. This lowers the balance that interest is calculated on the next day, creating a compounding effect of savings over the life of the loan.</p>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details class="faq-item">
        <summary><h3>How are student loan payments calculated?</h3></summary>
        <p>Student loan payments are typically calculated using a standard amortization formula. This factors in your total loan principal, the annual interest rate, and the repayment term (usually 10 to 25 years) to determine a fixed monthly payment that will pay off the loan entirely by the end of the term.</p>
      </details>

      <details class="faq-item">
        <summary><h3>Can I pay off my student loans early?</h3></summary>
        <p>Yes, in most cases, you can pay off your student loans early without any prepayment penalties. Making extra payments directly to your principal can significantly reduce the total amount of interest you pay over the life of the loan and shorten your repayment timeline.</p>
      </details>

      <details class="faq-item">
        <summary><h3>What is the standard repayment term for federal student loans?</h3></summary>
        <p>The standard repayment plan for federal student loans is 10 years (120 monthly payments). However, other plans like extended repayment or income-driven repayment can extend the term up to 20 or 25 years.</p>
      </details>

      <details class="faq-item">
        <summary><h3>How does interest accrue on student loans?</h3></summary>
        <p>Interest on most student loans accrues daily based on your outstanding principal balance. The daily interest formula is: (Interest Rate ÷ 365) × Outstanding Principal Balance.</p>
      </details>

      <details class="faq-item">
        <summary><h3>What happens if I make extra payments on my student loan?</h3></summary>
        <p>Making extra payments reduces your principal balance faster than scheduled. Because interest is calculated on the remaining principal, a lower balance means less interest accrues over time, saving you money and helping you become debt-free sooner.</p>
      </details>
    </div>
  </div>
</SiteLayout>

<style>
  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .calc-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .prefix {
    position: absolute;
    left: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    pointer-events: none;
    z-index: 2;
  }

  .input-wrapper input {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
  }

  .input-wrapper:has(.prefix) input {
    padding-left: 2rem;
  }

  .input-wrapper:has(.suffix) input {
    padding-right: 2.5rem;
  }

  .input-wrapper input:focus {
    outline: none;
    border-color: var(--accent-color);
  }

  .calc-results {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .result-box {
    background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
    border: 1px solid var(--accent-color);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }

  .calc-result-sub {
    display: block;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin: 0;
  }

  .stat-card {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 0.5rem;
  }

  .text-accent {
    color: var(--accent-color);
  }

  .stat-sub {
    font-size: 0.8rem;
    color: #22c55e;
    margin-top: 0.25rem;
    font-weight: 600;
  }

  details.faq-item {
    cursor: pointer;
  }

  details.faq-item summary {
    list-style: none;
    outline: none;
  }

  details.faq-item summary::-webkit-details-marker {
    display: none;
  }

  details.faq-item h3 {
    display: inline-block;
    margin: 0;
  }

  details.faq-item p {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }
</style>

<script>
  function initCalculator() {
    const loanAmountEl = document.getElementById('loanAmount');
    const interestRateEl = document.getElementById('interestRate');
    const loanTermEl = document.getElementById('loanTerm');
    const extraPaymentEl = document.getElementById('extraPayment');

    const monthlyPaymentOut = document.getElementById('monthlyPaymentOut');
    const paymentDetails = document.getElementById('paymentDetails');
    const totalPrincipalOut = document.getElementById('totalPrincipalOut');
    const totalInterestOut = document.getElementById('totalInterestOut');
    const totalCostOut = document.getElementById('totalCostOut');
    const payoffTimeOut = document.getElementById('payoffTimeOut');
    const timeSavedOut = document.getElementById('timeSaved');

    if (!loanAmountEl) return;

    function formatCurrency(num) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(num);
    }

    function formatMonthsToYears(months) {
      const years = Math.floor(months / 12);
      const remainingMonths = Math.ceil(months % 12);
      if (years > 0 && remainingMonths > 0) return `${years} Yr ${remainingMonths} Mo`;
      if (years > 0) return `${years} Years`;
      return `${remainingMonths} Months`;
    }

    function calculate() {
      const p = parseFloat(loanAmountEl.value) || 0;
      const annualRate = parseFloat(interestRateEl.value) || 0;
      const years = parseFloat(loanTermEl.value) || 0;
      const extra = parseFloat(extraPaymentEl.value) || 0;

      if (p <= 0 || years <= 0) {
        monthlyPaymentOut.textContent = '$0';
        totalPrincipalOut.textContent = '$0';
        totalInterestOut.textContent = '$0';
        totalCostOut.textContent = '$0';
        payoffTimeOut.textContent = '0 Years';
        timeSavedOut.style.display = 'none';
        paymentDetails.textContent = '';
        return;
      }

      const r = (annualRate / 100) / 12;
      const n = years * 12;

      let basePmt = 0;
      if (r === 0) {
        basePmt = p / n;
      } else {
        basePmt = p * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
      }

      const totalPmt = basePmt + extra;

      let balance = p;
      let totalInterestPaid = 0;
      let monthsCount = 0;

      // Amortization loop to handle extra payments
      while (balance > 0 && monthsCount < 1200) { // max 100 years safeguard
        const interestCharge = balance * r;
        totalInterestPaid += interestCharge;

        let principalPayment = totalPmt - interestCharge;
        if (principalPayment > balance) {
          principalPayment = balance;
        }

        balance -= principalPayment;
        monthsCount++;
      }

      monthlyPaymentOut.textContent = formatCurrency(totalPmt);
      totalPrincipalOut.textContent = formatCurrency(p);
      totalInterestOut.textContent = formatCurrency(totalInterestPaid);
      totalCostOut.textContent = formatCurrency(p + totalInterestPaid);
      payoffTimeOut.textContent = formatMonthsToYears(monthsCount);

      if (extra > 0) {
        paymentDetails.textContent = `Includes ${formatCurrency(extra)} extra`;
        const monthsSaved = n - monthsCount;
        if (monthsSaved > 0) {
          timeSavedOut.textContent = `Saved ${formatMonthsToYears(monthsSaved)}`;
          timeSavedOut.style.display = 'block';
        } else {
          timeSavedOut.style.display = 'none';
        }
      } else {
        paymentDetails.textContent = `Standard payment`;
        timeSavedOut.style.display = 'none';
      }
    }

    [loanAmountEl, interestRateEl, loanTermEl, extraPaymentEl].forEach(input => {
      input.addEventListener('input', calculate);
    });

    calculate();
  }

  // Handle standard load and View Transitions
  document.addEventListener('astro:page-load', () => {
    const calc = document.querySelector('.calculator-card');
    if (calc && !calc.dataset.initialized) {
      initCalculator();
      calc.dataset.initialized = "true";
    }
  });
</script>