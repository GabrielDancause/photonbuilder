---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": ["Article", "FAQPage"],
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you calculate position size in stocks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate position size, first determine your total account risk in dollars (e.g., 1% of your total account size). Then, determine your trade risk per share by subtracting your stop loss price from your entry price. Finally, divide your total account risk by your trade risk per share to get the optimal number of shares to purchase."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good position size for a stock?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A universally accepted professional standard is to risk no more than 1% to 2% of your total account equity on any single trade. The actual monetary value of the position size will vary based on your stop-loss distance, but the underlying risk remains constant."
      }
    },
    {
      "@type": "Question",
      "name": "Why is position sizing important in trading?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Position sizing is critical for risk management. It prevents a single losing trade from causing catastrophic damage to your portfolio. Proper sizing mathematically ensures you can survive losing streaks and allows your profitable trading edge to compound over time."
      }
    },
    {
      "@type": "Question",
      "name": "How does stop loss affect position size?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Stop loss is inversely proportional to position size. A wider stop loss (meaning a larger dollar risk per share) requires a smaller position size to maintain the same total account risk. Conversely, a tighter stop loss allows for a larger position size."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use the same position size for every trade?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not in terms of dollar amount or share quantity. While your total risk percentage (e.g., 1%) should remain relatively constant, the actual number of shares and capital allocated will dynamically change based on the specific stop-loss distance for each individual trade setup."
      }
    }
  ]
};

export const meta = {
  title: "Position Size Calculator: Advanced Risk Management Tool",
  description: "Protect your portfolio. Calculate optimal share sizing using fixed fractional risk and Kelly Criterion models based on your exact stop loss.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Position Size Calculator: Advanced Risk Management Tool"
  description="Protect your portfolio. Calculate optimal share sizing using fixed fractional risk and Kelly Criterion models based on your exact stop loss."
  canonical="https://westmountfundamentals.com/position-size-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Position Size Calculator</h1>
      <p class="subtitle">Calculate optimal share sizing, determine capital allocation, and protect your portfolio against catastrophic drawdowns.</p>
    </div>

    <div class="calculator-container">
      <div class="calculator-grid">
        <!-- Left Column: Inputs -->
        <div class="calc-panel">
          <h3 style="margin-bottom: 1rem;">Trade Parameters</h3>
          <div class="input-group">
            <label>Total Account Balance ($)</label>
            <input type="number" id="account-size" value="10000" min="100" step="100">
          </div>
          <div class="input-group">
            <label>Risk Tolerance (%)</label>
            <input type="number" id="risk-percent" value="1" min="0.1" max="100" step="0.1">
          </div>
          <div class="input-group">
            <label>Entry Price ($)</label>
            <input type="number" id="entry-price" value="150.00" min="0.01" step="0.01">
          </div>
          <div class="input-group">
            <label>Stop Loss Price ($)</label>
            <input type="number" id="stop-loss" value="140.00" min="0.01" step="0.01">
          </div>

          <div class="optional-section mt-4 pt-4" style="border-top: 1px solid var(--border-color);">
            <h4 style="margin-bottom: 1rem; color: var(--text-secondary);">Kelly Criterion Options (Optional)</h4>
            <div class="input-grid">
              <div>
                <label>Win Rate (%)</label>
                <input type="number" id="win-rate" value="55" min="1" max="99" step="1">
              </div>
              <div>
                <label>Target Price ($)</label>
                <input type="number" id="target-price" value="170.00" min="0.01" step="0.01">
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Results -->
        <div class="calc-panel">
          <div class="result-card">
            <div class="result-label">Recommended Shares</div>
            <div class="result-value" id="res-shares">0</div>
          </div>

          <div class="stats-grid">
            <div class="stat-box">
              <div class="stat-label">Total Capital Required</div>
              <div class="stat-value" id="res-capital">$0.00</div>
              <div class="stat-subtext" id="res-capital-pct">0% of account</div>
            </div>
            <div class="stat-box text-red">
              <div class="stat-label" style="color: inherit;">Maximum Risk</div>
              <div class="stat-value" style="color: inherit;" id="res-risk">$0.00</div>
              <div class="stat-subtext" style="color: inherit;" id="res-risk-share">Risk per share</div>
            </div>
          </div>

          <div class="stats-grid" style="margin-top: 1rem;">
            <div class="stat-box">
              <div class="stat-label">Kelly Criterion Suggestion</div>
              <div class="stat-value" id="res-kelly-pct">0%</div>
              <div class="stat-subtext">of account capital</div>
            </div>
            <div class="stat-box">
              <div class="stat-label">Risk/Reward Ratio</div>
              <div class="stat-value" id="res-rr">1:0</div>
            </div>
          </div>

          <div class="chart-wrapper">
            <canvas id="allocationChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>The Mathematics of Position Sizing</h2>
      <p>Professional trading is built upon strict risk management frameworks. Without mathematically sound position sizing, traders expose themselves to "Risk of Ruin"—the statistical probability that a string of inevitable losses will entirely deplete their trading capital. This position size calculator automates the fixed fractional sizing model, universally recognized as the industry standard for equity trading.</p>

      <p>If you trade derivatives instead of standard equities, you will want to utilize our <a href="/options-profit-calculator">Options Profit Calculator</a> to model non-linear payoffs, as standard share-based position sizing does not translate directly to multi-leg options strategies.</p>

      <h3>The Fixed Fractional Methodology</h3>
      <p>The core philosophy of fixed fractional sizing dictates that you risk the exact same percentage of your account equity on every single trade, regardless of the stock's absolute price or your subjective confidence in the setup. This calculator automates a specific three-step sequence:</p>

      <p><strong>Step 1: Determine Total Risk Allocation.</strong> First, the calculator computes your maximum allowable loss in absolute dollars based on your Account Balance and your defined Risk Tolerance percentage. A widely respected standard among institutional prop desks is to risk no more than 1% to 2% of total capital on a single idea. <br>
      <em>Formula: Account Size × (Risk % / 100) = Total Dollar Risk</em></p>

      <p><strong>Step 2: Calculate Trade Risk Per Share.</strong> Next, the tool determines how much capital is at risk on a per-share basis if the trade invalidates and triggers your stop-loss order.<br>
      <em>Formula: Entry Price - Stop Loss Price = Risk Per Share</em></p>

      <p><strong>Step 3: Define Optimal Share Quantity.</strong> Finally, the Total Dollar Risk is divided by the Risk Per Share. The output is the exact number of shares you should purchase. The calculator automatically rounds down to whole shares to ensure your strict risk threshold is never breached.<br>
      <em>Formula: Total Dollar Risk / Risk Per Share = Position Size (Shares)</em></p>

      <h3>Integrating the Kelly Criterion</h3>
      <p>This calculator also features an optional Kelly Criterion module. Originally developed in 1956 by John L. Kelly at Bell Labs, the Kelly Criterion is a mathematical formula used to determine the optimal size of a series of bets to maximize the long-term growth rate of capital.</p>

      <p>The formula calculates the ideal percentage of your account to allocate to a trade based on two critical variables:</p>
      <ul>
        <li><strong>Win Probability (W):</strong> Your historical or projected win rate for this specific type of trade setup.</li>
        <li><strong>Win/Loss Ratio (R):</strong> Your expected reward divided by your expected risk. The calculator determines this by comparing your Target Price distance against your Stop Loss distance.</li>
      </ul>

      <p><em>The Kelly Formula: Kelly % = W - [(1 - W) / R]</em></p>

      <p>If the Kelly calculation outputs a negative number, it indicates the trade has a negative expected value over the long run, and no capital should be allocated. While mathematically optimal for infinite compounding, the "Full Kelly" output can be highly volatile. Many professional traders utilize "Half-Kelly" or "Fractional Kelly" to smooth out equity curve drawdowns while maintaining a robust growth trajectory.</p>

      <h3>Stop Loss Dynamics and Capital Allocation</h3>
      <p>A common error among novice traders is sizing positions based on total capital required rather than total capital at risk. For example, buying $10,000 worth of a low-volatility utility stock with a tight 2% stop loss exposes the account to only $200 of risk. Conversely, buying $10,000 of a hyper-volatile tech stock with a wide 20% stop loss exposes the account to $2,000 of risk.</p>

      <p>This calculator automatically adjusts your capital allocation to normalize risk across all asset profiles. If a stock is highly volatile and requires a very wide stop loss to avoid getting "chopped out" by normal market noise, the calculator will mathematically reduce your total share quantity. This built-in governor ensures that whether you are trading a slow-mover or a fast-mover, your downside risk to your portfolio remains precisely standardized at your predetermined percentage threshold.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How do you calculate position size in stocks?</summary>
        <p>To calculate position size, first determine your total account risk in dollars (e.g., 1% of your total account size). Then, determine your trade risk per share by subtracting your stop loss price from your entry price. Finally, divide your total account risk by your trade risk per share to get the optimal number of shares to purchase.</p>
      </details>
      <details>
        <summary>What is a good position size for a stock?</summary>
        <p>A universally accepted professional standard is to risk no more than 1% to 2% of your total account equity on any single trade. The actual monetary value of the position size will vary based on your stop-loss distance, but the underlying risk remains constant.</p>
      </details>
      <details>
        <summary>Why is position sizing important in trading?</summary>
        <p>Position sizing is critical for risk management. It prevents a single losing trade from causing catastrophic damage to your portfolio. Proper sizing mathematically ensures you can survive losing streaks and allows your profitable trading edge to compound over time.</p>
      </details>
      <details>
        <summary>How does stop loss affect position size?</summary>
        <p>Stop loss is inversely proportional to position size. A wider stop loss (meaning a larger dollar risk per share) requires a smaller position size to maintain the same total account risk. Conversely, a tighter stop loss allows for a larger position size.</p>
      </details>
      <details>
        <summary>Should I use the same position size for every trade?</summary>
        <p>Not in terms of dollar amount or share quantity. While your total risk percentage (e.g., 1%) should remain relatively constant, the actual number of shares and capital allocated will dynamically change based on the specific stop-loss distance for each individual trade setup.</p>
      </details>
    </section>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function() {
      const inputs = document.querySelectorAll('input');
      let allocChart = null;

      function formatCurrency(val) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      }

      function updateChart(invested, cash) {
        const ctx = document.getElementById('allocationChart').getContext('2d');
        if (allocChart) allocChart.destroy();

        allocChart = new Chart(ctx, {
          type: 'doughnut',
          data: {
            labels: ['Capital Allocated', 'Available Cash'],
            datasets: [{
              data: [invested, cash],
              backgroundColor: ['#4a8fe7', 'rgba(255,255,255,0.05)'],
              borderColor: ['#4a8fe7', 'rgba(255,255,255,0.1)'],
              borderWidth: 1
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '75%',
            plugins: {
              legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,0.7)' } }
            }
          }
        });
      }

      function calculateSize() {
        const account = parseFloat(document.getElementById('account-size').value) || 0;
        const riskPct = parseFloat(document.getElementById('risk-percent').value) || 0;
        const entry = parseFloat(document.getElementById('entry-price').value) || 0;
        const stop = parseFloat(document.getElementById('stop-loss').value) || 0;

        // Kelly inputs
        const winRatePct = parseFloat(document.getElementById('win-rate').value) || 0;
        const target = parseFloat(document.getElementById('target-price').value) || 0;

        if (account <= 0 || riskPct <= 0 || entry <= 0 || stop <= 0 || entry === stop) {
            document.getElementById('res-shares').innerText = "0";
            return;
        }

        const isLong = entry > stop;
        const riskPerShare = isLong ? (entry - stop) : (stop - entry);
        const maxRiskDollar = account * (riskPct / 100);

        if (riskPerShare <= 0) return;

        const shares = Math.floor(maxRiskDollar / riskPerShare);
        const capitalReq = shares * entry;
        const capitalPct = (capitalReq / account) * 100;
        const actualRisk = shares * riskPerShare;

        document.getElementById('res-shares').innerText = shares.toLocaleString();
        document.getElementById('res-capital').innerText = formatCurrency(capitalReq);
        document.getElementById('res-capital-pct').innerText = capitalPct.toFixed(2) + '% of account';

        document.getElementById('res-risk').innerText = formatCurrency(actualRisk);
        document.getElementById('res-risk-share').innerText = `Risking ${formatCurrency(riskPerShare)} per share`;

        // Kelly calc
        const rewardPerShare = isLong ? (target - entry) : (entry - target);
        let kellyPct = 0;
        let rrText = "1:0";

        if (rewardPerShare > 0) {
            const w = winRatePct / 100;
            const r = rewardPerShare / riskPerShare;
            rrText = `1:${r.toFixed(2)}`;

            const k = w - ((1 - w) / r);
            kellyPct = k > 0 ? (k * 100) : 0;
        }

        document.getElementById('res-kelly-pct').innerText = kellyPct.toFixed(2) + '%';
        document.getElementById('res-rr').innerText = rrText;

        updateChart(capitalReq, Math.max(0, account - capitalReq));
      }

      inputs.forEach(input => {
        input.addEventListener('input', calculateSize);
      });

      // Initial calc
      calculateSize();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; }

    .calculator-container { margin: 2rem 0; }
    .calculator-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 2rem; }
    @media (max-width: 768px) { .calculator-grid { grid-template-columns: 1fr; } }

    .calc-panel { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }

    .input-group { margin-bottom: 1rem; }
    .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    label { display: block; font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.4rem; font-weight: 500; }
    input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 2rem; text-align: center; margin-bottom: 1.5rem; }
    .result-label { color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.5rem; }
    .result-value { font-size: 4rem; font-weight: 800; color: var(--accent-color); line-height: 1; }

    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .stat-box { background: rgba(0,0,0,0.2); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.25rem; text-align: center; }
    .stat-label { font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
    .stat-box .stat-value { font-size: 1.75rem; font-weight: 700; margin: 0.5rem 0; }
    .stat-subtext { font-size: 0.85rem; color: var(--text-secondary); }

    .text-red { color: #ef4444 !important; border-color: rgba(239, 68, 68, 0.3) !important; background: rgba(239, 68, 68, 0.05) !important; }

    .chart-wrapper { height: 250px; width: 100%; margin-top: 2rem; }

    .explainer { margin-top: 3rem; }
    .explainer h2, .explainer h3 { margin-top: 2rem; margin-bottom: 1rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); line-height: 1.7; }
    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer a { color: var(--accent-color); text-decoration: none; }
    .explainer a:hover { text-decoration: underline; }

    .faq-section { margin-top: 3rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .faq-section p { margin-top: 1rem; color: var(--text-secondary); }
  </style>
</SiteLayout>
