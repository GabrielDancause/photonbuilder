    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the accounting equation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The fundamental accounting equation is Assets = Liabilities + Shareholders' Equity. This means everything a company owns is financed by either borrowing money (liabilities) or using the owners' money (equity)."
        }
