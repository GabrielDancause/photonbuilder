  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "How to Read a Balance Sheet: A Comprehensive Guide",
    "description": "Learn how to analyze a company's balance sheet. Understand assets, liabilities, equity, working capital, and key financial ratios for better investing.",
    "author": {
      "@type": "Organization",
