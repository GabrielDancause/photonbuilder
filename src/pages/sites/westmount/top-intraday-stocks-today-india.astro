  { rank: 15, symbol: "MARUTI.NS", name: "MARUTI SUZUKI INDIA LTD.", price: 12972.0, marketCap: 4078430060544, volume: 1178874, sector: "Consumer Cyclical", beta: 0.111, dividendYield: 1.06, pros: "Large point movements per tick.", cons: "High stock price limits accessibility for retail.", why: "Provides massive intraday point swings for well-capitalized traders." }
