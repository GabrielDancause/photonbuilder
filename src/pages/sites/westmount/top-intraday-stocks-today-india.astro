  { rank: 3, symbol: "ICICIBANK.NS", name: "ICICI BANK LTD.", price: 1288.7, marketCap: 9223706509312, volume: 22302666, sector: "Financial Services", beta: 0.177, dividendYield: 0.86, pros: "Strong momentum trends during market hours.", cons: "Highly sensitive to macroeconomic announcements.", why: "Consistent high volume provides smooth execution for intraday momentum strategies." },
  { rank: 4, symbol: "RELIANCE.NS", name: "RELIANCE INDUSTRIES LTD", price: 1397.6, marketCap: 18912982859776, volume: 19006822, sector: "Energy", beta: 0.205, dividendYield: 0.39, pros: "Market leader with significant weight in Nifty.", cons: "Requires larger stop-losses due to wide spreads.", why: "Its sheer size and daily volume make it a staple for trend followers." },
