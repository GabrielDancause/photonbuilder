const faqs = [
  {
    question: "What makes a stock good for intraday trading in India?",
    answer: "The best intraday stocks typically have high liquidity and sufficient volatility. High liquidity ensures that you can enter and exit trades easily without significant slippage. Volatility provides the price movement necessary to generate profits within a single trading day."
  },
  {
    question: "How do I select the best intraday stocks for today?",
    answer: "Traders usually select intraday stocks by analyzing pre-market movers, identifying stocks breaking out of key support or resistance levels, and tracking sector-specific news. Using technical indicators like moving averages and RSI can also help confirm trends."
  },
  {
    question: "What is the role of volume in intraday trading?",
    answer: "Volume is crucial in intraday trading as it confirms the strength of a price movement. High trading volume indicates strong interest in a stock, making it easier to execute large orders. A breakout accompanied by high volume is generally considered more reliable."
  },
  {
    question: "Are large-cap stocks better for intraday trading?",
    answer: "Large-cap stocks are often preferred by intraday traders because they offer high liquidity and are less susceptible to manipulation compared to small-cap stocks. They typically move based on broader market trends and institutional buying."
  },
  {
    question: "How much capital is needed to start intraday trading in India?",
    answer: "While there is no fixed minimum, starting with sufficient capital to manage risk is advisable. Many experts suggest a minimum of ₹20,000 to ₹50,000 to allow for diversification across multiple trades while keeping position sizes small enough to limit potential losses."
  }
];

const schema = {
