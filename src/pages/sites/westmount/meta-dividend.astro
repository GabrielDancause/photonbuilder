  <script is:inline>
    // Calculator functionality
    const sharesInput = document.getElementById('shares');
    const amountInput = document.getElementById('amount');
    const growthRateSelect = document.getElementById('growth-rate');
    const dripCheckbox = document.getElementById('drip');
    const toggleButtons = document.querySelectorAll('.toggle');
    
    const quarterlyIncomeEl = document.getElementById('quarterly-income');
    const annualIncomeEl = document.getElementById('annual-income');
    const fiveYearIncomeEl = document.getElementById('five-year-income');
    const tenYearIncomeEl = document.getElementById('ten-year-income');

    const META_PRICE = 525.72;
    const QUARTERLY_DIVIDEND = 0.525;
    const ANNUAL_DIVIDEND = 2.22;

    let currentInputType = 'shares';

    // Toggle between shares and amount input
    toggleButtons.forEach(button => {
      button.addEventListener('click', () => {
        const type = button.dataset.type;
        
        toggleButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');
        
        if (type === 'shares') {
          document.getElementById('shares-input').classList.remove('hidden');
          document.getElementById('amount-input').classList.add('hidden');
          currentInputType = 'shares';
        } else {
          document.getElementById('shares-input').classList.add('hidden');
          document.getElementById('amount-input').classList.remove('hidden');
          currentInputType = 'amount';
        }
        
        updateCalculations();
      });
    });

    function getShares() {
      if (currentInputType === 'shares') {
        return parseFloat(sharesInput.value) || 0;
      } else {
        const amount = parseFloat(amountInput.value) || 0;
        return amount / META_PRICE;
      }
    }

    function updateCalculations() {
      const shares = getShares();
      const growthRate = parseFloat(growthRateSelect.value);
      const useDrip = dripCheckbox.checked;
      
      // Current income
      const quarterlyIncome = shares * QUARTERLY_DIVIDEND;
      const annualIncome = shares * ANNUAL_DIVIDEND;
      
      // Future projections
      let futureAnnualDividend5 = ANNUAL_DIVIDEND * Math.pow(1 + growthRate, 5);
      let futureAnnualDividend10 = ANNUAL_DIVIDEND * Math.pow(1 + growthRate, 10);
      
      let fiveYearIncome, tenYearIncome;
      
      if (useDrip) {
        // DRIP calculation - compound growth of both dividend amount and share count
        const totalReturn = growthRate; // Assume dividend growth equals total return for simplicity
        const futureShares5 = shares * Math.pow(1 + (annualIncome / (shares * META_PRICE)), 5);
        const futureShares10 = shares * Math.pow(1 + (annualIncome / (shares * META_PRICE)), 10);
        
        fiveYearIncome = futureShares5 * futureAnnualDividend5;
        tenYearIncome = futureShares10 * futureAnnualDividend10;
      } else {
        fiveYearIncome = shares * futureAnnualDividend5;
        tenYearIncome = shares * futureAnnualDividend10;
      }
      
      // Update display
      quarterlyIncomeEl.textContent = `$${quarterlyIncome.toFixed(2)}`;
      annualIncomeEl.textContent = `$${annualIncome.toFixed(2)}`;
      fiveYearIncomeEl.textContent = `$${fiveYearIncome.toFixed(2)}`;
      tenYearIncomeEl.textContent = `$${tenYearIncome.toFixed(2)}`;
    }

    // Event listeners for real-time updates
    sharesInput.addEventListener('input', updateCalculations);
    amountInput.addEventListener('input', updateCalculations);
    growthRateSelect.addEventListener('change', updateCalculations);
    dripCheckbox.addEventListener('change', updateCalculations);

    // Initial calculation
    updateCalculations();
  </script>
