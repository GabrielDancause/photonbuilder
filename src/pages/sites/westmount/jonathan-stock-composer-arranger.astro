  description: "How does intellectual property generate long-term wealth? Explore the economics behind artists like Jonathan Stock, composer and arranger.",
  category: "study",
  published: "2026-03-15",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is Jonathan Stock, the composer and arranger?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Jonathan Stock is known as a contemporary composer and arranger. In financial and educational contexts, the career of an arranger or composer is often used as a case study to understand intellectual property, royalty streams, and the monetization of creative assets."
      }
    },
    {
      "@type": "Question",
