  description={meta.description}
  canonical="https://westmountfundamentals.com/stock-profit-calculator"
  schema={JSON.stringify(schema)}
>
  <div class="page-content">
    <div class="calculator-container">
      <p class="intro-text">
        Calculate your exact stock profit, total return on investment (ROI), and net profit after factoring in commissions and capital gains taxes.
      </p>

      <form id="stockProfitForm" class="calculator-card">
        <div class="calculator-grid">
          <!-- Purchase Details -->
          <div class="input-section">
