    letter-spacing: 0.5px;
  }

  .result-value {
    font-size: 2rem;
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--text-primary);
  }

  .result-value.positive {
    color: color-mix(in srgb, var(--text-primary) 80%, #22c55e);
  }

  .result-value.negative {
    color: color-mix(in srgb, var(--text-primary) 80%, #ef4444);
  }

  .result-value.neutral {
    color: var(--text-primary);
  }

  /* Table Styles Override */
  .comparison-table {
    margin-top: 2rem;
  }

  .comparison-table table {
    margin-bottom: 0;
  }

  .comparison-table th {
    text-align: right;
  }

  .comparison-table th:first-child {
    text-align: left;
  }

  .comparison-table td {
    text-align: right;
    font-weight: 500;
  }

  .comparison-table td:first-child {
    text-align: left;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-weight: 600;
  }

  /* Content Formatting */
  .page-content h2 {
    margin-top: 3rem;
  }

  .page-content h3 {
    margin-top: 2rem;
    color: var(--text-primary);
