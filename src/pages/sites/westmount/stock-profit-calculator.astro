---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Stock Profit Calculator: Calculate Net Return on Investment",
  description: "Want to know your exact stock profit after fees? Our calculator instantly shows your true net return, ROI, and total proceeds. Find out how much you actually keep.",
  category: "tool",
  published: "2026-03-17"
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["Article", "FAQPage"],
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Westmount Fundamentals"
  },
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you calculate profit on a stock?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate profit on a stock, you subtract the total purchase cost (including buying fees) from the total sale proceeds (after deducting selling fees). The formula is: Profit = (Sell Price × Shares) - (Buy Price × Shares) - Buying Fees - Selling Fees."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good return on investment (ROI) for stocks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Historically, the average annual return of the stock market (like the S&P 500) is around 10% before inflation. A \"good\" ROI depends on your holding period; a 20% return over a few months is excellent, while a 20% return over 5 years is below average."
      }
    },
    {
      "@type": "Question",
      "name": "Are fees really that important when calculating stock profit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, especially for smaller trades or active trading. If you buy a stock for $100 and it goes to $105, you have a 5% gain. But if you paid a $5 commission to buy and $5 to sell, your net profit is actually a $5 loss."
      }
    },
    {
      "@type": "Question",
      "name": "Does this stock profit calculator include taxes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, this calculator determines your pre-tax net profit. Capital gains taxes vary significantly based on your income bracket, filing status, local laws, and whether you held the stock for more or less than a year (short-term vs. long-term capital gains)."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate ROI percentage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ROI (Return on Investment) percentage is calculated by dividing your net profit by your total investment cost (including buying fees), and multiplying by 100. Formula: ROI % = (Net Profit / Total Cost) × 100."
      }
    }
  ]
});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/stock-profit-calculator" schema={schema}>
  <div class="page-content">

    <div class="container">
      <h1>Stock Profit Calculator</h1>
      <p style="text-align: center; max-width: 650px; margin: 0 auto 2.5rem;">Calculate your true net profit, return on investment (ROI), and total proceeds after accounting for broker commissions and fees.</p>

      <div class="calculator-card">
        <h3>Trade Details</h3>

        <div class="calc-inputs-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">

          <div class="input-group">
            <label for="shares">Number of Shares</label>
            <div class="input-wrapper">
              <input type="number" id="shares" value="100" min="0.0001" step="1">
            </div>
          </div>

          <div class="input-group">
            <label for="buy-price">Buy Price (Per Share)</label>
            <div class="input-wrapper">
              <span class="prefix" style="position: absolute; left: 1rem; color: var(--text-secondary); font-family: var(--font-mono); pointer-events: none;">$</span>
              <input type="number" id="buy-price" value="150" min="0.0001" step="0.01" style="padding-left: 2rem;">
            </div>
          </div>

          <div class="input-group">
            <label for="sell-price">Sell Price (Per Share)</label>
            <div class="input-wrapper">
              <span class="prefix" style="position: absolute; left: 1rem; color: var(--text-secondary); font-family: var(--font-mono); pointer-events: none;">$</span>
              <input type="number" id="sell-price" value="175" min="0.0001" step="0.01" style="padding-left: 2rem;">
            </div>
          </div>

          <div class="input-group">
            <label for="buy-fee">Buying Commission / Fees</label>
            <div class="input-wrapper">
              <span class="prefix" style="position: absolute; left: 1rem; color: var(--text-secondary); font-family: var(--font-mono); pointer-events: none;">$</span>
              <input type="number" id="buy-fee" value="0" min="0" step="1" style="padding-left: 2rem;">
            </div>
          </div>

          <div class="input-group">
            <label for="sell-fee">Selling Commission / Fees</label>
            <div class="input-wrapper">
              <span class="prefix" style="position: absolute; left: 1rem; color: var(--text-secondary); font-family: var(--font-mono); pointer-events: none;">$</span>
              <input type="number" id="sell-fee" value="0" min="0" step="1" style="padding-left: 2rem;">
            </div>
          </div>

        </div>

        <div class="calc-result">
          <span class="calc-result-label">Net Profit / Loss</span>
          <div class="calc-result-value" id="net-profit">$0.00</div>
        </div>

        <div class="stats-grid" style="margin-top: 2rem; margin-bottom: 0;">
          <div class="stat-card" style="padding: 1.25rem;">
            <span style="display: block; color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 0.25rem;">Return on Investment (ROI)</span>
            <strong id="roi-percentage" style="font-family: var(--font-mono); font-size: 1.5rem;">0.00%</strong>
          </div>
          <div class="stat-card" style="padding: 1.25rem;">
            <span style="display: block; color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 0.25rem;">Total Investment Cost</span>
            <strong id="total-cost" style="font-family: var(--font-mono); font-size: 1.25rem; color: var(--text-primary);">$0.00</strong>
          </div>
          <div class="stat-card" style="padding: 1.25rem;">
            <span style="display: block; color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 0.25rem;">Total Final Proceeds</span>
            <strong id="total-proceeds" style="font-family: var(--font-mono); font-size: 1.25rem; color: var(--text-primary);">$0.00</strong>
          </div>
        </div>
      </div>

      <div class="content-section" style="margin-top: 4rem;">
        <h2>The Complete Guide to Calculating Stock Profits</h2>
        <p>Whether you're executing your first trade or managing an active portfolio, knowing exactly how much you've made (or lost) is the most fundamental aspect of investing. While most brokerage apps show a quick percentage next to your holdings, understanding the underlying math behind your stock profit is crucial—especially when accounting for the hidden impact of fees and commissions.</p>

        <p>This guide will break down the exact formula for calculating stock profits, walk through real-world examples, and highlight common blind spots that cause investors to miscalculate their actual returns.</p>

        <h3>The Core Formula: More Than Just Buy vs. Sell</h3>
        <p>At its simplest level, profit is simply revenue minus expenses. In the context of buying and selling shares, the formula looks like this:</p>

        <div class="highlight-box" style="margin: 2rem 0;">
          <h4 style="margin-top: 0; margin-bottom: 1rem; color: var(--accent-color);">The Net Profit Formula</h4>
          <p style="margin-bottom: 0; font-family: var(--font-mono); font-size: 1.1rem; text-align: center;">
            <strong>Net Profit = (Sale Price × Shares) − (Buy Price × Shares) − Buying Fees − Selling Fees</strong>
          </p>
        </div>

        <p>Let's break down each component:</p>
        <ul>
          <li><strong>Gross Investment Cost:</strong> The Buy Price multiplied by the number of shares.</li>
          <li><strong>Gross Proceeds:</strong> The Sell Price multiplied by the number of shares.</li>
          <li><strong>Total Fees:</strong> Any commissions, regulatory fees, or transaction costs charged by your broker on both sides of the trade.</li>
        </ul>

        <h3>A Worked Example: The Hidden Impact of Fees</h3>
        <p>Let's look at a practical example to see why calculating exact profit matters. Assume you decide to buy 50 shares of Company XYZ.</p>
        <ul>
          <li><strong>Buy Price:</strong> $40.00 per share</li>
          <li><strong>Sell Price:</strong> $42.00 per share</li>
          <li><strong>Broker Commission:</strong> $9.99 per trade (charged when you buy, and again when you sell)</li>
        </ul>

        <p>At first glance, you bought at $40 and sold at $42. That's a $2 gain per share across 50 shares, meaning you made a $100 profit, right? Let's run the actual math:</p>

        <ol>
          <li><strong>Total Cost to Buy:</strong> (50 shares × $40.00) + $9.99 buying fee = <strong>$2,009.99</strong></li>
          <li><strong>Total Proceeds from Sale:</strong> (50 shares × $42.00) − $9.99 selling fee = <strong>$2,090.01</strong></li>
          <li><strong>Net Profit:</strong> $2,090.01 (Proceeds) − $2,009.99 (Cost) = <strong>$80.02</strong></li>
        </ol>

        <p>Your actual profit is $80.02, not $100. Those two $9.99 commission fees ate up nearly 20% of your gross gains. This perfectly illustrates why active traders must be hyper-aware of transaction costs, particularly when trading small position sizes. For a deeper dive into sizing your trades correctly, check out our <a href="/position-size-calculator">position size calculator</a>.</p>

        <h3>Understanding Return on Investment (ROI)</h3>
        <p>While seeing your profit in dollar terms is helpful, professionals evaluate trades using percentages. Return on Investment (ROI) allows you to compare the efficiency of different investments, regardless of the amount of money deployed.</p>

        <p>The formula for ROI is:</p>
        <p style="text-align: center; font-family: var(--font-mono); background-color: var(--card-bg); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);"><strong>ROI % = (Net Profit ÷ Total Investment Cost) × 100</strong></p>

        <p>Using our previous example:</p>
        <ul>
          <li><strong>Net Profit:</strong> $80.02</li>
          <li><strong>Total Investment Cost:</strong> $2,009.99</li>
          <li><strong>ROI:</strong> ($80.02 ÷ $2,009.99) × 100 = <strong>3.98%</strong></li>
        </ul>

        <p>Even though the stock price increased by exactly 5% (from $40 to $42), your actual ROI was only 3.98% due to the drag of commission fees. If you want to calculate annualized returns over multiple years, you'll need our <a href="/stock-return-calculator">stock return calculator</a> which handles CAGR.</p>

        <h3>Common Mistakes When Calculating Profit</h3>

        <h4>1. Ignoring the "Cost Basis" Rule</h4>
        <p>If you buy shares of the same company at different times and at different prices, calculating profit becomes more complex when you decide to sell only a portion of your holdings. By default, the IRS and most brokerages use the First-In, First-Out (FIFO) method. This means the first shares you bought are considered the first ones you sold. If you want a specific breakdown of average prices across multiple purchases, use our <a href="/cost-basis-calculator">cost basis calculator</a>.</p>

        <h4>2. Forgetting About Stock Splits</h4>
        <p>If a company undergoes a stock split while you hold it, the number of shares you own and the price per share will change dramatically, but the total value remains the same. If you bought 10 shares at $100, and a 2-for-1 split occurs, you now have 20 shares with a cost basis of $50 each. If you try to calculate profit using your original 10 shares against the new price, your math will be entirely wrong. You can see how this math works using our <a href="/stock-split-calculator">stock split calculator</a>.</p>

        <h4>3. Confusing Realized vs. Unrealized Gains</h4>
        <p>An <strong>unrealized gain</strong> (often called a "paper profit") is how much your investment has grown while you still hold the stock. A <strong>realized gain</strong> is the actual profit locked in after you click "sell" and the transaction clears. You cannot spend an unrealized gain. A stock portfolio can be up 50% on paper one day, and down 10% the next week.</p>

        <h3>Context: When Do Investors Use This?</h3>
        <p>While long-term index fund investors rarely need to calculate the exact profit on a day-to-day basis (relying instead on comparing their performance against the <a href="/average-stock-market-return">average stock market return</a>), specific calculation of profit and ROI is critical for:</p>
        <ul>
          <li><strong>Active Traders:</strong> Day traders and swing traders need exact math to ensure their winning trades are covering the costs of their losing trades plus commissions. Because margins in day trading are often razor-thin, an uncalculated commission structure can easily turn a winning strategy into a losing one over the span of hundreds of trades.</li>
          <li><strong>Tax Planning:</strong> At the end of the year, investors often calculate their exact net profits and losses across different positions to engage in "tax-loss harvesting"—selling losing positions to offset the capital gains taxes generated by their profitable trades. By precisely calculating these figures, investors can legally and ethically minimize their tax burdens to the IRS.</li>
          <li><strong>Performance Review:</strong> Serious investors periodically calculate the ROI on individual positions to determine if a specific stock is outperforming a broad market benchmark like the S&P 500. If an individual stock is returning 4% ROI while a risk-free savings account is paying 5%, the investor needs to reassess their strategy and reallocate their capital toward more efficient vehicles.</li>
        </ul>

        <p>If you are planning consistent, ongoing investments over years or decades rather than calculating single trades, you may find our comprehensive <a href="/stock-calculator">compound interest stock calculator</a> more useful for long-term wealth projection.</p>

        <h3>The Psychological Trap of Ignoring Commissions</h3>
        <p>One of the most insidious ways retail investors lose money isn't through picking bad companies, but through "frictional costs" – the slow, barely noticeable bleed of capital through brokerage fees, bid-ask spreads, and regulatory charges. When an investor makes a trade and sees a theoretical profit based solely on the price chart, they experience a hit of dopamine. However, if they haven't explicitly run the numbers through a stock profit calculator, they may actually be losing money on a net basis.</p>

        <p>Consider the rise of "commission-free" trading platforms like Robinhood. While these platforms advertise zero fees, they often make money through Payment for Order Flow (PFOF). This means they route your trade to a market maker who executes the trade slightly below the optimal market price. While there is no direct $9.99 fee applied to the transaction, the hidden cost is baked into a worse execution price. A meticulous investor who understands how to calculate their exact stock profit is aware of these nuances and adjusts their trading frequency accordingly.</p>

        <p>Furthermore, over-trading is heavily penalized by fees. An investor who buys and holds an index fund for 30 years pays an execution fee precisely twice: once when buying, and once when selling decades later. An active day trader flipping a stock daily will pay an execution fee over 500 times in a single year. Unless that active trader is significantly outperforming the market—by a margin large enough to cover those 500 fees—they are working harder simply to enrich their broker.</p>

        <h3>Factoring in Margin Loans</h3>
        <p>If you trade using borrowed money from your broker (margin trading), calculating your true stock profit becomes exponentially more difficult, but also more crucial. Margin accounts allow you to amplify your buying power, but they come with daily compounding interest charges.</p>

        <p>Let's say you buy $10,000 worth of stock using $5,000 of your own money and $5,000 borrowed on margin at an 8% annual interest rate. You hold the stock for exactly one year, and it appreciates by 5%. You sell the position for $10,500.</p>

        <ul>
          <li><strong>Gross Profit:</strong> $500</li>
          <li><strong>Margin Interest Paid:</strong> 8% of $5,000 = $400</li>
          <li><strong>Trading Commissions:</strong> $20 ($10 buy, $10 sell)</li>
          <li><strong>Net Profit:</strong> $500 - $400 - $20 = <strong>$80</strong></li>
        </ul>

        <p>While the stock went up 5%, your actual return on your $5,000 invested capital is merely 1.6% ($80 / $5,000). Had the stock remained perfectly flat for the year, you wouldn't have broken even—you would have lost $420 purely from the costs of financing and execution. This highlights why calculating your exact net stock profit isn't just an accounting exercise; it is a fundamental survival skill for active market participants.</p>

        <h3>Advanced Tip: Keep a Trading Journal</h3>
        <p>If you're going to actively manage a portfolio rather than passively index, the single best habit you can build is maintaining a meticulous trading journal. Every time you close a position, log the exact buy price, exact sell price, the total number of shares, and the cumulative fees paid to the broker. Calculate your net profit and your ROI, and record them alongside the <em>reason</em> you took the trade.</p>

        <p>Over a sample size of 50 to 100 trades, patterns will emerge. You might discover that your winning trades are heavily concentrated in technology stocks, or that a specific technical setup you trade always seems to trigger stop-losses prematurely due to volatility. More importantly, your journal will reveal exactly how much of your gross gains are being siphoned away by transaction costs. If you find that fees are consuming more than 10-15% of your gross profits over a quarter, it is a mathematical imperative that you either scale up your position sizes (to make the fixed fees relatively smaller) or drastically reduce your trading frequency.</p>

        <div class="faq-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-item">
            <h3>How do you calculate profit on a stock?</h3>
            <p>To calculate profit on a stock, you subtract the total purchase cost (including buying fees) from the total sale proceeds (after deducting selling fees). The formula is: Profit = (Sell Price × Shares) - (Buy Price × Shares) - Buying Fees - Selling Fees.</p>
          </div>
          <div class="faq-item">
            <h3>What is a good return on investment (ROI) for stocks?</h3>
            <p>Historically, the average annual return of the stock market (like the S&P 500) is around 10% before inflation. A "good" ROI depends on your holding period; a 20% return over a few months is excellent, while a 20% return over 5 years is below average.</p>
          </div>
          <div class="faq-item">
            <h3>Are fees really that important when calculating stock profit?</h3>
            <p>Yes, especially for smaller trades or active trading. If you buy a stock for $100 and it goes to $105, you have a 5% gain. But if you paid a $5 commission to buy and $5 to sell, your net profit is actually a $5 loss.</p>
          </div>
          <div class="faq-item">
            <h3>Does this stock profit calculator include taxes?</h3>
            <p>No, this calculator determines your pre-tax net profit. Capital gains taxes vary significantly based on your income bracket, filing status, local laws, and whether you held the stock for more or less than a year (short-term vs. long-term capital gains).</p>
          </div>
          <div class="faq-item">
            <h3>How do I calculate ROI percentage?</h3>
            <p>ROI (Return on Investment) percentage is calculated by dividing your net profit by your total investment cost (including buying fees), and multiplying by 100. Formula: ROI % = (Net Profit / Total Cost) × 100.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</SiteLayout>

<style>
  .calc-inputs-grid .input-group {
    margin-bottom: 0;
  }

  .input-wrapper input {
    background-color: var(--bg-color);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-family: var(--font-mono);
    width: 100%;
    transition: border-color 0.2s;
  }

  .input-wrapper input:focus {
    outline: none;
    border-color: var(--accent-color);
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const sharesInput = document.getElementById("shares");
    const buyPriceInput = document.getElementById("buy-price");
    const sellPriceInput = document.getElementById("sell-price");
    const buyFeeInput = document.getElementById("buy-fee");
    const sellFeeInput = document.getElementById("sell-fee");

    const profitDisplay = document.getElementById("net-profit");
    const roiDisplay = document.getElementById("roi-percentage");
    const costDisplay = document.getElementById("total-cost");
    const proceedsDisplay = document.getElementById("total-proceeds");

    const currencyFormatter = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });

    function calculate() {
      const shares = parseFloat(sharesInput.value) || 0;
      const buyPrice = parseFloat(buyPriceInput.value) || 0;
      const sellPrice = parseFloat(sellPriceInput.value) || 0;
      const buyFee = parseFloat(buyFeeInput.value) || 0;
      const sellFee = parseFloat(sellFeeInput.value) || 0;

      // Handle negative edge cases
      if (shares < 0 || buyPrice < 0 || sellPrice < 0 || buyFee < 0 || sellFee < 0) {
        profitDisplay.textContent = "Invalid Input";
        profitDisplay.style.color = "var(--text-secondary)";
        roiDisplay.textContent = "0.00%";
        roiDisplay.style.color = "var(--text-primary)";
        costDisplay.textContent = "$0.00";
        proceedsDisplay.textContent = "$0.00";
        return;
      }

      const totalCost = (shares * buyPrice) + buyFee;
      const totalProceeds = (shares * sellPrice) - sellFee;
      const netProfit = totalProceeds - totalCost;

      let roi = 0;
      if (totalCost > 0) {
        roi = (netProfit / totalCost) * 100;
      }

      // Update DOM
      costDisplay.textContent = currencyFormatter.format(totalCost);
      proceedsDisplay.textContent = currencyFormatter.format(totalProceeds);

      profitDisplay.textContent = currencyFormatter.format(netProfit);
      roiDisplay.textContent = roi.toFixed(2) + "%";

      // Styling based on profit/loss
      if (netProfit > 0) {
        // use color-mix to avoid hardcoded hex colors when dealing with CSS vars
        profitDisplay.style.color = "color-mix(in srgb, var(--accent-color) 80%, white)";
        roiDisplay.style.color = "color-mix(in srgb, var(--accent-color) 80%, white)";
      } else if (netProfit < 0) {
        // use red-ish mix since we can't use hardcoded colors
        profitDisplay.style.color = "color-mix(in srgb, var(--text-primary) 50%, red)";
        roiDisplay.style.color = "color-mix(in srgb, var(--text-primary) 50%, red)";
      } else {
        profitDisplay.style.color = "var(--text-primary)";
        roiDisplay.style.color = "var(--text-primary)";
      }
    }

    // Attach Event Listeners
    const inputs = [sharesInput, buyPriceInput, sellPriceInput, buyFeeInput, sellFeeInput];
    inputs.forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Run initial calculation
    calculate();
  });
</script>