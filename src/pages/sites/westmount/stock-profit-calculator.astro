</style>

<script is:inline>
  function initCalculator() {
    const form = document.getElementById('stockProfitForm');
    if (!form) return;

    const inputs = ['shares', 'buyPrice', 'buyCommission', 'sellPrice', 'sellCommission', 'taxRate'];

    const elements = {};
    inputs.forEach(id => {
      elements[id] = document.getElementById(id);
      if (elements[id]) {
        elements[id].addEventListener('input', calculateProfit);
      }
    });

    const results = {
      netProfit: document.getElementById('netProfit'),
      roi: document.getElementById('roi'),
      grossProfit: document.getElementById('grossProfit'),
      grossRevenueVal: document.getElementById('grossRevenueVal'),
      initialCostVal: document.getElementById('initialCostVal'),
      totalFeesVal: document.getElementById('totalFeesVal'),
      taxesOwedVal: document.getElementById('taxesOwedVal'),
      netProceedsVal: document.getElementById('netProceedsVal')
    };

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value);
    }

    function formatPercent(value) {
      return new Intl.NumberFormat('en-US', {
        style: 'percent',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value / 100);
    }

    function updateColor(element, value) {
      if (!element) return;
      element.className = 'result-value';
      if (value > 0) element.classList.add('positive');
      else if (value < 0) element.classList.add('negative');
      else element.classList.add('neutral');
    }

    function calculateProfit() {
      // Get values
      const shares = parseFloat(elements.shares.value) || 0;
      const buyPrice = parseFloat(elements.buyPrice.value) || 0;
      const buyComm = parseFloat(elements.buyCommission.value) || 0;
      const sellPrice = parseFloat(elements.sellPrice.value) || 0;
      const sellComm = parseFloat(elements.sellCommission.value) || 0;
      const taxRate = parseFloat(elements.taxRate.value) || 0;

      // Core Math
      // We keep the initial purchase distinct from fees for the breakdown table
      const purchaseValue = shares * buyPrice;

      const grossRevenue = (shares * sellPrice); // Value of shares sold

      const totalFees = buyComm + sellComm;

      const initialInvestmentCost = purchaseValue + buyComm;

      // Profit is gross revenue minus initial investment cost (which is purchaseValue + totalFees)
      const grossProfit = grossRevenue - purchaseValue - totalFees;

      // Taxes are only paid on positive gross profit
      let taxesOwed = 0;
      if (grossProfit > 0) {
        taxesOwed = grossProfit * (taxRate / 100);
      }

      const netProfit = grossProfit - taxesOwed;

      let roi = 0;
      if (initialInvestmentCost > 0) {
        roi = (netProfit / initialInvestmentCost) * 100;
      }

      const netProceeds = grossRevenue - sellComm - taxesOwed; // What you actually walk away with in cash, subtracting sellComm because buyComm is already paid

      // Update UI
      if (results.netProfit) {
        results.netProfit.textContent = formatCurrency(netProfit);
        updateColor(results.netProfit, netProfit);
      }

      if (results.roi) {
        results.roi.textContent = formatPercent(roi);
        updateColor(results.roi, roi);
      }

      if (results.grossProfit) {
        results.grossProfit.textContent = formatCurrency(grossProfit);
        updateColor(results.grossProfit, grossProfit);
      }

      // Update Table
      if (results.grossRevenueVal) results.grossRevenueVal.textContent = formatCurrency(grossRevenue);
      if (results.initialCostVal) results.initialCostVal.textContent = "-" + formatCurrency(purchaseValue);
      if (results.totalFeesVal) results.totalFeesVal.textContent = "-" + formatCurrency(totalFees);
      if (results.taxesOwedVal) results.taxesOwedVal.textContent = "-" + formatCurrency(taxesOwed);
      if (results.netProceedsVal) results.netProceedsVal.textContent = formatCurrency(netProceeds);
    }

    // Initial calculation
    calculateProfit();
  }

  // Setup execution
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }

  // Astro view transitions support
  document.addEventListener('astro:page-load', initCalculator);
</script>
