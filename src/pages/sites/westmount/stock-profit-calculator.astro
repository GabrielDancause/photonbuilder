    border-radius: 0 8px 8px 0;
    color: var(--text-primary);
    overflow-x: auto;
  }

  .details-faq summary {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text-primary);
    cursor: pointer;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-color);
    list-style-position: inside;
  }

  .details-faq summary:hover {
    color: var(--accent-color);
  }

