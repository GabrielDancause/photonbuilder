            <thead>
              <tr style="border-bottom: 2px solid var(--border-color);">
                <th style="padding: 0.75rem; text-align: left; color: var(--text-secondary);">Breakdown</th>
                <th style="padding: 0.75rem; text-align: right; color: var(--text-secondary);">Amount</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.75rem;">Gross Revenue</td>
                <td style="padding: 0.75rem; text-align: right;" id="grossRevenueVal">$6,500.00</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.75rem;">Initial Investment Cost</td>
                <td style="padding: 0.75rem; text-align: right; color: color-mix(in srgb, var(--text-primary) 80%, #ef4444);" id="initialCostVal">-$5,000.00</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.75rem;">Total Fees & Commissions</td>
                <td style="padding: 0.75rem; text-align: right; color: color-mix(in srgb, var(--text-primary) 80%, #ef4444);" id="totalFeesVal">-$0.00</td>
              </tr>
              <tr style="border-bottom: 1px solid var(--border-color);">
                <td style="padding: 0.75rem;">Taxes Owed</td>
                <td style="padding: 0.75rem; text-align: right; color: color-mix(in srgb, var(--text-primary) 80%, #ef4444);" id="taxesOwedVal">-$225.00</td>
              </tr>
              <tr style="background: color-mix(in srgb, var(--accent-color) 10%, transparent);">
                <td style="padding: 0.75rem; font-weight: bold;">Net Proceeds (Take Home)</td>
                <td style="padding: 0.75rem; text-align: right; font-weight: bold;" id="netProceedsVal">$6,275.00</td>
              </tr>
            </tbody>
          </table>
        </div>
