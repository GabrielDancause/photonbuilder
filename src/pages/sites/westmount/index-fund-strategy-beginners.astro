    padding: 40px 0 20px;
    border-bottom: 1px solid var(--border-color);
  }
  .badge {
    display: inline-block;
    background: var(--accent-color);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 4px 12px;
    border-radius: 3px;
