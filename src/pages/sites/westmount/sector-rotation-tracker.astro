// Stats
const bestSector = SECTORS.reduce((a,b) => a.ytd > b.ytd ? a : b);
const worstSector = SECTORS.reduce((a,b) => a.ytd < b.ytd ? a : b);
const avgYTD = SECTORS.reduce((a,s) => a + s.ytd, 0) / SECTORS.length;
const spread = bestSector.ytd - worstSector.ytd;

document.getElementById('stats').innerHTML = `
  <div class="stat"><div class="val">11</div><div class="label">GICS Sectors</div></div>
