  <div class="stat"><div class="val">${worstSector.ticker}</div><div class="label">YTD Laggard (${worstSector.ytd > 0 ? '+' : ''}${worstSector.ytd}%)</div></div>
  <div class="stat"><div class="val">${spread.toFixed(1)}%</div><div class="label">Best-Worst Spread</div></div>
`;

// Sortable table
let sortKey = 'ytd', sortDir = -1;

function renderTable() {
  const sorted = [...SECTORS].sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (typeof va === 'string') return va.localeCompare(vb) * sortDir;
    return (va - vb) * sortDir;
  });

  const tbody = document.getElementById('tbody');
  tbody.innerHTML = sorted.map(s => `<tr>
    <td>${s.sector}</td>
    <td class="ticker">${s.ticker}</td>
    <td class="num ${s.w1 >= 0 ? 'pos' : 'neg'}">${s.w1 > 0 ? '+' : ''}${s.w1.toFixed(1)}%</td>
    <td class="num ${s.m1 >= 0 ? 'pos' : 'neg'}">${s.m1 > 0 ? '+' : ''}${s.m1.toFixed(1)}%</td>
    <td class="num ${s.m3 >= 0 ? 'pos' : 'neg'}">${s.m3 > 0 ? '+' : ''}${s.m3.toFixed(1)}%</td>
    <td class="num ${s.ytd >= 0 ? 'pos' : 'neg'}">${s.ytd > 0 ? '+' : ''}${s.ytd.toFixed(1)}%</td>
    <td class="num ${s.y1 >= 0 ? 'pos' : 'neg'}">${s.y1 > 0 ? '+' : ''}${s.y1.toFixed(1)}%</td>
    <td class="num">${s.weight.toFixed(1)}%</td>
  </tr>`).join('');
}

document.querySelectorAll('th[data-key]').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.key;
    if (sortKey === key) sortDir *= -1;
    else { sortKey = key; sortDir = th.dataset.type === 'num' ? -1 : 1; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
    renderTable();
  });
});

renderTable();

// Heatmap
let hmPeriod = 'm3';

function getHeatmapColor(val) {
  // Map value from -10 to +15 onto a color scale
  const t = Math.max(0, Math.min(1, (val + 10) / 25));
  if (t < 0.25) {
    const p = t / 0.25;
    return `rgb(${Math.round(220 + p * 19)}, ${Math.round(38 + p * 30)}, ${Math.round(38 + p * 0)})`;
  } else if (t < 0.5) {
    const p = (t - 0.25) / 0.25;
    return `rgb(${Math.round(239 - p * 0)}, ${Math.round(68 + p * 90)}, ${Math.round(38 + p * -27)})`;
  } else if (t < 0.75) {
    const p = (t - 0.5) / 0.25;
    return `rgb(${Math.round(245 - p * 211)}, ${Math.round(158 + p * 39)}, ${Math.round(11 + p * 83)})`;
  } else {
    const p = (t - 0.75) / 0.25;
    return `rgb(${Math.round(34 - p * 12)}, ${Math.round(197 - p * 34)}, ${Math.round(94 - p * 48)})`;
  }
}

function renderHeatmap() {
  const sorted = [...SECTORS].sort((a, b) => b[hmPeriod] - a[hmPeriod]);
  const grid = document.getElementById('heatmapGrid');
  grid.innerHTML = sorted.map(s => {
    const val = s[hmPeriod];
    const bg = getHeatmapColor(val);
    return `<div class="hm-cell" style="background:${bg}">
      <div class="hm-ticker">${s.ticker}</div>
      <div class="hm-name">${s.sector}</div>
      <div class="hm-val">${val > 0 ? '+' : ''}${val.toFixed(1)}%</div>
    </div>`;
  }).join('');
}

document.getElementById('hmControls').addEventListener('click', e => {
  if (e.target.tagName !== 'BUTTON') return;
  hmPeriod = e.target.dataset.period;
  document.querySelectorAll('#hmControls button').forEach(b => b.classList.remove('active'));
  e.target.classList.add('active');
  renderHeatmap();
});

renderHeatmap();

