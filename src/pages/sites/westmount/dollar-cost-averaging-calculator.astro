---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Dollar Cost Averaging Calculator: DCA vs Lump Sum Compared",
  description: "Compare dollar cost averaging vs lump sum investing with Monte Carlo simulations, price charts, and historical S&P 500 backtesting. Free DCA calculator.",
  category: "tool",
  published: "2026-03-21"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "datePublished": meta.published,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/dollar-cost-averaging-calculator"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is dollar cost averaging (DCA)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dollar cost averaging is an investment strategy where you divide your total investment amount into equal periodic purchases regardless of the asset's price. By buying at regular intervals, you purchase more shares when prices are low and fewer when prices are high, which can reduce the impact of volatility on your average cost per share."
          }
        },
        {
          "@type": "Question",
          "name": "Is dollar cost averaging better than lump sum investing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Historically, lump sum investing outperforms DCA about two-thirds of the time because markets tend to go up over time. However, DCA reduces the risk of investing at a market peak and can be psychologically easier for investors who are uncomfortable deploying a large sum all at once. The best strategy depends on your risk tolerance and market outlook."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I invest with dollar cost averaging?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The most common DCA frequencies are weekly, biweekly (every two weeks), or monthly. Monthly is the most popular because it aligns with pay schedules. Research shows that the specific frequency matters less than consistency—the key is to invest regularly regardless of market conditions."
          }
        },
        {
          "@type": "Question",
          "name": "Does DCA work in a bear market?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DCA tends to shine in bear markets and volatile sideways markets. When prices are falling, your fixed investment amount buys more shares at lower prices, reducing your average cost basis. When the market eventually recovers, you benefit from having accumulated shares at discounted prices."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between DCA and regular investing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "True DCA involves taking a lump sum you already have and spreading it out over time. Regular investing (sometimes called automatic investing) means investing new money as you earn it, such as contributing from each paycheck. While the mechanics are similar, DCA is specifically a strategy for deploying existing capital, whereas regular investing is about building wealth incrementally."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/dollar-cost-averaging-calculator"
  schema={schema}
>
  <div class="page-content">

    <div style="text-align: center; margin-bottom: 2rem;">
      <h1>Dollar Cost Averaging Calculator</h1>
      <p style="font-size: 1.2rem; max-width: 650px; margin: 0 auto;">Compare DCA vs lump sum investing with simulated price paths and Monte Carlo analysis.</p>
    </div>

    <div class="calculator-card">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
        <div class="input-group">
          <label for="totalAmount">Total Investment Amount</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="totalAmount" value="12000" min="100" step="100" style="padding-left: 2rem;">
          </div>
        </div>

        <div class="input-group">
          <label for="period">Investment Period</label>
          <div class="input-wrapper">
            <input type="number" id="period" value="12" min="1" max="120" step="1">
            <span class="suffix">months</span>
          </div>
        </div>

        <div class="input-group">
          <label for="frequency">Investment Frequency</label>
          <div class="input-wrapper">
            <select id="frequency">
              <option value="weekly">Weekly</option>
              <option value="biweekly">Biweekly</option>
              <option value="monthly" selected>Monthly</option>
            </select>
          </div>
        </div>

        <div class="input-group">
          <label for="annualReturn">Expected Annual Return</label>
          <div class="input-wrapper">
            <input type="number" id="annualReturn" value="10" min="-50" max="100" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="startPrice">Starting Share Price</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="startPrice" value="100" min="0.01" step="1" style="padding-left: 2rem;">
          </div>
        </div>

        <div class="input-group">
          <label for="volatility">Price Volatility</label>
          <div class="input-wrapper">
            <select id="volatility">
              <option value="low">Low (10%)</option>
              <option value="medium" selected>Medium (20%)</option>
              <option value="high">High (35%)</option>
            </select>
          </div>
        </div>
      </div>

      <button id="runBtn" style="display: block; width: 100%; margin-top: 1.5rem; padding: 0.85rem; background: var(--accent-color); color: #fff; border: none; border-radius: 8px; font-size: 1.05rem; font-weight: 600; cursor: pointer;">Run Simulation</button>
    </div>

    <!-- Comparison Results -->
    <div class="stats-grid" id="resultsGrid" style="margin-top: 2rem; display: none;">
      <div class="stat-card">
        <span class="calc-result-label">DCA Final Value</span>
        <div class="stat-value" style="color:#3b82f6;" id="dcaFinalValue">$0</div>
        <div class="stat-sub" id="dcaReturn">+0%</div>
      </div>
      <div class="stat-card">
        <span class="calc-result-label">Lump Sum Final Value</span>
        <div class="stat-value" style="color:#10b981;" id="lsFinalValue">$0</div>
        <div class="stat-sub" id="lsReturn">+0%</div>
      </div>
      <div class="stat-card">
        <span class="calc-result-label">DCA Avg Cost/Share</span>
        <div class="stat-value" id="dcaAvgCost">$0</div>
      </div>
      <div class="stat-card">
        <span class="calc-result-label">Lump Sum Cost/Share</span>
        <div class="stat-value" id="lsCostPerShare">$0</div>
      </div>
    </div>

    <div id="winner-banner" style="display: none; text-align: center; padding: 1rem; border-radius: 8px; margin-top: 1rem; font-weight: 600; font-size: 1.1rem;"></div>

    <!-- Price Chart with Buy Points -->
    <div class="chart-container" id="priceChartContainer" style="margin-top: 2rem; display: none;">
      <h3 style="margin-top: 0; margin-bottom: 1rem;">Simulated Price Path &amp; DCA Buy Points</h3>
      <canvas id="priceChart" height="300"></canvas>
    </div>

    <!-- Monte Carlo Section -->
    <div class="chart-container" id="monteCarloContainer" style="margin-top: 2rem; display: none;">
      <h3 style="margin-top: 0; margin-bottom: 0.5rem;">Monte Carlo Simulation (100 Runs)</h3>
      <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem;">Each line represents a possible outcome. The bold lines show the median path for each strategy.</p>
      <canvas id="monteCarloChart" height="320"></canvas>
      <div class="mc-stats" id="mcStats" style="margin-top: 1.5rem;"></div>
    </div>

    <!-- Historical Backtesting -->
    <div class="chart-container" id="backtestContainer" style="margin-top: 2rem; display: none;">
      <h3 style="margin-top: 0; margin-bottom: 1rem;">Historical Backtest: S&amp;P 500</h3>
      <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem;">Based on actual S&amp;P 500 monthly returns from 2000–2024, this shows how your selected amount invested via DCA vs lump sum would have performed across rolling periods matching your selected duration.</p>
      <div id="backtestResults"></div>
    </div>

    <!-- DCA Purchase Schedule -->
    <div class="chart-container" id="scheduleContainer" style="margin-top: 2rem; display: none;">
      <h3 style="margin-top: 0; margin-bottom: 1rem;">DCA Purchase Schedule</h3>
      <div class="table-container" style="max-height: 400px; overflow-y: auto;">
        <table id="purchaseTable">
          <thead style="position: sticky; top: 0; z-index: 1;">
            <tr>
              <th>Purchase #</th>
              <th>Price</th>
              <th>Amount Invested</th>
              <th>Shares Bought</th>
              <th>Total Shares</th>
              <th>Portfolio Value</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script is:inline>
    (function() {
      var $ = function(id) { return document.getElementById(id); };
      var fmt = function(n) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
      };
      var fmtPct = function(n) { return (n >= 0 ? '+' : '') + n.toFixed(2) + '%'; };

      var volMap = { low: 0.10, medium: 0.20, high: 0.35 };
      var freqMap = { weekly: 52/12, biweekly: 26/12, monthly: 1 };

      // S&P 500 approximate monthly total returns 2000-2024
      var sp500Monthly = [
        -0.0504,0.0201,-0.0198,0.0328,-0.0310,-0.0239,-0.0156,0.0621,-0.0528,-0.0049,-0.0801,-0.0041,
        -0.0146,-0.0189,0.0367,0.0607,-0.0062,-0.0067,-0.0780,0.0049,-0.0097,0.0189,-0.0603,0.0057,
        -0.0262,-0.0150,0.0008,0.0081,0.0509,0.0118,0.0162,0.0195,-0.0112,0.0556,0.0071,-0.0015,
        0.0173,0.0122,-0.0164,0.0121,0.0116,0.0334,0.0180,-0.0343,0.0396,0.0140,0.0386,0.0325,
        -0.0253,0.0189,0.0210,-0.0192,0.0301,0.0001,0.0353,0.0362,-0.0112,0.0297,-0.0350,0.0385,
        0.0251,0.0013,0.0114,0.0122,0.0246,-0.0180,0.0127,-0.0257,0.0115,0.0158,0.0363,0.0141,
        0.0026,-0.0310,0.0124,-0.0160,0.0325,-0.0288,-0.0350,-0.0129,0.0358,0.0250,0.0135,0.0096,
        -0.0613,0.0127,-0.0037,-0.0434,0.0444,-0.0135,-0.0167,0.0398,-0.0100,-0.0275,0.0475,-0.0069,
        -0.0604,-0.0341,-0.0043,0.0487,0.0130,0.0099,-0.0084,-0.0013,-0.0908,-0.0694,-0.0718,0.0103,
        -0.0846,-0.1077,-0.0574,0.0893,0.0939,0.0557,-0.0241,-0.0028,0.0372,-0.0192,0.0596,0.0178,
        -0.0363,0.0293,0.0597,0.0152,0.0093,-0.0548,-0.0066,0.0341,-0.0387,0.0376,-0.0001,0.0653,
        0.0232,0.0327,0.0001,0.0177,0.0286,-0.0139,-0.0021,-0.0574,-0.0744,0.1077,0.0030,0.0104,
        0.0454,-0.0020,0.0328,0.0112,-0.0606,-0.0396,0.0136,0.0203,0.0249,0.0243,-0.0054,0.0091,
        0.0502,0.0112,0.0360,0.0181,-0.0222,0.0295,-0.0131,-0.0300,0.0307,0.0451,0.0280,0.0236,
        -0.0356,0.0443,0.0069,0.0062,0.0208,0.0191,-0.0141,0.0377,0.0184,-0.0142,0.0269,0.0004,
        -0.0313,0.0548,-0.0164,0.0085,0.0105,0.0181,0.0207,0.0396,-0.0263,-0.0095,0.0036,0.0165,
        0.0180,-0.0004,0.0012,0.0120,0.0116,-0.0034,0.0361,-0.0204,0.0002,0.0378,0.0191,0.0078,
        0.0562,-0.0384,0.0081,-0.0054,0.0034,0.0055,0.0369,-0.0166,0.0031,0.0307,0.0582,0.0127,
        0.0632,-0.0312,0.0246,0.0175,0.0144,-0.0191,0.0122,0.0131,0.0297,-0.0252,0.0327,0.0184,
        -0.0009,0.0312,0.0424,0.0197,0.0080,-0.0557,-0.0169,-0.0478,0.0701,0.0612,-0.0016,0.0118,
        -0.0100,0.0536,-0.0001,0.0446,0.0283,0.0211,0.0240,0.0370,0.0280,0.0201,-0.0125,0.0296,
        0.0153,-0.0201,0.0310,0.0151,0.0033,-0.0108,-0.0416,0.0438,0.0200,-0.0069,0.0587,0.0447,
        0.0159,0.0527,-0.0139,-0.0050,0.0165,-0.0022,-0.0158,0.0124,0.0189,-0.0095,0.0556,0.0035,
        -0.0161,0.0142,-0.0008,0.0400,0.0234,-0.0063,-0.0034,0.0202,-0.0412,0.0099,0.0372,0.0453,
        0.0262,-0.0152,0.0339,-0.0420,0.0487,-0.0359,0.0345,-0.0235,-0.0477,-0.0066,0.0887,0.0373
      ];

      function simulatePricePath(months, annualReturn, annualVol, startPrice) {
        var dt = 1/12;
        var mu = annualReturn;
        var sigma = annualVol;
        var prices = [startPrice];
        for (var i = 1; i <= months; i++) {
          var z = gaussianRandom();
          var drift = (mu - 0.5 * sigma * sigma) * dt;
          var diffusion = sigma * Math.sqrt(dt) * z;
          prices.push(prices[i-1] * Math.exp(drift + diffusion));
        }
        return prices;
      }

      function gaussianRandom() {
        var u = 0, v = 0;
        while (u === 0) u = Math.random();
        while (v === 0) v = Math.random();
        return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
      }

      function getDCABuyIndices(months, freq) {
        var perMonth = freqMap[freq];
        var totalBuys = Math.max(1, Math.round(months * perMonth));
        var interval = months / totalBuys;
        var indices = [];
        for (var i = 0; i < totalBuys; i++) {
          indices.push(Math.min(Math.round(i * interval), months));
        }
        return indices;
      }

      function runSingleSim(prices, totalAmount, buyIndices) {
        var amountPerBuy = totalAmount / buyIndices.length;
        var totalShares = 0;
        var purchases = [];

        for (var j = 0; j < buyIndices.length; j++) {
          var idx = buyIndices[j];
          var price = prices[idx];
          var shares = amountPerBuy / price;
          totalShares += shares;
          purchases.push({ index: idx, price: price, amountInvested: amountPerBuy, shares: shares, totalShares: totalShares });
        }

        var finalPrice = prices[prices.length - 1];
        var dcaFinalValue = totalShares * finalPrice;
        var avgCost = totalAmount / totalShares;

        var lsShares = totalAmount / prices[0];
        var lsFinalValue = lsShares * finalPrice;

        return { dcaFinalValue: dcaFinalValue, lsFinalValue: lsFinalValue, avgCost: avgCost, totalShares: totalShares, lsShares: lsShares, purchases: purchases, finalPrice: finalPrice };
      }

      function runCalculation() {
        var totalAmount = Math.max(100, parseFloat($('totalAmount').value) || 12000);
        var months = Math.min(120, Math.max(1, parseInt($('period').value) || 12));
        $('period').value = months;
        var freq = $('frequency').value;
        var annualReturn = (parseFloat($('annualReturn').value) || 10) / 100;
        var startPrice = Math.max(0.01, parseFloat($('startPrice').value) || 100);
        var vol = volMap[$('volatility').value];

        var prices = simulatePricePath(months, annualReturn, vol, startPrice);
        var buyIndices = getDCABuyIndices(months, freq);
        var result = runSingleSim(prices, totalAmount, buyIndices);

        $('resultsGrid').style.display = '';
        $('dcaFinalValue').textContent = fmt(result.dcaFinalValue);
        $('lsFinalValue').textContent = fmt(result.lsFinalValue);
        $('dcaReturn').textContent = fmtPct((result.dcaFinalValue - totalAmount) / totalAmount * 100);
        $('lsReturn').textContent = fmtPct((result.lsFinalValue - totalAmount) / totalAmount * 100);
        $('dcaAvgCost').textContent = fmt(result.avgCost);
        $('lsCostPerShare').textContent = fmt(prices[0]);

        var banner = $('winner-banner');
        banner.style.display = 'block';
        if (result.lsFinalValue > result.dcaFinalValue) {
          var diff = result.lsFinalValue - result.dcaFinalValue;
          banner.style.background = 'rgba(16,185,129,0.12)';
          banner.style.color = '#10b981';
          banner.textContent = 'Lump sum wins by ' + fmt(diff) + ' in this simulation';
        } else {
          var diff2 = result.dcaFinalValue - result.lsFinalValue;
          banner.style.background = 'rgba(59,130,246,0.12)';
          banner.style.color = '#3b82f6';
          banner.textContent = 'DCA wins by ' + fmt(diff2) + ' in this simulation';
        }

        drawPriceChart(prices, result.purchases, months);
        drawPurchaseTable(result.purchases, prices);
        runMonteCarlo(months, annualReturn, vol, startPrice, totalAmount, freq);
        runBacktest(months, totalAmount, freq);
      }

      var priceChartInstance = null;
      function drawPriceChart(prices, purchases, months) {
        $('priceChartContainer').style.display = '';
        var ctx = $('priceChart').getContext('2d');
        if (priceChartInstance) priceChartInstance.destroy();

        var labels = [];
        for (var i = 0; i < prices.length; i++) {
          labels.push(i === 0 ? 'Start' : 'Mo ' + i);
        }

        var buyPoints = new Array(prices.length).fill(null);
        purchases.forEach(function(p) { buyPoints[p.index] = prices[p.index]; });

        priceChartInstance = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'Share Price',
                data: prices,
                borderColor: '#6366f1',
                backgroundColor: 'rgba(99,102,241,0.08)',
                fill: true,
                tension: 0.3,
                pointRadius: 0,
                borderWidth: 2
              },
              {
                label: 'DCA Buy Points',
                data: buyPoints,
                borderColor: 'transparent',
                backgroundColor: '#10b981',
                pointRadius: 5,
                pointStyle: 'circle',
                showLine: false
              }
            ]
          },
          options: {
            responsive: true,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: { labels: { color: '#94a3b8' } },
              tooltip: {
                callbacks: {
                  label: function(ctx) { return ctx.dataset.label + ': ' + fmt(ctx.parsed.y); }
                }
              }
            },
            scales: {
              x: { ticks: { color: '#64748b', maxTicksLimit: 12 }, grid: { color: 'rgba(148,163,184,0.1)' } },
              y: { ticks: { color: '#64748b', callback: function(v) { return '$' + v.toFixed(0); } }, grid: { color: 'rgba(148,163,184,0.1)' } }
            }
          }
        });
      }

      function drawPurchaseTable(purchases, prices) {
        $('scheduleContainer').style.display = '';
        var tbody = document.querySelector('#purchaseTable tbody');
        var finalPrice = prices[prices.length - 1];
        tbody.innerHTML = purchases.map(function(p, i) {
          return '<tr>' +
            '<td>' + (i + 1) + '</td>' +
            '<td>' + fmt(p.price) + '</td>' +
            '<td>' + fmt(p.amountInvested) + '</td>' +
            '<td>' + p.shares.toFixed(4) + '</td>' +
            '<td>' + p.totalShares.toFixed(4) + '</td>' +
            '<td style="color:var(--accent-color);font-weight:600;">' + fmt(p.totalShares * finalPrice) + '</td>' +
          '</tr>';
        }).join('');
      }

      var mcChartInstance = null;
      function runMonteCarlo(months, annualReturn, vol, startPrice, totalAmount, freq) {
        $('monteCarloContainer').style.display = '';
        var ctx = $('monteCarloChart').getContext('2d');
        if (mcChartInstance) mcChartInstance.destroy();

        var N = 100;
        var buyIndices = getDCABuyIndices(months, freq);
        var dcaFinals = [];
        var lsFinals = [];
        var dcaPaths = [];
        var lsPaths = [];

        for (var s = 0; s < N; s++) {
          var prices = simulatePricePath(months, annualReturn, vol, startPrice);
          var res = runSingleSim(prices, totalAmount, buyIndices);
          dcaFinals.push(res.dcaFinalValue);
          lsFinals.push(res.lsFinalValue);

          var amountPerBuy = totalAmount / buyIndices.length;
          var dcaShares = 0;
          var buyIdx = 0;
          var dcaPath = [];
          var lsSharesTotal = totalAmount / prices[0];
          var lsPath = [];

          for (var m = 0; m <= months; m++) {
            while (buyIdx < buyIndices.length && buyIndices[buyIdx] <= m) {
              dcaShares += amountPerBuy / prices[buyIndices[buyIdx]];
              buyIdx++;
            }
            dcaPath.push(dcaShares * prices[m]);
            lsPath.push(lsSharesTotal * prices[m]);
          }
          dcaPaths.push(dcaPath);
          lsPaths.push(lsPath);
        }

        var labels = [];
        for (var i = 0; i <= months; i++) {
          labels.push(i === 0 ? 'Start' : 'Mo ' + i);
        }
        var medianDCA = [];
        var medianLS = [];
        for (var m2 = 0; m2 <= months; m2++) {
          var dcaVals = dcaPaths.map(function(p) { return p[m2]; }).sort(function(a,b) { return a - b; });
          var lsVals = lsPaths.map(function(p) { return p[m2]; }).sort(function(a,b) { return a - b; });
          medianDCA.push(dcaVals[Math.floor(N/2)]);
          medianLS.push(lsVals[Math.floor(N/2)]);
        }

        var datasets = [];

        for (var s2 = 0; s2 < N; s2++) {
          datasets.push({
            data: dcaPaths[s2],
            borderColor: 'rgba(59,130,246,0.07)',
            borderWidth: 1,
            pointRadius: 0,
            fill: false,
            tension: 0.2
          });
          datasets.push({
            data: lsPaths[s2],
            borderColor: 'rgba(16,185,129,0.07)',
            borderWidth: 1,
            pointRadius: 0,
            fill: false,
            tension: 0.2
          });
        }

        datasets.push({
          label: 'DCA (Median)',
          data: medianDCA,
          borderColor: '#3b82f6',
          borderWidth: 3,
          pointRadius: 0,
          fill: false,
          tension: 0.3
        });
        datasets.push({
          label: 'Lump Sum (Median)',
          data: medianLS,
          borderColor: '#10b981',
          borderWidth: 3,
          pointRadius: 0,
          fill: false,
          tension: 0.3
        });

        mcChartInstance = new Chart(ctx, {
          type: 'line',
          data: { labels: labels, datasets: datasets },
          options: {
            responsive: true,
            animation: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: {
                labels: {
                  color: '#94a3b8',
                  filter: function(item) { return item.text !== undefined; }
                }
              },
              tooltip: {
                filter: function(item) { return item.dataset.label !== undefined; },
                callbacks: { label: function(ctx) { return ctx.dataset.label + ': ' + fmt(ctx.parsed.y); } }
              }
            },
            scales: {
              x: { ticks: { color: '#64748b', maxTicksLimit: 12 }, grid: { color: 'rgba(148,163,184,0.1)' } },
              y: { ticks: { color: '#64748b', callback: function(v) { return '$' + (v/1000).toFixed(0) + 'k'; } }, grid: { color: 'rgba(148,163,184,0.1)' } }
            }
          }
        });

        dcaFinals.sort(function(a,b) { return a - b; });
        lsFinals.sort(function(a,b) { return a - b; });

        // Count DCA wins by comparing paired simulations
        var dcaWins = 0;
        for (var w = 0; w < N; w++) {
          var dcaVal = dcaPaths[w][months];
          var lsVal = lsPaths[w][months];
          if (dcaVal > lsVal) dcaWins++;
        }

        $('mcStats').innerHTML =
          '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;">' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">DCA Median Final</span>' +
              '<div style="font-size:1.3rem;font-weight:700;color:#3b82f6;">' + fmt(dcaFinals[Math.floor(N/2)]) + '</div>' +
            '</div>' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">Lump Sum Median Final</span>' +
              '<div style="font-size:1.3rem;font-weight:700;color:#10b981;">' + fmt(lsFinals[Math.floor(N/2)]) + '</div>' +
            '</div>' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">DCA Best / Worst</span>' +
              '<div style="font-size:1.1rem;font-weight:600;color:var(--text-primary);">' + fmt(dcaFinals[N-1]) + ' / ' + fmt(dcaFinals[0]) + '</div>' +
            '</div>' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">Lump Sum Best / Worst</span>' +
              '<div style="font-size:1.1rem;font-weight:600;color:var(--text-primary);">' + fmt(lsFinals[N-1]) + ' / ' + fmt(lsFinals[0]) + '</div>' +
            '</div>' +
            '<div class="stat-card" style="grid-column: 1 / -1;">' +
              '<span class="calc-result-label">DCA Wins</span>' +
              '<div style="font-size:1.3rem;font-weight:700;color:var(--text-primary);">' + dcaWins + ' out of ' + N + ' simulations (' + dcaWins + '%)</div>' +
            '</div>' +
          '</div>';
      }

      function runBacktest(months, totalAmount, freq) {
        $('backtestContainer').style.display = '';
        if (months > sp500Monthly.length) {
          $('backtestResults').innerHTML = '<p style="color:var(--text-secondary);">Period too long for available historical data (max ~24 years).</p>';
          return;
        }

        var buyIndices = getDCABuyIndices(months, freq);
        var dcaWins = 0;
        var totalPeriods = 0;
        var totalDCAReturn = 0;
        var totalLSReturn = 0;

        for (var start = 0; start <= sp500Monthly.length - months; start++) {
          var prices = [100];
          for (var m = 0; m < months; m++) {
            prices.push(prices[prices.length - 1] * (1 + sp500Monthly[start + m]));
          }

          var res = runSingleSim(prices, totalAmount, buyIndices);
          var dcaReturn = (res.dcaFinalValue - totalAmount) / totalAmount * 100;
          var lsReturn = (res.lsFinalValue - totalAmount) / totalAmount * 100;

          if (res.dcaFinalValue > res.lsFinalValue) dcaWins++;
          totalPeriods++;
          totalDCAReturn += dcaReturn;
          totalLSReturn += lsReturn;
        }

        var avgDCA = totalDCAReturn / totalPeriods;
        var avgLS = totalLSReturn / totalPeriods;
        var lsWinPct = ((totalPeriods - dcaWins) / totalPeriods * 100).toFixed(1);
        var dcaWinPct = (dcaWins / totalPeriods * 100).toFixed(1);

        $('backtestResults').innerHTML =
          '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;">' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">Rolling Periods Tested</span>' +
              '<div style="font-size:1.5rem;font-weight:700;color:var(--text-primary);">' + totalPeriods + '</div>' +
            '</div>' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">Lump Sum Win Rate</span>' +
              '<div style="font-size:1.5rem;font-weight:700;color:#10b981;">' + lsWinPct + '%</div>' +
            '</div>' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">DCA Win Rate</span>' +
              '<div style="font-size:1.5rem;font-weight:700;color:#3b82f6;">' + dcaWinPct + '%</div>' +
            '</div>' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">Avg DCA Return</span>' +
              '<div style="font-size:1.3rem;font-weight:700;color:#3b82f6;">' + fmtPct(avgDCA) + '</div>' +
            '</div>' +
            '<div class="stat-card">' +
              '<span class="calc-result-label">Avg Lump Sum Return</span>' +
              '<div style="font-size:1.3rem;font-weight:700;color:#10b981;">' + fmtPct(avgLS) + '</div>' +
            '</div>' +
          '</div>' +
          '<p style="color:var(--text-secondary);margin-top:1rem;font-size:0.9rem;line-height:1.6;">Across ' + totalPeriods + ' rolling ' + months + '-month periods from 2000 to 2024, lump sum investing outperformed DCA ' + lsWinPct + '% of the time\u2014consistent with academic research showing that markets trend upward and deploying capital earlier captures more of that growth. However, DCA still won ' + dcaWinPct + '% of the time, particularly during periods that included major market downturns.</p>';
      }

      $('runBtn').addEventListener('click', runCalculation);
      runCalculation();
    })();
    </script>

