      width: 12px;
      height: 12px;
      border-radius: 50%;
    }

    .principal-dot { background-color: var(--accent-color); }
    .tax-dot { background-color: color-mix(in srgb, var(--accent-color) 70%, transparent); }
    .insurance-dot { background-color: color-mix(in srgb, var(--accent-color) 40%, transparent); }
