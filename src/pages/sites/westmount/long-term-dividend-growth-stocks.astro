---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Best Long-Term Dividend Growth Stocks | Westmount Fundamentals",
  description: "Explore the most reliable long-term dividend growth stocks. Discover companies that have consistently increased their payouts year after year, building true generational wealth.",
  category: "list",
  published: "2025-05-01"
};

const schema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What are long-term dividend growth stocks?", "acceptedAnswer": {"@type": "Answer", "text": "These are stocks of companies that have a consistent history of not only paying dividends but increasing their dividend payout year after year. They are often mature, stable companies."}}, {"@type": "Question", "name": "Why focus on dividend growth rather than high yield?", "acceptedAnswer": {"@type": "Answer", "text": "A high yield can sometimes signal a distressed company. Dividend growth indicates a healthy, growing business that can sustainably return increasing amounts of capital to shareholders over time, helping to outpace inflation."}}, {"@type": "Question", "name": "What is a good dividend growth rate?", "acceptedAnswer": {"@type": "Answer", "text": "A good dividend growth rate typically exceeds the rate of inflation. Consistently growing dividends by 5% to 10% annually is generally considered excellent for long-term investors."}}, {"@type": "Question", "name": "How does the payout ratio relate to dividend growth?", "acceptedAnswer": {"@type": "Answer", "text": "The payout ratio shows what percentage of earnings is paid as dividends. A lower payout ratio (e.g., under 60%) suggests the company has ample room to continue growing its dividend in the future."}}, {"@type": "Question", "name": "Are long-term dividend stocks good for retirement?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, they are highly favored by retirees because they provide a growing stream of passive income, which can help cover living expenses while preserving the principal investment."}}]};

const stocks = [
    { symbol: "JNJ", name: "Johnson & Johnson", yield: "3.2%", growthYears: 61, payoutRatio: "45%", analysis: "A healthcare behemoth with an impeccable track record. Its diversified business model across pharmaceuticals and medtech ensures extremely stable cash flows." },
    { symbol: "PG", name: "Procter & Gamble", yield: "2.5%", growthYears: 67, payoutRatio: "62%", analysis: "A consumer staples giant. Recessions rarely impact the demand for basic household goods, making PG a cornerstone of conservative dividend growth." },
    { symbol: "KO", name: "Coca-Cola Co.", yield: "3.1%", growthYears: 62, payoutRatio: "68%", analysis: "Warren Buffett's favorite. With unrivaled global brand power and a capital-light franchise model, KO generates immense free cash flow to fund its rising dividend." },
    { symbol: "MCD", name: "McDonald's Corp", yield: "2.4%", growthYears: 47, payoutRatio: "54%", analysis: "Operating largely as a real estate and franchise royalty business, McDonald's boasts highly predictable revenue streams perfect for steady dividend increases." },
    { symbol: "PEP", name: "PepsiCo Inc.", yield: "3.0%", growthYears: 51, payoutRatio: "65%", analysis: "Diversified across both beverages and snacks. PepsiCo offers defensive stability and has proven its pricing power in inflationary environments." },
    { symbol: "ABBV", name: "AbbVie Inc.", yield: "3.8%", growthYears: 52, payoutRatio: "48%", analysis: "Despite the Humira patent cliff, AbbVie's pipeline and successful acquisitions continue to drive robust cash flow, supporting aggressive dividend growth." },
    { symbol: "LMT", name: "Lockheed Martin", yield: "2.8%", growthYears: 21, payoutRatio: "42%", analysis: "A defense contractor with massive, long-term government contracts providing unmatched visibility into future earnings and dividend potential." },
    { symbol: "HD", name: "Home Depot", yield: "2.5%", growthYears: 14, payoutRatio: "50%", analysis: "A dominant force in home improvement. While cyclical, its long-term return on invested capital is spectacular, fueling rapid dividend growth." },
    { symbol: "V", name: "Visa Inc.", yield: "0.8%", growthYears: 15, payoutRatio: "21%", analysis: "The yield is tiny, but the growth rate is phenomenal. Visa's toll-booth business model is essentially an inflation hedge with massive margins." },
    { symbol: "MSFT", name: "Microsoft Corp", yield: "0.8%", growthYears: 19, payoutRatio: "25%", analysis: "Transitioning from a growth stock to a dividend powerhouse. Cloud computing dominance ensures massive free cash flow generation for decades." }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/long-term-dividend-growth-stocks" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Long-Term Dividend Growth Stocks</h1>
      <p class="subtitle">Building wealth through consistent, growing income streams.</p>
    </div>

    <div class="content-body">
      <p>The secret to compounding wealth isn't just finding a high starting yield; it's finding companies that can reliably increase their payouts year after year. These "Dividend Aristocrats" and "Dividend Kings" possess durable competitive advantages, allowing them to weather economic storms and consistently pass profits back to shareholders.</p>

      <div class="card">
        <input type="text" id="searchInput" placeholder="Filter by symbol or company..." style="width: 100%; padding: 0.75rem; margin-bottom: 1rem; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-primary); color: var(--text-primary);">
        <div style="overflow-x: auto;">
            <table id="stocksTable">
              <thead>
                <tr>
                  <th onclick="sortTable(0)" style="cursor: pointer;">Symbol ↕</th>
                  <th onclick="sortTable(1)" style="cursor: pointer;">Company ↕</th>
                  <th onclick="sortTable(2)" style="cursor: pointer;">Yield ↕</th>
                  <th onclick="sortTable(3)" style="cursor: pointer;">Years Grown ↕</th>
                  <th onclick="sortTable(4)" style="cursor: pointer;">Payout Ratio ↕</th>
                  <th>Analysis</th>
                </tr>
              </thead>
              <tbody>
                {stocks.map((stock) => (
                  <tr>
                    <td><strong><a href="/dividend-aristocrats/">{stock.symbol}</a></strong></td>
                    <td>{stock.name}</td>
                    <td>{stock.yield}</td>
                    <td>{stock.growthYears}</td>
                    <td>{stock.payoutRatio}</td>
                    <td>{stock.analysis}</td>
                  </tr>
                ))}
              </tbody>
            </table>
        </div>
      </div>

      <h2>The Power of Compounding</h2>
      <p>Investing in dividend growth stocks is a long game. The combination of reinvesting dividends and the company increasing those dividends creates an exponential compounding effect. Over decades, the yield on your original cost basis can easily hit double digits, providing massive passive income regardless of current market share prices.</p>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {JSON.parse(JSON.stringify(schema)).mainEntity.map((faq: any) => (
          <details>
            <summary>{faq.name}</summary>
            <p>{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </section>
    </div>
  </div>

  <script is:inline>
    // Search functionality
    document.getElementById('searchInput')?.addEventListener('keyup', function(e) {
      const term = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('#stocksTable tbody tr');
      rows.forEach(row => {
        const symbol = row.cells[0].textContent.toLowerCase();
        const name = row.cells[1].textContent.toLowerCase();
        if (symbol.includes(term) || name.includes(term)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });

    // Sort functionality
    let sortDirections = [true, true, true, true, true];
    function sortTable(columnIndex) {
      const table = document.getElementById("stocksTable");
      const tbody = table.tBodies[0];
      const rows = Array.from(tbody.querySelectorAll("tr"));
      const isAscending = sortDirections[columnIndex];

      rows.sort((a, b) => {
        let aVal = a.cells[columnIndex].textContent.trim();
        let bVal = b.cells[columnIndex].textContent.trim();

        // Handle numeric columns
        if (columnIndex === 2 || columnIndex === 4) {
          aVal = parseFloat(aVal.replace(/[^0-9.-]+/g,""));
          bVal = parseFloat(bVal.replace(/[^0-9.-]+/g,""));
        } else if (columnIndex === 3) {
            aVal = parseInt(aVal);
            bVal = parseInt(bVal);
        }

        if (aVal < bVal) return isAscending ? -1 : 1;
        if (aVal > bVal) return isAscending ? 1 : -1;
        return 0;
      });

      sortDirections[columnIndex] = !isAscending;
      tbody.append(...rows);
    }
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
    th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border-color); }
    th { background: rgba(0,0,0,0.05); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .content-body p { line-height: 1.6; color: var(--text-primary); margin-bottom: 1rem; }
    h2 { margin-top: 2rem; margin-bottom: 1rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</SiteLayout>
