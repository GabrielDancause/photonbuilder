---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Top Undervalued Stocks to Watch in May 2025 | Westmount Fundamentals",
  description: "Discover the top undervalued stocks for May 2025. Uncover hidden market gems and potential value plays before the rest of the market catches on.",
  category: "list",
  published: "2025-05-01"
};

const schema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What does it mean for a stock to be undervalued?", "acceptedAnswer": {"@type": "Answer", "text": "An undervalued stock is one that is trading at a price lower than its perceived intrinsic value. This can happen due to market overreactions, poor recent news, or general sector downturns, presenting a potential buying opportunity."}}, {"@type": "Question", "name": "How can I identify undervalued stocks?", "acceptedAnswer": {"@type": "Answer", "text": "Investors typically look at fundamental metrics such as the Price-to-Earnings (P/E) ratio, Price-to-Book (P/B) ratio, and Free Cash Flow. Comparing these metrics to the company's historical averages and industry peers helps identify potential undervaluation."}}, {"@type": "Question", "name": "Are undervalued stocks a safe investment?", "acceptedAnswer": {"@type": "Answer", "text": "Not necessarily. A stock might be cheap for a good reason, often referred to as a 'value trap.' It's crucial to analyze the company's long-term viability, debt levels, and competitive advantage before investing."}}, {"@type": "Question", "name": "Why are some sectors more undervalued than others?", "acceptedAnswer": {"@type": "Answer", "text": "Market sentiment often drives sector valuations. For example, during a tech boom, traditional sectors like utilities or financials might be overlooked and become undervalued relative to their earnings potential."}}, {"@type": "Question", "name": "When is the best time to buy undervalued stocks?", "acceptedAnswer": {"@type": "Answer", "text": "The best time is often when market sentiment is overly pessimistic about a fundamentally sound company. However, timing the market is difficult, so a long-term investment horizon is generally recommended."}}]};

const stocks = [
    { symbol: "CVS", name: "CVS Health Corp", pe: 10.5, pb: 1.2, dividendYield: "3.8%", analysis: "Despite near-term healthcare headwinds, CVS's integrated model and strong cash flow make its current valuation highly attractive." },
    { symbol: "PFE", name: "Pfizer Inc.", pe: 12.1, pb: 1.5, dividendYield: "6.1%", analysis: "Trading well below historical averages as post-pandemic revenue normalizes, but boasts a robust pipeline and excellent yield." },
    { symbol: "VZ", name: "Verizon Communications", pe: 8.9, pb: 1.6, dividendYield: "6.5%", analysis: "A classic value play offering immense yield and stable cash flows, currently discounted due to debt and competitive concerns." },
    { symbol: "BMY", name: "Bristol-Myers Squibb", pe: 9.8, pb: 2.1, dividendYield: "4.9%", analysis: "Facing patent cliffs, but the market has overly discounted its newer portfolio and pipeline potential." },
    { symbol: "T", name: "AT&T Inc.", pe: 8.2, pb: 1.1, dividendYield: "6.4%", analysis: "Following its media spin-off, AT&T is refocused on telecom and generating substantial free cash flow at a depressed multiple." },
    { symbol: "WBA", name: "Walgreens Boots Alliance", pe: 6.5, pb: 0.8, dividendYield: "4.5%", analysis: "A deep value turnaround play. Significant risks exist, but the extremely low P/B ratio reflects intense pessimism." },
    { symbol: "INTC", name: "Intel Corporation", pe: 15.2, pb: 1.0, dividendYield: "1.2%", analysis: "Currently priced near book value as it navigates a massive foundry transition. A high-risk, high-reward turnaround story." },
    { symbol: "BTI", name: "British American Tobacco", pe: 6.1, pb: 0.9, dividendYield: "9.8%", analysis: "Trading at distressed multiples with an enormous yield, as the market aggressively discounts its legacy combustible business." },
    { symbol: "C", name: "Citigroup Inc.", pe: 11.4, pb: 0.6, dividendYield: "3.3%", analysis: "Consistently trading below book value. Ongoing restructuring efforts aim to close the valuation gap with banking peers." },
    { symbol: "GM", name: "General Motors", pe: 5.8, pb: 0.7, dividendYield: "1.1%", analysis: "Legacy automakers are priced for obsolescence, ignoring GM's strong current profitability and capital return programs." }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/undervalued-stocks-may-2025" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Top Undervalued Stocks for May 2025</h1>
      <p class="subtitle">Discovering market discounts and potential value traps.</p>
    </div>

    <div class="content-body">
      <p>Value investing is about finding companies trading below their intrinsic value. In May 2025, several sectors, including telecommunications, legacy healthcare, and traditional banking, present intriguing opportunities where market pessimism may have overshot reality. The list below highlights large-cap stocks currently trading at historically low multiples, offering potential upside for patient investors.</p>

      <div class="card">
        <input type="text" id="searchInput" placeholder="Search by symbol or company name..." style="width: 100%; padding: 0.75rem; margin-bottom: 1rem; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-primary); color: var(--text-primary);">
        <div style="overflow-x: auto;">
            <table id="stocksTable">
              <thead>
                <tr>
                  <th onclick="sortTable(0)" style="cursor: pointer;">Symbol ↕</th>
                  <th onclick="sortTable(1)" style="cursor: pointer;">Company ↕</th>
                  <th onclick="sortTable(2)" style="cursor: pointer;">P/E Ratio ↕</th>
                  <th onclick="sortTable(3)" style="cursor: pointer;">P/B Ratio ↕</th>
                  <th onclick="sortTable(4)" style="cursor: pointer;">Div Yield ↕</th>
                  <th>Analysis</th>
                </tr>
              </thead>
              <tbody>
                {stocks.map((stock) => (
                  <tr>
                    <td><strong><a href="/stock-comparison-tool/">{stock.symbol}</a></strong></td>
                    <td>{stock.name}</td>
                    <td>{stock.pe}</td>
                    <td>{stock.pb}</td>
                    <td>{stock.dividendYield}</td>
                    <td>{stock.analysis}</td>
                  </tr>
                ))}
              </tbody>
            </table>
        </div>
      </div>

      <h2>Understanding the Metrics</h2>
      <p>When evaluating these stocks, keep in mind that a low P/E or P/B ratio doesn't guarantee future returns. Often, stocks are cheap for a reason. Investors must differentiate between temporary setbacks (creating a buying opportunity) and permanent structural decline (a value trap). Always examine free cash flow and debt levels before committing capital.</p>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        {JSON.parse(JSON.stringify(schema)).mainEntity.map((faq: any) => (
          <details>
            <summary>{faq.name}</summary>
            <p>{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </section>
    </div>
  </div>

  <script is:inline>
    // Search functionality
    document.getElementById('searchInput')?.addEventListener('keyup', function(e) {
      const term = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('#stocksTable tbody tr');
      rows.forEach(row => {
        const symbol = row.cells[0].textContent.toLowerCase();
        const name = row.cells[1].textContent.toLowerCase();
        if (symbol.includes(term) || name.includes(term)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });

    // Sort functionality
    let sortDirections = [true, true, true, true, true];
    function sortTable(columnIndex) {
      const table = document.getElementById("stocksTable");
      const tbody = table.tBodies[0];
      const rows = Array.from(tbody.querySelectorAll("tr"));
      const isAscending = sortDirections[columnIndex];

      rows.sort((a, b) => {
        let aVal = a.cells[columnIndex].textContent.trim();
        let bVal = b.cells[columnIndex].textContent.trim();

        // Handle numeric columns
        if (columnIndex >= 2 && columnIndex <= 4) {
          aVal = parseFloat(aVal.replace(/[^0-9.-]+/g,""));
          bVal = parseFloat(bVal.replace(/[^0-9.-]+/g,""));
        }

        if (aVal < bVal) return isAscending ? -1 : 1;
        if (aVal > bVal) return isAscending ? 1 : -1;
        return 0;
      });

      sortDirections[columnIndex] = !isAscending;
      tbody.append(...rows);
    }
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
    th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border-color); }
    th { background: rgba(0,0,0,0.05); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .content-body p { line-height: 1.6; color: var(--text-primary); margin-bottom: 1rem; }
    h2 { margin-top: 2rem; margin-bottom: 1rem; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</SiteLayout>
