    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Dollar Cost Averaging?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dollar Cost Averaging (DCA) is an investment strategy where you divide your total investment amount across periodic purchases of a target asset to reduce the impact of volatility."
        }
