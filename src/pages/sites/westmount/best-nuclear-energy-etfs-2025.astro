  <script is:inline>
    function parseValue(val) {
        val = val.toUpperCase().trim();
        // Extract the numeric part and the multiplier
        const numStr = val.replace(/[^0-9.-]/g, '');
        if (!numStr) return val; // return string if no number found
        let num = parseFloat(numStr);
        if (val.includes('T')) num *= 1e12;
        else if (val.includes('B')) num *= 1e9;
        else if (val.includes('M')) num *= 1e6;
        else if (val.includes('K')) num *= 1e3;
        return num;
    }

    function sortTable(n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById("dataTable");
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let valX = parseValue(x.innerHTML);
          let valY = parseValue(y.innerHTML);

          if (dir == "asc") {
            if (valX > valY) {
              shouldSwitch = true;
              break;
            }
          } else if (dir == "desc") {
            if (valX < valY) {
              shouldSwitch = true;
              break;
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }

    function applyFilters() {
        const minYield = parseFloat(document.getElementById("minYield").value) || 0;
        const sector = document.getElementById("sectorFilter").value;
        const table = document.getElementById("dataTable");
        const tr = table.getElementsByTagName("tr");
        const cards = document.getElementById("cardList").getElementsByClassName("card");

        for (let i = 1; i < tr.length; i++) {
            const yieldTd = tr[i].getElementsByTagName("td")[3];
            const sectorTd = tr[i].getElementsByTagName("td")[4];

            if (yieldTd && sectorTd) {
                const yieldVal = parseFloat(yieldTd.textContent.replace('%', '')) || 0;
                const sectorVal = sectorTd.textContent;

                let showRow = true;
                if (yieldVal < minYield) showRow = false;
                if (sector !== "All" && !sectorVal.includes(sector)) showRow = false;

                tr[i].style.display = showRow ? "" : "none";
                if(i - 1 < cards.length) {
                     cards[i-1].style.display = showRow ? "block" : "none";
                }
            }
        }
    }
  </script>

