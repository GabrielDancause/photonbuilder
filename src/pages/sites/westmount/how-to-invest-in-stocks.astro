            <span class="suffix">USD</span>
          </div>
        </div>

        <div class="input-group">
          <label for="years-invested">Years to Invest</label>
          <div class="input-wrapper">
            <input type="number" id="years-invested" value="30" min="1" max="60" step="1">
            <span class="suffix">Years</span>
          </div>
        </div>

        <div class="input-group">
          <label for="estimated-return">Estimated Annual Return</label>
          <div class="input-wrapper">
            <input type="number" id="estimated-return" value="8" min="1" max="20" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="calc-result">
          <span class="calc-result-label">Estimated Future Value</span>
          <div class="calc-result-value" id="calc-result-total">$0</div>
        </div>
        <div class="stats-grid" style="margin-top: 1rem;">
          <div class="stat-card">
            <span class="calc-result-label">Total Contributions</span>
            <div style="font-family: var(--font-mono); font-weight: 600; font-size: 1.25rem; color: var(--text-primary);" id="calc-result-contributed">$0</div>
          </div>
          <div class="stat-card">
            <span class="calc-result-label">Total Interest Earned</span>
            <div style="font-family: var(--font-mono); font-weight: 600; font-size: 1.25rem; color: var(--accent-color);" id="calc-result-interest">$0</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      const inputs = ['initial-investment', 'monthly-contribution', 'years-invested', 'estimated-return'].map(id => document.getElementById(id));
      const totalEl = document.getElementById('calc-result-total');
      const contributedEl = document.getElementById('calc-result-contributed');
      const interestEl = document.getElementById('calc-result-interest');

      function calculate() {
        const principal = parseFloat(inputs[0].value) || 0;
        const pmt = parseFloat(inputs[1].value) || 0;
        const years = parseFloat(inputs[2].value) || 0;
        const rate = (parseFloat(inputs[3].value) || 0) / 100;
        const n = 12; // compounding monthly
        const periods = n * years;

        let total = 0;

        if (Math.abs(rate) < 1e-10) {
            total = principal + (pmt * periods);
        } else {
            const rOverN = rate / n;
            const compoundFactor = Math.pow(1 + rOverN, periods);
            const futureValuePrincipal = principal * compoundFactor;
            const futureValueSeries = pmt * ((compoundFactor - 1) / rOverN);
            total = futureValuePrincipal + futureValueSeries;
        }

        const totalContributed = principal + (pmt * periods);
        const totalInterest = Math.max(0, total - totalContributed);

        // Fix potential floating point errors
        total = Math.round(total * 100) / 100;

        const formatter = new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0
        });

        totalEl.textContent = formatter.format(total);
        contributedEl.textContent = formatter.format(totalContributed);
        interestEl.textContent = formatter.format(totalInterest);
      }

      inputs.forEach(input => {
        if (input) {
          input.addEventListener('input', calculate);
        }
      });

      // Expose to window for testing if necessary
      window.compoundCalculatorInputs = inputs;

      // Initial calculation
      calculate();
    })();
  </script>





