    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin: 2rem 0 3rem;
  }

  .toc-card h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }

  .toc-card ul {
    list-style-type: none;
    padding-left: 0;
    margin-bottom: 0;
  }

  .toc-card li {
    margin-bottom: 0.75rem;
  }

  .toc-card a {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .toc-card a:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }

  .faq-section {
    margin-top: 4rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
  }

  .faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1.5rem;
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.5rem;
    color: var(--accent-color);
    transition: transform 0.3s ease;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item h3 {
    margin: 0;
    font-size: 1.1rem;
    display: inline-block;
  }

  .faq-item p {
    padding: 0 1.5rem 1.5rem;
    margin: 0;
    color: var(--text-secondary);
  }

  .calculator-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    margin: 3rem 0;
  }

  .calculator-card h3 {
    margin-top: 0;
    color: var(--accent-color);
    text-align: center;
  }

  .input-group {
    margin-bottom: 1.5rem;
  }

  .input-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-wrapper input {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .input-wrapper input:focus {
    border-color: var(--accent-color);
  }

  .suffix {
    position: absolute;
    right: 1rem;
    color: var(--text-secondary);
    pointer-events: none;
  }

  .calc-result {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
  }

  .calc-result-label {
    display: block;
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .calc-result-value {
    color: var(--accent-color);
    font-size: 2.5rem;
    font-weight: 800;
  }
</style>

<script>
  function setupCalculator() {
    const initialInput = document.getElementById('initialInvestment');
    const monthlyInput = document.getElementById('monthlyContribution');
    const yearsInput = document.getElementById('years');
    const returnInput = document.getElementById('expectedReturn');
    const resultDisplay = document.getElementById('futureValueResult');

    if (!initialInput || !monthlyInput || !yearsInput || !returnInput || !resultDisplay) return;

    function calculate() {
      const p = parseFloat(initialInput.value) || 0;
      const pmt = parseFloat(monthlyInput.value) || 0;
      const t = parseFloat(yearsInput.value) || 0;
      const r = (parseFloat(returnInput.value) || 0) / 100;
      const n = 12; // Compounded monthly

      // Future value of a lump sum
      const fvLumpSum = p * Math.pow(1 + (r / n), n * t);

      // Future value of an annuity (monthly contributions)
      let fvContributions = 0;
      if (r > 0) {
        fvContributions = pmt * ((Math.pow(1 + (r / n), n * t) - 1) / (r / n));
      } else {
        fvContributions = pmt * n * t;
      }

      const totalFutureValue = fvLumpSum + fvContributions;

      resultDisplay.textContent = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(totalFutureValue);
    }

    [initialInput, monthlyInput, yearsInput, returnInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  }

  // Setup on initial load and view transitions
  document.addEventListener('astro:page-load', setupCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupCalculator);
  } else {
    setupCalculator();
  }
</script>
