const schema = {"@context": "https://schema.org", "@graph": [{"@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "Why invest in lithium stocks?", "acceptedAnswer": {"@type": "Answer", "text": "Lithium is a critical component for EV batteries and energy storage systems. As the world transitions to green energy, demand for lithium is projected to outstrip supply, creating significant long-term growth opportunities for well-positioned companies."}}, {"@type": "Question", "name": "What is the difference between brine and hard rock lithium?", "acceptedAnswer": {"@type": "Answer", "text": "Brine extraction involves pumping salty water into evaporation ponds, a slow process but generally lower cost. Hard rock mining extracts spodumene ore, which is faster but requires energy-intensive processing to create lithium hydroxide."}}, {"@type": "Question", "name": "What is Direct Lithium Extraction (DLE)?", "acceptedAnswer": {"@type": "Answer", "text": "DLE is an emerging technology that uses chemical processes to extract lithium directly from brine without the need for massive evaporation ponds. It promises faster extraction times and a smaller environmental footprint, though it is still being proven at commercial scale."}}, {"@type": "Question", "name": "Are lithium stocks volatile?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, lithium stocks are highly sensitive to the spot price of lithium, which can fluctuate wildly based on supply chain disruptions, EV demand forecasts, and macroeconomic conditions. They are considered high-risk, high-reward investments."}}, {"@type": "Question", "name": "How do geopolitical tensions affect lithium?", "acceptedAnswer": {"@type": "Answer", "text": "Much of the world's lithium processing is concentrated in China, while reserves are spread across Australia and the Americas. Trade policies, tariffs, and government initiatives like the US Inflation Reduction Act significantly impact the supply chain and stock valuations."}}