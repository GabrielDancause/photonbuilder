---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Should I choose a Roth or Traditional IRA in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The choice between a Roth and Traditional IRA depends primarily on your current tax bracket versus your expected tax bracket in retirement. If you expect your tax rate to be higher in retirement, a Roth IRA is generally better. If you expect it to be lower, a Traditional IRA may offer better upfront tax savings."
      }
    },
    {
      "@type": "Question",
      "name": "What are the IRA contribution limits for 2024, 2025, and 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2024 and 2025, the contribution limit for both Roth and Traditional IRAs is $7,000, with an additional $1,000 catch-up contribution for those age 50 or older. Limits for 2026 have not yet been officially announced by the IRS."
      }
    },
    {
      "@type": "Question",
      "name": "What are the income phase-outs for a Roth IRA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2024, the income phase-out range for single filers is $146,000 to $161,000, and for married filing jointly, it is $230,000 to $240,000. For 2025, the ranges increased to $150,000-$165,000 for singles and $236,000-$246,000 for married couples."
      }
    },
    {
      "@type": "Question",
      "name": "Can I convert a Traditional IRA to a Roth IRA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, you can convert funds from a Traditional IRA to a Roth IRA at any time. This is often called a Roth conversion. However, you will have to pay ordinary income tax on the pre-tax amount you convert in the year of the conversion."
      }
    },
    {
      "@type": "Question",
      "name": "What are the RMD rules for Roth vs Traditional IRAs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Traditional IRAs are subject to Required Minimum Distributions (RMDs) starting at age 73 (or 75 for those born in 1960 or later). Roth IRAs do not have RMDs during the original owner's lifetime."
      }
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title="Roth vs Traditional IRA: Complete Decision Guide"
  description="Comprehensive comparison of Roth vs Traditional IRAs. Learn about contribution limits, tax benefits, and how to choose the right account for retirement."
  canonical="https://westmountfundamentals.com/guide-roth-vs-traditional-ira" schema={schema}
>


<div class="max-w-6xl mx-auto px-6 py-12">
        <h1 class="text-3xl md:text-4xl font-bold text-[var(--accent-color)] mb-6 text-center">Roth vs Traditional IRA: Complete Decision Guide</h1>
        <p style="text-align: center; color: var(--text-secondary); max-width: 800px; margin: 0 auto 2rem;">
            Deciding between a Roth and Traditional IRA is one of the most important retirement planning choices you'll make.
            This guide breaks down contribution limits, income phase-outs, and tax implications to help you optimize your savings.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 my-8">
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="font-mono text-3xl font-bold text-[var(--accent-color)]">$7,000</div>
                <div class="text-[var(--text-secondary)] text-sm font-medium mt-2 uppercase tracking-wide">2024/2025 Contribution Limit</div>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="font-mono text-3xl font-bold text-[var(--accent-color)]">$1,000</div>
                <div class="text-[var(--text-secondary)] text-sm font-medium mt-2 uppercase tracking-wide">Age 50+ Catch-up</div>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="font-mono text-3xl font-bold text-[var(--accent-color)]">Tax-Free</div>
                <div class="text-[var(--text-secondary)] text-sm font-medium mt-2 uppercase tracking-wide">Roth Growth & Withdrawals</div>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
                <div class="font-mono text-3xl font-bold text-[var(--accent-color)]">Tax-Deferred</div>
                <div class="text-[var(--text-secondary)] text-sm font-medium mt-2 uppercase tracking-wide">Traditional Growth</div>
            </div>
        </div>

        <h2 class="text-2xl font-bold text-white mt-8 mb-4">Historical Contribution Limits & Income Phase-outs</h2>
        <div class="flex justify-between mb-4 gap-4 flex-wrap">
            <input type="text" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg w-full max-w-xs focus:border-[var(--accent-color)] focus:outline-none" id="searchInput" placeholder="Search by year, limit, or phase-out...">
        </div>
        <div class="table-container">
            <table id="dataTable">
                <thead class="bg-white/5 border-b border-[var(--border-color)]">
                    <tr>
                        <th class="p-4 font-semibold text-white border-b border-[var(--border-color)]" onclick="sortTable(0)">Year ↕</th>
                        <th class="p-4 font-semibold text-white border-b border-[var(--border-color)]" onclick="sortTable(1)">Base Limit ↕</th>
                        <th class="p-4 font-semibold text-white border-b border-[var(--border-color)]" onclick="sortTable(2)">Catch-up Limit ↕</th>
                        <th class="p-4 font-semibold text-white border-b border-[var(--border-color)]" onclick="sortTable(3)">Roth Phase-out (Single) ↕</th>
                        <th class="p-4 font-semibold text-white border-b border-[var(--border-color)]" onclick="sortTable(4)">Roth Phase-out (MFJ) ↕</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- Data will be populated here -->
                </tbody>
            </table>
        </div>

        <h2 class="text-2xl font-bold text-white mt-8 mb-4">Break-Even Tax Rate Calculator</h2>
        <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Compare the projected ending balance of a Roth vs Traditional IRA. The traditional calculation assumes tax savings are invested in a taxable brokerage account.</p>

        <div class="section-box">
            <div class="calculator-inputs">
                <div class="input-group">
                    <label class="block font-semibold text-sm text-[var(--text-secondary)] mb-2">Annual Contribution ($)</label>
                    <input type="number" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg w-full max-w-xs focus:border-[var(--accent-color)] focus:outline-none" id="calcContrib" value="7000" step="500">
                </div>
                <div class="input-group">
                    <label class="block font-semibold text-sm text-[var(--text-secondary)] mb-2">Years to Retirement</label>
                    <input type="number" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg w-full max-w-xs focus:border-[var(--accent-color)] focus:outline-none" id="calcYears" value="30" step="1">
                </div>
                <div class="input-group">
                    <label class="block font-semibold text-sm text-[var(--text-secondary)] mb-2">Expected Annual Return (%)</label>
                    <input type="number" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg w-full max-w-xs focus:border-[var(--accent-color)] focus:outline-none" id="calcReturn" value="7" step="0.5">
                </div>
                <div class="input-group">
                    <label class="block font-semibold text-sm text-[var(--text-secondary)] mb-2">Current Tax Rate (%)</label>
                    <input type="number" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg w-full max-w-xs focus:border-[var(--accent-color)] focus:outline-none" id="calcCurrentTax" value="24" step="1">
                </div>
                <div class="input-group">
                    <label class="block font-semibold text-sm text-[var(--text-secondary)] mb-2">Retirement Tax Rate (%)</label>
                    <input type="number" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-white p-3 rounded-lg w-full max-w-xs focus:border-[var(--accent-color)] focus:outline-none" id="calcRetireTax" value="22" step="1">
                </div>
            </div>
            <button onclick="updateChart()" style="background: var(--accent-color); color: #fff; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; font-family: var(--font-main);">Calculate Projection</button>
        </div>

        <div class="relative h-[500px] w-full flex justify-center">
            <canvas id="projectionChart"></canvas>
        </div>

        <h2 class="text-2xl font-bold text-white mt-8 mb-4">Methodology & Data Sources</h2>
        <div class="section-box">
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Contribution Limits & Phase-outs:</strong> Data is sourced directly from the Internal Revenue Service (IRS). Historical limits are factual, while projected limits (e.g., 2026) are listed as 'N/A' or 'Null' until officially announced by the IRS.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Break-Even Calculator:</strong> The calculator assumes annual contributions made at the beginning of the year. For the Traditional IRA, we assume the upfront tax savings (Contribution * Current Tax Rate) are invested in a taxable brokerage account growing at the same rate, but subject to an assumed 15% long-term capital gains tax upon withdrawal. The final Traditional IRA balance is reduced by the Retirement Tax Rate to simulate after-tax value.</p>
        </div>

        <h2 class="text-2xl font-bold text-white mt-8 mb-4">Frequently Asked Questions</h2>
        <div class="section-box">
            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
                <div class="faq-question">Should I choose a Roth or Traditional IRA in 2026?</div>
                <div>The choice between a Roth and Traditional IRA depends primarily on your current tax bracket versus your expected tax bracket in retirement. If you expect your tax rate to be higher in retirement, a Roth IRA is generally better. If you expect it to be lower, a Traditional IRA may offer better upfront tax savings.</div>
            </div>
            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
                <div class="faq-question">What are the IRA contribution limits for 2024, 2025, and 2026?</div>
                <div>For 2024 and 2025, the contribution limit for both Roth and Traditional IRAs is $7,000, with an additional $1,000 catch-up contribution for those age 50 or older. Limits for 2026 have not yet been officially announced by the IRS.</div>
            </div>
            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
                <div class="faq-question">What are the income phase-outs for a Roth IRA?</div>
                <div>For 2024, the income phase-out range for single filers is $146,000 to $161,000, and for married filing jointly, it is $230,000 to $240,000. For 2025, the ranges increased to $150,000-$165,000 for singles and $236,000-$246,000 for married couples.</div>
            </div>
            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
                <div class="faq-question">Can I convert a Traditional IRA to a Roth IRA?</div>
                <div>Yes, you can convert funds from a Traditional IRA to a Roth IRA at any time. This is often called a Roth conversion. However, you will have to pay ordinary income tax on the pre-tax amount you convert in the year of the conversion.</div>
            </div>
            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
                <div class="faq-question">What are the RMD rules for Roth vs Traditional IRAs?</div>
                <div>Traditional IRAs are subject to Required Minimum Distributions (RMDs) starting at age 73 (or 75 for those born in 1960 or later). Roth IRAs do not have RMDs during the original owner's lifetime.</div>
            </div>
        </div>

        
    </div>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
// Real IRS Data
        const irsData = [
            { year: 2026, limit: null, catchUp: null, phaseOutSingle: null, phaseOutMFJ: null },
            { year: 2025, limit: "$7,000", catchUp: "$1,000", phaseOutSingle: "$150k - $165k", phaseOutMFJ: "$236k - $246k" },
            { year: 2024, limit: "$7,000", catchUp: "$1,000", phaseOutSingle: "$146k - $161k", phaseOutMFJ: "$230k - $240k" },
            { year: 2023, limit: "$6,500", catchUp: "$1,000", phaseOutSingle: "$138k - $153k", phaseOutMFJ: "$218k - $228k" },
            { year: 2022, limit: "$6,000", catchUp: "$1,000", phaseOutSingle: "$129k - $144k", phaseOutMFJ: "$204k - $214k" },
            { year: 2021, limit: "$6,000", catchUp: "$1,000", phaseOutSingle: "$125k - $140k", phaseOutMFJ: "$198k - $208k" }
        ];

        let currentSort = { col: 0, asc: true };

        function renderTable(data) {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            data.forEach(row => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="p-4 border-b border-[var(--border-color)] text-[var(--text-secondary)]">${row.year}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[var(--text-secondary)]">${row.limit || 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[var(--text-secondary)]">${row.catchUp || 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[var(--text-secondary)]">${row.phaseOutSingle || 'N/A'}</td>
                    <td class="p-4 border-b border-[var(--border-color)] text-[var(--text-secondary)]">${row.phaseOutMFJ || 'N/A'}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function sortTable(colIndex) {
            const keys = ['year', 'limit', 'catchUp', 'phaseOutSingle', 'phaseOutMFJ'];
            const key = keys[colIndex];

            if (currentSort.col === colIndex) {
                currentSort.asc = !currentSort.asc;
            } else {
                currentSort.col = colIndex;
                currentSort.asc = true;
            }

            const sortedData = [...irsData].sort((a, b) => {
                let valA = a[key] === null ? -1 : a[key];
                let valB = b[key] === null ? -1 : b[key];

                if (typeof valA === 'string') {
                    let numA = parseFloat(valA.replace(/[\$,k\s]/g, ''));
                    if (!isNaN(numA)) valA = numA;
                }
                if (typeof valB === 'string') {
                    let numB = parseFloat(valB.replace(/[\$,k\s]/g, ''));
                    if (!isNaN(numB)) valB = numB;
                }

                if (valA < valB) return currentSort.asc ? -1 : 1;
                if (valA > valB) return currentSort.asc ? 1 : -1;
                return 0;
            });

            renderTable(sortedData);
        }

        document.getElementById('searchInput').addEventListener('keyup', (e) => {
            const term = e.target.value.toLowerCase();
            const filtered = irsData.filter(row => {
                return Object.values(row).some(val =>
                    val !== null && val.toString().toLowerCase().includes(term)
                );
            });
            renderTable(filtered);
        });

        // Initialize Table
        renderTable(irsData);

        // Chart.js Setup
        let chartInstance = null;

        function updateChart() {
            const contrib = parseFloat(document.getElementById('calcContrib').value);
            const years = parseInt(document.getElementById('calcYears').value);
            const returnRate = parseFloat(document.getElementById('calcReturn').value) / 100;
            const currentTax = parseFloat(document.getElementById('calcCurrentTax').value) / 100;
            const retireTax = parseFloat(document.getElementById('calcRetireTax').value) / 100;
            const cgTax = 0.15; // Capital gains tax rate

            let labels = [];
            let rothData = [];
            let tradData = [];

            let rothBal = 0;
            let tradBal = 0;
            let taxSavingsBal = 0;
            let taxSavingsBasis = 0;

            for (let i = 1; i <= years; i++) {
                labels.push(`Year ${i}`);

                // Roth: Pay taxes upfront, invest after-tax amount? No, assume standard contribution is the max
                // Actually standard comparison:
                // Roth: Invest $Contrib after tax.
                // Traditional: Invest $Contrib pre-tax. You get a tax deduction of $Contrib * currentTax.
                // We assume this tax savings is invested in a taxable account.

                // End of year compounding
                rothBal = (rothBal + contrib) * (1 + returnRate);
                tradBal = (tradBal + contrib) * (1 + returnRate);

                const taxSavings = contrib * currentTax;
                taxSavingsBal = (taxSavingsBal + taxSavings) * (1 + returnRate);
                taxSavingsBasis += taxSavings;

                // After-tax value if withdrawn at this year
                const afterTaxRoth = rothBal;
                const afterTaxTrad = tradBal * (1 - retireTax);

                // Taxable account after-tax value
                const taxableGains = taxSavingsBal - taxSavingsBasis;
                const afterTaxTaxable = taxSavingsBal - (taxableGains > 0 ? taxableGains * cgTax : 0);

                rothData.push(Math.round(afterTaxRoth));
                tradData.push(Math.round(afterTaxTrad + afterTaxTaxable));
            }

            const ctx = document.getElementById('projectionChart').getContext('2d');

            if (chartInstance) {
                chartInstance.destroy();
            }

            chartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Roth IRA (After-Tax)',
                            data: rothData,
                            borderColor: '#4a8fe7',
                            backgroundColor: 'rgba(74, 143, 231, 0.1)',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.1
                        },
                        {
                            label: 'Traditional IRA + Taxable Account (After-Tax)',
                            data: tradData,
                            borderColor: '#e74a4a',
                            backgroundColor: 'rgba(231, 74, 74, 0.1)',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: {
                                color: '#f3f4f6',
                                font: { family: "'Inter', sans-serif" }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(context.parsed.y);
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#9ca3af', font: { family: "'Inter', sans-serif" } },
                            grid: { color: '#152040' }
                        },
                        y: {
                            ticks: {
                                color: '#9ca3af',
                                font: { family: "'Inter', sans-serif" },
                                callback: function(value, index, values) {
                                    if(value >= 1000000) return '$' + (value/1000000).toFixed(1) + 'M';
                                    if(value >= 1000) return '$' + (value/1000).toFixed(0) + 'k';
                                    return '$' + value;
                                }
                            },
                            grid: { color: '#152040' }
                        }
                    }
                }
            });
        }

        // Initial Chart Render
        updateChart();
  </script>
</SiteLayout>
