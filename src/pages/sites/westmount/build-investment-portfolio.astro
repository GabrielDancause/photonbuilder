---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { title: "How to Build an Investment Portfolio", description: "A step-by-step guide to building an investment portfolio, covering risk tolerance assessment, asset allocation models, the core-satellite approach, choosing index funds like VTI, VXUS, and BND, geographic and sector diversification, age-based portfolio examples, robo-advisors vs DIY, and tracking tools.", category: "guide", published: "2026-03-18" };

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "How to Build an Investment Portfolio",
  "description": "A step-by-step guide to building an investment portfolio, covering risk tolerance assessment, asset allocation models, the core-satellite approach, choosing index funds like VTI, VXUS, and BND, geographic and sector diversification, age-based portfolio examples, robo-advisors vs DIY, and tracking tools.",
  "author": {
    "@type": "Organization",
    "name": "Westmount Fundamentals"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an aggressive asset allocation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An aggressive allocation typically holds 80% to 100% in stocks and focuses on long-term growth, accepting higher volatility for potentially higher returns."
      }
    },
    {
      "@type": "Question",
      "name": "What are VTI, VXUS, and BND?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "They are popular Vanguard ETFs used in a three-fund portfolio: VTI covers the total US stock market, VXUS covers total international stocks, and BND covers the total US bond market."
      }
    },
    {
      "@type": "Question",
      "name": "How should my portfolio change in my 50s and 60s?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "As you approach retirement in your 50s and 60s, you generally shift toward a more conservative allocation, increasing bonds and cash to protect capital while still maintaining some stocks for growth."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use a robo-advisor or do it myself (DIY)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Robo-advisors are great for hands-off investors who want automated rebalancing and tax-loss harvesting for a small fee, while the DIY approach is better for those who want total control and the lowest possible fees."
      }
    },
    {
      "@type": "Question",
      "name": "What is the core-satellite approach?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The core-satellite approach uses low-cost index funds for the majority (core) of the portfolio while allocating a small percentage (satellite) to individual stocks or specific sectors."
      }
    }
  ]
};

const schema = [articleSchema, faqSchema];
---

<SiteLayout
  site="westmount"
  title="How to Build an Investment Portfolio | Westmount Fundamentals"
  description="A step-by-step guide to building an investment portfolio, covering risk tolerance, asset allocation, index funds, diversification, age-based examples, and tracking."
  canonical="https://westmountfundamentals.com/build-investment-portfolio"
  schema={JSON.stringify(schema)}
>
  <style>
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; color: var(--text-primary); }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }

    header { padding: 40px 0 20px; border-bottom: 1px solid var(--border-color); }
    .badge { display: inline-block; background: var(--accent-color); color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; padding: 4px 12px; border-radius: 3px; text-transform: uppercase; margin-bottom: 12px; }
    header h1 { font-size: clamp(28px, 4vw, 42px); font-weight: 800; line-height: 1.15; margin-bottom: 8px; }
    header p.subtitle { color: var(--text-secondary); font-size: 18px; max-width: 700px; }

    section { margin: 32px 0; }
    section h2 { font-size: 24px; margin-bottom: 16px; color: var(--accent-color); }
    section h3 { font-size: 20px; margin-top: 24px; margin-bottom: 12px; }
    section p { font-size: 16px; line-height: 1.6; margin-bottom: 16px; color: var(--text-secondary); }
    section ul, section ol { font-size: 16px; line-height: 1.6; color: var(--text-secondary); padding-left: 20px; margin-bottom: 16px; }
    section li { margin-bottom: 8px; }

    .callout { background: var(--card-bg); border-left: 4px solid var(--accent-color); padding: 20px; border-radius: 4px; margin: 24px 0; border-top: 1px solid var(--border-color); border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); }
    .callout h4 { margin-top: 0; margin-bottom: 8px; font-size: 16px; color: var(--text-primary); }
    .callout p { margin-bottom: 0; font-size: 15px; }

    .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin: 24px 0; }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 24px; }
    .card h3 { margin-top: 0; color: var(--accent-color); font-size: 18px; }

    .faq-section { margin: 48px 0; }
    .faq-section h2 { font-size: 24px; margin-bottom: 24px; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; margin-bottom: 12px; padding: 20px; }
    .faq-q { font-weight: 600; font-size: 16px; color: var(--text-primary); margin-bottom: 8px; }
    .faq-a { font-size: 15px; color: var(--text-secondary); line-height: 1.6; }
  </style>

  <div class="container">
    <header>
      <span class="badge">Investing Guide</span>
      <h1>How to Build an Investment Portfolio</h1>
      <p class="subtitle">A step-by-step guide to asset allocation, diversification, and constructing a robust investment portfolio for your financial goals.</p>
    </header>

    <section>
      <h2>Step 1: Risk Tolerance Assessment</h2>
      <p>Before buying any investments, you need to understand your ability and willingness to take risks. A thorough risk tolerance assessment evaluates two key factors:</p>
      <ul>
        <li><strong>Time Horizon:</strong> How long until you need the money? A 25-year-old saving for retirement has a long horizon and can afford more risk, while someone retiring in two years cannot.</li>
        <li><strong>Emotional Capacity:</strong> How would you react if your portfolio dropped by 30% in a month? If you would panic sell, you need a more conservative allocation, regardless of your timeline.</li>
      </ul>
    </section>

    <section>
      <h2>Step 2: Asset Allocation Models</h2>
      <p>Asset allocation is how you divide your money among different asset classes like stocks, bonds, and cash. It is the biggest driver of your portfolio's returns and volatility.</p>
      <div class="grid-2">
        <div class="card">
          <h3>Aggressive (80%-100% Stocks)</h3>
          <p>Designed for maximum growth over a long time horizon. High volatility, but historically provides the highest returns. Best for young investors or those decades away from retirement.</p>
        </div>
        <div class="card">
          <h3>Moderate (60% Stocks / 40% Bonds)</h3>
          <p>A balanced approach that offers growth potential while using bonds to cushion against major market crashes. A classic choice for middle-aged investors.</p>
        </div>
        <div class="card">
          <h3>Conservative (20%-40% Stocks)</h3>
          <p>Prioritizes capital preservation over high growth. Primarily relies on bonds and cash equivalents. Ideal for retirees or those needing their money very soon.</p>
        </div>
      </div>
    </section>

    <section>
      <h2>Step 3: Choosing Index Funds (The Three-Fund Portfolio)</h2>
      <p>Instead of trying to pick winning stocks, the most reliable way to build a portfolio is using low-cost broad market index funds or ETFs. A classic, highly diversified strategy is the "Three-Fund Portfolio."</p>
      <ul>
        <li><strong>VTI (Vanguard Total Stock Market ETF):</strong> Owns virtually every publicly traded company in the United States, giving you broad domestic exposure.</li>
        <li><strong>VXUS (Vanguard Total International Stock ETF):</strong> Provides exposure to developed and emerging markets outside the US, essential for geographic diversification.</li>
        <li><strong>BND (Vanguard Total Bond Market ETF):</strong> A highly diversified bond fund that provides stability and steady income when stock markets are volatile.</li>
      </ul>
      <div class="callout">
        <h4>The Core-Satellite Approach</h4>
        <p>If you want to pick individual stocks or sectors, consider the core-satellite approach. Keep 80-90% of your portfolio in broad index funds (the core), and use the remaining 10-20% for riskier bets or specific convictions (the satellites).</p>
      </div>
    </section>

    <section>
      <h2>Step 4: Deepening Diversification</h2>
      <p>Diversification protects your portfolio from catastrophic losses by spreading risk around.</p>
      <h3>Geographic Diversification</h3>
      <p>Don't invest solely in your home country. Different global economies perform well at different times. Adding international stocks (like VXUS) ensures you capture growth wherever it happens.</p>
      <h3>Sector Diversification</h3>
      <p>Broad market index funds inherently provide sector diversification because they hold technology, healthcare, financials, energy, and more. Avoid overweighting a single sector unless using a strict satellite strategy.</p>
    </section>

    <section>
      <h2>Portfolio Examples by Age</h2>
      <p>Your portfolio should evolve as you age, gradually shifting from wealth accumulation (growth) to wealth preservation (income).</p>
      <div class="grid-2">
        <div class="card">
          <h3>In Your 20s & 30s</h3>
          <p><strong>Allocation:</strong> 90-100% Stocks, 0-10% Bonds.</p>
          <p>Focus on aggressive growth. You have decades to recover from market crashes.</p>
        </div>
        <div class="card">
          <h3>In Your 40s</h3>
          <p><strong>Allocation:</strong> 70-80% Stocks, 20-30% Bonds.</p>
          <p>Begin introducing bonds to reduce volatility as your wealth grows and retirement comes into closer view.</p>
        </div>
        <div class="card">
          <h3>In Your 50s</h3>
          <p><strong>Allocation:</strong> 60% Stocks, 40% Bonds.</p>
          <p>The transition zone. You still need growth to fight inflation, but capital preservation becomes a significant priority.</p>
        </div>
        <div class="card">
          <h3>In Your 60s & Beyond</h3>
          <p><strong>Allocation:</strong> 40-50% Stocks, 50-60% Bonds & Cash.</p>
          <p>Focus shifts heavily to generating steady income and protecting the nest egg you've built.</p>
        </div>
      </div>
    </section>

    <section>
      <h2>Implementation: Robo-Advisors vs. DIY</h2>
      <p>Once you know your target allocation, you need to decide how to implement and manage it.</p>
      <ul>
        <li><strong>DIY (Do It Yourself):</strong> You open a brokerage account (like Vanguard, Fidelity, or Schwab), buy the ETFs yourself, and manually rebalance your portfolio when allocations drift. It requires more effort but guarantees the absolute lowest fees.</li>
        <li><strong>Robo-Advisors:</strong> Services like Betterment or Wealthfront automatically build, monitor, and rebalance your portfolio based on a questionnaire. They also offer automated tax-loss harvesting. They charge a small management fee (usually 0.25%), making them ideal for hands-off investors.</li>
      </ul>
    </section>

    <section>
      <h2>Tracking and Monitoring Tools</h2>
      <p>Once your portfolio is built, you should track its performance and allocation, but avoid checking it obsessively.</p>
      <ul>
        <li><strong>Spreadsheets:</strong> Simple Google Sheets or Excel templates can track your target versus actual asset allocation.</li>
        <li><strong>Personal Capital / Empower:</strong> A popular free tool that aggregates all your accounts in one dashboard to analyze your true asset allocation and fee breakdown.</li>
        <li><strong>Brokerage Dashboards:</strong> Most major brokerages now offer excellent built-in portfolio analysis tools.</li>
      </ul>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <div class="faq-q">What is an aggressive asset allocation?</div>
          <div class="faq-a">An aggressive allocation typically holds 80% to 100% in stocks and focuses on long-term growth, accepting higher volatility for potentially higher returns.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">What are VTI, VXUS, and BND?</div>
          <div class="faq-a">They are popular Vanguard ETFs used in a three-fund portfolio: VTI covers the total US stock market, VXUS covers total international stocks, and BND covers the total US bond market.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">How should my portfolio change in my 50s and 60s?</div>
          <div class="faq-a">As you approach retirement in your 50s and 60s, you generally shift toward a more conservative allocation, increasing bonds and cash to protect capital while still maintaining some stocks for growth.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">Should I use a robo-advisor or do it myself (DIY)?</div>
          <div class="faq-a">Robo-advisors are great for hands-off investors who want automated rebalancing and tax-loss harvesting for a small fee, while the DIY approach is better for those who want total control and the lowest possible fees.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">What is the core-satellite approach?</div>
          <div class="faq-a">The core-satellite approach uses low-cost index funds for the majority (core) of the portfolio while allocating a small percentage (satellite) to individual stocks or specific sectors.</div>
        </div>
      </div>
    </section>

  </div>
</SiteLayout>