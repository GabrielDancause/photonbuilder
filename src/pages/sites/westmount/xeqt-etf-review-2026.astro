---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is XEQT a good investment for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, XEQT remains a strong choice for long-term investors seeking a globally diversified, 100% equity portfolio in a single ETF with a low management fee."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between XEQT and VEQT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both are 100% equity ETFs, but XEQT has a slightly higher US allocation (approx. 45% vs 43%), lower Canadian allocation (25% vs 30%), and a slightly lower MER."
      }
    },
    {
      "@type": "Question",
      "name": "What is the MER of XEQT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "XEQT has a Management Expense Ratio (MER) of 0.20%, which is very competitive for an all-in-one global equity portfolio."
      }
    },
    {
      "@type": "Question",
      "name": "Does XEQT pay a dividend?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, XEQT pays distributions on a quarterly basis. The yield fluctuates based on the underlying global holdings."
      }
    },
    {
      "@type": "Question",
      "name": "What are the underlying ETFs in XEQT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "XEQT is a fund of funds that holds four other iShares ETFs: ITOT (US equity), XIC (Canadian equity), XEF (International equity), and IEMG (Emerging Markets equity)."
      }
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title="XEQT ETF Review 2026: iShares All Equity ETF vs VEQT"
  description="Complete 2026 review of XEQT (iShares Core Equity ETF). See performance vs VEQT, MER, asset allocation, underlying ETFs, and if it's the best ETF."
  canonical="https://westmountfundamentals.com/xeqt-etf-review-2026" schema={schema}
>
  <div class="max-w-[1000px] mx-auto px-6 py-12 font-sans bg-[var(--bg-color)] text-[#e2e8f0] leading-relaxed">
    <h1 class="text-[2rem] md:text-[2.5rem] mb-4 bg-gradient-to-r from-[#e2e8f0] to-[var(--accent-color)] bg-clip-text text-transparent leading-[1.2]">XEQT ETF Review 2026: The Ultimate All-Equity ETF?</h1>
    <p class="mb-4 text-[var(--text-secondary)]">A comprehensive review of the iShares Core Equity ETF Portfolio (XEQT), comparing its performance, asset allocation, and underlying holdings against Vanguard's VEQT.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 my-8">
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 text-center">
        <div class="font-mono text-[1.8rem] font-bold text-[var(--accent-color)] mb-2" id="val-price">...</div>
        <div class="text-[0.9rem] text-[var(--text-secondary)] uppercase tracking-[0.5px]">Price (CAD)</div>
      </div>
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 text-center">
        <div class="font-mono text-[1.8rem] font-bold text-[var(--accent-color)] mb-2" id="val-aum">...</div>
        <div class="text-[0.9rem] text-[var(--text-secondary)] uppercase tracking-[0.5px]">AUM</div>
      </div>
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 text-center">
        <div class="font-mono text-[1.8rem] font-bold text-[var(--accent-color)] mb-2" id="val-mer">0.20%</div>
        <div class="text-[0.9rem] text-[var(--text-secondary)] uppercase tracking-[0.5px]">MER</div>
      </div>
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-6 text-center">
        <div class="font-mono text-[1.8rem] font-bold text-[var(--accent-color)] mb-2" id="val-1y">...</div>
        <div class="text-[0.9rem] text-[var(--text-secondary)] uppercase tracking-[0.5px]">1-Year Return</div>
      </div>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-8 mb-8">
      <h2 class="text-[1.8rem] mt-10 mb-4 text-white first:mt-0">Asset Allocation Breakdown</h2>
      <p class="mb-4 text-[var(--text-secondary)]">XEQT is designed to be a one-ticket solution for aggressive investors seeking 100% equity exposure. It achieves global diversification by holding four underlying iShares ETFs.</p>

      <div class="relative h-[250px] md:h-[300px] w-full my-8">
        <canvas id="allocationChart"></canvas>
      </div>

      <h3 class="text-[1.4rem] mt-6 mb-2 text-white">Underlying Holdings</h3>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-[0.95rem]">
          <thead>
            <tr>
              <th class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Underlying ETF</th>
              <th class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Region</th>
              <th class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Target Allocation</th>
            </tr>
          </thead>
          <tbody>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="p-4 text-left border-b border-[var(--border-color)]">ITOT (iShares Core S&P Total US Stock Mkt)</td>
              <td class="p-4 text-left border-b border-[var(--border-color)]">United States</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">~45%</td>
            </tr>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="p-4 text-left border-b border-[var(--border-color)]">XIC (iShares Core S&P/TSX Capped Composite)</td>
              <td class="p-4 text-left border-b border-[var(--border-color)]">Canada</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">~25%</td>
            </tr>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="p-4 text-left border-b border-[var(--border-color)]">XEF (iShares Core MSCI EAFE IMI)</td>
              <td class="p-4 text-left border-b border-[var(--border-color)]">International (Dev)</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">~25%</td>
            </tr>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="p-4 text-left border-b border-[var(--border-color)]">IEMG (iShares Core MSCI Emerging Markets)</td>
              <td class="p-4 text-left border-b border-[var(--border-color)]">Emerging Markets</td>
              <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">~5%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-8 mb-8">
      <h2 class="text-[1.8rem] mt-10 mb-4 text-white first:mt-0">XEQT vs VEQT: Performance Comparison</h2>
      <p class="mb-4 text-[var(--text-secondary)]">The primary competitor to XEQT is Vanguard's All-Equity ETF Portfolio (VEQT). While both aim to provide global equity exposure, they have slight differences in geographical allocation and fees.</p>

      <div class="overflow-x-auto">
        <table id="performanceTable" class="w-full border-collapse text-[0.95rem]">
          <thead>
            <tr>
              <th data-sort="metric" class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Metric</th>
              <th data-sort="xeqt" class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">XEQT (iShares)</th>
              <th data-sort="veqt" class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">VEQT (Vanguard)</th>
            </tr>
          </thead>
          <tbody id="performanceBody">
            <!-- Populated via JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-8 mb-8">
      <h2 class="text-[1.8rem] mt-10 mb-4 text-white first:mt-0">Underlying ETFs Details</h2>
      <div class="flex justify-between mb-4 flex-wrap gap-4">
        <input type="text" id="etfSearch" placeholder="Search ETFs..." class="w-full max-w-[300px] px-4 py-2 rounded border border-[var(--border-color)] bg-[#060a12] text-[#e2e8f0] focus:outline-none focus:border-[var(--accent-color)]">
      </div>
      <div class="overflow-x-auto">
        <table id="etfTable" class="w-full border-collapse text-[0.95rem]">
          <thead>
            <tr>
              <th data-sort="ticker" class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Ticker</th>
              <th data-sort="name" class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Name</th>
              <th data-sort="price" class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Price</th>
              <th data-sort="yield" class="p-4 text-left border-b border-[var(--border-color)] font-semibold text-white cursor-pointer select-none hover:text-[var(--accent-color)] transition-colors">Yield</th>
            </tr>
          </thead>
          <tbody id="etfBody">
            <!-- Populated via JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-8 mb-8">
      <h2 class="text-[1.8rem] mt-10 mb-4 text-white first:mt-0">Frequently Asked Questions</h2>

      <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-b-0 last:mb-0 last:pb-0">
        <div class="font-semibold text-white mb-2">Is XEQT a good investment for 2026?</div>
        <div class="text-[var(--text-secondary)]">Yes, XEQT remains a strong choice for long-term investors seeking a globally diversified, 100% equity portfolio in a single ETF with a low management fee.</div>
      </div>

      <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-b-0 last:mb-0 last:pb-0">
        <div class="font-semibold text-white mb-2">What is the difference between XEQT and VEQT?</div>
        <div class="text-[var(--text-secondary)]">Both are 100% equity ETFs, but XEQT has a slightly higher US allocation (approx. 45% vs 43%), lower Canadian allocation (25% vs 30%), and a slightly lower MER.</div>
      </div>

      <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-b-0 last:mb-0 last:pb-0">
        <div class="font-semibold text-white mb-2">What is the MER of XEQT?</div>
        <div class="text-[var(--text-secondary)]">XEQT has a Management Expense Ratio (MER) of 0.20%, which is very competitive for an all-in-one global equity portfolio.</div>
      </div>

      <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-b-0 last:mb-0 last:pb-0">
        <div class="font-semibold text-white mb-2">Does XEQT pay a dividend?</div>
        <div class="text-[var(--text-secondary)]">Yes, XEQT pays distributions on a quarterly basis. The yield fluctuates based on the underlying global holdings.</div>
      </div>

      <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-b-0 last:mb-0 last:pb-0">
        <div class="font-semibold text-white mb-2">What are the underlying ETFs in XEQT?</div>
        <div class="text-[var(--text-secondary)]">XEQT is a fund of funds that holds four other iShares ETFs: ITOT (US equity), XIC (Canadian equity), XEF (International equity), and IEMG (Emerging Markets equity).</div>
      </div>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-8 mb-8">
      <h2 class="text-[1.8rem] mt-10 mb-4 text-white first:mt-0">Methodology & Data Sources</h2>
      <p class="mb-4 text-[var(--text-secondary)]">Data presented on this page is sourced from Yahoo Finance API via yahoo-finance2. Returns are calculated using monthly adjusted close prices over trailing 1, 3, and 5-year periods. Asset allocation targets are based on the fund's stated mandate from iShares by BlackRock. Performance metrics are backward-looking and do not guarantee future results.</p>
    </div>

  </div>
  <script is:inline>
// Data injected at build time
    const PAGE_DATA = {"xeqt":{"price":39.97,"yield":null,"aum":14832646144,"returns":{"1Y":22.57538613150675,"3Y":60.75370578711414,"5Y":72.32773613496694}},"veqt":{"price":53.85,"yield":null,"aum":12165570560,"returns":{"1Y":23.790016931572524,"3Y":61.58811420052399,"5Y":73.78723714386982}},"itot":{"price":145.34,"yield":0.843659,"aum":82422431744},"xic":{"price":52.56,"yield":1.3711806,"aum":26922676224},"xef":{"price":46.68,"yield":null,"aum":19624194048},"iemg":{"price":69.97,"yield":1.605092,"aum":148632256512}};

    document.addEventListener('DOMContentLoaded', () => {
      if (!PAGE_DATA || !PAGE_DATA.xeqt) return;

      // Formatters
      const formatCurrency = (val) => val != null ? '$' + val.toFixed(2) : 'N/A';
      const formatPercent = (val) => val != null ? val.toFixed(2) + '%' : 'N/A';
      const formatAUM = (val) => {
        if (val == null) return 'N/A';
        if (val >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
        if (val >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
        return '$' + val;
      };

      // Populate Stats
      document.getElementById('val-price').textContent = formatCurrency(PAGE_DATA.xeqt.price);
      document.getElementById('val-aum').textContent = formatAUM(PAGE_DATA.xeqt.aum);
      document.getElementById('val-1y').textContent = formatPercent(PAGE_DATA.xeqt.returns['1Y']);

      // Setup Allocation Chart
      const ctx = document.getElementById('allocationChart').getContext('2d');
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: ['US Equity (ITOT)', 'Canadian Equity (XIC)', 'International Dev (XEF)', 'Emerging Markets (IEMG)'],
          datasets: [{
            data: [45, 25, 25, 5],
            backgroundColor: [
              '#4a8fe7',
              '#e74a4a',
              '#4ae78f',
              '#e7b44a'
            ],
            borderColor: '#060a12',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'right',
              labels: { color: '#e2e8f0' }
            }
          }
        }
      });

      // Populate Performance Table
      const perfData = [
        { metric: 'Price (CAD)', xeqt: formatCurrency(PAGE_DATA.xeqt.price), veqt: formatCurrency(PAGE_DATA.veqt.price) },
        { metric: 'AUM', xeqt: formatAUM(PAGE_DATA.xeqt.aum), veqt: formatAUM(PAGE_DATA.veqt.aum) },
        { metric: 'Yield', xeqt: formatPercent(PAGE_DATA.xeqt.yield), veqt: formatPercent(PAGE_DATA.veqt.yield) },
        { metric: '1-Year Return', xeqt: formatPercent(PAGE_DATA.xeqt.returns['1Y']), veqt: formatPercent(PAGE_DATA.veqt.returns['1Y']) },
        { metric: '3-Year Return', xeqt: formatPercent(PAGE_DATA.xeqt.returns['3Y']), veqt: formatPercent(PAGE_DATA.veqt.returns['3Y']) },
        { metric: '5-Year Return', xeqt: formatPercent(PAGE_DATA.xeqt.returns['5Y']), veqt: formatPercent(PAGE_DATA.veqt.returns['5Y']) }
      ];

      const perfBody = document.getElementById('performanceBody');
      perfData.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = "hover:bg-white/5 transition-colors";
        tr.innerHTML = `
          <td class="p-4 text-left border-b border-[var(--border-color)]">${row.metric}</td>
          <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">${row.xeqt}</td>
          <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">${row.veqt}</td>
        `;
        perfBody.appendChild(tr);
      });

      // Populate Underlying ETFs Table
      const etfData = [
        { ticker: 'ITOT', name: 'iShares Core S&P Total US Stock Mkt', price: PAGE_DATA.itot.price, yield: PAGE_DATA.itot.yield },
        { ticker: 'XIC.TO', name: 'iShares Core S&P/TSX Capped Composite', price: PAGE_DATA.xic.price, yield: PAGE_DATA.xic.yield },
        { ticker: 'XEF.TO', name: 'iShares Core MSCI EAFE IMI', price: PAGE_DATA.xef.price, yield: PAGE_DATA.xef.yield },
        { ticker: 'IEMG', name: 'iShares Core MSCI Emerging Markets', price: PAGE_DATA.iemg.price, yield: PAGE_DATA.iemg.yield }
      ];

      const etfBody = document.getElementById('etfBody');
      const renderEtfTable = (data) => {
        etfBody.innerHTML = '';
        data.forEach(etf => {
          const tr = document.createElement('tr');
          tr.className = "hover:bg-white/5 transition-colors";
          tr.innerHTML = `
            <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">${etf.ticker}</td>
            <td class="p-4 text-left border-b border-[var(--border-color)]">${etf.name}</td>
            <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">${formatCurrency(etf.price)}</td>
            <td class="p-4 text-left border-b border-[var(--border-color)] font-mono">${formatPercent(etf.yield)}</td>
          `;
          etfBody.appendChild(tr);
        });
      };

      renderEtfTable(etfData);

      // Search functionality
      document.getElementById('etfSearch').addEventListener('keyup', (e) => {
        const query = e.target.value.toLowerCase();
        const filtered = etfData.filter(etf =>
          etf.ticker.toLowerCase().includes(query) ||
          etf.name.toLowerCase().includes(query)
        );
        renderEtfTable(filtered);
      });

      // Sort functionality
      let sortCol = '';
      let sortAsc = true;
      document.querySelectorAll('#etfTable th').forEach(th => {
        th.addEventListener('click', () => {
          const col = th.dataset.sort;
          if (sortCol === col) {
            sortAsc = !sortAsc;
          } else {
            sortCol = col;
            sortAsc = true;
          }

          const sorted = [...etfData].sort((a, b) => {
            let valA = a[col];
            let valB = b[col];
            if (typeof valA === 'string') valA = valA.toLowerCase();
            if (typeof valB === 'string') valB = valB.toLowerCase();

            if (valA < valB) return sortAsc ? -1 : 1;
            if (valA > valB) return sortAsc ? 1 : -1;
            return 0;
          });
          renderEtfTable(sorted);
        });
      });
    });
  </script>
</SiteLayout>
