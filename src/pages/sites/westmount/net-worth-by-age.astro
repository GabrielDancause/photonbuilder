  }
  .ladder-rung:hover {
    background: rgba(74,143,231,0.05);
  }
  .highlight-rung {
    background: rgba(74,143,231,0.08);
    border-radius: 8px;
  }
  .ladder-pct {
    font-weight: 700;
    color: var(--accent-color);
    font-size: 0.9rem;
  }
  .ladder-amount {
    font-weight: 800;
    font-size: 1.15rem;
  }
  .ladder-desc {
    color: var(--text-secondary);
