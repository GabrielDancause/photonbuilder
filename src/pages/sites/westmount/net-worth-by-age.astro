      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
    .data-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  // Net worth percentile data by age group (interpolated from Fed SCF data, inflation-adjusted to 2026)
  const DATA = {
    'under35': {
      label: 'Under 35',
      median: 39000,
      mean: 183500,
      percentiles: {
        10: -27000, 20: 3200, 25: 8200, 30: 14000, 40: 26000,
        50: 39000, 60: 63000, 70: 105000, 75: 140000, 80: 190000,
        90: 380000, 95: 680000, 99: 2400000
      }
    },
    '35to44': {
      label: '35-44',
      median: 135600,
      mean: 549600,
      percentiles: {
        10: -7000, 20: 18000, 25: 38000, 30: 62000, 40: 98000,
        50: 135600, 60: 210000, 70: 340000, 75: 430000, 80: 570000,
        90: 1100000, 95: 2000000, 99: 6500000
      }
    },
    '45to54': {
      label: '45-54',
      median: 247200,
      mean: 975800,
      percentiles: {
        10: 2000, 20: 42000, 25: 75000, 30: 115000, 40: 180000,
        50: 247200, 60: 380000, 70: 580000, 75: 720000, 80: 950000,
        90: 1900000, 95: 3400000, 99: 11000000
      }
    },
    '55to64': {
      label: '55-64',
      median: 364500,
      mean: 1566900,
      percentiles: {
        10: 7000, 20: 60000, 25: 110000, 30: 165000, 40: 260000,
        50: 364500, 60: 540000, 70: 830000, 75: 1050000, 80: 1400000,
        90: 2800000, 95: 5200000, 99: 16000000
      }
    },
    '65to74': {
      label: '65-74',
      median: 409900,
      mean: 1794600,
      percentiles: {
        10: 18000, 20: 80000, 25: 130000, 30: 195000, 40: 300000,
        50: 409900, 60: 610000, 70: 920000, 75: 1150000, 80: 1500000,
        90: 3200000, 95: 5800000, 99: 18000000
      }
    },
    '75plus': {
      label: '75+',
      median: 335600,
      mean: 1624100,
      percentiles: {
        10: 12000, 20: 62000, 25: 100000, 30: 155000, 40: 240000,
        50: 335600, 60: 500000, 70: 760000, 75: 950000, 80: 1250000,
        90: 2700000, 95: 4900000, 99: 15000000
      }
    }
  };

  function getAgeGroup(age) {
    if (age < 35) return 'under35';
    if (age < 45) return '35to44';
    if (age < 55) return '45to54';
    if (age < 65) return '55to64';
    if (age < 75) return '65to74';
    return '75plus';
  }

  function interpolatePercentile(nw, percentiles) {
    const pcts = Object.keys(percentiles).map(Number).sort((a, b) => a - b);
    
    if (nw <= percentiles[pcts[0]]) return Math.max(1, pcts[0] * (nw / percentiles[pcts[0]]));
    if (nw >= percentiles[pcts[pcts.length - 1]]) return Math.min(99, pcts[pcts.length - 1]);
    
    for (let i = 0; i < pcts.length - 1; i++) {
      const lowPct = pcts[i], highPct = pcts[i + 1];
      const lowVal = percentiles[lowPct], highVal = percentiles[highPct];
      
      if (nw >= lowVal && nw <= highVal) {
        const ratio = (nw - lowVal) / (highVal - lowVal);
        return Math.round(lowPct + ratio * (highPct - lowPct));
      }
    }
    return 50;
  }

  function formatMoney(n) {
    if (n < 0) return '-$' + Math.abs(n).toLocaleString();
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return '$' + Math.round(n / 1000) + 'K';
    return '$' + n.toLocaleString();
  }

  function calculatePercentile() {
    const age = parseInt(document.getElementById('age-input').value);
    const nw = parseInt(document.getElementById('nw-input').value);
    
    if (isNaN(age) || isNaN(nw)) return;
    
    const group = getAgeGroup(age);
    const data = DATA[group];
    const pct = interpolatePercentile(nw, data.percentiles);
    
    // Show result panel
    document.getElementById('result-panel').style.display = 'block';
    
    // Animate percentile ring
    const circle = document.getElementById('progress-circle');
    const circumference = 327;
    const offset = circumference - (pct / 100) * circumference;
    circle.style.transition = 'stroke-dashoffset 1.5s ease';
    circle.style.strokeDashoffset = offset;
    
    // Animate number
    const numEl = document.getElementById('percentile-number');
    let current = 0;
    const step = Math.max(1, Math.floor(pct / 30));
    const interval = setInterval(() => {
      current = Math.min(current + step, pct);
      numEl.textContent = current + 'th';
      if (current >= pct) clearInterval(interval);
    }, 40);
    
    // Result text
    const details = document.getElementById('result-details');
    const aboveBelow = nw >= data.median ? 'above' : 'below';
    const diff = Math.abs(nw - data.median);
    
    let verdict = '';
    if (pct >= 90) verdict = "🏆 You're in the top 10% for your age group. Exceptional wealth building.";
    else if (pct >= 75) verdict = "🌟 You're well above average. Strong financial position.";
    else if (pct >= 50) verdict = "👍 You're above the median. Better than half of your peers.";
    else if (pct >= 25) verdict = "📈 Room to grow, but you're building. Keep investing consistently.";
    else verdict = "🚀 Starting point identified. Small, consistent steps compound dramatically over time.";
    
    details.innerHTML = `
      <p>At age <strong>${age}</strong> with a net worth of <strong>${formatMoney(nw)}</strong>, you rank higher than <strong>${pct}%</strong> of American households in the ${data.label} age group.</p>
      <p>You're <strong>${formatMoney(diff)} ${aboveBelow}</strong> the median of ${formatMoney(data.median)}. The average (skewed by ultra-wealthy) is ${formatMoney(data.mean)}.</p>
      <p>${verdict}</p>
    `;
    
    // Comparison bar
    const maxVal = data.percentiles[95] || data.mean * 2;
    const barFill = document.getElementById('bar-fill');
    const barMarker = document.getElementById('bar-marker');
    const barMedian = document.getElementById('bar-median-marker');
    const barMaxLabel = document.getElementById('bar-max-label');
    
    barMaxLabel.textContent = formatMoney(maxVal);
    
    const yourPct = Math.min(Math.max(nw / maxVal * 100, 2), 98);
    const medPct = Math.min(data.median / maxVal * 100, 98);
    
    barFill.style.width = yourPct + '%';
    barMarker.style.left = yourPct + '%';
    barMedian.style.left = medPct + '%';
    
    // Smooth scroll to results
    document.getElementById('result-panel').scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
