    border-left: 4px solid var(--border-color);
    transition: transform 0.2s;
  }
  .milestone:hover {
    transform: translateX(4px);
  }
  .accent-milestone {
    border-left-color: var(--accent-color);
    background: linear-gradient(135deg, rgba(74,143,231,0.08), transparent);
  }
  .milestone-amount {
