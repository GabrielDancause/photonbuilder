    line-height: 1.5;
  }

  .milestones {
    margin: 1.5rem 0;
  }
  .milestone {
    position: relative;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
