  }
  .strategy-card:hover {
    transform: translateY(-2px);
  }
  .strategy-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .strategy-card h3 {
    margin-top: 0.5rem;
    font-size: 1rem;
  }
  .strategy-card p {
    font-size: 0.9rem;
