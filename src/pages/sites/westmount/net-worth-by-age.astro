  .callout-box {
    background: linear-gradient(135deg, rgba(74,143,231,0.1), rgba(99,102,241,0.05));
    border-left: 4px solid var(--accent-color);
    border-radius: 0 12px 12px 0;
    padding: 1.5rem;
    margin: 2rem 0;
  }
  .callout-box h3 {
