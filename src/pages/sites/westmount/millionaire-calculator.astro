---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'How Long It Actually Takes to Become a Millionaire | By Profession',
  description: 'Interactive calculator showing exactly how many years each profession takes to reach $1M net worth. Compare careers side-by-side with real salary data.',
  category: 'calculator',
  keywords: ['millionaire calculator', 'time to millionaire', 'wealth by profession', 'savings rate calculator', 'net worth growth', 'career wealth comparison']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
    "publisher": { "@type": "Organization", "name": "Westmount Fundamentals" },
    "datePublished": "2026-03-22",
    "dateModified": "2026-03-22"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does it take the average person to become a millionaire?",
        "acceptedAnswer": { "@type": "Answer", "text": "At the median US household income of $74,580 with a 5.8% savings rate and average S&P 500 returns of 10.3%, it takes approximately 35-40 years. Increasing your savings rate to 20% can cut this to under 25 years." }
      },
      {
        "@type": "Question",
        "name": "Which profession becomes a millionaire the fastest?",
        "acceptedAnswer": { "@type": "Answer", "text": "Among common professions, trades like plumbers and electricians often reach millionaire status surprisingly fast — sometimes before doctors — because they start earning earlier, carry almost no student debt, and benefit from more years of compound growth." }
      },
      {
        "@type": "Question",
        "name": "Does a higher salary guarantee becoming a millionaire sooner?",
        "acceptedAnswer": { "@type": "Answer", "text": "Not necessarily. A doctor earning $229,000 but starting at 30 with $215,000 in debt may reach $1M later than a plumber earning $63,000 who starts at 19 with only $3,000 in debt. The three levers are income, savings rate, and time — and time is the most powerful." }
      },
      {
        "@type": "Question",
        "name": "What savings rate do I need to become a millionaire?",
        "acceptedAnswer": { "@type": "Answer", "text": "The average American saves only 5.8% of their income. Financial advisors recommend at least 20%. At a 20% savings rate with average market returns, most middle-income earners can reach $1M within 25-30 years of starting to save." }
      },
      {
        "@type": "Question",
        "name": "How does compound interest help you become a millionaire?",
        "acceptedAnswer": { "@type": "Answer", "text": "Compound interest is the engine that turns modest savings into millions. At a 10.3% average annual return (historical S&P 500), $1 invested doubles roughly every 7 years. Starting just 5 years earlier can mean hundreds of thousands more at retirement." }
      }
    ]
  }
]);
---

<SiteLayout site="westmount" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <section class="mill-hero">
    <div class="mill-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>How Long It <em>Actually</em> Takes to Become a Millionaire</h1>
    <p class="mill-hero-hook">A plumber starting at 19 reaches <strong>$1M before a surgeon starting at 30</strong>. <br/>The math will surprise you.</p>
    <div class="mill-hero-stats">
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-fastest"></span>
        <span class="mill-stat-label">Fastest Path</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-slowest"></span>
        <span class="mill-stat-label">Slowest Path</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num">10.3%</span>
        <span class="mill-stat-label">Avg S&P Return</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="mill-section">
    <h2 class="mill-section-title">Your Path to $1 Million</h2>
    <p class="mill-section-sub">Select a profession or enter custom numbers to see your timeline.</p>

    <div class="mill-calc-container">
      <div class="mill-calc-inputs">
        <div class="mill-input-group">
          <label for="profession-select">Profession</label>
          <select id="profession-select">
            <option value="">— Select a profession —</option>
            <option value="custom">Custom (enter your own)</option>
          </select>
        </div>

        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="input-salary">Annual Salary</label>
            <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="input-salary" min="0" max="1000000" step="1000" /></div>
          </div>
          <div class="mill-input-group">
            <label for="input-debt">Student Debt</label>
            <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="input-debt" min="0" max="500000" step="1000" /></div>
          </div>
          <div class="mill-input-group">
            <label for="input-start-age">Start Age</label>
            <input type="number" id="input-start-age" min="16" max="50" />
          </div>
        </div>

        <div class="mill-input-group">
          <label for="savings-slider">Savings Rate: <strong id="savings-rate-display">20%</strong></label>
          <input type="range" id="savings-slider" min="1" max="50" value="20" />
          <div class="mill-slider-labels"><span>1%</span><span>Avg: 5.8%</span><span>50%</span></div>
        </div>

        <div class="mill-input-group">
          <label for="return-select">Investment Strategy</label>
          <select id="return-select">
            <option value="10.3">S&P 500 Index (10.3% avg)</option>
            <option value="8.5">60/40 Portfolio (8.5% avg)</option>
            <option value="5">Conservative Bonds (5%)</option>
            <option value="4.5">High-Yield Savings (4.5%)</option>
          </select>
        </div>

        <button id="calc-btn" class="mill-btn">Calculate My Timeline</button>
      </div>

      <!-- RESULTS -->
      <div class="mill-calc-results" id="results-panel" style="display:none;">
        <div class="mill-result-header">
          <div class="mill-result-title" id="result-profession-name">Your Results</div>
          <div class="mill-result-age">Millionaire by age <strong id="result-age">—</strong></div>
          <div class="mill-result-years"><span id="result-years">—</span> years of investing</div>
        </div>

        <!-- MILESTONES -->
        <div class="mill-milestones" id="milestones-container"></div>

        <!-- ANIMATED BAR CHART -->
        <div class="mill-chart-wrap">
          <div class="mill-chart-title">Wealth Growth Over Time</div>
          <div class="mill-chart" id="wealth-chart"></div>
          <div class="mill-chart-legend">
            <span><i class="mill-legend-dot contributions"></i> Contributions</span>
            <span><i class="mill-legend-dot growth"></i> Investment Growth</span>
          </div>
        </div>

        <div class="mill-insight" id="result-insight"></div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="mill-section">
    <h2 class="mill-section-title">Compare Two Professions</h2>
    <p class="mill-section-sub">See how career choice, debt, and starting age change the path to $1M.</p>

    <div class="mill-compare-controls">
      <div class="mill-input-group">
        <label for="compare-a">Profession A</label>
        <select id="compare-a"></select>
      </div>
      <div class="mill-vs">VS</div>
      <div class="mill-input-group">
        <label for="compare-b">Profession B</label>
        <select id="compare-b"></select>
      </div>
      <button id="compare-btn" class="mill-btn">Compare</button>
    </div>

    <div class="mill-compare-results" id="compare-results" style="display:none;">
      <div class="mill-compare-cards">
        <div class="mill-compare-card" id="compare-card-a"></div>
        <div class="mill-compare-card" id="compare-card-b"></div>
      </div>
      <div class="mill-compare-race" id="compare-race"></div>
    </div>
  </section>

  <!-- RANKINGS TABLE -->
  <section class="mill-section">
    <h2 class="mill-section-title">All Professions Ranked</h2>
    <p class="mill-section-sub">Years to $1M at 20% savings rate with S&P 500 returns.</p>
    <div class="mill-rankings" id="rankings-table"></div>
  </section>

  <!-- THE 3 LEVERS -->
  <section class="mill-section">
    <h2 class="mill-section-title">The 3 Levers That Control Your Timeline</h2>
    <div class="mill-levers">
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="16" stroke="currentColor" stroke-width="1.5" opacity="0.2"/><path d="M18 8v4M18 24v4M8 18h4M24 18h4" stroke="var(--accent-color, #4a8fe7)" stroke-width="2" stroke-linecap="round"/><circle cx="18" cy="18" r="5" fill="var(--accent-color, #4a8fe7)" opacity="0.2" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.5"/></svg>
        </div>
        <h3>Income</h3>
        <p>Higher income gives you more raw dollars to invest. But income alone doesn't determine speed — a $229K earner with massive debt can lose to a $63K earner who starts debt-free.</p>
        <div class="mill-lever-impact">Impact: <strong>Medium</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="4" y="22" width="6" height="10" rx="1" fill="var(--accent-color, #4a8fe7)" opacity="0.25"/><rect x="13" y="16" width="6" height="16" rx="1" fill="var(--accent-color, #4a8fe7)" opacity="0.5"/><rect x="22" y="8" width="6" height="24" rx="1" fill="var(--accent-color, #4a8fe7)" opacity="0.8"/></svg>
        </div>
        <h3>Savings Rate</h3>
        <p>The average American saves 5.8%. Bumping to 20% can shave <strong>10+ years</strong> off your timeline. This is the lever most within your control.</p>
        <div class="mill-lever-impact">Impact: <strong>High</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="14" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.5" opacity="0.3"/><circle cx="18" cy="18" r="14" stroke="var(--accent-color, #4a8fe7)" stroke-width="2.5" stroke-dasharray="88" stroke-dashoffset="22" stroke-linecap="round"/><line x1="18" y1="18" x2="18" y2="10" stroke="var(--accent-color, #4a8fe7)" stroke-width="2" stroke-linecap="round"/><line x1="18" y1="18" x2="24" y2="18" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.5" stroke-linecap="round"/><circle cx="18" cy="18" r="2" fill="var(--accent-color, #4a8fe7)"/></svg>
        </div>
        <h3>Time (Compound Growth)</h3>
        <p>At 10.3% returns, your money doubles every ~7 years. Starting at 19 vs 30 means <em>two extra doublings</em>. Time is the most powerful lever of all.</p>
        <div class="mill-lever-impact">Impact: <strong>Highest</strong></div>
      </div>
    </div>
  </section>

  <!-- CALLOUT -->
  <div class="mill-callout">
    <strong>Already know your net worth?</strong> Check where you stand for your age with our <a href="/net-worth-by-age">Net Worth by Age Percentile Calculator</a>.
  </div>

  <!-- FAQ -->
  <section class="mill-section">
    <h2 class="mill-section-title">Frequently Asked Questions</h2>
    <div class="mill-faq">
      <details class="mill-faq-item">
        <summary>How long does it take the average person to become a millionaire?</summary>
        <p>At the median US household income of $74,580 with a 5.8% savings rate and average S&P 500 returns of 10.3%, it takes approximately 35–40 years. Increasing your savings rate to 20% can cut this to under 25 years.</p>
      </details>
      <details class="mill-faq-item">
        <summary>Which profession becomes a millionaire the fastest?</summary>
        <p>Among common professions, trades like plumbers and electricians often reach millionaire status surprisingly fast — sometimes before doctors — because they start earning earlier, carry almost no student debt, and benefit from more years of compound growth.</p>
      </details>
      <details class="mill-faq-item">
        <summary>Does a higher salary guarantee becoming a millionaire sooner?</summary>
        <p>Not necessarily. A doctor earning $229,000 but starting at 30 with $215,000 in debt may reach $1M later than a plumber earning $63,000 who starts at 19 with only $3,000 in debt. The three levers are income, savings rate, and time — and time is the most powerful.</p>
      </details>
      <details class="mill-faq-item">
        <summary>What savings rate do I need to become a millionaire?</summary>
        <p>The average American saves only 5.8% of their income. Financial advisors recommend at least 20%. At a 20% savings rate with average market returns, most middle-income earners can reach $1M within 25–30 years of starting to save.</p>
      </details>
      <details class="mill-faq-item">
        <summary>How does compound interest help you become a millionaire?</summary>
        <p>Compound interest is the engine that turns modest savings into millions. At a 10.3% average annual return (historical S&P 500), $1 invested doubles roughly every 7 years. Starting just 5 years earlier can mean hundreds of thousands more at retirement.</p>
      </details>
    </div>
  </section>

  <div class="mill-disclaimer">
    <p><strong>Disclaimer:</strong> This calculator uses simplified assumptions including constant salary, fixed returns, and no taxes. Real-world results will vary based on salary growth, market volatility, tax brackets, inflation, and lifestyle changes. Median salary data from BLS 2024. Historical S&P 500 returns are not indicative of future performance.</p>
  </div>
</SiteLayout>

<style is:global>
  /* ===== MILLIONAIRE CALCULATOR ===== */
  .mill-page { max-width: 1100px; margin: 0 auto; }
  .mill-hero {
    text-align: center;
    padding: 2.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(74,143,231,0.12) 0%, rgba(74,143,231,0.02) 60%, rgba(74,143,231,0.08) 100%);
    border-bottom: 1px solid var(--border-color, #152040);
    position: relative;
    overflow: hidden;
  }
  .mill-hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(74,143,231,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(74,143,231,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    padding: 0.35rem 1rem;
    border: 1px solid var(--accent-color, #4a8fe7);
    border-radius: 100px;
    color: var(--accent-color, #4a8fe7);
    margin-bottom: 1.5rem;
    font-weight: 600;
    animation: mill-fadeUp 0.6s ease both;
  }
  .mill-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    margin: 0 auto 1rem;
    max-width: 700px;
    color: var(--text-primary, #c8d0de);
    animation: mill-fadeUp 0.6s 0.1s ease both;
  }
  .mill-hero h1 em {
    color: var(--accent-color, #4a8fe7);
    font-style: italic;
  }
  .mill-hero-hook {
    font-size: 1.15rem;
    color: var(--text-secondary, #94a3b8);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    animation: mill-fadeUp 0.6s 0.2s ease both;
  }
  .mill-hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    animation: mill-fadeUp 0.6s 0.3s ease both;
  }
  .mill-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .mill-stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent-color, #4a8fe7);
    white-space: nowrap;
  }
  .mill-stat-label {
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* SECTIONS */
  .mill-section {
    padding: 2.5rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .mill-section-title {
    font-size: 1.6rem;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .mill-section-sub {
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  /* CALCULATOR */
  .mill-calc-container {
    display: grid;
    gap: 2rem;
  }
  .mill-calc-inputs {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 2rem;
  }
  .mill-input-row {
    display: grid;
    grid-template-columns: 1fr 1fr 0.7fr;
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .mill-input-row { grid-template-columns: 1fr; }
  }
  .mill-input-group {
    margin-bottom: 1.25rem;
  }
  .mill-input-group label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.4rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .mill-input-group select,
  .mill-input-group input[type="number"] {
    width: 100%;
    padding: 0.65rem 0.75rem;
    background: var(--bg-color, #060a12);
    border: 1px solid var(--border-color, #152040);
    border-radius: 8px;
    color: var(--text-primary, #c8d0de);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .mill-input-group select:focus,
  .mill-input-group input:focus {
    outline: none;
    border-color: var(--accent-color, #4a8fe7);
    box-shadow: 0 0 0 3px rgba(74,143,231,0.1);
  }
  .mill-input-wrap {
    position: relative;
  }
  .mill-input-prefix {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary, #94a3b8);
    font-size: 0.95rem;
    pointer-events: none;
  }
  .mill-input-wrap input {
    padding-left: 1.5rem !important;
  }

  /* SLIDER */
  .mill-input-group input[type="range"] {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 6px;
    background: linear-gradient(90deg, var(--accent-color, #4a8fe7) 0%, var(--border-color, #152040) 0%);
    border-radius: 3px;
    outline: none;
    margin-top: 0.5rem;
  }
  .mill-input-group input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent-color, #4a8fe7);
    cursor: pointer;
    box-shadow: 0 0 12px rgba(74,143,231,0.4);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .mill-input-group input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.2);
    box-shadow: 0 0 18px rgba(74,143,231,0.5);
  }
  .mill-input-group input[type="range"]::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--accent-color, #4a8fe7);
    cursor: pointer;
    border: none;
    box-shadow: 0 0 12px rgba(74,143,231,0.4);
  }
  .mill-slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    margin-top: 0.3rem;
  }

  /* BUTTON */
  .mill-btn {
    width: 100%;
    padding: 0.85rem;
    border: none;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--accent-color, #4a8fe7), #3a6fd4);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    margin-top: 0.5rem;
    position: relative;
    overflow: hidden;
  }
  .mill-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.1) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: transform 0.5s;
  }
  .mill-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(74,143,231,0.35);
  }
  .mill-btn:hover::after {
    transform: translateX(100%);
  }
  .mill-btn:active {
    transform: translateY(0);
  }

  /* RESULTS */
  .mill-calc-results {
    animation: mill-fadeUp 0.5s ease;
  }
  @keyframes mill-fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .mill-result-header {
    text-align: center;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(74,143,231,0.12), rgba(74,143,231,0.03));
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .mill-result-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent-color, #4a8fe7), transparent);
  }
  .mill-result-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.5rem;
  }
  .mill-result-age {
    font-size: 1.5rem;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.25rem;
  }
  .mill-result-age strong {
    font-size: 2.4rem;
    color: var(--accent-color, #4a8fe7);
    text-shadow: 0 0 30px rgba(74,143,231,0.3);
  }
  .mill-result-years {
    color: var(--text-secondary, #94a3b8);
    font-size: 0.95rem;
  }
  .mill-result-years span {
    color: var(--accent-color, #4a8fe7);
    font-weight: 700;
  }

  /* MILESTONES */
  .mill-milestones {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 600px) {
    .mill-milestones { grid-template-columns: repeat(2, 1fr); }
  }
  .mill-milestone {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 10px;
    padding: 1rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
