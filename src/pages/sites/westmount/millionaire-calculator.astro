<script is:inline>
(function() {
  'use strict';

  var PROFESSIONS = [
    { name: 'Software Engineer', salary: 130000, debt: 37000, startAge: 22 },
    { name: 'Doctor (MD)', salary: 229000, debt: 215000, startAge: 30 },
    { name: 'Nurse (RN)', salary: 86000, debt: 47000, startAge: 24 },
    { name: 'Teacher', salary: 62000, debt: 55000, startAge: 23 },
    { name: 'Electrician', salary: 65000, debt: 5000, startAge: 20 },
    { name: 'Plumber', salary: 63000, debt: 3000, startAge: 19 },
    { name: 'Accountant', salary: 83000, debt: 42000, startAge: 22 },
    { name: 'Marketing Manager', salary: 140000, debt: 45000, startAge: 23 },
    { name: 'Pharmacist', salary: 132000, debt: 170000, startAge: 26 },
    { name: 'Lawyer', salary: 145000, debt: 165000, startAge: 26 },
    { name: 'Data Scientist', salary: 108000, debt: 40000, startAge: 23 },
    { name: 'Mechanic', salary: 48000, debt: 5000, startAge: 19 },
    { name: 'Dental Hygienist', salary: 87000, debt: 55000, startAge: 22 }
  ];

  function fmt(n) {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return '$' + Math.round(n / 1000) + 'K';
    return '$' + Math.round(n);
  }

  function fmtFull(n) {
    return '$' + Math.round(n).toLocaleString();
  }

  function simulate(salary, debt, startAge, savingsRate, annualReturn) {
    var rate = savingsRate / 100;
    var ret = annualReturn / 100;
    var annualSaving = salary * rate;
    var balance = -debt;
    var years = [];
    var contributions = 0;

    for (var y = 0; y <= 60; y++) {
      var currentBal = Math.max(balance, 0);
      var currentContrib = Math.max(Math.min(contributions, currentBal), 0);
      years.push({
        year: y,
        age: startAge + y,
        balance: currentBal,
        totalContributions: currentContrib,
        growth: currentBal - currentContrib
      });
      if (balance >= 1000000) break;
      contributions += annualSaving;
      balance = (balance + annualSaving) * (1 + ret);
      if (y >= 59) break;
    }
    return years;
  }

  function yearsToMillion(salary, debt, startAge, savingsRate, annualReturn) {
    var data = simulate(salary, debt, startAge, savingsRate || 20, annualReturn || 10.3);
    for (var i = 0; i < data.length; i++) {
      if (data[i].balance >= 1000000) return data[i].year;
    }
    return 60;
  }

  // Populate profession dropdowns
  var profSelect = document.getElementById('profession-select');
  var compareA = document.getElementById('compare-a');
  var compareB = document.getElementById('compare-b');

  PROFESSIONS.forEach(function(p, i) {
    var opt = document.createElement('option');
    opt.value = i;
    opt.textContent = p.name;
    profSelect.appendChild(opt);
    compareA.appendChild(opt.cloneNode(true));
    compareB.appendChild(opt.cloneNode(true));
  });

  compareA.value = '5'; // Plumber
  compareB.value = '1'; // Doctor

  // Auto-fill on profession select
  profSelect.addEventListener('change', function() {
    var v = this.value;
    if (v === '' || v === 'custom') return;
    var p = PROFESSIONS[parseInt(v)];
    document.getElementById('input-salary').value = p.salary;
    document.getElementById('input-debt').value = p.debt;
    document.getElementById('input-start-age').value = p.startAge;
  });

  // Savings slider with gradient track
  var slider = document.getElementById('savings-slider');
  var sliderDisplay = document.getElementById('savings-rate-display');

  function updateSlider() {
    var pct = ((slider.value - slider.min) / (slider.max - slider.min)) * 100;
    slider.style.background = 'linear-gradient(90deg, ' +
      'var(--accent-color, #4a8fe7) ' + pct + '%, ' +
      'var(--border-color, #152040) ' + pct + '%)';
    sliderDisplay.textContent = slider.value + '%';
  }
  slider.addEventListener('input', updateSlider);
  updateSlider();

  // MAIN CALCULATOR
  document.getElementById('calc-btn').addEventListener('click', function() {
    var salary = parseFloat(document.getElementById('input-salary').value) || 0;
    var debt = parseFloat(document.getElementById('input-debt').value) || 0;
    var startAge = parseInt(document.getElementById('input-start-age').value) || 22;
    var savingsRate = parseInt(slider.value);
    var annualReturn = parseFloat(document.getElementById('return-select').value);

    if (salary <= 0) return;

    var data = simulate(salary, debt, startAge, savingsRate, annualReturn);
    var panel = document.getElementById('results-panel');
    panel.style.display = 'block';

    setTimeout(function() {
      panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 50);

    var hitEntry = null;
    for (var i = 0; i < data.length; i++) {
      if (data[i].balance >= 1000000) { hitEntry = data[i]; break; }
    }
    var years = hitEntry ? hitEntry.year : 60;
    var millAge = startAge + years;

    var pIdx = profSelect.value;
    var profName = (pIdx !== '' && pIdx !== 'custom') ? PROFESSIONS[parseInt(pIdx)].name : 'Custom Profile';
    document.getElementById('result-profession-name').textContent = profName;
    document.getElementById('result-age').textContent = hitEntry ? millAge : '80+';
    document.getElementById('result-years').textContent = hitEntry ? years : '60+';

    // Milestones
    var milestones = [
      { amt: 100000, icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.5" stroke-linecap="round"/></svg>', label: '$100K' },
      { amt: 250000, icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L15 10H22L16.5 14.5L18.5 22L12 17.5L5.5 22L7.5 14.5L2 10H9L12 2Z" fill="var(--accent-color, #4a8fe7)" opacity="0.3" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.2"/></svg>', label: '$250K' },
      { amt: 500000, icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 20L12 4L20 20" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="7" y1="14" x2="17" y2="14" stroke="var(--accent-color, #4a8fe7)" stroke-width="1.5"/></svg>', label: '$500K' },
      { amt: 1000000, icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="#fbbf24" opacity="0.15" stroke="#fbbf24" stroke-width="1.5"/><path d="M12 7v2m0 6v2m-3-7h1.5c.83 0 1.5.67 1.5 1.5S11.33 13 10.5 13H12h1.5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5H12" stroke="#fbbf24" stroke-width="1.3" stroke-linecap="round"/></svg>', label: '$1M' }
    ];
    var mc = document.getElementById('milestones-container');
    mc.innerHTML = '';
    milestones.forEach(function(m, mi) {
      var hit = null;
      for (var j = 0; j < data.length; j++) {
        if (data[j].balance >= m.amt) { hit = data[j]; break; }
      }
      var div = document.createElement('div');
      div.className = 'mill-milestone' + (hit ? ' reached' : '');
      div.innerHTML = '<div class="mill-milestone-icon">' + m.icon + '</div>' +
        '<div class="mill-milestone-amt">' + m.label + '</div>' +
        '<div class="mill-milestone-age">' + (hit ? 'Age ' + hit.age + ' (' + hit.year + ' yrs)' : 'Not reached') + '</div>';
      mc.appendChild(div);
      setTimeout(function() { div.classList.add('show'); }, 100 + mi * 120);
      if (hit) {
        setTimeout(function() { div.classList.add('celebrate'); }, 400 + mi * 200);
      }
    });

    // Chart
    renderChart(data);

    // Insight
    var insightEl = document.getElementById('result-insight');
    var lastEntry = hitEntry || data[data.length - 1];
    var totalContrib = lastEntry.totalContributions;
    var totalBal = lastEntry.balance;
    var growthPct = totalBal > 0 ? Math.round(((totalBal - totalContrib) / totalBal) * 100) : 0;

    var insight = '<strong>' + growthPct + '% of your balance comes from investment growth</strong>, not your contributions. ';
    if (savingsRate <= 6) {
      var diff = yearsToMillion(salary, debt, startAge, savingsRate, annualReturn) - yearsToMillion(salary, debt, startAge, 20, annualReturn);
      if (diff > 0) {
        insight += 'At the average savings rate, you\'re leaving time on the table. Moving to 20% would shave <strong>' + diff + ' years</strong> off your timeline.';
      } else {
        insight += 'Even at a low savings rate, your income advantage helps — but a higher rate would build wealth faster.';
      }
    } else if (!hitEntry) {
      insight += 'At current rates, $1M isn\'t reached within 60 years. Consider higher returns or increasing your savings rate.';
    } else if (years > 30) {
      insight += 'Increasing your savings rate or choosing higher-return investments could significantly accelerate your path.';
    } else {
      insight += 'Compound growth is doing the heavy lifting — this is what starting early and staying consistent looks like.';
    }
    insightEl.innerHTML = insight;
  });

  function renderChart(data) {
    var chart = document.getElementById('wealth-chart');
    chart.innerHTML = '';

    // Filter to ~30 bars max
    var maxBars = 30;
    var step = Math.max(1, Math.floor(data.length / maxBars));
    var filtered = [];
    for (var i = 0; i < data.length; i++) {
      if (i % step === 0 || i === data.length - 1) filtered.push(data[i]);
    }

    var maxVal = 0;
    for (var k = 0; k < filtered.length; k++) {
      if (filtered[k].balance > maxVal) maxVal = filtered[k].balance;
    }
    maxVal = Math.max(maxVal, 1000000);

    var chartH = 214;

    // Million line
    var linePos = Math.min((1000000 / maxVal) * chartH, chartH);
    var line = document.createElement('div');
    line.className = 'mill-chart-million-line';
    line.style.bottom = (26 + linePos) + 'px';
    line.innerHTML = '<span class="mill-chart-million-label">$1M</span>';
    chart.appendChild(line);

    filtered.forEach(function(d, idx) {
      var group = document.createElement('div');
      group.className = 'mill-chart-bar-group';

      var h = Math.max((d.balance / maxVal) * chartH, 2);
      var contribH = d.totalContributions > 0 ? Math.max((d.totalContributions / maxVal) * chartH, 1) : 0;
      var growthH = Math.max(h - contribH, 0);

      var bar = document.createElement('div');
      bar.className = 'mill-chart-bar';
      bar.style.height = '0px';

      var contribPart = document.createElement('div');
      contribPart.className = 'contrib-part';
      contribPart.style.height = '0px';

      var growthPart = document.createElement('div');
      growthPart.className = 'growth-part';
      growthPart.style.height = '0px';

      bar.appendChild(growthPart);
      bar.appendChild(contribPart);

      // Label (show every few)
      var showLabel = idx === 0 || idx === filtered.length - 1 || idx % Math.ceil(filtered.length / 8) === 0;
      if (showLabel) {
        var label = document.createElement('div');
        label.className = 'mill-chart-bar-label';
        label.textContent = d.age;
        group.appendChild(label);
      }

      var tooltip = document.createElement('div');
      tooltip.className = 'mill-chart-tooltip';
      tooltip.textContent = 'Age ' + d.age + ': ' + fmtFull(d.balance);

      group.appendChild(tooltip);
      group.appendChild(bar);
      chart.appendChild(group);

      setTimeout(function() {
        bar.style.height = h + 'px';
        contribPart.style.height = Math.min(contribH, h) + 'px';
        growthPart.style.height = growthH + 'px';
      }, 60 + idx * 35);
    });
  }

  // COMPARISON
  document.getElementById('compare-btn').addEventListener('click', function() {
    var ia = parseInt(compareA.value);
    var ib = parseInt(compareB.value);
    if (isNaN(ia) || isNaN(ib)) return;
    var pa = PROFESSIONS[ia];
    var pb = PROFESSIONS[ib];
    var rate = 20, ret = 10.3;

    var yrsA = yearsToMillion(pa.salary, pa.debt, pa.startAge, rate, ret);
    var yrsB = yearsToMillion(pb.salary, pb.debt, pb.startAge, rate, ret);

    var results = document.getElementById('compare-results');
    results.style.display = 'block';

    function renderCard(id, p, yrs, isWinner, otherYrs) {
      var card = document.getElementById(id);
      var ageAt = p.startAge + yrs;
      var diff = Math.abs(yrsA - yrsB);
      card.innerHTML =
        '<h3>' + p.name + '</h3>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Salary</span><span class="mill-compare-stat-val">' + fmt(p.salary) + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Student Debt</span><span class="mill-compare-stat-val">' + fmt(p.debt) + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Career Starts</span><span class="mill-compare-stat-val">Age ' + p.startAge + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">$1M Reached</span><span class="mill-compare-stat-val">' + (yrs < 60 ? 'Age ' + ageAt : '80+') + '</span></div>' +
        '<div class="mill-compare-stat"><span class="mill-compare-stat-label">Years to $1M</span><span class="mill-compare-stat-val">' + (yrs < 60 ? yrs + ' years' : '60+') + '</span></div>' +
        '<div class="mill-compare-winner ' + (isWinner ? 'is-winner' : 'is-loser') + '">' +
        (isWinner ? 'Reaches $1M first!' : (diff > 0 ? diff + ' years behind' : 'Tied!')) + '</div>';
    }

    var winA = yrsA <= yrsB;
    renderCard('compare-card-a', pa, yrsA, winA, yrsB);
    renderCard('compare-card-b', pb, yrsB, !winA, yrsA);

    // Race bars
    var race = document.getElementById('compare-race');
    var maxYrs = Math.max(yrsA, yrsB, 1);
    race.innerHTML =
      '<div class="mill-race-label">Timeline to $1M (20% savings, S&P 500 returns)</div>' +
      '<div class="mill-race-track"><div class="mill-race-bar bar-a" style="width: 0%">' + pa.name + ' — ' + yrsA + ' yrs</div></div>' +
      '<div class="mill-race-track"><div class="mill-race-bar bar-b" style="width: 0%">' + pb.name + ' — ' + yrsB + ' yrs</div></div>';

    setTimeout(function() {
      race.querySelector('.bar-a').style.width = Math.max(Math.round((yrsA / maxYrs) * 100), 25) + '%';
      race.querySelector('.bar-b').style.width = Math.max(Math.round((yrsB / maxYrs) * 100), 25) + '%';
    }, 100);
  });

  // RANKINGS
  function buildRankings() {
    var rate = 20, ret = 10.3;
    var ranked = PROFESSIONS.map(function(p) {
      var yrs = yearsToMillion(p.salary, p.debt, p.startAge, rate, ret);
      return {
        name: p.name,
        salary: p.salary,
        debt: p.debt,
        startAge: p.startAge,
        years: yrs,
        millAge: p.startAge + yrs
      };
    }).sort(function(a, b) { return a.years - b.years; });

    var table = document.getElementById('rankings-table');
    table.innerHTML = '<div class="mill-rank-row rank-header">' +
      '<div>#</div><div>Profession</div><div class="mill-rank-salary">Salary</div>' +
      '<div class="mill-rank-debt">Debt</div><div class="mill-rank-start">Start</div>' +
      '<div class="mill-rank-years">Years</div></div>';

    ranked.forEach(function(p, i) {
      var row = document.createElement('div');
      row.className = 'mill-rank-row';
      row.innerHTML =
        '<div class="mill-rank-num">' + (i + 1) + '</div>' +
        '<div class="mill-rank-name">' + p.name + '</div>' +
        '<div class="mill-rank-salary">' + fmt(p.salary) + '</div>' +
        '<div class="mill-rank-debt">' + fmt(p.debt) + '</div>' +
        '<div class="mill-rank-start">' + p.startAge + '</div>' +
        '<div class="mill-rank-years">' + (p.years < 60 ? p.years + ' yrs' : '60+') + '</div>';
      table.appendChild(row);
    });

    // Hero stats
    document.getElementById('hero-fastest').textContent = ranked[0].name.split(' ')[0] + ' (' + ranked[0].years + ' yrs)';
    document.getElementById('hero-slowest').textContent = ranked[ranked.length - 1].name.split(' ')[0] + ' (' + ranked[ranked.length - 1].years + ' yrs)';
  }

  buildRankings();

  // Auto-trigger comparison on load
  document.getElementById('compare-btn').click();
})();
</script>
