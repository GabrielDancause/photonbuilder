<script is:inline>
  const PROFESSIONS = {
    software_engineer: { name: 'Software Engineer', salary: 130000, debt: 37000, startAge: 22 },
    doctor: { name: 'Doctor (MD)', salary: 229000, debt: 215000, startAge: 30 },
    nurse: { name: 'Nurse (RN)', salary: 86000, debt: 47000, startAge: 24 },
    teacher: { name: 'Teacher', salary: 62000, debt: 55000, startAge: 23 },
    electrician: { name: 'Electrician', salary: 65000, debt: 5000, startAge: 20 },
    plumber: { name: 'Plumber', salary: 63000, debt: 3000, startAge: 19 },
    accountant: { name: 'Accountant', salary: 83000, debt: 42000, startAge: 22 },
    marketing_manager: { name: 'Marketing Manager', salary: 140000, debt: 45000, startAge: 23 },
    pharmacist: { name: 'Pharmacist', salary: 132000, debt: 170000, startAge: 26 },
    real_estate_agent: { name: 'Real Estate Agent', salary: 56000, debt: 30000, startAge: 25 },
    lawyer: { name: 'Lawyer', salary: 145000, debt: 165000, startAge: 26 },
    data_scientist: { name: 'Data Scientist', salary: 108000, debt: 40000, startAge: 23 },
    mechanic: { name: 'Mechanic', salary: 48000, debt: 5000, startAge: 19 },
    dental_hygienist: { name: 'Dental Hygienist', salary: 87000, debt: 55000, startAge: 22 }
  };

  let currentMode = 'profession';

  function switchMode(mode) {
    currentMode = mode;
    document.getElementById('tab-profession').classList.toggle('active', mode === 'profession');
    document.getElementById('tab-custom').classList.toggle('active', mode === 'custom');
    document.getElementById('profession-mode').style.display = mode === 'profession' ? 'flex' : 'none';
    document.getElementById('custom-mode').style.display = mode === 'custom' ? 'flex' : 'none';
  }

  function fillFromProfession() {
    const key = document.getElementById('prof-select').value;
    if (!key) return;
    const p = PROFESSIONS[key];
    document.getElementById('prof-salary').value = '$' + p.salary.toLocaleString();
    document.getElementById('prof-debt').value = '$' + p.debt.toLocaleString();
    document.getElementById('prof-start').value = 'Age ' + p.startAge;
  }

  function updateRateDisplay() {
    document.getElementById('rate-display').textContent = document.getElementById('savings-rate').value + '%';
  }

  function updateReturnDisplay() {
    const sel = document.getElementById('return-rate');
    document.getElementById('return-display').textContent = sel.options[sel.selectedIndex].text;
  }

  function fmt(n) {
    if (n >= 1000000) return '$' + (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return '$' + Math.round(n / 1000).toLocaleString() + 'K';
    return '$' + Math.round(n).toLocaleString();
  }

  function simulate(salary, startAge, debt, savingsRate, annualReturn, maxYears) {
    const loanRate = 0.065;
    const loanTerm = 10;
    const monthlyLoanPayment = debt > 0 ? (debt * (loanRate/12)) / (1 - Math.pow(1 + loanRate/12, -loanTerm*12)) : 0;
    const annualLoanPayment = monthlyLoanPayment * 12;

    let balance = -debt;
    const data = [{ age: startAge, balance: balance, contributed: 0, year: 0 }];
    let totalContributed = 0;
    const milestones = {};
    const targets = [100000, 250000, 500000, 1000000];

    for (let yr = 1; yr <= maxYears; yr++) {
      const age = startAge + yr;
      let annualSavings = salary * savingsRate;
      if (yr <= loanTerm && debt > 0) {
        annualSavings = Math.max(0, annualSavings - annualLoanPayment);
      }
      // Debt payoff: after loan term, balance gets a boost
      if (yr <= loanTerm && debt > 0) {
        // Still paying off loan, invest what's left
      }

      balance = balance + annualSavings;
      if (balance > 0) {
        balance = balance * (1 + annualReturn);
      }
      totalContributed += annualSavings;

      data.push({ age, balance: Math.round(balance), contributed: Math.round(totalContributed), year: yr });

      for (const t of targets) {
        if (!milestones[t] && balance >= t) {
          milestones[t] = { age, years: yr };
        }
      }
      if (balance >= 1000000 && !milestones['done']) {
        milestones['done'] = true;
      }
    }
    return { data, milestones, totalContributed };
  }

  function runCalculation() {
    let salary, startAge, debt, currentSavings = 0;

    if (currentMode === 'profession') {
      const key = document.getElementById('prof-select').value;
      if (!key) { alert('Please select a profession first.'); return; }
      const p = PROFESSIONS[key];
      salary = p.salary;
      startAge = p.startAge;
      debt = p.debt;
    } else {
      salary = parseInt(document.getElementById('custom-salary').value) || 75000;
      startAge = parseInt(document.getElementById('custom-age').value) || 25;
      debt = parseInt(document.getElementById('custom-debt').value) || 0;
      currentSavings = parseInt(document.getElementById('custom-savings').value) || 0;
    }

    const savingsRate = parseInt(document.getElementById('savings-rate').value) / 100;
    const annualReturn = parseFloat(document.getElementById('return-rate').value);
    const maxYears = 45;

    const result = simulate(salary, startAge, debt, savingsRate, annualReturn, maxYears);

    // Show results
    document.getElementById('results-section').style.display = 'block';

    // Summary
    const ms1M = result.milestones[1000000];
    const summaryEl = document.getElementById('result-summary');
    if (ms1M) {
      summaryEl.innerHTML = `
        <div class="big-number">Age ${ms1M.age}</div>
        <div class="big-label">You'll hit $1,000,000 in <strong>${ms1M.years} years</strong></div>
        <div class="sub-stats">
          <div class="sub-stat"><div class="ss-val">${fmt(salary)}</div><div class="ss-label">Annual Salary</div></div>
          <div class="sub-stat"><div class="ss-val">${Math.round(savingsRate*100)}%</div><div class="ss-label">Savings Rate</div></div>
          <div class="sub-stat"><div class="ss-val">${fmt(salary * savingsRate)}/yr</div><div class="ss-label">Annual Investment</div></div>
          <div class="sub-stat"><div class="ss-val">${(annualReturn*100).toFixed(1)}%</div><div class="ss-label">Annual Return</div></div>
        </div>`;
    } else {
      const finalBal = result.data[result.data.length - 1].balance;
      summaryEl.innerHTML = `
        <div class="big-number">${fmt(finalBal)}</div>
        <div class="big-label">Projected net worth after ${maxYears} years (age ${startAge + maxYears})</div>
        <div class="sub-stats">
          <div class="sub-stat"><div class="ss-val">${fmt(salary)}</div><div class="ss-label">Annual Salary</div></div>
          <div class="sub-stat"><div class="ss-val">${Math.round(savingsRate*100)}%</div><div class="ss-label">Savings Rate</div></div>
          <div class="sub-stat"><div class="ss-val">${fmt(salary * savingsRate)}/yr</div><div class="ss-label">Annual Investment</div></div>
          <div class="sub-stat"><div class="ss-val">${(annualReturn*100).toFixed(1)}%</div><div class="ss-label">Annual Return</div></div>
        </div>
        <p style="margin-top:1rem;color:var(--text-secondary);font-size:0.9rem">With these parameters, $1M isn't reached within ${maxYears} years. Try increasing your savings rate!</p>`;
    }

    // Milestones
    const msRow = document.getElementById('milestones-row');
    const msTargets = [
      { amount: 100000, label: '$100K', emoji: '🎯' },
      { amount: 250000, label: '$250K', emoji: '🔥' },
      { amount: 500000, label: '$500K', emoji: '🚀' },
      { amount: 1000000, label: '$1M', emoji: '🏆' }
    ];
    msRow.innerHTML = msTargets.map(t => {
      const ms = result.milestones[t.amount];
      const reached = !!ms;
      return `<div class="ms-card ${reached ? 'reached celebrate' : ''}">
        <div class="ms-confetti">${reached ? t.emoji : ''}</div>
        <div class="ms-amount">${t.label}</div>
        <div class="ms-age">${ms ? 'Age ' + ms.age : '—'}</div>
        <div class="ms-years">${ms ? ms.years + ' years' : 'Not reached'}</div>
      </div>`;
    }).join('');

    // Chart
    renderChart(result.data);

    // Scroll to results
    document.getElementById('results-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function renderChart(data) {
    const container = document.getElementById('chart-container');
    // Sample data points (show every 2-3 years for readability)
    const step = data.length > 30 ? 3 : data.length > 20 ? 2 : 1;
    const sampled = data.filter((d, i) => i === 0 || i === data.length - 1 || i % step === 0);

    const maxVal = Math.max(...sampled.map(d => Math.max(d.balance, 0)));
    const chartMax = Math.max(maxVal * 1.1, 100000);

    // Y-axis labels
    const yLabels = [];
    const ySteps = 5;
    for (let i = ySteps; i >= 0; i--) {
      yLabels.push(fmt(Math.round(chartMax * i / ySteps)));
    }

    // $1M line position
    const millionPct = Math.min((1000000 / chartMax) * 100, 100);
    const showMillionLine = chartMax >= 1000000;

    let html = `<div class="chart-y-axis">${yLabels.map(l => `<span class="chart-y-label">${l}</span>`).join('')}</div>`;

    if (showMillionLine) {
      html += `<div class="chart-million-line" style="bottom:calc(2.5rem + ${millionPct}% * (100% - 4rem) / 100)"><span class="chart-million-label">$1M</span></div>`;
    }

    html += '<div class="chart-bars" style="margin-left:3.5rem">';
    sampled.forEach((d, i) => {
      const totalH = Math.max((Math.max(d.balance, 0) / chartMax) * 100, 0.5);
      const contribH = Math.max((Math.max(d.contributed, 0) / chartMax) * 100, 0);
      const growthH = totalH;
      html += `<div class="chart-bar-group">
        <div class="chart-bar" style="height:${totalH}%;background:rgba(74,143,231,0.15)">
          <div class="growth-fill" style="height:100%"></div>
          <div class="contrib-fill" style="height:${contribH > 0 ? (contribH/totalH)*100 : 0}%"></div>
        </div>
        <div class="chart-bar-label">${d.age}</div>
      </div>`;
    });
    html += '</div>';
    container.innerHTML = html;

    // Re-apply million line position using actual pixel math
    if (showMillionLine) {
      requestAnimationFrame(() => {
        const chartBars = container.querySelector('.chart-bars');
        if (chartBars) {
          const barsHeight = chartBars.offsetHeight;
          const linePos = (1000000 / chartMax) * barsHeight;
          const line = container.querySelector('.chart-million-line');
          if (line) {
            line.style.bottom = '';
            line.style.top = (container.offsetHeight - 40 - linePos) + 'px';
          }
        }
      });
    }
  }

  // Comparison
  function runComparison() {
    const keyA = document.getElementById('compare-a').value;
    const keyB = document.getElementById('compare-b').value;
    const pA = PROFESSIONS[keyA];
    const pB = PROFESSIONS[keyB];
    const savingsRate = 0.20;
    const annualReturn = 0.103;

    const resA = simulate(pA.salary, pA.startAge, pA.debt, savingsRate, annualReturn, 45);
    const resB = simulate(pB.salary, pB.startAge, pB.debt, savingsRate, annualReturn, 45);

    const msA = resA.milestones[1000000];
    const msB = resB.milestones[1000000];

    const resultsEl = document.getElementById('compare-results');
    resultsEl.innerHTML = `
      <div class="compare-card">
        <h4>${pA.name}</h4>
        <div class="cc-row"><span>Salary</span><span class="cc-val">${fmt(pA.salary)}</span></div>
        <div class="cc-row"><span>Start Age</span><span class="cc-val">${pA.startAge}</span></div>
        <div class="cc-row"><span>Student Debt</span><span class="cc-val">${fmt(pA.debt)}</span></div>
        <div class="cc-row"><span>Annual Investment</span><span class="cc-val">${fmt(pA.salary * savingsRate)}/yr</span></div>
        <div class="cc-row"><span>Millionaire At</span><span class="cc-highlight">${msA ? 'Age ' + msA.age : 'Not in 45yr'}</span></div>
      </div>
      <div class="compare-card">
        <h4>${pB.name}</h4>
        <div class="cc-row"><span>Salary</span><span class="cc-val">${fmt(pB.salary)}</span></div>
        <div class="cc-row"><span>Start Age</span><span class="cc-val">${pB.startAge}</span></div>
        <div class="cc-row"><span>Student Debt</span><span class="cc-val">${fmt(pB.debt)}</span></div>
        <div class="cc-row"><span>Annual Investment</span><span class="cc-val">${fmt(pB.salary * savingsRate)}/yr</span></div>
        <div class="cc-row"><span>Millionaire At</span><span class="cc-highlight">${msB ? 'Age ' + msB.age : 'Not in 45yr'}</span></div>
      </div>`;

    // Verdict
    let verdict = '';
    if (msA && msB) {
      const diff = msB.age - msA.age;
      if (diff > 0) {
        verdict = `<strong>${pA.name}</strong> reaches $1M <strong>${diff} years earlier</strong> (age ${msA.age} vs ${msB.age}). ${pA.salary < pB.salary ? `Despite earning ${fmt(pB.salary - pA.salary)} less per year, starting ${pB.startAge - pA.startAge} years earlier ${pA.debt < pB.debt ? 'with far less debt ' : ''}gives compound interest more time to work.` : `Higher salary and ${pA.debt < pB.debt ? 'lower debt' : 'similar debt'} means faster accumulation.`}`;
      } else if (diff < 0) {
        verdict = `<strong>${pB.name}</strong> reaches $1M <strong>${Math.abs(diff)} years earlier</strong> (age ${msB.age} vs ${msA.age}). ${pB.salary < pA.salary ? `Despite earning less, starting earlier gives compound interest more time.` : `Higher salary overcomes the late start.`}`;
      } else {
        verdict = `Both reach $1M at <strong>age ${msA.age}</strong> — a dead heat! Different paths, same destination.`;
      }
    } else {
      verdict = 'One or both professions don\'t reach $1M within 45 years at these parameters. Try adjusting the savings rate.';
    }

    resultsEl.innerHTML += `<div class="compare-verdict">${verdict}</div>`;

    // Bar chart
    const chartEl = document.getElementById('compare-chart');
    const maxAge = Math.max(msA ? msA.age : 70, msB ? msB.age : 70);
    const barMaxAge = maxAge + 5;
    chartEl.innerHTML = `
      <div class="compare-bar-row">
        <span class="compare-bar-label">${pA.name}</span>
        <div class="compare-bar-track">
          <div class="compare-bar-fill" style="width:${msA ? (msA.age/barMaxAge)*100 : 100}%;background:linear-gradient(90deg,#4a8fe7,#6366f1)">${msA ? 'Age ' + msA.age + ' (' + msA.years + 'yr)' : 'Not reached'}</div>
        </div>
      </div>
      <div class="compare-bar-row">
        <span class="compare-bar-label">${pB.name}</span>
        <div class="compare-bar-track">
          <div class="compare-bar-fill" style="width:${msB ? (msB.age/barMaxAge)*100 : 100}%;background:linear-gradient(90deg,#10b981,#059669)">${msB ? 'Age ' + msB.age + ' (' + msB.years + 'yr)' : 'Not reached'}</div>
        </div>
      </div>`;
  }

  // Build professions table
  function buildTable() {
    const savingsRate = 0.20;
    const annualReturn = 0.103;
    const rows = [];

    for (const [key, p] of Object.entries(PROFESSIONS)) {
      const res = simulate(p.salary, p.startAge, p.debt, savingsRate, annualReturn, 50);
      const ms = res.milestones[1000000];
      rows.push({
        name: p.name,
        salary: p.salary,
        startAge: p.startAge,
        debt: p.debt,
        years: ms ? ms.years : 999,
        millionaireAge: ms ? ms.age : null
      });
    }

    rows.sort((a, b) => a.years - b.years);

    const tbody = document.getElementById('prof-tbody');
    tbody.innerHTML = rows.map((r, i) => `
      <tr>
        <td class="rank-cell">${r.years < 999 ? i + 1 : '—'}</td>
        <td><strong>${r.name}</strong></td>
        <td>${fmt(r.salary)}</td>
        <td>${r.startAge}</td>
        <td>${fmt(r.debt)}</td>
        <td class="highlight-cell">${r.years < 999 ? r.years + ' years' : '50+ years'}</td>
        <td><strong>${r.millionaireAge ? 'Age ' + r.millionaireAge : '—'}</strong></td>
      </tr>`).join('');
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', function() {
    buildTable();
    runComparison();
  });
</script>