// Table
const tbody = document.getElementById('tbody');
const searchEl = document.getElementById('search');
const catFilter = document.getElementById('catFilter');
const typeFilter = document.getElementById('typeFilter');
const erFilterEl = document.getElementById('erFilter');

let sortKey = 'aum', sortDir = -1;

function erClass(v){return v<=0.04?'er-low':v<=0.1?'er-mid':'er-high'}
function retClass(v){return v==null?'':v>=0?'pos':'neg'}

function renderTable(){
  const q = searchEl.value.toLowerCase();
  const cat = catFilter.value;
  const typ = typeFilter.value;
  const erf = erFilterEl.value;
  let filtered = FUNDS.filter(f=>{
    if(q && !f.ticker.toLowerCase().includes(q) && !f.name.toLowerCase().includes(q)) return false;
    if(cat && f.category!==cat) return false;
    if(typ && f.type!==typ) return false;
    if(erf){const [lo,hi]=erf.split('-').map(Number);if(f.er<lo||f.er>=hi) return false;}
    return true;
  });
  filtered.sort((a,b)=>{
    let va=a[sortKey],vb=b[sortKey];
    if(va==null) return 1;if(vb==null) return -1;
    if(typeof va==='string') return va.localeCompare(vb)*sortDir;
    return (va-vb)*sortDir;
  });
  tbody.innerHTML = filtered.map(f=>`<tr>
    <td class="ticker">${f.ticker}</td>
    <td>${f.name}</td>
    <td>${f.category}</td>
    <td class="num ${erClass(f.er)}">${f.er.toFixed(f.er<0.1?3:2)}%</td>
    <td class="num">$${f.aum}</td>
    <td>${f.minInvest}</td>
    <td class="num ${retClass(f.ret5y)}">${f.ret5y!=null?f.ret5y.toFixed(1)+'%':'—'}</td>
    <td class="num">${f.divYield.toFixed(1)}%</td>
    <td class="${f.type==='ETF'?'type-etf':'type-mutual'}">${f.type}</td>
  </tr>`).join('');
}

document.querySelectorAll('th[data-key]').forEach(th=>{
  th.addEventListener('click',()=>{
    const key=th.dataset.key;
    if(sortKey===key) sortDir*=-1; else {sortKey=key;sortDir=th.dataset.type==='num'?-1:1;}
    document.querySelectorAll('th').forEach(t=>t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir===1?'sorted-asc':'sorted-desc');
    renderTable();
  });
});
searchEl.addEventListener('input',renderTable);
catFilter.addEventListener('change',renderTable);
typeFilter.addEventListener('change',renderTable);
erFilterEl.addEventListener('change',renderTable);
renderTable();

// Head-to-head
