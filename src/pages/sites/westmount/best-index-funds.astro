  const opt=`<option value="${i}">${f.ticker}</option>`;
  h2h1.innerHTML+=opt;h2h2.innerHTML+=opt;h2h3.innerHTML+=`<option value="${i}">${f.ticker}</option>`;
});
h2h1.value="0";h2h2.value="5";

document.getElementById('h2hBtn').addEventListener('click',()=>{
  const picks=[FUNDS[h2h1.value],FUNDS[h2h2.value]];
  if(h2h3.value) picks.push(FUNDS[h2h3.value]);
  const metrics=[
    {label:"Category",key:"category",fmt:v=>v,best:null},
    {label:"Expense Ratio",key:"er",fmt:v=>v.toFixed(v<0.1?3:2)+"%",best:"min"},
    {label:"AUM",key:"aum",fmt:v=>"$"+v+"B",best:"max"},
    {label:"Min. Investment",key:"minInvest",fmt:v=>v,best:null},
    {label:"Holdings",key:"holdings",fmt:v=>v.toLocaleString(),best:"max"},
    {label:"5-Year Return",key:"ret5y",fmt:v=>v!=null?v.toFixed(1)+"%":"—",best:"max"},
    {label:"3-Year Return",key:"ret3y",fmt:v=>v!=null?v.toFixed(1)+"%":"—",best:"max"},
    {label:"1-Year Return",key:"ret1y",fmt:v=>v!=null?v.toFixed(1)+"%":"—",best:"max"},
    {label:"Dividend Yield",key:"divYield",fmt:v=>v.toFixed(1)+"%",best:"max"},
    {label:"Type",key:"type",fmt:v=>v,best:null},
    {label:"Index Tracked",key:"index",fmt:v=>v,best:null},
    {label:"Issuer",key:"issuer",fmt:v=>v,best:null},
    {label:"Inception",key:"inception",fmt:v=>v,best:"min"}
  ];
  let html=`<div class="comparison-wrap"><table><thead><tr><th>Metric</th>${picks.map(p=>`<th>${p.ticker}</th>`).join('')}</tr></thead><tbody>`;
  metrics.forEach(m=>{
    const vals=picks.map(p=>p[m.key]);
    let bestIdx=-1;
    if(m.best&&vals.every(v=>v!=null)){
      const numVals=vals.map(Number);
      bestIdx=m.best==='max'?numVals.indexOf(Math.max(...numVals)):numVals.indexOf(Math.min(...numVals));
    }
    const isHighlight=["er","ret5y","divYield"].includes(m.key);
    html+=`<tr${isHighlight?' class="highlight-row"':''}>`;
    html+=`<td><strong>${m.label}</strong></td>`;
    picks.forEach((p,i)=>{
      html+=`<td class="${i===bestIdx?'winner':''}">${m.fmt(p[m.key])}</td>`;
    });
    html+=`</tr>`;
  });
  html+=`</tbody></table></div>`;
  document.getElementById('h2hResult').innerHTML=html;
});
document.getElementById('h2hBtn').click();

