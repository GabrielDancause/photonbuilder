// Table rendering
const tbody = document.getElementById('tbody');
const searchEl = document.getElementById('search');
const stratFilter = document.getElementById('stratFilter');
const yieldFilter = document.getElementById('yieldFilter');
const erFilter = document.getElementById('erFilter');

let sortKey = 'yield', sortDir = -1;

function retClass(v){return v==null?'':v>=0?'pos':'neg'}
function erClass(v){return v<=0.1?'er-low':v<=0.35?'er-mid':'er-high'}

function renderTable(){
  const q = searchEl.value.toLowerCase();
  const strat = stratFilter.value;
  const yr = yieldFilter.value;
  const erf = erFilter.value;
  let filtered = ETFS.filter(e=>{
    if(q && !e.ticker.toLowerCase().includes(q) && !e.name.toLowerCase().includes(q)) return false;
    if(strat && e.strategy!==strat) return false;
    if(yr){const [lo,hi]=yr.split('-').map(Number);if(e.yield<lo||e.yield>=hi) return false;}
    if(erf){const [lo,hi]=erf.split('-').map(Number);if(e.er<lo||e.er>=hi) return false;}
    return true;
  });
  filtered.sort((a,b)=>{
    let va=a[sortKey],vb=b[sortKey];
    if(va==null) return 1;if(vb==null) return -1;
    if(typeof va==='string') return va.localeCompare(vb)*sortDir;
    return (va-vb)*sortDir;
  });
  tbody.innerHTML = filtered.map(e=>`<tr>
    <td class="ticker">${e.ticker}</td>
    <td>${e.name}</td>
    <td>${e.strategy}</td>
    <td class="num ${e.yield>=5?'yield-high':e.yield>=3?'yield-mid':''}">${e.yield.toFixed(1)}%</td>
    <td class="num ${erClass(e.er)}">${e.er.toFixed(2)}%</td>
    <td class="num">$${e.aum.toFixed(1)}</td>
    <td class="${e.freq==='Monthly'?'freq-monthly':'freq-quarterly'}">${e.freq}</td>
    <td class="num ${retClass(e.ret1y)}">${e.ret1y!=null?e.ret1y.toFixed(1)+'%':'—'}</td>
    <td class="num ${retClass(e.ret3y)}">${e.ret3y!=null?e.ret3y.toFixed(1)+'%':'—'}</td>
    <td class="num ${retClass(e.ret5y)}">${e.ret5y!=null?e.ret5y.toFixed(1)+'%':'—'}</td>
  </tr>`).join('');
}

document.querySelectorAll('th[data-key]').forEach(th=>{
  th.addEventListener('click',()=>{
    const key=th.dataset.key;
    if(sortKey===key) sortDir*=-1; else {sortKey=key;sortDir=th.dataset.type==='num'?-1:1;}
    document.querySelectorAll('th').forEach(t=>t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir===1?'sorted-asc':'sorted-desc');
    renderTable();
  });
});
searchEl.addEventListener('input',renderTable);
stratFilter.addEventListener('change',renderTable);
yieldFilter.addEventListener('change',renderTable);
erFilter.addEventListener('change',renderTable);
renderTable();

// Head-to-head
const h2h1=document.getElementById('h2h1'),h2h2=document.getElementById('h2h2'),h2h3=document.getElementById('h2h3');
ETFS.forEach((e,i)=>{
  const opt=`<option value="${i}">${e.ticker}</option>`;
  h2h1.innerHTML+=opt;h2h2.innerHTML+=opt;h2h3.innerHTML+=`<option value="${i}">${e.ticker}</option>`;
});
h2h1.value="0";h2h2.value="1";

document.getElementById('h2hBtn').addEventListener('click',()=>{
  const picks=[ETFS[h2h1.value],ETFS[h2h2.value]];
  if(h2h3.value) picks.push(ETFS[h2h3.value]);
  const metrics=[
    {label:"Dividend Yield",key:"yield",fmt:v=>v.toFixed(1)+"%",best:"max"},
    {label:"Expense Ratio",key:"er",fmt:v=>v.toFixed(2)+"%",best:"min"},
    {label:"AUM",key:"aum",fmt:v=>"$"+v.toFixed(1)+"B",best:"max"},
    {label:"Holdings",key:"holdings",fmt:v=>v.toLocaleString(),best:"max"},
    {label:"Distribution",key:"freq",fmt:v=>v,best:null},
    {label:"Strategy",key:"strategy",fmt:v=>v,best:null},
    {label:"1-Year Return",key:"ret1y",fmt:v=>v!=null?v.toFixed(1)+"%":"—",best:"max"},
    {label:"3-Year Ann.",key:"ret3y",fmt:v=>v!=null?v.toFixed(1)+"%":"—",best:"max"},
    {label:"5-Year Ann.",key:"ret5y",fmt:v=>v!=null?v.toFixed(1)+"%":"—",best:"max"},
    {label:"Inception",key:"inception",fmt:v=>v,best:"min"},
    {label:"Issuer",key:"issuer",fmt:v=>v,best:null},
    {label:"Index",key:"index",fmt:v=>v,best:null}
  ];
  let html=`<div class="comparison-wrap"><table><thead><tr><th>Metric</th>${picks.map(p=>`<th>${p.ticker}</th>`).join('')}</tr></thead><tbody>`;
  metrics.forEach(m=>{
    const vals=picks.map(p=>p[m.key]);
    let bestIdx=-1;
    if(m.best&&vals.every(v=>v!=null)){
      const numVals=vals.map(Number);
      bestIdx=m.best==='max'?numVals.indexOf(Math.max(...numVals)):numVals.indexOf(Math.min(...numVals));
      if(m.key==='er') bestIdx=numVals.indexOf(Math.min(...numVals));
    }
    const isHighlight=["yield","er","ret5y"].includes(m.key);
    html+=`<tr${isHighlight?' class="highlight-row"':''}>`;
    html+=`<td><strong>${m.label}</strong></td>`;
    picks.forEach((p,i)=>{
      html+=`<td class="${i===bestIdx?'winner':''}">${m.fmt(p[m.key])}</td>`;
    });
    html+=`</tr>`;
  });
  html+=`</tbody></table></div>`;
  document.getElementById('h2hResult').innerHTML=html;
});
