<script>
  function initGrahamCalculator() {
    const btn = document.getElementById('calculate-graham');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const epsInput = document.getElementById('graham-eps');
      const growthInput = document.getElementById('graham-growth');
      const yieldInput = document.getElementById('graham-yield');

      const eps = parseFloat(epsInput.value);
      const growth = parseFloat(growthInput.value);
      const currentYield = parseFloat(yieldInput.value);

      if (isNaN(eps) || isNaN(growth) || isNaN(currentYield) || currentYield === 0) {
        alert("Please enter valid positive numbers for all fields.");
        return;
      }

      // V = (EPS * (8.5 + 2g) * 4.4) / Y
      const intrinsicValue = (eps * (8.5 + 2 * growth) * 4.4) / currentYield;

      const resultBox = document.getElementById('graham-result');
      const valueDisplay = document.getElementById('graham-value-display');

      valueDisplay.textContent = "$" + intrinsicValue.toFixed(2);
      resultBox.classList.remove('hidden');
    });
  }

  // Initialize on direct load and on Astro View Transition page loads
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGrahamCalculator);
  } else {
    initGrahamCalculator();
  }

  document.addEventListener('astro:page-load', initGrahamCalculator);
</script>
