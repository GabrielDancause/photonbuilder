<script>
  function initCalculator() {
    const priceInput = document.getElementById('stockPrice');
    const epsInput = document.getElementById('earningsPerShare');
    const resultDisplay = document.getElementById('peResult');
    const analysisDisplay = document.getElementById('peAnalysis');

    if (!priceInput || !epsInput || !resultDisplay || !analysisDisplay) return;

    function calculatePE() {
      const price = parseFloat(priceInput.value) || 0;
      const eps = parseFloat(epsInput.value) || 0;

      if (eps <= 0) {
        resultDisplay.textContent = 'N/A';
        analysisDisplay.textContent = 'Earnings must be greater than zero to calculate a meaningful P/E ratio.';
        return;
      }

      const peRatio = price / eps;
      resultDisplay.textContent = peRatio.toFixed(2);

      let analysisText = `Investors are paying $${peRatio.toFixed(2)} for every $1 of earnings.`;

      if (peRatio < 15) {
        analysisText += ' This is generally considered a lower valuation, often seen in mature or slow-growing companies.';
      } else if (peRatio > 30) {
        analysisText += ' This is a higher valuation, suggesting investors expect significant future growth.';
      }

      analysisDisplay.textContent = analysisText;
    }

    priceInput.addEventListener('input', calculatePE);
    epsInput.addEventListener('input', calculatePE);

    // Initial calculation
    calculatePE();
  }

  // Run on load and after View Transitions
  document.addEventListener('DOMContentLoaded', initCalculator);
  document.addEventListener('astro:page-load', initCalculator);

  // Also run immediately in case it's late
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initCalculator();
  }
</script>

