---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tip Calculator | Calculate Gratuity & Split Bills Instantly",
  description: "Easily calculate the tip and split the bill among your party. Get real-time gratuity calculations, total bill amounts, and per-person cost breakdowns.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you calculate a tip?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate a tip, multiply the total bill amount by the desired tip percentage (as a decimal). For example, a 20% tip on a $50 bill is $50 × 0.20 = $10. The total cost is the original bill plus the tip."
      }
    },
    {
      "@type": "Question",
      "name": "What is the standard tip percentage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In the United States and Canada, the standard tip for good service at a sit-down restaurant is 15% to 20%. For exceptional service, 20% or more is customary."
      }
    },
    {
      "@type": "Question",
      "name": "Should you tip on the pre-tax or post-tax amount?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Etiquette experts generally agree that you should tip on the pre-tax subtotal. However, many people simply tip based on the final post-tax total for convenience."
      }
    },
    {
      "@type": "Question",
      "name": "How do you split a bill with a tip?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To split a bill, first calculate the total amount including the tip. Then, divide that total evenly by the number of people in your party."
      }
    },
    {
      "@type": "Question",
      "name": "Is it customary to tip for takeout orders?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "While not strictly required like dine-in service, leaving a 5% to 10% tip for takeout orders is a common and appreciated practice, especially for large or complicated orders."
      }
    }
  ]
});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/tip-calculator" schema={schema}>
  <div class="page-content">
    <h1>Tip Calculator</h1>
    <p class="intro-text">
      Whether you're dining out, splitting a bill with friends, or simply trying to quickly calculate the appropriate gratuity, this real-time tip calculator does the math for you. Simply enter your total bill, choose your tip percentage, and see the exact amount down to the penny.
    </p>

    <div class="calculator-card">
      <h3>Tip Calculator</h3>

      <div class="input-grid">
        <div class="input-group">
          <label for="billAmount">Bill Amount</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="billAmount" min="0" step="0.01" value="50.00" placeholder="0.00">
          </div>
        </div>

        <div class="input-group">
          <label for="tipPercentage">Tip Percentage</label>
          <div class="input-wrapper">
            <input type="number" id="tipPercentage" min="0" step="1" value="20">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="numberOfPeople">Split Between (People)</label>
          <div class="input-wrapper">
            <span class="prefix-icon">👥</span>
            <input type="number" id="numberOfPeople" min="1" step="1" value="1">
          </div>
        </div>
      </div>

      <div class="preset-buttons">
        <button type="button" class="preset-btn" data-value="15">15%</button>
        <button type="button" class="preset-btn" data-value="18">18%</button>
        <button type="button" class="preset-btn active" data-value="20">20%</button>
        <button type="button" class="preset-btn" data-value="25">25%</button>
      </div>

      <div class="results-grid">
        <div class="result-box">
          <span class="result-label">Tip Amount</span>
          <span class="result-value" id="resultTipAmount">$10.00</span>
        </div>
        <div class="result-box total-box">
          <span class="result-label">Total Bill</span>
          <span class="result-value" id="resultTotalAmount">$60.00</span>
        </div>
      </div>

      <div class="split-result-box" id="splitResultBox" style="display: none;">
        <span class="result-label">Per Person</span>
        <span class="result-value" id="resultPerPerson">$60.00</span>
        <span class="split-detail" id="splitDetailText">(includes $10.00 tip per person)</span>
      </div>
    </div>

    <h2>How to Calculate a Tip</h2>
    <p>
      Calculating the correct tip for a service doesn't have to be complicated. The mathematical formula for gratuity is straightforward:
    </p>

    <div class="highlight-box formula-box">
      <strong>Tip Formula:</strong>
      <code>Tip = Bill Amount × (Tip Percentage ÷ 100)</code>
    </div>

    <p>
      For example, if your dinner bill is <strong>$85.50</strong> and you want to leave a standard <strong>20% tip</strong> for excellent service, you convert the percentage to a decimal (0.20) and multiply:
    </p>

    <ul>
      <li>$85.50 × 0.20 = <strong>$17.10</strong> (Tip Amount)</li>
      <li>$85.50 + $17.10 = <strong>$102.60</strong> (Total Amount)</li>
    </ul>

    <h3>Splitting the Bill</h3>
    <p>
      When dining with a group, the easiest way to split the bill fairly is to calculate the total cost (including the total tip) first, and then divide that final number by the number of people in your party.
    </p>
    <div class="highlight-box formula-box">
      <strong>Split Formula:</strong>
      <code>Per Person = Total Amount ÷ Number of People</code>
    </div>

    <h2>Standard Tipping Etiquette</h2>
    <p>
      Tipping norms vary widely depending on the country and the type of service provided. In the United States and Canada, the hospitality industry heavily relies on tips to supplement wages.
    </p>
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Service Type</th>
            <th>Standard Tip Range</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Sit-Down Restaurant</td>
            <td>15% – 20%</td>
            <td>20%+ for exceptional service; 10% for poor service.</td>
          </tr>
          <tr>
            <td>Bartender</td>
            <td>15% – 20%</td>
            <td>Alternatively, $1-$2 per drink ordered.</td>
          </tr>
          <tr>
            <td>Food Delivery</td>
            <td>10% – 15%</td>
            <td>A minimum of $3-$5, especially in bad weather.</td>
          </tr>
          <tr>
            <td>Takeout / Pickup</td>
            <td>0% – 10%</td>
            <td>Not strictly required, but appreciated for large orders.</td>
          </tr>
          <tr>
            <td>Rideshare / Taxi</td>
            <td>15% – 20%</td>
            <td>Based on the total fare, assuming safe and clean service.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2>Pre-Tax vs. Post-Tax Tipping</h2>
    <p>
      A common debate is whether you should tip on the total bill before tax or after tax. According to traditional etiquette, <strong>you only need to tip on the pre-tax subtotal</strong>. You are paying for the service provided on the food and drink, not tipping the government on taxes.
    </p>
    <p>
      However, in practice, many modern POS systems (like those digital screens at coffee shops or the printed receipts at restaurants) automatically calculate suggested tip percentages based on the final, post-tax total. While it is perfectly acceptable to calculate your own tip based on the subtotal, many diners simply use the final total for mathematical convenience.
    </p>
    <h2>Frequently Asked Questions</h2>
    <div class="faq-section">
      <details class="faq-item">
        <summary>
          <h3>How do you calculate a tip?</h3>
          <span class="icon">+</span>
        </summary>
        <p>
          To calculate a tip, multiply the total bill amount by the desired tip percentage (as a decimal). For example, a 20% tip on a $50 bill is $50 × 0.20 = $10. The total cost is the original bill plus the tip.
        </p>
      </details>

      <details class="faq-item">
        <summary>
          <h3>What is the standard tip percentage?</h3>
          <span class="icon">+</span>
        </summary>
        <p>
          In the United States and Canada, the standard tip for good service at a sit-down restaurant is 15% to 20%. For exceptional service, 20% or more is customary.
        </p>
      </details>

      <details class="faq-item">
        <summary>
          <h3>Should you tip on the pre-tax or post-tax amount?</h3>
          <span class="icon">+</span>
        </summary>
        <p>
          Etiquette experts generally agree that you should tip on the pre-tax subtotal. However, many people simply tip based on the final post-tax total for convenience.
        </p>
      </details>

      <details class="faq-item">
        <summary>
          <h3>How do you split a bill with a tip?</h3>
          <span class="icon">+</span>
        </summary>
        <p>
          To split a bill, first calculate the total amount including the tip. Then, divide that total evenly by the number of people in your party.
        </p>
      </details>

      <details class="faq-item">
        <summary>
          <h3>Is it customary to tip for takeout orders?</h3>
          <span class="icon">+</span>
        </summary>
        <p>
          While not strictly required like dine-in service, leaving a 5% to 10% tip for takeout orders is a common and appreciated practice, especially for large or complicated orders.
        </p>
      </details>
    </div>
    <script>
      function initCalculator() {
        const calculatorCard = document.querySelector('.calculator-card');
        if (!calculatorCard || calculatorCard.dataset.initialized) return;
        calculatorCard.dataset.initialized = 'true';

        // Get inputs
        const billAmountInput = document.getElementById('billAmount');
        const tipPercentageInput = document.getElementById('tipPercentage');
        const numberOfPeopleInput = document.getElementById('numberOfPeople');
        const presetButtons = document.querySelectorAll('.preset-btn');

        // Get outputs
        const resultTipAmount = document.getElementById('resultTipAmount');
        const resultTotalAmount = document.getElementById('resultTotalAmount');
        const splitResultBox = document.getElementById('splitResultBox');
        const resultPerPerson = document.getElementById('resultPerPerson');
        const splitDetailText = document.getElementById('splitDetailText');

        function formatCurrency(num) {
          return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD'
          }).format(num);
        }

        function calculateTip() {
          const billValue = parseFloat(billAmountInput.value) || 0;
          const tipPercent = parseFloat(tipPercentageInput.value) || 0;
          let numPeople = parseInt(numberOfPeopleInput.value) || 1;

          // Validate negative numbers
          if (billValue < 0 || tipPercent < 0 || numPeople < 1) {
            numPeople = Math.max(1, numPeople); // Enforce at least 1 person
          }

          const tipAmount = billValue * (tipPercent / 100);
          const totalAmount = billValue + tipAmount;

          // Update UI
          resultTipAmount.textContent = formatCurrency(tipAmount);
          resultTotalAmount.textContent = formatCurrency(totalAmount);

          if (numPeople > 1) {
            const perPersonTotal = totalAmount / numPeople;
            const perPersonTip = tipAmount / numPeople;

            resultPerPerson.textContent = formatCurrency(perPersonTotal);
            splitDetailText.textContent = `(includes ${formatCurrency(perPersonTip)} tip per person)`;
            splitResultBox.style.display = 'flex';
          } else {
            splitResultBox.style.display = 'none';
          }
        }

        // Add event listeners to inputs
        const inputs = [billAmountInput, tipPercentageInput, numberOfPeopleInput];
        inputs.forEach(input => {
          if (input) {
            input.addEventListener('input', calculateTip);
            // Also recalculate on change to catch edge cases
            input.addEventListener('change', calculateTip);
          }
        });

        // Add event listeners to preset buttons
        presetButtons.forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            // Update the active class visually
            presetButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            // Update the input field and trigger calculation
            const newTip = btn.getAttribute('data-value');
            if (newTip && tipPercentageInput) {
              tipPercentageInput.value = newTip;
              calculateTip();
            }
          });
        });

        // Initial calculation
        calculateTip();
      }

      // Handle standard page load
      document.addEventListener('DOMContentLoaded', initCalculator);
      // Handle Astro view transitions
      document.addEventListener('astro:page-load', initCalculator);
    </script>
  </div>
</SiteLayout>

<style>
  .intro-text {
    font-size: 1.15rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .calculator-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2.5rem;
    margin: 3rem auto;
    max-width: 600px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .calculator-card h3 {
    margin-top: 0;
    margin-bottom: 2rem;
    text-align: center;
    font-size: 1.75rem;
    color: var(--text-primary);
  }

  .input-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .prefix, .prefix-icon {
    position: absolute;
    left: 1rem;
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 1.1rem;
    pointer-events: none;
    z-index: 2;
  }

  .suffix {
    position: absolute;
    right: 1rem;
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 1.1rem;
    pointer-events: none;
    z-index: 2;
  }

  input[type="number"] {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 600;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05);
  }

  input[id="billAmount"] {
    padding-left: 2.5rem;
  }

  input[id="tipPercentage"] {
    padding-right: 2.5rem;
  }

  input[id="numberOfPeople"] {
    padding-left: 2.5rem;
  }

  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  input[type="number"] {
    -moz-appearance: textfield;
  }

  input[type="number"]:focus {
    outline: none;
    border-color: var(--accent-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 25%, transparent);
  }

  .preset-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .preset-btn {
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .preset-btn:hover {
    border-color: var(--accent-color);
    background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
  }

  .preset-btn.active {
    background-color: var(--accent-color);
    color: #fff;
    border-color: var(--accent-color);
    box-shadow: 0 4px 6px -1px color-mix(in srgb, var(--accent-color) 50%, transparent);
  }

  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    border-top: 2px dashed var(--border-color);
    padding-top: 2rem;
  }

  .result-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: var(--bg-color);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border-color);
  }

  .total-box {
    background-color: color-mix(in srgb, var(--accent-color) 10%, var(--bg-color));
    border-color: color-mix(in srgb, var(--accent-color) 30%, var(--border-color));
  }

  .result-label {
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .total-box .result-label {
    color: var(--text-primary);
  }

  .result-value {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .total-box .result-value {
    color: var(--accent-color);
    font-size: 2.25rem;
  }

  .split-result-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: color-mix(in srgb, var(--text-secondary) 15%, var(--bg-color));
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 1.5rem;
    text-align: center;
  }

  .split-result-box .result-value {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin: 0.25rem 0;
  }

  .split-detail {
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-style: italic;
  }

  /* Educational Section Styling */
  .formula-box {
    text-align: center;
    padding: 1.25rem;
    background-color: color-mix(in srgb, var(--accent-color) 5%, var(--card-bg));
  }

  .formula-box code {
    display: block;
    margin-top: 0.75rem;
    font-size: 1.1rem;
    padding: 0.75rem;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
  }

  .table-container {
    overflow-x: auto;
    margin: 2rem 0;
    border-radius: 8px;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
  }

  /* FAQ Styles overriding global layout if needed */
  .faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--text-primary);
    list-style: none; /* remove default arrow */
    user-select: none;
    transition: background-color 0.2s ease;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary:hover {
    background-color: color-mix(in srgb, var(--accent-color) 5%, transparent);
  }

  .faq-item summary h3 {
    margin: 0;
    font-size: 1.1rem;
  }

  .faq-item .icon {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--accent-color);
    transition: transform 0.3s ease;
  }

  .faq-item[open] .icon {
    transform: rotate(45deg);
  }

  .faq-item p {
    padding: 0 1.5rem 1.5rem 1.5rem;
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.6;
    border-top: 1px solid transparent;
  }

  .faq-item[open] p {
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }

  @media (max-width: 640px) {
    .calculator-card {
      padding: 1.5rem;
    }

    .preset-buttons {
      grid-template-columns: repeat(2, 1fr);
    }

    .results-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
