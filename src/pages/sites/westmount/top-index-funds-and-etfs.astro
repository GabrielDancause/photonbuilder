  <script is:inline>
    function initFiltersAndSorting() {
        const container = document.getElementById('main-content-container');
        if (!container || container.dataset.initialized) return;
        container.dataset.initialized = 'true';

        // Table Sorting Logic
        const table = document.getElementById('summary-table');
        if (table) {
            const headers = table.querySelectorAll('th.sortable-header');
            const tbody = table.querySelector('tbody');
            let sortCol = -1;
            let sortAsc = true;

            headers.forEach((header, index) => {
                header.addEventListener('click', () => {
                    if (sortCol === index) {
                        sortAsc = !sortAsc;
                    } else {
                        sortCol = index;
                        sortAsc = true;
                    }

                    const rows = Array.from(tbody.querySelectorAll('tr'));
                    rows.sort((a, b) => {
                        let valA = a.cells[index].textContent.trim();
                        let valB = b.cells[index].textContent.trim();

                        const numA = parseFloat(valA.replace(/[^0-9.-]+/g,""));
                        const numB = parseFloat(valB.replace(/[^0-9.-]+/g,""));

                        if (!isNaN(numA) && !isNaN(numB) && valA !== 'N/A' && valB !== 'N/A') {
                             let multA = 1, multB = 1;
                             if(valA.includes('B')) multA = 1e9;
                             if(valA.includes('M')) multA = 1e6;
                             if(valB.includes('B')) multB = 1e9;
                             if(valB.includes('M')) multB = 1e6;

                             return sortAsc ? (numA*multA - numB*multB) : (numB*multB - numA*multA);
                        }

                        return sortAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                    });

                    rows.forEach(row => tbody.appendChild(row));
                });
            });
        }

        // Filtering Logic
        const yieldFilter = document.getElementById('yield-filter');
        const capFilter = document.getElementById('cap-filter');
        const resetBtn = document.getElementById('reset-filters');
        const cards = document.querySelectorAll('.item-card');

        function applyFilters() {
            const minYield = parseFloat(yieldFilter?.value) || 0;
            const minCap = parseFloat(capFilter?.value) || 0;

            cards.forEach(card => {
                const cardYield = parseFloat(card.getAttribute('data-yield')) || 0;
                const cardCap = parseFloat(card.getAttribute('data-cap')) || 0;

                if (cardYield >= minYield && cardCap >= minCap) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        if (yieldFilter) yieldFilter.addEventListener('change', applyFilters);
        if (capFilter) capFilter.addEventListener('change', applyFilters);
        if (resetBtn) {
            resetBtn.addEventListener('click', () => {
                if (yieldFilter) yieldFilter.value = "0";
                if (capFilter) capFilter.value = "0";
                applyFilters();
            });
        }
    }

    document.addEventListener('DOMContentLoaded', initFiltersAndSorting);
    document.addEventListener('astro:page-load', initFiltersAndSorting);
  </script>
</SiteLayout>
