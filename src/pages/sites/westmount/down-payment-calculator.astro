---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Down Payment Calculator | Calculate Mortgage Costs & PMI",
  description: "Calculate your down payment, mortgage costs, and estimate PMI with our free, interactive down payment calculator. Real-time updates and detailed breakdown.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much down payment do I need for a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "While 20% is often recommended to avoid Private Mortgage Insurance (PMI), many buyers purchase homes with much less. Conventional loans often require as little as 3% down, FHA loans require 3.5%, and VA or USDA loans can offer 0% down for eligible borrowers."
      }
    },
    {
      "@type": "Question",
      "name": "What is PMI (Private Mortgage Insurance)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PMI is an insurance policy that protects the lender if you default on your conventional loan. It is typically required if your down payment is less than 20% of the home's purchase price. The cost usually ranges from 0.5% to 1.5% of the original loan amount per year."
      }
    },
    {
      "@type": "Question",
      "name": "Does a larger down payment lower my interest rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, generally speaking. A larger down payment reduces the lender's risk, which often translates to a lower interest rate on your mortgage. It also reduces your overall loan amount, resulting in lower monthly payments."
      }
    },
    {
      "@type": "Question",
      "name": "Should I put 20% down if I can afford it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Putting 20% down avoids PMI and lowers your monthly payment. However, some buyers prefer to put down less (e.g., 5% or 10%) so they can keep more cash on hand for emergencies, renovations, or other investments, even if it means paying PMI temporarily."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use gift money for a down payment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, most loan programs allow you to use monetary gifts from family members for some or all of your down payment. You will typically need to provide a 'gift letter' stating that the money is a gift and does not need to be repaid."
      }
    }
  ]
});
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/down-payment-calculator"
  schema={schema}
>
  <div class="page-content">
    <h1>Down Payment Calculator</h1>

    <p>A down payment is one of the most critical elements of buying a home. The amount of cash you put down initially determines your loan amount, dictates your monthly payments, and decides whether you will be required to pay Private Mortgage Insurance (PMI). Use our interactive down payment calculator to estimate your costs, model different down payment percentages, and visualize your total monthly housing expenses.</p>

    <!-- Calculator UI -->
    <div class="calculator-card">
      <div class="calc-grid">
        <!-- Input Column -->
        <div class="calc-inputs">
          <h3>Mortgage Details</h3>

          <div class="input-group">
            <label for="homePrice">Home Price</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="homePrice" value="400000" min="10000" step="1000" aria-label="Home Price">
            </div>
          </div>

          <div class="input-row">
            <div class="input-group">
              <label for="downPaymentPercent">Down Payment (%)</label>
              <div class="input-wrapper">
                <input type="number" id="downPaymentPercent" value="20" min="0" max="100" step="0.1" aria-label="Down Payment Percentage">
                <span class="suffix">%</span>
              </div>
            </div>
            <div class="input-group">
              <label for="downPaymentAmount">Down Payment ($)</label>
              <div class="input-wrapper">
                <span class="prefix">$</span>
                <input type="number" id="downPaymentAmount" value="80000" min="0" step="1000" aria-label="Down Payment Amount">
              </div>
            </div>
          </div>

          <div class="input-row">
            <div class="input-group">
              <label for="interestRate">Interest Rate</label>
              <div class="input-wrapper">
                <input type="number" id="interestRate" value="6.5" min="0.1" max="25" step="0.1" aria-label="Interest Rate">
                <span class="suffix">%</span>
              </div>
            </div>
            <div class="input-group">
              <label for="loanTerm">Loan Term</label>
              <div class="input-wrapper">
                <input type="number" id="loanTerm" value="30" min="5" max="40" step="5" aria-label="Loan Term in Years">
                <span class="suffix">Yrs</span>
              </div>
            </div>
          </div>

          <details class="advanced-options">
            <summary>Advanced Options (Taxes & Insurance)</summary>
            <div class="advanced-grid">
              <div class="input-group">
                <label for="propertyTax">Property Tax / Year</label>
                <div class="input-wrapper">
                  <span class="prefix">$</span>
                  <input type="number" id="propertyTax" value="4800" min="0" step="100" aria-label="Annual Property Tax">
                </div>
              </div>
              <div class="input-group">
                <label for="homeInsurance">Home Insurance / Year</label>
                <div class="input-wrapper">
                  <span class="prefix">$</span>
                  <input type="number" id="homeInsurance" value="1200" min="0" step="100" aria-label="Annual Home Insurance">
                </div>
              </div>
              <div class="input-group">
                <label for="hoaFees">HOA Fees / Month</label>
                <div class="input-wrapper">
                  <span class="prefix">$</span>
                  <input type="number" id="hoaFees" value="0" min="0" step="10" aria-label="Monthly HOA Fees">
                </div>
              </div>
              <div class="input-group">
                <label for="pmiRate">PMI Rate / Year (%)</label>
                <div class="input-wrapper">
                  <input type="number" id="pmiRate" value="0.5" min="0" max="5" step="0.1" aria-label="Annual PMI Rate">
                  <span class="suffix">%</span>
                </div>
                <small class="helper-text">Only applies if down payment < 20%</small>
              </div>
            </div>
          </details>
        </div>

        <!-- Results Column -->
        <div class="calc-results">
          <h3>Payment Breakdown</h3>

          <div class="main-result">
            <span class="result-label">Estimated Monthly Payment</span>
            <div class="result-value" id="totalMonthlyPayment">$2,523</div>
          </div>

          <div class="breakdown-list">
            <div class="breakdown-item">
              <div class="item-label">
                <span class="color-dot dot-principal"></span> Principal & Interest
              </div>
              <div class="item-value" id="monthlyPrincipalInterest">$2,023</div>
            </div>
            <div class="breakdown-item">
              <div class="item-label">
                <span class="color-dot dot-taxes"></span> Property Taxes
              </div>
              <div class="item-value" id="monthlyTaxes">$400</div>
            </div>
            <div class="breakdown-item">
              <div class="item-label">
                <span class="color-dot dot-insurance"></span> Home Insurance
              </div>
              <div class="item-value" id="monthlyInsurance">$100</div>
            </div>
            <div class="breakdown-item">
              <div class="item-label">
                <span class="color-dot dot-hoa"></span> HOA Fees
              </div>
              <div class="item-value" id="monthlyHoa">$0</div>
            </div>
            <div class="breakdown-item pmi-row" id="pmiRow" style="display: none;">
              <div class="item-label">
                <span class="color-dot dot-pmi"></span> PMI
              </div>
              <div class="item-value" id="monthlyPmi">$0</div>
            </div>
          </div>

          <div class="loan-summary">
            <div class="summary-item">
              <span>Loan Amount:</span>
              <strong id="summaryLoanAmount">$320,000</strong>
            </div>
            <div class="summary-item">
              <span>Down Payment:</span>
              <strong id="summaryDownPayment">$80,000</strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Educational Content -->
    <h2>Understanding Down Payments</h2>
    <p>A down payment represents your initial equity stake in a property. It is paid upfront at closing and is calculated as a percentage of the home's total purchase price. The remainder of the purchase price is covered by your mortgage loan.</p>

    <h3>The 20% Down Payment Standard</h3>
    <p>For decades, a 20% down payment was considered the gold standard for buying a home. Putting 20% down offers several significant advantages:</p>
    <ul>
      <li><strong>No Private Mortgage Insurance (PMI):</strong> Conventional lenders require PMI if your down payment is less than 20% to protect them against default. Reaching the 20% threshold completely eliminates this monthly expense.</li>
      <li><strong>Lower Monthly Payments:</strong> Because you are borrowing less money, your principal and interest payments will naturally be lower.</li>
      <li><strong>Better Interest Rates:</strong> Lenders view borrowers with substantial down payments as lower risk, which often qualifies them for the most competitive interest rates.</li>
      <li><strong>Instant Equity:</strong> Starting with 20% equity provides a strong buffer against market downturns, making it highly unlikely you'll end up "underwater" on your mortgage.</li>
    </ul>

    <h3>Low Down Payment Options</h3>
    <p>While 20% is advantageous, it is not strictly necessary. In fact, saving 20% can take years, especially in high-cost housing markets. Fortunately, several mortgage programs cater to low down payments:</p>
    <ul>
      <li><strong>Conventional Loans:</strong> Can go as low as 3% down for first-time homebuyers.</li>
      <li><strong>FHA Loans:</strong> Backed by the Federal Housing Administration, these require as little as 3.5% down and are more forgiving of lower credit scores.</li>
      <li><strong>VA Loans:</strong> Available to eligible military veterans and active-duty service members, offering 0% down with no PMI.</li>
      <li><strong>USDA Loans:</strong> Designed for rural and suburban homebuyers meeting specific income limits, also offering 0% down.</li>
    </ul>

    <h3>What is PMI and How Much Does It Cost?</h3>
    <p>Private Mortgage Insurance (PMI) is an added premium you pay monthly when putting down less than 20% on a conventional loan. It protects the lender, not you. The cost of PMI varies based on your credit score, loan type, and down payment size, but it typically ranges from <strong>0.5% to 1.5% of the original loan amount per year</strong>.</p>
    <p>For example, if you take out a $350,000 loan with a 1% annual PMI rate, you'll pay $3,500 per year, or roughly $291 per month, just for PMI. Once your loan balance reaches 80% of the home's original appraised value, you can request to have PMI removed.</p>

    <!-- FAQ Section (Matches JSON-LD Schema) -->
    <h2>Frequently Asked Questions</h2>
    <div class="faq-section">
      <details class="faq-item">
        <summary>How much down payment do I need for a house?</summary>
        <p>While 20% is often recommended to avoid Private Mortgage Insurance (PMI), many buyers purchase homes with much less. Conventional loans often require as little as 3% down, FHA loans require 3.5%, and VA or USDA loans can offer 0% down for eligible borrowers.</p>
      </details>
      <details class="faq-item">
        <summary>What is PMI (Private Mortgage Insurance)?</summary>
        <p>PMI is an insurance policy that protects the lender if you default on your conventional loan. It is typically required if your down payment is less than 20% of the home's purchase price. The cost usually ranges from 0.5% to 1.5% of the original loan amount per year.</p>
      </details>
      <details class="faq-item">
        <summary>Does a larger down payment lower my interest rate?</summary>
        <p>Yes, generally speaking. A larger down payment reduces the lender's risk, which often translates to a lower interest rate on your mortgage. It also reduces your overall loan amount, resulting in lower monthly payments.</p>
      </details>
      <details class="faq-item">
        <summary>Should I put 20% down if I can afford it?</summary>
        <p>Putting 20% down avoids PMI and lowers your monthly payment. However, some buyers prefer to put down less (e.g., 5% or 10%) so they can keep more cash on hand for emergencies, renovations, or other investments, even if it means paying PMI temporarily.</p>
      </details>
      <details class="faq-item">
        <summary>Can I use gift money for a down payment?</summary>
        <p>Yes, most loan programs allow you to use monetary gifts from family members for some or all of your down payment. You will typically need to provide a 'gift letter' stating that the money is a gift and does not need to be repaid.</p>
      </details>
    </div>
  </div>
</SiteLayout>

<script>
  function initCalculator() {
    const container = document.querySelector('.calculator-card');
    if (!container || container.dataset.initialized) return;
    container.dataset.initialized = "true";

    // Inputs
    const homePriceInput = document.getElementById('homePrice');
    const downPaymentPercentInput = document.getElementById('downPaymentPercent');
    const downPaymentAmountInput = document.getElementById('downPaymentAmount');
    const interestRateInput = document.getElementById('interestRate');
    const loanTermInput = document.getElementById('loanTerm');
    const propertyTaxInput = document.getElementById('propertyTax');
    const homeInsuranceInput = document.getElementById('homeInsurance');
    const hoaFeesInput = document.getElementById('hoaFees');
    const pmiRateInput = document.getElementById('pmiRate');

    // Outputs
    const totalMonthlyPaymentEl = document.getElementById('totalMonthlyPayment');
    const monthlyPrincipalInterestEl = document.getElementById('monthlyPrincipalInterest');
    const monthlyTaxesEl = document.getElementById('monthlyTaxes');
    const monthlyInsuranceEl = document.getElementById('monthlyInsurance');
    const monthlyHoaEl = document.getElementById('monthlyHoa');
    const pmiRowEl = document.getElementById('pmiRow');
    const monthlyPmiEl = document.getElementById('monthlyPmi');

    const summaryLoanAmountEl = document.getElementById('summaryLoanAmount');
    const summaryDownPaymentEl = document.getElementById('summaryDownPayment');

    // Formatters
    const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);

    // Track active input to prevent circular updates
    let activeInput = null;

    function calculate() {
      // Parse inputs
      const homePrice = parseFloat(homePriceInput.value) || 0;
      let downPercent = parseFloat(downPaymentPercentInput.value) || 0;
      let downAmount = parseFloat(downPaymentAmountInput.value) || 0;

      const interestRate = parseFloat(interestRateInput.value) || 0;
      const loanTermYears = parseFloat(loanTermInput.value) || 0;

      const propertyTaxAnnual = parseFloat(propertyTaxInput.value) || 0;
      const homeInsuranceAnnual = parseFloat(homeInsuranceInput.value) || 0;
      const hoaMonthly = parseFloat(hoaFeesInput.value) || 0;
      const pmiRateAnnual = parseFloat(pmiRateInput.value) || 0;

      // Handle Down Payment Syncing
      if (activeInput === 'percent') {
        downAmount = homePrice * (downPercent / 100);
        downPaymentAmountInput.value = downAmount.toFixed(0);
      } else if (activeInput === 'amount') {
        downPercent = homePrice > 0 ? (downAmount / homePrice) * 100 : 0;
        downPaymentPercentInput.value = downPercent.toFixed(1);
      } else {
        // Default sync on other inputs (like home price changing)
        downAmount = homePrice * (downPercent / 100);
        downPaymentAmountInput.value = downAmount.toFixed(0);
      }

      // Constraints
      if (downAmount > homePrice) {
        downAmount = homePrice;
        downPaymentAmountInput.value = downAmount.toFixed(0);
        downPercent = 100;
        downPaymentPercentInput.value = downPercent.toFixed(1);
      }

      // Calculations
      const loanAmount = homePrice - downAmount;
      const monthlyInterestRate = (interestRate / 100) / 12;
      const numberOfPayments = loanTermYears * 12;

      // Principal & Interest (Amortization Formula)
      let monthlyPrincipalInterest = 0;
      if (loanAmount > 0 && monthlyInterestRate > 0) {
        monthlyPrincipalInterest = loanAmount * (monthlyInterestRate * Math.pow(1 + monthlyInterestRate, numberOfPayments)) / (Math.pow(1 + monthlyInterestRate, numberOfPayments) - 1);
      } else if (loanAmount > 0) {
        monthlyPrincipalInterest = loanAmount / numberOfPayments;
      }

      // Taxes & Insurance (Monthly)
      const monthlyTaxes = propertyTaxAnnual / 12;
      const monthlyInsurance = homeInsuranceAnnual / 12;

      // PMI Calculation
      let monthlyPmi = 0;
      if (downPercent < 20 && loanAmount > 0) {
        monthlyPmi = (loanAmount * (pmiRateAnnual / 100)) / 12;
        pmiRowEl.style.display = 'flex';
      } else {
        pmiRowEl.style.display = 'none';
      }

      // Total Monthly Payment
      const totalMonthlyPayment = monthlyPrincipalInterest + monthlyTaxes + monthlyInsurance + hoaMonthly + monthlyPmi;

      // Update UI
      totalMonthlyPaymentEl.textContent = formatCurrency(totalMonthlyPayment);
      monthlyPrincipalInterestEl.textContent = formatCurrency(monthlyPrincipalInterest);
      monthlyTaxesEl.textContent = formatCurrency(monthlyTaxes);
      monthlyInsuranceEl.textContent = formatCurrency(monthlyInsurance);
      monthlyHoaEl.textContent = formatCurrency(hoaMonthly);
      monthlyPmiEl.textContent = formatCurrency(monthlyPmi);

      summaryLoanAmountEl.textContent = formatCurrency(loanAmount);
      summaryDownPaymentEl.textContent = formatCurrency(downAmount);
    }

    // Event Listeners
    const inputs = [
      homePriceInput, interestRateInput, loanTermInput,
      propertyTaxInput, homeInsuranceInput, hoaFeesInput, pmiRateInput
    ];

    inputs.forEach(input => {
      input.addEventListener('input', () => {
        activeInput = null;
        calculate();
      });
    });

    downPaymentPercentInput.addEventListener('input', () => {
      activeInput = 'percent';
      calculate();
    });

    downPaymentAmountInput.addEventListener('input', () => {
      activeInput = 'amount';
      calculate();
    });

    // Initial Calculation
    calculate();
  }

  // Handle both standard loads and Astro view transitions
  document.addEventListener('DOMContentLoaded', initCalculator);
  document.addEventListener('astro:page-load', initCalculator);
</script>

<style>
