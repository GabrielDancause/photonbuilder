// Sort
let etfSortKey='yield',etfSortDir='desc';
let etfData=[...ETF_DATA];

function sortETFs(key,type){
  if(etfSortKey===key){etfSortDir=etfSortDir==='asc'?'desc':'asc';}
  else{etfSortKey=key;etfSortDir=type==='num'?'desc':'asc';}
  etfData.sort((a,b)=>{
    let av=a[key],bv=b[key];
    if(typeof av==='string')av=av.toLowerCase();
    if(typeof bv==='string')bv=bv.toLowerCase();
    if(av<bv)return etfSortDir==='asc'?-1:1;
    if(av>bv)return etfSortDir==='asc'?1:-1;
    return 0;
  });
  document.querySelectorAll('#etf-table th').forEach(th=>{
    th.classList.remove('sorted-asc','sorted-desc');
    if(th.dataset.key===key)th.classList.add('sorted-'+etfSortDir);
  });
  renderETFs(etfData);
}

// Table header click handlers
document.querySelectorAll('#etf-table th[data-key]').forEach(th=>{
  th.addEventListener('click',()=>sortETFs(th.dataset.key,th.dataset.type));
});

