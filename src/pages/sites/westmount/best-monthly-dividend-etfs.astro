// Render ETF table
function renderETFs(data){
  const tbody=document.getElementById('etf-tbody');
  tbody.innerHTML=data.map(e=>{
    const yc=e.yield>=8?'yield-high':e.yield>=5?'yield-mid':'yield-low';
    const freq=e.frequency.includes('*')?e.frequency:`${e.frequency}`;
    return `<tr>
      <td class="ticker">${e.ticker}</td>
      <td>${e.name}</td>
      <td class="num ${yc}">${e.yield.toFixed(1)}%</td>
      <td class="num">${e.expenseRatio>0?e.expenseRatio.toFixed(2)+'%':'N/A (stock)'}</td>
      <td class="num">${e.aum>0?'$'+e.aum.toFixed(1)+'B':'—'}</td>
      <td class="num">${e.holdings>0?e.holdings.toLocaleString():'—'}</td>
      <td>${freq}</td>
      <td>${e.strategy}</td>
    </tr>`;
  }).join('');
}

// Render stock table
function renderStocks(data){
  const tbody=document.getElementById('stock-tbody');
  tbody.innerHTML=data.map(s=>{
    const yc=s.yield>=8?'yield-high':s.yield>=5?'yield-mid':'yield-low';
    return `<tr>
      <td class="ticker">${s.ticker}</td>
      <td>${s.name}</td>
      <td>${s.sector}</td>
      <td class="num ${yc}">${s.yield.toFixed(1)}%</td>
      <td class="num">${s.payoutRatio}%</td>
      <td class="num">${s.consecutiveYears}</td>
      <td class="num">${s.marketCap}</td>
    </tr>`;
  }).join('');
}

// Render FAQ
