  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const sectorFilter = document.getElementById('sector-filter');
      const yieldFilter = document.getElementById('yield-filter');
      const cards = document.querySelectorAll('#rankings-container .card');
      const tableRows = document.querySelectorAll('#summary-table tbody tr');

      function applyFilters() {
        const selectedSector = sectorFilter.value;
        const minYield = parseFloat(yieldFilter.value);

        cards.forEach((card, index) => {
          const sector = card.getAttribute('data-sector');
          const itemYield = parseFloat(card.getAttribute('data-yield'));

          const matchesSector = selectedSector === 'all' || sector === selectedSector;
          const matchesYield = itemYield >= minYield;

          const shouldShow = matchesSector && matchesYield;
          card.style.display = shouldShow ? 'block' : 'none';
          if (tableRows[index]) {
            tableRows[index].style.display = shouldShow ? 'table-row' : 'none';
          }
        });
      }

      sectorFilter.addEventListener('change', applyFilters);
      yieldFilter.addEventListener('change', applyFilters);

      // Sorting logic for table
      const getCellValue = (tr, idx) => tr.children[idx].innerText || tr.children[idx].textContent;
      const comparer = (idx, asc) => (a, b) => ((v1, v2) =>
        v1 !== '' && v2 !== '' && !isNaN(v1.replace(/[^0-9.-]+/g,"")) && !isNaN(v2.replace(/[^0-9.-]+/g,"")) ?
          parseFloat(v1.replace(/[^0-9.-]+/g,"")) - parseFloat(v2.replace(/[^0-9.-]+/g,"")) :
          v1.toString().localeCompare(v2)
        )(getCellValue(asc ? a : b, idx), getCellValue(asc ? b : a, idx));

      document.querySelectorAll('th[data-sort]').forEach(th => th.addEventListener('click', (() => {
        const table = th.closest('table');
        const tbody = table.querySelector('tbody');
        Array.from(tbody.querySelectorAll('tr'))
          .sort(comparer(Array.from(th.parentNode.children).indexOf(th), this.asc = !this.asc))
          .forEach(tr => tbody.appendChild(tr));
      })));
    });
  </script>

