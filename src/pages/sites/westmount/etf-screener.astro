// Head-to-head comparison
document.getElementById('compareBtn').addEventListener('click', () => {
  const tickers = ['cmp1','cmp2','cmp3'].map(id => document.getElementById(id).value).filter(Boolean);
  const grid = document.getElementById('compareGrid');

  if (tickers.length < 2) {
    grid.innerHTML = '<div class="compare-empty">Please select at least 2 ETFs to compare.</div>';
    return;
  }

  const selected = tickers.map(t => ETFS.find(e => e.ticker === t)).filter(Boolean);
  if (selected.length < 2) {
    grid.innerHTML = '<div class="compare-empty">ETF not found. Please try again.</div>';
    return;
  }

  const bestER = Math.min(...selected.map(e => e.er));
  const bestYield = Math.max(...selected.map(e => e.yield));
  const bestAUM = Math.max(...selected.map(e => e.aum));
  const bestYTD = Math.max(...selected.map(e => e.ytd));
  const bestHoldings = Math.max(...selected.map(e => e.holdings));

  grid.innerHTML = selected.map(e => `<div class="compare-card">
    <h3>${escapeHTML(e.ticker)}</h3>
    <div class="compare-name">${escapeHTML(e.name)}</div>
    <div class="compare-row"><span class="compare-label">Category</span><span class="compare-val">${escapeHTML(e.category)}</span></div>
    <div class="compare-row"><span class="compare-label">Expense Ratio</span><span class="compare-val ${e.er === bestER ? 'compare-winner' : ''}">${e.er.toFixed(2)}%${e.er === bestER ? ' ★' : ''}</span></div>
    <div class="compare-row"><span class="compare-label">AUM</span><span class="compare-val ${e.aum === bestAUM ? 'compare-winner' : ''}">${escapeHTML(fmtAUM(e.aum))}${e.aum === bestAUM ? ' ★' : ''}</span></div>
    <div class="compare-row"><span class="compare-label">YTD Return</span><span class="compare-val ${e.ytd === bestYTD ? 'compare-winner' : ''}">${e.ytd > 0 ? '+' : ''}${e.ytd.toFixed(1)}%${e.ytd === bestYTD ? ' ★' : ''}</span></div>
    <div class="compare-row"><span class="compare-label">Dividend Yield</span><span class="compare-val ${e.yield === bestYield ? 'compare-winner' : ''}">${e.yield > 0 ? e.yield.toFixed(1) + '%' : '—'}${e.yield === bestYield ? ' ★' : ''}</span></div>
    <div class="compare-row"><span class="compare-label">Holdings</span><span class="compare-val ${e.holdings === bestHoldings ? 'compare-winner' : ''}">${e.holdings.toLocaleString()}${e.holdings === bestHoldings ? ' ★' : ''}</span></div>
  </div>`).join('');
});

