---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is an ETF screener?","acceptedAnswer":{"@type":"Answer","text":"An ETF screener is a tool that filters exchange-traded funds based on criteria like expense ratio, yield, category, AUM, and performance. Instead of browsing thousands of ETFs manually, a screener narrows results to funds matching your strategy. Our free screener includes 40 popular ETFs spanning equity, bond, commodity, crypto, and REIT categories with instant filtering and preset screens."}},
    {"@type":"Question","name":"What is the best free ETF screener?","acceptedAnswer":{"@type":"Answer","text":"The best free ETF screeners include ETF.com, VettaFi (formerly ETFdb), Morningstar, and our tool on this page. ETF.com offers the deepest fund analysis, VettaFi has the largest ETF database (3,000+), and Morningstar provides the most trusted ratings. Our screener focuses on 40 of the most popular ETFs with instant filtering by category, expense ratio, yield, and performance — no account required."}},
    {"@type":"Question","name":"What expense ratio is considered good for an ETF?","acceptedAnswer":{"@type":"Answer","text":"An expense ratio under 0.10% is considered excellent and typical of broad index ETFs like VOO (0.03%) and VTI (0.03%). Under 0.20% is good for most categories. Actively managed ETFs like ARKK charge 0.75% or more. As a rule, never pay more than 0.50% for a passive index ETF. Over 30 years, the difference between 0.03% and 0.75% on a $100,000 investment is roughly $50,000 in lost returns."}},
    {"@type":"Question","name":"How do I choose between similar ETFs like VOO and SPY?","acceptedAnswer":{"@type":"Answer","text":"VOO and SPY both track the S&P 500 but differ in cost and structure. VOO charges 0.03% vs SPY's 0.09% — saving roughly $60/year per $100,000 invested. SPY has higher trading volume and tighter spreads, making it better for active traders. For long-term buy-and-hold investors, VOO wins on cost. IVV (0.03%) is another near-identical alternative. The performance difference between all three is negligible over any period."}},
    {"@type":"Question","name":"What is ETF yield and how is it calculated?","acceptedAnswer":{"@type":"Answer","text":"ETF yield (distribution yield or SEC yield) represents the income an ETF pays as a percentage of its price. It includes dividends from stock ETFs and interest from bond ETFs. A 30-day SEC yield is the most standardized measure. High-yield ETFs (3%+) include dividend-focused funds like SCHD (3.5%) and bond ETFs like HYG (5.8%). Be cautious of extremely high yields — they may signal capital return rather than true income, especially in covered-call ETFs like QYLD."}},
    {"@type":"Question","name":"Should I invest in bond ETFs or individual bonds?","acceptedAnswer":{"@type":"Answer","text":"Bond ETFs offer diversification, daily liquidity, and low minimums — making them better for most investors. AGG holds 10,000+ bonds for a 0.03% fee, impossible to replicate individually. However, bond ETFs never mature (they constantly roll bonds), so you face interest rate risk indefinitely. Individual bonds guarantee return of principal at maturity. For investors needing predictable income at a specific date, individual bonds or bond ladders work better."}},
    {"@type":"Question","name":"What is AUM and why does it matter for ETFs?","acceptedAnswer":{"@type":"Answer","text":"AUM (Assets Under Management) is the total market value of all shares in an ETF. Higher AUM generally means tighter bid-ask spreads, lower trading costs, and lower risk of fund closure. ETFs under $50M AUM face higher closure risk. SPY ($550B), VOO ($450B), and VTI ($400B) are the largest and most liquid. For buy-and-hold investors, AUM above $1B is ideal; for active traders, AUM above $10B ensures the tightest spreads."}},
    {"@type":"Question","name":"How do I build a diversified ETF portfolio?","acceptedAnswer":{"@type":"Answer","text":"A classic diversified ETF portfolio uses 3-4 funds: US stocks (VTI or VOO), international stocks (VXUS or EFA), US bonds (BND or AGG), and optionally REITs (VNQ). A common allocation is 60% US stocks, 20% international, and 20% bonds — adjusted for age and risk tolerance. Younger investors tilt toward stocks (80-90%), while retirees increase bonds (40-60%). This approach gives exposure to 10,000+ securities for under 0.05% average expense ratio."}}
  ]
};

export const meta = {
  title: "Free ETF Screener — Filter & Compare 40 Popular ETFs",
  description: "Screen 40 popular ETFs by expense ratio, yield, AUM, category & performance. Preset screens for income, low-cost, growth & bond ETFs. Free ETF finder tool.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="Free ETF Screener: Compare 40 Popular ETFs by Expense Ratio, Yield & Performance"
  description="Screen 40 popular ETFs instantly. Filter by category, expense ratio, yield, AUM, and returns. Preset screens for income, low-cost, growth, and bond strategies. Free ETF comparison tool."
  canonical="https://westmountfundamentals.com/etf-screener" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
header h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
header p.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.meta{color:var(--text-secondary);font-size:13px;margin-top:12px;font-family:'JetBrains Mono',monospace}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:32px 0}
.stat{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.stat .val{font-size:32px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.stat .label{font-size:13px;color:var(--text-secondary);margin-top:4px}

/* Presets */
.presets-section{margin:32px 0}
.presets-section h2{font-size:22px;margin-bottom:12px}
.presets-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.preset-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;cursor:pointer;transition:border-color .2s}
.preset-card:hover,.preset-card.active{border-color:var(--accent-color)}
.preset-card.active{background:rgba(74,143,231,.06)}
.preset-card h3{font-size:15px;margin-bottom:4px;color:var(--accent-color)}
.preset-card p{font-size:13px;color:var(--text-secondary);margin-bottom:8px}
.preset-card .preset-criteria{font-size:11px;color:var(--text-secondary);font-family:'JetBrains Mono',monospace;line-height:1.8}

/* Filters */
.filter-section{margin:32px 0}
.filter-section h2{font-size:22px;margin-bottom:12px}
.filter-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:16px}
.filter-group{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px}
.filter-group label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:8px}
.filter-group select,.filter-group input{width:100%;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 10px;border-radius:6px;font-size:13px;font-family:'Inter',sans-serif;box-sizing:border-box}
.filter-actions{display:flex;gap:12px;margin-top:12px}
.filter-actions button{padding:8px 18px;border-radius:6px;font-size:14px;cursor:pointer;font-weight:600;border:none}
.btn-primary{background:var(--accent-color);color:#fff}
.btn-primary:hover{opacity:.9}
.btn-secondary{background:var(--card-bg);color:var(--text-primary);border:1px solid var(--border-color) !important}
.btn-secondary:hover{border-color:var(--accent-color) !important}
.result-count{color:var(--text-secondary);font-size:13px;font-family:'JetBrains Mono',monospace;margin-bottom:12px}

/* Table */
.table-section{margin:32px 0}
.table-section h2{font-size:22px;margin-bottom:12px}
.search-bar{margin-bottom:16px}
.search-bar input{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:10px 14px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif;width:100%;max-width:400px;box-sizing:border-box}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--border-color);user-select:none;position:sticky;top:0}
th:hover{color:var(--accent-color)}
th.sorted-asc::after{content:' ▲';color:var(--accent-color)}
th.sorted-desc::after{content:' ▼';color:var(--accent-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color);white-space:nowrap}
tr:hover{background:rgba(74,143,231,.06)}
.ticker{font-family:'JetBrains Mono',monospace;font-weight:600;color:var(--accent-color)}
.num{font-family:'JetBrains Mono',monospace;text-align:right}
.pos{color:#22c55e}
.neg{color:#ef4444}

/* Category breakdown */
.category-section{margin:32px 0}
.category-section h2{font-size:22px;margin-bottom:16px}
.category-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px}
.category-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:14px;text-align:center}
.category-card .cat-name{font-size:12px;color:var(--text-secondary);margin-bottom:4px}
.category-card .cat-count{font-size:24px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.category-card .cat-avg{font-size:11px;color:var(--text-secondary);margin-top:2px}

/* Findings */
.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px;line-height:1.7}

/* FAQ */
.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

/* Related */
.related-section{margin:32px 0}
.related-section h2{font-size:22px;margin-bottom:16px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.related-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px;text-decoration:none;transition:border-color .2s}
.related-card:hover{border-color:var(--accent-color);text-decoration:none}
.related-card h3{font-size:15px;margin-bottom:4px;color:var(--text-primary)}
.related-card p{font-size:13px;color:var(--text-secondary)}

.methodology{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.methodology h2{font-size:18px;margin-bottom:12px}
.methodology p{color:var(--text-secondary);font-size:14px;margin-bottom:10px;line-height:1.7}

.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}
.updated-badge{display:inline-block;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-secondary);font-size:12px;padding:4px 10px;border-radius:4px;margin-top:8px;font-family:'JetBrains Mono',monospace}

footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:640px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .filter-grid{grid-template-columns:1fr}
  .presets-grid{grid-template-columns:1fr}
  .category-grid{grid-template-columns:repeat(2,1fr)}
  .related-grid{grid-template-columns:1fr}
}
  </style>

<div class="container">
    <h1>Free ETF Screener: Compare 40 Popular ETFs Instantly</h1>
    <div class="updated-badge">Last Updated: March 2026</div>

    <div class="stats" id="stats"></div>

    <div class="presets-section">
      <h2>Preset Screens</h2>
      <div class="presets-grid" id="presets"></div>
    </div>

    <div class="filter-section">
      <h2>Custom Filters</h2>
      <div class="filter-grid">
        <div class="filter-group">
          <label>Category</label>
          <select id="fCat">
            <option value="">All Categories</option>
            <option value="Equity">Equity</option>
            <option value="Bond">Bond</option>
            <option value="Commodity">Commodity</option>
            <option value="Crypto">Crypto</option>
            <option value="REIT">REIT</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Dividend Yield</label>
          <select id="fYield">
            <option value="">Any Yield</option>
            <option value="0-1">Under 1%</option>
            <option value="1-3">1% – 3%</option>
            <option value="3-5">3% – 5%</option>
            <option value="5-">5%+ (High Yield)</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Expense Ratio</label>
          <select id="fER">
            <option value="">Any Expense Ratio</option>
            <option value="0-0.05">Ultra Low (&lt;0.05%)</option>
            <option value="0.05-0.10">Low (0.05% – 0.10%)</option>
            <option value="0.10-0.30">Moderate (0.10% – 0.30%)</option>
            <option value="0.30-">High (0.30%+)</option>
          </select>
        </div>
        <div class="filter-group">
          <label>AUM</label>
          <select id="fAUM">
            <option value="">Any AUM</option>
            <option value="100-">$100B+</option>
            <option value="50-100">$50B – $100B</option>
            <option value="10-50">$10B – $50B</option>
            <option value="0-10">Under $10B</option>
          </select>
        </div>
        <div class="filter-group">
          <label>YTD Return</label>
          <select id="fYTD">
            <option value="">Any Return</option>
            <option value="10-">Up 10%+</option>
            <option value="5-10">Up 5% – 10%</option>
            <option value="0-5">Up 0% – 5%</option>
            <option value="-100-0">Negative (Down)</option>
          </select>
        </div>
      </div>
      <div class="filter-actions">
        <button class="btn-primary" id="applyBtn">Apply Filters</button>
        <button class="btn-secondary" id="resetBtn">Reset All</button>
      </div>
    </div>

    <div class="table-section">
      <h2>Screening Results</h2>
      <div class="search-bar">
        <input type="text" id="search" placeholder="Search by ticker or fund name…">
      </div>
      <div class="result-count" id="resultCount"></div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th data-key="ticker">Ticker</th>
              <th data-key="name">Name</th>
              <th data-key="category">Category</th>
              <th data-key="er" data-type="num">Expense Ratio</th>
              <th data-key="aum" data-type="num">AUM</th>
              <th data-key="yield" data-type="num">Yield</th>
              <th data-key="ytd" data-type="num">YTD Return</th>
              <th data-key="y1" data-type="num">1Y Return</th>
            </tr>
          </thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
    </div>

    <div class="category-section">
      <h2>ETF Category Breakdown</h2>
      <div class="category-grid" id="categoryGrid"></div>
    </div>

    <div class="findings">
      <h2>Key Screening Insights</h2>
      <div class="finding-card">
        <h3>Index Funds Dominate AUM for Good Reason</h3>
        <p>The top 5 ETFs by AUM — SPY, VOO, VTI, QQQ, and IWM — are all passive index funds with expense ratios under 0.10%. Together they hold over $2 trillion in assets. Over the past decade, low-cost index ETFs have outperformed roughly 90% of actively managed funds in the same category, reinforcing the case for passive investing as a core strategy.</p>
      </div>
      <div class="finding-card">
        <h3>Income ETFs Offer 3-12% Yields — But Read the Fine Print</h3>
        <p>High-yield ETFs like QYLD (11.8%), JEPI (7.2%), and JEPQ (9.5%) deliver attractive income through covered-call strategies. However, these funds cap upside during rallies — QYLD returned just 4.2% YTD vs. QQQ's 8.5%. Traditional dividend ETFs like SCHD and VYM offer lower yields (3-3.5%) but better total returns over full market cycles. Match your income strategy to whether you need current cash flow or long-term growth.</p>
      </div>
      <div class="finding-card">
        <h3>Bond ETFs Show Wide Dispersion in 2026</h3>
        <p>Bond ETF performance varies dramatically by duration and credit quality. Short-term funds like BIL (T-bills) and VTIP (short TIPS) show minimal volatility, while long-duration TLT has swung -8.2% YTD as rate expectations shift. High-yield HYG outperforms investment-grade AGG by 3+ percentage points but carries meaningfully higher credit risk. Diversify across the yield curve rather than concentrating in any single bond category.</p>
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div id="faq"></div>
    </div>

    <div class="related-section">
      <h2>Related Tools &amp; Research</h2>
      <div class="related-grid">
        <a class="related-card" href="/sites/westmount/best-index-funds">
          <h3>Best Index Funds</h3>
          <p>Compare the top index funds by cost, tracking error, and long-term performance for passive investors.</p>
        </a>
        <a class="related-card" href="/sites/westmount/stock-screener">
          <h3>Stock Screener</h3>
          <p>Screen 50 S&amp;P 500 stocks by market cap, PE ratio, dividend yield, sector &amp; 52-week performance.</p>
        </a>
        <a class="related-card" href="/sites/westmount/dividend-etf-comparison">
          <h3>Dividend ETF Comparison</h3>
          <p>Compare 21 dividend ETFs side-by-side: SCHD, VYM, JEPI, QYLD &amp; more ranked by yield and returns.</p>
        </a>
      </div>
    </div>

    <div class="methodology">
      <h2>Methodology</h2>
      <p>ETF data represents approximate values for 40 of the most widely-held exchange-traded funds as of Q1 2026. Expense ratios reflect the most recent prospectus filings. AUM figures are rounded to the nearest billion. Yields represent trailing 12-month distribution yields. YTD and 1-year returns are price returns (excluding reinvested distributions).</p>
      <p>Preset screens use commonly accepted thresholds: Income ETFs (yield &gt; 3%), Low-Cost ETFs (expense ratio &lt; 0.10%), Growth ETFs (YTD return &gt; 5%, equity category), and Bond ETFs (bond category only). Screens are for educational purposes and do not constitute buy or sell recommendations.</p>
    </div>

    <div class="disclaimer">This tool provides data for informational and educational purposes only. Not investment advice. ETF data is approximate and may not reflect real-time values. Always verify data and read fund prospectuses before making investment decisions.</div>
</div>

  <script is:inline>
