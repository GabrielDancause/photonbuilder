// Filtering
const fCat = document.getElementById('fCat');
const fYield = document.getElementById('fYield');
const fER = document.getElementById('fER');
const fAUM = document.getElementById('fAUM');
const fYTD = document.getElementById('fYTD');
const searchEl = document.getElementById('search');

function resetFilters() {
  fCat.value = '';
  fYield.value = '';
  fER.value = '';
  fAUM.value = '';
  fYTD.value = '';
  searchEl.value = '';
  activePreset = -1;
  document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
}

document.getElementById('resetBtn').addEventListener('click', () => {
  resetFilters();
  renderTable();
});

document.getElementById('applyBtn').addEventListener('click', () => {
  activePreset = -1;
  document.querySelectorAll('.preset-card').forEach(c => c.classList.remove('active'));
  renderTable();
});

searchEl.addEventListener('input', renderTable);

function parseRange(val) {
  if (!val) return null;
  const parts = val.split('-');
  if (parts.length === 3 && parts[0] === '') {
    return [-parseFloat(parts[1]), parts[2] === '' ? Infinity : parseFloat(parts[2])];
  }
  const lo = parts[0] === '' ? -Infinity : parseFloat(parts[0]);
  const hi = parts.length < 2 || parts[1] === '' ? Infinity : parseFloat(parts[1]);
  return [lo, hi];
}

function inRange(val, range) {
  if (!range) return true;
  return val >= range[0] && val <= range[1];
}

let sortKey = 'aum', sortDir = -1;

function filterETFs() {
  const q = searchEl.value.toLowerCase();
  let filtered = ETFS;

  if (activePreset >= 0) {
    const p = presets[activePreset];
    const c = p.criteria;
    filtered = filtered.filter(e => {
      if (c.yieldMin && e.yield < c.yieldMin) return false;
      if (c.erMax && e.er > c.erMax) return false;
      if (c.category && e.category !== c.category) return false;
      if (c.ytdMin && e.ytd < c.ytdMin) return false;
      return true;
    });
  } else {
    const rYield = parseRange(fYield.value);
    const rER = parseRange(fER.value);
    const rAUM = parseRange(fAUM.value);
    const rYTD = parseRange(fYTD.value);
    const cat = fCat.value;

    filtered = filtered.filter(e => {
      if (q && !e.ticker.toLowerCase().includes(q) && !e.name.toLowerCase().includes(q)) return false;
      if (cat && e.category !== cat) return false;
      if (rYield && !inRange(e.yield, rYield)) return false;
      if (rER && !inRange(e.er, rER)) return false;
      if (rAUM && !inRange(e.aum, rAUM)) return false;
      if (rYTD && !inRange(e.ytd, rYTD)) return false;
      return true;
    });
  }

  if (q && activePreset >= 0) {
    filtered = filtered.filter(e => e.ticker.toLowerCase().includes(q) || e.name.toLowerCase().includes(q));
  }

  filtered.sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (typeof va === 'string') return va.localeCompare(vb) * sortDir;
    return (va - vb) * sortDir;
  });

  return filtered;
}

function fmtAUM(v) {
  if (v >= 1000) return '$' + (v/1000).toFixed(1) + 'T';
  return '$' + v + 'B';
}

function renderTable() {
  const filtered = filterETFs();
  document.getElementById('resultCount').textContent = `Showing ${filtered.length} of ${ETFS.length} ETFs`;

  const tbody = document.getElementById('tbody');
  tbody.innerHTML = filtered.map(e => `<tr>
    <td class="ticker">${e.ticker}</td>
    <td>${e.name}</td>
    <td>${e.category}</td>
    <td class="num">${e.er.toFixed(2)}%</td>
    <td class="num">${fmtAUM(e.aum)}</td>
    <td class="num">${e.yield > 0 ? e.yield.toFixed(1) + '%' : '—'}</td>
    <td class="num ${e.ytd >= 0 ? 'pos' : 'neg'}">${e.ytd > 0 ? '+' : ''}${e.ytd.toFixed(1)}%</td>
    <td class="num ${e.y1 >= 0 ? 'pos' : 'neg'}">${e.y1 > 0 ? '+' : ''}${e.y1.toFixed(1)}%</td>
  </tr>`).join('');
}

// Sortable headers
document.querySelectorAll('th[data-key]').forEach(th => {
  th.addEventListener('click', () => {
    const key = th.dataset.key;
    if (sortKey === key) sortDir *= -1;
    else { sortKey = key; sortDir = th.dataset.type === 'num' ? -1 : 1; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
    renderTable();
  });
});

renderTable();

