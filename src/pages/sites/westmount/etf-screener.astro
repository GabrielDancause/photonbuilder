---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is an ETF screener?","acceptedAnswer":{"@type":"Answer","text":"An ETF screener is a tool that filters exchange-traded funds based on criteria like expense ratio, assets under management, dividend yield, category, and performance. Instead of manually comparing hundreds of ETFs, a screener narrows the list to funds matching your investment goals. Our free screener includes 50 popular ETFs across 8 categories with instant filtering, preset screens, and head-to-head comparison — no account required."}},
    {"@type":"Question","name":"What is the best free ETF screener?","acceptedAnswer":{"@type":"Answer","text":"The best free ETF screeners include ETF.com, Morningstar, VettaFi (formerly ETF Database), and our tool on this page. ETF.com offers the deepest fund analysis, Morningstar provides star ratings and analyst reports, and VettaFi has the largest ETF database (3,000+). Our screener focuses on the 50 most popular ETFs with instant filtering by category, expense ratio, AUM, yield, and YTD performance — plus head-to-head comparison."}},
    {"@type":"Question","name":"What is a good expense ratio for an ETF?","acceptedAnswer":{"@type":"Answer","text":"For broad market index ETFs, a good expense ratio is under 0.10% — funds like VOO (0.03%), VTI (0.03%), and IVV (0.03%) set the standard. For international ETFs, under 0.20% is competitive. Sector and thematic ETFs typically charge 0.30–0.75%. Bond ETFs range from 0.03% (BND) to 0.50%. Every 0.10% in fees costs roughly $1,000 per year on a $1M portfolio, compounding to significant drag over decades."}},
    {"@type":"Question","name":"How do I compare ETFs head-to-head?","acceptedAnswer":{"@type":"Answer","text":"To compare ETFs effectively, look at: (1) expense ratio — lower is almost always better for similar funds, (2) AUM and trading volume — larger funds have tighter bid-ask spreads, (3) tracking error — how closely the ETF follows its index, (4) holdings count and concentration — more holdings means more diversification, (5) dividend yield and distribution frequency, and (6) historical performance. Our comparison tool lets you select 2–3 ETFs and view all these metrics side-by-side."}},
    {"@type":"Question","name":"What is AUM and why does it matter for ETFs?","acceptedAnswer":{"@type":"Answer","text":"AUM (Assets Under Management) is the total market value of all investments held by an ETF. Higher AUM generally means: tighter bid-ask spreads (lower trading costs), lower risk of fund closure, and better index tracking. ETFs with under $50M in AUM face higher closure risk. For most investors, sticking with ETFs above $1B in AUM ensures liquidity and stability. The largest ETFs like SPY ($500B+) and VOO ($400B+) trade millions of shares daily."}},
    {"@type":"Question","name":"Should I buy ETFs or individual stocks?","acceptedAnswer":{"@type":"Answer","text":"ETFs offer instant diversification, lower risk, and minimal research time — ideal for most investors. A single ETF like VTI gives you exposure to 4,000+ US stocks for just 0.03% annually. Individual stocks offer higher potential returns but require significant research and carry concentration risk. Most financial advisors recommend a core portfolio of broad ETFs (80–90%) with individual stock picks as satellites (10–20%) for those who enjoy active research."}},
    {"@type":"Question","name":"What is the difference between ETFs and index funds?","acceptedAnswer":{"@type":"Answer","text":"ETFs and index mutual funds often track the same indices with similar expense ratios. Key differences: ETFs trade throughout the day like stocks (real-time pricing), while mutual funds settle once daily at market close. ETFs have no minimum investment (buy 1 share), while many index funds require $1,000–$3,000 minimums. ETFs are generally more tax-efficient due to their creation/redemption mechanism. For long-term buy-and-hold investors, performance differences are negligible."}},
    {"@type":"Question","name":"How many ETFs should I own in a portfolio?","acceptedAnswer":{"@type":"Answer","text":"A well-diversified portfolio needs just 3–5 ETFs: a US total market ETF (VTI or VOO), an international ETF (VXUS or EFA), a bond ETF (BND or AGG), and optionally a REIT or small-cap ETF. Owning 15+ ETFs often creates overlap — for example, VOO and VTI share 500 identical holdings. The 3-fund portfolio (US stocks, international stocks, bonds) remains one of the most effective and simple strategies recommended by Bogleheads."}}
  ]
};

export const meta = {
  title: "Free ETF Screener — Filter & Compare 50 Popular ETFs",
  description: "Screen 50 popular ETFs by category, expense ratio, AUM, dividend yield & YTD performance. Preset screens, head-to-head comparison tool & filtering across 8 categories.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="Free ETF Screener: Filter & Compare 50 Popular ETFs by Cost, Yield & Performance"
  description="Screen 50 popular ETFs instantly. Filter by category, expense ratio, AUM, dividend yield, and YTD return. Preset screens for cheapest, highest yield, and best performance. Head-to-head comparison tool."
  canonical="https://westmountfundamentals.com/etf-screener" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
header h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
header p.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.meta{color:var(--text-secondary);font-size:13px;margin-top:12px;font-family:'JetBrains Mono',monospace}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:16px;margin:32px 0}
.stat{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.stat .val{font-size:32px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.stat .label{font-size:13px;color:var(--text-secondary);margin-top:4px}

.presets-section{margin:32px 0}
.presets-section h2{font-size:22px;margin-bottom:12px}
.presets-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.preset-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;cursor:pointer;transition:border-color .2s}
.preset-card:hover,.preset-card.active{border-color:var(--accent-color)}
.preset-card.active{background:rgba(74,143,231,.06)}
.preset-card h3{font-size:15px;margin-bottom:4px;color:var(--accent-color)}
.preset-card p{font-size:13px;color:var(--text-secondary);margin-bottom:8px}
.preset-card .preset-criteria{font-size:11px;color:var(--text-secondary);font-family:'JetBrains Mono',monospace;line-height:1.8}

.filter-section{margin:32px 0}
.filter-section h2{font-size:22px;margin-bottom:12px}
.filter-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-bottom:16px}
.filter-group{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px}
.filter-group label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:8px}
.filter-group select,.filter-group input{width:100%;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 10px;border-radius:6px;font-size:13px;font-family:'Inter',sans-serif;box-sizing:border-box}
.filter-actions{display:flex;gap:12px;margin-top:12px}
.filter-actions button{padding:8px 18px;border-radius:6px;font-size:14px;cursor:pointer;font-weight:600;border:none}
.btn-primary{background:var(--accent-color);color:#fff}
.btn-primary:hover{opacity:.9}
.btn-secondary{background:var(--card-bg);color:var(--text-primary);border:1px solid var(--border-color) !important}
.btn-secondary:hover{border-color:var(--accent-color) !important}
.result-count{color:var(--text-secondary);font-size:13px;font-family:'JetBrains Mono',monospace;margin-bottom:12px}

.table-section{margin:32px 0}
.table-section h2{font-size:22px;margin-bottom:12px}
.search-bar{margin-bottom:16px}
.search-bar input{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:10px 14px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif;width:100%;max-width:400px;box-sizing:border-box}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;cursor:pointer;white-space:nowrap;border-bottom:1px solid var(--border-color);user-select:none;position:sticky;top:0}
th:hover{color:var(--accent-color)}
th.sorted-asc::after{content:' ▲';color:var(--accent-color)}
th.sorted-desc::after{content:' ▼';color:var(--accent-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color);white-space:nowrap}
tr:hover{background:rgba(74,143,231,.06)}
.ticker{font-family:'JetBrains Mono',monospace;font-weight:600;color:var(--accent-color)}
.num{font-family:'JetBrains Mono',monospace;text-align:right}
.pos{color:#22c55e}
.neg{color:#ef4444}

.compare-section{margin:32px 0}
.compare-section h2{font-size:22px;margin-bottom:12px}
.compare-desc{color:var(--text-secondary);font-size:14px;margin-bottom:16px}
.compare-controls{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;align-items:center}
.compare-controls select{background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:8px 12px;border-radius:6px;font-size:13px;font-family:'Inter',sans-serif;min-width:180px}
.compare-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.compare-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px}
.compare-card h3{font-size:18px;font-weight:700;color:var(--accent-color);font-family:'JetBrains Mono',monospace;margin-bottom:4px}
.compare-card .compare-name{font-size:13px;color:var(--text-secondary);margin-bottom:16px}
.compare-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-color);font-size:13px}
.compare-row:last-child{border-bottom:none}
.compare-label{color:var(--text-secondary)}
.compare-val{font-family:'JetBrains Mono',monospace;font-weight:600}
.compare-winner{color:var(--accent-color)}
.compare-empty{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:40px;text-align:center;color:var(--text-secondary);font-size:14px}

.category-section{margin:32px 0}
.category-section h2{font-size:22px;margin-bottom:16px}
.category-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px}
.category-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:14px;text-align:center}
.category-card .cat-name{font-size:12px;color:var(--text-secondary);margin-bottom:4px}
.category-card .cat-count{font-size:24px;font-weight:800;color:var(--accent-color);font-family:'JetBrains Mono',monospace}
.category-card .cat-avg{font-size:11px;color:var(--text-secondary);margin-top:2px}

.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px;line-height:1.7}

.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

.related-section{margin:32px 0}
.related-section h2{font-size:22px;margin-bottom:16px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.related-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px;text-decoration:none;transition:border-color .2s}
.related-card:hover{border-color:var(--accent-color);text-decoration:none}
.related-card h3{font-size:15px;margin-bottom:4px;color:var(--text-primary)}
.related-card p{font-size:13px;color:var(--text-secondary)}

.methodology{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.methodology h2{font-size:18px;margin-bottom:12px}
.methodology p{color:var(--text-secondary);font-size:14px;margin-bottom:10px;line-height:1.7}

.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}
.updated-badge{display:inline-block;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-secondary);font-size:12px;padding:4px 10px;border-radius:4px;margin-top:8px;font-family:'JetBrains Mono',monospace}

footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:640px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .filter-grid{grid-template-columns:1fr}
  .presets-grid{grid-template-columns:1fr}
  .category-grid{grid-template-columns:repeat(2,1fr)}
  .compare-grid{grid-template-columns:1fr}
  .compare-controls{flex-direction:column}
  .compare-controls select{width:100%}
  .related-grid{grid-template-columns:1fr}
}
  </style>

<div class="container">
    <h1>Free ETF Screener: Filter &amp; Compare 50 Popular ETFs</h1>
    <div class="updated-badge">Last Updated: March 2026</div>

    <div class="stats" id="stats"></div>

    <div class="presets-section">
      <h2>Preset Screens</h2>
      <div class="presets-grid" id="presets"></div>
    </div>

    <div class="filter-section">
      <h2>Custom Filters</h2>
      <div class="filter-grid">
        <div class="filter-group">
          <label>Category</label>
          <select id="fCat">
            <option value="">All Categories</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Expense Ratio</label>
          <select id="fER">
            <option value="">Any Expense Ratio</option>
            <option value="0-0.05">Ultra-Low (&le; 0.05%)</option>
            <option value="0-0.10">Under 0.10%</option>
            <option value="0.10-0.30">0.10% – 0.30%</option>
            <option value="0.30-0.60">0.30% – 0.60%</option>
            <option value="0.60-">0.60%+ (Premium)</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Dividend Yield</label>
          <select id="fYield">
            <option value="">Any Yield</option>
            <option value="0-0">No Dividend</option>
            <option value="0.01-2">Under 2%</option>
            <option value="2-4">2% – 4%</option>
            <option value="4-">4%+ (High Yield)</option>
          </select>
        </div>
        <div class="filter-group">
          <label>AUM Minimum</label>
          <select id="fAUM">
            <option value="">Any AUM</option>
            <option value="100-">$100B+</option>
            <option value="50-">$50B+</option>
            <option value="10-">$10B+</option>
            <option value="5-">$5B+</option>
            <option value="1-">$1B+</option>
          </select>
        </div>
        <div class="filter-group">
          <label>YTD Return</label>
          <select id="fYTD">
            <option value="">Any Performance</option>
            <option value="10-">Up 10%+</option>
            <option value="5-10">Up 5% – 10%</option>
            <option value="0-5">Up 0% – 5%</option>
            <option value="-100-0">Negative (Down)</option>
          </select>
        </div>
      </div>
      <div class="filter-actions">
        <button class="btn-primary" id="applyBtn">Apply Filters</button>
        <button class="btn-secondary" id="resetBtn">Reset All</button>
      </div>
    </div>

    <div class="table-section">
      <h2>Screening Results</h2>
      <div class="search-bar">
        <input type="text" id="search" placeholder="Search by ticker or ETF name…">
      </div>
      <div class="result-count" id="resultCount"></div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th data-key="ticker">Ticker</th>
              <th data-key="name">Name</th>
              <th data-key="category">Category</th>
              <th data-key="er" data-type="num">Expense Ratio</th>
              <th data-key="aum" data-type="num">AUM</th>
              <th data-key="ytd" data-type="num">YTD Return</th>
              <th data-key="yield" data-type="num">Div Yield</th>
              <th data-key="holdings" data-type="num">Holdings</th>
            </tr>
          </thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
    </div>

    <div class="compare-section">
      <h2>Head-to-Head ETF Comparison</h2>
      <p class="compare-desc">Select 2–3 ETFs to compare side-by-side on cost, yield, performance, and holdings.</p>
      <div class="compare-controls">
        <select id="cmp1"><option value="">Select ETF 1</option></select>
        <select id="cmp2"><option value="">Select ETF 2</option></select>
        <select id="cmp3"><option value="">Select ETF 3 (optional)</option></select>
        <button class="btn-primary" id="compareBtn">Compare</button>
      </div>
      <div class="compare-grid" id="compareGrid">
        <div class="compare-empty">Select 2–3 ETFs above and click Compare to see a side-by-side breakdown.</div>
      </div>
    </div>

    <div class="category-section">
      <h2>ETF Category Breakdown</h2>
      <div class="category-grid" id="categoryGrid"></div>
    </div>

    <div class="findings">
      <h2>Key Screening Insights</h2>
      <div class="finding-card">
        <h3>The Fee War Has Driven Costs to Near Zero</h3>
        <p>Broad US equity ETFs now average just 0.03% in expense ratios — that's $3 per year on a $10,000 investment. VOO, VTI, IVV, and SPLG all charge 0.03% or less, making cost virtually irrelevant for core equity holdings. The real fee differences emerge in thematic and sector ETFs, where expense ratios range from 0.10% to 0.75% — a gap that compounds to thousands of dollars over a 30-year investing horizon.</p>
      </div>
      <div class="finding-card">
        <h3>Dividend ETFs Offer 3–5x the Yield of Broad Market Funds</h3>
        <p>While SPY and VOO yield roughly 1.3%, dividend-focused ETFs like SCHD (3.5%), VYM (2.8%), and HDV (3.4%) deliver 2–4x higher income without sacrificing diversification. JEPI takes it further at 7.2% yield using a covered call strategy — though at the cost of capped upside. For retirees seeking income, a blend of SCHD and BND provides both equity growth and predictable distributions.</p>
      </div>
      <div class="finding-card">
        <h3>Growth ETFs Dominate YTD Performance but Carry Higher Valuations</h3>
        <p>QQQ (+12.8%), VGT (+11.5%), and SOXX (+10.2%) lead 2026 YTD returns, driven by continued AI and semiconductor demand. However, these growth-heavy ETFs carry elevated valuations and higher concentration risk — QQQ's top 10 holdings represent over 50% of assets. International value ETFs like EFA and VWO have lagged but trade at significant discounts, offering potential mean-reversion opportunity for patient investors.</p>
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div id="faq"></div>
    </div>

    <div class="related-section">
      <h2>Related Tools &amp; Research</h2>
      <div class="related-grid">
        <a class="related-card" href="/stock-screener">
          <h3>Stock Screener</h3>
          <p>Screen 50 S&amp;P 500 stocks by market cap, PE ratio, dividend yield, sector &amp; 52-week performance.</p>
        </a>
        <a class="related-card" href="/best-index-funds">
          <h3>Best Index Funds</h3>
          <p>Compare the top index funds for long-term investing — ranked by cost, diversification, and historical returns.</p>
        </a>
        <a class="related-card" href="/dividend-etf-comparison">
          <h3>Dividend ETF Comparison</h3>
          <p>Compare 21 dividend ETFs side-by-side: SCHD, VYM, JEPI, QYLD &amp; more ranked by yield and returns.</p>
        </a>
      </div>
    </div>

    <div class="methodology">
      <h2>Methodology</h2>
      <p>ETF data represents approximate values for 50 of the most widely held exchange-traded funds as of Q1 2026. Expense ratios are sourced from fund prospectuses. AUM (Assets Under Management), dividend yields, and YTD returns are based on publicly available data and may not reflect intraday changes. Holdings counts represent approximate numbers of underlying securities.</p>
      <p>Preset screens use commonly accepted thresholds: Cheapest ETFs (expense ratio &le; 0.10%), Highest Yield (dividend yield &ge; 3%), Largest AUM (assets &ge; $50B), and Best YTD Performance (YTD return &ge; 8%). Screens are for educational purposes and do not constitute buy recommendations.</p>
    </div>

    <div class="disclaimer">This tool provides data for informational and educational purposes only. Not investment advice. ETF data is approximate and may not reflect real-time values. Always verify data and read fund prospectuses before making investment decisions.</div>
</div>

  <script is:inline>
function escapeHTML(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

const ETFS = [
  // US Equity (7)
  {ticker:"SPY",name:"SPDR S&P 500 ETF Trust",category:"US Equity",er:0.09,aum:522,ytd:8.4,yield:1.3,holdings:503},
  {ticker:"VOO",name:"Vanguard S&P 500 ETF",category:"US Equity",er:0.03,aum:428,ytd:8.5,yield:1.3,holdings:503},
  {ticker:"IVV",name:"iShares Core S&P 500 ETF",category:"US Equity",er:0.03,aum:398,ytd:8.5,yield:1.3,holdings:503},
  {ticker:"VTI",name:"Vanguard Total Stock Market ETF",category:"US Equity",er:0.03,aum:382,ytd:8.2,yield:1.3,holdings:3645},
  {ticker:"QQQ",name:"Invesco QQQ Trust",category:"US Equity",er:0.20,aum:268,ytd:12.8,yield:0.5,holdings:101},
  {ticker:"SPLG",name:"SPDR Portfolio S&P 500 ETF",category:"US Equity",er:0.02,aum:38,ytd:8.5,yield:1.3,holdings:503},
  {ticker:"RSP",name:"Invesco S&P 500 Equal Weight ETF",category:"US Equity",er:0.20,aum:62,ytd:5.8,yield:1.5,holdings:503},
  // International (6)
