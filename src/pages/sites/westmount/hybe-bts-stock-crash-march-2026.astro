  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "NewsArticle",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": "2026-03-23T15:00:00Z",
      "dateModified": "2026-03-23T15:00:00Z",
      "publisher": { "@type": "Organization", "name": "Westmount Fundamentals" },
      "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
      "mainEntityOfPage": "https://westmountfundamentals.com/hybe-bts-stock-crash-march-2026/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Hybe shares fall on March 23, 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hybe (KOSPI: 352820) shares fell 15.5% on Monday, March 23, 2026, following the highly anticipated free BTS comeback concert in Seoul over the weekend. The concert drew approximately 104,000 attendees, significantly lower than the expected 260,000."
          }
        },
        {
          "@type": "Question",
          "name": "When and where was the BTS comeback concert held?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The free comeback concert was held in Gwanghwamun Square, Seoul on Saturday, March 22, 2026. This marked the first time all 7 members performed together since their 2022 hiatus for military service."
          }
        },
        {
          "@type": "Question",
          "name": "How many people attended the BTS comeback concert in Seoul?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Actual attendance was estimated at around 104,000 people, which was less than half of the expected 260,000. Strict crowd control measures were cited as one of the factors for the lower turnout."
          }
        },
        {
          "@type": "Question",
          "name": "Was the concert available to watch internationally?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, the concert was live-streamed globally on Netflix, reaching viewers in over 190 countries. Netflix viewership figures are expected to be released later this week."
          }
        },
        {
          "@type": "Question",
          "name": "What is next for BTS after the comeback concert?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BTS has an 82-date sold-out world tour ahead of them, along with the release of their new album, 'Arirang'."
          }
        }
      ]
    }
  ]
};

const faqItems = schema["@graph"][1].mainEntity;
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/hybe-bts-stock-crash-march-2026/" schema={JSON.stringify(schema)}>

<style is:inline>
  .news-article { max-width: 800px; margin: 0 auto; padding: 2rem 24px 3rem; }

