export const meta = {
  title: "Hybe Stock Plunges 15.5% Following BTS Comeback Concert Turnout — March 23, 2026",
  description: "Shares of Hybe (KOSPI: 352820) fell 15.5% after the BTS free comeback concert in Seoul drew less than half of the expected attendance despite global Netflix streaming.",
  category: "study",
  published: "2026-03-23"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "NewsArticle",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": "2026-03-23T15:00:00Z",
      "dateModified": "2026-03-23T15:00:00Z",
      "publisher": { "@type": "Organization", "name": "Westmount Fundamentals" },
      "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
      "mainEntityOfPage": "https://westmountfundamentals.com/hybe-bts-stock-crash-march-2026/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Hybe shares fall on March 23, 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hybe (KOSPI: 352820) shares fell 15.5% primarily because the highly anticipated BTS free comeback concert in Gwanghwamun Square drew roughly 104,000 attendees, significantly lower than the expected 260,000. Strict crowd control measures were also cited as a factor."
          }
        },
        {
          "@type": "Question",
          "name": "When and where was the BTS comeback concert?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The free comeback concert took place in Gwanghwamun Square, Seoul on Saturday, March 22, 2026. It marked the first time all seven members performed together since their hiatus began in 2022 for mandatory military service."
          }
        },
        {
          "@type": "Question",
          "name": "How many people attended the BTS comeback concert?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The actual attendance was approximately 104,000 people, which was less than half of the expected 260,000 attendees."
          }
        },
        {
          "@type": "Question",
          "name": "Was the BTS concert broadcast globally?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, the concert was live-streamed on Netflix to over 190 countries. Netflix viewership figures are expected to be released later in the week."
          }
        },
        {
          "@type": "Question",
          "name": "What are the upcoming plans for BTS?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BTS has a highly anticipated new album titled 'Arirang' and an upcoming 82-date sold-out world tour ahead."
          }
        }
      ]
    }
  ]
};

const faqItems = schema["@graph"][1].mainEntity;
