export const meta = {
  title: "Hybe Shares Plunge 15% Following Underwhelming BTS Comeback Concert — March 23, 2026",
  description: "Hybe (KOSPI: 352820) stock fell 15.5% after the highly anticipated BTS free comeback concert in Seoul drew less than half of expected attendance despite live-streaming to 190+ countries.",
  category: "study",
  published: "2026-03-23"
};

