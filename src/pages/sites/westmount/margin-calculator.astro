---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is the difference between margin and markup?","acceptedAnswer":{"@type":"Answer","text":"Margin and markup both measure profitability but from different perspectives. Margin is profit as a percentage of selling price — a $100 item with $40 cost has a 60% margin. Markup is profit as a percentage of cost — the same item has a 150% markup ($60 profit ÷ $40 cost). Margin is always lower than markup for the same transaction. A 50% markup equals a 33.3% margin. A 100% markup equals a 50% margin. Businesses typically use markup for pricing decisions and margin for financial reporting. The relationship is: Margin = Markup ÷ (1 + Markup) and Markup = Margin ÷ (1 − Margin)."}},
    {"@type":"Question","name":"How do you calculate gross profit margin?","acceptedAnswer":{"@type":"Answer","text":"Gross profit margin is calculated as: (Revenue − Cost of Goods Sold) ÷ Revenue × 100. For example, if you sell a product for $80 and it costs $30 to make, your gross profit is $50 and your gross margin is 62.5% ($50 ÷ $80 × 100). Gross margin only accounts for direct production costs (materials, labor, manufacturing) — it does not include overhead like rent, marketing, or salaries. It is the most commonly used profitability metric because it shows how efficiently a business converts revenue into profit before operating expenses."}},
    {"@type":"Question","name":"What is a good profit margin for a business?","acceptedAnswer":{"@type":"Answer","text":"Good profit margins vary dramatically by industry. SaaS companies typically achieve 70-85% gross margins due to low marginal costs. Retail businesses average 25-50% gross margins depending on the category. Restaurants operate on thin 60-70% gross margins (3-9% net). Manufacturing ranges from 25-40%. Professional services like consulting achieve 50-70%. As a general rule, gross margins above 50% are considered strong, 30-50% is average, and below 30% is thin. Net profit margins (after all expenses) are much lower — 10-20% is excellent for most industries."}},
    {"@type":"Question","name":"How do I convert between margin and markup?","acceptedAnswer":{"@type":"Answer","text":"To convert markup to margin: Margin = Markup ÷ (1 + Markup). For example, a 50% markup (0.50): 0.50 ÷ 1.50 = 0.333, or 33.3% margin. To convert margin to markup: Markup = Margin ÷ (1 − Margin). For example, a 40% margin (0.40): 0.40 ÷ 0.60 = 0.667, or 66.7% markup. Common equivalents to memorize: 100% markup = 50% margin, 50% markup = 33.3% margin, 33.3% markup = 25% margin. These conversions are essential for pricing strategy because suppliers quote markup while financial statements report margin."}},
    {"@type":"Question","name":"What is the difference between gross margin and net margin?","acceptedAnswer":{"@type":"Answer","text":"Gross margin measures profitability after subtracting only direct costs (cost of goods sold) from revenue. Net margin measures profitability after subtracting all expenses — COGS, operating expenses, interest, taxes, and depreciation. A company might have a 60% gross margin but only a 10% net margin after paying for rent, salaries, marketing, and taxes. Gross margin shows production efficiency, while net margin shows overall business profitability. Both are important: a high gross margin with low net margin suggests high overhead costs that may need to be addressed."}},
    {"@type":"Question","name":"How do I calculate the selling price from cost and desired margin?","acceptedAnswer":{"@type":"Answer","text":"To find the selling price when you know cost and desired margin: Selling Price = Cost ÷ (1 − Margin). For example, if an item costs $40 and you want a 60% margin: $40 ÷ (1 − 0.60) = $40 ÷ 0.40 = $100 selling price. A common mistake is adding the margin percentage to cost — that gives you markup pricing, not margin pricing. If you add 60% to $40, you get $64, which only gives you a 37.5% margin, not 60%. This distinction matters because margin-based pricing always results in a higher selling price than the equivalent markup percentage."}},
    {"@type":"Question","name":"How do discounts affect profit margin?","acceptedAnswer":{"@type":"Answer","text":"Discounts have a disproportionately large impact on profit margin. A 10% discount on price does not reduce profit by 10% — it reduces profit by much more. For example, a $100 item with $60 cost has a 40% margin and $40 profit. A 10% discount drops the price to $90, reducing profit to $30 — a 25% reduction in profit, not 10%. At a 20% discount ($80 price), profit falls to $20 — a 50% reduction. This is why even small discounts can devastate margins, and businesses need significantly higher volume to compensate for discounting."}},
    {"@type":"Question","name":"What markup percentage should I use for my business?","acceptedAnswer":{"@type":"Answer","text":"Markup percentages vary by industry and business model. Retail clothing typically uses 100-300% markup (keystone to triple keystone). Grocery stores use 5-25% markup due to high volume and perishability. Restaurants mark up food 200-400% and beverages 300-500%. Electronics retail uses 10-30% markup due to price transparency. Jewelry uses 100-300% markup. Professional services mark up labor costs 100-200%. The right markup depends on your overhead costs, competitive landscape, perceived value, and target profit margin. Start with your desired net margin and work backward to determine the required markup."}}
  ]
};

export const meta = {
  title: "Margin Calculator — Profit Margin, Markup & Discount Tool",
  description: "Calculate profit margin, markup percentage, and discount savings instantly. Visual margin bar, margin vs markup comparison, and industry average margins reference table.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="Margin Calculator: Profit Margin, Markup & Discount Calculator"
  description="Calculate gross margin, markup percentage, and discount savings instantly. Visual margin bar shows profitability. Compare margins across retail, SaaS, restaurants, and manufacturing."
  canonical="https://westmountfundamentals.com/margin-calculator" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.updated-badge{display:inline-block;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-secondary);font-size:12px;padding:4px 10px;border-radius:4px;margin-top:8px;font-family:'JetBrains Mono',monospace}

/* Mode Tabs */
.mode-tabs{display:flex;gap:4px;margin-bottom:20px;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:4px}
.mode-tab{flex:1;padding:10px 16px;background:none;border:none;color:var(--text-secondary);font-size:13px;font-weight:600;cursor:pointer;border-radius:6px;transition:all .2s;font-family:'Inter',sans-serif}
.mode-tab:hover{color:var(--text-primary)}
.mode-tab.active{background:var(--accent-color);color:#fff}

/* Calculator */
.calc-section{margin:32px 0}
.calc-section h2{font-size:22px;margin-bottom:16px}
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.calc-inputs{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.calc-results{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.input-group{margin-bottom:16px}
.input-group label{display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:6px}
.input-group input{width:100%;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:10px 12px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif;box-sizing:border-box}
.input-group input:focus{outline:none;border-color:var(--accent-color)}
.input-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.input-hint{font-size:11px;color:var(--text-secondary);margin-top:4px}
.calc-btn{width:100%;padding:12px;background:var(--accent-color);color:#fff;border:none;border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;margin-top:8px}
.calc-btn:hover{opacity:.9}
.mode-panel{display:none}
.mode-panel.active{display:block}

/* Results */
.result-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px}
.result-box{text-align:center;padding:16px 8px;background:rgba(74,143,231,.04);border-radius:8px;border:1px solid var(--border-color)}
.result-box .val{font-size:28px;font-weight:800;font-family:'JetBrains Mono',monospace;color:var(--accent-color)}
.result-box .label{font-size:11px;color:var(--text-secondary);margin-top:4px;text-transform:uppercase;letter-spacing:.5px}
.result-box.highlight{border-color:var(--accent-color);background:rgba(74,143,231,.08)}
.result-placeholder{text-align:center;padding:40px 20px;color:var(--text-secondary);font-size:14px}

/* Margin Bar */
.margin-bar-section{margin-top:20px}
.margin-bar-label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:10px}
.margin-bar-wrap{position:relative;height:44px;border-radius:6px;overflow:hidden;background:var(--card-bg);border:1px solid var(--border-color)}
.margin-bar-inner{display:flex;height:100%;width:100%}
.margin-bar-cost{background:#ef4444;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;transition:width .4s ease;min-width:30px}
.margin-bar-profit{background:#22c55e;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;transition:width .4s ease;min-width:30px}
.margin-bar-discount{background:#f59e0b;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff;transition:width .4s ease;min-width:20px}
.margin-bar-legend{display:flex;gap:16px;justify-content:center;margin-top:8px;font-size:12px;color:var(--text-secondary)}
.margin-bar-legend span{display:flex;align-items:center;gap:4px}
.margin-bar-legend .dot{width:10px;height:10px;border-radius:2px;display:inline-block}

/* Comparison Table */
.comparison-section{margin:32px 0}
.comparison-section h2{font-size:22px;margin-bottom:16px}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;white-space:nowrap;border-bottom:1px solid var(--border-color)}
td{padding:10px 14px;border-bottom:1px solid var(--border-color)}
tr:hover{background:rgba(74,143,231,.06)}
.num{font-family:'JetBrains Mono',monospace;text-align:right}

/* Industry Averages */
.industry-section{margin:32px 0}
.industry-section h2{font-size:22px;margin-bottom:16px}
.industry-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px}
.industry-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px}
.industry-card .ind-name{font-size:14px;font-weight:700;margin-bottom:8px}
.industry-card .ind-row{display:flex;justify-content:space-between;font-size:12px;padding:3px 0;color:var(--text-secondary)}
.industry-card .ind-row .ind-val{font-family:'JetBrains Mono',monospace;color:var(--text-primary);font-weight:600}
.ind-bar-wrap{height:8px;background:var(--border-color);border-radius:4px;margin-top:8px;overflow:hidden}
.ind-bar{height:100%;border-radius:4px;background:var(--accent-color);transition:width .4s ease}

/* Findings */
.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px;line-height:1.7}

/* FAQ */
.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

/* Related */
.related-section{margin:32px 0}
.related-section h2{font-size:22px;margin-bottom:16px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.related-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px;text-decoration:none;transition:border-color .2s}
.related-card:hover{border-color:var(--accent-color);text-decoration:none}
.related-card h3{font-size:15px;margin-bottom:4px;color:var(--text-primary)}
.related-card p{font-size:13px;color:var(--text-secondary)}

.methodology{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.methodology h2{font-size:18px;margin-bottom:12px}
.methodology p{color:var(--text-secondary);font-size:14px;margin-bottom:10px;line-height:1.7}

.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}

footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:768px){
  .calc-grid{grid-template-columns:1fr}
  .result-grid{grid-template-columns:1fr 1fr 1fr}
  .industry-grid{grid-template-columns:1fr}
  .related-grid{grid-template-columns:1fr}
  .mode-tabs{flex-direction:column}
}
@media(max-width:480px){
  .result-grid{grid-template-columns:1fr}
  .input-row{grid-template-columns:1fr}
}
  </style>

<div class="container">
    <h1>Margin Calculator: Profit Margin, Markup &amp; Discount</h1>
    <p class="subtitle">Calculate gross margin, markup percentage, and discount impact. Compare your margins against industry averages for retail, SaaS, restaurants, and manufacturing.</p>
    <div class="updated-badge">Last Updated: March 2026</div>

    <div class="calc-section">
      <h2>Calculate Margins</h2>
      <div class="mode-tabs">
        <button class="mode-tab active" data-mode="margin">Profit Margin</button>
        <button class="mode-tab" data-mode="markup">Markup Calculator</button>
        <button class="mode-tab" data-mode="discount">Discount Calculator</button>
      </div>
      <div class="calc-grid">
        <div class="calc-inputs">
          <!-- Profit Margin Mode -->
          <div class="mode-panel active" id="panel-margin">
            <div class="input-group">
              <label>Revenue / Selling Price ($)</label>
              <input type="number" id="marginRevenue" placeholder="e.g. 100.00" step="0.01" min="0">
              <div class="input-hint">Total revenue or per-unit selling price</div>
            </div>
            <div class="input-group">
              <label>Cost / COGS ($)</label>
              <input type="number" id="marginCost" placeholder="e.g. 40.00" step="0.01" min="0">
              <div class="input-hint">Cost of goods sold or per-unit cost</div>
            </div>
            <button class="calc-btn" id="calcMarginBtn">Calculate Profit Margin</button>
          </div>

          <!-- Markup Mode -->
          <div class="mode-panel" id="panel-markup">
            <div class="input-group">
              <label>Cost ($)</label>
              <input type="number" id="markupCost" placeholder="e.g. 40.00" step="0.01" min="0">
              <div class="input-hint">Your cost per unit or total cost</div>
            </div>
            <div class="input-group">
              <label>Markup (%)</label>
              <input type="number" id="markupPct" placeholder="e.g. 50" step="0.1" min="0">
              <div class="input-hint">Desired markup percentage over cost</div>
            </div>
            <button class="calc-btn" id="calcMarkupBtn">Calculate Selling Price</button>
          </div>

          <!-- Discount Mode -->
          <div class="mode-panel" id="panel-discount">
            <div class="input-group">
              <label>Original Price ($)</label>
              <input type="number" id="discountOriginal" placeholder="e.g. 100.00" step="0.01" min="0">
              <div class="input-hint">Price before discount</div>
            </div>
            <div class="input-group">
              <label>Discount (%)</label>
              <input type="number" id="discountPct" placeholder="e.g. 20" step="0.1" min="0" max="100">
              <div class="input-hint">Discount percentage off original price</div>
            </div>
            <button class="calc-btn" id="calcDiscountBtn">Calculate Sale Price</button>
          </div>
        </div>
        <div class="calc-results" id="calcResults">
          <div class="result-placeholder">Enter revenue and cost to calculate profit margin, markup percentage, and see a visual breakdown of your margins.</div>
        </div>
      </div>
    </div>

    <div class="comparison-section">
      <h2>Margin vs Markup — Conversion Table</h2>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px">Margin and markup are not the same. This table shows the exact conversion between the two — a common source of pricing errors.</p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Markup %</th>
              <th class="num">Margin %</th>
              <th class="num">Cost $40 → Price</th>
              <th class="num">Profit</th>
              <th>Common Use</th>
            </tr>
          </thead>
          <tbody id="conversionTbody"></tbody>
        </table>
      </div>
    </div>

    <div class="industry-section">
      <h2>Industry Average Margins — Reference</h2>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px">Gross margins vary dramatically by industry. Use these benchmarks to see how your margins compare to typical businesses.</p>
      <div class="industry-grid" id="industryGrid"></div>
    </div>

    <div class="findings">
      <h2>Margin Calculator: Key Insights</h2>
      <div class="finding-card">
        <h3>Margin vs Markup: The #1 Pricing Mistake</h3>
        <p>Confusing margin with markup is the most common pricing error in business. If you want a 50% margin but apply a 50% markup, you'll only achieve a 33.3% margin. The difference compounds — on $1M in revenue, that mistake costs you $166,700 in expected profit. Always clarify whether pricing targets are based on margin (percentage of selling price) or markup (percentage of cost) before setting prices.</p>
      </div>
      <div class="finding-card">
        <h3>Small Discounts Destroy Margins Disproportionately</h3>
        <p>A 10% discount does not reduce profit by 10%. If your margin is 40%, a 10% price cut eliminates 25% of your gross profit. A 20% discount wipes out 50% of profit. To maintain the same total profit after a 10% discount at 40% margin, you need to sell 33% more units. This is why successful businesses focus on value-based pricing rather than competing on discounts.</p>
      </div>
      <div class="finding-card">
        <h3>Gross Margin Is Only Half the Story</h3>
        <p>A 70% gross margin means nothing if operating expenses consume 65% of revenue, leaving only 5% net margin. SaaS companies often report 80%+ gross margins but spend heavily on sales and R&amp;D, resulting in net margins of 10-25%. Restaurants with 65% gross margins frequently operate at 3-9% net margins due to labor, rent, and overhead. Always analyze both gross and net margins to understand true business profitability.</p>
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div id="faq"></div>
    </div>

    <div class="related-section">
      <h2>Related Tools &amp; Research</h2>
      <div class="related-grid">
        <a class="related-card" href="/sites/westmount/pe-ratio-calculator">
          <h3>PE Ratio Calculator</h3>
          <p>Calculate trailing PE, forward PE, and PEG ratio. Compare stock valuations against S&amp;P 500 and sector averages.</p>
        </a>
        <a class="related-card" href="/sites/westmount/investment-calculator">
          <h3>Investment Calculator</h3>
          <p>Model compound growth, dividend reinvestment, and portfolio projections for long-term investment planning.</p>
        </a>
      </div>
    </div>

    <div class="methodology">
      <h2>Methodology</h2>
      <p>Gross margin is calculated as (Revenue − Cost) ÷ Revenue × 100. Markup is calculated as (Revenue − Cost) ÷ Cost × 100. Net margin subtracts all operating expenses, interest, and taxes from revenue. The discount calculator computes sale price as Original Price × (1 − Discount Rate).</p>
      <p>Industry average margins are approximate values based on publicly reported financial data from major companies in each sector as of Q1 2026. Actual margins vary by company size, geography, and business model. All figures are for educational reference.</p>
    </div>

    <div class="disclaimer">This calculator is for informational and educational purposes only. Not financial advice. Margins vary by business model, location, and scale. Always consult with a financial professional for business pricing decisions.</div>
</div>

  <script is:inline>
// Mode tab switching
const modeTabs = document.querySelectorAll('.mode-tab');
const modePanels = document.querySelectorAll('.mode-panel');
modeTabs.forEach(tab => {
  tab.addEventListener('click', () => {
    modeTabs.forEach(t => t.classList.remove('active'));
    modePanels.forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('panel-' + tab.dataset.mode).classList.add('active');
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder">Enter values and click calculate to see results.</div>';
  });
});

// Enter key support
document.querySelectorAll('.calc-inputs input').forEach(input => {
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      const panel = input.closest('.mode-panel');
      if (panel) panel.querySelector('.calc-btn').click();
    }
  });
});

// Margin calculator
document.getElementById('calcMarginBtn').addEventListener('click', () => {
  const revenue = parseFloat(document.getElementById('marginRevenue').value);
  const cost = parseFloat(document.getElementById('marginCost').value);
  const results = document.getElementById('calcResults');

  if (!revenue || revenue <= 0) { results.innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid revenue / selling price.</div>'; return; }
  if (isNaN(cost) || cost < 0) { results.innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid cost.</div>'; return; }
  if (cost >= revenue) { results.innerHTML = '<div class="result-placeholder" style="color:#ef4444">Cost must be less than revenue for a positive margin.</div>'; return; }

  const profit = revenue - cost;
  const grossMargin = (profit / revenue) * 100;
  const markup = (profit / cost) * 100;
  const costPct = (cost / revenue) * 100;

  let html = '<div class="result-grid">';
  html += '<div class="result-box highlight"><div class="val">' + grossMargin.toFixed(1) + '%</div><div class="label">Gross Margin</div></div>';
  html += '<div class="result-box"><div class="val">' + markup.toFixed(1) + '%</div><div class="label">Markup</div></div>';
  html += '<div class="result-box"><div class="val">$' + profit.toFixed(2) + '</div><div class="label">Profit</div></div>';
  html += '</div>';

  // Margin bar
  html += '<div class="margin-bar-section">';
  html += '<div class="margin-bar-label">Revenue Breakdown</div>';
  html += '<div class="margin-bar-wrap"><div class="margin-bar-inner">';
  html += '<div class="margin-bar-cost" style="width:' + costPct + '%">Cost $' + cost.toFixed(2) + '</div>';
  html += '<div class="margin-bar-profit" style="width:' + (100 - costPct) + '%">Profit $' + profit.toFixed(2) + '</div>';
  html += '</div></div>';
  html += '<div class="margin-bar-legend"><span><span class="dot" style="background:#ef4444"></span> Cost (' + costPct.toFixed(1) + '%)</span>';
  html += '<span><span class="dot" style="background:#22c55e"></span> Profit (' + grossMargin.toFixed(1) + '%)</span></div>';
  html += '</div>';

  // Additional metrics
  html += '<div style="margin-top:16px;font-size:13px;color:var(--text-secondary);line-height:2">';
  html += '<div>Revenue: <strong style="color:var(--text-primary)">$' + revenue.toFixed(2) + '</strong></div>';
  html += '<div>Cost of Goods: <strong style="color:var(--text-primary)">$' + cost.toFixed(2) + '</strong> (' + costPct.toFixed(1) + '% of revenue)</div>';
  html += '<div>Gross Profit: <strong style="color:#22c55e">$' + profit.toFixed(2) + '</strong></div>';
  html += '<div>Margin: <strong style="color:var(--text-primary)">' + grossMargin.toFixed(2) + '%</strong> \u2192 Equivalent Markup: <strong style="color:var(--text-primary)">' + markup.toFixed(2) + '%</strong></div>';
  html += '<div>Multiplier: <strong style="color:var(--text-primary)">' + (revenue / cost).toFixed(3) + 'x</strong> cost</div>';
  html += '</div>';

  results.innerHTML = html;
});

// Markup calculator
document.getElementById('calcMarkupBtn').addEventListener('click', () => {
  const cost = parseFloat(document.getElementById('markupCost').value);
  const markupPct = parseFloat(document.getElementById('markupPct').value);
  const results = document.getElementById('calcResults');

  if (!cost || cost <= 0) { results.innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid cost.</div>'; return; }
  if (isNaN(markupPct) || markupPct < 0) { results.innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid markup percentage.</div>'; return; }

  const profit = cost * (markupPct / 100);
  const sellingPrice = cost + profit;
  const margin = (profit / sellingPrice) * 100;
  const costPct = (cost / sellingPrice) * 100;

  let html = '<div class="result-grid">';
  html += '<div class="result-box highlight"><div class="val">$' + sellingPrice.toFixed(2) + '</div><div class="label">Selling Price</div></div>';
  html += '<div class="result-box"><div class="val">$' + profit.toFixed(2) + '</div><div class="label">Profit</div></div>';
  html += '<div class="result-box"><div class="val">' + margin.toFixed(1) + '%</div><div class="label">Margin</div></div>';
  html += '</div>';

  // Margin bar
  html += '<div class="margin-bar-section">';
  html += '<div class="margin-bar-label">Price Breakdown</div>';
  html += '<div class="margin-bar-wrap"><div class="margin-bar-inner">';
  html += '<div class="margin-bar-cost" style="width:' + costPct + '%">Cost $' + cost.toFixed(2) + '</div>';
  html += '<div class="margin-bar-profit" style="width:' + (100 - costPct) + '%">Profit $' + profit.toFixed(2) + '</div>';
  html += '</div></div>';
  html += '<div class="margin-bar-legend"><span><span class="dot" style="background:#ef4444"></span> Cost (' + costPct.toFixed(1) + '%)</span>';
  html += '<span><span class="dot" style="background:#22c55e"></span> Profit (' + margin.toFixed(1) + '%)</span></div>';
  html += '</div>';

  html += '<div style="margin-top:16px;font-size:13px;color:var(--text-secondary);line-height:2">';
  html += '<div>Cost: <strong style="color:var(--text-primary)">$' + cost.toFixed(2) + '</strong></div>';
  html += '<div>Markup: <strong style="color:var(--text-primary)">' + markupPct.toFixed(1) + '%</strong> \u2192 Equivalent Margin: <strong style="color:var(--text-primary)">' + margin.toFixed(2) + '%</strong></div>';
  html += '<div>Selling Price: <strong style="color:#22c55e">$' + sellingPrice.toFixed(2) + '</strong></div>';
  html += '<div>Multiplier: <strong style="color:var(--text-primary)">' + (sellingPrice / cost).toFixed(3) + 'x</strong> cost</div>';
  html += '</div>';

  results.innerHTML = html;
});

// Discount calculator
document.getElementById('calcDiscountBtn').addEventListener('click', () => {
  const original = parseFloat(document.getElementById('discountOriginal').value);
  const discountPct = parseFloat(document.getElementById('discountPct').value);
  const results = document.getElementById('calcResults');

  if (!original || original <= 0) { results.innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid original price.</div>'; return; }
  if (isNaN(discountPct) || discountPct < 0 || discountPct > 100) { results.innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid discount percentage (0-100).</div>'; return; }

  const savings = original * (discountPct / 100);
  const salePrice = original - savings;
  const salePct = (salePrice / original) * 100;

  let html = '<div class="result-grid">';
  html += '<div class="result-box highlight"><div class="val">$' + salePrice.toFixed(2) + '</div><div class="label">Sale Price</div></div>';
  html += '<div class="result-box"><div class="val">$' + savings.toFixed(2) + '</div><div class="label">You Save</div></div>';
  html += '<div class="result-box"><div class="val">' + discountPct.toFixed(1) + '%</div><div class="label">Discount</div></div>';
  html += '</div>';

  // Margin bar
  html += '<div class="margin-bar-section">';
  html += '<div class="margin-bar-label">Price Breakdown</div>';
  html += '<div class="margin-bar-wrap"><div class="margin-bar-inner">';
  html += '<div class="margin-bar-profit" style="width:' + salePct + '%">Sale $' + salePrice.toFixed(2) + '</div>';
  html += '<div class="margin-bar-discount" style="width:' + (100 - salePct) + '%">-$' + savings.toFixed(2) + '</div>';
  html += '</div></div>';
  html += '<div class="margin-bar-legend"><span><span class="dot" style="background:#22c55e"></span> Sale Price (' + salePct.toFixed(1) + '%)</span>';
  html += '<span><span class="dot" style="background:#f59e0b"></span> Savings (' + discountPct.toFixed(1) + '%)</span></div>';
  html += '</div>';

  html += '<div style="margin-top:16px;font-size:13px;color:var(--text-secondary);line-height:2">';
  html += '<div>Original Price: <strong style="color:var(--text-primary)">$' + original.toFixed(2) + '</strong></div>';
  html += '<div>Discount: <strong style="color:#f59e0b">' + discountPct.toFixed(1) + '%</strong> (-$' + savings.toFixed(2) + ')</div>';
  html += '<div>Final Price: <strong style="color:#22c55e">$' + salePrice.toFixed(2) + '</strong></div>';

  // Show what additional discounts would do
  if (discountPct < 50) {
    const d2 = discountPct * 2;
    const s2 = original * (d2 / 100);
    html += '<div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border-color)">At ' + d2.toFixed(0) + '% discount: <strong style="color:var(--text-primary)">$' + (original - s2).toFixed(2) + '</strong> (save $' + s2.toFixed(2) + ')</div>';
  }
  html += '</div>';

  results.innerHTML = html;
});

