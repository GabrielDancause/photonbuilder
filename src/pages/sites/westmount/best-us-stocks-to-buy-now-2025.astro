  <script>
    document.addEventListener('astro:page-load', () => {
        const container = document.querySelector('.page-content');
        if (!container || container.dataset.initialized) return;
        container.dataset.initialized = "true";

        const applyBtn = document.getElementById('applyFilters');
        if (applyBtn) {
            applyBtn.addEventListener('click', () => {
                const sectorFilter = document.getElementById('sectorFilter').value;
                const minYield = parseFloat(document.getElementById('minYield').value) || 0;

                // Filter rows
                const rows = document.querySelectorAll('.asset-row');
                rows.forEach(row => {
                    const sector = row.dataset.sector;
                    const yld = parseFloat(row.dataset.yield) || 0;

                    let show = true;
                    if (sectorFilter !== 'All' && sector !== sectorFilter) show = false;
                    if (yld < minYield) show = false;

                    row.style.display = show ? '' : 'none';
                });

                // Filter cards
                const cards = document.querySelectorAll('.asset-card');
                cards.forEach(card => {
                    const sector = card.dataset.sector;
                    const yld = parseFloat(card.dataset.yield) || 0;

                    let show = true;
                    if (sectorFilter !== 'All' && sector !== sectorFilter) show = false;
                    if (yld < minYield) show = false;

                    card.style.display = show ? 'block' : 'none';
                });
            });
        }
    });
  </script>

  <script is:inline>
    // Sortable table script
    function sortTable(n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById("assetTable");
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let valX = x.innerHTML.toLowerCase().replace(/[^0-9.-]+/g,"");
          let valY = y.innerHTML.toLowerCase().replace(/[^0-9.-]+/g,"");

          let isNum = !isNaN(parseFloat(valX)) && !isNaN(parseFloat(valY));

          if (dir == "asc") {
            if (isNum) {
                if (parseFloat(valX) > parseFloat(valY)) { shouldSwitch = true; break; }
            } else {
                if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            }
          } else if (dir == "desc") {
            if (isNum) {
                if (parseFloat(valX) < parseFloat(valY)) { shouldSwitch = true; break; }
            } else {
                if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) { shouldSwitch = true; break; }
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }
  </script>

