    // Sortable table
    function sortTable(n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById("summary-table");
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let valX = x.getAttribute('data-value') || x.innerHTML.replace(/[\$,%]/g, '').trim();
          let valY = y.getAttribute('data-value') || y.innerHTML.replace(/[\$,%]/g, '').trim();

          if (valX === 'N/A') valX = dir === 'asc' ? 999999999999999 : -999999999999999;
          else if (!isNaN(valX)) valX = parseFloat(valX);

          if (valY === 'N/A') valY = dir === 'asc' ? 999999999999999 : -999999999999999;
          else if (!isNaN(valY)) valY = parseFloat(valY);

          if (dir == "asc") {
            if (valX > valY) { shouldSwitch = true; break; }
          } else if (dir == "desc") {
            if (valX < valY) { shouldSwitch = true; break; }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }

    // Filtering
    document.getElementById('expense-filter').addEventListener('change', filterCards);

    function filterCards() {
      const maxExpense = document.getElementById('expense-filter').value;
      const cards = document.querySelectorAll('.item-card');

      cards.forEach(card => {
        let expenseRatio = 999;
        const textElements = card.querySelectorAll('div');
        for (let el of textElements) {
          if (el.textContent.includes('Expense Ratio:')) {
             const match = el.textContent.match(/([0-9.]+)%/);
             if (match) expenseRatio = parseFloat(match[1]);
          }
        }

        let show = true;
        if (maxExpense !== 'all') {
           if (expenseRatio > parseFloat(maxExpense)) {
              show = false;
           }
        }

        card.style.display = show ? 'block' : 'none';
      });
