  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let currentMode = 'single';
let cardIdCounter = 0;
let singleMinSchedule = [];
let singleFixSchedule = [];
let multiSchedule = [];
let multiNoExtraSchedule = [];

// ─── MODE SWITCHING ───
window.setMode = (mode) => {
    currentMode = mode;
    document.getElementById('tab-single').classList.toggle('active', mode === 'single');
    document.getElementById('tab-multi').classList.toggle('active', mode === 'multi');
    document.getElementById('single-mode').style.display = mode === 'single' ? 'block' : 'none';
    document.getElementById('multi-mode').style.display = mode === 'multi' ? 'block' : 'none';
    calculate();
};

// ─── SINGLE CARD LOGIC ───
function simulateSingleMinimum(balance, apr, minFixed, minPct, minType) {
    if (balance <= 0) return { schedule: [], totalInterest: 0, months: 0 };
    const monthlyRate = apr / 100 / 12;
    const schedule = [];
    let remaining = balance;
    let totalInterest = 0;
    let month = 0;
    const maxMonths = 600;
    const floorPayment = 25;

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        const interest = remaining * monthlyRate;
        let minPay;
        if (minType === 'percent') {
            minPay = Math.max(remaining * (minPct / 100), floorPayment);
        } else {
            minPay = minFixed;
        }
        let payment = Math.min(minPay, remaining + interest);
        let principal = payment - interest;
        if (principal < 0) principal = 0;
        remaining -= principal;
        if (remaining < 0.01) remaining = 0;
        totalInterest += interest;

        schedule.push({
            month, payment, principal, interest,
            totalBalance: remaining, totalInterest
        });
    }

    return { schedule, totalInterest, months: month };
}

function simulateSingleFixed(balance, apr, fixedPayment) {
    if (balance <= 0 || fixedPayment <= 0) return { schedule: [], totalInterest: 0, months: 0 };
    const monthlyRate = apr / 100 / 12;
    const schedule = [];
    let remaining = balance;
    let totalInterest = 0;
    let month = 0;
    const maxMonths = 600;

    // Check if payment covers interest
    const firstInterest = remaining * monthlyRate;
    if (fixedPayment <= firstInterest) {
        return { schedule: [], totalInterest: 0, months: -1 }; // never pays off
    }

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        const interest = remaining * monthlyRate;
        let payment = Math.min(fixedPayment, remaining + interest);
        let principal = payment - interest;
        if (principal < 0) principal = 0;
        remaining -= principal;
        if (remaining < 0.01) remaining = 0;
        totalInterest += interest;

        schedule.push({
            month, payment, principal, interest,
            totalBalance: remaining, totalInterest
        });
    }

    return { schedule, totalInterest, months: month };
}

// ─── MULTI CARD LOGIC ───
const defaultCards = [
    { name: 'Visa Platinum', balance: 4200, apr: 24.99, minPayment: 100 },
    { name: 'Mastercard Rewards', balance: 7800, apr: 21.49, minPayment: 180 },
    { name: 'Store Card', balance: 1500, apr: 28.99, minPayment: 40 },
];

function addCard(name, balance, apr, minPayment) {
    const id = cardIdCounter++;
    const list = document.getElementById('card-list');
    const row = document.createElement('div');
    row.className = 'card-row';
    row.id = 'card-' + id;
    row.innerHTML = `
        <div class="input-group">
            ${id === 0 ? '<label>Card Name</label>' : ''}
            <div class="input-wrapper">
                <input type="text" class="card-name" value="${name || ''}" placeholder="e.g. Visa Platinum">
            </div>
        </div>
        <div class="input-group">
            ${id === 0 ? '<label>Balance</label>' : ''}
            <div class="input-wrapper has-prefix">
                <span class="prefix">$</span>
                <input type="number" class="card-balance" value="${balance || ''}" min="0" step="100" placeholder="0">
            </div>
        </div>
        <div class="input-group">
            ${id === 0 ? '<label>APR</label>' : ''}
            <div class="input-wrapper has-suffix">
                <span class="suffix">%</span>
                <input type="number" class="card-apr" value="${apr || ''}" min="0" max="50" step="0.01" placeholder="0">
            </div>
        </div>
        <div class="input-group">
            ${id === 0 ? '<label>Min. Payment</label>' : ''}
            <div class="input-wrapper has-prefix">
                <span class="prefix">$</span>
                <input type="number" class="card-min" value="${minPayment || ''}" min="0" step="5" placeholder="0">
            </div>
        </div>
        <div class="input-group">
            ${id === 0 ? '<label>&nbsp;</label>' : ''}
            <button class="remove-btn" onclick="removeCard(${id})" title="Remove card">&times;</button>
        </div>
    `;
    list.appendChild(row);
    row.querySelectorAll('input').forEach(inp => inp.addEventListener('input', calculate));
    calculate();
}

window.addCard = addCard;

window.removeCard = (id) => {
    const row = document.getElementById('card-' + id);
    if (row) { row.remove(); calculate(); }
};

function getCards() {
    const rows = document.querySelectorAll('.card-row');
    const cards = [];
    rows.forEach(row => {
        const name = row.querySelector('.card-name').value || 'Unnamed';
        const balance = parseFloat(row.querySelector('.card-balance').value) || 0;
        const apr = parseFloat(row.querySelector('.card-apr').value) || 0;
        const minPayment = parseFloat(row.querySelector('.card-min').value) || 0;
        if (balance > 0) cards.push({ name, balance, apr, minPayment });
    });
    return cards;
}

function simulateMultiCard(cards, extraMonthly) {
    if (cards.length === 0) return { schedule: [], totalInterest: 0, months: 0, cardPayoffs: [] };

    let active = cards.map(d => ({ ...d, remaining: d.balance }));
    // Avalanche: highest APR first
    active.sort((a, b) => b.apr - a.apr || a.balance - b.balance);

    const schedule = [];
    const cardPayoffs = [];
    let totalInterest = 0;
    let month = 0;
    const maxMonths = 600;

    while (active.some(d => d.remaining > 0.01) && month < maxMonths) {
        month++;
        let extraLeft = extraMonthly;
        let monthInterest = 0;
        let monthPrincipal = 0;
        let monthPayment = 0;
        const paidOff = [];

        // Minimums
        for (const d of active) {
            if (d.remaining <= 0.01) continue;
            const interest = d.remaining * (d.apr / 100 / 12);
            monthInterest += interest;
            let payment = Math.min(d.minPayment, d.remaining + interest);
            let principal = payment - interest;
            if (principal < 0) principal = 0;
            d.remaining -= principal;
            monthPrincipal += principal;
            monthPayment += payment;
        }

        // Extra payments to highest-APR card
        const targets = active.filter(d => d.remaining > 0.01).sort((a, b) => b.apr - a.apr || a.remaining - b.remaining);
        for (const t of targets) {
            if (extraLeft <= 0.01) break;
            const apply = Math.min(extraLeft, t.remaining);
            t.remaining -= apply;
            extraLeft -= apply;
            monthPrincipal += apply;
            monthPayment += apply;
        }

        totalInterest += monthInterest;

        for (const d of active) {
            if (d.remaining <= 0.01 && !cardPayoffs.find(p => p.name === d.name)) {
                d.remaining = 0;
                cardPayoffs.push({ name: d.name, month });
                paidOff.push(d.name);
            }
        }

        const totalRemaining = active.reduce((s, d) => s + Math.max(0, d.remaining), 0);
        schedule.push({
            month, payment: monthPayment, principal: monthPrincipal,
            interest: monthInterest, totalBalance: totalRemaining,
            totalInterest, paidOff
        });
        if (totalRemaining <= 0.01) break;
    }

    return { schedule, totalInterest, months: month, cardPayoffs };
}

// ─── CALCULATE ───
function calculate() {
    if (currentMode === 'single') {
        calculateSingle();
    } else {
        calculateMulti();
    }
}

function calculateSingle() {
    const balance = parseFloat(document.getElementById('s-balance').value) || 0;
    const apr = parseFloat(document.getElementById('s-apr').value) || 0;
    const minType = document.getElementById('s-min-type').value;
    const minFixed = parseFloat(document.getElementById('s-min-fixed').value) || 0;
    const minPct = parseFloat(document.getElementById('s-min-pct').value) || 2;
    const extra = parseFloat(document.getElementById('s-extra').value) || 0;

    if (balance <= 0) {
        clearSingleResults();
        return;
    }

    // Minimum-only simulation
    const minResult = simulateSingleMinimum(balance, apr, minFixed, minPct, minType);
    singleMinSchedule = minResult.schedule;

    // Initial minimum to determine fixed payment
    let initialMin;
    if (minType === 'percent') {
        initialMin = Math.max(balance * (minPct / 100), 25);
    } else {
        initialMin = minFixed;
    }

    const fixedPayment = initialMin + extra;
    const fixResult = simulateSingleFixed(balance, apr, fixedPayment);
    singleFixSchedule = fixResult.schedule;

    // Min results
    document.getElementById('min-payment').innerText = minType === 'percent' ? fmt(initialMin) + ' (initial)' : fmt(minFixed);
    document.getElementById('min-months').innerText = minResult.months === -1 ? 'Never' : formatMonths(minResult.months);
    document.getElementById('min-interest').innerText = fmt(minResult.totalInterest);
    document.getElementById('min-total').innerText = fmt(balance + minResult.totalInterest);
    document.getElementById('min-date').innerText = minResult.months > 0 ? futureDate(minResult.months) : '—';

    // Fixed results
    if (fixResult.months === -1) {
        document.getElementById('fix-payment').innerText = fmt(fixedPayment);
        document.getElementById('fix-months').innerText = 'Never';
        document.getElementById('fix-interest').innerText = '—';
        document.getElementById('fix-total').innerText = '—';
        document.getElementById('fix-date').innerText = '—';
    } else {
        document.getElementById('fix-payment').innerText = fmt(fixedPayment);
        document.getElementById('fix-months').innerText = formatMonths(fixResult.months);
        document.getElementById('fix-interest').innerText = fmt(fixResult.totalInterest);
        document.getElementById('fix-total').innerText = fmt(balance + fixResult.totalInterest);
        document.getElementById('fix-date').innerText = futureDate(fixResult.months);
    }

    // Savings banner
    const banner = document.getElementById('single-savings');
    if (minResult.months > 0 && fixResult.months > 0) {
        const interestSaved = minResult.totalInterest - fixResult.totalInterest;
        const monthsSaved = minResult.months - fixResult.months;
        if (interestSaved > 1) {
            banner.style.display = 'block';
            document.getElementById('single-savings-interest').innerText = fmt(interestSaved);
            document.getElementById('single-savings-time').innerText = formatMonths(monthsSaved);
            document.getElementById('single-savings-total').innerText = fmt(interestSaved);
        } else {
            banner.style.display = 'none';
        }
    } else {
        banner.style.display = 'none';
    }

    renderSingleSchedule();
    drawSingleChart();
}

function clearSingleResults() {
    ['min-payment', 'min-interest', 'min-total', 'fix-payment', 'fix-interest', 'fix-total'].forEach(id => {
        document.getElementById(id).innerText = '$0';
    });
    ['min-months', 'fix-months'].forEach(id => {
        document.getElementById(id).innerText = '0';
    });
    ['min-date', 'fix-date'].forEach(id => {
        document.getElementById(id).innerText = '—';
    });
    document.getElementById('single-savings').style.display = 'none';
    document.getElementById('schedule-tbody').innerHTML = '';
    singleMinSchedule = [];
    singleFixSchedule = [];
}

function calculateMulti() {
    const cards = getCards();
    const extra = parseFloat(document.getElementById('m-extra').value) || 0;

    const totalMin = cards.reduce((s, c) => s + c.minPayment, 0);
    document.getElementById('m-total-min').innerText = fmt(totalMin);
    document.getElementById('m-total-monthly').innerText = fmt(totalMin + extra);

    if (cards.length === 0) {
        clearMultiResults();
        return;
    }

    const result = simulateMultiCard(cards, extra);
    multiSchedule = result.schedule;

    const noExtraResult = simulateMultiCard(cards, 0);
    multiNoExtraSchedule = noExtraResult.schedule;

    const totalDebt = cards.reduce((s, c) => s + c.balance, 0);

    document.getElementById('m-total-debt').innerText = fmt(totalDebt);
    document.getElementById('m-payoff-months').innerText = formatMonths(result.months);
    document.getElementById('m-total-interest').innerText = fmt(result.totalInterest);
    document.getElementById('m-payoff-date').innerText = futureDate(result.months);

    // Savings vs no extra
    const banner = document.getElementById('multi-savings');
    if (extra > 0 && noExtraResult.months > 0 && result.months > 0) {
        const interestSaved = noExtraResult.totalInterest - result.totalInterest;
        const monthsSaved = noExtraResult.months - result.months;
        if (interestSaved > 1) {
            banner.style.display = 'block';
            document.getElementById('multi-savings-interest').innerText = fmt(interestSaved);
            document.getElementById('multi-savings-time').innerText = formatMonths(monthsSaved);
        } else {
            banner.style.display = 'none';
        }
    } else {
        banner.style.display = 'none';
    }

    renderMultiSchedule();
    drawMultiChart(result);
}

function clearMultiResults() {
    document.getElementById('m-total-debt').innerText = '$0';
    document.getElementById('m-payoff-months').innerText = '0';
    document.getElementById('m-total-interest').innerText = '$0';
    document.getElementById('m-payoff-date').innerText = '—';
    document.getElementById('multi-savings').style.display = 'none';
    document.getElementById('schedule-tbody').innerHTML = '';
    multiSchedule = [];
    multiNoExtraSchedule = [];
}

// ─── HELPERS ───
function formatMonths(m) {
    if (m <= 0) return '0';
    const years = Math.floor(m / 12);
    const months = m % 12;
    if (years === 0) return months + ' mo';
    if (months === 0) return years + ' yr';
    return years + ' yr ' + months + ' mo';
}

function futureDate(monthsFromNow) {
    if (monthsFromNow <= 0) return '—';
    const d = new Date();
    d.setMonth(d.getMonth() + monthsFromNow);
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

// ─── SCHEDULE TABLE ───
function renderSingleSchedule() {
    const thead = document.getElementById('schedule-thead');
    const tbody = document.getElementById('schedule-tbody');
    thead.innerHTML = '<tr><th>Month</th><th>Payment</th><th>Principal</th><th>Interest</th><th>Balance</th></tr>';
    // Show fixed payment schedule (more useful)
    const data = singleFixSchedule.length > 0 ? singleFixSchedule : singleMinSchedule;
    let html = '';
    for (const row of data) {
        html += `<tr><td>${row.month}</td><td>${fmt2(row.payment)}</td><td>${fmt2(row.principal)}</td><td>${fmt2(row.interest)}</td><td>${fmt(row.totalBalance)}</td></tr>`;
    }
    tbody.innerHTML = html;
}

function renderMultiSchedule() {
    const thead = document.getElementById('schedule-thead');
    const tbody = document.getElementById('schedule-tbody');
    thead.innerHTML = '<tr><th>Month</th><th>Payment</th><th>Principal</th><th>Interest</th><th>Balance</th><th>Event</th></tr>';
    let html = '';
    for (const row of multiSchedule) {
        const event = row.paidOff.length > 0 ? row.paidOff.join(', ') + ' paid off' : '';
        html += `<tr><td>${row.month}</td><td>${fmt2(row.payment)}</td><td>${fmt2(row.principal)}</td><td>${fmt2(row.interest)}</td><td>${fmt(row.totalBalance)}</td><td style="text-align:left;font-family:var(--font-ui);" ${event ? 'class="paid-off-row"' : ''}>${event}</td></tr>`;
    }
    tbody.innerHTML = html;
}

// ─── CHARTS ───
function drawSingleChart() {
    const canvas = document.getElementById('balanceChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    const legendEl = document.getElementById('chart-legend');
    legendEl.innerHTML = `
        <div class="chart-legend-item"><span class="chart-legend-color" style="background:var(--color-minimum);"></span>Minimum Payments</div>
        <div class="chart-legend-item"><span class="chart-legend-color" style="background:var(--color-fixed);"></span>Fixed Payment</div>
    `;

    if (singleMinSchedule.length === 0 && singleFixSchedule.length === 0) return;

    const padding = { top: 30, right: 20, bottom: 40, left: 65 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    const maxMonths = Math.max(singleMinSchedule.length, singleFixSchedule.length);
    const maxBalance = Math.max(
        singleMinSchedule.length > 0 ? singleMinSchedule[0].totalBalance + singleMinSchedule[0].principal : 0,
        singleFixSchedule.length > 0 ? singleFixSchedule[0].totalBalance + singleFixSchedule[0].principal : 0
    ) * 1.05;

    drawGrid(ctx, w, h, padding, chartW, chartH, maxMonths, maxBalance);
    drawLine(ctx, singleMinSchedule, '#E25C5C', padding, chartW, chartH, maxMonths, maxBalance);
    drawLine(ctx, singleFixSchedule, '#4A90E2', padding, chartW, chartH, maxMonths, maxBalance);
}

function drawMultiChart(result) {
    const canvas = document.getElementById('balanceChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    const legendEl = document.getElementById('chart-legend');
    legendEl.innerHTML = `
        <div class="chart-legend-item"><span class="chart-legend-color" style="background:var(--color-fixed);"></span>With Extra Payments</div>
        <div class="chart-legend-item"><span class="chart-legend-color" style="background:var(--color-minimum);"></span>Minimums Only</div>
    `;

    if (multiSchedule.length === 0) return;

    const padding = { top: 30, right: 20, bottom: 40, left: 65 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    const maxMonths = Math.max(multiSchedule.length, multiNoExtraSchedule.length);
    const maxBalance = Math.max(
        multiSchedule.length > 0 ? multiSchedule[0].totalBalance + multiSchedule[0].principal : 0,
        multiNoExtraSchedule.length > 0 ? multiNoExtraSchedule[0].totalBalance + multiNoExtraSchedule[0].principal : 0
    ) * 1.05;

    drawGrid(ctx, w, h, padding, chartW, chartH, maxMonths, maxBalance);
    drawLine(ctx, multiNoExtraSchedule, '#E25C5C', padding, chartW, chartH, maxMonths, maxBalance);
    drawLine(ctx, multiSchedule, '#4A90E2', padding, chartW, chartH, maxMonths, maxBalance);

    // Mark payoff events
    for (const row of multiSchedule) {
        if (row.paidOff.length > 0) {
            const x = padding.left + (row.month / maxMonths) * chartW;
            const y = padding.top + chartH - (row.totalBalance / maxBalance) * chartH;
            ctx.beginPath();
            ctx.arc(x, y, 4, 0, Math.PI * 2);
            ctx.fillStyle = '#4A90E2';
            ctx.fill();
        }
    }
}

function drawGrid(ctx, w, h, padding, chartW, chartH, maxMonths, maxBalance) {
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    const gridLines = 5;
    for (let i = 0; i <= gridLines; i++) {
        const y = padding.top + (chartH / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();

        const val = maxBalance - (maxBalance / gridLines) * i;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        if (val >= 1000) {
            ctx.fillText('$' + Math.round(val / 1000) + 'k', padding.left - 8, y);
        } else {
            ctx.fillText('$' + Math.round(val), padding.left - 8, y);
        }
    }

    const xStep = maxMonths > 60 ? 12 : maxMonths > 24 ? 6 : maxMonths > 12 ? 3 : 1;
    for (let m = 0; m <= maxMonths; m += xStep) {
        if (m === 0) continue;
        const x = padding.left + (m / maxMonths) * chartW;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText(m >= 12 ? Math.round(m / 12) + 'yr' : m + 'mo', x, padding.top + chartH + 8);
    }
}

function drawLine(ctx, data, color, padding, chartW, chartH, maxMonths, maxBalance) {
    if (data.length === 0) return;
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = 2.5;

    const startBalance = data[0].totalBalance + data[0].principal;
    const startX = padding.left;
    const startY = padding.top + chartH - (startBalance / maxBalance) * chartH;
    ctx.moveTo(startX, startY);

    for (let i = 0; i < data.length; i++) {
        const x = padding.left + ((i + 1) / maxMonths) * chartW;
        const y = padding.top + chartH - (data[i].totalBalance / maxBalance) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.stroke();
}

// ─── CSV EXPORT ───
window.exportCSV = () => {
    let data;
    if (currentMode === 'single') {
        data = singleFixSchedule.length > 0 ? singleFixSchedule : singleMinSchedule;
    } else {
        data = multiSchedule;
    }
    if (data.length === 0) return;

    let csv = 'Month,Payment,Principal,Interest,Remaining Balance';
    if (currentMode === 'multi') csv += ',Event';
    csv += '\n';

    for (const row of data) {
        csv += `${row.month},${row.payment.toFixed(2)},${row.principal.toFixed(2)},${row.interest.toFixed(2)},${row.totalBalance.toFixed(2)}`;
        if (currentMode === 'multi') {
            const event = row.paidOff && row.paidOff.length > 0 ? '"' + row.paidOff.join(', ') + ' paid off"' : '';
            csv += ',' + event;
        }
        csv += '\n';
    }

    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'credit-card-payoff-schedule.csv';
    a.click();
    URL.revokeObjectURL(url);
};

// ─── MIN TYPE TOGGLE ───
document.getElementById('s-min-type').addEventListener('change', function() {
    const isPercent = this.value === 'percent';
    document.getElementById('s-min-fixed-group').style.display = isPercent ? 'none' : 'block';
    document.getElementById('s-min-pct-group').style.display = isPercent ? 'block' : 'none';
    calculate();
});

// ─── EVENT LISTENERS ───
['s-balance', 's-apr', 's-min-fixed', 's-min-pct', 's-extra'].forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
});
document.getElementById('m-extra').addEventListener('input', calculate);

window.addEventListener('resize', () => {
    if (currentMode === 'single') {
        drawSingleChart();
    } else if (multiSchedule.length > 0) {
        drawMultiChart({ schedule: multiSchedule });
    }
});

// Initialize
defaultCards.forEach(c => addCard(c.name, c.balance, c.apr, c.minPayment));
calculateSingle();
  </script>
