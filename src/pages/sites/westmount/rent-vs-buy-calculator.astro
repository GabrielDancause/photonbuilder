---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Rent vs Buy Calculator: Which Makes More Financial Sense?",
  description: "Stop guessing if you should rent or buy. This interactive calculator compares the true costs of homeownership vs renting to help you make the right choice.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Rent vs Buy Calculator",
    "description": "Calculate and compare the financial outcomes of renting versus buying a home over time.",
    "author": {
      "@type": "Organization",
      "name": "Westmount Fundamentals"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is it always better to buy a house instead of renting?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, it is not always better to buy. While buying builds equity, it also comes with high sunk costs like property taxes, maintenance, HOA fees, and mortgage interest. If you plan to move within 5-7 years, renting and investing your savings is often more financially beneficial."
        }
      },
      {
        "@type": "Question",
        "name": "What is the 5% rule in real estate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 5% rule is a quick financial heuristic that states you should compare the annual cost of renting to 5% of the value of the home you would buy. This 5% accounts for property taxes (1%), maintenance (1%), and cost of capital (3%). If a home costs $500,000, 5% is $25,000/year (or $2,083/month). If you can rent a similar home for less than $2,083/month, renting might be financially better."
        }
      },
      {
        "@type": "Question",
        "name": "How long do I need to live in a house to make buying worth it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Generally, you need to stay in a home for at least 5 to 7 years to break even on the upfront costs of buying (like closing costs) and the eventual costs of selling (like realtor commissions). If you move sooner, renting is usually cheaper."
        }
      },
      {
        "@type": "Question",
        "name": "What are the unrecoverable costs of owning a home?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Unrecoverable costs, or 'sunk costs', of homeownership include mortgage interest, property taxes, home insurance, HOA fees, and maintenance costs. Unlike principal payments which build equity, this money is gone forever, similar to paying rent."
        }
      },
      {
        "@type": "Question",
        "name": "Why does investment return matter in a rent vs buy calculation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "When you buy a home, a large amount of capital is tied up in a down payment. When you rent, you can invest that down payment in the stock market instead. Additionally, if renting is cheaper per month than owning, the monthly savings can also be invested. A true financial comparison must account for the opportunity cost of not investing those funds."
        }
      }
    ]
  }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/rent-vs-buy-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Rent vs Buy Calculator</h1>
      <p class="subtitle">Discover the true cost of homeownership vs renting and investing the difference.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-section">
        <h3>Buying Assumptions</h3>

        <div class="input-group">
          <label for="homePrice">Home Price ($)</label>
          <input type="number" id="homePrice" value="500000" min="10000" step="10000" />
        </div>

        <div class="input-group">
          <label for="downPaymentPercent">Down Payment (%)</label>
          <input type="number" id="downPaymentPercent" value="20" min="0" max="100" step="1" />
        </div>

        <div class="input-group">
          <label for="interestRate">Mortgage Interest Rate (%)</label>
          <input type="number" id="interestRate" value="7.0" min="0" step="0.1" />
        </div>

        <div class="input-group">
          <label for="loanTerm">Loan Term (Years)</label>
          <select id="loanTerm">
            <option value="15">15 Years</option>
            <option value="30" selected>30 Years</option>
          </select>
        </div>

        <div class="input-group">
          <label for="propertyTaxRate">Annual Property Tax (%)</label>
          <input type="number" id="propertyTaxRate" value="1.2" min="0" step="0.1" />
        </div>

        <div class="input-group">
          <label for="homeInsurance">Annual Home Insurance ($)</label>
          <input type="number" id="homeInsurance" value="1500" min="0" step="100" />
        </div>

        <div class="input-group">
          <label for="maintenanceRate">Annual Maintenance (%)</label>
          <input type="number" id="maintenanceRate" value="1.0" min="0" step="0.1" />
          <small class="hint">Percentage of home value</small>
        </div>

        <div class="input-group">
          <label for="hoaFees">Monthly HOA Fees ($)</label>
          <input type="number" id="hoaFees" value="0" min="0" step="50" />
        </div>

        <div class="input-group">
          <label for="closingCostsBuy">Buying Closing Costs (%)</label>
          <input type="number" id="closingCostsBuy" value="3.0" min="0" step="0.1" />
        </div>

        <div class="input-group">
          <label for="sellingCosts">Selling Costs / Commissions (%)</label>
          <input type="number" id="sellingCosts" value="6.0" min="0" step="0.1" />
        </div>
      </div>

      <div class="calc-section">
        <h3>Renting Assumptions</h3>

        <div class="input-group">
          <label for="monthlyRent">Monthly Rent ($)</label>
          <input type="number" id="monthlyRent" value="2500" min="0" step="100" />
        </div>

        <div class="input-group">
          <label for="rentersInsurance">Annual Renter's Insurance ($)</label>
          <input type="number" id="rentersInsurance" value="200" min="0" step="10" />
        </div>

        <div class="input-group">
          <label for="rentIncrease">Annual Rent Increase (%)</label>
          <input type="number" id="rentIncrease" value="3.0" min="0" step="0.1" />
        </div>

        <div class="input-group">
          <label for="deposit">Security Deposit ($)</label>
          <input type="number" id="deposit" value="2500" min="0" step="100" />
        </div>

        <h3>Market Assumptions</h3>

        <div class="input-group">
          <label for="homeAppreciation">Home Appreciation Rate (%)</label>
          <input type="number" id="homeAppreciation" value="3.0" min="0" step="0.1" />
        </div>

        <div class="input-group">
          <label for="investmentReturn">Investment Return Rate (%)</label>
          <input type="number" id="investmentReturn" value="7.0" min="0" step="0.1" />
          <small class="hint">Return on stock market investments</small>
        </div>

        <div class="input-group">
          <label for="inflationRate">Inflation Rate (%)</label>
          <input type="number" id="inflationRate" value="2.5" min="0" step="0.1" />
        </div>

        <div class="input-group">
          <label for="yearsToCompare">Years to Compare</label>
          <input type="number" id="yearsToCompare" value="10" min="1" max="50" step="1" />
        </div>
      </div>

      <div class="results-grid">
        <div class="result-card" id="winner-card">
          <h3 id="winner-text">Loading...</h3>
          <div class="result-value" id="net-difference">$0</div>
        </div>

        <div class="stats-row">
          <div class="sub-result">
            <h4>Net Worth (Buying)</h4>
            <div id="net-worth-buying">$0</div>
          </div>
          <div class="sub-result">
            <h4>Net Worth (Renting)</h4>
            <div id="net-worth-renting">$0</div>
          </div>
        </div>

        <div class="comparison-details">
          <div class="detail-column">
            <h4>Cost Breakdown: Buying</h4>
            <ul class="cost-list">
              <li><span>Total Mortgage Paid:</span> <strong id="out-mortgage">$0</strong></li>
              <li><span>Total Interest Paid:</span> <strong id="out-interest">$0</strong></li>
              <li><span>Property Taxes Paid:</span> <strong id="out-taxes">$0</strong></li>
              <li><span>Maintenance/HOA/Ins:</span> <strong id="out-maint">$0</strong></li>
              <li><span>Sunk Costs (Unrecoverable):</span> <strong id="out-sunk-buy" class="text-negative">$0</strong></li>
              <li class="separator"></li>
              <li><span>Final Home Value:</span> <strong id="out-home-val">$0</strong></li>
              <li><span>Remaining Loan Balance:</span> <strong id="out-loan-bal">$0</strong></li>
              <li><span>Proceeds After Selling:</span> <strong id="out-proceeds">$0</strong></li>
            </ul>
          </div>

          <div class="detail-column">
            <h4>Cost Breakdown: Renting</h4>
            <ul class="cost-list">
              <li><span>Total Rent Paid:</span> <strong id="out-rent">$0</strong></li>
              <li><span>Renter's Insurance:</span> <strong id="out-rent-ins">$0</strong></li>
              <li><span>Sunk Costs (Unrecoverable):</span> <strong id="out-sunk-rent" class="text-negative">$0</strong></li>
              <li class="separator"></li>
              <li><span>Invested Down Payment:</span> <strong id="out-invest-dp">$0</strong></li>
              <li><span>Invested Monthly Savings:</span> <strong id="out-invest-monthly">$0</strong></li>
              <li><span>Total Investment Portfolio:</span> <strong id="out-portfolio">$0</strong></li>
            </ul>
          </div>
        </div>
      </div>

      <div id="error-message" class="error-text" style="display: none;">Please enter valid numbers.</div>
    </div>

    <div class="explainer">
      <h2>Understanding the Rent vs Buy Decision</h2>
      <p>
        The decision to rent or buy a home is often framed as a simple choice between "throwing money away on rent" and "building equity." However, the reality is much more complex. Homeownership comes with its own set of "sunk costs"—expenses that you never get back, much like rent.
      </p>

      <h3>The True Sunk Costs of Homeownership</h3>
      <p>
        When you make a mortgage payment, only a portion goes toward the principal (building equity). The rest is unrecoverable. The primary sunk costs of buying include:
      </p>
      <ul>
        <li><strong>Mortgage Interest:</strong> In the early years of a 30-year mortgage, the vast majority of your payment goes toward interest, not principal.</li>
        <li><strong>Property Taxes:</strong> A recurring annual expense based on your home's assessed value.</li>
        <li><strong>Maintenance and Repairs:</strong> As a rule of thumb, expect to spend 1% to 2% of your home's value annually on upkeep.</li>
        <li><strong>Homeowners Insurance and HOA Fees:</strong> Mandatory expenses to protect the property and maintain shared spaces.</li>
        <li><strong>Transaction Costs:</strong> Closing costs when you buy (2-5%) and agent commissions when you sell (usually 5-6%).</li>
      </ul>

      <h3>The Power of Opportunity Cost</h3>
      <p>
        The most overlooked factor in the rent vs buy debate is <strong>opportunity cost</strong>. When you buy a home, you must provide a large down payment. If you rented instead, that money could be invested in the stock market.
      </p>
      <p>
        Furthermore, if your total monthly housing costs (rent + renter's insurance) are lower than the total monthly costs of owning (mortgage + taxes + insurance + maintenance + HOA), you can invest that monthly difference. Over time, the compounding returns of those investments can often outpace the equity built in a home.
      </p>

      <h3>When Does Buying Make Sense?</h3>
      <p>
        Buying typically makes financial sense if:
      </p>
      <ul>
        <li>You plan to stay in the home for a long time (typically 7+ years) to absorb the high transaction costs of buying and selling.</li>
        <li>Rent in your area is exceptionally high compared to home prices (a low price-to-rent ratio).</li>
        <li>You value the stability, customization, and forced savings mechanism that homeownership provides over pure financial optimization.</li>
      </ul>

      <p>
        Our calculator dynamically models both scenarios month-by-month, projecting home appreciation, investment returns, and inflation to give you a clear picture of your net worth in either path.
      </p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>Is it always better to buy a house instead of renting?</summary>
        <p>No, it is not always better to buy. While buying builds equity, it also comes with high sunk costs like property taxes, maintenance, HOA fees, and mortgage interest. If you plan to move within 5-7 years, renting and investing your savings is often more financially beneficial.</p>
      </details>

      <details>
        <summary>What is the 5% rule in real estate?</summary>
        <p>The 5% rule is a quick financial heuristic that states you should compare the annual cost of renting to 5% of the value of the home you would buy. This 5% accounts for property taxes (1%), maintenance (1%), and cost of capital (3%). If a home costs $500,000, 5% is $25,000/year (or $2,083/month). If you can rent a similar home for less than $2,083/month, renting might be financially better.</p>
      </details>

      <details>
        <summary>How long do I need to live in a house to make buying worth it?</summary>
        <p>Generally, you need to stay in a home for at least 5 to 7 years to break even on the upfront costs of buying (like closing costs) and the eventual costs of selling (like realtor commissions). If you move sooner, renting is usually cheaper.</p>
      </details>

      <details>
        <summary>What are the unrecoverable costs of owning a home?</summary>
        <p>Unrecoverable costs, or 'sunk costs', of homeownership include mortgage interest, property taxes, home insurance, HOA fees, and maintenance costs. Unlike principal payments which build equity, this money is gone forever, similar to paying rent.</p>
      </details>

      <details>
        <summary>Why does investment return matter in a rent vs buy calculation?</summary>
        <p>When you buy a home, a large amount of capital is tied up in a down payment. When you rent, you can invest that down payment in the stock market instead. Additionally, if renting is cheaper per month than owning, the monthly savings can also be invested. A true financial comparison must account for the opportunity cost of not investing those funds.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      }).format(value);
    }

    function calculateRentVsBuy() {
      // 1. Get Inputs
      const p = {
        homePrice: parseFloat(document.getElementById('homePrice').value),
        downPaymentPercent: parseFloat(document.getElementById('downPaymentPercent').value) / 100,
        interestRate: parseFloat(document.getElementById('interestRate').value) / 100,
        loanTerm: parseInt(document.getElementById('loanTerm').value),
        propertyTaxRate: parseFloat(document.getElementById('propertyTaxRate').value) / 100,
        homeInsurance: parseFloat(document.getElementById('homeInsurance').value),
        maintenanceRate: parseFloat(document.getElementById('maintenanceRate').value) / 100,
        hoaFees: parseFloat(document.getElementById('hoaFees').value),
        closingCostsBuy: parseFloat(document.getElementById('closingCostsBuy').value) / 100,
        sellingCosts: parseFloat(document.getElementById('sellingCosts').value) / 100,

        monthlyRent: parseFloat(document.getElementById('monthlyRent').value),
        rentersInsurance: parseFloat(document.getElementById('rentersInsurance').value),
        rentIncrease: parseFloat(document.getElementById('rentIncrease').value) / 100,
        deposit: parseFloat(document.getElementById('deposit').value),

        homeAppreciation: parseFloat(document.getElementById('homeAppreciation').value) / 100,
        investmentReturn: parseFloat(document.getElementById('investmentReturn').value) / 100,
        inflationRate: parseFloat(document.getElementById('inflationRate').value) / 100,
        yearsToCompare: parseInt(document.getElementById('yearsToCompare').value)
      };

      const errorMsg = document.getElementById('error-message');

      // Basic validation
      if (Object.values(p).some(isNaN) || p.homePrice <= 0 || p.yearsToCompare <= 0) {
        errorMsg.style.display = 'block';
        return;
      }
      errorMsg.style.display = 'none';

      const months = p.yearsToCompare * 12;

      // --- BUYING SCENARIO ---
      const downPayment = p.homePrice * p.downPaymentPercent;
      const loanAmount = p.homePrice - downPayment;
      const initialClosingCosts = p.homePrice * p.closingCostsBuy;

      // Monthly Mortgage (P&I)
      let monthlyMortgage = 0;
      if (loanAmount > 0 && p.interestRate > 0) {
        const monthlyRate = p.interestRate / 12;
        const totalPayments = p.loanTerm * 12;
        monthlyMortgage = loanAmount * (monthlyRate * Math.pow(1 + monthlyRate, totalPayments)) / (Math.pow(1 + monthlyRate, totalPayments) - 1);
      } else if (loanAmount > 0 && p.interestRate === 0) {
        monthlyMortgage = loanAmount / (p.loanTerm * 12);
      }

      let currentHomeValue = p.homePrice;
      let remainingLoan = loanAmount;

      let totalMortgagePaid = 0;
      let totalInterestPaid = 0;
      let totalPropertyTax = 0;
      let totalMaintenance = 0;
      let totalHomeInsurance = 0;
      let totalHoa = 0;

      // Month-by-month buying simulation
      for (let m = 1; m <= months; m++) {
        // Appreciate home value yearly
        if (m > 1 && (m - 1) % 12 === 0) {
          currentHomeValue *= (1 + p.homeAppreciation);
        }

        // Mortgage payment breakdown
        let interestPayment = 0;
        let principalPayment = 0;

        if (remainingLoan > 0) {
          interestPayment = remainingLoan * (p.interestRate / 12);
          principalPayment = monthlyMortgage - interestPayment;

          if (principalPayment > remainingLoan) {
            principalPayment = remainingLoan;
            interestPayment = monthlyMortgage - principalPayment;
          }

          remainingLoan -= principalPayment;
          totalInterestPaid += interestPayment;
          totalMortgagePaid += (principalPayment + interestPayment);
        }

        // Monthly costs (inflate annually)
        const yearIndex = Math.floor((m - 1) / 12);
        const inflationMultiplier = Math.pow(1 + p.inflationRate, yearIndex);

        const monthlyTax = (currentHomeValue * p.propertyTaxRate) / 12;
        const monthlyMaint = (currentHomeValue * p.maintenanceRate) / 12;
        const monthlyIns = (p.homeInsurance * inflationMultiplier) / 12;
        const monthlyHoa = p.hoaFees * inflationMultiplier;

        totalPropertyTax += monthlyTax;
        totalMaintenance += monthlyMaint;
        totalHomeInsurance += monthlyIns;
        totalHoa += monthlyHoa;
      }

      // Final Buy Calculations
      const sellingCostAmount = currentHomeValue * p.sellingCosts;
      const proceedsFromSale = currentHomeValue - remainingLoan - sellingCostAmount;

      const totalMaintHoaIns = totalMaintenance + totalHoa + totalHomeInsurance;
      const totalSunkBuy = initialClosingCosts + totalInterestPaid + totalPropertyTax + totalMaintHoaIns + sellingCostAmount;

      // Calculate total cash out of pocket for buying (excluding selling costs handled in net worth)
      // Net Worth (Buying) = Proceeds from sale - total non-mortgage cash paid - closing costs
      // Actually simpler: Net Worth = Final Asset Value - Remaining Debt - Total Cash Outflow + Initial Cash
      // Let's track pure Net Worth: Assets - Liabilities
      // We assume initial cash = Down Payment + Initial Closing Costs (which could have been invested)

      // Wait, standard net worth comparison assumes you start with the same cash.
      // Initial Cash Available = Down Payment + Buying Closing Costs
      const initialCash = downPayment + initialClosingCosts;

      // Net Worth Buy = Current Home Value - Remaining Loan - Selling Costs (if liquidated)
      // BUT we also need to account for monthly cash flows. If buying costs more per month, we must penalize it. If renting costs more, we penalize renting.
      // To compare apples to apples: Let's track the "Side Fund"

      // We need to re-run the loop to compare monthly cash flows exactly.

      // --- RENTING SCENARIO & COMPARISON ---
      let currentRent = p.monthlyRent;
      let totalRentPaid = 0;
      let totalRentersInsurance = 0;

      // Renters start by investing the cash they DIDN'T spend on a down payment and closing costs
      let renterPortfolio = downPayment + initialClosingCosts - p.deposit;

      // Buyer's portfolio (if renting is more expensive, buyer invests the difference)
      let buyerPortfolio = 0;

      currentHomeValue = p.homePrice;
      remainingLoan = loanAmount;
      const monthlyReturnRate = Math.pow(1 + p.investmentReturn, 1/12) - 1;

      // Reset monthly accumulators to zero for the exact side-by-side run
      totalMortgagePaid = 0;
      totalInterestPaid = 0;
      totalPropertyTax = 0;
      totalMaintenance = 0;
      totalHomeInsurance = 0;
      totalHoa = 0;

      for (let m = 1; m <= months; m++) {
        // Annual updates
        const yearIndex = Math.floor((m - 1) / 12);
        if (m > 1 && (m - 1) % 12 === 0) {
          currentHomeValue *= (1 + p.homeAppreciation);
          currentRent *= (1 + p.rentIncrease);
        }

        const inflationMultiplier = Math.pow(1 + p.inflationRate, yearIndex);

        // -- BUYER MONTHLY OUTFLOW --
        let interestPayment = 0;
        let principalPayment = 0;

        if (remainingLoan > 0) {
          interestPayment = remainingLoan * (p.interestRate / 12);
          principalPayment = monthlyMortgage - interestPayment;
          if (principalPayment > remainingLoan) principalPayment = remainingLoan;
          remainingLoan -= principalPayment;
        }

        const monthlyTax = (currentHomeValue * p.propertyTaxRate) / 12;
        const monthlyMaint = (currentHomeValue * p.maintenanceRate) / 12;
        const monthlyIns = (p.homeInsurance * inflationMultiplier) / 12;
        const monthlyHoa = p.hoaFees * inflationMultiplier;

        const totalBuyerMonthlyCost = monthlyMortgage + monthlyTax + monthlyMaint + monthlyIns + monthlyHoa;

        totalMortgagePaid += (principalPayment + interestPayment);
        totalInterestPaid += interestPayment;
        totalPropertyTax += monthlyTax;
        totalMaintenance += monthlyMaint;
        totalHomeInsurance += monthlyIns;
        totalHoa += monthlyHoa;

        // -- RENTER MONTHLY OUTFLOW --
        const monthlyRentIns = (p.rentersInsurance * inflationMultiplier) / 12;
        const totalRenterMonthlyCost = currentRent + monthlyRentIns;

        totalRentPaid += currentRent;
        totalRentersInsurance += monthlyRentIns;

        // -- GROW PORTFOLIOS & INVEST DIFFERENCE --
        renterPortfolio *= (1 + monthlyReturnRate);
        buyerPortfolio *= (1 + monthlyReturnRate);

        const monthlyDifference = totalRenterMonthlyCost - totalBuyerMonthlyCost;

        if (monthlyDifference > 0) {
          // Renting is more expensive this month. Buyer invests the savings.
          buyerPortfolio += monthlyDifference;
        } else {
          // Buying is more expensive this month. Renter invests the savings.
          renterPortfolio += Math.abs(monthlyDifference);
        }
      }

      // -- FINAL NET WORTH CALCULATION --
      // Buyer Net Worth = Home Value - Remaining Loan - Selling Costs + Buyer Portfolio
      const finalSellingCostAmount = currentHomeValue * p.sellingCosts;
      const netWorthBuy = (currentHomeValue - remainingLoan - finalSellingCostAmount) + buyerPortfolio;

      // Renter Net Worth = Renter Portfolio + Deposit Returned
      const netWorthRent = renterPortfolio + p.deposit;

      // Total Sunk Costs
      const finalTotalMaintHoaIns = totalMaintenance + totalHoa + totalHomeInsurance;
      const totalSunkBuyFinal = initialClosingCosts + totalInterestPaid + totalPropertyTax + finalTotalMaintHoaIns + finalSellingCostAmount;
      const totalSunkRentFinal = totalRentPaid + totalRentersInsurance;

      // Renter Investment breakdown
      const initialInvested = initialCash - p.deposit;
      // We know Renter Portfolio = Initial Growth + Monthly Contribution Growth.
      // To simplify the UI, we just show total portfolio.

      // Update UI
      const netDiff = Math.abs(netWorthBuy - netWorthRent);
      const winnerCard = document.getElementById('winner-card');
      const winnerText = document.getElementById('winner-text');

      winnerCard.className = 'result-card'; // reset
      if (netWorthBuy > netWorthRent) {
        winnerCard.classList.add('buy-wins');
        winnerText.textContent = `Buying is better by`;
      } else if (netWorthRent > netWorthBuy) {
        winnerCard.classList.add('rent-wins');
        winnerText.textContent = `Renting is better by`;
      } else {
        winnerText.textContent = `It's a tie!`;
      }

      document.getElementById('net-difference').textContent = formatCurrency(netDiff);

      document.getElementById('net-worth-buying').textContent = formatCurrency(netWorthBuy);
      document.getElementById('net-worth-renting').textContent = formatCurrency(netWorthRent);

      // Buy Breakdown
      document.getElementById('out-mortgage').textContent = formatCurrency(totalMortgagePaid);
      document.getElementById('out-interest').textContent = formatCurrency(totalInterestPaid);
      document.getElementById('out-taxes').textContent = formatCurrency(totalPropertyTax);
      document.getElementById('out-maint').textContent = formatCurrency(finalTotalMaintHoaIns);
      document.getElementById('out-sunk-buy').textContent = formatCurrency(totalSunkBuyFinal);

      document.getElementById('out-home-val').textContent = formatCurrency(currentHomeValue);
      document.getElementById('out-loan-bal').textContent = formatCurrency(remainingLoan);
      document.getElementById('out-proceeds').textContent = formatCurrency(currentHomeValue - remainingLoan - finalSellingCostAmount);

      // Rent Breakdown
      document.getElementById('out-rent').textContent = formatCurrency(totalRentPaid);
      document.getElementById('out-rent-ins').textContent = formatCurrency(totalRentersInsurance);
      document.getElementById('out-sunk-rent').textContent = formatCurrency(totalSunkRentFinal);

      document.getElementById('out-invest-dp').textContent = formatCurrency(initialInvested);
      // Monthly savings invested is rough approx since it mixes into portfolio
      const monthlySavingsInvestedTotal = renterPortfolio - initialInvested * Math.pow(1 + p.investmentReturn, p.yearsToCompare);
      document.getElementById('out-invest-monthly').textContent = formatCurrency(Math.max(0, monthlySavingsInvestedTotal));
      document.getElementById('out-portfolio').textContent = formatCurrency(renterPortfolio);
    }

    // Initialization logic for Astro view transitions and regular load
    function initCalculator() {
      const inputs = document.querySelectorAll('.calculator-container input, .calculator-container select');
      inputs.forEach(input => {
        // Prevent multiple listener attachments on view transitions
        if (!input.dataset.initialized) {
          input.addEventListener('input', calculateRentVsBuy);
          input.dataset.initialized = 'true';
        }
      });
      calculateRentVsBuy();
    }

    document.addEventListener('DOMContentLoaded', initCalculator);
    document.addEventListener('astro:page-load', initCalculator);
  </script>
