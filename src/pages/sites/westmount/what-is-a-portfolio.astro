    color: var(--text-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: 0.5rem;
    padding-top: 1rem;
  }

  .faq-content p {
    margin: 0;
  }

  @media (max-width: 600px) {
    .hero-section h1 {
      font-size: 2rem;
    }

    .results-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initCalculator() {
    const equityAlloc = document.getElementById('equityAlloc');
    const bondAlloc = document.getElementById('bondAlloc');
    const equityLabel = document.getElementById('equityLabel');
    const bondLabel = document.getElementById('bondLabel');
    const allocError = document.getElementById('allocError');

    const riskProfile = document.getElementById('riskProfile');
    const estReturn = document.getElementById('estReturn');
    const estDrawdown = document.getElementById('estDrawdown');

    const equityBar = document.getElementById('equityBar');
    const bondBar = document.getElementById('bondBar');

    if (!equityAlloc || !bondAlloc) return;

    let isUpdating = false;

    function updateCalculations(source) {
      if (isUpdating) return;
      isUpdating = true;

      let eVal = parseInt(equityAlloc.value, 10);
      let bVal = parseInt(bondAlloc.value, 10);

      if (source === 'equity') {
        bVal = 100 - eVal;
        bondAlloc.value = bVal;
      } else if (source === 'bond') {
        eVal = 100 - bVal;
        equityAlloc.value = eVal;
      }

      equityLabel.textContent = eVal;
      bondLabel.textContent = bVal;

      equityBar.style.width = eVal + '%';
      bondBar.style.width = bVal + '%';

      if (eVal === 0) equityBar.textContent = ''; else equityBar.textContent = 'Stocks';
      if (bVal === 0) bondBar.textContent = ''; else bondBar.textContent = 'Bonds';

      // Update metrics based on historical approximations
      if (eVal >= 80) {
        riskProfile.textContent = 'Aggressive';
        estReturn.textContent = '~9.0% / yr';
        estDrawdown.textContent = '-40% to -50%';
      } else if (eVal >= 60) {
        riskProfile.textContent = 'Moderate';
        estReturn.textContent = '~7.2% / yr';
        estDrawdown.textContent = '-25% to -30%';
      } else if (eVal >= 40) {
        riskProfile.textContent = 'Conservative';
        estReturn.textContent = '~5.5% / yr';
        estDrawdown.textContent = '-15% to -20%';
      } else if (eVal >= 20) {
        riskProfile.textContent = 'Income Focused';
        estReturn.textContent = '~4.0% / yr';
        estDrawdown.textContent = '-5% to -10%';
      } else {
        riskProfile.textContent = 'Capital Preservation';
        estReturn.textContent = '~2.5% / yr';
        estDrawdown.textContent = 'Minimal';
      }

      allocError.style.display = 'none';
      isUpdating = false;
    }

    equityAlloc.addEventListener('input', () => updateCalculations('equity'));
    bondAlloc.addEventListener('input', () => updateCalculations('bond'));
  }

  // Initialize for Astro View Transitions and direct loads
  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
