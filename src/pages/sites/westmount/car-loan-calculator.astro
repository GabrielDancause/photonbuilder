---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Car Loan Calculator | Auto Loan Payment Estimator",
  description: "Calculate your monthly auto loan payments, see the total cost of your car, and understand how interest rates and down payments affect your bottom line.",
  category: "tool",
  published: true
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does my credit score affect my car loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your credit score is the primary factor lenders use to determine your interest rate. A higher credit score generally qualifies you for lower interest rates, which can save you thousands of dollars over the life of the loan."
      }
    },
    {
      "@type": "Question",
      "name": "Should I make a down payment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, making a down payment reduces the principal amount of your loan. This lowers your monthly payment and decreases the total interest you'll pay. A typical recommendation is to put down at least 20% to avoid being \"upside down\" on the loan as the car depreciates."
      }
    },
    {
      "@type": "Question",
      "name": "What is loan amortization?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Amortization is the process of paying off a debt over time in regular, equal installments. In the early months of the loan, a larger portion of your payment goes toward interest. Over time, an increasing percentage goes toward paying down the principal."
      }
    },
    {
      "@type": "Question",
      "name": "Are taxes and fees included in the loan amount?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Often, yes. Sales tax, title, and registration fees can be rolled into your auto loan, which increases your total borrowed amount and the interest you'll pay on it. Our calculator allows you to input a sales tax rate to see how it affects your loan."
      }
    },
    {
      "@type": "Question",
      "name": "Is it better to have a 60-month or 72-month car loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 60-month loan is generally better because you'll pay less total interest and build equity in the car faster. A 72-month loan lowers your monthly payment, but increases the overall cost of the car and the risk of owing more than the car is worth."
      }
    }
  ]
});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/car-loan-calculator" schema={schema}>
  <div class="page-content container">
    <h1>Car Loan Calculator</h1>

    <div class="calculator-card" id="car-loan-calculator">
      <div class="calc-grid">
        <div class="inputs-section">
          <div class="input-group">
            <label for="vehicle-price">Vehicle Price</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="vehicle-price" value="35000" min="0" step="100" />
            </div>
          </div>

          <div class="input-row">
            <div class="input-group">
              <label for="down-payment">Down Payment</label>
              <div class="input-wrapper">
                <span class="prefix">$</span>
                <input type="number" id="down-payment" value="5000" min="0" step="100" />
              </div>
            </div>

            <div class="input-group">
              <label for="trade-in-value">Trade-in Value</label>
              <div class="input-wrapper">
                <span class="prefix">$</span>
                <input type="number" id="trade-in-value" value="0" min="0" step="100" />
              </div>
            </div>
          </div>

          <div class="input-row">
            <div class="input-group">
              <label for="interest-rate">Interest Rate</label>
              <div class="input-wrapper">
                <input type="number" id="interest-rate" value="6.5" min="0" max="30" step="0.1" />
                <span class="suffix">%</span>
              </div>
            </div>

            <div class="input-group">
              <label for="loan-term">Loan Term</label>
              <div class="input-wrapper">
                <input type="number" id="loan-term" value="60" min="12" max="120" step="1" />
                <span class="suffix">mos</span>
              </div>
            </div>
          </div>

          <div class="input-group">
            <label for="sales-tax-rate">Sales Tax Rate</label>
            <div class="input-wrapper">
              <input type="number" id="sales-tax-rate" value="7.0" min="0" max="15" step="0.1" />
              <span class="suffix">%</span>
            </div>
          </div>
        </div>

        <div class="results-section">
          <div class="primary-result">
            <span class="calc-result-label">Estimated Monthly Payment</span>
            <div class="calc-result-value" id="result-monthly-payment">$0.00</div>
          </div>

          <div class="secondary-results">
            <div class="result-row">
              <span class="result-label">Total Loan Amount</span>
              <span class="result-value" id="result-loan-amount">$0.00</span>
            </div>
            <div class="result-row">
              <span class="result-label">Sales Tax</span>
              <span class="result-value" id="result-tax-amount">$0.00</span>
            </div>
            <div class="result-row">
              <span class="result-label">Total Interest Paid</span>
              <span class="result-value" id="result-total-interest">$0.00</span>
            </div>
            <div class="result-row total">
              <span class="result-label">Total Cost of Vehicle</span>
              <span class="result-value" id="result-total-cost">$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="content-section">
      <h2>Understanding Car Loans</h2>
      <p>Taking out a car loan is a significant financial commitment. It's important to understand how your monthly payment is calculated and the total cost of the vehicle over the life of the loan. This calculator helps you break down the costs, including interest, taxes, and the impact of down payments and trade-ins.</p>

      <h3>The Math Behind the Payment</h3>
      <p>The core of any loan calculation is the amortization formula. Your monthly payment (M) is determined by the principal loan amount (P), the monthly interest rate (r), and the total number of payments (n).</p>
      <p>The formula is: <strong>M = P [ r(1 + r)^n ] / [ (1 + r)^n - 1 ]</strong></p>

      <p>When you calculate your car loan, keep these key factors in mind:</p>
      <ul>
          <li><strong>Interest Rate:</strong> Even a small difference in your APR can significantly affect the total interest paid over the life of the loan.</li>
          <li><strong>Loan Term:</strong> Longer terms mean lower monthly payments, but you will pay more in interest overall.</li>
          <li><strong>Down Payment & Trade-In:</strong> Reducing the principal amount upfront lowers both your monthly payment and your total interest.</li>
      </ul>

      <div class="faq-section">
          <h2>Frequently Asked Questions</h2>
          <div class="faq-item">
              <details>
                  <summary><h3>How does my credit score affect my car loan?</h3></summary>
                  <p>Your credit score is the primary factor lenders use to determine your interest rate. A higher credit score generally qualifies you for lower interest rates, which can save you thousands of dollars over the life of the loan.</p>
              </details>
          </div>
          <div class="faq-item">
              <details>
                  <summary><h3>Should I make a down payment?</h3></summary>
                  <p>Yes, making a down payment reduces the principal amount of your loan. This lowers your monthly payment and decreases the total interest you'll pay. A typical recommendation is to put down at least 20% to avoid being "upside down" on the loan as the car depreciates.</p>
              </details>
          </div>
          <div class="faq-item">
              <details>
                  <summary><h3>What is loan amortization?</h3></summary>
                  <p>Amortization is the process of paying off a debt over time in regular, equal installments. In the early months of the loan, a larger portion of your payment goes toward interest. Over time, an increasing percentage goes toward paying down the principal.</p>
              </details>
          </div>
          <div class="faq-item">
              <details>
                  <summary><h3>Are taxes and fees included in the loan amount?</h3></summary>
                  <p>Often, yes. Sales tax, title, and registration fees can be rolled into your auto loan, which increases your total borrowed amount and the interest you'll pay on it. Our calculator allows you to input a sales tax rate to see how it affects your loan.</p>
              </details>
          </div>
          <div class="faq-item">
              <details>
                  <summary><h3>Is it better to have a 60-month or 72-month car loan?</h3></summary>
                  <p>A 60-month loan is generally better because you'll pay less total interest and build equity in the car faster. A 72-month loan lowers your monthly payment, but increases the overall cost of the car and the risk of owing more than the car is worth.</p>
              </details>
          </div>
      </div>
    </div>
  </div>
</SiteLayout>

<script>
  document.addEventListener('DOMContentLoaded', initCalculator);
  document.addEventListener('astro:page-load', initCalculator);

  function initCalculator() {
    const container = document.getElementById('car-loan-calculator');
    if (!container || container.dataset.initialized) return;
    container.dataset.initialized = 'true';

    const inputs = {
      price: document.getElementById('vehicle-price'),
      downPayment: document.getElementById('down-payment'),
      tradeIn: document.getElementById('trade-in-value'),
      interestRate: document.getElementById('interest-rate'),
      loanTerm: document.getElementById('loan-term'),
      salesTax: document.getElementById('sales-tax-rate'),
    };

    const outputs = {
      monthlyPayment: document.getElementById('result-monthly-payment'),
      totalInterest: document.getElementById('result-total-interest'),
      totalCost: document.getElementById('result-total-cost'),
      loanAmount: document.getElementById('result-loan-amount'),
      taxAmount: document.getElementById('result-tax-amount')
    };

    function calculate() {
      const price = parseFloat(inputs.price.value) || 0;
      const downPayment = parseFloat(inputs.downPayment.value) || 0;
      const tradeIn = parseFloat(inputs.tradeIn.value) || 0;
      const interestRate = parseFloat(inputs.interestRate.value) || 0;
      const loanTerm = parseInt(inputs.loanTerm.value) || 0;
      const salesTax = parseFloat(inputs.salesTax.value) || 0;

      const taxableAmount = Math.max(0, price - tradeIn);
      const taxAmount = taxableAmount * (salesTax / 100);

      const loanAmount = Math.max(0, price + taxAmount - downPayment - tradeIn);

      let monthlyPayment = 0;
      let totalInterest = 0;
      let totalCost = 0;

      if (loanAmount > 0 && loanTerm > 0) {
        if (interestRate > 0) {
          const r = (interestRate / 100) / 12;
          const n = loanTerm;
          monthlyPayment = loanAmount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
          const totalPaid = monthlyPayment * n;
          totalInterest = totalPaid - loanAmount;
        } else {
          monthlyPayment = loanAmount / loanTerm;
          totalInterest = 0;
        }
      }

      totalCost = downPayment + tradeIn + (monthlyPayment * loanTerm);

      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);

      outputs.monthlyPayment.textContent = formatCurrency(monthlyPayment);
      outputs.totalInterest.textContent = formatCurrency(totalInterest);
      outputs.totalCost.textContent = formatCurrency(totalCost);
      outputs.loanAmount.textContent = formatCurrency(loanAmount);
      outputs.taxAmount.textContent = formatCurrency(taxAmount);
    }

    Object.values(inputs).forEach(input => {
      if(input) {
        input.addEventListener('input', calculate);
      }
    });

    calculate();
  }
</script>

<style>
  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .calc-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .prefix {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    pointer-events: none;
    z-index: 1;
  }

  .suffix {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
    z-index: 1;
  }

  .input-wrapper input {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: border-color 0.2s;
  }

  .input-wrapper:has(.prefix) input {
    padding-left: 2rem;
  }

  .input-wrapper:has(.suffix) input {
    padding-right: 2.5rem;
  }

  .results-section {
    background-color: color-mix(in srgb, var(--card-bg) 50%, var(--bg-color));
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .primary-result {
    text-align: center;
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .secondary-results {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .result-label {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .result-value {
    font-family: var(--font-mono);
    color: var(--text-primary);
    font-weight: 500;
  }

  .result-row.total {
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--border-color);
  }

  .result-row.total .result-label,
  .result-row.total .result-value {
    font-weight: 700;
    color: var(--accent-color);
  }

  details {
    cursor: pointer;
  }

  details summary {
    font-weight: 600;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  details summary::after {
    content: '+';
    color: var(--accent-color);
    font-size: 1.5rem;
    line-height: 1;
  }

  details[open] summary::after {
    content: '-';
  }

  details p {
    margin-top: 1rem;
  }
</style>
