---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Savings Calculator: Grow Your Wealth",
  description: "Plan your financial future with our interactive savings calculator. See how your deposits and interest compound over time to build your wealth.",
};

const schema = JSON.stringify({"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What is a savings calculator?", "acceptedAnswer": {"@type": "Answer", "text": "A savings calculator is a tool that helps you estimate how much your savings will grow over a certain period. It factors in your initial deposit, regular contributions, and the expected interest rate or return on investment to project your future balance."}}, {"@type": "Question", "name": "How does compounding work with savings?", "acceptedAnswer": {"@type": "Answer", "text": "Compounding occurs when you earn interest not only on your initial deposit but also on the interest you've already earned. Over time, this causes your savings to grow at an accelerating rate, which is often referred to as 'interest on interest'."}}, {"@type": "Question", "name": "Why should I make regular contributions?", "acceptedAnswer": {"@type": "Answer", "text": "Regular contributions (like monthly deposits) significantly boost the growth of your savings. Even small, consistent amounts add up over time and benefit from compounding, making it easier to reach your financial goals faster than just relying on an initial lump sum."}}, {"@type": "Question", "name": "What is APY?", "acceptedAnswer": {"@type": "Answer", "text": "APY stands for Annual Percentage Yield. It represents the real rate of return earned on an investment, taking into account the effect of compounding interest over a year. It's a more accurate measure of growth than the simple interest rate (APR)."}}, {"@type": "Question", "name": "How do taxes and inflation affect my savings?", "acceptedAnswer": {"@type": "Answer", "text": "Taxes on interest earned can reduce your actual take-home return. Inflation decreases the purchasing power of your money over time. To grow real wealth, your savings or investments need to yield a return that outpaces both taxes and inflation."}}]});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/savings-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Savings Goal Calculator</h1>
      <p class="subtitle">Visualize the power of compounding and map out your path to financial freedom.</p>
    </div>

    <div class="calculator-container">
      <div class="input-section">
        <div class="input-group">
          <label for="initial-deposit">Initial Deposit</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="initial-deposit" value="1000" min="0" step="100" />
          </div>
        </div>

        <div class="input-group">
          <label for="monthly-contribution">Monthly Contribution</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="monthly-contribution" value="250" min="0" step="50" />
          </div>
        </div>

        <div class="input-group">
          <label for="interest-rate">Annual Interest Rate (APY)</label>
          <div class="input-wrapper">
            <input type="number" id="interest-rate" value="5.0" min="0" step="0.1" />
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="years">Years to Grow</label>
          <div class="input-wrapper">
            <input type="number" id="years" value="10" min="1" max="100" step="1" />
            <span class="suffix">Yrs</span>
          </div>
        </div>

        <div class="input-group">
          <label for="compound-frequency">Compounding Frequency</label>
          <div class="input-wrapper">
              <select id="compound-frequency">
                <option value="1">Annually (1x/yr)</option>
                <option value="4">Quarterly (4x/yr)</option>
                <option value="12" selected>Monthly (12x/yr)</option>
                <option value="365">Daily (365x/yr)</option>
              </select>
          </div>
        </div>

      </div>

      <div class="results-section">
        <div class="result-card primary">
          <h3>Total Savings Balance</h3>
          <div class="result-value" id="total-balance">$0.00</div>
        </div>

        <div class="secondary-results">
          <div class="sub-result">
            <h4>Total Principal</h4>
            <div id="total-principal" class="val">$0.00</div>
          </div>
          <div class="sub-result">
            <h4>Total Interest Earned</h4>
            <div id="total-interest" class="val accent">$0.00</div>
          </div>
        </div>

        <div class="chart-container">
           <canvas id="savingsChart"></canvas>
        </div>
      </div>
    </div>

    <div class="explainer-content content-section">
        <h2>How to Use This Savings Calculator</h2>
        <p>Building wealth is a marathon, not a sprint. This calculator helps you visualize how consistent saving and the magic of compound interest work together to grow your money over time.</p>

        <h3>The Variables You Control</h3>
        <ul>
            <li><strong>Initial Deposit:</strong> The amount of money you are starting with right now.</li>
            <li><strong>Monthly Contribution:</strong> The amount you commit to saving and adding to the account each month. Consistency here is key.</li>
            <li><strong>Annual Interest Rate:</strong> The expected yearly return on your savings or investment. High-Yield Savings Accounts (HYSAs) might offer 4-5%, while long-term stock market investments might historically average 7-10%.</li>
            <li><strong>Years to Grow:</strong> Your time horizon. The longer you leave the money invested, the more pronounced the compounding effect becomes.</li>
        </ul>

        <h3>Understanding the Results</h3>
        <p>Your <strong>Total Savings Balance</strong> is the final projected amount at the end of the time period. It is broken down into two components:</p>
        <ol>
            <li><strong>Total Principal:</strong> This is the total amount of <em>your own money</em> that you deposited (initial deposit plus all monthly contributions).</li>
            <li><strong>Total Interest Earned:</strong> This is the "free money" generated by your money working for you. In longer timeframes, the interest earned can eventually surpass the principal you contributed!</li>
        </ol>
    </div>

    <div class="faq-section content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">

        <div class="faq-item">
          <h3>What is a savings calculator?</h3>
          <p>A savings calculator is a tool that helps you estimate how much your savings will grow over a certain period. It factors in your initial deposit, regular contributions, and the expected interest rate or return on investment to project your future balance.</p>
        </div>

        <div class="faq-item">
          <h3>How does compounding work with savings?</h3>
          <p>Compounding occurs when you earn interest not only on your initial deposit but also on the interest you've already earned. Over time, this causes your savings to grow at an accelerating rate, which is often referred to as 'interest on interest'.</p>
        </div>

        <div class="faq-item">
          <h3>Why should I make regular contributions?</h3>
          <p>Regular contributions (like monthly deposits) significantly boost the growth of your savings. Even small, consistent amounts add up over time and benefit from compounding, making it easier to reach your financial goals faster than just relying on an initial lump sum.</p>
        </div>

        <div class="faq-item">
          <h3>What is APY?</h3>
          <p>APY stands for Annual Percentage Yield. It represents the real rate of return earned on an investment, taking into account the effect of compounding interest over a year. It's a more accurate measure of growth than the simple interest rate (APR).</p>
        </div>

        <div class="faq-item">
          <h3>How do taxes and inflation affect my savings?</h3>
          <p>Taxes on interest earned can reduce your actual take-home return. Inflation decreases the purchasing power of your money over time. To grow real wealth, your savings or investments need to yield a return that outpaces both taxes and inflation.</p>
        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    let chartInstance = null;

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      }).format(value);
    }

    function calculateSavings() {
      const initialDeposit = parseFloat(document.getElementById('initial-deposit').value) || 0;
      const monthlyContribution = parseFloat(document.getElementById('monthly-contribution').value) || 0;
      const annualRate = parseFloat(document.getElementById('interest-rate').value) || 0;
      const years = parseInt(document.getElementById('years').value) || 0;
      const compoundFreq = parseInt(document.getElementById('compound-frequency').value) || 12;

      // Rate per period
      const r = annualRate / 100;

      let totalBalance = 0;
      let totalPrincipal = initialDeposit + (monthlyContribution * 12 * years);

      const chartLabels = [];
      const chartPrincipalData = [];
      const chartInterestData = [];
      const chartTotalData = [];

      let currentBalance = initialDeposit;
      let currentPrincipal = initialDeposit;

      chartLabels.push("Year 0");
      chartPrincipalData.push(currentPrincipal);
      chartInterestData.push(0);
      chartTotalData.push(currentBalance);

      // We calculate year by year for the chart
      for (let y = 1; y <= years; y++) {
          // Calculate growth for this year

          let yearEndBalance = currentBalance;

          // Apply contributions and compounding based on frequency
          const periodsPerYear = compoundFreq;
          const ratePerPeriod = r / periodsPerYear;
          const contributionsPerPeriod = (monthlyContribution * 12) / periodsPerYear;

          for(let p = 0; p < periodsPerYear; p++) {
              // Add contribution (assuming end of period)
              yearEndBalance += contributionsPerPeriod;
              // Apply interest
              yearEndBalance *= (1 + ratePerPeriod);
          }

          currentBalance = yearEndBalance;
          currentPrincipal += (monthlyContribution * 12);

          chartLabels.push("Year " + y);
          chartPrincipalData.push(currentPrincipal);
          chartInterestData.push(currentBalance - currentPrincipal);
          chartTotalData.push(currentBalance);
      }

      totalBalance = currentBalance;
      const totalInterest = totalBalance - totalPrincipal;

      // Update DOM
      document.getElementById('total-balance').textContent = formatCurrency(totalBalance);
      document.getElementById('total-principal').textContent = formatCurrency(totalPrincipal);
      document.getElementById('total-interest').textContent = formatCurrency(totalInterest > 0 ? totalInterest : 0);

      updateChart(chartLabels, chartPrincipalData, chartInterestData);
    }

    function updateChart(labels, principalData, interestData) {
        const ctx = document.getElementById('savingsChart').getContext('2d');

        // Use CSS variables for colors if possible, otherwise fallbacks
        const rootStyles = getComputedStyle(document.documentElement);
        const accentColor = rootStyles.getPropertyValue('--accent-color').trim() || '#3b82f6';
        const textSecondary = rootStyles.getPropertyValue('--text-secondary').trim() || '#9ca3af';

        if (chartInstance) {
            chartInstance.destroy();
        }

        chartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Principal',
                        data: principalData,
                        backgroundColor: 'rgba(156, 163, 175, 0.3)',
                        borderColor: 'rgba(156, 163, 175, 0.8)',
                        borderWidth: 1
                    },
                    {
                        label: 'Interest',
                        data: interestData,
                        backgroundColor: accentColor,
                        borderColor: accentColor,
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { stacked: true, grid: { display: false } },
                    y: {
                        stacked: true,
                        grid: { color: 'rgba(156, 163, 175, 0.1)' },
                        ticks: {
                            callback: function(value) {
                                if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                                if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'k';
                                return '$' + value;
                            }
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) { label += ': '; }
                                if (context.parsed.y !== null) {
                                    label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(context.parsed.y);
                                }
                                return label;
                            }
                        }
                    }
                }
            }
        });
    }

    function init() {
      const inputs = document.querySelectorAll('.input-group input, .input-group select');
      inputs.forEach(input => {
        input.addEventListener('input', calculateSavings);
      });
      calculateSavings();
    }

    document.addEventListener('astro:page-load', init);
    // Fallback for direct load
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
  </script>

  <style>
    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      margin-bottom: 1rem;
    }

    .subtitle {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .calculator-container {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2rem;
      margin-bottom: 3rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    @media (min-width: 768px) {
      .calculator-container {
        grid-template-columns: 1fr 1fr;
      }
    }

    .input-section {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .input-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    .prefix, .suffix {
      position: absolute;
      color: var(--text-secondary);
      font-weight: 500;
      pointer-events: none;
    }

    .prefix { left: 1rem; }
    .suffix { right: 1rem; }

    input[type="number"], select {
      width: 100%;
      padding: 0.875rem 1rem;
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    /* Padding for absolute positioned spans */
    .input-wrapper:has(.prefix) input { padding-left: 2.5rem; }
    .input-wrapper:has(.suffix) input { padding-right: 3rem; }

    /* Fallback for browsers that don't support :has */
    input[id="initial-deposit"], input[id="monthly-contribution"] { padding-left: 2.5rem; }
    input[id="interest-rate"], input[id="years"] { padding-right: 3rem; }

    input[type="number"]:focus, select:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .results-section {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .result-card {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }

    .result-card.primary {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border-color: color-mix(in srgb, var(--accent-color) 30%, transparent);
    }

    .result-card h3 {
      font-size: 1.125rem;
      color: var(--text-secondary);
      margin-top: 0;
      margin-bottom: 0.5rem;
    }

    .result-value {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent-color);
      font-family: var(--font-mono, monospace);
    }

    .secondary-results {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .sub-result {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1rem;
      text-align: center;
    }

    .sub-result h4 {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin: 0 0 0.5rem 0;
    }

    .sub-result .val {
      font-size: 1.25rem;
      font-weight: 700;
      font-family: var(--font-mono, monospace);
    }

    .sub-result .accent {
      color: var(--accent-color);
    }

    .chart-container {
        background: var(--bg-color);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1rem;
        height: 250px;
        position: relative;
    }

    .content-section {
      margin-bottom: 3rem;
    }

    .content-section h2 {
      font-size: 1.75rem;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
    }

    .content-section h3 {
      font-size: 1.25rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    .content-section p {
      margin-bottom: 1rem;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .content-section ul, .content-section ol {
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    .content-section li {
      margin-bottom: 0.5rem;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .faq-item h3 {
      margin-top: 0;
      margin-bottom: 0.75rem;
      font-size: 1.125rem;
    }

    .faq-item p {
      margin-bottom: 0;
    }
  </style>
</SiteLayout>
