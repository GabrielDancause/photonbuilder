    .suggestion:hover { background: #0a1020; }
    .suggestion:last-child { border-bottom: none; }
    .suggestion-ticker { color: #4a8fe7; font-weight: 600; }
    .suggestion-name { color: #8a9ab0; margin-left: 8px; }
    .btn { background: #4a8fe7; color: #fff; border: none; padding: 12px 24px; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn:hover { background: #3a7fd7; transform: translateY(-1px); }
    .btn:disabled { background: #2a3a50; cursor: not-allowed; transform: none; }

    /* Stats Grid */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: linear-gradient(135deg, #0a1020 0%, #0d1428 100%); border: 1px solid #152040; border-radius: 12px; padding: 20px; text-align: center; }
    .stat-value { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 700; color: #4a8fe7; line-height: 1.1; }
    .stat-label { font-size: 0.75rem; color: #8a9ab0; margin-top: 4px; }
    .stat-green { color: #48bb78; }

    /* Portfolio Holdings */
    .holdings-section { margin-bottom: 32px; }
    .holdings-table { width: 100%; border-collapse: collapse; background: #060a12; border-radius: 12px; overflow: hidden; border: 1px solid #152040; }
    .holdings-table th, .holdings-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid #152040; }
    .holdings-table th { background: #0a1020; font-size: 0.8rem; color: #8a9ab0; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
