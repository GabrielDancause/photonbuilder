    .form-input:focus { outline: none; border-color: #4a8fe7; }
    .suggestions { position: absolute; background: #060a12; border: 1px solid #152040; border-radius: 8px; max-height: 200px; overflow-y: auto; z-index: 100; width: 100%; margin-top: 2px; }
