    <div class="methodology">
      <h2>Methodology</h2>
      <p>This net worth tracker calculates your total assets minus total liabilities in real time as you enter values. Asset allocation percentages are derived from the six asset categories (cash, investments, real estate, retirement, vehicles, other). The debt-to-asset ratio divides total liabilities by total assets — lower is better.</p>
      <p>Snapshots are saved to your browser's localStorage, meaning your data stays on your device and is never sent to any server. Historical tracking shows your net worth trend over time with change amounts between snapshots. Clear your browser data to remove all stored snapshots.</p>
    </div>

    <div class="disclaimer">This tool is for informational and educational purposes only. It does not constitute financial advice. All data is stored locally in your browser — we never collect or transmit your financial information. Consult a certified financial planner for personalized advice.</div>
</div>

  <script is:inline>
// Asset groups and colors
const ASSET_GROUPS = {
  cash: {label:'Cash & Savings', color:'#4a8fe7'},
  investments: {label:'Investments', color:'#22c55e'},
  realEstate: {label:'Real Estate', color:'#f59e0b'},
  retirement: {label:'Retirement', color:'#8b5cf6'},
  vehicles: {label:'Vehicles', color:'#ec4899'},
  otherAssets: {label:'Other Assets', color:'#6b7280'}
};

const LIABILITY_GROUPS = {
  mortgage:'Mortgage', autoLoans:'Auto Loans', studentLoans:'Student Loans',
  creditCards:'Credit Cards', personalLoans:'Personal Loans', otherLiabilities:'Other'
};

const LS_KEY = 'westmount_nw_snapshots';

function getSnapshots() {
  try { return JSON.parse(localStorage.getItem(LS_KEY)) || []; }
  catch { return []; }
}

function saveSnapshots(data) {
  localStorage.setItem(LS_KEY, JSON.stringify(data));
}

function fmtMoney(v) {
  const abs = Math.abs(v);
  const sign = v < 0 ? '-' : '';
  if (abs >= 1e6) return sign + '$' + (abs/1e6).toFixed(1) + 'M';
  if (abs >= 1e3) return sign + '$' + (abs/1e3).toFixed(1) + 'K';
  return sign + '$' + abs.toLocaleString('en-US', {maximumFractionDigits:0});
}

function getGroupTotal(group) {
  let total = 0;
  document.querySelectorAll(`input[data-group="${group}"]`).forEach(inp => {
    total += parseFloat(inp.value) || 0;
  });
  return total;
}

function getAllTotals() {
  let totalAssets = 0, totalLiabilities = 0;
  const assetBreakdown = {};
  const liabilityBreakdown = {};

  for (const g in ASSET_GROUPS) {
    const t = getGroupTotal(g);
    assetBreakdown[g] = t;
    totalAssets += t;
  }
  for (const g in LIABILITY_GROUPS) {
    const t = getGroupTotal(g);
    liabilityBreakdown[g] = t;
    totalLiabilities += t;
  }

  return {
    totalAssets, totalLiabilities,
    netWorth: totalAssets - totalLiabilities,
    debtToAsset: totalAssets > 0 ? totalLiabilities / totalAssets : 0,
    assetBreakdown, liabilityBreakdown
  };
}

function updateSummary() {
  const t = getAllTotals();
  const nwClass = t.netWorth >= 0 ? 'positive' : 'negative';
  document.getElementById('summary').innerHTML = `
    <div class="summary-card"><div class="val neutral">${fmtMoney(t.totalAssets)}</div><div class="label">Total Assets</div></div>
    <div class="summary-card"><div class="val negative">${fmtMoney(t.totalLiabilities)}</div><div class="label">Total Liabilities</div></div>
    <div class="summary-card"><div class="val ${nwClass}">${fmtMoney(t.netWorth)}</div><div class="label">Net Worth</div></div>
    <div class="summary-card"><div class="val neutral">${(t.debtToAsset * 100).toFixed(1)}%</div><div class="label">Debt-to-Asset Ratio</div></div>
  `;

  // Category totals
  for (const g in ASSET_GROUPS) {
    const el = document.getElementById('cat' + g.charAt(0).toUpperCase() + g.slice(1));
    if (el) el.textContent = fmtMoney(t.assetBreakdown[g]);
  }
  // Map group names to element IDs for liabilities
  const liabIdMap = {mortgage:'Mortgage',autoLoans:'AutoLoans',studentLoans:'StudentLoans',creditCards:'CreditCards',personalLoans:'PersonalLoans',otherLiabilities:'OtherLiabilities'};
  for (const g in LIABILITY_GROUPS) {
    const el = document.getElementById('cat' + liabIdMap[g]);
    if (el) el.textContent = fmtMoney(t.liabilityBreakdown[g]);
  }

  updatePieChart(t);
}

function updatePieChart(t) {
  const pieEl = document.getElementById('pieChart');
  const legendEl = document.getElementById('pieLegend');
  document.getElementById('pieCenterVal').textContent = fmtMoney(t.totalAssets);

  if (t.totalAssets === 0) {
    pieEl.style.background = 'var(--border-color)';
    legendEl.innerHTML = '<div style="color:var(--text-secondary);font-size:13px">Enter asset values to see allocation</div>';
    return;
  }

  // Build conic gradient
  const segments = [];
  let cumPct = 0;
  const legendItems = [];

  for (const g in ASSET_GROUPS) {
    const pct = (t.assetBreakdown[g] / t.totalAssets) * 100;
    if (pct > 0) {
      segments.push(`${ASSET_GROUPS[g].color} ${cumPct}% ${cumPct + pct}%`);
      legendItems.push({label: ASSET_GROUPS[g].label, color: ASSET_GROUPS[g].color, pct, val: t.assetBreakdown[g]});
      cumPct += pct;
    }
  }

  pieEl.style.background = `conic-gradient(${segments.join(', ')})`;

  legendEl.innerHTML = legendItems.map(li =>
    `<div class="legend-item">
      <div class="legend-dot" style="background:${li.color}"></div>
      <span class="legend-label">${li.label} (${li.pct.toFixed(1)}%)</span>
      <span class="legend-val">${fmtMoney(li.val)}</span>
    </div>`
  ).join('');
}

function renderTrendChart() {
  const snapshots = getSnapshots();
  const container = document.getElementById('trendChart');
  const noData = document.getElementById('noTrendData');

  if (snapshots.length === 0) {
    container.innerHTML = '';
    container.appendChild(noData || Object.assign(document.createElement('div'), {
      className:'no-data',
      innerHTML:'<span>No snapshots yet</span><span style="font-size:12px">Save your first snapshot to start tracking</span>'
    }));
    return;
  }

  const values = snapshots.map(s => s.netWorth);
  const maxVal = Math.max(...values, 0);
  const minVal = Math.min(...values, 0);
  const range = maxVal - minVal || 1;
  const padding = range * 0.1;
  const chartMin = minVal - padding;
  const chartMax = maxVal + padding;
  const chartRange = chartMax - chartMin;

  // Y-axis labels
  const ySteps = 5;
  let yLabelsHtml = '';
  for (let i = ySteps; i >= 0; i--) {
    const val = chartMin + (chartRange * i / ySteps);
    yLabelsHtml += `<div>${fmtMoney(val)}</div>`;
  }

  // Gridlines
  let gridHtml = '';
  for (let i = 0; i <= ySteps; i++) {
    const top = (i / ySteps) * 100;
    gridHtml += `<div class="chart-gridline" style="top:${top}%"></div>`;
  }

  // Points and line
  let pointsHtml = '';
  let svgPath = '';
  const n = snapshots.length;

  snapshots.forEach((s, i) => {
    const x = n === 1 ? 50 : (i / (n - 1)) * 100;
    const y = 100 - ((s.netWorth - chartMin) / chartRange) * 100;
    pointsHtml += `<div class="chart-point" style="left:${x}%;top:${y}%"><div class="chart-point-label">${fmtMoney(s.netWorth)}</div></div>`;
    if (i === 0) svgPath += `M ${x} ${y}`;
    else svgPath += ` L ${x} ${y}`;
  });

  // X labels
  let xLabelsHtml = '';
  const maxXLabels = 8;
  const step = Math.max(1, Math.ceil(n / maxXLabels));
  snapshots.forEach((s, i) => {
    if (i % step === 0 || i === n - 1) {
      xLabelsHtml += `<div>${s.date}</div>`;
    }
  });

  container.innerHTML = `
    <div class="chart-canvas">
      <div class="chart-y-labels">${yLabelsHtml}</div>
      <div class="chart-area">
        ${gridHtml}
        <svg class="chart-svg" viewBox="0 0 100 100" preserveAspectRatio="none">
          <polyline points="${snapshots.map((s, i) => {
            const x = n === 1 ? 50 : (i / (n - 1)) * 100;
            const y = 100 - ((s.netWorth - chartMin) / chartRange) * 100;
            return `${x},${y}`;
          }).join(' ')}" fill="none" stroke="var(--accent-color)" stroke-width="1.5" vector-effect="non-scaling-stroke"/>
        </svg>
        ${pointsHtml}
      </div>
    </div>
    <div class="chart-x-labels">${xLabelsHtml}</div>
  `;
}

function renderSnapshotTable() {
  const snapshots = getSnapshots();
  const tbody = document.getElementById('snapshotBody');

  if (snapshots.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-secondary);padding:20px">No snapshots saved yet. Enter your values and click "Save Snapshot" to begin tracking.</td></tr>';
    return;
  }

  tbody.innerHTML = snapshots.map((s, i) => {
    const prev = i > 0 ? snapshots[i - 1].netWorth : null;
    const change = prev !== null ? s.netWorth - prev : null;
    const changeStr = change !== null
      ? `<span class="${change >= 0 ? 'pos' : 'neg'}">${change >= 0 ? '+' : ''}${fmtMoney(change)}</span>`
      : '—';
    const ratio = s.totalAssets > 0 ? ((s.totalLiabilities / s.totalAssets) * 100).toFixed(1) + '%' : '0%';
    return `<tr>
      <td>${s.date}</td>
      <td class="num">${fmtMoney(s.totalAssets)}</td>
      <td class="num">${fmtMoney(s.totalLiabilities)}</td>
      <td class="num" style="font-weight:700;color:${s.netWorth >= 0 ? '#22c55e' : '#ef4444'}">${fmtMoney(s.netWorth)}</td>
      <td class="num">${changeStr}</td>
      <td class="num">${ratio}</td>
      <td><button class="del-btn" data-idx="${i}" title="Delete snapshot">×</button></td>
    </tr>`;
  }).join('');

  // Delete handlers
  tbody.querySelectorAll('.del-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.idx);
      const snaps = getSnapshots();
      snaps.splice(idx, 1);
      saveSnapshots(snaps);
      renderSnapshotTable();
      renderTrendChart();
    });
  });
}

// Save snapshot
document.getElementById('saveSnapshot').addEventListener('click', () => {
  const t = getAllTotals();
  if (t.totalAssets === 0 && t.totalLiabilities === 0) {
    alert('Please enter at least one asset or liability value before saving a snapshot.');
    return;
  }

  const now = new Date();
  const date = now.toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});
  const snapshot = {
    date,
    timestamp: now.getTime(),
    totalAssets: t.totalAssets,
    totalLiabilities: t.totalLiabilities,
    netWorth: t.netWorth,
    assetBreakdown: t.assetBreakdown,
    liabilityBreakdown: t.liabilityBreakdown
  };

  const snaps = getSnapshots();
  snaps.push(snapshot);
  saveSnapshots(snaps);
  renderSnapshotTable();
  renderTrendChart();
  alert('Snapshot saved! Your net worth has been recorded.');
});

// Clear form
document.getElementById('clearForm').addEventListener('click', () => {
  document.querySelectorAll('input[type="number"]').forEach(inp => { inp.value = ''; });
  updateSummary();
});

// Clear history
document.getElementById('clearHistory').addEventListener('click', () => {
  if (confirm('Are you sure? This will permanently delete all saved snapshots.')) {
    localStorage.removeItem(LS_KEY);
    renderSnapshotTable();
    renderTrendChart();
  }
});

// Live calculation on input
document.querySelectorAll('input[type="number"]').forEach(inp => {
  inp.addEventListener('input', updateSummary);
});

// FAQ
const faqs = [
  {q:"What is net worth and how do you calculate it?",a:"Net worth is the difference between what you own (assets) and what you owe (liabilities). Add up all your assets — cash, investments, real estate, retirement accounts, vehicles, and other valuables — then subtract all debts including mortgage, auto loans, student loans, credit cards, and personal loans. A positive net worth means your assets exceed your debts. Tracking net worth over time is the single best measure of financial progress."},
  {q:"What is a good net worth by age?",a:"A common benchmark from The Millionaire Next Door: expected net worth = age × pre-tax income ÷ 10. The Federal Reserve's Survey of Consumer Finances shows median net worth by age: under 35 ($39,000), 35–44 ($135,600), 45–54 ($247,200), 55–64 ($364,500), 65–74 ($409,900). These are medians — averages are 3–5x higher due to wealth concentration."},
  {q:"Should I include my home in net worth calculations?",a:"Yes — include your home's market value as an asset and mortgage balance as a liability. Your home equity (value minus mortgage) contributes to net worth. Many planners also track 'investable net worth' excluding your primary residence since you can't easily liquidate it. This tracker separates real estate so you can see both figures."},
  {q:"How often should I track my net worth?",a:"Monthly tracking is ideal — frequent enough to spot trends but not so often that daily market fluctuations cause anxiety. Quarterly works if monthly feels excessive. The key is consistency: pick a schedule and stick to it. Many people track on the 1st of each month. Avoid daily checking — short-term investment fluctuations can be misleading."},
  {q:"What is a good debt-to-asset ratio?",a:"Below 0.5 (50%) is generally healthy, meaning you own more than you owe. Below 0.3 (30%) is strong, below 0.1 (10%) indicates very low leverage. Young adults often have ratios above 1.0 due to student loans and mortgages — this is normal and improves over time as you pay down debt and grow assets. The ratio should decrease steadily year over year."}
];

const faqEl = document.getElementById('faq');
faqs.forEach(f => {
  faqEl.innerHTML += `<div class="faq-item"><div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div></div>`;
});
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});

// Initial render
updateSummary();
renderSnapshotTable();
renderTrendChart();
  </script>

