<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  
  // Year filter functionality
  const filterBtns = document.querySelectorAll('.filter-btn');
  const tableRows = document.querySelectorAll('#tableBody tr');
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const year = this.dataset.year;
      
      // Update active button
      filterBtns.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      
      // Filter table rows
      tableRows.forEach(row => {
        if (year === 'all' || row.dataset.year === year) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });
  });

  // Chart.js configuration
  const chartData = {
    labels: ['Dec 22', 'Feb 23', 'Mar 23', 'Apr 23', 'May 23', 'Jun 23', 'Jul 23', 'Aug 23', 'Sep 23', 'Oct 23', 'Nov 23', 'Dec 23', 'Feb 24', 'Mar 24', 'Apr 24', 'May 24', 'Jun 24', 'Jul 24', 'Aug 24', 'Sep 24', 'Oct 24', 'Nov 24', 'Dec 24', 'Feb 25', 'Mar 25', 'Apr 25', 'May 25', 'Jun 25', 'Jul 25', 'Aug 25', 'Sep 25', 'Oct 25', 'Nov 25', 'Dec 25', 'Feb 26', 'Mar 26'],
    datasets: [{
      label: 'Monthly Distribution ($)',
      data: [0.57554, 0.44065, 0.43296, 0.45394, 0.48406, 0.35656, 0.3668, 0.36588, 0.45056, 0.41719, 0.41766, 0.42214, 0.34167, 0.38037, 0.42728, 0.43112, 0.4497, 0.42115, 0.42676, 0.55686, 0.55062, 0.49362, 0.50832, 0.45019, 0.48238, 0.54069, 0.59786, 0.62074, 0.49416, 0.44377, 0.44195, 0.44612, 0.47553, 0.55323, 0.46572, 0.509],
      backgroundColor: '#4a8fe7',
      borderColor: '#4a8fe7',
      borderWidth: 2,
      fill: false,
      tension: 0.1
    }]
  };

  const ctx = document.getElementById('distributionChart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: chartData,
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          labels: {
            color: '#e0e6ed'
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: {
            color: '#152040'
          },
          ticks: {
            color: '#8892b0',
            callback: function(value) {
              return '$' + value.toFixed(2);
            }
          }
        },
        x: {
          grid: {
            color: '#152040'
          },
          ticks: {
            color: '#8892b0',
            maxTicksLimit: 12
          }
        }
      },
      elements: {
        point: {
          radius: 4,
          hoverRadius: 6
        }
      }
    }
  });

  // Calculator functionality
  const investmentInput = document.getElementById('investment-amount');
  const shareInput = document.getElementById('share-count');
  const yieldInput = document.getElementById('current-yield');
  const reinvestCheckbox = document.getElementById('reinvest');
  const calculateBtn = document.getElementById('calculate-btn');
  const resultsDiv = document.getElementById('calculator-results');
  
  const currentPrice = 54.13;

  // Auto-calculate shares when investment amount changes
  investmentInput.addEventListener('input', function() {
    if (this.value) {
      const shares = Math.floor(parseFloat(this.value) / currentPrice);
      shareInput.value = shares;
    }
  });

  // Auto-calculate investment when shares change
  shareInput.addEventListener('input', function() {
    if (this.value) {
      const investment = parseFloat(this.value) * currentPrice;
      investmentInput.value = investment.toFixed(0);
    }
  });

  calculateBtn.addEventListener('click', function() {
    const investment = parseFloat(investmentInput.value) || 0;
    const shares = parseFloat(shareInput.value) || Math.floor(investment / currentPrice);
    const yieldPercent = parseFloat(yieldInput.value) || 11.39;
    const shouldReinvest = reinvestCheckbox.checked;

    if (shares > 0) {
      const annualIncome = (shares * currentPrice * yieldPercent / 100);
      const monthlyIncome = annualIncome / 12;

      document.getElementById('monthly-income').textContent = '$' + monthlyIncome.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0});
      document.getElementById('annual-income').textContent = '$' + annualIncome.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0});
      document.getElementById('total-shares').textContent = shares.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0});
      document.getElementById('yield-on-cost').textContent = yieldPercent.toFixed(2) + '%';

      // 5-year projection
      if (shouldReinvest) {
        const projectionBody = document.getElementById('projection-body');
        projectionBody.innerHTML = '';

        let currentShares = shares;
        for (let year = 1; year <= 5; year++) {
          const yearlyIncome = currentShares * currentPrice * yieldPercent / 100;
          const newShares = yearlyIncome / currentPrice;
          currentShares += newShares;
          const totalValue = currentShares * currentPrice;

          const row = `<tr>
            <td>Year ${year}</td>
            <td>${currentShares.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0})}</td>
            <td>$${yearlyIncome.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0})}</td>
            <td>$${totalValue.toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0})}</td>
          </tr>`;
          projectionBody.innerHTML += row;
        }
      }

      resultsDiv.style.display = 'block';
    }
  });

  // Trigger initial calculation
  calculateBtn.click();
});
</script>

