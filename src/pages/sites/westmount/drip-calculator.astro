---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "DRIP Calculator (Dividend Reinvestment Plan)",
  description: "Discover how powerful compound growth can be. Calculate your future portfolio value and passive income using our interactive DRIP calculator.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a DRIP?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A DRIP, or Dividend Reinvestment Plan, is an arrangement offered by corporations or brokerages that allows investors to automatically reinvest their cash dividends into additional shares or fractional shares of the underlying stock."
          }
        },
        {
          "@type": "Question",
          "name": "Why are DRIPs effective for long-term investing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DRIPs are effective because they harness the power of compound interest. By reinvesting dividends to buy more shares, those new shares generate their own dividends in the future, accelerating the growth of your portfolio over time."
          }
        },
        {
          "@type": "Question",
          "name": "Do I have to pay taxes on reinvested dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, unless the investments are held in a tax-advantaged account like an IRA or a TFSA, you are generally required to pay taxes on dividends in the year they are issued, even if they are automatically reinvested."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between yield and growth?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dividend yield is the annual dividend payout expressed as a percentage of the current share price. Dividend growth refers to the annualized rate at which a company increases its dividend payout over time."
          }
        },
        {
          "@type": "Question",
          "name": "Can DRIPs buy fractional shares?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, one of the primary benefits of a DRIP is that it typically allows the purchase of fractional shares, ensuring that every cent of your dividend is immediately put back to work."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      }
    }
  ]
};
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/drip-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>{meta.title}</h1>
      <p class="subtitle">Calculate the compounding power of dividend reinvestment over time</p>
    </div>

    <div class="calculator-container">
      <div class="input-grid">
        <div class="input-group">
          <label for="initial-investment">Initial Investment ($)</label>
          <input type="number" id="initial-investment" value="10000" min="0" step="100" />
        </div>
        <div class="input-group">
          <label for="share-price">Initial Share Price ($)</label>
          <input type="number" id="share-price" value="50" min="0.01" step="0.5" />
        </div>
        <div class="input-group">
          <label for="dividend-yield">Annual Dividend Yield (%)</label>
          <input type="number" id="dividend-yield" value="4.0" min="0" step="0.1" />
        </div>
        <div class="input-group">
          <label for="expected-growth">Expected Annual Stock Growth (%)</label>
          <input type="number" id="expected-growth" value="6.0" min="0" step="0.1" />
        </div>
        <div class="input-group">
          <label for="div-growth">Expected Annual Dividend Growth (%)</label>
          <input type="number" id="div-growth" value="5.0" min="0" step="0.1" />
        </div>
        <div class="input-group">
          <label for="years">Years to Invest</label>
          <input type="number" id="years" value="10" min="1" step="1" />
        </div>
      </div>

      <div class="results-grid">
        <div class="result-card primary-result">
          <div class="result-label">Total Portfolio Value</div>
          <div class="result-value" id="final-value">$0.00</div>
        </div>
        <div class="result-card">
          <div class="result-label">Total Dividends Reinvested</div>
          <div class="result-value" id="total-dividends">$0.00</div>
        </div>
        <div class="result-card">
          <div class="result-label">Annual Income (Final Year)</div>
          <div class="result-value" id="final-income">$0.00</div>
        </div>
      </div>

      <div class="table-container">
        <table id="drip-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Share Price</th>
              <th>Total Shares</th>
              <th>Annual Dividend</th>
              <th>End Portfolio Value</th>
            </tr>
          </thead>
          <tbody>
            <!-- Populated by JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding the DRIP Calculator</h2>
      <p>A Dividend Reinvestment Plan (DRIP) is one of the most powerful wealth-building strategies available to long-term investors. Rather than taking cash payouts from dividends, a DRIP automatically uses those distributions to purchase additional shares—or fractional shares—of the underlying stock. Over time, this creates a compounding effect, as your new shares begin generating their own dividends. Our interactive DRIP calculator is designed to help you visualize the long-term impact of this compounding process based on your initial investment and projected growth rates.</p>

      <h3>The Power of Compound Interest</h3>
      <p>Compound interest is often referred to as the "eighth wonder of the world," and DRIP investing is its purest application in the stock market. When you reinvest dividends, the growth of your portfolio is not linear; it is exponential. As your share count increases, your total dividend payout increases, allowing you to buy even more shares the following quarter or year.</p>

      <p>Consider the core variables in our calculator:</p>
      <ul>
        <li><strong>Initial Investment & Share Price:</strong> These determine your starting share count. If you invest $10,000 at $50 per share, you begin with 200 shares.</li>
        <li><strong>Annual Dividend Yield:</strong> This is the percentage of the share price paid out annually. A 4% yield on a $50 stock is $2.00 per share per year.</li>
        <li><strong>Expected Stock Growth:</strong> The estimated percentage the underlying stock price will appreciate each year. As the price goes up, each reinvested dividend buys fewer fractional shares, but your existing holdings become more valuable.</li>
        <li><strong>Dividend Growth:</strong> High-quality companies (often referred to as Dividend Aristocrats) consistently raise their dividend payouts year over year. If a $2.00 dividend grows by 5% annually, it becomes $2.10 the next year, further accelerating your compounding engine.</li>
      </ul>

      <h3>DRIP vs. Cash Dividends</h3>
      <p>While taking cash dividends is perfectly viable for investors seeking immediate income, choosing not to reinvest fundamentally alters the trajectory of your portfolio. If you take cash, your portfolio's growth relies entirely on capital appreciation (the stock price going up). With a DRIP, your portfolio can continue to grow—in terms of share count and future income potential—even during flat or bear markets. In fact, when the stock price is down, your reinvested dividends buy more fractional shares at a discount.</p>

      <h3>Tax Implications</h3>
      <p>It is important to understand that reinvesting dividends does not shield them from taxation unless the assets are held in a tax-advantaged account like a Roth IRA or a Tax-Free Savings Account (TFSA). In a standard taxable brokerage account, you will owe taxes on the dividends in the year they are distributed, even if you never see the cash because it was automatically reinvested. However, because you are purchasing new shares with the dividends, those new shares establish their own cost basis, which is important for calculating future capital gains taxes.</p>

      <h3>Integration with Overall Strategy</h3>
      <p>Dividend investing is a long game. The most significant growth occurs in the later years of a multi-decade timeframe as the compounding curve steepens. It is a strategy of patience and consistency. While DRIP investing provides steady, predictable share accumulation, some investors look to supplement their returns or hedge their positions using options. If you are interested in exploring how options can generate additional yield or define risk, check out our <a href="/sites/westmount/options-calculator">Options Profit Calculator</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is a DRIP?</summary>
        <p>A DRIP, or Dividend Reinvestment Plan, is an arrangement offered by corporations or brokerages that allows investors to automatically reinvest their cash dividends into additional shares or fractional shares of the underlying stock.</p>
      </details>
      <details>
        <summary>Why are DRIPs effective for long-term investing?</summary>
        <p>DRIPs are effective because they harness the power of compound interest. By reinvesting dividends to buy more shares, those new shares generate their own dividends in the future, accelerating the growth of your portfolio over time.</p>
      </details>
      <details>
        <summary>Do I have to pay taxes on reinvested dividends?</summary>
        <p>Yes, unless the investments are held in a tax-advantaged account like an IRA or a TFSA, you are generally required to pay taxes on dividends in the year they are issued, even if they are automatically reinvested.</p>
      </details>
      <details>
        <summary>What is the difference between yield and growth?</summary>
        <p>Dividend yield is the annual dividend payout expressed as a percentage of the current share price. Dividend growth refers to the annualized rate at which a company increases its dividend payout over time.</p>
      </details>
      <details>
        <summary>Can DRIPs buy fractional shares?</summary>
        <p>Yes, one of the primary benefits of a DRIP is that it typically allows the purchase of fractional shares, ensuring that every cent of your dividend is immediately put back to work.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = {
        initialInvestment: document.getElementById('initial-investment'),
        sharePrice: document.getElementById('share-price'),
        dividendYield: document.getElementById('dividend-yield'),
        expectedGrowth: document.getElementById('expected-growth'),
        divGrowth: document.getElementById('div-growth'),
        years: document.getElementById('years')
      };

      const outputs = {
        finalValue: document.getElementById('final-value'),
        totalDividends: document.getElementById('total-dividends'),
        finalIncome: document.getElementById('final-income'),
        tableBody: document.querySelector('#drip-table tbody')
      };

      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      const formatNumber = (val) => new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 }).format(val);

      function calculate() {
        // Parse inputs
        const initialInvestment = parseFloat(inputs.initialInvestment.value) || 0;
        let currentSharePrice = parseFloat(inputs.sharePrice.value) || 0.01;
        if (currentSharePrice <= 0) currentSharePrice = 0.01; // prevent division by zero
        let currentDividendPerShare = currentSharePrice * ((parseFloat(inputs.dividendYield.value) || 0) / 100);

        const stockGrowthRate = (parseFloat(inputs.expectedGrowth.value) || 0) / 100;
        const divGrowthRate = (parseFloat(inputs.divGrowth.value) || 0) / 100;
        const years = parseInt(inputs.years.value, 10) || 1;

        let totalShares = initialInvestment / currentSharePrice;
        let totalDividendsReinvested = 0;
        let finalIncome = 0;

        outputs.tableBody.innerHTML = '';

        for (let year = 1; year <= years; year++) {
          // Calculate dividends for the year
          const annualDividend = totalShares * currentDividendPerShare;
          totalDividendsReinvested += annualDividend;

          // Grow the stock price and dividend for the NEXT year
          // We reinvest at the end of the year at the current price before growth
          const newShares = annualDividend / currentSharePrice;
          totalShares += newShares;

          currentSharePrice *= (1 + stockGrowthRate);
          currentDividendPerShare *= (1 + divGrowthRate);

          if (year === years) {
            finalIncome = totalShares * currentDividendPerShare;
          }

          const endValue = totalShares * currentSharePrice;

          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>Year ${year}</td>
            <td>${formatCurrency(currentSharePrice)}</td>
            <td>${formatNumber(totalShares)}</td>
            <td>${formatCurrency(annualDividend)}</td>
            <td>${formatCurrency(endValue)}</td>
          `;
          outputs.tableBody.appendChild(tr);
        }

        const finalPortfolioValue = totalShares * currentSharePrice;

        outputs.finalValue.textContent = formatCurrency(finalPortfolioValue);
        outputs.totalDividends.textContent = formatCurrency(totalDividendsReinvested);
        outputs.finalIncome.textContent = formatCurrency(finalIncome);
      }

      // Add event listeners
      Object.values(inputs).forEach(input => {
        if (input) {
          input.addEventListener('input', calculate);
          input.addEventListener('change', calculate);
        }
      });

      // Initial calculation
      calculate();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .input-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; text-align: center; }
    .primary-result { background: color-mix(in srgb, #22c55e 10%, transparent); border-color: #22c55e; }
    .primary-result .result-value { color: #22c55e; }

    .result-label { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
    .result-value { font-size: 2rem; font-weight: 800; color: var(--accent-color); }

    .table-container { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th, td { padding: 1rem; border-bottom: 1px solid var(--border-color); }
    th { color: var(--text-secondary); font-weight: 600; font-size: 0.9rem; }
    td { font-family: var(--font-mono, monospace); }

    .explainer { margin-top: 3rem; line-height: 1.7; }
    .explainer h2, .explainer h3 { color: var(--text-primary); margin-top: 2rem; margin-bottom: 1rem; }
    .explainer p, .explainer ul { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer code { background: color-mix(in srgb, var(--text-primary) 10%, transparent); padding: 0.2rem 0.4rem; border-radius: 4px; font-family: monospace; }
    .explainer a { color: var(--accent-color); text-decoration: none; }
    .explainer a:hover { text-decoration: underline; }

    .faq-section { margin-top: 3rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); }
    .faq-section p { margin-top: 1rem; color: var(--text-secondary); margin-bottom: 0; }
  </style>
</SiteLayout>
