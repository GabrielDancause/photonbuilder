<script is:inline>
  function initDripCalculator() {
    const inputs = [
      document.getElementById('initialInvestment'),
      document.getElementById('sharePrice'),
      document.getElementById('annualYield'),
      document.getElementById('annualGrowth'),
      document.getElementById('annualContribution'),
      document.getElementById('years')
    ];

    if (!inputs[0]) return;

    // Format currency
    const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
    const formatNumber = (val) => new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 }).format(val);

    const calculateDrip = () => {
      // Get inputs
      const initialInvestment = parseFloat(document.getElementById('initialInvestment').value) || 0;
      const initialSharePrice = parseFloat(document.getElementById('sharePrice').value) || 0;
      const annualYield = (parseFloat(document.getElementById('annualYield').value) || 0) / 100;
      const annualGrowth = (parseFloat(document.getElementById('annualGrowth').value) || 0) / 100;
      const annualContribution = parseFloat(document.getElementById('annualContribution').value) || 0;
      let years = parseInt(document.getElementById('years').value) || 0;

      // Basic validation & Edge cases
      if (years > 100) years = 100; // Prevent infinite/massive loops
      if (years < 0) years = 0;
      if (initialSharePrice <= 0 || years === 0) {
        // Just empty out the results gracefully instead of blocking alert on input
        document.getElementById('resTotalValue').textContent = "$0";
        document.getElementById('resTotalShares').textContent = "0";
        document.getElementById('resAnnualIncome').textContent = "$0";
        document.getElementById('resNoDripValue').textContent = "$0";
        document.getElementById('resDifference').textContent = "$0";
        document.getElementById('resYearsText').textContent = "0";
        document.getElementById('resExtraShares').textContent = "0";
        document.getElementById('scheduleBody').innerHTML = '<tr><td colspan="6" style="text-align:center; padding: 1rem;">Enter valid values to see schedule.</td></tr>';
        return;
      }

      const safeInitialInvestment = Math.max(0, initialInvestment);
      const safeAnnualContribution = Math.max(0, annualContribution);

      // Variables for DRIP tracking
      let shares = safeInitialInvestment / initialSharePrice;
      let sharePrice = initialSharePrice;
      let scheduleHtml = '';

      // Variables for Non-DRIP tracking
      let nonDripShares = shares;
      let nonDripCash = 0;

      for (let y = 1; y <= years; y++) {
        // 1. Add annual contribution at start of year (buys shares at current price)
        if (safeAnnualContribution > 0) {
            const newSharesFromContrib = safeAnnualContribution / sharePrice;
            shares += newSharesFromContrib;
            nonDripShares += newSharesFromContrib;
        }

        const startingShares = shares;

        // 2. Calculate dividend earned this year (based on current price and yield)
        const dividendPerShare = sharePrice * Math.max(0, annualYield);
        const totalDividendEarned = startingShares * dividendPerShare;

        // Non-DRIP dividend tracking
        const nonDripDividend = nonDripShares * dividendPerShare;
        nonDripCash += nonDripDividend;

        // 3. Reinvest dividend (DRIP)
        const newSharesBought = totalDividendEarned / sharePrice;
        shares += newSharesBought;

        // 4. End of year price appreciation
        sharePrice = sharePrice * (1 + annualGrowth);

        // Track schedule
        scheduleHtml += `
          <tr>
            <td>Year ${y}</td>
            <td>${formatCurrency(sharePrice)}</td>
            <td>${formatNumber(startingShares)}</td>
            <td>${formatCurrency(totalDividendEarned)}</td>
            <td>${formatNumber(newSharesBought)}</td>
            <td>${formatCurrency(shares * sharePrice)}</td>
          </tr>
        `;
      }

      // Final Calculations
      const dripFinalValue = shares * sharePrice;
      const finalDividendIncome = shares * sharePrice * annualYield;

      const nonDripFinalValue = (nonDripShares * sharePrice) + nonDripCash;

      const difference = dripFinalValue - nonDripFinalValue;
      const extraShares = shares - nonDripShares;

      // Update DOM
      document.getElementById('resTotalValue').textContent = formatCurrency(dripFinalValue);
      document.getElementById('resTotalShares').textContent = formatNumber(shares);
      document.getElementById('resAnnualIncome').textContent = formatCurrency(finalDividendIncome);
      document.getElementById('resNoDripValue').textContent = formatCurrency(nonDripFinalValue);

      document.getElementById('resDifference').textContent = formatCurrency(difference);
      document.getElementById('resYearsText').textContent = years;
      document.getElementById('resExtraShares').textContent = formatNumber(extraShares);

      document.getElementById('scheduleBody').innerHTML = scheduleHtml;
    };

    inputs.forEach(input => {
      if (input) {
        input.addEventListener('input', calculateDrip);
      }
    });

    // Initial calculation
    calculateDrip();
  }

  // Initialize on load and on View Transitions
  document.addEventListener('astro:page-load', initDripCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDripCalculator);
  } else {
    initDripCalculator();
  }
</script>
