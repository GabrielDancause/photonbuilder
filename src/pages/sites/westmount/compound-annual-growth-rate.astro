---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is CAGR and how is it calculated?","acceptedAnswer":{"@type":"Answer","text":"CAGR (Compound Annual Growth Rate) measures the mean annual growth rate of an investment over a specified period longer than one year. The formula is: CAGR = (Ending Value / Beginning Value)^(1/Years) - 1. For example, an investment that grows from $10,000 to $25,000 over 10 years has a CAGR of 9.6%. CAGR smooths out volatility to show a steady annual rate, making it the standard metric for comparing investment performance across different time periods and asset classes."}},
    {"@type":"Question","name":"What is the difference between CAGR and average annual return?","acceptedAnswer":{"@type":"Answer","text":"CAGR accounts for compounding while average annual return does not. If an investment gains 50% in year one and loses 33% in year two, the average annual return is +8.5% — but your actual ending value is the same as where you started (CAGR = 0%). CAGR reflects what actually happened to your money because it captures the compounding effect. Average return overstates performance when returns are volatile. The more volatile the returns, the larger the gap between average return and CAGR. This difference is known as 'volatility drag.'"}},
    {"@type":"Question","name":"What is a good CAGR for an investment?","acceptedAnswer":{"@type":"Answer","text":"A 'good' CAGR depends on the asset class and risk level. The S&P 500 has delivered approximately 10% CAGR over the past century (about 7% after inflation). Bonds have averaged roughly 5% CAGR. Real estate has historically returned 8-12% including rental income. A CAGR that consistently beats the relevant benchmark is considered excellent. For individual stocks, top performers like Amazon and Apple have delivered 25-35% CAGR over their best decades. Any CAGR above inflation (historically ~3%) means you are growing real purchasing power."}},
    {"@type":"Question","name":"How do I use CAGR to compare investments?","acceptedAnswer":{"@type":"Answer","text":"CAGR is the best metric for apples-to-apples comparison because it normalizes different time periods and starting amounts into a single annualized rate. To compare: calculate the CAGR for each investment over matching time periods. An investment with 12% CAGR over 10 years outperformed one with 8% CAGR over the same period, regardless of the path each took. However, also consider risk — two investments with the same CAGR but different volatility have different risk-adjusted returns. The Sharpe ratio pairs well with CAGR for this purpose."}},
    {"@type":"Question","name":"What is the CAGR of the S&P 500?","acceptedAnswer":{"@type":"Answer","text":"The S&P 500 has delivered approximately 10.2% CAGR including dividends over the past 50 years (1976-2026). Adjusted for inflation, the real CAGR is approximately 7%. Over the most recent 10 years (2016-2026), the S&P 500 CAGR has been approximately 12%, boosted by technology mega-cap growth. Over 20 years including the 2008 crisis and COVID crash, the CAGR is approximately 9.5%. These figures include dividend reinvestment — without dividends, the price-only CAGR is roughly 2 percentage points lower across all periods."}},
    {"@type":"Question","name":"Can CAGR be negative?","acceptedAnswer":{"@type":"Answer","text":"Yes, CAGR is negative when an investment loses value over the measured period. For example, if you invested $10,000 and it was worth $7,000 after 5 years, the CAGR is -6.9%. A negative CAGR means your money shrank on an annualized basis. This can happen with individual stocks, sector-specific funds, or even broad markets over certain periods. Japan's Nikkei 225 had a negative CAGR for over 30 years from its 1989 peak to its recovery. Negative CAGR is a clear signal that the investment underperformed cash."}},
    {"@type":"Question","name":"What are the limitations of CAGR?","acceptedAnswer":{"@type":"Answer","text":"CAGR has several limitations: (1) It assumes smooth growth and hides volatility — an investment with wild swings and one with steady growth can show the same CAGR. (2) It only considers the start and end values, ignoring what happened in between. (3) It does not account for additional investments or withdrawals during the period — use IRR (Internal Rate of Return) for that. (4) It is backward-looking and does not predict future returns. (5) It does not account for risk — pair CAGR with standard deviation or maximum drawdown for a complete picture."}},
    {"@type":"Question","name":"How is CAGR used in business and finance?","acceptedAnswer":{"@type":"Answer","text":"CAGR is used extensively beyond investment returns. Companies report revenue CAGR to show growth trajectory — a company growing revenue from $100M to $400M over 5 years has a 32% revenue CAGR. Analysts use earnings CAGR to project future valuations. Private equity firms use CAGR to benchmark fund performance. In business planning, CAGR helps forecast market size — if a market grew from $10B to $25B over 5 years (20% CAGR), planners might project continued growth at a moderated rate. CAGR is also used for population growth, GDP growth, and customer base expansion."}}
  ]
};

export const meta = {
  title: "CAGR Calculator — Compound Annual Growth Rate Tool",
  description: "Calculate CAGR instantly with formula breakdown, year-by-year growth table, reverse calculator, and multi-investment comparison chart. Compare against S&P 500, bonds, and inflation benchmarks.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="westmount"
  title="CAGR Calculator: Compound Annual Growth Rate & Annualized Return Tool"
  description="Calculate CAGR instantly with formula breakdown, year-by-year growth table, reverse calculator, and visual comparison chart. Benchmark against S&P 500 (~10%), bonds (~5%), and inflation (~3%)."
  canonical="https://westmountfundamentals.com/compound-annual-growth-rate" schema={schema}
>
  <style is:inline>
.container{max-width:1200px;margin:0 auto;padding:0 20px}
a{color:var(--accent-color);text-decoration:none}
a:hover{text-decoration:underline}

header{padding:40px 0 20px;border-bottom:1px solid var(--border-color)}
.badge{display:inline-block;background:var(--accent-color);color:#fff;font-size:11px;font-weight:700;letter-spacing:1.5px;padding:4px 12px;border-radius:3px;text-transform:uppercase;margin-bottom:12px}
h1{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.15;margin-bottom:8px}
.subtitle{color:var(--text-secondary);font-size:18px;max-width:700px}
.updated-badge{display:inline-block;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-secondary);font-size:12px;padding:4px 10px;border-radius:4px;margin-top:8px;font-family:'JetBrains Mono',monospace}

/* Calculator */
.calc-section{margin:32px 0}
.calc-section h2{font-size:22px;margin-bottom:16px}
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
.calc-inputs{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.calc-results{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.input-group{margin-bottom:16px}
.input-group label{display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:6px}
.input-group input,.input-group select{width:100%;background:var(--card-bg);border:1px solid var(--border-color);color:var(--text-primary);padding:10px 12px;border-radius:6px;font-size:14px;font-family:'Inter',sans-serif;box-sizing:border-box}
.input-group input:focus{outline:none;border-color:var(--accent-color)}
.input-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.input-hint{font-size:11px;color:var(--text-secondary);margin-top:4px}
.calc-btn{width:100%;padding:12px;background:var(--accent-color);color:#fff;border:none;border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;margin-top:8px}
.calc-btn:hover{opacity:.9}

/* Tabs */
.tab-row{display:flex;gap:0;margin-bottom:20px;border-bottom:2px solid var(--border-color)}
.tab-btn{padding:10px 20px;background:none;border:none;color:var(--text-secondary);font-size:14px;font-weight:600;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;font-family:'Inter',sans-serif}
.tab-btn.active{color:var(--accent-color);border-bottom-color:var(--accent-color)}
.tab-btn:hover{color:var(--text-primary)}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* Results */
.result-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.result-box{text-align:center;padding:16px 8px;background:rgba(74,143,231,.04);border-radius:8px;border:1px solid var(--border-color)}
.result-box .val{font-size:28px;font-weight:800;font-family:'JetBrains Mono',monospace;color:var(--accent-color)}
.result-box .label{font-size:11px;color:var(--text-secondary);margin-top:4px;text-transform:uppercase;letter-spacing:.5px}
.result-box.highlight{border-color:var(--accent-color);background:rgba(74,143,231,.08)}
.result-placeholder{text-align:center;padding:40px 20px;color:var(--text-secondary);font-size:14px}

/* Formula */
.formula-box{background:rgba(74,143,231,.04);border:1px solid var(--border-color);border-radius:8px;padding:16px;margin:16px 0;font-family:'JetBrains Mono',monospace;font-size:13px;text-align:center;line-height:2}
.formula-box .formula-label{font-family:'Inter',sans-serif;font-size:11px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;font-weight:700}

/* Year-by-year table */
.growth-table-wrap{max-height:400px;overflow-y:auto;border-radius:8px;border:1px solid var(--border-color);margin-top:16px}
.table-wrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border-color)}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:#0c1428;color:var(--text-secondary);font-weight:600;text-transform:uppercase;font-size:11px;letter-spacing:.5px;padding:12px 14px;text-align:left;white-space:nowrap;border-bottom:1px solid var(--border-color);position:sticky;top:0;z-index:1}
td{padding:10px 14px;border-bottom:1px solid var(--border-color)}
tr:hover{background:rgba(74,143,231,.06)}
.num{font-family:'JetBrains Mono',monospace;text-align:right}
.pos{color:#22c55e}
.neg{color:#ef4444}

/* Comparison */
.comparison-section{margin:32px 0}
.comparison-section h2{font-size:22px;margin-bottom:16px}
.comp-inputs{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px;margin-bottom:20px}
.comp-row{display:grid;grid-template-columns:1fr 1fr 1fr 1fr auto;gap:10px;align-items:end;margin-bottom:10px}
.comp-row .input-group{margin-bottom:0}
.comp-row .remove-btn{padding:10px 14px;background:none;border:1px solid var(--border-color);color:var(--text-secondary);border-radius:6px;cursor:pointer;font-size:16px}
.comp-row .remove-btn:hover{border-color:#ef4444;color:#ef4444}
.comp-btn-row{display:flex;gap:10px;margin-top:12px}
.comp-btn-add{padding:10px 20px;background:none;border:1px solid var(--border-color);color:var(--text-secondary);border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif}
.comp-btn-add:hover{border-color:var(--accent-color);color:var(--accent-color)}

/* Bar chart */
.chart-section{margin:20px 0}
.chart-wrap{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.bar-chart{display:flex;align-items:flex-end;gap:16px;height:250px;padding:0 20px;border-bottom:1px solid var(--border-color)}
.bar-group{display:flex;flex-direction:column;align-items:center;flex:1;min-width:60px}
.bar{width:100%;max-width:60px;border-radius:4px 4px 0 0;min-height:4px;transition:all .3s ease;position:relative}
.bar:hover{opacity:.85}
.bar-val{font-size:12px;font-weight:700;font-family:'JetBrains Mono',monospace;margin-bottom:4px;text-align:center}
.bar-name{font-size:11px;color:var(--text-secondary);margin-top:8px;text-align:center;max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.chart-legend{display:flex;gap:16px;justify-content:center;margin-top:16px;font-size:12px;color:var(--text-secondary);flex-wrap:wrap}
.chart-legend span{display:flex;align-items:center;gap:4px}
.chart-legend .dot{width:10px;height:10px;border-radius:2px;display:inline-block}

/* Context benchmarks */
.benchmark-section{margin:32px 0}
.benchmark-section h2{font-size:22px;margin-bottom:16px}
.bench-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
.bench-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;text-align:center}
.bench-card .bench-val{font-size:32px;font-weight:800;font-family:'JetBrains Mono',monospace;color:var(--accent-color)}
.bench-card .bench-name{font-size:13px;font-weight:600;margin-bottom:4px}
.bench-card .bench-desc{font-size:11px;color:var(--text-secondary);margin-top:6px}

/* Findings */
.findings{margin:32px 0}
.findings h2{font-size:22px;margin-bottom:16px}
.finding-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:20px;margin-bottom:12px}
.finding-card h3{font-size:16px;margin-bottom:6px;color:var(--accent-color)}
.finding-card p{color:var(--text-secondary);font-size:14px;line-height:1.7}

/* FAQ */
.faq-section{margin:32px 0}
.faq-section h2{font-size:22px;margin-bottom:16px}
.faq-item{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;margin-bottom:10px;overflow:hidden}
.faq-q{padding:16px 20px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.faq-q:hover{color:var(--accent-color)}
.faq-q::after{content:'+';font-size:20px;color:var(--text-secondary);transition:transform .2s}
.faq-item.open .faq-q::after{transform:rotate(45deg);color:var(--accent-color)}
.faq-a{padding:0 20px 16px;color:var(--text-secondary);font-size:14px;line-height:1.7;display:none}
.faq-item.open .faq-a{display:block}

/* Related */
.related-section{margin:32px 0}
.related-section h2{font-size:22px;margin-bottom:16px}
.related-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.related-card{background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:16px;text-decoration:none;transition:border-color .2s}
.related-card:hover{border-color:var(--accent-color);text-decoration:none}
.related-card h3{font-size:15px;margin-bottom:4px;color:var(--text-primary)}
.related-card p{font-size:13px;color:var(--text-secondary)}

.methodology{margin:32px 0;background:var(--card-bg);border:1px solid var(--border-color);border-radius:8px;padding:24px}
.methodology h2{font-size:18px;margin-bottom:12px}
.methodology p{color:var(--text-secondary);font-size:14px;margin-bottom:10px;line-height:1.7}

.disclaimer{margin:20px 0;padding:16px;border:1px solid var(--border-color);border-radius:8px;font-size:12px;color:var(--text-secondary);text-align:center;font-style:italic}

footer{border-top:1px solid var(--border-color);padding:24px 0;text-align:center;color:var(--text-secondary);font-size:13px;margin-top:40px}

@media(max-width:768px){
  .calc-grid{grid-template-columns:1fr}
  .result-grid{grid-template-columns:1fr 1fr}
  .comp-row{grid-template-columns:1fr 1fr;gap:8px}
  .comp-row .remove-btn{grid-column:span 2;justify-self:end}
  .related-grid{grid-template-columns:1fr}
  .bench-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:480px){
  .result-grid{grid-template-columns:1fr}
  .comp-row{grid-template-columns:1fr}
  .comp-row .remove-btn{grid-column:1;justify-self:end}
  .bench-grid{grid-template-columns:1fr}
  .bar-chart{gap:8px;height:200px}
}
  </style>

<div class="container">
    <h1>CAGR Calculator: Compound Annual Growth Rate</h1>
    <p class="subtitle">Calculate annualized returns, project future values, compare investments side-by-side, and benchmark against the S&amp;P 500, bonds, and inflation.</p>
    <div class="updated-badge">Last Updated: March 2026</div>

    <!-- Tab navigation -->
    <div class="calc-section">
      <div class="tab-row">
        <button class="tab-btn active" data-tab="cagr">Calculate CAGR</button>
        <button class="tab-btn" data-tab="reverse">Reverse Calculator</button>
        <button class="tab-btn" data-tab="compare">Compare Investments</button>
      </div>

      <!-- Tab 1: Calculate CAGR -->
      <div class="tab-panel active" id="tab-cagr">
        <div class="calc-grid">
          <div class="calc-inputs">
            <div class="input-group">
              <label>Beginning Value ($)</label>
              <input type="number" id="beginVal" placeholder="e.g. 10000" step="0.01" min="0">
              <div class="input-hint">Initial investment amount or starting portfolio value</div>
            </div>
            <div class="input-group">
              <label>Ending Value ($)</label>
              <input type="number" id="endVal" placeholder="e.g. 25000" step="0.01" min="0">
              <div class="input-hint">Final value of the investment today</div>
            </div>
            <div class="input-group">
              <label>Number of Years</label>
              <input type="number" id="numYears" placeholder="e.g. 10" step="0.1" min="0.1">
              <div class="input-hint">Investment holding period in years</div>
            </div>
            <button class="calc-btn" id="calcBtn">Calculate CAGR</button>
          </div>
          <div class="calc-results" id="calcResults">
            <div class="result-placeholder">Enter a beginning value, ending value, and number of years to calculate the compound annual growth rate.</div>
          </div>
        </div>
      </div>

      <!-- Tab 2: Reverse Calculator -->
      <div class="tab-panel" id="tab-reverse">
        <div class="calc-grid">
          <div class="calc-inputs">
            <div class="input-group">
              <label>Beginning Value ($)</label>
              <input type="number" id="revBeginVal" placeholder="e.g. 10000" step="0.01" min="0">
              <div class="input-hint">Your starting investment amount</div>
            </div>
            <div class="input-group">
              <label>Expected CAGR (%)</label>
              <input type="number" id="revCagr" placeholder="e.g. 10" step="0.1">
              <div class="input-hint">Annual growth rate you expect</div>
            </div>
            <div class="input-group">
              <label>Number of Years</label>
              <input type="number" id="revYears" placeholder="e.g. 10" step="0.1" min="0.1">
              <div class="input-hint">How long you plan to hold</div>
            </div>
            <button class="calc-btn" id="revCalcBtn">Calculate Future Value</button>
          </div>
          <div class="calc-results" id="revResults">
            <div class="result-placeholder">Enter a beginning value, expected CAGR, and years to project the future value of your investment.</div>
          </div>
        </div>
      </div>

      <!-- Tab 3: Compare Investments -->
      <div class="tab-panel" id="tab-compare">
        <div class="comp-inputs" id="compInputs">
          <div id="compRows">
            <div class="comp-row" data-idx="0">
              <div class="input-group"><label>Name</label><input type="text" class="comp-name" placeholder="e.g. Stock A"></div>
              <div class="input-group"><label>Begin ($)</label><input type="number" class="comp-begin" placeholder="10000" step="0.01" min="0"></div>
              <div class="input-group"><label>End ($)</label><input type="number" class="comp-end" placeholder="25000" step="0.01" min="0"></div>
              <div class="input-group"><label>Years</label><input type="number" class="comp-years" placeholder="10" step="0.1" min="0.1"></div>
              <button class="remove-btn" title="Remove">&times;</button>
            </div>
            <div class="comp-row" data-idx="1">
              <div class="input-group"><label>Name</label><input type="text" class="comp-name" placeholder="e.g. Stock B"></div>
              <div class="input-group"><label>Begin ($)</label><input type="number" class="comp-begin" placeholder="10000" step="0.01" min="0"></div>
              <div class="input-group"><label>End ($)</label><input type="number" class="comp-end" placeholder="18000" step="0.01" min="0"></div>
              <div class="input-group"><label>Years</label><input type="number" class="comp-years" placeholder="10" step="0.1" min="0.1"></div>
              <button class="remove-btn" title="Remove">&times;</button>
            </div>
          </div>
          <div class="comp-btn-row">
            <button class="comp-btn-add" id="addCompBtn">+ Add Investment</button>
            <button class="calc-btn" id="compCalcBtn" style="width:auto;margin:0;padding:12px 24px">Compare CAGRs</button>
          </div>
        </div>
        <div id="compResultsArea"></div>
      </div>
    </div>

    <!-- Benchmark Context -->
    <div class="benchmark-section">
      <h2>Historical CAGR Benchmarks</h2>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px">Use these long-term averages to benchmark your investment's CAGR against major asset classes.</p>
      <div class="bench-grid">
        <div class="bench-card">
          <div class="bench-name">S&amp;P 500</div>
          <div class="bench-val">~10%</div>
          <div class="bench-desc">50-year average including dividends. ~7% after inflation.</div>
        </div>
        <div class="bench-card">
          <div class="bench-name">US Bonds (Agg)</div>
          <div class="bench-val">~5%</div>
          <div class="bench-desc">Bloomberg US Aggregate Bond Index long-term average.</div>
        </div>
        <div class="bench-card">
          <div class="bench-name">Inflation (CPI)</div>
          <div class="bench-val">~3%</div>
          <div class="bench-desc">US historical average. Your real return = CAGR minus inflation.</div>
        </div>
        <div class="bench-card">
          <div class="bench-name">Real Estate</div>
          <div class="bench-val">~9%</div>
          <div class="bench-desc">US housing + REITs average including income. Varies by market.</div>
        </div>
        <div class="bench-card">
          <div class="bench-name">Gold</div>
          <div class="bench-val">~7%</div>
          <div class="bench-desc">50-year average. No yield — pure price appreciation.</div>
        </div>
        <div class="bench-card">
          <div class="bench-name">Cash / T-Bills</div>
          <div class="bench-val">~3.5%</div>
          <div class="bench-desc">Risk-free rate baseline. Barely keeps pace with inflation.</div>
        </div>
      </div>
    </div>

    <!-- Key insights -->
    <div class="findings">
      <h2>Understanding CAGR: Key Insights</h2>
      <div class="finding-card">
        <h3>CAGR vs. Average Return: The Volatility Trap</h3>
        <p>An investment that gains 100% then loses 50% has an average annual return of +25% — but your money is exactly where it started (CAGR = 0%). This gap between average return and CAGR widens with volatility, a phenomenon called "volatility drag." CAGR tells you what actually happened to your money. Average return tells you what happened in a typical year. For evaluating real investment performance, CAGR is the only honest metric.</p>
      </div>
      <div class="finding-card">
        <h3>The Power of Small CAGR Differences Over Time</h3>
        <p>The difference between 8% and 10% CAGR seems small, but over 30 years it is enormous. $10,000 at 8% CAGR becomes $100,627. At 10% it becomes $174,494 — 73% more money from just 2 percentage points of additional annual growth. This is why even small improvements in investment returns compound into massive wealth differences over a career. It also explains why minimizing fees (which reduce CAGR) is one of the most impactful financial decisions you can make.</p>
      </div>
      <div class="finding-card">
        <h3>When to Use CAGR vs. IRR</h3>
        <p>CAGR works perfectly when you make a single lump-sum investment and measure from start to end. But if you add money regularly (like monthly 401k contributions) or make withdrawals, CAGR does not capture the full picture — it ignores the timing of cash flows. In those cases, use Internal Rate of Return (IRR) or Money-Weighted Return instead. CAGR is best for evaluating buy-and-hold performance, comparing funds, and projecting future values from a single starting amount.</p>
      </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div id="faq"></div>
    </div>

    <!-- Related -->
    <div class="related-section">
      <h2>Related Tools &amp; Research</h2>
      <div class="related-grid">
        <a class="related-card" href="/sites/westmount/investment-calculator">
          <h3>Investment Calculator</h3>
          <p>Project portfolio growth with regular contributions, variable return rates, and compounding frequency options.</p>
        </a>
        <a class="related-card" href="/sites/westmount/compound-interest-calculator">
          <h3>Compound Interest Calculator</h3>
          <p>Calculate compound interest with different compounding frequencies, contribution schedules, and time horizons.</p>
        </a>
      </div>
    </div>

    <div class="methodology">
      <h2>Methodology</h2>
      <p>CAGR is calculated using the standard formula: CAGR = (Ending Value / Beginning Value)^(1/Number of Years) − 1. The reverse calculator uses: Future Value = Beginning Value × (1 + CAGR)^Years. All calculations assume no additional contributions or withdrawals during the period.</p>
      <p>Historical benchmark figures are approximate long-term averages sourced from publicly available index data. S&amp;P 500 CAGR includes dividend reinvestment. Inflation figure uses US CPI. All values are for educational reference and may not reflect current market conditions.</p>
    </div>

    <div class="disclaimer">This calculator is for informational and educational purposes only. Not investment advice. Past performance does not guarantee future results. CAGR smooths volatility and does not reflect risk. Always do your own research before making investment decisions.</div>
</div>

  <script is:inline>
// ===== Tab switching =====
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

// ===== Helpers =====
function formatCurrency(n) {
  if (Math.abs(n) >= 1e9) return '$' + (n/1e9).toFixed(2) + 'B';
  if (Math.abs(n) >= 1e6) return '$' + (n/1e6).toFixed(2) + 'M';
  return '$' + n.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
}

function calcCAGR(begin, end, years) {
  return Math.pow(end / begin, 1 / years) - 1;
}

// ===== Tab 1: CAGR Calculator =====
document.getElementById('calcBtn').addEventListener('click', calculateCAGR);
document.querySelectorAll('#tab-cagr .calc-inputs input').forEach(input => {
  input.addEventListener('keydown', e => { if (e.key === 'Enter') calculateCAGR(); });
});

function calculateCAGR() {
  const begin = parseFloat(document.getElementById('beginVal').value);
  const end = parseFloat(document.getElementById('endVal').value);
  const years = parseFloat(document.getElementById('numYears').value);

  if (!begin || begin <= 0) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid beginning value greater than zero.</div>';
    return;
  }
  if (!end || end <= 0) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid ending value greater than zero.</div>';
    return;
  }
  if (!years || years <= 0) {
    document.getElementById('calcResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid number of years.</div>';
    return;
  }

  const cagr = calcCAGR(begin, end, years);
  const totalReturn = (end / begin - 1) * 100;
  const absGain = end - begin;

  let html = '<div class="result-grid">';
  html += `<div class="result-box highlight"><div class="val">${(cagr * 100).toFixed(2)}%</div><div class="label">CAGR</div></div>`;
  html += `<div class="result-box"><div class="val">${totalReturn.toFixed(1)}%</div><div class="label">Total Return</div></div>`;
  html += `<div class="result-box"><div class="val">${formatCurrency(absGain)}</div><div class="label">Absolute Gain</div></div>`;
  html += `<div class="result-box"><div class="val">${years}</div><div class="label">Years</div></div>`;
  html += '</div>';

  // Formula display
  html += '<div class="formula-box">';
  html += '<div class="formula-label">CAGR Formula</div>';
  html += `CAGR = (${formatCurrency(end)} / ${formatCurrency(begin)})<sup>1/${years}</sup> − 1 = <strong>${(cagr * 100).toFixed(2)}%</strong>`;
  html += '</div>';

  // Context vs benchmarks
  const benchmarks = [
    {name:'S&P 500', rate:0.10},
    {name:'Bonds', rate:0.05},
    {name:'Inflation', rate:0.03}
  ];
  html += '<div style="margin-top:16px">';
  html += '<div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:10px">vs. Benchmarks</div>';
  benchmarks.forEach(b => {
    const diff = ((cagr - b.rate) * 100).toFixed(2);
    const color = cagr >= b.rate ? '#22c55e' : '#ef4444';
    const sign = cagr >= b.rate ? '+' : '';
    html += `<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border-color);font-size:13px">`;
    html += `<span>${b.name} (~${(b.rate*100).toFixed(0)}%)</span>`;
    html += `<span style="color:${color};font-family:'JetBrains Mono',monospace;font-weight:600">${sign}${diff}%</span>`;
    html += '</div>';
  });
  html += '</div>';

  // Year-by-year growth table
  html += '<div class="growth-table-wrap"><table><thead><tr><th>Year</th><th class="num">Value</th><th class="num">Growth</th><th class="num">Cumulative</th></tr></thead><tbody>';
  let currentVal = begin;
  for (let y = 0; y <= Math.ceil(years); y++) {
    const effectiveYear = Math.min(y, years);
    const val = begin * Math.pow(1 + cagr, effectiveYear);
    const yearGrowth = y === 0 ? 0 : val - (begin * Math.pow(1 + cagr, effectiveYear - 1));
    const cumReturn = ((val / begin - 1) * 100);
    const growthColor = yearGrowth >= 0 ? 'pos' : 'neg';
    const label = y === Math.ceil(years) && years % 1 !== 0 ? years.toFixed(1) : y;
    html += `<tr>`;
    html += `<td>${label}</td>`;
    html += `<td class="num">${formatCurrency(val)}</td>`;
    html += `<td class="num ${growthColor}">${y === 0 ? '—' : (yearGrowth >= 0 ? '+' : '') + formatCurrency(yearGrowth)}</td>`;
    html += `<td class="num">${y === 0 ? '0.0%' : cumReturn.toFixed(1) + '%'}</td>`;
    html += '</tr>';
    if (y === Math.ceil(years) - 1 && years % 1 !== 0) {
      // add the fractional final year
    }
  }
  html += '</tbody></table></div>';

  document.getElementById('calcResults').innerHTML = html;
}

// ===== Tab 2: Reverse Calculator =====
document.getElementById('revCalcBtn').addEventListener('click', calculateReverse);
document.querySelectorAll('#tab-reverse .calc-inputs input').forEach(input => {
  input.addEventListener('keydown', e => { if (e.key === 'Enter') calculateReverse(); });
});

function calculateReverse() {
  const begin = parseFloat(document.getElementById('revBeginVal').value);
  const cagr = parseFloat(document.getElementById('revCagr').value) / 100;
  const years = parseFloat(document.getElementById('revYears').value);

  if (!begin || begin <= 0) {
    document.getElementById('revResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid beginning value.</div>';
    return;
  }
  if (isNaN(cagr)) {
    document.getElementById('revResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter an expected CAGR.</div>';
    return;
  }
  if (!years || years <= 0) {
    document.getElementById('revResults').innerHTML = '<div class="result-placeholder" style="color:#ef4444">Please enter a valid number of years.</div>';
    return;
  }

  const endVal = begin * Math.pow(1 + cagr, years);
  const totalGain = endVal - begin;
  const totalReturn = ((endVal / begin - 1) * 100);
  const multiplier = endVal / begin;

  let html = '<div class="result-grid">';
  html += `<div class="result-box highlight"><div class="val">${formatCurrency(endVal)}</div><div class="label">Projected Value</div></div>`;
  html += `<div class="result-box"><div class="val">${formatCurrency(totalGain)}</div><div class="label">Total Gain</div></div>`;
  html += `<div class="result-box"><div class="val">${totalReturn.toFixed(1)}%</div><div class="label">Total Return</div></div>`;
  html += `<div class="result-box"><div class="val">${multiplier.toFixed(2)}x</div><div class="label">Multiplier</div></div>`;
  html += '</div>';

  // Formula
  html += '<div class="formula-box">';
  html += '<div class="formula-label">Future Value Formula</div>';
  html += `FV = ${formatCurrency(begin)} × (1 + ${(cagr*100).toFixed(1)}%)<sup>${years}</sup> = <strong>${formatCurrency(endVal)}</strong>`;
  html += '</div>';

  // Year-by-year projection
  html += '<div class="growth-table-wrap"><table><thead><tr><th>Year</th><th class="num">Value</th><th class="num">Year Growth</th><th class="num">Cumulative</th></tr></thead><tbody>';
  for (let y = 0; y <= Math.ceil(years); y++) {
    const effectiveYear = Math.min(y, years);
    const val = begin * Math.pow(1 + cagr, effectiveYear);
    const prevVal = y === 0 ? begin : begin * Math.pow(1 + cagr, effectiveYear - 1);
    const yearGrowth = y === 0 ? 0 : val - prevVal;
    const cumReturn = ((val / begin - 1) * 100);
    const growthColor = yearGrowth >= 0 ? 'pos' : 'neg';
    const label = y === Math.ceil(years) && years % 1 !== 0 ? years.toFixed(1) : y;
    html += `<tr><td>${label}</td><td class="num">${formatCurrency(val)}</td><td class="num ${growthColor}">${y === 0 ? '—' : (yearGrowth >= 0 ? '+' : '') + formatCurrency(yearGrowth)}</td><td class="num">${y === 0 ? '0.0%' : cumReturn.toFixed(1) + '%'}</td></tr>`;
  }
  html += '</tbody></table></div>';

  document.getElementById('revResults').innerHTML = html;
}

// ===== Tab 3: Compare Investments =====
let compCounter = 2;
const COLORS = ['#4a8fe7','#22c55e','#f59e0b','#ef4444','#a855f7','#ec4899','#06b6d4','#84cc16'];

document.getElementById('addCompBtn').addEventListener('click', () => {
  const idx = compCounter++;
  const row = document.createElement('div');
  row.className = 'comp-row';
  row.dataset.idx = idx;
  row.innerHTML = `
    <div class="input-group"><label>Name</label><input type="text" class="comp-name" placeholder="e.g. Investment ${idx+1}"></div>
    <div class="input-group"><label>Begin ($)</label><input type="number" class="comp-begin" placeholder="10000" step="0.01" min="0"></div>
    <div class="input-group"><label>End ($)</label><input type="number" class="comp-end" placeholder="20000" step="0.01" min="0"></div>
    <div class="input-group"><label>Years</label><input type="number" class="comp-years" placeholder="10" step="0.1" min="0.1"></div>
    <button class="remove-btn" title="Remove">&times;</button>`;
  document.getElementById('compRows').appendChild(row);
});

document.getElementById('compRows').addEventListener('click', e => {
  if (e.target.classList.contains('remove-btn')) {
    const rows = document.querySelectorAll('.comp-row');
    if (rows.length > 2) e.target.closest('.comp-row').remove();
  }
});

document.getElementById('compCalcBtn').addEventListener('click', compareInvestments);

function compareInvestments() {
  const rows = document.querySelectorAll('.comp-row');
  const investments = [];

  rows.forEach((row, i) => {
    const name = row.querySelector('.comp-name').value || `Investment ${i+1}`;
    const begin = parseFloat(row.querySelector('.comp-begin').value);
    const end = parseFloat(row.querySelector('.comp-end').value);
    const years = parseFloat(row.querySelector('.comp-years').value);

    if (begin > 0 && end > 0 && years > 0) {
      const cagr = calcCAGR(begin, end, years);
      investments.push({name, begin, end, years, cagr, totalReturn: (end/begin - 1)*100});
    }
  });

  if (investments.length < 2) {
    document.getElementById('compResultsArea').innerHTML = '<div class="result-placeholder" style="color:#ef4444;padding:20px;text-align:center">Please fill in at least two investments to compare.</div>';
    return;
  }

  // Sort by CAGR desc
  investments.sort((a, b) => b.cagr - a.cagr);

  // Results table
  let html = '<div class="table-wrap"><table><thead><tr><th>Rank</th><th>Investment</th><th class="num">CAGR</th><th class="num">Total Return</th><th class="num">Begin</th><th class="num">End</th><th class="num">Years</th></tr></thead><tbody>';
  investments.forEach((inv, i) => {
    const cagrColor = inv.cagr >= 0 ? 'pos' : 'neg';
    html += `<tr${i === 0 ? ' style="background:rgba(74,143,231,.08)"' : ''}>`;
    html += `<td style="font-weight:700;color:${COLORS[i % COLORS.length]}">#${i+1}</td>`;
    html += `<td style="font-weight:600">${inv.name}</td>`;
    html += `<td class="num ${cagrColor}" style="font-weight:700">${(inv.cagr*100).toFixed(2)}%</td>`;
    html += `<td class="num">${inv.totalReturn.toFixed(1)}%</td>`;
    html += `<td class="num">${formatCurrency(inv.begin)}</td>`;
    html += `<td class="num">${formatCurrency(inv.end)}</td>`;
    html += `<td class="num">${inv.years}</td>`;
    html += '</tr>';
  });
  html += '</tbody></table></div>';

  // Bar chart
  const maxCagr = Math.max(...investments.map(inv => Math.abs(inv.cagr)));
  const chartMax = maxCagr * 1.2;

  html += '<div class="chart-section"><div class="chart-wrap">';
  html += '<div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-secondary);margin-bottom:16px">CAGR Comparison</div>';
  html += '<div class="bar-chart">';

  investments.forEach((inv, i) => {
    const pct = chartMax > 0 ? (Math.abs(inv.cagr) / chartMax) * 100 : 0;
    const color = COLORS[i % COLORS.length];
    const cagrStr = (inv.cagr * 100).toFixed(2) + '%';
    html += `<div class="bar-group">`;
    html += `<div class="bar-val" style="color:${color}">${cagrStr}</div>`;
    html += `<div class="bar" style="height:${Math.max(pct, 3)}%;background:${color}" title="${inv.name}: ${cagrStr} CAGR"></div>`;
    html += `<div class="bar-name">${inv.name}</div>`;
    html += '</div>';
  });

  // Add benchmark bars
  const benchmarks = [{name:'S&P 500', rate:0.10}, {name:'Bonds', rate:0.05}, {name:'Inflation', rate:0.03}];
  benchmarks.forEach(b => {
    const pct = chartMax > 0 ? (b.rate / chartMax) * 100 : 0;
    const cagrStr = (b.rate * 100).toFixed(0) + '%';
    html += `<div class="bar-group">`;
    html += `<div class="bar-val" style="color:var(--text-secondary)">${cagrStr}</div>`;
    html += `<div class="bar" style="height:${Math.max(pct, 3)}%;background:var(--border-color);opacity:.6" title="${b.name}: ${cagrStr}"></div>`;
    html += `<div class="bar-name" style="font-style:italic">${b.name}</div>`;
    html += '</div>';
  });

  html += '</div>';

  // Legend
  html += '<div class="chart-legend">';
  investments.forEach((inv, i) => {
    html += `<span><span class="dot" style="background:${COLORS[i % COLORS.length]}"></span>${inv.name}</span>`;
  });
  html += '<span><span class="dot" style="background:var(--border-color);opacity:.6"></span>Benchmarks</span>';
  html += '</div></div></div>';

  document.getElementById('compResultsArea').innerHTML = html;
}

// ===== FAQ =====
const faqs = [
  {q:"What is CAGR and how is it calculated?",a:"CAGR (Compound Annual Growth Rate) measures the mean annual growth rate of an investment over a specified period. The formula is: CAGR = (Ending Value / Beginning Value)^(1/Years) − 1. For example, an investment growing from $10,000 to $25,000 over 10 years has a CAGR of 9.6%. CAGR smooths out volatility to show a steady annual rate, making it the standard for comparing investment performance."},
  {q:"What is the difference between CAGR and average annual return?",a:"CAGR accounts for compounding while average return does not. If an investment gains 50% then loses 33%, the average return is +8.5% — but your money is back where it started (CAGR = 0%). CAGR reflects what actually happened to your money. The more volatile the returns, the larger the gap between average return and CAGR. This is known as 'volatility drag.'"},
  {q:"What is a good CAGR for an investment?",a:"It depends on the asset class. The S&P 500 has delivered ~10% CAGR over 50 years (~7% after inflation). Bonds average ~5%. Real estate 8-12% including income. Any CAGR above inflation (~3%) means you're growing real purchasing power. A CAGR that consistently beats the relevant benchmark is considered excellent."},
  {q:"What is the CAGR of the S&P 500?",a:"The S&P 500 has delivered approximately 10.2% CAGR including dividends over the past 50 years. After inflation, the real CAGR is ~7%. Over the most recent 10 years, the CAGR has been ~12%, boosted by tech mega-caps. Without dividend reinvestment, the price-only CAGR is roughly 2 percentage points lower."},
  {q:"Can CAGR be negative?",a:"Yes. CAGR is negative when an investment loses value over the period. For example, $10,000 becoming $7,000 after 5 years equals a CAGR of −6.9%. A negative CAGR means your money shrank on an annualized basis. It's a clear signal the investment underperformed cash."},
  {q:"How do I use CAGR to compare investments?",a:"Calculate the CAGR for each investment over matching time periods. CAGR normalizes different time periods and starting amounts into a single annualized rate for direct comparison. An investment with 12% CAGR outperformed one with 8% CAGR regardless of the path each took. Also consider risk — use the Sharpe ratio alongside CAGR for risk-adjusted comparison."},
  {q:"What are the limitations of CAGR?",a:"CAGR: (1) hides volatility — wild swings and steady growth can show the same CAGR, (2) only uses start and end values, ignoring what happened in between, (3) doesn't account for additional investments or withdrawals (use IRR for that), (4) is backward-looking and doesn't predict future returns, (5) doesn't measure risk. Pair CAGR with standard deviation or max drawdown for a complete picture."},
  {q:"How is CAGR used in business and finance?",a:"Beyond investment returns, CAGR is used for revenue growth (e.g., revenue from $100M to $400M over 5 years = 32% revenue CAGR), earnings projections, private equity benchmarking, market size forecasting, population growth, and GDP analysis. It's the universal language for expressing annualized growth across virtually any metric."}
];

const faqEl = document.getElementById('faq');
faqs.forEach(f => {
  faqEl.innerHTML += `<div class="faq-item"><div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div></div>`;
});
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
});
  </script>
