import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is tax loss harvesting?","acceptedAnswer":{"@type":"Answer","text":"Tax loss harvesting is an investment strategy where you sell securities at a loss to offset capital gains taxes. You then reinvest in a similar (but not substantially identical) security to maintain your portfolio allocation. The harvested losses reduce your taxable income — up to $3,000 per year against ordinary income, with unlimited offset against capital gains. Any unused losses carry forward indefinitely to future tax years."}},
    {"@type":"Question","name":"What is the wash sale rule?","acceptedAnswer":{"@type":"Answer","text":"The wash sale rule (IRS Section 1091) prevents you from claiming a tax deduction on a security sold at a loss if you buy a substantially identical security within 30 days before or after the sale. This creates a 61-day window (30 days before + sale day + 30 days after) where you cannot repurchase the same or substantially identical investment. The disallowed loss gets added to the cost basis of the replacement security."}},
    {"@type":"Question","name":"How much can tax loss harvesting save me?","acceptedAnswer":{"@type":"Answer","text":"Tax loss harvesting savings depend on your capital gains, tax bracket, and available losses. At the highest federal rate (37% short-term / 20% long-term + 3.8% NIIT), harvesting $10,000 in short-term losses could save up to $4,080 in taxes. For long-term losses, the same $10,000 saves up to $2,380. Even with no capital gains, you can deduct up to $3,000 in net losses against ordinary income each year."}},
    {"@type":"Question","name":"What are common tax loss harvesting pairs?","acceptedAnswer":{"@type":"Answer","text":"Common TLH pairs are funds that track similar but not identical indexes. Popular swaps include: VTI (Vanguard Total Market) → ITOT (iShares Total Market), VOO (Vanguard S&P 500) → IVV (iShares S&P 500) or SPLG, VXUS (Vanguard International) → IXUS (iShares International), BND (Vanguard Total Bond) → AGG (iShares Total Bond), and VWO (Vanguard Emerging Markets) → IEMG (iShares Emerging Markets)."}},
    {"@type":"Question","name":"Can I tax loss harvest in a 401(k) or IRA?","acceptedAnswer":{"@type":"Answer","text":"No. Tax loss harvesting only works in taxable brokerage accounts. Retirement accounts like 401(k)s, IRAs, and Roth IRAs are already tax-advantaged — gains and losses inside these accounts have no immediate tax impact. However, be careful: buying a substantially identical security in your IRA within the wash sale window after selling at a loss in your taxable account can trigger the wash sale rule and permanently disallow the loss."}},
    {"@type":"Question","name":"When is the best time to tax loss harvest?","acceptedAnswer":{"@type":"Answer","text":"Tax loss harvesting can be done year-round, not just in December. Market dips throughout the year create harvesting opportunities. However, year-end is the most common time because investors review their tax situation and have clarity on their total gains for the year. The key is to harvest losses when they're available — waiting for year-end means you might miss opportunities from mid-year volatility."}},
    {"@type":"Question","name":"Does tax loss harvesting work for crypto?","acceptedAnswer":{"@type":"Answer","text":"Yes, and crypto has a significant advantage: the wash sale rule currently does not apply to cryptocurrency (as of 2026, though legislation has been proposed). This means you can sell Bitcoin at a loss and immediately rebuy Bitcoin to claim the tax deduction — something you cannot do with stocks or ETFs. This makes crypto one of the most efficient assets for tax loss harvesting."}},
    {"@type":"Question","name":"Is tax loss harvesting worth it for small portfolios?","acceptedAnswer":{"@type":"Answer","text":"Tax loss harvesting can be worthwhile even for smaller portfolios. The $3,000 annual deduction against ordinary income is available regardless of portfolio size. If you're in the 24% bracket, that $3,000 deduction saves $720 in taxes. For portfolios under $50,000, the savings may be modest but still meaningful, especially when losses carry forward. Robo-advisors like Wealthfront and Betterment automate TLH at no extra cost, making it effortless for any account size."}}
  ]
};

export const meta = {
  title: "Tax Loss Harvesting Guide 2026",
  description: "Complete tax loss harvesting guide with interactive calculator, wash sale rules, TLH pairs, step-by-step process, and year-end checklist.",
  category: "guide",
