// === 1) CALCULATOR ===
const cStG=document.getElementById('cStG'),cLtG=document.getElementById('cLtG'),cStL=document.getElementById('cStL'),cLtL=document.getElementById('cLtL'),cBracket=document.getElementById('cBracket'),cState=document.getElementById('cState'),cNiit=document.getElementById('cNiit'),cFiling=document.getElementById('cFiling');

function runCalc(){
  const stG=Math.max(0,+cStG.value||0),ltG=Math.max(0,+cLtG.value||0);
  const stL=Math.max(0,+cStL.value||0),ltL=Math.max(0,+cLtL.value||0);
  const bracket=+cBracket.value,stateR=(+cState.value||0)/100;
  const niitR=cNiit.value==='yes'?0.038:0;
  const ltRate=bracket<=0.12?0:bracket<=0.35?0.15:0.20;

  let netST=stG-stL,netLT=ltG-ltL;
  if(netST<0&&netLT>0){const o=Math.min(-netST,netLT);netLT-=o;netST+=o;}
  else if(netLT<0&&netST>0){const o=Math.min(-netLT,netST);netST-=o;netLT+=o;}

  const totalNet=netST+netLT;
  const incDeduct=totalNet<0?Math.min(-totalNet,3000):0;
  const carryFwd=totalNet<0?Math.max(0,-totalNet-3000):0;

  const taxWithout=stG*(bracket+stateR+niitR)+ltG*(ltRate+stateR+niitR);
  const taxWith=Math.max(0,netST)*(bracket+stateR+niitR)+Math.max(0,netLT)*(ltRate+stateR+niitR);
  const incSavings=incDeduct*(bracket+stateR);
  const totalSavings=taxWithout-taxWith+incSavings;

  const f=v=>'$'+Math.round(v).toLocaleString();
  document.getElementById('calcOut').innerHTML=`
    <div class="result-row"><span class="result-label">Tax without harvesting</span><span class="result-value red">${f(taxWithout)}</span></div>
    <div class="result-row"><span class="result-label">Tax with harvesting</span><span class="result-value">${f(taxWith)}</span></div>
    <div class="result-row"><span class="result-label">Ordinary income deduction ($3K max)</span><span class="result-value green">${incDeduct>0?f(incDeduct):'$0'}</span></div>
    <div class="result-row"><span class="result-label">Tax saved from income deduction</span><span class="result-value green">${incSavings>0?f(incSavings):'$0'}</span></div>
    <div class="result-row"><span class="result-label">Loss carry-forward to next year</span><span class="result-value">${carryFwd>0?f(carryFwd):'$0'}</span></div>
    <div class="result-total"><div class="t-label">Estimated Total Tax Savings</div><div class="t-val">${f(totalSavings)}</div></div>
    <div class="result-note">Effective rates — ST: ${((bracket+stateR+niitR)*100).toFixed(1)}% | LT: ${((ltRate+stateR+niitR)*100).toFixed(1)}%</div>
  `;
}
[cStG,cLtG,cStL,cLtL,cState].forEach(el=>el.addEventListener('input',runCalc));
[cBracket,cNiit,cFiling].forEach(el=>el.addEventListener('change',runCalc));
runCalc();

