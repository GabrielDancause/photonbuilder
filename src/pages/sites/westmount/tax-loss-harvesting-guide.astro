  <script is:inline>
// Calculator
const calcLoss=document.getElementById('calcLoss');
const calcGains=document.getElementById('calcGains');
const calcBracket=document.getElementById('calcBracket');
const calcCGRate=document.getElementById('calcCGRate');
const calcResults=document.getElementById('calcResults');

function runCalc(){
  const loss=Math.max(0,parseFloat(calcLoss.value)||0);
  const gains=Math.max(0,parseFloat(calcGains.value)||0);
  const bracket=parseFloat(calcBracket.value);
  const cgRate=parseFloat(calcCGRate.value);

  // Losses first offset capital gains at the CG rate
  const gainsOffset=Math.min(loss,gains);
  const cgSavings=gainsOffset*cgRate;

  // Remaining losses offset ordinary income up to $3,000
  const remainingLoss=loss-gainsOffset;
  const ordinaryOffset=Math.min(remainingLoss,3000);
  const ordinarySavings=ordinaryOffset*bracket;

  // Carry forward
  const carryForward=Math.max(0,remainingLoss-3000);

  const totalSavings=cgSavings+ordinarySavings;

  calcResults.innerHTML=`
    <div class="calc-result"><div class="val">$${totalSavings.toLocaleString(undefined,{maximumFractionDigits:0})}</div><div class="label">Total Tax Savings (Year 1)</div></div>
    <div class="calc-result"><div class="val">$${cgSavings.toLocaleString(undefined,{maximumFractionDigits:0})}</div><div class="label">Capital Gains Offset</div></div>
    <div class="calc-result"><div class="val">$${ordinarySavings.toLocaleString(undefined,{maximumFractionDigits:0})}</div><div class="label">Ordinary Income Offset</div></div>
    <div class="calc-result"><div class="val">$${carryForward.toLocaleString(undefined,{maximumFractionDigits:0})}</div><div class="label">Loss Carried Forward</div></div>
  `;
}
calcLoss.addEventListener('input',runCalc);
calcGains.addEventListener('input',runCalc);
calcBracket.addEventListener('change',runCalc);
calcCGRate.addEventListener('change',runCalc);
runCalc();

