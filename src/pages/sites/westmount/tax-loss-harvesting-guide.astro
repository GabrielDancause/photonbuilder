const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is tax-loss harvesting?","acceptedAnswer":{"@type":"Answer","text":"Tax-loss harvesting is an investment strategy where you sell securities at a loss to offset capital gains taxes. You then reinvest in a similar (but not substantially identical) security to maintain your portfolio allocation. The harvested losses can offset capital gains dollar-for-dollar and up to $3,000 of ordinary income per year, with unused losses carried forward indefinitely."}},
    {"@type":"Question","name":"What is the wash sale rule?","acceptedAnswer":{"@type":"Answer","text":"The wash sale rule is an IRS regulation that disallows a tax deduction on a security sold at a loss if you purchase a substantially identical security within 30 days before or after the sale. This creates a 61-day window (30 days before + sale day + 30 days after) during which you cannot repurchase the same or substantially identical investment. The disallowed loss gets added to the cost basis of the replacement security."}},
    {"@type":"Question","name":"How much can tax-loss harvesting save me?","acceptedAnswer":{"@type":"Answer","text":"Tax-loss harvesting savings depend on your tax bracket and the size of your unrealized losses. At a 35% marginal tax rate with $10,000 in harvested losses, you could save $3,500 in taxes. For taxable accounts, automated tax-loss harvesting typically generates 0.5–1.5% in annual tax alpha. Wealthfront reports their tax-loss harvesting has generated an average of 1.8% in annual tax savings for eligible accounts."}},
    {"@type":"Question","name":"Can you tax-loss harvest in an IRA or 401(k)?","acceptedAnswer":{"@type":"Answer","text":"No, tax-loss harvesting only works in taxable brokerage accounts. IRAs, 401(k)s, Roth IRAs, and other tax-advantaged accounts are already tax-deferred or tax-free, so there is no tax benefit to harvesting losses in these accounts. However, be careful: buying a substantially identical security in your IRA within the 30-day wash sale window can trigger the wash sale rule and permanently disallow the loss."}},
    {"@type":"Question","name":"What are the best ETF swap pairs for tax-loss harvesting?","acceptedAnswer":{"@type":"Answer","text":"Common tax-loss harvesting swap pairs include: SPY ↔ IVV or VOO (S&P 500), VTI ↔ ITOT (total US market), VXUS ↔ IXUS (international), BND ↔ AGG (US bonds), VWO ↔ IEMG (emerging markets), and VEA ↔ IEFA (developed international). The key is choosing ETFs that track similar but not identical indexes to avoid wash sale violations while maintaining your target allocation."}},
    {"@type":"Question","name":"Is tax-loss harvesting worth it?","acceptedAnswer":{"@type":"Answer","text":"Tax-loss harvesting is worth it for most investors with taxable accounts, especially those in higher tax brackets (24%+). The strategy can generate 0.5–1.5% in annual tax savings, which often exceeds robo-advisor management fees. However, it may not be worth it if you are in the 10–12% tax bracket, have a very small taxable account, or plan to hold positions for decades without selling (deferring all gains until death for a stepped-up basis)."}},
    {"@type":"Question","name":"Does tax-loss harvesting work with individual stocks?","acceptedAnswer":{"@type":"Answer","text":"Yes, tax-loss harvesting works with individual stocks and is even more effective through direct indexing. Instead of holding an S&P 500 ETF, direct indexing buys individual stocks from the index, allowing you to harvest losses on individual positions even when the overall market is up. Wealthfront offers direct indexing for accounts over $100,000, and it can generate significantly more tax savings than ETF-level harvesting alone."}},
    {"@type":"Question","name":"When should you NOT harvest tax losses?","acceptedAnswer":{"@type":"Answer","text":"Avoid tax-loss harvesting when: 1) You are in the 0% capital gains bracket (income under ~$44,625 single). 2) The transaction costs or tracking complexity outweigh the tax benefit. 3) You would trigger a wash sale by buying a substantially identical security. 4) You plan to hold until death for a stepped-up cost basis. 5) You are harvesting in a down market but expect to be in a higher tax bracket when you eventually realize gains, effectively converting a lower future rate into a higher current deduction."}}
  ]
};

export const meta = {
