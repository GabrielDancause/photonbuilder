---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Energy Stocks to Buy: Top Picks & Analysis",
  description: "Looking for the best energy stocks to buy right now? Discover our top picks, featuring impressive dividend yields and key financial metrics you can't afford to ignore.",
  category: "list",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are the best energy stocks to buy right now?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Some of the best energy stocks currently include Exxon Mobil (XOM), Chevron (CVX), and TotalEnergies (TTE), due to their strong cash flows, solid dividend yields, and resilient business models."
          }
        },
        {
          "@type": "Question",
          "name": "Why invest in energy stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Energy stocks often provide high dividend yields and act as a hedge against inflation. They are essential to global economic activity, offering steady demand."
          }
        },
        {
          "@type": "Question",
          "name": "Are energy stocks a good long-term investment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, major energy companies are diversifying into renewable energy while maintaining their profitable oil and gas operations, making them viable long-term investments."
          }
        },
        {
          "@type": "Question",
          "name": "What metrics should I look for in energy stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Key metrics include Dividend Yield, Price-to-Earnings (P/E) Ratio, Market Capitalization, and free cash flow generation."
          }
        },
        {
          "@type": "Question",
          "name": "Do energy stocks pay good dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Historically, the energy sector is known for returning significant capital to shareholders through high dividend yields and share buyback programs."
          }
        }
      ]
    }
  ]
};

const stocks = [
  { symbol: "XOM", name: "Exxon Mobil Corporation", price: 158.81, dividendYield: 2.62, peRatio: 23.46, marketCap: "661.7B" },
  { symbol: "CVX", name: "Chevron Corporation", price: 197.97, dividendYield: 3.62, peRatio: 29.68, marketCap: "395.8B" },
  { symbol: "SHEL", name: "Shell PLC", price: 91.97, dividendYield: 3.29, peRatio: 15.08, marketCap: "260.6B" },
  { symbol: "TTE", name: "TotalEnergies SE", price: 86.04, dividendYield: 4.72, peRatio: 14.32, marketCap: "182.6B" },
  { symbol: "BP", name: "BP p.l.c.", price: 43.85, dividendYield: 4.65, peRatio: 2192.50, marketCap: "112.3B" },
  { symbol: "COP", name: "ConocoPhillips", price: 122.87, dividendYield: 2.77, peRatio: 19.11, marketCap: "150.2B" },
  { symbol: "EOG", name: "EOG Resources, Inc.", price: 135.72, dividendYield: 3.03, peRatio: 14.75, marketCap: "73.6B" },
  { symbol: "OXY", name: "Occidental Petroleum", price: 57.73, dividendYield: 1.82, peRatio: 42.45, marketCap: "56.9B" },
  { symbol: "MPC", name: "Marathon Petroleum", price: 233.26, dividendYield: 1.67, peRatio: 17.33, marketCap: "70.1B" }
];
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/energy-stocks-to-buy" schema={JSON.stringify(schema)}>
  <div class="container page-content">
    <div class="hero">
      <h1>Energy Stocks to Buy Right Now</h1>
      <p class="subtitle">A comprehensive breakdown of the most promising energy equities, complete with real-time fundamental analysis and strong dividend yields.</p>
    </div>

    <div class="article-body">
      <h2>Why Invest in the Energy Sector?</h2>
      <p>Investing in energy stocks has long been considered a bedrock strategy for those seeking income and a hedge against macroeconomic shifts. Energy is the underlying resource that powers every modern economy. From massive international supermajors extracting fossil fuels, to midstream pipeline operators, down to emerging renewable energy producers, there is a diverse set of opportunities.</p>

      <p>As of recent analysis, despite a global push toward green energy transitions, traditional oil and gas companies continue to report massive free cash flows. This allows for substantial shareholder returns—primarily through generous dividends and share buybacks. But with high cyclicality, how do you find the right <strong>energy stocks to buy</strong>? Let's review the data.</p>
    </div>

    <div class="card interactive-section">
      <h3>Compare Top Energy Stocks</h3>
      <p>Use the search and filter tools below to analyze our top energy stock picks.</p>

      <div class="filters">
        <input type="text" id="stock-search" placeholder="Search by ticker or name..." />
        <select id="sort-select">
          <option value="symbol">Sort by Ticker</option>
          <option value="yield-desc">Yield (High to Low)</option>
          <option value="pe-asc">P/E Ratio (Low to High)</option>
        </select>
      </div>

      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Symbol</th>
              <th>Company Name</th>
              <th>Price</th>
              <th>Div Yield</th>
              <th>P/E Ratio</th>
              <th>Market Cap</th>
            </tr>
          </thead>
          <tbody id="stock-table-body">
            {stocks.map(stock => (
              <tr class="stock-row" data-symbol={stock.symbol} data-name={stock.name} data-yield={stock.dividendYield || 0} data-pe={stock.peRatio || 9999}>
                <td><strong>{stock.symbol}</strong></td>
                <td>{stock.name}</td>
                <td>${stock.price?.toFixed(2) || "N/A"}</td>
                <td>{stock.dividendYield ? `${stock.dividendYield}%` : "N/A"}</td>
                <td>{stock.peRatio ? stock.peRatio.toFixed(2) : "N/A"}</td>
                <td>${stock.marketCap}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="article-body">
      <h2>Key Stock Analysis</h2>

      <h3>Exxon Mobil (XOM)</h3>
      <p>As the largest U.g. oil producer, Exxon Mobil stands out as a colossal cash-generating machine. Its integrated business model—spanning upstream exploration to downstream refining—protects it during oil price volatility. Its current P/E of around 23.4 and a dividend yield over 2.6% make it a solid anchor for an energy portfolio.</p>

      <h3>Chevron Corporation (CVX)</h3>
      <p>Chevron has fiercely defended its dividend through thick and thin. With a higher yield of 3.6% and aggressive strategic acquisitions in the Permian Basin, Chevron represents both defensive income and geographic growth potential.</p>

      <h3>European Supermajors (SHEL, TTE, BP)</h3>
      <p>Companies like Shell, TotalEnergies, and BP generally trade at lower P/E ratios than their American counterparts. TotalEnergies (TTE) in particular offers an attractive yield near 4.7% alongside massive commitments to low-carbon energy infrastructure.</p>

      <p>Looking to explore options related to tech as well? Read our analysis on <a href="/tech-stocks-dominate-options-2026">how tech stocks dominate options</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What are the best energy stocks to buy right now?</summary>
        <p>Some of the best energy stocks currently include Exxon Mobil (XOM), Chevron (CVX), and TotalEnergies (TTE), due to their strong cash flows, solid dividend yields, and resilient business models.</p>
      </details>
      <details>
        <summary>Why invest in energy stocks?</summary>
        <p>Energy stocks often provide high dividend yields and act as a hedge against inflation. They are essential to global economic activity, offering steady demand.</p>
      </details>
      <details>
        <summary>Are energy stocks a good long-term investment?</summary>
        <p>Yes, major energy companies are diversifying into renewable energy while maintaining their profitable oil and gas operations, making them viable long-term investments.</p>
      </details>
      <details>
        <summary>What metrics should I look for in energy stocks?</summary>
        <p>Key metrics include Dividend Yield, Price-to-Earnings (P/E) Ratio, Market Capitalization, and free cash flow generation.</p>
      </details>
      <details>
        <summary>Do energy stocks pay good dividends?</summary>
        <p>Historically, the energy sector is known for returning significant capital to shareholders through high dividend yields and share buyback programs.</p>
      </details>
    </section>
  </div>
  <script>
    function initEnergyStocks() {
      const searchInput = document.getElementById('stock-search');
      const sortSelect = document.getElementById('sort-select');
      const tableBody = document.getElementById('stock-table-body');

      if (!searchInput || !sortSelect || !tableBody || tableBody.dataset.initialized) return;
      tableBody.dataset.initialized = 'true';

      function updateTable() {
        const query = searchInput.value.toLowerCase();
        const sortMode = sortSelect.value;
        const rows = Array.from(tableBody.querySelectorAll('.stock-row'));

        const filtered = rows.filter(row => {
          const symbol = row.dataset.symbol.toLowerCase();
          const name = row.dataset.name.toLowerCase();
          return symbol.includes(query) || name.includes(query);
        });

        filtered.sort((a, b) => {
          if (sortMode === 'symbol') {
            return a.dataset.symbol.localeCompare(b.dataset.symbol);
          } else if (sortMode === 'yield-desc') {
            return parseFloat(b.dataset.yield) - parseFloat(a.dataset.yield);
          } else if (sortMode === 'pe-asc') {
            return parseFloat(a.dataset.pe) - parseFloat(b.dataset.pe);
          }
          return 0;
        });

        tableBody.innerHTML = '';
        filtered.forEach(row => {
          tableBody.appendChild(row);
        });
      }

      searchInput.addEventListener('input', updateTable);
      sortSelect.addEventListener('change', updateTable);
    }

    document.addEventListener('DOMContentLoaded', initEnergyStocks);
    document.addEventListener('astro:page-load', initEnergyStocks);
  </script>
  <style>
    .page-content {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    .hero {
      text-align: center;
      padding: 3rem 0 2rem;
    }
    .hero h1 {
      font-size: 2.2rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
    }
    .subtitle {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }
    .article-body p {
      margin-bottom: 1.25rem;
      line-height: 1.7;
    }
    .article-body h2 {
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-size: 1.8rem;
    }
    .article-body h3 {
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      font-size: 1.4rem;
    }
    .interactive-section {
      margin: 2.5rem 0;
    }
    .filters {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .filters input, .filters select {
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      background: var(--bg-color);
      color: var(--text-primary);
    }
    .filters input {
      flex: 1;
    }
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .table-container {
      overflow-x: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 0;
    }
    th, td {
      padding: 0.75rem 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }
    th {
      font-weight: 600;
      background: var(--bg-color);
      position: sticky;
      top: 0;
    }
    .faq-section h2 {
      margin-bottom: 1.5rem;
      font-size: 1.8rem;
    }
    .faq-section details {
      margin: 1rem 0;
      padding: 1rem;
      background: var(--card-bg);
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }
    .faq-section summary {
      font-weight: 600;
      cursor: pointer;
    }
  </style>
</SiteLayout>
