---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "SCHD Dividend History, Yield & Analysis | Schwab US Dividend Equity ETF",
  description: "Complete SCHD dividend history with quarterly payouts, yield trends, growth rate analysis, and income calculator. See every dividend payment since 2011.",
  category: "tool",
  published: "2026-03-28",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "SCHD Dividend History & Yield Analysis: Complete Guide to Schwab US Dividend Equity ETF",
    "description": "Comprehensive analysis of SCHD's dividend history, quarterly payouts, yield trends, and growth rate. Includes dividend income calculator and reinvestment projections.",
    "author": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" },
    "publisher": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" },
    "datePublished": "2026-03-28",
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://westmountfundamentals.com/schd-dividend" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How often does SCHD pay dividends?", "acceptedAnswer": { "@type": "Answer", "text": "SCHD pays dividends quarterly, typically in March, June, September, and December. Ex-dividend dates usually fall in the third week of each quarter month. Payments are deposited within a few business days of the pay date." } },
      { "@type": "Question", "name": "What is SCHD's current dividend yield?", "acceptedAnswer": { "@type": "Answer", "text": "SCHD's trailing 12-month dividend yield fluctuates between 3.3% and 3.8% depending on the share price. As of early 2026, the yield is approximately 3.5%, which is significantly higher than the S&P 500 average yield of around 1.3%. The yield changes daily as the share price moves." } },
      { "@type": "Question", "name": "Is SCHD a good dividend ETF?", "acceptedAnswer": { "@type": "Answer", "text": "SCHD is widely considered one of the best dividend ETFs available. It has a low expense ratio (0.06%), strong dividend growth history (averaging 10-12% annual dividend growth), quality screening methodology (Dow Jones U.S. Dividend 100 Index), and holds roughly 100 high-quality dividend-paying stocks. It balances yield with growth better than most peers." } },
      { "@type": "Question", "name": "How has SCHD's dividend grown over time?", "acceptedAnswer": { "@type": "Answer", "text": "SCHD's annual dividend per share has grown from approximately $0.85 in 2012 to over $2.80 in 2025, representing a compound annual growth rate of roughly 10%. This consistent growth, well above inflation, is one of the ETF's strongest selling points for income-focused investors." } },
      { "@type": "Question", "name": "What stocks are in SCHD?", "acceptedAnswer": { "@type": "Answer", "text": "SCHD holds approximately 100 U.S. stocks selected from the Dow Jones U.S. Dividend 100 Index. Top holdings typically include companies like Cisco, Broadcom, Home Depot, Verizon, Coca-Cola, PepsiCo, and Merck. The fund reconstitutes annually, favoring companies with at least 10 years of consecutive dividend payments, strong financials, and high dividend yield relative to peers." } }
    ]
  }
];

const dividendHistory = [
  { year: 2012, q1: 0.1812, q2: 0.2094, q3: 0.2195, q4: 0.2389, annual: 0.8490 },
  { year: 2013, q1: 0.2186, q2: 0.2448, q3: 0.2419, q4: 0.2755, annual: 0.9808 },
  { year: 2014, q1: 0.2385, q2: 0.2727, q3: 0.2740, q4: 0.3135, annual: 1.0987 },
  { year: 2015, q1: 0.2647, q2: 0.3011, q3: 0.2975, q4: 0.3316, annual: 1.1949 },
  { year: 2016, q1: 0.2766, q2: 0.3138, q3: 0.3173, q4: 0.3744, annual: 1.2821 },
  { year: 2017, q1: 0.3222, q2: 0.3440, q3: 0.3509, q4: 0.3959, annual: 1.4130 },
  { year: 2018, q1: 0.3509, q2: 0.3809, q3: 0.3879, q4: 0.4511, annual: 1.5708 },
  { year: 2019, q1: 0.3886, q2: 0.4418, q3: 0.4411, q4: 0.5073, annual: 1.7788 },
  { year: 2020, q1: 0.4422, q2: 0.4419, q3: 0.4387, q4: 0.6331, annual: 1.9559 },
  { year: 2021, q1: 0.4080, q2: 0.5438, q3: 0.6086, q4: 0.6384, annual: 2.1988 },
  { year: 2022, q1: 0.5176, q2: 0.7038, q3: 0.6520, q4: 0.7045, annual: 2.5779 },
  { year: 2023, q1: 0.5965, q2: 0.6619, q3: 0.6523, q4: 0.7504, annual: 2.6611 },
  { year: 2024, q1: 0.6372, q2: 0.7051, q3: 0.7509, q4: 0.7571, annual: 2.8503 },
  { year: 2025, q1: 0.6418, q2: 0.7200, q3: 0.7340, q4: 0.7690, annual: 2.8648 },
];
---

<SiteLayout title={meta.title} description={meta.description} site="westmount">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  </Fragment>

  <style>
    .schd-container { max-width: 900px; margin: 0 auto; padding: 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #c8d6e5; }
    h1 { font-size: 2rem; color: #f1f5f9; text-align: center; margin-bottom: 8px; }
    .subtitle { text-align: center; color: #64748b; margin-bottom: 28px; font-size: 1.05rem; }
    h2 { font-size: 1.4rem; color: #e2e8f0; margin: 40px 0 16px; border-bottom: 1px solid #152040; padding-bottom: 8px; }
    h3 { font-size: 1.15rem; color: #cbd5e1; margin: 24px 0 12px; }

    .card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 24px; margin-bottom: 20px; }

    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 20px 0; }
    @media (max-width: 600px) { .stats-row { grid-template-columns: repeat(2, 1fr); } }
    .stat { background: #0a1020; border: 1px solid #152040; border-radius: 10px; padding: 16px; text-align: center; }
    .stat-val { font-size: 1.6rem; font-weight: 800; color: #4a8fe7; font-family: 'JetBrains Mono', monospace; }
    .stat-lbl { font-size: 0.78rem; color: #64748b; margin-top: 4px; }
    .stat-green .stat-val { color: #22c55e; }

    .chart-wrap { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 20px; margin: 20px 0; }
    .chart-wrap canvas { max-height: 350px; }

    .div-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin: 16px 0; }
    .div-table th { background: #0f1b30; color: #94a3b8; padding: 10px 12px; text-align: right; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #152040; }
    .div-table th:first-child { text-align: left; }
    .div-table td { padding: 10px 12px; border-bottom: 1px solid #0f1629; text-align: right; font-family: 'JetBrains Mono', monospace; color: #c8d6e5; }
    .div-table td:first-child { text-align: left; color: #e2e8f0; font-weight: 600; }
    .div-table tr:hover td { background: rgba(74,143,231,0.04); }
    .growth-pos { color: #22c55e; }
    .growth-neg { color: #ef4444; }

    .calc-card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 24px; margin: 20px 0; }
    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 600px) { .calc-grid { grid-template-columns: 1fr; } }
    .field label { display: block; font-size: 0.85rem; color: #94a3b8; margin-bottom: 6px; }
    .field input { width: 100%; padding: 10px 14px; background: #060a12; border: 1px solid #152040; border-radius: 8px; color: #f1f5f9; font-size: 1rem; font-family: 'JetBrains Mono', monospace; box-sizing: border-box; }
    .field input:focus { outline: none; border-color: #4a8fe7; }
    .calc-result { margin-top: 20px; padding: 20px; background: #060a12; border-radius: 10px; border: 1px solid #152040; }
    .calc-result .big-num { font-size: 2rem; color: #4a8fe7; font-weight: 800; font-family: 'JetBrains Mono', monospace; }
    .calc-result .detail { color: #94a3b8; font-size: 0.9rem; margin-top: 8px; line-height: 1.6; }

    .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px; margin: 16px 0; }
    .info-card { background: #0a1020; border: 1px solid #152040; border-radius: 10px; padding: 20px; }
    .info-card h4 { color: #e2e8f0; margin: 0 0 8px; }
    .info-card p { color: #94a3b8; font-size: 0.9rem; margin: 0; line-height: 1.5; }

    .faq-section { margin-top: 40px; }
    .faq-item { border: 1px solid #152040; border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
    .faq-q { padding: 16px 20px; background: #0a1020; cursor: pointer; display: flex; justify-content: space-between; align-items: center; color: #e2e8f0; font-weight: 500; }
    .faq-q:hover { background: #0f1629; }
    .faq-arrow { transition: transform 0.2s; color: #4a8fe7; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }
    .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.3s, padding 0.3s; }
    .faq-item.open .faq-a { max-height: 400px; padding: 16px 20px; }
    .faq-a p { color: #94a3b8; line-height: 1.7; margin: 0; }

    .related-links { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px; }
    .related-link { padding: 8px 16px; background: #0a1020; border: 1px solid #152040; border-radius: 8px; color: #4a8fe7; text-decoration: none; font-size: 0.9rem; transition: all 0.2s; }
    .related-link:hover { border-color: #4a8fe7; background: #0f1629; }
  </style>

  <div class="schd-container">
    <h1>SCHD Dividend History & Analysis</h1>
    <p class="subtitle">Schwab U.S. Dividend Equity ETF — Complete quarterly dividend history since inception</p>

    <!-- Key Stats -->
    <div class="stats-row">
      <div class="stat"><div class="stat-val">$2.86</div><div class="stat-lbl">2025 Annual Dividend</div></div>
      <div class="stat"><div class="stat-val">~3.5%</div><div class="stat-lbl">Trailing Yield</div></div>
      <div class="stat stat-green"><div class="stat-val">+10.2%</div><div class="stat-lbl">Avg Annual Growth</div></div>
      <div class="stat"><div class="stat-val">0.06%</div><div class="stat-lbl">Expense Ratio</div></div>
    </div>

    <!-- Annual Dividend Chart -->
    <div class="chart-wrap">
      <h3 style="margin-top:0;">Annual Dividend Per Share</h3>
      <canvas id="annualChart"></canvas>
    </div>

    <!-- Dividend History Table -->
    <h2>Complete Dividend History</h2>
    <div style="overflow-x:auto;">
      <table class="div-table">
        <thead>
          <tr><th>Year</th><th>Q1</th><th>Q2</th><th>Q3</th><th>Q4</th><th>Annual</th><th>YoY Growth</th></tr>
        </thead>
        <tbody id="divTableBody"></tbody>
      </table>
    </div>

    <!-- Quarterly Chart -->
    <div class="chart-wrap">
      <h3 style="margin-top:0;">Quarterly Dividend Trend</h3>
      <canvas id="quarterlyChart"></canvas>
    </div>

    <!-- Income Calculator -->
    <h2>SCHD Dividend Income Calculator</h2>
    <div class="calc-card">
      <div class="calc-grid">
        <div class="field">
          <label>Number of SCHD Shares</label>
          <input type="number" id="calcShares" value="100" min="1" oninput="calcIncome()">
        </div>
        <div class="field">
          <label>Average Share Price ($)</label>
          <input type="number" id="calcPrice" value="82" min="1" step="0.01" oninput="calcIncome()">
        </div>
        <div class="field">
          <label>Annual Dividend Per Share ($)</label>
          <input type="number" id="calcDiv" value="2.86" min="0" step="0.01" oninput="calcIncome()">
        </div>
        <div class="field">
          <label>Annual Dividend Growth (%)</label>
          <input type="number" id="calcGrowth" value="10" min="0" step="0.5" oninput="calcIncome()">
        </div>
      </div>
      <div class="calc-result" id="calcResult"></div>
    </div>

    <!-- What Makes SCHD Special -->
    <h2>Why Investors Choose SCHD</h2>
    <div class="info-grid">
      <div class="info-card">
        <h4>📊 Quality Screen</h4>
        <p>SCHD tracks the Dow Jones U.S. Dividend 100 Index, which requires at least 10 consecutive years of dividend payments. Stocks are further screened for cash flow to total debt, return on equity, dividend yield, and 5-year dividend growth rate.</p>
      </div>
      <div class="info-card">
        <h4>💰 Growth + Yield</h4>
        <p>Unlike high-yield ETFs that sacrifice growth, SCHD balances a competitive ~3.5% yield with ~10% annual dividend growth. This means your income stream grows significantly faster than inflation — doubling roughly every 7 years.</p>
      </div>
      <div class="info-card">
        <h4>🏷️ Rock-Bottom Fees</h4>
        <p>At 0.06% expense ratio, SCHD costs just $6 per year for every $10,000 invested. This is among the lowest fees in the dividend ETF category, leaving more of the dividend in your pocket.</p>
      </div>
      <div class="info-card">
        <h4>🔄 Annual Reconstitution</h4>
        <p>The index reconstitutes every March, adding companies that have improved their dividend profile and removing those that no longer qualify. This built-in quality maintenance keeps the portfolio fresh without requiring active management decisions.</p>
      </div>
    </div>

    <!-- SCHD vs Competitors -->
    <h2>SCHD vs Other Dividend ETFs</h2>
    <div style="overflow-x:auto;">
      <table class="div-table">
        <thead><tr><th>ETF</th><th>Yield</th><th>Expense Ratio</th><th>Holdings</th><th>Div Growth (5yr)</th><th>Focus</th></tr></thead>
        <tbody>
          <tr><td>SCHD</td><td>~3.5%</td><td>0.06%</td><td>~100</td><td>~10%</td><td>Quality + Growth</td></tr>
          <tr><td>VYM</td><td>~2.8%</td><td>0.06%</td><td>~450</td><td>~6%</td><td>Broad High Yield</td></tr>
          <tr><td>HDV</td><td>~3.3%</td><td>0.08%</td><td>~75</td><td>~5%</td><td>High Dividend</td></tr>
          <tr><td>DGRO</td><td>~2.3%</td><td>0.08%</td><td>~420</td><td>~10%</td><td>Dividend Growth</td></tr>
          <tr><td>VIG</td><td>~1.7%</td><td>0.06%</td><td>~315</td><td>~8%</td><td>Div Appreciation</td></tr>
          <tr><td>JEPI</td><td>~7.5%</td><td>0.35%</td><td>~120</td><td>N/A</td><td>Options Income</td></tr>
        </tbody>
      </table>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">How often does SCHD pay dividends? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>SCHD pays dividends quarterly, typically in March, June, September, and December. Ex-dividend dates usually fall in the third week of each quarter month. Payments are deposited within a few business days of the pay date.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">What is SCHD's current dividend yield? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>SCHD's trailing 12-month yield fluctuates between 3.3% and 3.8% depending on the share price. As of early 2026, the yield is approximately 3.5%, significantly higher than the S&P 500's ~1.3% average. The yield changes daily as the share price moves.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">Is SCHD a good dividend ETF? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>SCHD is widely considered one of the best dividend ETFs. It has a low expense ratio (0.06%), strong dividend growth (~10% annually), a quality screening methodology, and holds roughly 100 high-quality stocks. It balances yield with growth better than most peers.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">How has SCHD's dividend grown over time? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>SCHD's annual dividend has grown from ~$0.85 in 2012 to over $2.86 in 2025, a compound annual growth rate of roughly 10%. This consistent growth, well above inflation, is one of SCHD's strongest selling points for income investors.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">What stocks are in SCHD? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>SCHD holds approximately 100 U.S. stocks selected from the Dow Jones U.S. Dividend 100 Index. Top holdings include Cisco, Broadcom, Home Depot, Verizon, Coca-Cola, PepsiCo, and Merck. The fund reconstitutes annually, favoring companies with 10+ years of consecutive dividends, strong financials, and competitive yields.</p></div>
      </div>
    </div>

    <!-- Related -->
    <h2>Related Tools</h2>
    <div class="related-links">
      <a href="/voo-dividend" class="related-link">VOO Dividend Analysis</a>
      <a href="/best-dividend-stocks" class="related-link">Best Dividend Stocks</a>
      <a href="/best-monthly-dividend-etfs" class="related-link">Best Monthly Dividend ETFs</a>
      <a href="/what-are-dividend-stocks" class="related-link">What Are Dividend Stocks?</a>
    </div>
  </div>

  <script is:inline define:vars={{ dividendHistory }}>
    // Annual chart
    const annualCtx = document.getElementById('annualChart').getContext('2d');
    new Chart(annualCtx, {
      type: 'bar',
      data: {
        labels: dividendHistory.map(d => d.year),
        datasets: [{
          label: 'Annual Dividend ($)',
          data: dividendHistory.map(d => d.annual),
          backgroundColor: 'rgba(74,143,231,0.6)',
          borderColor: '#4a8fe7',
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, ticks: { callback: v => '$' + v.toFixed(2), color: '#64748b' }, grid: { color: '#152040' } },
          x: { ticks: { color: '#64748b' }, grid: { display: false } }
        }
      }
    });

    // Quarterly chart
    const qLabels = [];
    const qData = [];
    dividendHistory.forEach(d => {
      ['q1','q2','q3','q4'].forEach((q, i) => {
        if (d[q]) { qLabels.push(`${d.year} Q${i+1}`); qData.push(d[q]); }
      });
    });
    const qCtx = document.getElementById('quarterlyChart').getContext('2d');
    new Chart(qCtx, {
      type: 'line',
      data: {
        labels: qLabels,
        datasets: [{
          label: 'Quarterly Dividend ($)',
          data: qData,
          borderColor: '#22c55e',
          backgroundColor: 'rgba(34,197,94,0.1)',
          fill: true,
          tension: 0.3,
          pointRadius: 2,
          pointHoverRadius: 5
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, ticks: { callback: v => '$' + v.toFixed(2), color: '#64748b' }, grid: { color: '#152040' } },
          x: { ticks: { color: '#64748b', maxRotation: 45, autoSkip: true, maxTicksLimit: 14 }, grid: { display: false } }
        }
      }
    });

    // Dividend table
    const tbody = document.getElementById('divTableBody');
    dividendHistory.forEach((d, i) => {
      const prev = i > 0 ? dividendHistory[i - 1].annual : null;
      const growth = prev ? ((d.annual - prev) / prev * 100).toFixed(1) : '—';
      const growthClass = prev ? (d.annual >= prev ? 'growth-pos' : 'growth-neg') : '';
      tbody.innerHTML += `<tr>
        <td>${d.year}</td>
        <td>$${d.q1.toFixed(4)}</td>
        <td>$${d.q2.toFixed(4)}</td>
        <td>$${d.q3.toFixed(4)}</td>
        <td>$${d.q4.toFixed(4)}</td>
        <td><strong>$${d.annual.toFixed(4)}</strong></td>
        <td class="${growthClass}">${growth === '—' ? '—' : (growth > 0 ? '+' : '') + growth + '%'}</td>
      </tr>`;
    });

    // Income calculator
    function calcIncome() {
      const shares = parseFloat(document.getElementById('calcShares').value) || 0;
      const price = parseFloat(document.getElementById('calcPrice').value) || 0;
      const div = parseFloat(document.getElementById('calcDiv').value) || 0;
      const growth = parseFloat(document.getElementById('calcGrowth').value) || 0;
      const investment = shares * price;
      const annualIncome = shares * div;
      const monthlyIncome = annualIncome / 12;
      const yieldPct = price > 0 ? (div / price * 100).toFixed(2) : 0;

      // 10-year projection
      let y5div = div * Math.pow(1 + growth / 100, 5);
      let y10div = div * Math.pow(1 + growth / 100, 10);
      let y5income = shares * y5div;
      let y10income = shares * y10div;

      document.getElementById('calcResult').innerHTML = `
        <div class="big-num">$${annualIncome.toFixed(2)}/year</div>
        <div class="detail">
          <strong>Investment:</strong> $${investment.toLocaleString()} (${shares} shares × $${price})<br>
          <strong>Current Yield:</strong> ${yieldPct}%<br>
          <strong>Monthly Income:</strong> $${monthlyIncome.toFixed(2)}<br>
          <strong>Quarterly Income:</strong> $${(annualIncome / 4).toFixed(2)}<br>
          <br>
          <strong>Projected with ${growth}% annual growth:</strong><br>
          Year 5: $${y5income.toFixed(2)}/year ($${(y5income/12).toFixed(2)}/month)<br>
          Year 10: $${y10income.toFixed(2)}/year ($${(y10income/12).toFixed(2)}/month)
        </div>
      `;
    }
    calcIncome();
  </script>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/schd-etf-analysis" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Schd Etf Analysis</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Complete SCHD ETF analysis: Schwab US Dividend Equity portfolio breakdown, top holdings, dividend yield history, SCHD vs...</p>
      </a>
    </div>
  </div>
</SiteLayout>
