---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Online Budget Calculator | Plan Your Finances",
  description: "Take control of your finances with our free, real-time online budget calculator. Track income, expenses, and savings goals effortlessly.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the 50/30/20 budgeting rule?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 50/30/20 rule is a simple budgeting method where you allocate 50% of your after-tax income to needs (like housing and groceries), 30% to wants (like entertainment and dining out), and 20% to savings or debt payoff."
      }
    },
    {
      "@type": "Question",
      "name": "Why is it important to create a budget?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Creating a budget helps you understand exactly where your money is going, prevents overspending, helps you prepare for emergencies, and ensures you are actively working towards your financial goals like saving for a house or retirement."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I review my budget?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It's best practice to review your budget monthly to ensure your spending aligns with your plan. However, you should also adjust it whenever there's a significant change in your income or living expenses."
      }
    },
    {
      "@type": "Question",
      "name": "What are fixed vs. variable expenses?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Fixed expenses stay relatively consistent each month (like rent, mortgage, or car payments). Variable expenses change based on your usage or choices (like groceries, entertainment, or utility bills)."
      }
    },
    {
      "@type": "Question",
      "name": "What should I do if my expenses exceed my income?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you are spending more than you earn, you need to either decrease your expenses by cutting back on 'wants', or increase your income through a side hustle, asking for a raise, or finding a higher-paying job."
      }
    }
  ]
};
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/budget-calculator" schema={JSON.stringify(schema)}>
  <div class="page-content">
    <div class="hero">
      <h1>Free Online Budget Calculator</h1>
      <p class="subtitle">Take control of your finances and visualize exactly where your money is going.</p>
    </div>

    <div class="calculator-container">
      <div class="inputs-section">

        <div class="input-category">
          <h2>1. Monthly Income</h2>
          <div class="input-group">
            <label for="primary-income">Primary Income (After Tax)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="primary-income" value="4000" min="0" step="100" />
            </div>
          </div>
          <div class="input-group">
            <label for="secondary-income">Secondary Income / Side Hustle</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="secondary-income" value="500" min="0" step="100" />
            </div>
          </div>
        </div>

        <div class="input-category">
          <h2>2. Housing & Utilities (Needs)</h2>
          <div class="input-group">
            <label for="rent-mortgage">Rent / Mortgage</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="rent-mortgage" value="1500" min="0" step="50" />
            </div>
          </div>
          <div class="input-group">
            <label for="utilities">Utilities (Electric, Water, Gas)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="utilities" value="200" min="0" step="10" />
            </div>
          </div>
          <div class="input-group">
            <label for="internet-phone">Internet & Phone</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="internet-phone" value="100" min="0" step="10" />
            </div>
          </div>
        </div>

        <div class="input-category">
          <h2>3. Living Expenses (Needs & Wants)</h2>
          <div class="input-group">
            <label for="groceries">Groceries</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="groceries" value="400" min="0" step="50" />
            </div>
          </div>
          <div class="input-group">
            <label for="transportation">Transportation (Gas, Transit)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="transportation" value="150" min="0" step="25" />
            </div>
          </div>
          <div class="input-group">
            <label for="dining-entertainment">Dining Out & Entertainment</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="dining-entertainment" value="300" min="0" step="50" />
            </div>
          </div>
        </div>

        <div class="input-category">
          <h2>4. Debt & Savings</h2>
          <div class="input-group">
            <label for="debt-payments">Debt Payments (Loans, Credit Cards)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="debt-payments" value="250" min="0" step="50" />
            </div>
          </div>
          <div class="input-group">
            <label for="savings-investments">Savings & Investments</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="savings-investments" value="500" min="0" step="50" />
            </div>
          </div>
        </div>
      </div>

      <div class="results-section">
        <div class="sticky-results">
          <h2>Budget Summary</h2>

          <div class="summary-cards">
            <div class="summary-card income-card">
              <h3>Total Monthly Income</h3>
              <div class="summary-value" id="total-income-display">$0.00</div>
            </div>

            <div class="summary-card expenses-card">
              <h3>Total Monthly Expenses</h3>
              <div class="summary-value" id="total-expenses-display">$0.00</div>
            </div>
          </div>

          <div class="balance-card" id="balance-card">
            <h3>Remaining Balance</h3>
            <div class="balance-value" id="remaining-balance-display">$0.00</div>
            <div class="balance-status" id="balance-status-message">You have a surplus!</div>
          </div>

          <div class="breakdown-chart">
            <h3>Expense Breakdown</h3>
            <div class="progress-bar-container">
              <div class="progress-bar housing" id="bar-housing" style="width: 0%"></div>
              <div class="progress-bar living" id="bar-living" style="width: 0%"></div>
              <div class="progress-bar debt" id="bar-debt" style="width: 0%"></div>
            </div>
            <div class="legend">
              <div class="legend-item"><span class="dot housing-dot"></span> Housing (<span id="pct-housing">0</span>%)</div>
              <div class="legend-item"><span class="dot living-dot"></span> Living (<span id="pct-living">0</span>%)</div>
              <div class="legend-item"><span class="dot debt-dot"></span> Debt/Savings (<span id="pct-debt">0</span>%)</div>
            </div>
          </div>

          <div id="error-message" class="error-text" style="display: none;">Please enter valid numbers.</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Mastering Your Monthly Budget</h2>
      <p>
        A budget isn't about restricting your life; it's about giving every dollar a purpose. Without a clear plan, money often slips away on small, unplanned purchases, leaving you wondering where your paycheck went at the end of the month. Using a budget calculator helps you build a solid financial foundation and reach your goals faster.
      </p>

      <h3>The 50/30/20 Budgeting Rule</h3>
      <p>
        One of the most popular and straightforward ways to structure your budget is the 50/30/20 rule, popularized by Senator Elizabeth Warren. It breaks your after-tax income into three main categories:
      </p>
      <ul>
        <li><strong>50% for Needs:</strong> These are absolute essentials. This category includes rent or mortgage, utility bills, basic groceries, required insurance, and minimum debt payments.</li>
        <li><strong>30% for Wants:</strong> This covers non-essentials and lifestyle choices. Think dining out, vacations, entertainment, hobbies, and new clothes.</li>
        <li><strong>20% for Savings & Debt Payoff:</strong> This chunk is dedicated to your financial future. It includes emergency fund contributions, retirement investing (like a 401(k) or IRA), and making extra payments on debt to clear it faster.</li>
      </ul>

      <h3>Why Categorizing Expenses Matters</h3>
      <p>
        When you categorize your expenses as Needs vs. Wants, it becomes much easier to identify where you can cut back. If you are struggling to make ends meet, your "Needs" category is usually fixed and difficult to change quickly (e.g., breaking a lease is hard). However, your "Wants" category is entirely under your control. Cutting back on dining out or subscription services provides immediate cash flow relief.
      </p>

      <h3>Dealing with Irregular Expenses</h3>
      <p>
        Not all expenses happen monthly. Things like car insurance premiums, property taxes, or holiday gifts might occur once or twice a year. To handle these in a monthly budget, calculate the annual cost and divide by 12. Set that amount aside each month in a separate savings account so the money is ready when the bill arrives. This strategy prevents sudden, large expenses from derailing your monthly budget.
      </p>

      <h3>The Zero-Based Budgeting Alternative</h3>
      <p>
        If the 50/30/20 rule feels too broad, consider a "Zero-Based Budget." In this method, your income minus your expenses must equal zero by the end of the month. This means every single dollar is assigned a job—whether that job is buying groceries, paying a bill, or going straight into savings. If you have $200 left over after all expenses are planned, you don't just leave it in your checking account; you explicitly allocate it to an investment or debt payoff goal.
      </p>

      <h3>Adjusting Your Budget Over Time</h3>
      <p>
        A budget is a living document. Your income will change, you'll pay off debts, and you'll encounter new expenses. Review your budget at the end of every month. Did you overspend on groceries? Did you have more left over than expected? Use that information to adjust your allocations for the following month. Consistency is the key to building wealth.
      </p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>What is the 50/30/20 budgeting rule?</summary>
        <p>The 50/30/20 rule is a simple budgeting method where you allocate 50% of your after-tax income to needs (like housing and groceries), 30% to wants (like entertainment and dining out), and 20% to savings or debt payoff.</p>
      </details>

      <details>
        <summary>Why is it important to create a budget?</summary>
        <p>Creating a budget helps you understand exactly where your money is going, prevents overspending, helps you prepare for emergencies, and ensures you are actively working towards your financial goals like saving for a house or retirement.</p>
      </details>

      <details>
        <summary>How often should I review my budget?</summary>
        <p>It's best practice to review your budget monthly to ensure your spending aligns with your plan. However, you should also adjust it whenever there's a significant change in your income or living expenses.</p>
      </details>

      <details>
        <summary>What are fixed vs. variable expenses?</summary>
        <p>Fixed expenses stay relatively consistent each month (like rent, mortgage, or car payments). Variable expenses change based on your usage or choices (like groceries, entertainment, or utility bills).</p>
      </details>

      <details>
        <summary>What should I do if my expenses exceed my income?</summary>
        <p>If you are spending more than you earn, you need to either decrease your expenses by cutting back on 'wants', or increase your income through a side hustle, asking for a raise, or finding a higher-paying job.</p>
      </details>
    </section>
  </div>  <script is:inline>
    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value);
    }

    function calculateBudget() {
      const ids = [
        'primary-income', 'secondary-income',
        'rent-mortgage', 'utilities', 'internet-phone',
        'groceries', 'transportation', 'dining-entertainment',
        'debt-payments', 'savings-investments'
      ];

      let values = {};
      let hasError = false;

      ids.forEach(id => {
        const val = parseFloat(document.getElementById(id).value);
        if (isNaN(val) || val < 0) {
          hasError = true;
        }
        values[id] = val || 0;
      });

      const errorMsg = document.getElementById('error-message');

      if (hasError) {
        errorMsg.style.display = 'block';
        return;
      }
      errorMsg.style.display = 'none';

      const totalIncome = values['primary-income'] + values['secondary-income'];

      const housingExpenses = values['rent-mortgage'] + values['utilities'] + values['internet-phone'];
      const livingExpenses = values['groceries'] + values['transportation'] + values['dining-entertainment'];
      const debtSavings = values['debt-payments'] + values['savings-investments'];

      const totalExpenses = housingExpenses + livingExpenses + debtSavings;
      const remainingBalance = totalIncome - totalExpenses;

      document.getElementById('total-income-display').textContent = formatCurrency(totalIncome);
      document.getElementById('total-expenses-display').textContent = formatCurrency(totalExpenses);

      const balanceEl = document.getElementById('remaining-balance-display');
      const statusEl = document.getElementById('balance-status-message');
      const balanceCard = document.getElementById('balance-card');

      balanceEl.textContent = formatCurrency(remainingBalance);

      if (remainingBalance > 0) {
        balanceCard.className = 'balance-card surplus';
        statusEl.textContent = 'You have a surplus! Great job!';
      } else if (remainingBalance < 0) {
        balanceCard.className = 'balance-card deficit';
        statusEl.textContent = 'You have a deficit. You need to cut expenses or increase income.';
      } else {
        balanceCard.className = 'balance-card balanced';
        statusEl.textContent = 'Zero-based budget achieved!';
      }

      // Update Breakdown Chart
      const totalAllocated = totalExpenses > 0 ? totalExpenses : 1; // Prevent division by zero

      const pctHousing = (housingExpenses / totalAllocated) * 100;
      const pctLiving = (livingExpenses / totalAllocated) * 100;
      const pctDebt = (debtSavings / totalAllocated) * 100;

      document.getElementById('bar-housing').style.width = `${pctHousing}%`;
      document.getElementById('bar-living').style.width = `${pctLiving}%`;
      document.getElementById('bar-debt').style.width = `${pctDebt}%`;

      document.getElementById('pct-housing').textContent = pctHousing.toFixed(1);
      document.getElementById('pct-living').textContent = pctLiving.toFixed(1);
      document.getElementById('pct-debt').textContent = pctDebt.toFixed(1);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const inputs = document.querySelectorAll('.calculator-container input[type="number"]');
      inputs.forEach(input => {
        input.addEventListener('input', calculateBudget);
      });
      calculateBudget();
    });
  </script>

  <style>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

    .calculator-container {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin: 2rem 0;
      align-items: start;
    }

    @media (min-width: 768px) {
      .calculator-container {
        grid-template-columns: 1.5fr 1fr;
      }
    }

    .inputs-section {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .input-category {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .input-category h2 {
      font-size: 1.25rem;
      margin-top: 0;
      margin-bottom: 1rem;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    .input-group { margin-bottom: 1.25rem; }
    .input-group:last-child { margin-bottom: 0; }

    .input-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      font-size: 0.95rem;
      color: var(--text-primary);
    }

    .input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    .prefix {
      position: absolute;
      left: 1rem;
      color: var(--text-secondary);
      font-family: var(--font-mono);
      font-weight: 600;
    }

    input[type="number"] {
      background: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1rem 0.75rem 2rem;
      border-radius: 8px;
      width: 100%;
      font-size: 1.1rem;
      font-family: var(--font-mono);
      transition: border-color 0.2s;
    }

    input[type="number"]:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    /* Results Section */
    .sticky-results {
      position: sticky;
      top: 80px;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .sticky-results h2 {
      margin-top: 0;
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
      text-align: center;
    }

    .summary-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .summary-card {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      padding: 1rem;
      border-radius: 8px;
      text-align: center;
    }

    .summary-card h3 {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin: 0 0 0.5rem 0;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .summary-value {
      font-size: 1.4rem;
      font-weight: 700;
      font-family: var(--font-mono);
      color: var(--text-primary);
    }

    .balance-card {
      padding: 1.5rem;
      border-radius: 12px;
      text-align: center;
      margin-bottom: 1.5rem;
      border: 2px solid transparent;
      transition: all 0.3s ease;
    }

    .balance-card h3 {
      margin: 0 0 0.5rem 0;
      font-size: 1.1rem;
      color: var(--text-primary);
    }

    .balance-value {
      font-size: 2.5rem;
      font-weight: 800;
      font-family: var(--font-mono);
      margin-bottom: 0.5rem;
    }

    .balance-status {
      font-size: 0.95rem;
      font-weight: 500;
    }

    /* Dynamic Balance States */
    .balance-card.surplus {
      background: color-mix(in srgb, #22c55e 10%, transparent);
      border-color: color-mix(in srgb, #22c55e 50%, transparent);
    }
    .balance-card.surplus .balance-value, .balance-card.surplus .balance-status {
      color: #22c55e;
    }

    .balance-card.deficit {
      background: color-mix(in srgb, #ef4444 10%, transparent);
      border-color: color-mix(in srgb, #ef4444 50%, transparent);
    }
    .balance-card.deficit .balance-value, .balance-card.deficit .balance-status {
      color: #ef4444;
    }

    .balance-card.balanced {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border-color: color-mix(in srgb, var(--accent-color) 50%, transparent);
    }
    .balance-card.balanced .balance-value, .balance-card.balanced .balance-status {
      color: var(--accent-color);
    }

    /* Breakdown Chart */
    .breakdown-chart {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-color);
    }

    .breakdown-chart h3 {
      font-size: 1rem;
      margin-top: 0;
      margin-bottom: 1rem;
      text-align: center;
      color: var(--text-secondary);
    }

    .progress-bar-container {
      display: flex;
      height: 12px;
      border-radius: 6px;
      overflow: hidden;
      background: var(--border-color);
      margin-bottom: 1rem;
    }

    .progress-bar {
      height: 100%;
      transition: width 0.3s ease;
    }

    .progress-bar.housing { background: var(--accent-color); }
    .progress-bar.living { background: color-mix(in srgb, var(--accent-color) 60%, transparent); }
    .progress-bar.debt { background: color-mix(in srgb, var(--accent-color) 30%, transparent); }

    .legend {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }

    .housing-dot { background: var(--accent-color); }
    .living-dot { background: color-mix(in srgb, var(--accent-color) 60%, transparent); }
    .debt-dot { background: color-mix(in srgb, var(--accent-color) 30%, transparent); }


    .error-text { color: #ef4444; margin-top: 1rem; font-weight: 600; text-align: center; }

    /* Prose Formatting */
    .explainer { margin: 3rem 0; line-height: 1.6; }
    .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; color: var(--accent-color); }
    .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 0.75rem; color: var(--text-primary); }
    .explainer p { margin-bottom: 1.25rem; color: var(--text-secondary); }
    .explainer ul, .explainer ol { margin-bottom: 1.5rem; color: var(--text-secondary); padding-left: 1.5rem; }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer strong { color: var(--text-primary); }

    .faq-section { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border-color); }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; text-align: center; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; font-size: 1.1rem; cursor: pointer; color: var(--text-primary); }
    .faq-section details p { margin: 1rem 0 0 0; color: var(--text-secondary); line-height: 1.6; }

  </style>
</SiteLayout>
