<script>
  function initCalculator() {
    const initialInput = document.getElementById('initialInvestment');
    const monthlyInput = document.getElementById('monthlyContribution');
    const yearsInput = document.getElementById('years');
    const returnInput = document.getElementById('annualReturn');

    const totalContResult = document.getElementById('totalContributionsResult');
    const futureValueResult = document.getElementById('futureValueResult');

    if (!initialInput || !monthlyInput || !yearsInput || !returnInput || !totalContResult || !futureValueResult) return;

    function calculate() {
      const p = parseFloat(initialInput.value) || 0;
      const pmt = parseFloat(monthlyInput.value) || 0;
      const t = parseFloat(yearsInput.value) || 0;
      const r = parseFloat(returnInput.value) || 0;

      const rate = r / 100;
      const months = t * 12;
      const monthlyRate = rate / 12;

      let futureValue = 0;

      if (rate === 0) {
        futureValue = p + (pmt * months);
      } else {
        // Compound interest formula with monthly contributions
        futureValue = p * Math.pow(1 + monthlyRate, months) +
                      pmt * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);
      }

      const totalContributions = p + (pmt * months);

      const formatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      });

      totalContResult.textContent = formatter.format(totalContributions);
      futureValueResult.textContent = formatter.format(futureValue);
    }

    [initialInput, monthlyInput, yearsInput, returnInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  }

  // Handle Astro view transitions
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for direct loads without view transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
