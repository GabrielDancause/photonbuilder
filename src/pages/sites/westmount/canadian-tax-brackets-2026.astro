---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the Canadian federal tax brackets for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2026, the projected federal tax brackets are: 15% up to $58,809; 20.5% between $58,809 and $117,619; 26% between $117,619 and $182,329; 29% between $182,329 and $259,749; and 33% on income over $259,749."
      }
    },
    {
      "@type": "Question",
      "name": "How much is the Basic Personal Amount (BPA) for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The projected federal Basic Personal Amount for 2026 is approximately $16,611. This is the amount of income you can earn before paying any federal income tax."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between marginal tax rate and average tax rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your marginal tax rate is the percentage of tax applied to your last dollar earned. Your average tax rate is the total tax you pay divided by your total income, which is always lower than your marginal rate due to progressive tax brackets."
      }
    },
    {
      "@type": "Question",
      "name": "Are Canadian tax brackets adjusted for inflation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, both federal and provincial tax brackets (in most provinces) are indexed to inflation annually using the Consumer Price Index (CPI). This prevents 'bracket creep' where inflation pushes individuals into higher tax brackets without a real increase in purchasing power."
      }
    },
    {
      "@type": "Question",
      "name": "How much are the CPP and EI deductions in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2026, CPP base contributions are roughly 5.95% up to the max pensionable earnings limit, plus the CPP2 second ceiling contribution of 4%. EI premiums are 1.66% up to the maximum insurable earnings limit."
      }
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title="2026 Canadian Tax Brackets & Income Calculator"
  description="Complete 2026 Canadian federal and provincial tax brackets. Interactive calculator: see your marginal rate, total tax, and take-home pay instantly."
  canonical="https://westmountfundamentals.com/canadian-tax-brackets-2026" schema={schema}
>
<div class="max-w-[1200px] mx-auto py-[60px] px-6 text-[#c8d0de]">
    <div class="text-center mb-[60px]">
        <h1 class="text-[3.5rem] sm:text-[2.5rem] font-black tracking-[-1.5px] mb-4 bg-gradient-to-br from-[#ffffff] to-[#a0b0c0] text-transparent bg-clip-text leading-[1.1]">2026 Canadian Tax Calculator</h1>
        <p class="text-[1.2rem] text-[#6a7a90] max-w-[600px] mx-auto">Complete federal and provincial income tax rates, CPP/EI deductions, and take-home pay analysis.</p>
    </div>

    <div class="grid grid-cols-[350px_1fr] md:grid-cols-1 gap-8 mb-[60px]">
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-2xl p-8">
            <h2 class="text-[1.25rem] font-bold text-white mb-6 flex items-center gap-2">Your Income Details</h2>

            <div class="mb-6">
                <label for="income" class="block text-[0.9rem] font-semibold text-[#6a7a90] mb-2">Annual Employment Income ($)</label>
                <input type="number" id="income" value="85000" min="0" step="1000" class="w-full bg-[rgba(0,0,0,0.2)] border border-[var(--border-color)] rounded-lg py-3.5 px-4 font-mono text-[1.1rem] text-white transition-all duration-200 focus:outline-none focus:border-[var(--accent-color)] focus:ring-[3px] focus:ring-[rgba(74,143,231,0.2)]">
            </div>

            <div class="mb-6">
                <label for="province" class="block text-[0.9rem] font-semibold text-[#6a7a90] mb-2">Province / Territory</label>
                <select id="province" class="w-full bg-[rgba(0,0,0,0.2)] border border-[var(--border-color)] rounded-lg py-3.5 px-4 font-mono text-[1.1rem] text-white transition-all duration-200 focus:outline-none focus:border-[var(--accent-color)] focus:ring-[3px] focus:ring-[rgba(74,143,231,0.2)] [&>option]:bg-[var(--card-bg)] [&>option]:text-white">
                    <option value="ON">Ontario (ON)</option>
                    <option value="BC">British Columbia (BC)</option>
                    <option value="AB">Alberta (AB)</option>
                    <option value="QC">Quebec (QC)</option>
                    <option value="MB">Manitoba (MB)</option>
                    <option value="SK">Saskatchewan (SK)</option>
                    <option value="NS">Nova Scotia (NS)</option>
                    <option value="NB">New Brunswick (NB)</option>
                    <option value="NL">Newfoundland & Labrador (NL)</option>
                    <option value="PE">Prince Edward Island (PE)</option>
                    <option value="YT">Yukon (YT)</option>
                    <option value="NT">Northwest Territories (NT)</option>
                    <option value="NU">Nunavut (NU)</option>
                </select>
            </div>

            <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 16px;">
                Note: Assumes standard basic personal amounts. Does not include specific regional tax credits or RRSP deductions.
            </p>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-2xl p-8">
            <h2 class="text-[1.25rem] font-bold text-white mb-6 flex items-center gap-2">Tax Summary & Take-Home Pay</h2>

            <div class="grid grid-cols-2 md:grid-cols-1 gap-4 mb-8">
                <div class="bg-[rgba(0,0,0,0.2)] border border-[var(--border-color)] rounded-xl p-5">
                    <div class="font-mono text-[2rem] font-bold text-[#2ecc71] mb-1" id="takeHomePay">$0</div>
                    <div class="text-[0.85rem] font-semibold text-[#6a7a90] uppercase tracking-[0.5px]">Net Take-Home Pay</div>
                </div>
                <div class="bg-[rgba(0,0,0,0.2)] border border-[var(--border-color)] rounded-xl p-5">
                    <div class="font-mono text-[2rem] font-bold text-[#e74c3c] mb-1" id="totalTax">$0</div>
                    <div class="text-[0.85rem] font-semibold text-[#6a7a90] uppercase tracking-[0.5px]">Total Income Tax</div>
                </div>
                <div class="bg-[rgba(0,0,0,0.2)] border border-[var(--border-color)] rounded-xl p-5">
                    <div class="font-mono text-[2rem] font-bold text-[var(--accent-color)] mb-1" id="avgRate">0%</div>
                    <div class="text-[0.85rem] font-semibold text-[#6a7a90] uppercase tracking-[0.5px]">Average Tax Rate</div>
                </div>
                <div class="bg-[rgba(0,0,0,0.2)] border border-[var(--border-color)] rounded-xl p-5">
                    <div class="font-mono text-[2rem] font-bold text-white mb-1" id="marginalRate">0%</div>
                    <div class="text-[0.85rem] font-semibold text-[#6a7a90] uppercase tracking-[0.5px]">Marginal Tax Rate</div>
                </div>
            </div>

            <div class="h-[300px] mt-6 relative">
                <canvas id="taxChart"></canvas>
            </div>

            <table class="w-full border-collapse mt-8">
                <thead>
                    <tr>
                        <th class="text-left py-3 px-4 border-b-2 border-[var(--border-color)] text-[#6a7a90] text-[0.85rem] uppercase tracking-[0.5px]">Deduction</th>
                        <th class="text-right py-3 px-4 border-b-2 border-[var(--border-color)] text-[#6a7a90] text-[0.85rem] uppercase tracking-[0.5px]">Amount</th>
                        <th class="text-right py-3 px-4 border-b-2 border-[var(--border-color)] text-[#6a7a90] text-[0.85rem] uppercase tracking-[0.5px]">% of Income</th>
                    </tr>
                </thead>
                <tbody id="breakdownBody" class="[&>tr:last-child>td]:border-b-0 [&>.row-total>td]:font-bold [&>.row-total>td]:text-white [&>.row-total>td]:border-t-2 [&>.row-total>td]:border-[var(--border-color)] [&>tr>td]:py-4 [&>tr>td]:border-b [&>tr>td]:border-[var(--border-color)] [&>tr>td]:font-mono [&>tr>td]:text-[0.95rem]">
                    <!-- JS injected -->
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-[60px]">
        <h2 class="text-[1.25rem] font-bold text-white mb-6 flex items-center gap-2">2026 Tax Brackets Table</h2>
        <div class="flex gap-3 mb-6 border-b border-[var(--border-color)] pb-4 overflow-x-auto" id="bracketTabs">
            <button class="tab active bg-transparent border-none text-[var(--accent-color)] font-sans text-[1rem] font-semibold cursor-pointer py-2 px-4 rounded-lg transition-all duration-200 whitespace-nowrap bg-[rgba(74,143,231,0.1)]" data-target="federal">Federal</button>
            <button class="tab bg-transparent border-none text-[#6a7a90] font-sans text-[1rem] font-semibold cursor-pointer py-2 px-4 rounded-lg transition-all duration-200 whitespace-nowrap hover:bg-[rgba(255,255,255,0.05)] hover:text-[#c8d0de]" data-target="provincial">Provincial</button>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-1 gap-8" id="bracketsDisplay">
            <!-- JS injected -->
        </div>
    </div>

    <div class="mt-[80px]">
        <h2 class="text-[2rem] font-bold text-white mb-6 flex items-center gap-2">Frequently Asked Questions</h2>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-4">
            <h3 class="text-[1.2rem] text-white mb-3 font-bold">What are the Canadian federal tax brackets for 2026?</h3>
            <p class="text-[#c8d0de]">For 2026, the projected federal tax brackets are: 15% up to $58,809; 20.5% between $58,809 and $117,619; 26% between $117,619 and $182,329; 29% between $182,329 and $259,749; and 33% on income over $259,749.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-4">
            <h3 class="text-[1.2rem] text-white mb-3 font-bold">How much is the Basic Personal Amount (BPA) for 2026?</h3>
            <p class="text-[#c8d0de]">The projected federal Basic Personal Amount for 2026 is approximately $16,611. This is the amount of income you can earn before paying any federal income tax.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-4">
            <h3 class="text-[1.2rem] text-white mb-3 font-bold">What is the difference between marginal tax rate and average tax rate?</h3>
            <p class="text-[#c8d0de]">Your marginal tax rate is the percentage of tax applied to your last dollar earned. Your average tax rate is the total tax you pay divided by your total income, which is always lower than your marginal rate due to progressive tax brackets.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-4">
            <h3 class="text-[1.2rem] text-white mb-3 font-bold">Are Canadian tax brackets adjusted for inflation?</h3>
            <p class="text-[#c8d0de]">Yes, both federal and provincial tax brackets (in most provinces) are indexed to inflation annually using the Consumer Price Index (CPI). This prevents 'bracket creep' where inflation pushes individuals into higher tax brackets without a real increase in purchasing power.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-4">
            <h3 class="text-[1.2rem] text-white mb-3 font-bold">How much are the CPP and EI deductions in 2026?</h3>
            <p class="text-[#c8d0de]">For 2026, CPP base contributions are roughly 5.95% up to the max pensionable earnings limit, plus the CPP2 second ceiling contribution of 4%. EI premiums are 1.66% up to the maximum insurable earnings limit.</p>
        </div>
    </div>

    <div class="mt-[80px] p-8 bg-[rgba(74,143,231,0.05)] border border-[var(--accent-color)] rounded-xl">
        <h2 class="text-[var(--accent-color)] mb-4 text-[1.5rem] font-bold">Data & Methodology</h2>
        <p class="text-[#c8d0de]">The 2026 tax brackets, basic personal amounts, and payroll limits presented here are <strong class="text-white">projected estimates</strong>. The Canada Revenue Agency (CRA) traditionally announces official indexation factors in November of the preceding year. We have applied a standard historical inflation indexation factor (~2.5%) to the finalized 2024/2025 CRA and provincial limits to generate these forward-looking estimates. Actual limits may vary slightly when officially finalized. This calculator focuses on standard employment income and standard basic personal amounts; it does not factor in RRSP contributions, self-employment, capital gains, or specific regional tax credits.</p>
    </div>

</div>
  <script is:inline>
document.getElementById('year').textContent = new Date().getFullYear();

    const taxData = {
      federal: [
        { rate: 0.15, threshold: 0 },
        { rate: 0.205, threshold: 58809 },
        { rate: 0.26, threshold: 117619 },
        { rate: 0.29, threshold: 182329 },
        { rate: 0.33, threshold: 259749 }
      ],
      ON: [
        { rate: 0.0505, threshold: 0 },
        { rate: 0.0915, threshold: 52732 },
        { rate: 0.1116, threshold: 105464 },
        { rate: 0.1216, threshold: 150000 },
        { rate: 0.1316, threshold: 220000 }
      ],
      BC: [
        { rate: 0.0506, threshold: 0 },
        { rate: 0.0770, threshold: 49152 },
        { rate: 0.1050, threshold: 98305 },
        { rate: 0.1229, threshold: 112870 },
        { rate: 0.1470, threshold: 137997 },
        { rate: 0.1680, threshold: 183858 },
        { rate: 0.2050, threshold: 247915 }
      ],
      AB: [
        { rate: 0.10, threshold: 0 },
        { rate: 0.12, threshold: 152000 },
        { rate: 0.13, threshold: 182400 },
        { rate: 0.14, threshold: 243200 },
        { rate: 0.15, threshold: 304000 }
      ],
      QC: [
        { rate: 0.14, threshold: 0 },
        { rate: 0.19, threshold: 51069 },
        { rate: 0.24, threshold: 102137 },
        { rate: 0.2575, threshold: 125568 }
      ],
      MB: [
        { rate: 0.108, threshold: 0 },
        { rate: 0.1275, threshold: 48350 },
        { rate: 0.174, threshold: 102434 }
      ],
      SK: [
        { rate: 0.105, threshold: 0 },
        { rate: 0.125, threshold: 53139 },
        { rate: 0.145, threshold: 152865 }
      ],
      NS: [
        { rate: 0.0879, threshold: 0 },
        { rate: 0.1495, threshold: 29590 },
        { rate: 0.1667, threshold: 59180 },
        { rate: 0.175, threshold: 93000 },
        { rate: 0.21, threshold: 150000 }
      ],
      NB: [
        { rate: 0.094, threshold: 0 },
        { rate: 0.14, threshold: 49451 },
        { rate: 0.16, threshold: 98901 },
        { rate: 0.195, threshold: 189726 },
        { rate: 0.203, threshold: 199623 }
      ],
      PE: [
        { rate: 0.0965, threshold: 0 },
        { rate: 0.1363, threshold: 33328 },
        { rate: 0.1665, threshold: 64656 },
        { rate: 0.18, threshold: 105000 },
        { rate: 0.1875, threshold: 140000 }
      ],
      NL: [
        { rate: 0.087, threshold: 0 },
        { rate: 0.145, threshold: 44040 },
        { rate: 0.158, threshold: 88081 },
        { rate: 0.178, threshold: 148107 },
        { rate: 0.198, threshold: 209761 },
        { rate: 0.208, threshold: 262201 },
        { rate: 0.213, threshold: 524401 },
        { rate: 0.218, threshold: 1048803 }
      ],
      YT: [
        { rate: 0.064, threshold: 0 },
        { rate: 0.09, threshold: 58809 },
        { rate: 0.109, threshold: 117619 },
        { rate: 0.128, threshold: 182329 },
        { rate: 0.15, threshold: 500000 }
      ],
      NT: [
        { rate: 0.059, threshold: 0 },
        { rate: 0.086, threshold: 52206 },
        { rate: 0.122, threshold: 104412 },
        { rate: 0.1405, threshold: 169824 }
      ],
      NU: [
        { rate: 0.04, threshold: 0 },
        { rate: 0.07, threshold: 55653 },
        { rate: 0.09, threshold: 111306 },
        { rate: 0.115, threshold: 181313 }
      ]
    };

    const payrollData = {
        bpaFederal: 16611,
        eiRate: 0.0166,
        eiMax: 1087.30,
        cppRate: 0.0595,
        cppExemption: 3500,
        cppMax: 4034.10,
        cpp2Rate: 0.04,
        cpp2Threshold: 71300,
        cpp2Max: 204
    };

    const provNames = {
        ON: "Ontario", BC: "British Columbia", AB: "Alberta", QC: "Quebec",
        MB: "Manitoba", SK: "Saskatchewan", NS: "Nova Scotia", NB: "New Brunswick",
        PE: "Prince Edward Island", NL: "Newfoundland & Labrador", YT: "Yukon",
        NT: "Northwest Territories", NU: "Nunavut"
    };

    let currentChart = null;

    function formatMoney(amount) {
        return new Intl.NumberFormat('en-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 }).format(amount);
    }

    function formatPct(rate) {
        return (rate * 100).toFixed(1) + '%';
    }

    function calculateTax(income, brackets, bpa) {
        let tax = 0;
        let marginalRate = brackets[0].rate;
        let taxableIncome = Math.max(0, income - bpa);

        for (let i = 0; i < brackets.length; i++) {
            const b = brackets[i];
            const nextThreshold = brackets[i+1] ? brackets[i+1].threshold : Infinity;

            if (taxableIncome > b.threshold) {
                const incomeInBracket = Math.min(taxableIncome - b.threshold, nextThreshold - b.threshold);
                tax += incomeInBracket * b.rate;
                marginalRate = b.rate;
            }
        }
        return { tax, marginalRate };
    }

    function calculate() {
        const income = parseFloat(document.getElementById('income').value) || 0;
        const prov = document.getElementById('province').value;

        // Payroll deductions
        const ei = Math.min(income * payrollData.eiRate, payrollData.eiMax);
        const cppIncome = Math.max(0, income - payrollData.cppExemption);
        const cppBase = Math.min(cppIncome * payrollData.cppRate, payrollData.cppMax);

        let cpp2 = 0;
        if (income > payrollData.cpp2Threshold) {
             cpp2 = Math.min((income - payrollData.cpp2Threshold) * payrollData.cpp2Rate, payrollData.cpp2Max);
        }
        const totalCppEi = ei + cppBase + cpp2;

        // Tax
        const federalBPA = payrollData.bpaFederal;
        const provBPA = federalBPA * 0.8; // Rough estimate for prov BPA

        const fed = calculateTax(income, taxData.federal, federalBPA);
        const prv = calculateTax(income, taxData[prov], provBPA);

        const totalTax = fed.tax + prv.tax;
        const takeHome = income - totalTax - totalCppEi;

        const marginalTotal = fed.marginalRate + prv.marginalRate;
        const avgTotal = income > 0 ? (totalTax / income) : 0;

        // Update DOM
        document.getElementById('takeHomePay').textContent = formatMoney(takeHome);
        document.getElementById('totalTax').textContent = formatMoney(totalTax);
        document.getElementById('avgRate').textContent = formatPct(avgTotal);
        document.getElementById('marginalRate').textContent = formatPct(marginalTotal);

        // Breakdown table
        document.getElementById('breakdownBody').innerHTML = `
            <tr>
                <td>Federal Income Tax</td>
                <td class="text-right">${formatMoney(fed.tax)}</td>
                <td class="text-right">${formatPct(income > 0 ? fed.tax / income : 0)}</td>
            </tr>
            <tr>
                <td>Provincial Income Tax (${provNames[prov]})</td>
                <td class="text-right">${formatMoney(prv.tax)}</td>
                <td class="text-right">${formatPct(income > 0 ? prv.tax / income : 0)}</td>
            </tr>
            <tr>
                <td>CPP / QPP Premiums</td>
                <td class="text-right">${formatMoney(cppBase + cpp2)}</td>
                <td class="text-right">${formatPct(income > 0 ? (cppBase + cpp2) / income : 0)}</td>
            </tr>
            <tr>
                <td>EI Premiums</td>
                <td class="text-right">${formatMoney(ei)}</td>
                <td class="text-right">${formatPct(income > 0 ? ei / income : 0)}</td>
            </tr>
            <tr class="row-total">
                <td>Total Deductions</td>
                <td class="text-right" style="color: #e74c3c">${formatMoney(totalTax + totalCppEi)}</td>
                <td class="text-right">${formatPct(income > 0 ? (totalTax + totalCppEi) / income : 0)}</td>
            </tr>
            <tr class="row-total">
                <td>Net Take-Home Pay</td>
                <td class="text-right" style="color: #2ecc71">${formatMoney(takeHome)}</td>
                <td class="text-right">${formatPct(income > 0 ? takeHome / income : 0)}</td>
            </tr>
        `;

        updateChart(takeHome, fed.tax, prv.tax, cppBase + cpp2 + ei);
    }

    function updateChart(takeHome, fed, prv, cppEi) {
        if (!window.Chart) return;
        const ctx = document.getElementById('taxChart').getContext('2d');
        if (currentChart) currentChart.destroy();

        currentChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Take-Home Pay', 'Federal Tax', 'Provincial Tax', 'CPP & EI'],
                datasets: [{
                    data: [takeHome, fed, prv, cppEi],
                    backgroundColor: ['#2ecc71', '#3498db', '#9b59b6', '#f1c40f'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: { color: '#c8d0de', font: { family: 'Inter', size: 12 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let label = context.label || '';
                                if (label) label += ': ';
                                label += formatMoney(context.raw);
                                return label;
                            }
                        }
                    }
                }
            }
        });
    }

    function renderBrackets(type) {
        const container = document.getElementById('bracketsDisplay');
        let html = '';

        function renderTable(title, brackets) {
            let t = `<div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl overflow-hidden"><table class="w-full border-collapse [&_th]:p-4 [&_th]:text-left [&_th]:border-b [&_th]:border-[var(--border-color)] [&_td]:p-4 [&_td]:text-left [&_td]:border-b [&_td]:border-[var(--border-color)] [&_tr:last-child>td]:border-b-0">
                <thead><tr><th colspan="2" class="text-[1.1rem] text-white bg-[var(--card-bg)] font-bold">${title}</th></tr>
                <tr><th class="bg-[rgba(0,0,0,0.2)] text-[0.85rem] text-[#6a7a90] uppercase tracking-[0.5px]">Income Threshold</th><th class="bg-[rgba(0,0,0,0.2)] text-[0.85rem] text-[#6a7a90] uppercase tracking-[0.5px]">Tax Rate</th></tr></thead><tbody class="[&_td]:font-mono [&_td]:text-[0.95rem]">`;

            for (let i = 0; i < brackets.length; i++) {
                const start = formatMoney(brackets[i].threshold);
                const end = brackets[i+1] ? ' to ' + formatMoney(brackets[i+1].threshold) : ' and up';
                const range = i === 0 ? `Up to ${brackets[i+1] ? formatMoney(brackets[i+1].threshold) : 'and up'}` : `${start}${end}`;
                t += `<tr><td>${range}</td><td>${formatPct(brackets[i].rate)}</td></tr>`;
            }
            t += `</tbody></table></div>`;
            return t;
        }

        if (type === 'federal') {
            html += renderTable('2026 Federal Tax Brackets', taxData.federal);
        } else {
            const prov = document.getElementById('province').value;
            html += renderTable(`2026 Provincial Brackets (${provNames[prov]})`, taxData[prov]);
        }

        container.innerHTML = html;
    }

    document.getElementById('income').addEventListener('input', calculate);
    document.getElementById('province').addEventListener('change', () => {
        calculate();
        const activeTab = document.querySelector('.tab.active').dataset.target;
        if (activeTab === 'provincial') renderBrackets('provincial');
    });

    document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', (e) => {
            document.querySelectorAll('.tab').forEach(t => {
                t.classList.remove('active');
                t.classList.replace('text-[var(--accent-color)]', 'text-[#6a7a90]');
                t.classList.replace('bg-[rgba(74,143,231,0.1)]', 'bg-transparent');
            });
            e.target.classList.add('active');
            e.target.classList.replace('text-[#6a7a90]', 'text-[var(--accent-color)]');
            e.target.classList.replace('bg-transparent', 'bg-[rgba(74,143,231,0.1)]');
            renderBrackets(e.target.dataset.target);
        });
    });

    // Init
    setTimeout(() => {
        calculate();
        renderBrackets('federal');
    }, 100);
  </script>
</SiteLayout>
