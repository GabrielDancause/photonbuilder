---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Compound Interest Visualizer: Watch Your Money Grow",
  description: "See the power of compound interest with interactive charts. Visualize year-by-year growth, compare starting early vs late, and discover your money's doubling time.",
  category: "tool",
  published: "2026-03-21"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": meta.title,
      "description": meta.description,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "datePublished": meta.published,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/compound-interest-visualizer"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is compound interest and how does it work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Compound interest is interest earned on both your original principal and on previously accumulated interest. Unlike simple interest which only applies to the initial amount, compound interest causes your money to grow exponentially over time. For example, $10,000 at 8% annual return becomes $10,800 after year one, then $11,664 after year two because the 8% applies to the new, larger balance."
          }
        },
        {
          "@type": "Question",
          "name": "How long does it take for money to double with compound interest?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can estimate doubling time using the Rule of 72: divide 72 by your annual rate of return. At 8% annual returns, your money doubles approximately every 9 years (72 / 8 = 9). At 10%, it doubles every 7.2 years. At 6%, it takes about 12 years. This rule provides a quick mental shortcut that is remarkably accurate for rates between 2% and 15%."
          }
        },
        {
          "@type": "Question",
          "name": "How much difference does starting 5 years earlier make?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Starting 5 years earlier can make a dramatic difference due to exponential growth. For example, investing $500/month at 8% for 30 years yields about $745,000, while starting just 5 years later (25 years) yields about $475,000 — a difference of $270,000 from only $30,000 more in contributions. The earlier years of compounding create a snowball effect that becomes impossible to replicate by investing more later."
          }
        },
        {
          "@type": "Question",
          "name": "What rate of return should I use for compound interest calculations?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For long-term stock market investments, 7-10% is a commonly used range. The S&P 500 has historically returned about 10% annually before inflation, or roughly 7% after inflation. For a balanced portfolio with bonds, 5-7% is more realistic. For savings accounts or CDs, use 3-5% in the current rate environment. Always consider using the inflation-adjusted (real) rate for more accurate purchasing-power projections."
          }
        },
        {
          "@type": "Question",
          "name": "Why does compound interest appear to grow slowly at first then accelerate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This is the nature of exponential growth. In the early years, the interest earned is small relative to your contributions. But as your balance grows, each year's interest becomes larger in absolute terms. After 20+ years, the interest earned in a single year can exceed your entire annual contribution. This is why long time horizons are so critical — the most dramatic growth happens in the final third of your investment period."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/compound-interest-visualizer"
  schema={schema}
>
  <div class="page-content">

    <div style="text-align: center; margin-bottom: 2rem;">
      <h1>Compound Interest Visualizer</h1>
      <p style="font-size: 1.2rem; max-width: 640px; margin: 0 auto;">Watch your money grow exponentially. See the dramatic power of compounding — and what happens when you start earlier or later.</p>
    </div>

    <div class="calculator-card">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
        <div class="input-group">
          <label for="initialInvestment">Initial Investment</label>
          <div class="input-wrapper">
            <span style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
            <input type="number" id="initialInvestment" value="10000" min="0" step="1000" style="padding-left: 2rem;">
          </div>
        </div>

        <div class="input-group">
          <label for="monthlyContribution">Monthly Contribution</label>
          <div class="input-wrapper">
            <span style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
            <input type="number" id="monthlyContribution" value="500" min="0" step="50" style="padding-left: 2rem;">
          </div>
        </div>

        <div class="input-group">
          <label for="annualRate">Annual Rate of Return</label>
          <div class="input-wrapper">
            <input type="number" id="annualRate" value="8" min="0.1" max="30" step="0.5">
            <span class="suffix">%</span>
          </div>
        </div>

        <div class="input-group">
          <label for="timeHorizon">Time Horizon</label>
          <div class="input-wrapper">
            <input type="number" id="timeHorizon" value="25" min="1" max="50" step="1">
            <span class="suffix">years</span>
          </div>
        </div>
      </div>

      <div style="text-align: center; margin-top: 1.5rem;">
        <button id="calcBtn" style="padding: 0.75rem 2rem; background: var(--accent-color); color: #fff; border: none; border-radius: 6px; font-size: 1rem; font-weight: 600; cursor: pointer;">Visualize Growth</button>
      </div>
    </div>

    <!-- Results -->
    <div id="resultsSection" style="display: none;">

      <!-- Key Stats -->
      <div class="stats-grid" style="margin-top: 2rem;">
        <div class="stat-card">
          <span class="calc-result-label">Final Balance</span>
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--accent-color);" id="finalBalance">$0</div>
        </div>
        <div class="stat-card">
          <span class="calc-result-label">Total Contributions</span>
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary);" id="totalContributions">$0</div>
        </div>
        <div class="stat-card">
          <span class="calc-result-label">Total Interest Earned</span>
          <div style="font-size: 1.5rem; font-weight: 700; color: #50c878;" id="totalInterest">$0</div>
        </div>
        <div class="stat-card">
          <span class="calc-result-label">Doubling Time</span>
          <div style="font-size: 1.5rem; font-weight: 700; color: #e8a735;" id="doublingTime">—</div>
          <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;" id="doublingNote"></div>
        </div>
      </div>

      <!-- Interest vs Contributions bar -->
      <div class="chart-container" style="margin-top: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem;">Your Money: Contributions vs Interest Earned</h3>
        <div id="breakdownBar" style="display: flex; border-radius: 8px; overflow: hidden; height: 48px; font-weight: 600; font-size: 0.9rem;"></div>
        <div style="display: flex; justify-content: space-between; margin-top: 0.75rem; font-size: 0.9rem; color: var(--text-secondary);">
          <span id="contribPct"></span>
          <span id="interestPct"></span>
        </div>
      </div>

      <!-- Stacked Area Chart -->
      <div class="chart-container" style="margin-top: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem;">Growth Over Time</h3>
        <canvas id="growthChart" style="width: 100%; height: 380px;"></canvas>
      </div>

      <!-- What-if comparison -->
      <div class="chart-container" style="margin-top: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem;">What If You Started 5 Years Earlier or Later?</h3>
        <div class="stats-grid" style="margin-bottom: 1.5rem;">
          <div class="stat-card" style="border-left: 3px solid #50c878;">
            <span class="calc-result-label">5 Years Earlier</span>
            <div style="font-size: 1.3rem; font-weight: 700; color: #50c878;" id="earlierValue">$0</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;" id="earlierDiff"></div>
          </div>
          <div class="stat-card" style="border-left: 3px solid var(--accent-color);">
            <span class="calc-result-label">Your Plan</span>
            <div style="font-size: 1.3rem; font-weight: 700; color: var(--accent-color);" id="currentValue">$0</div>
          </div>
          <div class="stat-card" style="border-left: 3px solid #e05555;">
            <span class="calc-result-label">5 Years Later</span>
            <div style="font-size: 1.3rem; font-weight: 700; color: #e05555;" id="laterValue">$0</div>
            <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;" id="laterDiff"></div>
          </div>
        </div>
        <canvas id="comparisonChart" style="width: 100%; height: 320px;"></canvas>
      </div>

      <!-- Year-by-Year Table -->
      <div class="chart-container" style="margin-top: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem;">Year-by-Year Growth</h3>
        <div class="table-container" style="max-height: 500px; overflow-y: auto;">
          <table id="growthTable">
            <thead style="position: sticky; top: 0; z-index: 1;">
              <tr>
                <th>Year</th>
                <th>Contributions</th>
                <th>Interest Earned</th>
                <th>Total Balance</th>
                <th>Year's Growth</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>

      <div class="info-box" style="margin-top: 2rem; padding: 1.25rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;">
        <p style="margin: 0; color: var(--text-secondary); font-size: 0.95rem;"><strong>Note:</strong> This visualizer assumes a constant annual rate of return compounded monthly. Real-world returns vary year to year — actual results will differ. The purpose is to illustrate the <em>principle</em> of compound growth, not to predict exact future values. For a more detailed projection, try our <a href="/investment-calculator">investment calculator</a>.</p>
      </div>
    </div>

    <script is:inline>
      var fmt = function(n) { return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n); };

      function computeGrowth(initial, monthly, annualRate, years) {
        var monthlyRate = annualRate / 100 / 12;
        var data = [];
        var balance = initial;
        var totalContrib = initial;
        var prevBalance = initial;

        data.push({ year: 0, contributions: initial, interest: 0, balance: initial, yearGrowth: 0 });

        for (var y = 1; y <= years; y++) {
          for (var m = 0; m < 12; m++) {
            balance = balance * (1 + monthlyRate) + monthly;
          }
          totalContrib += monthly * 12;
          var interest = balance - totalContrib;
          var yearGrowth = balance - prevBalance;
          data.push({ year: y, contributions: totalContrib, interest: interest, balance: balance, yearGrowth: yearGrowth });
          prevBalance = balance;
        }
        return data;
      }

      function calculate() {
        var initial = Math.max(0, parseFloat(document.getElementById('initialInvestment').value) || 0);
        var monthly = Math.max(0, parseFloat(document.getElementById('monthlyContribution').value) || 0);
        var rate = Math.max(0.1, Math.min(30, parseFloat(document.getElementById('annualRate').value) || 8));
        var years = Math.max(1, Math.min(50, parseInt(document.getElementById('timeHorizon').value) || 25));

        if (initial === 0 && monthly === 0) {
          initial = 1000;
          document.getElementById('initialInvestment').value = 1000;
        }

        var data = computeGrowth(initial, monthly, rate, years);
        var final_ = data[years];

        // Key stats
        document.getElementById('resultsSection').style.display = '';
        document.getElementById('finalBalance').textContent = fmt(final_.balance);
        document.getElementById('totalContributions').textContent = fmt(final_.contributions);
        document.getElementById('totalInterest').textContent = fmt(final_.interest);

        // Doubling time (Rule of 72 for display, exact for milestone)
        var rule72 = 72 / rate;
        document.getElementById('doublingTime').textContent = rule72.toFixed(1) + ' years';
        document.getElementById('doublingNote').textContent = 'Rule of 72: 72 \u00F7 ' + rate + '% = ' + rule72.toFixed(1);

        // Breakdown bar
        var contribPct = (final_.contributions / final_.balance * 100);
        var interestPctVal = (final_.interest / final_.balance * 100);
        var bar = document.getElementById('breakdownBar');
        bar.innerHTML =
          '<div style="width: ' + contribPct + '%; background: var(--accent-color); display: flex; align-items: center; justify-content: center; color: #fff; min-width: 60px;">' + fmt(final_.contributions) + '</div>' +
          '<div style="width: ' + interestPctVal + '%; background: #50c878; display: flex; align-items: center; justify-content: center; color: #fff; min-width: 60px;">' + fmt(final_.interest) + '</div>';
        document.getElementById('contribPct').textContent = 'Contributions: ' + contribPct.toFixed(1) + '%';
        document.getElementById('interestPct').textContent = 'Interest: ' + interestPctVal.toFixed(1) + '%';

        // What-if: 5 years earlier/later
        var earlierYears = years + 5;
        var laterYears = Math.max(1, years - 5);
        var earlierData = computeGrowth(initial, monthly, rate, earlierYears);
        var laterData = computeGrowth(initial, monthly, rate, laterYears);
        var earlierFinal = earlierData[earlierYears].balance;
        var laterFinal = laterData[laterYears].balance;

        document.getElementById('earlierValue').textContent = fmt(earlierFinal);
        document.getElementById('earlierDiff').textContent = '+' + fmt(earlierFinal - final_.balance) + ' more';
        document.getElementById('currentValue').textContent = fmt(final_.balance);
        document.getElementById('laterValue').textContent = fmt(laterFinal);
        document.getElementById('laterDiff').textContent = fmt(laterFinal - final_.balance) + ' less';

        // Year-by-year table
        var tbody = document.querySelector('#growthTable tbody');
        var html = '';
        for (var i = 0; i <= years; i++) {
          var d = data[i];
          var growthColor = i === 0 ? 'var(--text-secondary)' : 'var(--text-primary)';
          html += '<tr>' +
            '<td>' + (i === 0 ? 'Start' : i) + '</td>' +
            '<td>' + fmt(d.contributions) + '</td>' +
            '<td>' + fmt(d.interest) + '</td>' +
            '<td style="font-weight: 600;">' + fmt(d.balance) + '</td>' +
            '<td style="color: ' + growthColor + ';">' + (i === 0 ? '\u2014' : fmt(d.yearGrowth)) + '</td>' +
          '</tr>';
        }
        tbody.innerHTML = html;

        drawGrowthChart(data, years);
        drawComparisonChart(data, earlierData, laterData, years, earlierYears, laterYears);
      }

      function drawGrowthChart(data, years) {
        var canvas = document.getElementById('growthChart');
        var ctx = canvas.getContext('2d');
        var dpr = window.devicePixelRatio || 1;
        var rect = canvas.getBoundingClientRect();
        canvas.width = rect.width * dpr;
        canvas.height = 380 * dpr;
        canvas.style.height = '380px';
        ctx.scale(dpr, dpr);
        var W = rect.width;
        var H = 380;

        ctx.clearRect(0, 0, W, H);

        var pad = { top: 20, right: 20, bottom: 50, left: 80 };
        var cw = W - pad.left - pad.right;
        var ch = H - pad.top - pad.bottom;

        var maxVal = data[years].balance * 1.05;

        var xScale = function(i) { return pad.left + (i / years) * cw; };
        var yScale = function(v) { return pad.top + ch - (v / maxVal) * ch; };

        var styles = getComputedStyle(document.documentElement);
        var textColor = styles.getPropertyValue('--text-secondary').trim() || '#888';
        var borderColor = styles.getPropertyValue('--border-color').trim() || '#333';
        var accentColor = styles.getPropertyValue('--accent-color').trim() || '#4a9eff';

        // Grid
        ctx.strokeStyle = borderColor;
        ctx.lineWidth = 0.5;
        ctx.font = '11px system-ui, sans-serif';
        ctx.fillStyle = textColor;

        var gridLines = 5;
        for (var g = 0; g <= gridLines; g++) {
          var y = pad.top + (g / gridLines) * ch;
          var val = maxVal - (g / gridLines) * maxVal;
          ctx.beginPath();
          ctx.moveTo(pad.left, y);
          ctx.lineTo(W - pad.right, y);
          ctx.stroke();
          ctx.textAlign = 'right';
          ctx.fillText('$' + Math.round(val).toLocaleString(), pad.left - 8, y + 4);
        }

        // X labels
        ctx.textAlign = 'center';
        var step = years <= 10 ? 1 : years <= 20 ? 2 : 5;
        for (var xi = 0; xi <= years; xi += step) {
          ctx.fillText(xi === 0 ? 'Now' : 'Yr ' + xi, xScale(xi), H - pad.bottom + 20);
        }

        // Stacked area: contributions (bottom), interest (top)
        // Interest area (total balance)
        ctx.beginPath();
        ctx.moveTo(xScale(0), yScale(0));
        for (var i = 0; i <= years; i++) {
          ctx.lineTo(xScale(i), yScale(data[i].balance));
        }
        ctx.lineTo(xScale(years), yScale(0));
        ctx.closePath();
        ctx.fillStyle = 'rgba(80, 200, 120, 0.3)';
        ctx.fill();

        // Contributions area
        ctx.beginPath();
        ctx.moveTo(xScale(0), yScale(0));
        for (var i = 0; i <= years; i++) {
          ctx.lineTo(xScale(i), yScale(data[i].contributions));
        }
        ctx.lineTo(xScale(years), yScale(0));
        ctx.closePath();
        ctx.fillStyle = 'rgba(74, 158, 255, 0.35)';
        ctx.fill();

        // Total balance line
        ctx.strokeStyle = '#50c878';
        ctx.lineWidth = 2.5;
        ctx.lineJoin = 'round';
        ctx.beginPath();
        for (var i = 0; i <= years; i++) {
          var x = xScale(i);
          var yy = yScale(data[i].balance);
          if (i === 0) ctx.moveTo(x, yy);
          else ctx.lineTo(x, yy);
        }
        ctx.stroke();

        // Contributions line
        ctx.strokeStyle = accentColor;
        ctx.lineWidth = 2;
        ctx.beginPath();
        for (var i = 0; i <= years; i++) {
          var x = xScale(i);
          var yy = yScale(data[i].contributions);
          if (i === 0) ctx.moveTo(x, yy);
          else ctx.lineTo(x, yy);
        }
        ctx.stroke();

        // Doubling milestone marker
        var doublingTarget = data[0].balance * 2;
        if (data[0].balance > 0) {
          for (var i = 1; i <= years; i++) {
            if (data[i].balance >= doublingTarget && data[i-1].balance < doublingTarget) {
              var dx = xScale(i);
              var dy = yScale(data[i].balance);
              ctx.fillStyle = '#e8a735';
              ctx.beginPath();
              ctx.arc(dx, dy, 6, 0, Math.PI * 2);
              ctx.fill();
              ctx.fillStyle = '#e8a735';
              ctx.font = 'bold 11px system-ui, sans-serif';
              ctx.textAlign = 'left';
              ctx.fillText('2x at Yr ' + i, dx + 10, dy - 4);
              ctx.font = '11px system-ui, sans-serif';
              break;
            }
          }
        }

        // Legend
        ctx.font = '12px system-ui, sans-serif';
        var legendY = H - 8;
        ctx.fillStyle = accentColor;
        ctx.fillRect(pad.left, legendY - 8, 14, 3);
        ctx.fillStyle = textColor;
        ctx.textAlign = 'left';
        ctx.fillText('Contributions', pad.left + 20, legendY);

        ctx.fillStyle = '#50c878';
        ctx.fillRect(pad.left + 120, legendY - 8, 14, 3);
        ctx.fillStyle = textColor;
        ctx.fillText('Total Balance', pad.left + 140, legendY);

        ctx.fillStyle = 'rgba(80, 200, 120, 0.3)';
        ctx.fillRect(pad.left + 240, legendY - 12, 14, 10);
        ctx.fillStyle = textColor;
        ctx.fillText('Interest Earned', pad.left + 260, legendY);
      }

      function drawComparisonChart(data, earlierData, laterData, years, earlierYears, laterYears) {
        var canvas = document.getElementById('comparisonChart');
        var ctx = canvas.getContext('2d');
        var dpr = window.devicePixelRatio || 1;
        var rect = canvas.getBoundingClientRect();
        canvas.width = rect.width * dpr;
        canvas.height = 320 * dpr;
        canvas.style.height = '320px';
        ctx.scale(dpr, dpr);
        var W = rect.width;
        var H = 320;

        ctx.clearRect(0, 0, W, H);

        var pad = { top: 20, right: 20, bottom: 50, left: 80 };
        var cw = W - pad.left - pad.right;
        var ch = H - pad.top - pad.bottom;

        var maxYears = earlierYears;
        var maxVal = earlierData[earlierYears].balance * 1.05;

        var xScale = function(i) { return pad.left + (i / maxYears) * cw; };
        var yScale = function(v) { return pad.top + ch - (v / maxVal) * ch; };

        var styles = getComputedStyle(document.documentElement);
        var textColor = styles.getPropertyValue('--text-secondary').trim() || '#888';
        var borderColor = styles.getPropertyValue('--border-color').trim() || '#333';

        // Grid
        ctx.strokeStyle = borderColor;
        ctx.lineWidth = 0.5;
        ctx.font = '11px system-ui, sans-serif';
        ctx.fillStyle = textColor;

        var gridLines = 5;
        for (var g = 0; g <= gridLines; g++) {
          var y = pad.top + (g / gridLines) * ch;
          var val = maxVal - (g / gridLines) * maxVal;
          ctx.beginPath();
          ctx.moveTo(pad.left, y);
          ctx.lineTo(W - pad.right, y);
          ctx.stroke();
          ctx.textAlign = 'right';
          ctx.fillText('$' + Math.round(val).toLocaleString(), pad.left - 8, y + 4);
        }

        // X labels
        ctx.textAlign = 'center';
        var step = maxYears <= 10 ? 1 : maxYears <= 20 ? 2 : 5;
        for (var xi = 0; xi <= maxYears; xi += step) {
          ctx.fillText('Yr ' + xi, xScale(xi), H - pad.bottom + 20);
        }

        // Draw earlier line (green)
        ctx.strokeStyle = '#50c878';
        ctx.lineWidth = 2.5;
        ctx.lineJoin = 'round';
        ctx.setLineDash([]);
        ctx.beginPath();
        for (var i = 0; i <= earlierYears; i++) {
          var x = xScale(i);
          var yy = yScale(earlierData[i].balance);
          if (i === 0) ctx.moveTo(x, yy);
          else ctx.lineTo(x, yy);
        }
        ctx.stroke();

        // Draw current line (accent)
        var accentColor = styles.getPropertyValue('--accent-color').trim() || '#4a9eff';
        ctx.strokeStyle = accentColor;
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        for (var i = 0; i <= years; i++) {
          var x = xScale(i);
          var yy = yScale(data[i].balance);
          if (i === 0) ctx.moveTo(x, yy);
          else ctx.lineTo(x, yy);
        }
        ctx.stroke();

        // Draw later line (red, dashed)
        ctx.strokeStyle = '#e05555';
        ctx.lineWidth = 2;
        ctx.setLineDash([6, 4]);
        ctx.beginPath();
        for (var i = 0; i <= laterYears; i++) {
          var x = xScale(i);
          var yy = yScale(laterData[i].balance);
          if (i === 0) ctx.moveTo(x, yy);
          else ctx.lineTo(x, yy);
        }
        ctx.stroke();
        ctx.setLineDash([]);

        // End-point labels
        ctx.font = 'bold 12px system-ui, sans-serif';
        ctx.textAlign = 'left';

        ctx.fillStyle = '#50c878';
        ctx.fillText(fmt(earlierData[earlierYears].balance), xScale(earlierYears) - 60, yScale(earlierData[earlierYears].balance) - 10);

        ctx.fillStyle = accentColor;
        ctx.fillText(fmt(data[years].balance), xScale(years) + 5, yScale(data[years].balance) - 10);

        ctx.fillStyle = '#e05555';
        ctx.fillText(fmt(laterData[laterYears].balance), xScale(laterYears) + 5, yScale(laterData[laterYears].balance) - 10);

        // Legend
        ctx.font = '12px system-ui, sans-serif';
        var legendY = H - 8;

        ctx.fillStyle = '#50c878';
        ctx.fillRect(pad.left, legendY - 8, 14, 3);
        ctx.fillStyle = textColor;
        ctx.textAlign = 'left';
        ctx.fillText('5 Yrs Earlier (' + earlierYears + ' yrs)', pad.left + 20, legendY);

        ctx.fillStyle = accentColor;
        ctx.fillRect(pad.left + 170, legendY - 8, 14, 3);
        ctx.fillStyle = textColor;
        ctx.fillText('Your Plan (' + years + ' yrs)', pad.left + 190, legendY);

        ctx.strokeStyle = '#e05555';
        ctx.lineWidth = 2;
        ctx.setLineDash([6, 4]);
        ctx.beginPath();
        ctx.moveTo(pad.left + 320, legendY - 6);
        ctx.lineTo(pad.left + 334, legendY - 6);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = textColor;
        ctx.fillText('5 Yrs Later (' + laterYears + ' yrs)', pad.left + 340, legendY);
      }

      document.getElementById('calcBtn').addEventListener('click', calculate);
      calculate();
    </script>

