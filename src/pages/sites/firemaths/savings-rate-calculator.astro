---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Savings Rate Calculator",
  "url": "https://firemaths.info/savings-rate-calculator",
  "description": "Calculate your savings rate and estimate how many years until financial independence based on your income, expenses, and investment returns.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a good savings rate for financial independence?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A savings rate of 50% or higher is considered excellent for achieving financial independence (FI) quickly — typically in about 17 years. The FIRE community generally recommends saving at least 25-50% of take-home pay. At 25%, you can expect to reach FI in roughly 32 years. At 75%, it drops to about 7 years. The national average savings rate in the US is only about 3-5%, which would require 60+ years of working."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my savings rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your savings rate is calculated by dividing your total monthly savings and investments by your take-home pay (after-tax income), then multiplying by 100. For example, if your take-home pay is $6,000/month and you save/invest $2,000/month, your savings rate is 33.3%. Some people prefer to calculate it against gross income, but using take-home pay gives a more actionable number since taxes are largely outside your control."
      }
    },
    {
      "@type": "Question",
      "name": "How does savings rate affect time to financial independence?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your savings rate is the single most important factor determining how quickly you reach financial independence. This is because a higher savings rate works in two ways: it increases the amount you invest AND decreases the amount you need in retirement (since you're already living on less). At a 10% savings rate, FI takes about 51 years. At 30%, it's about 28 years. At 50%, roughly 17 years. At 70%, only about 8.5 years. The math assumes you can live on the same expenses in retirement and uses the 4% safe withdrawal rate."
      }
    },
    {
      "@type": "Question",
      "name": "What expenses should I include when calculating my savings rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Include all monthly expenses: housing (rent/mortgage, insurance, property tax), utilities, groceries, transportation, insurance premiums, subscriptions, dining out, entertainment, clothing, healthcare costs, and any debt payments. Do NOT include savings contributions, investment contributions, or retirement account contributions — those count as savings, not expenses. The key formula is: Savings Rate = (Take-Home Pay - Total Expenses) / Take-Home Pay × 100."
      }
    },
    {
      "@type": "Question",
      "name": "Does investment return rate matter more than savings rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For most people, savings rate matters significantly more than investment returns, especially in the early years. Increasing your savings rate from 10% to 20% can cut decades off your FI timeline, while the difference between a 6% and 8% return might only save a few years. However, as your portfolio grows larger, investment returns become more impactful since they compound on a bigger base. The best strategy is to maximize your savings rate first, then optimize your investment returns through low-cost index funds and proper asset allocation."
      }
    }
  ]
};

export const meta = {
  title: "Savings Rate Calculator | firemaths.info",
  description: "Calculate your savings rate and estimate years to financial independence. See how your savings rate compares to national averages and FI milestones.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Savings Rate Calculator | firemaths.info"
  description="Calculate your savings rate and estimate years to financial independence. See how your savings rate compares to national averages and FI milestones."
  canonical="https://firemaths.info/savings-rate-calculator" schema={schema}
>
  <style>
:root {
    --chart-color-a: #D4A017;
    --chart-color-b: #4A90E2;
    --chart-color-c: #50E3C2;
    --chart-color-d: #E85D75;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.chart-header {
    margin-bottom: 1.5rem;
    text-align: center;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
}

.indicator-a { background-color: var(--chart-color-a); }
.indicator-b { background-color: var(--chart-color-b); }
.indicator-c { background-color: var(--chart-color-c); }
.indicator-d { background-color: var(--chart-color-d); }

.chart-container {
    width: 100%;
    height: 400px;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

.scenario-comparison {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .scenario-comparison {
        grid-template-columns: 1fr;
    }
}

.scenario-box {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
}

.scenario-box h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
}

.scenario-box .rate {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
}

.scenario-box .amount {
    font-family: var(--font-mono);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.scenario-box .detail {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.scenario-optimistic { border-top: 3px solid #50E3C2; }
.scenario-moderate { border-top: 3px solid #4A90E2; }
.scenario-conservative { border-top: 3px solid #D4A017; }

.scenario-optimistic .amount { color: #50E3C2; }
.scenario-moderate .amount { color: #4A90E2; }
.scenario-conservative .amount { color: #D4A017; }

.milestone-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.milestone-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.milestone-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .milestone-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.milestone-item {
    text-align: center;
    padding: 1rem 0.5rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    transition: border-color 0.2s;
}

.milestone-item.active {
    border-color: var(--accent-color);
    background-color: rgba(212, 160, 23, 0.05);
}

.milestone-rate {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.milestone-years {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    margin: 0.25rem 0;
}

.milestone-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
}

.avg-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.avg-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.avg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .avg-grid {
        grid-template-columns: 1fr;
    }
}

.avg-item {
    text-align: center;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.avg-item.highlighted {
    border-color: var(--accent-color);
    background-color: rgba(212, 160, 23, 0.05);
}

.avg-age {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}

.avg-rate {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
}

.avg-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

.your-rate-badge {
    display: inline-block;
    background-color: var(--accent-color);
    color: #000;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-top: 0.5rem;
}

.progress-bar-container {
    margin-top: 1.5rem;
    padding: 1rem;
    background-color: var(--bg-color);
    border-radius: 8px;
}

.progress-bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}

.progress-bar {
    width: 100%;
    height: 24px;
    background-color: var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
}

.progress-fill {
    height: 100%;
    border-radius: 12px;
    background: linear-gradient(90deg, var(--chart-color-d), var(--chart-color-a), var(--chart-color-c));
    transition: width 0.5s ease;
}

.progress-markers {
    display: flex;
    justify-content: space-between;
    margin-top: 0.25rem;
    font-size: 0.7rem;
    color: var(--text-secondary);
    position: relative;
}

.tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .tips-grid {
        grid-template-columns: 1fr;
    }
}

.tip-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.tip-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.tip-card ul {
    list-style: none;
    padding: 0;
}

.tip-card li {
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
}

.tip-card li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--accent-color);
    font-weight: bold;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "\2212";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Savings Rate Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Calculate your savings rate and estimate your time to financial independence</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your Income &amp; Expenses</h2>
                </div>

                <div class="inputs">
                    <div class="input-group">
                        <label for="gross-income">Gross Annual Income (before tax)</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="gross-income" value="85000" min="0" step="1000">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="take-home-pay">Monthly Take-Home Pay (after tax)</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="take-home-pay" value="5500" min="0" step="100">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="monthly-expenses">Total Monthly Expenses</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="monthly-expenses" value="3500" min="0" step="100">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="monthly-savings">Total Monthly Savings / Investments</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="monthly-savings" value="2000" min="0" step="100">
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="input-group">
                            <label for="current-age">Current Age</label>
                            <div class="input-wrapper">
                                <input type="number" id="current-age" value="30" min="18" max="80" step="1">
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="current-portfolio">Current Portfolio Value</label>
                            <div class="input-wrapper has-prefix">
                                <span class="prefix">$</span>
                                <input type="number" id="current-portfolio" value="50000" min="0" step="1000">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your Savings Rate</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Savings Rate</span>
                        <div class="result-value">
                            <span id="savings-rate">0%</span>
                            <button class="copy-btn" onclick="copyValue('savings-rate', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Annual Savings</span>
                        <span class="result-value" id="annual-savings" style="color: var(--chart-color-c);">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Annual Expenses</span>
                        <span class="result-value" id="annual-expenses" style="color: var(--chart-color-d);">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">FI Number (25x expenses)</span>
                        <span class="result-value" id="fi-number" style="color: var(--chart-color-b);">$0</span>
                    </div>

                    <div style="flex-grow: 1;"></div>

                    <div class="result-item" style="padding-top: 1rem; border-top: 1px dashed var(--border-color);">
                        <span class="result-label">Effective Tax Rate</span>
                        <span class="result-value" id="tax-rate" style="font-size: 1rem;">0%</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Gross Savings Rate</span>
                        <span class="result-value" id="gross-savings-rate" style="font-size: 1rem; color: var(--text-secondary);">0%</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Expense-to-Income Ratio</span>
                        <span class="result-value" id="expense-ratio" style="font-size: 0.9rem; font-family: var(--font-ui); color: var(--text-secondary);">0%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Savings Rate Progress Bar -->
        <div class="milestone-card">
            <h2>Your Savings Rate vs. FI Milestones</h2>
            <div class="progress-bar-container">
                <div class="progress-bar-label">
                    <span>0%</span>
                    <span id="progress-label">Your Rate: 0%</span>
                    <span>100%</span>
                </div>
