  <script is:inline>
const formatCurrency = (value) => {
    return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
    }).format(value);
};

window.copyValue = async (elementId, btn) => {
    const text = document.getElementById(elementId).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => { btn.innerText = orig; }, 2000);
    } catch (err) {
        console.error('Failed to copy: ', err);
    }
};

window.toggleFaq = (btn) => {
    const item = btn.parentElement;
    item.classList.toggle('open');
};

// Calculate years to FI given savings rate and real return rate
function yearsToFI(savingsRate, realReturn, currentPortfolio, annualSavings, annualExpenses) {
    if (savingsRate >= 1) return 0;
    if (savingsRate <= 0) return Infinity;

    const fiNumber = annualExpenses * 25; // 4% rule
    if (currentPortfolio >= fiNumber) return 0;

    const monthlyReturn = realReturn / 12;
    const monthlySavings = annualSavings / 12;
    let balance = currentPortfolio;
    let months = 0;
    const maxMonths = 100 * 12;

    while (balance < fiNumber && months < maxMonths) {
        balance = balance * (1 + monthlyReturn) + monthlySavings;
        months++;
    }

    return months / 12;
}

// Classic MMM formula: years to FI based purely on savings rate (no existing portfolio)
function yearsToFIPure(savingsRate, realReturn) {
    if (savingsRate >= 1) return 0;
    if (savingsRate <= 0) return Infinity;

    // FI number = annual expenses * 25
    // annual expenses = (1 - savingsRate) * income
    // annual savings = savingsRate * income
    // We need: portfolio = 25 * annual expenses
    // Solving with compound growth:
    const r = realReturn;
    if (r === 0) return (1 - savingsRate) * 25 / savingsRate;

    // Using future value of annuity formula
    // FV = PMT * ((1+r)^n - 1) / r = 25 * expenses
    // PMT = savingsRate * income, expenses = (1-savingsRate) * income
    // savingsRate * ((1+r)^n - 1) / r = 25 * (1 - savingsRate)
    // ((1+r)^n - 1) / r = 25 * (1-savingsRate) / savingsRate
    const target = 25 * (1 - savingsRate) / savingsRate;
    const n = Math.log(target * r + 1) / Math.log(1 + r);
    return Math.max(0, n);
}

function updateAll() {
    const grossIncome = parseFloat(document.getElementById('gross-income').value) || 0;
    const takeHomePay = parseFloat(document.getElementById('take-home-pay').value) || 0;
    const monthlyExpenses = parseFloat(document.getElementById('monthly-expenses').value) || 0;
    const monthlySavings = parseFloat(document.getElementById('monthly-savings').value) || 0;
    const currentAge = parseInt(document.getElementById('current-age').value) || 30;
    const currentPortfolio = parseFloat(document.getElementById('current-portfolio').value) || 0;

    // Calculate savings rate
    const savingsRate = takeHomePay > 0 ? (monthlySavings / takeHomePay) : 0;
    const savingsRatePct = savingsRate * 100;
    const grossSavingsRate = grossIncome > 0 ? (monthlySavings * 12 / grossIncome) * 100 : 0;
    const annualSavings = monthlySavings * 12;
    const annualExpenses = monthlyExpenses * 12;
    const fiNumber = annualExpenses * 25;
    const annualTakeHome = takeHomePay * 12;
    const taxRate = grossIncome > 0 ? ((grossIncome - annualTakeHome) / grossIncome) * 100 : 0;
    const expenseRatio = takeHomePay > 0 ? (monthlyExpenses / takeHomePay) * 100 : 0;

    // Update main results
    document.getElementById('savings-rate').innerText = savingsRatePct.toFixed(1) + '%';
    document.getElementById('annual-savings').innerText = formatCurrency(annualSavings);
    document.getElementById('annual-expenses').innerText = formatCurrency(annualExpenses);
    document.getElementById('fi-number').innerText = formatCurrency(fiNumber);
    document.getElementById('tax-rate').innerText = taxRate.toFixed(1) + '%';
    document.getElementById('gross-savings-rate').innerText = grossSavingsRate.toFixed(1) + '%';
    document.getElementById('expense-ratio').innerText = expenseRatio.toFixed(1) + '%';

    // Progress bar
    const fillPct = Math.min(100, Math.max(0, savingsRatePct));
    document.getElementById('progress-fill').style.width = fillPct + '%';
    document.getElementById('progress-label').innerText = 'Your Rate: ' + savingsRatePct.toFixed(1) + '%';

    // Milestone highlights
    ['25', '50', '75', '90'].forEach(ms => {
        const el = document.getElementById('ms-' + ms);
        if (savingsRatePct >= parseInt(ms)) {
            el.classList.add('active');
        } else {
            el.classList.remove('active');
        }
    });

    // Years to FI at different return rates
    [4, 6, 8].forEach(rate => {
        const realReturn = rate / 100;
        const years = yearsToFI(savingsRate, realReturn, currentPortfolio, annualSavings, annualExpenses);
        const yearsText = years >= 99 ? '99+ yrs' : years.toFixed(1) + ' yrs';
        document.getElementById('fi-years-' + rate).innerText = yearsText;

        // Portfolio at FI
        document.getElementById('fi-bal-' + rate).innerText = 'FI target: ' + formatCurrency(fiNumber);

        // FI age
        const fiAge = currentAge + years;
        const ageText = years >= 99 ? 'FI age: 99+' : 'FI age: ' + Math.round(fiAge);
        document.getElementById('fi-age-' + rate).innerText = ageText;
    });

    // National average comparison
    const ageGroups = [
        { id: 'avg-under25', min: 0, max: 24 },
        { id: 'avg-25-34', min: 25, max: 34 },
        { id: 'avg-35-44', min: 35, max: 44 },
        { id: 'avg-45-54', min: 45, max: 54 },
        { id: 'avg-55-64', min: 55, max: 64 },
        { id: 'avg-65plus', min: 65, max: 120 }
    ];

    ageGroups.forEach(group => {
        const el = document.getElementById(group.id);
        const badge = el.querySelector('.your-rate-badge');
        if (badge) badge.remove();

        if (currentAge >= group.min && currentAge <= group.max) {
            el.classList.add('highlighted');
            const badgeEl = document.createElement('div');
            badgeEl.className = 'your-rate-badge';
            badgeEl.innerText = 'YOU: ' + savingsRatePct.toFixed(1) + '%';
            el.appendChild(badgeEl);
        } else {
            el.classList.remove('highlighted');
        }
    });

    // Draw chart
    drawChart(savingsRatePct);
}

// Chart: Savings Rate vs Years to FI
let chartCanvas = document.getElementById('fiChart');
let ctx = chartCanvas.getContext('2d');

function drawChart(userSavingsRate) {
    const dpr = window.devicePixelRatio || 1;
    const rect = chartCanvas.parentElement.getBoundingClientRect();
    chartCanvas.width = rect.width * dpr;
    chartCanvas.height = rect.height * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);

    const width = rect.width;
    const height = rect.height;
    ctx.clearRect(0, 0, width, height);

    const padding = { top: 20, right: 20, bottom: 40, left: 60 };
    const cw = width - padding.left - padding.right;
    const ch = height - padding.top - padding.bottom;

    // Generate curve data: savings rate 5% to 95%
    const curveData = [];
    for (let sr = 5; sr <= 95; sr++) {
        const years = yearsToFIPure(sr / 100, 0.05); // 5% real return
        curveData.push({ sr, years: Math.min(years, 70) });
    }

    const maxYears = 70;
    const xOf = (sr) => padding.left + cw * ((sr - 5) / 90);
    const yOf = (years) => padding.top + ch * (years / maxYears);

    // Grid
    ctx.strokeStyle = '#2a2010';
    ctx.lineWidth = 1;
    ctx.font = '12px Inter, sans-serif';
    ctx.fillStyle = '#888888';

    // Y-axis (years)
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    const yTicks = [0, 10, 20, 30, 40, 50, 60, 70];
    yTicks.forEach(val => {
        const y = yOf(val);
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(width - padding.right, y);
        ctx.stroke();
        ctx.fillText(val + ' yr', padding.left - 8, y);
    });

    // X-axis (savings rate)
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    for (let sr = 10; sr <= 90; sr += 10) {
        const x = xOf(sr);
        ctx.beginPath();
        ctx.moveTo(x, height - padding.bottom);
        ctx.lineTo(x, height - padding.bottom + 5);
        ctx.stroke();
        ctx.fillText(sr + '%', x, height - padding.bottom + 8);
    }

    // X-axis label
    ctx.fillStyle = '#888888';
    ctx.textAlign = 'center';
    ctx.fillText('Savings Rate', width / 2, height - 5);

    // Draw curve
    ctx.beginPath();
    ctx.strokeStyle = '#D4A017';
    ctx.lineWidth = 3;
    curveData.forEach((point, i) => {
        const x = xOf(point.sr);
        const y = yOf(point.years);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    });
    ctx.stroke();

    // Fill under curve
    ctx.lineTo(xOf(95), yOf(0));
    ctx.lineTo(xOf(5), yOf(0));
    ctx.closePath();
    ctx.fillStyle = 'rgba(212, 160, 23, 0.08)';
    ctx.fill();

    // Draw user's savings rate line
    if (userSavingsRate >= 5 && userSavingsRate <= 95) {
        const userYears = yearsToFIPure(userSavingsRate / 100, 0.05);
        const userYearsCapped = Math.min(userYears, 70);
        const ux = xOf(userSavingsRate);
        const uy = yOf(userYearsCapped);

        // Vertical dashed line
        ctx.setLineDash([5, 5]);
        ctx.strokeStyle = '#E85D75';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(ux, yOf(0));
        ctx.lineTo(ux, uy);
        ctx.stroke();

        // Horizontal dashed line
        ctx.beginPath();
        ctx.moveTo(padding.left, uy);
        ctx.lineTo(ux, uy);
        ctx.stroke();
        ctx.setLineDash([]);

        // Dot
        ctx.beginPath();
        ctx.arc(ux, uy, 6, 0, Math.PI * 2);
        ctx.fillStyle = '#E85D75';
        ctx.fill();
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 2;
        ctx.stroke();

        // Label
        ctx.fillStyle = '#E85D75';
        ctx.font = 'bold 13px Inter, sans-serif';
        ctx.textAlign = 'left';
        const labelText = userSavingsRate.toFixed(1) + '% → ' + (userYears >= 99 ? '99+' : userYearsCapped.toFixed(1)) + ' years';
        const labelX = ux + 10;
        const labelY = uy - 10;
        // Background
        const metrics = ctx.measureText(labelText);
        ctx.fillStyle = 'rgba(0,0,0,0.7)';
        ctx.fillRect(labelX - 4, labelY - 12, metrics.width + 8, 18);
        ctx.fillStyle = '#E85D75';
        ctx.fillText(labelText, labelX, labelY);
    }
}

// Attach listeners
document.querySelectorAll('input[type="number"]').forEach(input => {
    input.addEventListener('input', updateAll);
});

// Initial calculation
updateAll();

// Redraw chart on resize
window.addEventListener('resize', () => {
    const sr = parseFloat(document.getElementById('monthly-savings').value) || 0;
    const thp = parseFloat(document.getElementById('take-home-pay').value) || 0;
    drawChart(thp > 0 ? (sr / thp) * 100 : 0);
});
  </script>
