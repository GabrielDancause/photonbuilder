    .help-text { display: block; font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.25rem; }
    .calc-button { width: 100%; padding: 1rem; background: var(--accent-color); color: white; border: none; border-radius: 8px; font-size: 1.1rem; font-weight: bold; cursor: pointer; transition: background 0.2s; margin-bottom: 1rem; }
    .calc-button:hover { opacity: 0.9; }
    .results-section { border-top: 1px solid var(--border-color); padding-top: 1.5rem; animation: fadeIn 0.3s; }
    .results-section h3 { margin-top: 0; margin-bottom: 1rem; font-size: 1.4rem; color: var(--text-primary); }
    .result-row { display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: rgba(45, 184, 154, 0.1); border-radius: 8px; font-weight: bold; font-size: 1.2rem; margin-bottom: 0.5rem; }
    .highlight-total { color: var(--accent-color); font-size: 1.6rem; }
    .sub-total { color: var(--text-primary); font-size: 1.2rem; }
    .coverage-breakdown { margin-top: 1.5rem; padding: 1rem; border: 1px dashed var(--border-color); border-radius: 8px; }
    .coverage-breakdown h4 { margin-top: 0; margin-bottom: 0.5rem; font-size: 1rem; }
    .coverage-breakdown ul { margin: 0; padding-left: 1.5rem; font-size: 0.95rem; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>

