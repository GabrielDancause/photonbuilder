        <div class="faq-section">
            <h2>Frequently Asked Questions</h2>
            {faqSchema.mainEntity.map((item) => (
                <div class="faq-item">
                    <div class="faq-question">{item.name}</div>
                    <div class="faq-answer">{item.acceptedAnswer.text}</div>
                </div>
            ))}
        </div>

