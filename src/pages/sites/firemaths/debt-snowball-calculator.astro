</div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let debtIdCounter = 0;
let scheduleView = 'snowball';
let snowballSchedule = [];
let avalancheSchedule = [];

const defaultDebts = [
    { name: 'Credit Card', balance: 5000, rate: 22.99, minPayment: 120 },
    { name: 'Car Loan', balance: 12000, rate: 6.5, minPayment: 280 },
    { name: 'Student Loan', balance: 8500, rate: 5.8, minPayment: 150 },
    { name: 'Personal Loan', balance: 3200, rate: 12.0, minPayment: 95 },
];

function addDebt(name, balance, rate, minPayment) {
    const id = debtIdCounter++;
    const list = document.getElementById('debt-list');
    const row = document.createElement('div');
    row.className = 'debt-row';
    row.id = 'debt-' + id;
    row.innerHTML = `
        <div class="input-group">
            ${id === 0 ? '<label>Debt Name</label>' : ''}
            <div class="input-wrapper">
                <input type="text" class="debt-name" value="${name || ''}" placeholder="e.g. Credit Card">
            </div>
        </div>
        <div class="input-group">
            ${id === 0 ? '<label>Balance</label>' : ''}
            <div class="input-wrapper has-prefix">
                <span class="prefix">$</span>
                <input type="number" class="debt-balance" value="${balance || ''}" min="0" step="100" placeholder="0">
            </div>
        </div>
        <div class="input-group">
            ${id === 0 ? '<label>APR</label>' : ''}
            <div class="input-wrapper has-suffix">
                <span class="suffix">%</span>
                <input type="number" class="debt-rate" value="${rate || ''}" min="0" max="50" step="0.1" placeholder="0">
            </div>
        </div>
        <div class="input-group">
            ${id === 0 ? '<label>Min. Payment</label>' : ''}
            <div class="input-wrapper has-prefix">
                <span class="prefix">$</span>
                <input type="number" class="debt-min" value="${minPayment || ''}" min="0" step="5" placeholder="0">
            </div>
        </div>
        <button class="remove-btn" onclick="removeDebt(${id})" title="Remove debt">&times;</button>
    `;
    list.appendChild(row);

    // Attach listeners
    row.querySelectorAll('input').forEach(inp => {
        inp.addEventListener('input', calculate);
    });
    calculate();
}

window.addDebt = addDebt;

window.removeDebt = (id) => {
    const row = document.getElementById('debt-' + id);
    if (row) {
        row.remove();
        calculate();
    }
};

function getDebts() {
    const rows = document.querySelectorAll('.debt-row');
    const debts = [];
    rows.forEach(row => {
        const name = row.querySelector('.debt-name').value || 'Unnamed';
        const balance = parseFloat(row.querySelector('.debt-balance').value) || 0;
        const rate = parseFloat(row.querySelector('.debt-rate').value) || 0;
        const minPayment = parseFloat(row.querySelector('.debt-min').value) || 0;
        if (balance > 0) {
            debts.push({ name, balance, rate, minPayment });
        }
    });
    return debts;
}

function simulatePayoff(debts, extraMonthly, method) {
    if (debts.length === 0) return { schedule: [], totalInterest: 0, months: 0, payoffOrder: [] };

    // Clone debts
    let active = debts.map(d => ({ ...d, remaining: d.balance }));

    // Sort for target selection
    if (method === 'snowball') {
        active.sort((a, b) => a.balance - b.balance || b.rate - a.rate);
    } else {
        active.sort((a, b) => b.rate - a.rate || a.balance - b.balance);
    }

    const schedule = [];
    const payoffOrder = [];
    let totalInterest = 0;
    let month = 0;
    const maxMonths = 600; // 50 year safety cap

    while (active.some(d => d.remaining > 0.01) && month < maxMonths) {
        month++;
        let extraLeft = extraMonthly;
        let monthInterest = 0;
        let monthPrincipal = 0;
        let monthPayment = 0;
        const paidOff = [];

        // 1. Apply interest and minimum payments to all debts
        for (const d of active) {
            if (d.remaining <= 0.01) continue;
            const interest = d.remaining * (d.rate / 100 / 12);
            monthInterest += interest;
            let payment = Math.min(d.minPayment, d.remaining + interest);
            let principal = payment - interest;
            if (principal < 0) principal = 0;
            d.remaining -= principal;
            monthPrincipal += principal;
            monthPayment += payment;
        }

        // 2. Apply extra payment to target debt(s)
        // Re-sort active debts each month for correct targeting
        let targets;
        if (method === 'snowball') {
            targets = active.filter(d => d.remaining > 0.01).sort((a, b) => a.remaining - b.remaining || b.rate - a.rate);
        } else {
            targets = active.filter(d => d.remaining > 0.01).sort((a, b) => b.rate - a.rate || a.remaining - b.remaining);
        }

        for (const t of targets) {
            if (extraLeft <= 0.01) break;
            const apply = Math.min(extraLeft, t.remaining);
            t.remaining -= apply;
            extraLeft -= apply;
            monthPrincipal += apply;
            monthPayment += apply;
        }

        totalInterest += monthInterest;

        // Check for newly paid off debts
        for (const d of active) {
            if (d.remaining <= 0.01 && !payoffOrder.find(p => p.name === d.name)) {
                d.remaining = 0;
                payoffOrder.push({ name: d.name, month });
                paidOff.push(d.name);
            }
        }

        const totalRemaining = active.reduce((s, d) => s + Math.max(0, d.remaining), 0);

        schedule.push({
            month,
            payment: monthPayment,
            principal: monthPrincipal,
            interest: monthInterest,
            totalBalance: totalRemaining,
            totalInterest,
            paidOff
        });

        if (totalRemaining <= 0.01) break;
    }

    return {
        schedule,
        totalInterest,
        months: month,
        payoffOrder
    };
}

function calculate() {
    const debts = getDebts();
    const extra = parseFloat(document.getElementById('extra-payment').value) || 0;

    const totalMin = debts.reduce((s, d) => s + d.minPayment, 0);
    document.getElementById('total-minimums').innerText = fmt(totalMin);
    document.getElementById('total-monthly').innerText = fmt(totalMin + extra);

    if (debts.length === 0) {
        clearResults();
        return;
    }

    const snow = simulatePayoff(debts, extra, 'snowball');
    const aval = simulatePayoff(debts, extra, 'avalanche');

    snowballSchedule = snow.schedule;
    avalancheSchedule = aval.schedule;

    const totalDebt = debts.reduce((s, d) => s + d.balance, 0);

    // Snowball results
    document.getElementById('snow-interest').innerText = fmt(snow.totalInterest);
    document.getElementById('snow-total').innerText = fmt(totalDebt + snow.totalInterest);
    document.getElementById('snow-months').innerText = formatMonths(snow.months);
    document.getElementById('snow-date').innerText = futureDate(snow.months);

    // Avalanche results
    document.getElementById('aval-interest').innerText = fmt(aval.totalInterest);
    document.getElementById('aval-total').innerText = fmt(totalDebt + aval.totalInterest);
    document.getElementById('aval-months').innerText = formatMonths(aval.months);
    document.getElementById('aval-date').innerText = futureDate(aval.months);

    // Payoff order
    renderPayoffOrder('snow-order', snow.payoffOrder);
    renderPayoffOrder('aval-order', aval.payoffOrder);

    // Savings banner
    const banner = document.getElementById('savings-banner');
    const interestDiff = Math.abs(snow.totalInterest - aval.totalInterest);
    const monthDiff = Math.abs(snow.months - aval.months);

    if (interestDiff > 1) {
        banner.style.display = 'block';
        const winner = aval.totalInterest < snow.totalInterest ? 'Avalanche' : 'Snowball';
        document.getElementById('savings-amount').innerText = fmt(interestDiff);
        document.querySelector('.savings-banner-title').innerText = winner + ' saves you';
        const timeStr = monthDiff > 0 ? ' and ' + formatMonths(monthDiff) + ' sooner' : '';
        document.getElementById('savings-time').innerText = 'in interest compared to ' + (winner === 'Avalanche' ? 'Snowball' : 'Avalanche') + timeStr;
    } else {
        banner.style.display = 'block';
        document.getElementById('savings-amount').innerText = 'Same cost';
        document.querySelector('.savings-banner-title').innerText = 'Both methods';
        document.getElementById('savings-time').innerText = 'pay the same total interest for your debt profile';
    }

    renderScheduleTable();
    drawTimelineChart(snow.schedule, aval.schedule);
}

function clearResults() {
    ['snow-interest', 'snow-total', 'aval-interest', 'aval-total'].forEach(id => {
        document.getElementById(id).innerText = '$0';
    });
    ['snow-months', 'aval-months'].forEach(id => {
        document.getElementById(id).innerText = '0';
    });
    ['snow-date', 'aval-date'].forEach(id => {
        document.getElementById(id).innerText = '—';
    });
    ['snow-order', 'aval-order'].forEach(id => {
        document.getElementById(id).innerHTML = '';
    });
    document.getElementById('savings-banner').style.display = 'none';
    document.getElementById('schedule-tbody').innerHTML = '';
    snowballSchedule = [];
    avalancheSchedule = [];
}

function formatMonths(m) {
    if (m === 0) return '0';
    const years = Math.floor(m / 12);
    const months = m % 12;
    if (years === 0) return months + ' mo';
    if (months === 0) return years + ' yr';
    return years + ' yr ' + months + ' mo';
}

function futureDate(monthsFromNow) {
    if (monthsFromNow === 0) return '—';
    const d = new Date();
    d.setMonth(d.getMonth() + monthsFromNow);
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function renderPayoffOrder(elementId, order) {
    const el = document.getElementById(elementId);
    let html = '';
    order.forEach((item, i) => {
        html += `<li><span class="payoff-order-num">${i + 1}.</span> <span class="payoff-order-name">${item.name}</span> <span class="payoff-order-date">${formatMonths(item.month)}</span></li>`;
    });
    el.innerHTML = html;
}

function renderScheduleTable() {
    const thead = document.getElementById('schedule-thead');
    const tbody = document.getElementById('schedule-tbody');
    const data = scheduleView === 'snowball' ? snowballSchedule : avalancheSchedule;

    thead.innerHTML = '<tr><th>Month</th><th>Payment</th><th>Principal</th><th>Interest</th><th>Balance</th><th>Event</th></tr>';
    let html = '';
    for (const row of data) {
        const event = row.paidOff.length > 0 ? row.paidOff.join(', ') + ' paid off' : '';
        html += `<tr><td>${row.month}</td><td>${fmt2(row.payment)}</td><td>${fmt2(row.principal)}</td><td>${fmt2(row.interest)}</td><td>${fmt(row.totalBalance)}</td><td style="text-align:left;font-family:var(--font-ui);" ${event ? 'class="debt-paid"' : ''}>${event}</td></tr>`;
    }
    tbody.innerHTML = html;
}

window.setScheduleView = (view) => {
    scheduleView = view;
    document.getElementById('btn-snowball-schedule').classList.toggle('active', view === 'snowball');
    document.getElementById('btn-avalanche-schedule').classList.toggle('active', view === 'avalanche');
    renderScheduleTable();
};

function drawTimelineChart(snowData, avalData) {
    const canvas = document.getElementById('timelineChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    if (snowData.length === 0 && avalData.length === 0) return;

    const padding = { top: 30, right: 20, bottom: 40, left: 65 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    const maxMonths = Math.max(snowData.length, avalData.length);
    const maxBalance = Math.max(
        snowData.length > 0 ? snowData[0].totalBalance : 0,
        avalData.length > 0 ? avalData[0].totalBalance : 0
    ) * 1.05;

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    const gridLines = 5;
    for (let i = 0; i <= gridLines; i++) {
        const y = padding.top + (chartH / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();

        const val = maxBalance - (maxBalance / gridLines) * i;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        if (val >= 1000) {
            ctx.fillText('$' + Math.round(val / 1000) + 'k', padding.left - 8, y);
        } else {
            ctx.fillText('$' + Math.round(val), padding.left - 8, y);
        }
    }

    // X-axis labels
    const xStep = maxMonths > 60 ? 12 : maxMonths > 24 ? 6 : maxMonths > 12 ? 3 : 1;
    for (let m = 0; m <= maxMonths; m += xStep) {
        if (m === 0) continue;
        const x = padding.left + (m / maxMonths) * chartW;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText(m >= 12 ? Math.round(m / 12) + 'yr' : m + 'mo', x, padding.top + chartH + 8);
    }

    // Draw lines
    function drawLine(data, color) {
        if (data.length === 0) return;
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2.5;

        // Start point at month 0 with initial total balance
        const startBalance = data[0].totalBalance + data[0].principal;
        const startX = padding.left;
        const startY = padding.top + chartH - (startBalance / maxBalance) * chartH;
        ctx.moveTo(startX, startY);

        for (let i = 0; i < data.length; i++) {
            const x = padding.left + ((i + 1) / maxMonths) * chartW;
            const y = padding.top + chartH - (data[i].totalBalance / maxBalance) * chartH;
            ctx.lineTo(x, y);
        }
        ctx.stroke();
    }

    drawLine(snowData, '#4A90E2');
    drawLine(avalData, '#E25C5C');

    // Mark payoff events on snowball line
    for (const row of snowData) {
        if (row.paidOff.length > 0) {
            const x = padding.left + (row.month / maxMonths) * chartW;
            const y = padding.top + chartH - (row.totalBalance / maxBalance) * chartH;
            ctx.beginPath();
            ctx.arc(x, y, 4, 0, Math.PI * 2);
            ctx.fillStyle = '#4A90E2';
            ctx.fill();
        }
    }

    for (const row of avalData) {
        if (row.paidOff.length > 0) {
            const x = padding.left + (row.month / maxMonths) * chartW;
            const y = padding.top + chartH - (row.totalBalance / maxBalance) * chartH;
            ctx.beginPath();
            ctx.arc(x, y, 4, 0, Math.PI * 2);
            ctx.fillStyle = '#E25C5C';
            ctx.fill();
        }
    }
}

window.exportCSV = () => {
    const data = scheduleView === 'snowball' ? snowballSchedule : avalancheSchedule;
    if (data.length === 0) return;

    const methodName = scheduleView === 'snowball' ? 'Snowball' : 'Avalanche';
    let csv = 'Month,Payment,Principal,Interest,Remaining Balance,Event\n';
    for (const row of data) {
        const event = row.paidOff.length > 0 ? '"' + row.paidOff.join(', ') + ' paid off"' : '';
        csv += `${row.month},${row.payment.toFixed(2)},${row.principal.toFixed(2)},${row.interest.toFixed(2)},${row.totalBalance.toFixed(2)},${event}\n`;
    }

    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'debt-' + scheduleView + '-schedule.csv';
    a.click();
    URL.revokeObjectURL(url);
};

// Attach extra payment listener
document.getElementById('extra-payment').addEventListener('input', calculate);

window.addEventListener('resize', () => {
    if (snowballSchedule.length > 0 || avalancheSchedule.length > 0) {
        drawTimelineChart(snowballSchedule, avalancheSchedule);
    }
});

// Initialize with default debts
defaultDebts.forEach(d => addDebt(d.name, d.balance, d.rate, d.minPayment));
  </script>

