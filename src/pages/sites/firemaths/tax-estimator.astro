    .secondary-results { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid color-mix(in srgb, var(--accent-color) 20%, transparent); }
    .sec-result-item { display: flex; flex-direction: column; align-items: center; }
    .sec-label { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.25rem; }
