---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Credit Card Payoff Calculator",
  "url": "https://firemaths.info/credit-card-payoff",
  "description": "Calculate your credit card payoff timeline with minimum or fixed payments and find the optimal monthly amount.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Credit Card Payoff Calculator | firemaths.info"
  description="Calculate your credit card payoff timeline. Compare minimum payments, fixed payments, and find the optimal amount to become debt-free faster."
  canonical="https://firemaths.info/credit-card-payoff" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
        
        <main>
            <div class="main-inputs">
                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="balance">Current Card Balance</label>
                    <div class="relative flex items-center">
                        <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                        <input type="number" id="balance" value="5000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="rate">Interest Rate (APR)</label>
                    <div class="relative flex items-center">
                        <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                        <input type="number" id="rate" value="21.99" min="0" step="0.1" max="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
                <!-- Fixed Payment Scenario -->
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" id="scenario-fixed">
                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Fixed Payment</h2>
                    </div>

                    <div class="inputs">
                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="fixed-payment">Monthly Payment</label>
                            <div class="relative flex items-center">
                                <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                <input type="number" id="fixed-payment" value="200" min="0" step="10" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                            </div>
                            <div id="fixed-error" class="text-red-500 text-sm mt-2 !hidden">Payment is too low to cover interest!</div>
                        </div>
                    </div>

                    <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                        <div class="result-item result-highlight">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Time to Payoff</span>
                            <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                                <span id="fixed-months">0</span>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Interest</span>
                            <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                                <span id="fixed-interest">$0</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('fixed-interest', this)">Copy</button>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Paid</span>
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="fixed-total">$0</span>
                        </div>
                    </div>
                </div>

                <!-- Optimal Target Scenario -->
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" id="scenario-target">
                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Target Payoff</h2>
                    </div>

                    <div class="inputs">
                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="target-months">Desired Payoff Time</label>
                            <div class="relative flex items-center">
                                <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">mo</span>
                                <input type="number" id="target-months" value="12" min="1" max="360" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                            </div>
                        </div>
                    </div>

                    <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                        <div class="result-item result-highlight">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Required Payment</span>
                            <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                                <span id="target-payment">$0</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('target-payment', this)">Copy</button>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Interest</span>
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="target-interest">$0</span>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Paid</span>
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="target-total">$0</span>
                        </div>
                    </div>
                </div>

                <!-- Minimum Payment Scenario -->
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" id="scenario-min">
                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Minimum Payment</h2>
                    </div>

                    <div class="inputs">
                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="min-percent">Min Payment %</label>
                            <div class="relative flex items-center">
                                <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                                <input type="number" id="min-percent" value="2" min="1" step="0.5" max="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                            </div>
                        </div>
                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="min-floor">Min Payment Floor</label>
                            <div class="relative flex items-center">
                                <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                <input type="number" id="min-floor" value="25" min="0" step="5" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                            </div>
                        </div>
                    </div>

                    <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                        <div class="result-item result-highlight">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Time to Payoff</span>
                            <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                                <span id="min-months">0</span>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Interest</span>
                            <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                                <span id="min-interest">$0</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('min-interest', this)">Copy</button>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Paid</span>
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="min-total">$0</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-12 mb-16">
                <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">How to Pay Off Credit Card Debt Faster</h2>
                <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Credit card debt can be notoriously difficult to pay off because of high compound interest rates. Making only the minimum payment each month is the most expensive and slowest way to eliminate your debt, often keeping you trapped in a cycle of debt for decades. By increasing your monthly payments even slightly, you can drastically cut down both the time it takes to become debt-free and the amount of interest you will pay.</p>

                <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">The Danger of Minimum Payments</h2>
                <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Credit card companies usually set your minimum payment to be a tiny percentage of your overall balance, typically between 1% and 3%, or a flat minimum floor (like $25 or $35). This means the majority of your payment goes towards the interest, and only a fraction actually reduces the principal balance. The lower your balance gets, the lower the minimum payment required becomes, which artificially stretches out your payoff timeline.</p>

                <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Choosing the Right Strategy</h2>
                <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                    <li><strong>Fixed Monthly Payment:</strong> Decide on a set amount that you can comfortably afford, ideally significantly more than your minimum, and pay that exact amount every single month until the balance is zero.</li>
                    <li><strong>Target Payoff Goal:</strong> Choose a specific date or number of months by which you want to be completely debt-free. Our calculator determines the optimal, fixed monthly payment required to hit that exact target, taking interest into account.</li>
                    <li><strong>Snowball or Avalanche Methods:</strong> If you have multiple cards, you can focus extra payments on the smallest balance first for a psychological win (Debt Snowball), or focus on the card with the highest interest rate to save the most money mathematically (Debt Avalanche).</li>
                </ul>
            </div>
        </main>
        
    </div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            minimumFractionDigits: 0,
            maximumFractionDigits: 2
        }).format(value);
    };

    // Format months to readable string (e.g., "2 yrs 4 mos")
    const formatMonths = (months) => {
        if (!isFinite(months) || months <= 0) return "Never";
        const yrs = Math.floor(months / 12);
        const mos = Math.ceil(months % 12);

        let result = [];
        if (yrs > 0) result.push(`${yrs} yr${yrs !== 1 ? 's' : ''}`);
        if (mos > 0 || yrs === 0) result.push(`${mos} mo${mos !== 1 ? 's' : ''}`);

        return result.join(' ');
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const calculateFixedPayment = (balance, apr, payment) => {
        const monthlyRate = (apr / 100) / 12;
        let currentBalance = balance;
        let months = 0;
        let totalInterest = 0;

        // If payment is less than the first month's interest, it will never be paid off
        if (payment <= balance * monthlyRate) {
            return { months: Infinity, interest: Infinity, total: Infinity, valid: false };
        }

        while (currentBalance > 0 && months < 1200) { // cap at 100 years
            const interest = currentBalance * monthlyRate;
            totalInterest += interest;

            let principalPaid = payment - interest;
            if (principalPaid > currentBalance) {
                principalPaid = currentBalance;
            }

            currentBalance -= principalPaid;
            months++;
        }

        return { months, interest: totalInterest, total: balance + totalInterest, valid: true };
    };

    const calculateTargetPayoff = (balance, apr, targetMonths) => {
        const monthlyRate = (apr / 100) / 12;

        // PMT formula: P = (r * PV) / (1 - (1 + r)^-n)
        let payment;
        if (monthlyRate === 0) {
            payment = balance / targetMonths;
        } else {
            payment = (monthlyRate * balance) / (1 - Math.pow(1 + monthlyRate, -targetMonths));
        }

        const totalPaid = payment * targetMonths;
        const totalInterest = totalPaid - balance;

        return { payment, interest: totalInterest, total: totalPaid };
    };

    const calculateMinimumPayment = (balance, apr, minPercent, minFloor) => {
        const monthlyRate = (apr / 100) / 12;
        const minRate = minPercent / 100;

        let currentBalance = balance;
        let months = 0;
        let totalInterest = 0;
        let totalPaid = 0;

        // Failsafe: if min payment is always less than interest, infinite loop
        // Standard credit card rules usually make min payment = interest + 1% of principal if higher
        // We'll use max(balance * minRate, minFloor)

        while (currentBalance > 0 && months < 1200) { // cap at 100 years
            const interest = currentBalance * monthlyRate;
            totalInterest += interest;

            let payment = Math.max(currentBalance * minRate, minFloor);

            // If payment is less than interest, debt will grow
            if (payment <= interest) {
                // Often minimum payment includes all interest plus 1%
                payment = interest + (currentBalance * 0.01);
                if (payment < minFloor) payment = minFloor;
            }

            if (payment > currentBalance + interest) {
                payment = currentBalance + interest;
            }

            totalPaid += payment;
            currentBalance -= (payment - interest);
            months++;
        }

        return { months, interest: totalInterest, total: totalPaid };
    };

    const updateCalculator = () => {
        const balance = parseFloat(document.getElementById('balance').value) || 0;
        const apr = parseFloat(document.getElementById('rate').value) || 0;

        if (balance <= 0) return;

        // 1. Fixed Payment Scenario
        const fixedPayment = parseFloat(document.getElementById('fixed-payment').value) || 0;
        const fixedRes = calculateFixedPayment(balance, apr, fixedPayment);

        const fixedError = document.getElementById('fixed-error');
        if (!fixedRes.valid) {
            fixedError.style.display = 'block';
            document.getElementById('fixed-months').innerText = "Never";
            document.getElementById('fixed-interest').innerText = "Infinity";
            document.getElementById('fixed-total').innerText = "Infinity";
        } else {
            fixedError.style.display = 'none';
            document.getElementById('fixed-months').innerText = formatMonths(fixedRes.months);
            document.getElementById('fixed-interest').innerText = formatCurrency(fixedRes.interest);
            document.getElementById('fixed-total').innerText = formatCurrency(fixedRes.total);
        }

        // 2. Target Payoff Scenario
        const targetMonths = parseInt(document.getElementById('target-months').value) || 1;
        const targetRes = calculateTargetPayoff(balance, apr, targetMonths);

        document.getElementById('target-payment').innerText = formatCurrency(targetRes.payment);
        document.getElementById('target-interest').innerText = formatCurrency(targetRes.interest);
        document.getElementById('target-total').innerText = formatCurrency(targetRes.total);

        // 3. Minimum Payment Scenario
        const minPercent = parseFloat(document.getElementById('min-percent').value) || 0;
        const minFloor = parseFloat(document.getElementById('min-floor').value) || 0;
        const minRes = calculateMinimumPayment(balance, apr, minPercent, minFloor);

        document.getElementById('min-months').innerText = formatMonths(minRes.months);
        document.getElementById('min-interest').innerText = formatCurrency(minRes.interest);
        document.getElementById('min-total').innerText = formatCurrency(minRes.total);
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"]');
    inputs.forEach(input => {
        input.addEventListener('input', updateCalculator);
    });

    // Initial calculation
    updateCalculator();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-debt-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">How to Get Out of Debt: The Complete Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
