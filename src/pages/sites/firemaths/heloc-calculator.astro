---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'HELOC Calculator | Firemaths',
  description: 'Calculate your Home Equity Line of Credit (HELOC). Estimate available equity, maximum loan amount, and projected monthly payments for draw and repayment periods.',
  category: 'tool',
  keywords: ['heloc calculator', 'home equity line of credit', 'home equity calculator', 'heloc payment calculator', 'heloc rates', 'LTV calculator']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "firemaths.info" },
    "publisher": { "@type": "Organization", "name": "firemaths.info" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much of a HELOC can I get?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most lenders allow you to borrow up to 80% or 85% of your home's appraised value, minus what you currently owe on your primary mortgage. This calculator uses a standard 80% Loan-to-Value (LTV) ratio to estimate your available credit." }
      },
      {
        "@type": "Question",
        "name": "What is the difference between the draw period and repayment period?",
        "acceptedAnswer": { "@type": "Answer", "text": "The draw period (typically 5-10 years) is when you can borrow money from your HELOC, and you usually only have to make interest payments. The repayment period (typically 10-20 years) follows, during which you can no longer borrow, and your payments include both principal and interest to pay off the balance." }
      },
      {
        "@type": "Question",
        "name": "Is a HELOC better than a home equity loan?",
        "acceptedAnswer": { "@type": "Answer", "text": "A HELOC offers flexibility, allowing you to borrow only what you need when you need it, often with a variable rate. A home equity loan provides a lump sum upfront with a fixed interest rate and fixed monthly payments. The better choice depends on whether you have a specific, immediate expense or ongoing financing needs." }
      },
      {
        "@type": "Question",
        "name": "How is a HELOC monthly payment calculated?",
        "acceptedAnswer": { "@type": "Answer", "text": "During the draw period, your minimum payment is typically just the interest on the amount you've borrowed. During the repayment period, your payment is calculated to fully amortize (pay off) the outstanding balance over the remaining term, including both principal and interest." }
      },
      {
        "@type": "Question",
        "name": "What does LTV mean in a HELOC?",
        "acceptedAnswer": { "@type": "Answer", "text": "LTV stands for Loan-to-Value ratio. It compares the total amount of debt secured by your home (including your primary mortgage and the potential HELOC) to the home's appraised value. Lenders use it to determine your risk and maximum credit limit." }
      }
    ]
  }
]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <style is:inline>
    /* Scoped CSS using standard variables */
    .heloc-hero {
      background: var(--bg-primary);
      padding: 4rem 2rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
      margin-bottom: 2rem;
    }
    .heloc-hero-badge {
      display: inline-block;
      background: var(--accent-color);
      color: #fff;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .heloc-hero h1 {
      font-size: 2.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
      line-height: 1.2;
    }
    .heloc-hero p {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 800px;
      margin: 0 auto 2rem;
    }
    .heloc-hero-stats {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .heloc-stat {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      min-width: 200px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .heloc-stat-num {
      display: block;
      font-size: 2rem;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 0.5rem;
    }
    .heloc-stat-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .heloc-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .heloc-calc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 4rem;
    }
    @media (max-width: 768px) {
      .heloc-calc-grid {
        grid-template-columns: 1fr;
      }
    }

    .heloc-panel {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .heloc-panel h2 {
      margin-top: 0;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
      font-size: 1.5rem;
    }

    .heloc-input-group {
      margin-bottom: 1.5rem;
    }
    .heloc-input-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      font-weight: 500;
    }
    .heloc-input-group .help-text {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
      display: block;
    }
    .heloc-input-wrap {
      display: flex;
      align-items: center;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .heloc-input-wrap:focus-within {
      border-color: var(--accent-color);
    }
    .heloc-input-prefix, .heloc-input-suffix {
      padding: 0.75rem 1rem;
      color: var(--text-secondary);
      background: var(--bg-primary);
      border-right: 1px solid var(--border-color);
    }
    .heloc-input-suffix {
      border-right: none;
      border-left: 1px solid var(--border-color);
    }
    .heloc-input-wrap input, .heloc-input-wrap select {
      flex: 1;
      border: none;
      padding: 0.75rem 1rem;
      background: transparent;
      color: var(--text-primary);
      font-size: 1rem;
      width: 100%;
      outline: none;
    }

    .heloc-btn {
      width: 100%;
      background: var(--accent-color);
      color: #fff;
      border: none;
      padding: 1rem;
      border-radius: 8px;
      font-size: 1.125rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .heloc-btn:hover {
      opacity: 0.9;
    }

    /* Results Visualization */
    .heloc-results-header {
      text-align: center;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border-color);
    }
    .heloc-results-amount {
      font-size: 3rem;
      font-weight: 700;
      color: var(--accent-color);
      line-height: 1;
      margin: 0.5rem 0;
    }

    .heloc-chart-container {
      margin: 2rem 0;
    }
    .heloc-bar-chart {
      height: 40px;
      width: 100%;
      background: var(--bg-primary);
      border-radius: 20px;
      overflow: hidden;
      display: flex;
      border: 1px solid var(--border-color);
      margin-bottom: 1rem;
    }
    .heloc-bar-mortgage {
      background: #64748b; /* Slate 500 */
      height: 100%;
      transition: width 0.5s ease;
    }
    .heloc-bar-heloc {
      background: var(--accent-color);
      height: 100%;
      transition: width 0.5s ease;
    }
    .heloc-bar-equity {
      background: #10b981; /* Emerald 500 */
      height: 100%;
      transition: width 0.5s ease;
    }

    .heloc-legend {
      display: flex;
      justify-content: space-between;
      font-size: 0.875rem;
      color: var(--text-secondary);
      flex-wrap: wrap;
      gap: 1rem;
    }
    .heloc-legend-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .heloc-legend-color {
      width: 12px;
      height: 12px;
      border-radius: 3px;
    }

    .heloc-breakdown {
      margin-top: 2rem;
    }
    .heloc-breakdown-row {
      display: flex;
      justify-content: space-between;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border-color);
    }
    .heloc-breakdown-row:last-child {
      border-bottom: none;
    }
    .heloc-breakdown-label {
      color: var(--text-secondary);
      font-weight: 500;
    }
    .heloc-breakdown-val {
      color: var(--text-primary);
      font-weight: 600;
    }
    .heloc-highlight {
      color: var(--accent-color);
      font-size: 1.125rem;
    }

    /* Educational Section */
    .heloc-edu-section {
      margin: 4rem 0;
    }
    .heloc-edu-title {
      text-align: center;
      font-size: 2rem;
      color: var(--text-primary);
      margin-bottom: 2rem;
    }
    .heloc-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }
    .heloc-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .heloc-card h3 {
      color: var(--accent-color);
      margin-top: 0;
      margin-bottom: 1rem;
    }
    .heloc-card p {
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 0;
    }

    /* Comparison Table */
    .heloc-table-wrapper {
      overflow-x: auto;
      margin: 2rem 0;
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }
    .heloc-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    .heloc-table th, .heloc-table td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-color);
    }
    .heloc-table th {
      background: var(--bg-primary);
      color: var(--text-primary);
      font-weight: 600;
    }
    .heloc-table tr:last-child td {
      border-bottom: none;
    }
    .heloc-table td {
      color: var(--text-secondary);
    }

    /* FAQ Section */
    .heloc-faq {
      margin: 4rem 0;
    }
    .heloc-faq-item {
      border-bottom: 1px solid var(--border-color);
      padding: 1.5rem 0;
    }
    .heloc-faq-q {
      font-size: 1.25rem;
      color: var(--text-primary);
      font-weight: 600;
      margin: 0 0 0.5rem 0;
    }
    .heloc-faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    /* Related Links */
    .heloc-related {
      margin: 4rem 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
    }
    .heloc-related-list {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      list-style: none;
      padding: 0;
    }
    .heloc-related-list a {
      display: inline-block;
      padding: 0.5rem 1rem;
      background: var(--bg-primary);
      color: var(--accent-color);
      text-decoration: none;
      border-radius: 999px;
      border: 1px solid var(--border-color);
      transition: all 0.2s;
    }
    .heloc-related-list a:hover {
      background: var(--accent-color);
      color: #fff;
    }

    .heloc-error {
      color: #ef4444; /* Red 500 */
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
    }
  </style>

  <!-- HERO -->
  <section class="heloc-hero">
    <div class="heloc-hero-badge">Interactive Calculator</div>
    <h1>Unlock Your Home's Equity</h1>
    <p>Calculate your available equity, maximum HELOC amount, and projected monthly payments instantly. Understand the true cost before you borrow.</p>
    <div class="heloc-hero-stats">
      <div class="heloc-stat">
        <span class="heloc-stat-num" id="hero-equity">$0</span>
        <span class="heloc-stat-label">Available Equity</span>
      </div>
      <div class="heloc-stat">
        <span class="heloc-stat-num" id="hero-draw-pay">$0</span>
        <span class="heloc-stat-label">Est. Draw Payment</span>
      </div>
      <div class="heloc-stat">
        <span class="heloc-stat-num" id="hero-repay-pay">$0</span>
        <span class="heloc-stat-label">Est. Repay Payment</span>
      </div>
    </div>
  </section>

  <div class="heloc-container">
    <!-- CALCULATOR APP -->
    <div class="heloc-calc-grid">
      <!-- Input Panel -->
      <div class="heloc-panel">
        <h2>Property Details</h2>

        <div class="heloc-input-group">
          <label for="heloc-home-value">Current Home Value</label>
          <span class="help-text">Estimated market value of your property</span>
          <div class="heloc-input-wrap">
            <span class="heloc-input-prefix">$</span>
            <input type="number" id="heloc-home-value" value="500000" min="50000" max="10000000" step="10000" />
          </div>
          <div id="error-home-value" class="heloc-error">Home value must be greater than zero.</div>
        </div>

        <div class="heloc-input-group">
          <label for="heloc-mortgage-bal">Current Mortgage Balance</label>
          <span class="help-text">Amount you currently owe on your primary mortgage</span>
          <div class="heloc-input-wrap">
            <span class="heloc-input-prefix">$</span>
            <input type="number" id="heloc-mortgage-bal" value="300000" min="0" max="10000000" step="5000" />
          </div>
          <div id="error-mortgage-bal" class="heloc-error">Mortgage balance cannot exceed home value.</div>
        </div>

        <div class="heloc-input-group">
          <label for="heloc-ltv">Max Loan-to-Value (LTV)</label>
          <span class="help-text">Most lenders cap total debt at 80% or 85% of home value</span>
          <div class="heloc-input-wrap">
            <input type="number" id="heloc-ltv" value="80" min="50" max="100" step="1" />
            <span class="heloc-input-suffix">%</span>
          </div>
        </div>

        <div class="heloc-input-group">
          <label for="heloc-credit-score">Credit Score Range</label>
          <div class="heloc-input-wrap">
            <select id="heloc-credit-score">
              <option value="760">Excellent (760+)</option>
              <option value="700">Good (700 - 759)</option>
              <option value="660">Fair (660 - 699)</option>
              <option value="620">Poor (Below 660)</option>
            </select>
          </div>
        </div>

        <hr style="border:0; border-top:1px solid var(--border-color); margin: 2rem 0;"/>
        <h2>HELOC Details</h2>

        <div class="heloc-input-group">
          <label for="heloc-draw-amt">Initial Draw Amount</label>
          <span class="help-text">Amount you plan to borrow immediately</span>
          <div class="heloc-input-wrap">
            <span class="heloc-input-prefix">$</span>
            <input type="number" id="heloc-draw-amt" value="50000" min="0" step="1000" />
          </div>
          <div id="error-draw-amt" class="heloc-error">Draw amount cannot exceed max HELOC limit.</div>
        </div>

        <div class="heloc-input-group">
          <label for="heloc-rate">Estimated Interest Rate</label>
          <span class="help-text">Estimated based on prime rate + margin</span>
          <div class="heloc-input-wrap">
            <input type="number" id="heloc-rate" value="8.5" min="1" max="25" step="0.1" />
            <span class="heloc-input-suffix">%</span>
          </div>
        </div>

        <div class="heloc-input-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="heloc-input-group">
            <label for="heloc-draw-period">Draw Period</label>
            <div class="heloc-input-wrap">
              <select id="heloc-draw-period">
                <option value="5">5 Years</option>
                <option value="10" selected>10 Years</option>
                <option value="15">15 Years</option>
              </select>
            </div>
          </div>
          <div class="heloc-input-group">
            <label for="heloc-repay-period">Repayment Period</label>
            <div class="heloc-input-wrap">
              <select id="heloc-repay-period">
                <option value="10">10 Years</option>
                <option value="15">15 Years</option>
                <option value="20" selected>20 Years</option>
              </select>
            </div>
          </div>
        </div>

        <button id="btn-calculate" class="heloc-btn">Calculate Your Equity</button>
      </div>

      <!-- Results Panel -->
      <div class="heloc-panel">
        <div class="heloc-results-header">
          <div style="color: var(--text-secondary); text-transform: uppercase; font-size: 0.875rem; letter-spacing: 0.05em;">Maximum HELOC Amount</div>
          <div class="heloc-results-amount" id="res-max-heloc">$100,000</div>
          <div style="color: var(--text-secondary); font-size: 0.875rem;">Based on 80% LTV limit</div>
        </div>

        <div class="heloc-chart-container">
          <div style="margin-bottom: 0.5rem; font-weight: 500; color: var(--text-primary);">Home Equity Breakdown</div>
          <div class="heloc-bar-chart" id="equity-chart">
            <div class="heloc-bar-mortgage" id="bar-mortgage" style="width: 60%;"></div>
            <div class="heloc-bar-heloc" id="bar-heloc" style="width: 20%;"></div>
            <div class="heloc-bar-equity" id="bar-equity" style="width: 20%;"></div>
          </div>
          <div class="heloc-legend">
            <div class="heloc-legend-item">
              <div class="heloc-legend-color" style="background: #64748b;"></div>
              <span id="leg-mortgage">Mortgage (60%)</span>
            </div>
            <div class="heloc-legend-item">
              <div class="heloc-legend-color" style="background: var(--accent-color);"></div>
              <span id="leg-heloc">Max HELOC (20%)</span>
            </div>
            <div class="heloc-legend-item">
              <div class="heloc-legend-color" style="background: #10b981;"></div>
              <span id="leg-equity">Untapped Equity (20%)</span>
            </div>
          </div>
        </div>

        <div class="heloc-breakdown">
          <h3>Equity Calculation</h3>
          <div class="heloc-breakdown-row">
            <span class="heloc-breakdown-label">Home Value</span>
            <span class="heloc-breakdown-val" id="res-home-val">$500,000</span>
          </div>
          <div class="heloc-breakdown-row">
            <span class="heloc-breakdown-label">Max Allowed Debt (<span id="res-ltv-label">80%</span> LTV)</span>
            <span class="heloc-breakdown-val" id="res-max-debt">$400,000</span>
          </div>
          <div class="heloc-breakdown-row">
            <span class="heloc-breakdown-label">Less Current Mortgage</span>
            <span class="heloc-breakdown-val" id="res-mortgage">-$300,000</span>
          </div>
          <div class="heloc-breakdown-row">
            <span class="heloc-breakdown-label heloc-highlight">Available Line of Credit</span>
            <span class="heloc-breakdown-val heloc-highlight" id="res-available">$100,000</span>
          </div>
        </div>

        <div class="heloc-breakdown" style="margin-top: 3rem;">
          <h3>Estimated Payments (Based on <span id="res-draw-amount">$50,000</span> Draw)</h3>

          <div class="heloc-breakdown-row">
            <div>
              <div class="heloc-breakdown-label" style="color: var(--text-primary); font-weight: 600;">Draw Period Payment (Interest Only)</div>
              <div style="font-size: 0.875rem; color: var(--text-secondary);">For the first <span id="res-draw-years">10</span> years</div>
            </div>
            <span class="heloc-breakdown-val heloc-highlight" style="font-size: 1.5rem;" id="res-payment-draw">$354/mo</span>
          </div>

          <div class="heloc-breakdown-row">
            <div>
              <div class="heloc-breakdown-label" style="color: var(--text-primary); font-weight: 600;">Repayment Period Payment</div>
              <div style="font-size: 0.875rem; color: var(--text-secondary);">For the final <span id="res-repay-years">20</span> years (Principal + Interest)</div>
            </div>
            <span class="heloc-breakdown-val heloc-highlight" style="font-size: 1.5rem;" id="res-payment-repay">$434/mo</span>
          </div>
        </div>

      </div>
    </div>

    <!-- EDUCATIONAL CONTENT -->
