  <script is:inline>
    // Formatting Helpers
    function formatCurrency(num) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(num);
    }

    function formatCurrencyWithCents(num) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(num);
    }

    // Calculation Logic
    function calculateHELOC() {
      // 1. Get Inputs
      const homeValue = parseFloat(document.getElementById('heloc-home-value').value) || 0;
      const mortgageBal = parseFloat(document.getElementById('heloc-mortgage-bal').value) || 0;
      const ltvLimit = parseFloat(document.getElementById('heloc-ltv').value) / 100 || 0.8;
      let drawAmount = parseFloat(document.getElementById('heloc-draw-amt').value) || 0;
      const creditScore = document.getElementById('heloc-credit-score').value;

      // Auto-adjust rate based on credit score if rate hasn't been manually changed much
      const rateInput = document.getElementById('heloc-rate');
      let rate = parseFloat(rateInput.value) || 8.5;

      const drawYears = parseInt(document.getElementById('heloc-draw-period').value) || 10;
      const repayYears = parseInt(document.getElementById('heloc-repay-period').value) || 20;

      // Reset Errors
      document.getElementById('error-home-value').style.display = 'none';
      document.getElementById('error-mortgage-bal').style.display = 'none';
      document.getElementById('error-draw-amt').style.display = 'none';

      // Validation
      let hasError = false;
      if (homeValue <= 0) {
        document.getElementById('error-home-value').style.display = 'block';
        hasError = true;
      }
      if (mortgageBal > homeValue) {
        document.getElementById('error-mortgage-bal').style.display = 'block';
        hasError = true;
      }

      // 2. Core Calculations
      const maxTotalDebt = homeValue * ltvLimit;
      const maxHeloc = Math.max(0, maxTotalDebt - mortgageBal);

      if (drawAmount > maxHeloc) {
        document.getElementById('error-draw-amt').style.display = 'block';
        // Cap draw amount for calculations to prevent crazy numbers
        drawAmount = maxHeloc;
      }

      // Calculate Payments
      const monthlyRate = (rate / 100) / 12;

      // Draw Period (Interest Only)
      const drawPayment = drawAmount * monthlyRate;

      // Repayment Period (Amortized P&I)
      const repayMonths = repayYears * 12;
      let repayPayment = 0;
      if (monthlyRate > 0) {
        repayPayment = drawAmount * (monthlyRate * Math.pow(1 + monthlyRate, repayMonths)) / (Math.pow(1 + monthlyRate, repayMonths) - 1);
      } else {
        repayPayment = drawAmount / repayMonths;
      }

      // 3. Update DOM - Numbers
      if (!hasError) {
        // Hero
        document.getElementById('hero-equity').textContent = formatCurrency(maxHeloc);
        document.getElementById('hero-draw-pay').textContent = formatCurrency(drawPayment) + '/mo';
        document.getElementById('hero-repay-pay').textContent = formatCurrency(repayPayment) + '/mo';

        // Details Panel
        document.getElementById('res-max-heloc').textContent = formatCurrency(maxHeloc);
        document.getElementById('res-home-val').textContent = formatCurrency(homeValue);
        document.getElementById('res-ltv-label').textContent = (ltvLimit * 100).toFixed(0) + '%';
        document.getElementById('res-max-debt').textContent = formatCurrency(maxTotalDebt);
        document.getElementById('res-mortgage').textContent = '-' + formatCurrency(mortgageBal);
        document.getElementById('res-available').textContent = formatCurrency(maxHeloc);

        // Payment Panel
        document.getElementById('res-draw-amount').textContent = formatCurrency(drawAmount);
        document.getElementById('res-draw-years').textContent = drawYears;
        document.getElementById('res-repay-years').textContent = repayYears;
        document.getElementById('res-payment-draw').textContent = formatCurrencyWithCents(drawPayment) + '/mo';
        document.getElementById('res-payment-repay').textContent = formatCurrencyWithCents(repayPayment) + '/mo';

        // 4. Update DOM - Chart
        const pctMortgage = (mortgageBal / homeValue) * 100;
        const pctHeloc = (maxHeloc / homeValue) * 100;
        const pctUntapped = 100 - pctMortgage - pctHeloc;

        document.getElementById('bar-mortgage').style.width = pctMortgage + '%';
        document.getElementById('bar-heloc').style.width = pctHeloc + '%';
        document.getElementById('bar-equity').style.width = pctUntapped + '%';

        document.getElementById('leg-mortgage').textContent = 'Mortgage (' + pctMortgage.toFixed(1) + '%)';
        document.getElementById('leg-heloc').textContent = 'Max HELOC (' + pctHeloc.toFixed(1) + '%)';
        document.getElementById('leg-equity').textContent = 'Untapped (' + pctUntapped.toFixed(1) + '%)';
      }
    }

    // Dynamic Rate Adjustment based on Credit Score (Simple Simulation)
    document.getElementById('heloc-credit-score').addEventListener('change', function(e) {
      const score = parseInt(e.target.value);
      const rateInput = document.getElementById('heloc-rate');

      // Base Prime Rate assumption (e.g., 8.5%)
      let baseRate = 8.5;

      if (score >= 760) rateInput.value = baseRate.toFixed(2);
      else if (score >= 700) rateInput.value = (baseRate + 0.5).toFixed(2);
      else if (score >= 660) rateInput.value = (baseRate + 1.5).toFixed(2);
      else rateInput.value = (baseRate + 3.0).toFixed(2);

      calculateHELOC();
    });

    // Event Listeners
    const inputs = document.querySelectorAll('.heloc-input-wrap input, .heloc-input-wrap select');
    inputs.forEach(input => {
      input.addEventListener('input', calculateHELOC);
      input.addEventListener('change', calculateHELOC);
    });

    document.getElementById('btn-calculate').addEventListener('click', calculateHELOC);

    // Initial calculation on load
    window.addEventListener('DOMContentLoaded', calculateHELOC);

  </script>
