---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Emergency Fund Calculator",
  "url": "https://firemaths.info/emergency-fund-calculator.html",
  "description": "Calculate your ideal emergency fund based on your monthly expenses, job stability, health, and dependents.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Emergency Fund Calculator: How Much Do You Actually Need?"
  description="Most people save thousands more than they actually need. Find out exactly how much your lifestyle requires with our emergency fund calculator and stop wasting potential returns."
  canonical="https://firemaths.info/emergency-fund-calculator.html" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
        

        <main>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
                <!-- Left Column: Inputs -->
                <div>
                    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                        <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Monthly Essential Expenses</h2>
                            <div class="total-display" id="total-expenses">$0</div>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="housing">Housing (Rent/Mortgage)</label>
                            <div class="input-row">
                                <input type="range" id="housing-slider" min="0" max="5000" step="50" value="1500" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 expense-slider font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                                <div class="relative flex items-center">
                                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                    <input type="number" id="housing-number" min="0" step="50" value="1500" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="food">Food & Groceries</label>
                            <div class="input-row">
                                <input type="range" id="food-slider" min="0" max="2000" step="10" value="400" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 expense-slider font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                                <div class="relative flex items-center">
                                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                    <input type="number" id="food-number" min="0" step="10" value="400" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="utilities">Utilities & Internet</label>
                            <div class="input-row">
                                <input type="range" id="utilities-slider" min="0" max="1000" step="10" value="200" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 expense-slider font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                                <div class="relative flex items-center">
                                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                    <input type="number" id="utilities-number" min="0" step="10" value="200" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="transport">Transportation</label>
                            <div class="input-row">
                                <input type="range" id="transport-slider" min="0" max="1500" step="10" value="300" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 expense-slider font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                                <div class="relative flex items-center">
                                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                    <input type="number" id="transport-number" min="0" step="10" value="300" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="insurance">Insurance & Healthcare</label>
                            <div class="input-row">
                                <input type="range" id="insurance-slider" min="0" max="1500" step="10" value="250" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 expense-slider font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                                <div class="relative flex items-center">
                                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                    <input type="number" id="insurance-number" min="0" step="10" value="250" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="debt">Minimum Debt Payments</label>
                            <div class="input-row">
                                <input type="range" id="debt-slider" min="0" max="3000" step="10" value="200" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 expense-slider font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                                <div class="relative flex items-center">
                                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                    <input type="number" id="debt-number" min="0" step="10" value="200" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors expense-number">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                        <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Risk Factors & Savings</h2>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="job-stability">Job Stability</label>
                            <select id="job-stability" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base risk-input transition-colors">
                                <option value="stable">Stable / Secure Salary</option>
                                <option value="freelance">Freelance / Contractor / Commission</option>
                                <option value="seasonal">Seasonal / Highly Volatile</option>
                            </select>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="dependents">Dependents</label>
                            <select id="dependents" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base risk-input transition-colors">
                                <option value="0">0 (Single/No Dependents)</option>
                                <option value="1">1 or more (Children, Spouse, etc.)</option>
                            </select>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="health">Health & Medical Risks</label>
                            <select id="health" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base risk-input transition-colors">
                                <option value="good">Good Health / Low Expected Costs</option>
                                <option value="chronic">Chronic Condition / High Expected Costs</option>
                            </select>
                        </div>

                        <div class="mb-5" style="margin-top: 2rem;">
                            <label for="current-savings">Current Emergency Fund Savings</label>
                            <div class="input-row" style="max-width: 250px;">
                                <div class="relative flex items-center" style="width: 100%;">
                                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                    <input type="number" id="current-savings" min="0" step="100" value="2500" style="width: 100%;" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 savings-input font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Results -->
                <div>
                    <div class="card results-section" style="position: sticky; top: 5rem;">
                        <div class="target-card recommended">
                            <div class="target-label">Recommended Target (<span id="rec-months">6</span> Months)</div>
                            <div class="target-value" id="rec-target">$0</div>
                            <div style="font-size: 0.85rem; color: var(--text-secondary);" id="rec-reasoning">Based on your risk profile</div>
                        </div>

                        <div class="target-card">
                            <div class="target-label">3 Months (Minimum Base)</div>
                            <div class="target-value">
                                <span id="target-3">$0</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('target-3', this)">Copy</button>
                            </div>
                        </div>

                        <div class="target-card">
                            <div class="target-label">6 Months (Standard Safe)</div>
                            <div class="target-value">
                                <span id="target-6">$0</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('target-6', this)">Copy</button>
                            </div>
                        </div>

                        <div class="target-card">
                            <div class="target-label">12 Months (Conservative)</div>
                            <div class="target-value">
                                <span id="target-12">$0</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('target-12', this)">Copy</button>
                            </div>
                        </div>

                        <div class="progress-container">
                            <div class="progress-header">
                                <span>Savings Progress</span>
                                <span id="progress-percent" style="color: var(--accent-color); font-weight: 600;">0%</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill" id="progress-fill"></div>
                            </div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); font-family: var(--font-mono);">
                                <span id="progress-current">$0</span>
                                <span id="progress-goal">$0</span>
                            </div>
                            <div style="margin-top: 1rem; font-size: 0.875rem; text-align: center; color: var(--text-secondary);" id="progress-message">
                                Keep saving! You have $X left to reach your goal.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Content Sections -->
            <div class="content-section">
                <h2>Where to keep it: Comparing High-Yield Savings Accounts (HYSA)</h2>
                <p>Your emergency fund must be completely liquid and protected from market drops. Do not invest this money in the stock market. The standard recommendation is to hold these funds in a High-Yield Savings Account (HYSA). Unlike traditional bank accounts paying 0.01%, HYSAs often pay 4% to 5% APY, helping your cash keep pace with inflation.</p>

                <table class="hysa-table">
                    <thead class="bg-[var(--card-bg)] border-b border-[var(--border-color)]">
                        <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                            <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Account Type</th>
                            <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Average APY*</th>
                            <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Liquidity</th>
                            <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Risk</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                            <td class="p-4 text-white font-mono">High-Yield Savings (HYSA)</td>
                            <td class="p-4 text-white font-mono">~4.0% - 5.0%</td>
                            <td class="p-4 text-white font-mono">Immediate (1-3 days transfer)</td>
                            <td class="p-4 text-white font-mono">None (FDIC Insured)</td>
                        </tr>
                        <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                            <td class="p-4 text-white font-mono">Money Market Account (MMA)</td>
                            <td class="p-4 text-white font-mono">~4.0% - 5.2%</td>
                            <td class="p-4 text-white font-mono">Immediate (Often includes debit/checks)</td>
                            <td class="p-4 text-white font-mono">None (FDIC Insured)</td>
                        </tr>
                        <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                            <td class="p-4 text-white font-mono">No-Penalty CDs</td>
                            <td class="p-4 text-white font-mono">~4.5% - 5.0%</td>
                            <td class="p-4 text-white font-mono">High (Can withdraw after 7 days)</td>
                            <td class="p-4 text-white font-mono">None (FDIC Insured)</td>
                        </tr>
                        <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                            <td class="p-4 text-white font-mono">Traditional Bank Savings</td>
                            <td class="p-4 text-white font-mono">~0.01% - 0.4%</td>
                            <td class="p-4 text-white font-mono">Immediate</td>
                            <td class="p-4 text-white font-mono">None (FDIC Insured)</td>
                        </tr>
                    </tbody>
                </table>
                <p style="font-size: 0.8rem; opacity: 0.7;">*Rates fluctuate based on Federal Reserve benchmark rates. Check current rates with institutions directly.</p>
            </div>

            <div class="content-section">
                <h2>Emergency Fund FAQ</h2>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">What is an emergency fund calculator and how do I use it?</div>
                    <div class="faq-answer">An emergency fund calculator helps you determine the exact amount of cash you need to set aside to cover essential living expenses in case of a financial shock, such as a job loss or medical emergency. Enter your monthly essential expenses (like rent, food, and utilities) and adjust your personal risk factors to see your customized target.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">How much emergency fund do I need?</div>
                    <div class="faq-answer">The general rule of thumb is to save enough to cover 3 to 6 months of essential living expenses. However, the exact amount depends on your job stability, dependents, and health. Freelancers or individuals in volatile industries may need closer to 12 months of expenses saved.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">Should I save a 3 months vs 6 months emergency fund?</div>
                    <div class="faq-answer">A 3-month emergency fund is often sufficient for single individuals with highly secure jobs and low fixed costs. A 6-month fund is recommended for most people, particularly those with dependents, single-income households, or standard corporate jobs with average turnover risk.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">Where should I keep my emergency fund?</div>
                    <div class="faq-answer">Your emergency fund must be liquid and safe. The best places are High-Yield Savings Accounts (HYSA), Money Market Accounts, or No-Penalty CDs, which offer higher interest rates than traditional savings accounts while protecting your principal from market volatility.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">Does an emergency fund cover job loss or other expenses?</div>
                    <div class="faq-answer">Yes, the primary purpose of an emergency fund is to replace your income during a job loss. However, it also covers other sudden, unavoidable expenses such as major medical bills, emergency car repairs, or urgent home repairs (like a broken furnace or leaking roof).</div>
                </div>
            </div>
        </main>

        
    </div>
  <script is:inline>
// Formatting function
        const formatMoney = (amount) => {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(amount);
        };

        // Copy functionality
        window.copyValue = async (elementId, btn) => {
            const text = document.getElementById(elementId).innerText;
            try {
                await navigator.clipboard.writeText(text);
                const originalText = btn.innerText;
                btn.innerText = 'Copied!';
                setTimeout(() => { btn.innerText = originalText; }, 2000);
            } catch (err) {
                console.error('Failed to copy', err);
            }
        };

        // Sync inputs and calculate
        const categories = ['housing', 'food', 'utilities', 'transport', 'insurance', 'debt'];

        const calculate = () => {
            let totalMonthly = 0;

            // Sync logic and calculate sum
            categories.forEach(cat => {
                const numInput = document.getElementById(`${cat}-number`);
                const sliderInput = document.getElementById(`${cat}-slider`);

                // Keep values in sync handled by event listeners, here we just read
                let val = parseFloat(numInput.value) || 0;
                totalMonthly += val;
            });

            document.getElementById('total-expenses').innerText = formatMoney(totalMonthly);

            const target3 = totalMonthly * 3;
            const target6 = totalMonthly * 6;
            const target12 = totalMonthly * 12;

            document.getElementById('target-3').innerText = formatMoney(target3);
            document.getElementById('target-6').innerText = formatMoney(target6);
            document.getElementById('target-12').innerText = formatMoney(target12);

            // Calculate Recommended
            let recommendedMonths = 3;
            let reasoning = ["Base 3 months"];

            const job = document.getElementById('job-stability').value;
            const deps = document.getElementById('dependents').value;
            const health = document.getElementById('health').value;

            if (job === 'freelance') { recommendedMonths += 3; reasoning.push("+3 for variable income"); }
            if (job === 'seasonal') { recommendedMonths += 6; reasoning.push("+6 for high volatility"); }

            if (deps === '1') { recommendedMonths += 3; reasoning.push("+3 for dependents"); }

            if (health === 'chronic') { recommendedMonths += 3; reasoning.push("+3 for health risks"); }

            if (recommendedMonths > 12) recommendedMonths = 12;

            const recommendedTarget = totalMonthly * recommendedMonths;
            document.getElementById('rec-months').innerText = recommendedMonths;
            document.getElementById('rec-target').innerText = formatMoney(recommendedTarget);
            document.getElementById('rec-reasoning').innerText = reasoning.join(', ');

            // Progress tracking
            const currentSavings = parseFloat(document.getElementById('current-savings').value) || 0;

            let percent = 0;
            if (recommendedTarget > 0) {
                percent = Math.min(100, (currentSavings / recommendedTarget) * 100);
            } else if (currentSavings > 0) {
                percent = 100;
            }

            document.getElementById('progress-fill').style.width = `${percent}%`;
            document.getElementById('progress-percent').innerText = `${percent.toFixed(1)}%`;
            document.getElementById('progress-current').innerText = formatMoney(currentSavings);
            document.getElementById('progress-goal').innerText = formatMoney(recommendedTarget);

            const remaining = recommendedTarget - currentSavings;
            const msgEl = document.getElementById('progress-message');
            if (remaining > 0) {
                msgEl.innerText = `Keep saving! You have ${formatMoney(remaining)} left to reach your recommended goal.`;
                msgEl.style.color = "var(--text-secondary)";
            } else {
                msgEl.innerText = `Congratulations! Your emergency fund is fully funded based on your profile.`;
                msgEl.style.color = "var(--accent-color)";
            }
        };

        // Attach event listeners for syncing and calculating
        categories.forEach(cat => {
            const numInput = document.getElementById(`${cat}-number`);
            const sliderInput = document.getElementById(`${cat}-slider`);

            numInput.addEventListener('input', (e) => {
                sliderInput.value = e.target.value;
                calculate();
            });

            sliderInput.addEventListener('input', (e) => {
                numInput.value = e.target.value;
                calculate();
            });
        });

        const riskInputs = document.querySelectorAll('.risk-input, .savings-input');
        riskInputs.forEach(input => {
            input.addEventListener('change', calculate);
            input.addEventListener('input', calculate);
        });

        // Init
        calculate();
  </script>

