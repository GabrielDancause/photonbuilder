---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Emergency Fund Calculator",
  "url": "https://firemaths.info/emergency-fund-calculator",
  "description": "Calculate your ideal emergency fund based on your monthly expenses, job stability, health, and dependents.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

export const meta = {
  title: "Emergency Fund Calculator: How Much Do You Actually Need?",
  description: "Most people save thousands more than they actually need. Find out exactly how much your lifestyle requires with our emergency fund calculator and stop...",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="firemaths"
  title="Emergency Fund Calculator: How Much Do You Actually Need?"
  description="Most people save thousands more than they actually need. Find out exactly how much your lifestyle requires with our emergency fund calculator and stop."
  canonical="https://firemaths.info/emergency-fund-calculator" schema={schema}
>
  <style>

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: var(--font-ui);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, h4 {
            font-weight: 700;
            line-height: 1.2;
            color: var(--text-primary);
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 3rem 1.5rem;
        }

        header {
            text-align: center;
            margin-bottom: 3rem;
        }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            color: var(--accent-color);
        }

        header p {
            color: var(--text-secondary);
            font-size: 1.125rem;
        }

        .calculator-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
            margin-bottom: 4rem;
        }

        @media (min-width: 800px) {
            .calculator-grid {
                grid-template-columns: 1.2fr 1fr;
            }
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .card-header {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-header h2 {
            font-size: 1.25rem;
            color: var(--accent-color);
        }

        .total-display {
            font-family: var(--font-mono);
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .input-group {
            margin-bottom: 1.25rem;
        }

        .input-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-secondary);
        }

        .input-row {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        input[type="range"] {
            flex-grow: 1;
            -webkit-appearance: none;
            width: 100%;
            height: 6px;
            background: var(--border-color);
            border-radius: 3px;
            outline: none;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: var(--accent-color);
            cursor: pointer;
        }

        input[type="range"]::-moz-range-thumb {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: var(--accent-color);
            cursor: pointer;
            border: none;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            width: 120px;
            flex-shrink: 0;
        }

        .prefix {
            position: absolute;
            left: 0.75rem;
            color: var(--text-secondary);
            font-family: var(--font-mono);
        }

        input[type="number"], select {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            font-size: 0.9rem;
            padding: 0.5rem 0.5rem 0.5rem 1.75rem;
            border-radius: 6px;
            font-family: var(--font-mono);
            outline: none;
            transition: border-color 0.2s;
        }

        select {
            padding-left: 0.75rem;
            font-family: var(--font-ui);
            cursor: pointer;
        }

        input[type="number"]:focus, select:focus {
            border-color: var(--accent-color);
        }

        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .results-section {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .target-card {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .target-card.recommended {
            background-color: rgba(212, 160, 23, 0.05);
            border-color: var(--accent-color);
            flex-direction: column;
            align-items: center;
            padding: 1.5rem;
            text-align: center;
        }

        .target-card.recommended .target-label {
            color: var(--accent-color);
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .target-card.recommended .target-value {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
        }

        .target-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .target-value {
            font-family: var(--font-mono);
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .progress-container {
            margin-top: 1rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-color);
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .progress-bar-bg {
            width: 100%;
            height: 8px;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 0.5rem;
        }

        .progress-bar-fill {
            height: 100%;
            background-color: var(--accent-color);
            width: 0%;
            transition: width 0.3s ease;
        }

        .copy-btn {
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            cursor: pointer;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-family: var(--font-ui);
            transition: all 0.2s;
        }

        .copy-btn:hover {
            border-color: var(--accent-color);
            color: var(--text-primary);
        }

        .content-section {
            margin-top: 4rem;
        }

        .content-section h2 {
            font-size: 1.75rem;
            margin-bottom: 1rem;
            color: var(--accent-color);
        }

        .content-section h3 {
            font-size: 1.25rem;
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
        }

        .content-section p {
            margin-bottom: 1rem;
            color: var(--text-secondary);
        }

        .hysa-table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.5rem 0;
            font-size: 0.9rem;
        }

        .hysa-table th, .hysa-table td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .hysa-table th {
            color: var(--text-primary);
            font-weight: 600;
        }

        .hysa-table td {
            color: var(--text-secondary);
        }

        .faq-item {
            margin-bottom: 1.5rem;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.25rem;
        }

        .faq-question {
            font-weight: 600;
            font-size: 1.1rem;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .faq-answer {
            color: var(--text-secondary);
        }

        footer {
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 0.875rem;
            margin-top: 4rem;
        }

        .disclaimer {
            font-size: 0.75rem;
            margin-top: 0.5rem;
            opacity: 0.7;
        }
  </style>

<div class="container">
    <h1>Emergency Fund Calculator: How Much Do You Actually Need?</h1>

        <main>
            <div class="calculator-grid">
                <!-- Left Column: Inputs -->
                <div>
                    <div class="card">
                        <div class="card-header">
                            <h2>Monthly Essential Expenses</h2>
                            <div class="total-display" id="total-expenses">$0</div>
                        </div>

                        <div class="input-group">
                            <label for="housing">Housing (Rent/Mortgage)</label>
                            <div class="input-row">
                                <input type="range" id="housing-slider" min="0" max="5000" step="50" value="1500" class="expense-slider">
                                <div class="input-wrapper">
                                    <span class="prefix">$</span>
                                    <input type="number" id="housing-number" min="0" step="50" value="1500" class="expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="input-group">
                            <label for="food">Food & Groceries</label>
                            <div class="input-row">
                                <input type="range" id="food-slider" min="0" max="2000" step="10" value="400" class="expense-slider">
                                <div class="input-wrapper">
                                    <span class="prefix">$</span>
                                    <input type="number" id="food-number" min="0" step="10" value="400" class="expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="input-group">
                            <label for="utilities">Utilities & Internet</label>
                            <div class="input-row">
                                <input type="range" id="utilities-slider" min="0" max="1000" step="10" value="200" class="expense-slider">
                                <div class="input-wrapper">
                                    <span class="prefix">$</span>
                                    <input type="number" id="utilities-number" min="0" step="10" value="200" class="expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="input-group">
                            <label for="transport">Transportation</label>
                            <div class="input-row">
                                <input type="range" id="transport-slider" min="0" max="1500" step="10" value="300" class="expense-slider">
                                <div class="input-wrapper">
                                    <span class="prefix">$</span>
                                    <input type="number" id="transport-number" min="0" step="10" value="300" class="expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="input-group">
                            <label for="insurance">Insurance & Healthcare</label>
                            <div class="input-row">
                                <input type="range" id="insurance-slider" min="0" max="1500" step="10" value="250" class="expense-slider">
                                <div class="input-wrapper">
                                    <span class="prefix">$</span>
                                    <input type="number" id="insurance-number" min="0" step="10" value="250" class="expense-number">
                                </div>
                            </div>
                        </div>

                        <div class="input-group">
                            <label for="debt">Minimum Debt Payments</label>
                            <div class="input-row">
                                <input type="range" id="debt-slider" min="0" max="3000" step="10" value="200" class="expense-slider">
                                <div class="input-wrapper">
                                    <span class="prefix">$</span>
                                    <input type="number" id="debt-number" min="0" step="10" value="200" class="expense-number">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h2>Risk Factors & Savings</h2>
                        </div>

                        <div class="input-group">
                            <label for="job-stability">Job Stability</label>
                            <select id="job-stability" class="risk-input">
                                <option value="stable">Stable / Secure Salary</option>
                                <option value="freelance">Freelance / Contractor / Commission</option>
                                <option value="seasonal">Seasonal / Highly Volatile</option>
                            </select>
                        </div>

                        <div class="input-group">
                            <label for="dependents">Dependents</label>
                            <select id="dependents" class="risk-input">
                                <option value="0">0 (Single/No Dependents)</option>
                                <option value="1">1 or more (Children, Spouse, etc.)</option>
                            </select>
                        </div>

                        <div class="input-group">
                            <label for="health">Health & Medical Risks</label>
                            <select id="health" class="risk-input">
                                <option value="good">Good Health / Low Expected Costs</option>
                                <option value="chronic">Chronic Condition / High Expected Costs</option>
                            </select>
                        </div>

                        <div class="input-group" style="margin-top: 2rem;">
                            <label for="current-savings">Current Emergency Fund Savings</label>
                            <div class="input-row" style="max-width: 250px;">
                                <div class="input-wrapper" style="width: 100%;">
                                    <span class="prefix">$</span>
                                    <input type="number" id="current-savings" min="0" step="100" value="2500" style="width: 100%;" class="savings-input">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Results -->
                <div>
                    <div class="card results-section" style="position: sticky; top: 5rem;">
                        <div class="target-card recommended">
                            <div class="target-label">Recommended Target (<span id="rec-months">6</span> Months)</div>
                            <div class="target-value" id="rec-target">$0</div>
                            <div style="font-size: 0.85rem; color: var(--text-secondary);" id="rec-reasoning">Based on your risk profile</div>
                        </div>

                        <div class="target-card">
                            <div class="target-label">3 Months (Minimum Base)</div>
                            <div class="target-value">
                                <span id="target-3">$0</span>
                                <button class="copy-btn" onclick="copyValue('target-3', this)">Copy</button>
                            </div>
                        </div>

                        <div class="target-card">
                            <div class="target-label">6 Months (Standard Safe)</div>
                            <div class="target-value">
                                <span id="target-6">$0</span>
                                <button class="copy-btn" onclick="copyValue('target-6', this)">Copy</button>
                            </div>
                        </div>

                        <div class="target-card">
                            <div class="target-label">12 Months (Conservative)</div>
                            <div class="target-value">
                                <span id="target-12">$0</span>
                                <button class="copy-btn" onclick="copyValue('target-12', this)">Copy</button>
                            </div>
                        </div>

                        <div class="progress-container">
                            <div class="progress-header">
                                <span>Savings Progress</span>
                                <span id="progress-percent" style="color: var(--accent-color); font-weight: 600;">0%</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill" id="progress-fill"></div>
                            </div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); font-family: var(--font-mono);">
                                <span id="progress-current">$0</span>
                                <span id="progress-goal">$0</span>
                            </div>
                            <div style="margin-top: 1rem; font-size: 0.875rem; text-align: center; color: var(--text-secondary);" id="progress-message">
                                Keep saving! You have $X left to reach your goal.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Content Sections -->
            <div class="content-section">
                <h2>Where to keep it: Comparing High-Yield Savings Accounts (HYSA)</h2>
                <p>Your emergency fund must be completely liquid and protected from market drops. Do not invest this money in the stock market. The standard recommendation is to hold these funds in a High-Yield Savings Account (HYSA). Unlike traditional bank accounts paying 0.01%, HYSAs often pay 4% to 5% APY, helping your cash keep pace with inflation.</p>

                <table class="hysa-table">
                    <thead>
                        <tr>
                            <th>Account Type</th>
                            <th>Average APY*</th>
                            <th>Liquidity</th>
                            <th>Risk</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>High-Yield Savings (HYSA)</td>
                            <td>~4.0% - 5.0%</td>
                            <td>Immediate (1-3 days transfer)</td>
                            <td>None (FDIC Insured)</td>
                        </tr>
                        <tr>
                            <td>Money Market Account (MMA)</td>
                            <td>~4.0% - 5.2%</td>
                            <td>Immediate (Often includes debit/checks)</td>
                            <td>None (FDIC Insured)</td>
                        </tr>
                        <tr>
                            <td>No-Penalty CDs</td>
                            <td>~4.5% - 5.0%</td>
                            <td>High (Can withdraw after 7 days)</td>
                            <td>None (FDIC Insured)</td>
                        </tr>
                        <tr>
                            <td>Traditional Bank Savings</td>
                            <td>~0.01% - 0.4%</td>
                            <td>Immediate</td>
                            <td>None (FDIC Insured)</td>
                        </tr>
                    </tbody>
                </table>
                <p style="font-size: 0.8rem; opacity: 0.7;">*Rates fluctuate based on Federal Reserve benchmark rates. Check current rates with institutions directly.</p>
            </div>

            <div class="content-section">
                <h2>Emergency Fund FAQ</h2>

                <div class="faq-item">
                    <div class="faq-question">What is an emergency fund calculator and how do I use it?</div>
                    <div class="faq-answer">An emergency fund calculator helps you determine the exact amount of cash you need to set aside to cover essential living expenses in case of a financial shock, such as a job loss or medical emergency. Enter your monthly essential expenses (like rent, food, and utilities) and adjust your personal risk factors to see your customized target.</div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">How much emergency fund do I need?</div>
                    <div class="faq-answer">The general rule of thumb is to save enough to cover 3 to 6 months of essential living expenses. However, the exact amount depends on your job stability, dependents, and health. Freelancers or individuals in volatile industries may need closer to 12 months of expenses saved.</div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">Should I save a 3 months vs 6 months emergency fund?</div>
                    <div class="faq-answer">A 3-month emergency fund is often sufficient for single individuals with highly secure jobs and low fixed costs. A 6-month fund is recommended for most people, particularly those with dependents, single-income households, or standard corporate jobs with average turnover risk.</div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">Where should I keep my emergency fund?</div>
                    <div class="faq-answer">Your emergency fund must be liquid and safe. The best places are High-Yield Savings Accounts (HYSA), Money Market Accounts, or No-Penalty CDs, which offer higher interest rates than traditional savings accounts while protecting your principal from market volatility.</div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">Does an emergency fund cover job loss or other expenses?</div>
                    <div class="faq-answer">Yes, the primary purpose of an emergency fund is to replace your income during a job loss. However, it also covers other sudden, unavoidable expenses such as major medical bills, emergency car repairs, or urgent home repairs (like a broken furnace or leaking roof).</div>
                </div>
            </div>
        </main>

    </div>
  <script is:inline>
// Formatting function
        const formatMoney = (amount) => {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(amount);
        };

        // Copy functionality
        window.copyValue = async (elementId, btn) => {
            const text = document.getElementById(elementId).innerText;
            try {
                await navigator.clipboard.writeText(text);
                const originalText = btn.innerText;
                btn.innerText = 'Copied!';
                setTimeout(() => { btn.innerText = originalText; }, 2000);
            } catch (err) {
                console.error('Failed to copy', err);
            }
        };

        // Sync inputs and calculate
        const categories = ['housing', 'food', 'utilities', 'transport', 'insurance', 'debt'];

        const calculate = () => {
            let totalMonthly = 0;

            // Sync logic and calculate sum
            categories.forEach(cat => {
                const numInput = document.getElementById(`${cat}-number`);
                const sliderInput = document.getElementById(`${cat}-slider`);

                // Keep values in sync handled by event listeners, here we just read
                let val = parseFloat(numInput.value) || 0;
                totalMonthly += val;
            });

            document.getElementById('total-expenses').innerText = formatMoney(totalMonthly);

            const target3 = totalMonthly * 3;
            const target6 = totalMonthly * 6;
            const target12 = totalMonthly * 12;

            document.getElementById('target-3').innerText = formatMoney(target3);
            document.getElementById('target-6').innerText = formatMoney(target6);
            document.getElementById('target-12').innerText = formatMoney(target12);

            // Calculate Recommended
            let recommendedMonths = 3;
            let reasoning = ["Base 3 months"];

            const job = document.getElementById('job-stability').value;
            const deps = document.getElementById('dependents').value;
            const health = document.getElementById('health').value;

            if (job === 'freelance') { recommendedMonths += 3; reasoning.push("+3 for variable income"); }
            if (job === 'seasonal') { recommendedMonths += 6; reasoning.push("+6 for high volatility"); }

            if (deps === '1') { recommendedMonths += 3; reasoning.push("+3 for dependents"); }

            if (health === 'chronic') { recommendedMonths += 3; reasoning.push("+3 for health risks"); }

            if (recommendedMonths > 12) recommendedMonths = 12;

            const recommendedTarget = totalMonthly * recommendedMonths;
            document.getElementById('rec-months').innerText = recommendedMonths;
            document.getElementById('rec-target').innerText = formatMoney(recommendedTarget);
            document.getElementById('rec-reasoning').innerText = reasoning.join(', ');

            // Progress tracking
            const currentSavings = parseFloat(document.getElementById('current-savings').value) || 0;

            let percent = 0;
            if (recommendedTarget > 0) {
                percent = Math.min(100, (currentSavings / recommendedTarget) * 100);
            } else if (currentSavings > 0) {
                percent = 100;
            }

            document.getElementById('progress-fill').style.width = `${percent}%`;
            document.getElementById('progress-percent').innerText = `${percent.toFixed(1)}%`;
            document.getElementById('progress-current').innerText = formatMoney(currentSavings);
            document.getElementById('progress-goal').innerText = formatMoney(recommendedTarget);

            const remaining = recommendedTarget - currentSavings;
            const msgEl = document.getElementById('progress-message');
            if (remaining > 0) {
                msgEl.innerText = `Keep saving! You have ${formatMoney(remaining)} left to reach your recommended goal.`;
                msgEl.style.color = "var(--text-secondary)";
            } else {
                msgEl.innerText = `Congratulations! Your emergency fund is fully funded based on your profile.`;
                msgEl.style.color = "var(--accent-color)";
            }
        };

        // Attach event listeners for syncing and calculating
        categories.forEach(cat => {
            const numInput = document.getElementById(`${cat}-number`);
            const sliderInput = document.getElementById(`${cat}-slider`);

            numInput.addEventListener('input', (e) => {
                sliderInput.value = e.target.value;
                calculate();
            });

            sliderInput.addEventListener('input', (e) => {
                numInput.value = e.target.value;
                calculate();
            });
        });

        const riskInputs = document.querySelectorAll('.risk-input, .savings-input');
        riskInputs.forEach(input => {
            input.addEventListener('change', calculate);
            input.addEventListener('input', calculate);
        });

        // Init
        calculate();
