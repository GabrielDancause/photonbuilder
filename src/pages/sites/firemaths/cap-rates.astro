    // State
    let currentData = [...rawData];
    let sortColumn = 'capRate';
    let sortAsc = false;

    // Formatters
    const formatCurrency = (val) => val === null ? "N/A" : new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
    const formatPercent = (val) => val === null ? "N/A" : val.toFixed(2) + '%';
    const formatNum = (val) => val === null ? "N/A" : val.toFixed(2);

    // Init
    function init() {
      renderStats();
      renderTable();
      setupEventListeners();
    }

    function renderStats() {
      const validData = rawData.filter(item => item.capRate !== null);

      let html = '';
      if (validData.length > 0) {
        const highest = validData[0];
        const avgCap = validData.reduce((sum, item) => sum + item.capRate, 0) / validData.length;
        const lowest = validData[validData.length - 1];

        html = `
          <div class="stat-card">
            <div class="stat-value">${formatPercent(highest.capRate)}</div>
            <div class="stat-label">Highest Avg Cap Rate (${highest.city})</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">${formatPercent(avgCap)}</div>
            <div class="stat-label">National Average Cap Rate</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">${formatPercent(lowest.capRate)}</div>
            <div class="stat-label">Lowest Avg Cap Rate (${lowest.city})</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">${rawData.length}</div>
            <div class="stat-label">Metros Analyzed</div>
          </div>
        `;
      } else {
         html = `
          <div class="stat-card">
            <div class="stat-value">N/A</div>
            <div class="stat-label">Data Unavailable</div>
          </div>
          <div class="stat-card">
            <div class="stat-value">${rawData.length}</div>
            <div class="stat-label">Metros Crawled</div>
          </div>
         `;
      }
      document.getElementById('stats-container').innerHTML = html;
    }

    function renderTable() {
      const tbody = document.getElementById('tableBody');
      tbody.innerHTML = '';

      if (currentData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding: 40px;">No cities found matching criteria.</td></tr>';
        return;
      }

      currentData.forEach(item => {
        let capClass = '';
        if (item.capRate !== null) {
          if (item.capRate >= 4.5) capClass = 'high-cap';
          else if (item.capRate >= 3.5) capClass = 'med-cap';
          else capClass = 'low-cap';
        }

        let popClass = '';
        let popSymbol = '';
        if (item.popGrowth !== null) {
          popClass = item.popGrowth > 0 ? 'high-cap' : (item.popGrowth < 0 ? 'low-cap' : '');
          popSymbol = item.popGrowth > 0 ? '+' : '';
        }

        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>
            <span class="td-city">${item.city}</span>,
            <span class="td-state">${item.state}</span>
          </td>
          <td>${formatCurrency(item.medianPrice)}</td>
          <td>${formatCurrency(item.avgRentMonthly)}</td>
          <td class="${capClass}" style="font-weight: 600;">${formatPercent(item.capRate)}</td>
          <td>${formatNum(item.priceToRent)}</td>
          <td class="${popClass}">${popSymbol}${formatPercent(item.popGrowth)}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    function setupEventListeners() {
      // Search
      document.getElementById('searchInput').addEventListener('input', (e) => {
        filterData();
      });

      // Filter
      document.getElementById('regionFilter').addEventListener('change', (e) => {
        filterData();
      });

      // Sort
      document.querySelectorAll('th[data-sort]').forEach(th => {
        th.addEventListener('click', () => {
          const col = th.dataset.sort;
          if (sortColumn === col) {
            sortAsc = !sortAsc;
          } else {
            sortColumn = col;
            sortAsc = col === 'city' ? true : false; // Default desc for numbers, asc for text
          }

          // Update UI
          document.querySelectorAll('th').forEach(h => {
            h.classList.remove('sort-asc', 'sort-desc');
          });
          th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');

          filterData(); // re-sorts and renders
        });
      });
    }

    function filterData() {
      const query = document.getElementById('searchInput').value.toLowerCase();
      const capFilter = document.getElementById('regionFilter').value;

      currentData = rawData.filter(item => {
        // Search
        const matchesSearch = item.city.toLowerCase().includes(query) || item.state.toLowerCase().includes(query);
        if (!matchesSearch) return false;

        // Cap filter
        if (capFilter === 'high' && item.capRate <= 4.5) return false;
        if (capFilter === 'med' && (item.capRate > 4.5 || item.capRate < 3.5)) return false;
        if (capFilter === 'low' && item.capRate >= 3.5) return false;

        return true;
      });

      // Sort
      currentData.sort((a, b) => {
        let valA = a[sortColumn];
        let valB = b[sortColumn];

        if (typeof valA === 'string') {
          return sortAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else {
          return sortAsc ? valA - valB : valB - valA;
        }
      });

      renderTable();
    }

    // Run
    init();
  </script>

