---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between a high-yield savings account and a GIC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A High-Yield Savings Account (HYSA) provides variable interest and allows you to withdraw your money at any time. A Guaranteed Investment Certificate (GIC) requires you to lock your money for a fixed term in exchange for a guaranteed interest rate."
      }
    },
    {
      "@type": "Question",
      "name": "Are money market funds safer than savings accounts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Money market funds are extremely low risk, but unlike bank deposits (which may be insured by CDIC in Canada or FDIC in the US), they are not guaranteed by the government and can technically lose value, although it is very rare."
      }
    },
    {
      "@type": "Question",
      "name": "Why would someone buy Treasury Bills (T-Bills) over a GIC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "T-Bills are highly liquid, incredibly secure (backed by the government), and offer tax advantages in some jurisdictions, whereas GICs lock up your cash and have standard interest taxation."
      }
    },
    {
      "@type": "Question",
      "name": "How much cash should I keep in savings for FIRE?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For the FIRE journey, you generally want an emergency fund covering 3-6 months of expenses in highly liquid accounts, and potentially up to 1-3 years of living expenses in a cash wedge to mitigate sequence of returns risk if you are nearing or entering early retirement."
      }
    },
    {
      "@type": "Question",
      "name": "How does inflation affect my cash savings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Inflation reduces the purchasing power of your cash. If your savings account pays 4% interest but inflation is 3%, your real return is only 1%. You must compare your after-tax yield to the inflation rate to determine your true return."
      }
    }
  ]
};

export const meta = {
  title: "Cash Savings Compared: HYSAs, GICs, Money Market & T-Bills",
  description: "A complete guide comparing high-yield savings accounts, GICs, money market funds, and Treasury Bills to optimize your cash strategy.",
  category: "study",
  published: "2026-03-15",
};
