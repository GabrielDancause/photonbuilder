<SiteLayout site="firemaths" title="Where to Keep Your Emergency Fund: Accessibility vs. Yield" description="Discover the best places to store your emergency fund. Balance high interest yields with immediate accessibility to optimize your cash buffer." canonical="https://firemaths.info/emergency-fund-where" schema={schema}>
  <div class="page-content">
