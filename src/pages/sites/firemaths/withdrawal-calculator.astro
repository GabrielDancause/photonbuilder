---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Retirement Withdrawal Calculator",
  "description": "Calculate retirement safe withdrawal rates, portfolio longevity, and the impact of the 4% rule, inflation, and social security.",
  "url": "https://firemaths.info/withdrawal-calculator.html",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Any"
};
---

<SiteLayout
  site="firemaths"
  title="Retirement Withdrawal Calculator — Safe Withdrawal Rates & 4% Rule"
  description="Calculate your safe retirement withdrawal rate using the 4% rule. See how long your portfolio will last with inflation, social security, and investment returns."
  canonical="https://firemaths.info/withdrawal-calculator" schema={schema}
>
  <main class="max-w-4xl mx-auto px-6 py-10 container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16 calculator-grid">
        <!-- Inputs -->
        <div class="bg-[var(--card-bg)] border-2 border-[var(--border-color)] rounded-2xl p-8 card">
            <div class="mb-5 last:mb-0 input-group">
                <label for="portfolio" class="block text-sm font-semibold text-white mb-2">Starting Portfolio Value</label>
                <div class="relative flex items-center input-wrapper has-prefix">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none prefix">$</span>
                    <input type="number" id="portfolio" value="1000000" min="0" step="10000" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-lg transition-colors focus:outline-none focus:border-[var(--accent-color)] pl-8 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                </div>
            </div>

            <div class="mb-5 last:mb-0 input-group">
                <label for="withdrawalRate" class="block text-sm font-semibold text-white mb-2">Initial Withdrawal Rate</label>
                <span class="block text-xs text-[var(--text-secondary)] mb-2 -mt-1 hint">The famous "4% Rule" suggests starting here.</span>
                <div class="relative flex items-center input-wrapper has-suffix">
                    <input type="number" id="withdrawalRate" value="4" min="0" max="100" step="0.1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-lg transition-colors focus:outline-none focus:border-[var(--accent-color)] pr-8 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                    <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none suffix">%</span>
                </div>
            </div>

            <div class="mb-5 last:mb-0 input-group">
                <label for="returns" class="block text-sm font-semibold text-white mb-2">Expected Annual Returns (Nominal)</label>
                <span class="block text-xs text-[var(--text-secondary)] mb-2 -mt-1 hint">Average stock market return is ~7-10% before inflation.</span>
                <div class="relative flex items-center input-wrapper has-suffix">
                    <input type="number" id="returns" value="7" min="0" max="30" step="0.1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-lg transition-colors focus:outline-none focus:border-[var(--accent-color)] pr-8 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                    <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none suffix">%</span>
                </div>
            </div>

            <div class="mb-5 last:mb-0 input-group">
                <label for="inflation" class="block text-sm font-semibold text-white mb-2">Expected Inflation</label>
                <span class="block text-xs text-[var(--text-secondary)] mb-2 -mt-1 hint">Historical average is around 2.5-3%.</span>
                <div class="relative flex items-center input-wrapper has-suffix">
                    <input type="number" id="inflation" value="3" min="0" max="20" step="0.1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-lg transition-colors focus:outline-none focus:border-[var(--accent-color)] pr-8 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                    <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none suffix">%</span>
                </div>
            </div>

            <div class="mb-5 last:mb-0 input-group">
                <label for="years" class="block text-sm font-semibold text-white mb-2">Years in Retirement</label>
                <div class="relative flex items-center input-wrapper has-suffix">
                    <input type="number" id="years" value="30" min="1" max="100" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-lg transition-colors focus:outline-none focus:border-[var(--accent-color)] pr-12 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                    <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none suffix">Yrs</span>
                </div>
            </div>

            <div class="mb-5 last:mb-0 input-group">
                <label for="socialSecurity" class="block text-sm font-semibold text-white mb-2">Annual Social Security / Pension</label>
                <span class="block text-xs text-[var(--text-secondary)] mb-2 -mt-1 hint">Optional. Fixed income that reduces portfolio withdrawals.</span>
                <div class="relative flex items-center input-wrapper has-prefix">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none prefix">$</span>
                    <input type="number" id="socialSecurity" value="0" min="0" step="1000" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-lg transition-colors focus:outline-none focus:border-[var(--accent-color)] pl-8 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                </div>
            </div>
        </div>

        <!-- Results -->
        <div class="flex flex-col gap-5 bg-[var(--card-bg)] border-2 border-[var(--border-color)] rounded-2xl p-8 results">
            <div class="bg-[var(--bg-color)] border border-[var(--accent-color)] rounded-xl p-6 relative bg-gradient-to-b from-[color-mix(in_srgb,var(--accent-color)_5%,transparent)] to-transparent result-box highlight">
                <div class="text-sm font-semibold text-[var(--text-secondary)] uppercase tracking-wide mb-2 result-label">Initial Annual Withdrawal</div>
                <div class="font-mono text-3xl font-semibold text-[var(--accent-color)] result-value" id="res-initial-withdrawal">$40,000</div>
                <div class="text-sm text-[var(--text-secondary)] mt-1 result-sub">Your target spending for Year 1</div>
                <button class="absolute top-6 right-6 bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] rounded-md px-2 py-1 text-xs font-semibold cursor-pointer transition-colors hover:border-[var(--accent-color)] hover:text-[var(--accent-color)] copy-btn" data-copy="res-initial-withdrawal" aria-label="Copy Withdrawal">Copy</button>
            </div>

            <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-xl p-6 relative result-box" id="res-status-box">
                <div class="text-sm font-semibold text-[var(--text-secondary)] uppercase tracking-wide mb-2 result-label">Portfolio Longevity</div>
                <div class="font-mono text-3xl font-semibold text-white result-value" id="res-status">Lasts 30+ Years</div>
                <div class="text-sm text-[var(--text-secondary)] mt-1 result-sub" id="res-status-sub">Your money survives the simulation</div>
            </div>

            <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-xl p-6 relative result-box">
                <div class="text-sm font-semibold text-[var(--text-secondary)] uppercase tracking-wide mb-2 result-label">Final Portfolio Value</div>
                <div class="font-mono text-3xl font-semibold text-white result-value" id="res-final-value">$1,234,567</div>
                <div class="text-sm text-[var(--text-secondary)] mt-1 result-sub" id="res-final-sub">After 30 years (Nominal value)</div>
                <button class="absolute top-6 right-6 bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] rounded-md px-2 py-1 text-xs font-semibold cursor-pointer transition-colors hover:border-[var(--accent-color)] hover:text-[var(--accent-color)] copy-btn" data-copy="res-final-value" aria-label="Copy Final Value">Copy</button>
            </div>
        </div>
    </div>

    <!-- SEO Content Section -->
    <article class="max-w-3xl mx-auto mb-20 content-section">
        <h2 class="text-3xl font-bold text-white mt-10 mb-4">What is a Safe Withdrawal Rate (SWR)?</h2>
        <p class="text-[var(--text-secondary)] mb-4 text-lg">A Safe Withdrawal Rate (SWR) is the percentage of your initial retirement portfolio that you can withdraw in your first year of retirement, adjusting that amount for inflation in subsequent years, without running out of money before you die. The most famous benchmark for SWR is the <strong>4% Rule</strong>.</p>
        <p class="text-[var(--text-secondary)] mb-4 text-lg">The 4% Rule originates from the 1998 Trinity Study, which tested various withdrawal rates against historical stock and bond market data. It concluded that a retiree with a 50/50 or 75/25 stock-to-bond allocation could withdraw 4% initially, adjusted for inflation annually, and have a near 100% success rate over a 30-year retirement period.</p>

        <h2 class="text-3xl font-bold text-white mt-10 mb-4">How Inflation Impacts Your Portfolio</h2>
        <p class="text-[var(--text-secondary)] mb-4 text-lg">Inflation is the silent killer of retirement portfolios. If your initial spending target is $40,000 and inflation averages 3%, your spending target in year 10 will need to be over $53,000 just to maintain the exact same purchasing power.</p>
        <p class="text-[var(--text-secondary)] mb-4 text-lg">This calculator adjusts your desired income up by your estimated inflation rate each year. Your investment returns must work hard not just to fund your withdrawals, but to keep the remaining principal growing fast enough to offset this compounding inflation.</p>

        <h2 class="text-3xl font-bold text-white mt-10 mb-4">Factoring in Social Security & Pensions</h2>
        <p class="text-[var(--text-secondary)] mb-4 text-lg">The 4% Rule traditionally assumes your entire lifestyle is funded by your portfolio. In reality, many retirees have fixed income sources like Social Security, pensions, or rental income.</p>
        <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc">
            <li class="mb-2 text-lg"><strong>Reduced Reliance:</strong> If your target spending is $60,000 and you receive $20,000 from Social Security, you only need to withdraw $40,000 from your investments.</li>
            <li class="mb-2 text-lg"><strong>Lower Required Portfolio:</strong> By reducing the withdrawal burden on your portfolio, Social Security drastically lowers the total amount you need to save to achieve financial independence.</li>
        </ul>
        <p class="text-[var(--text-secondary)] mb-4 text-lg">Note: In this calculator's model, we assume your Social Security or Pension benefits will also scale with inflation (like Cost of Living Adjustments, or COLAs).</p>
    </article>
</main>
  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
        const inputs = {
            portfolio: document.getElementById('portfolio'),
            withdrawalRate: document.getElementById('withdrawalRate'),
            returns: document.getElementById('returns'),
            inflation: document.getElementById('inflation'),
            years: document.getElementById('years'),
            socialSecurity: document.getElementById('socialSecurity')
        };

        const outputs = {
            initialWithdrawal: document.getElementById('res-initial-withdrawal'),
            statusBox: document.getElementById('res-status-box'),
            status: document.getElementById('res-status'),
            statusSub: document.getElementById('res-status-sub'),
            finalValue: document.getElementById('res-final-value'),
            finalSub: document.getElementById('res-final-sub')
        };

        const copyButtons = document.querySelectorAll('.copy-btn');

        const formatCurrency = (value) => {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(value);
        };

        const calculateWithdrawal = () => {
            const portfolio = parseFloat(inputs.portfolio.value) || 0;
            const withdrawalRate = parseFloat(inputs.withdrawalRate.value) || 0;
            const returns = parseFloat(inputs.returns.value) || 0;
            const inflation = parseFloat(inputs.inflation.value) || 0;
            const years = parseInt(inputs.years.value) || 0;
            const socialSecurity = parseFloat(inputs.socialSecurity.value) || 0;

            const rateDecimal = withdrawalRate / 100;
            const returnDecimal = returns / 100;
            const inflationDecimal = inflation / 100;

            // Year 1 Target Income
            const initialTargetIncome = portfolio * rateDecimal;

            outputs.initialWithdrawal.textContent = formatCurrency(initialTargetIncome);

            let currentPortfolio = portfolio;
            let currentTargetIncome = initialTargetIncome;
            let currentSocialSecurity = socialSecurity;
            let failedYear = -1;

            for (let i = 1; i <= years; i++) {
                // Calculate how much we need to pull from portfolio
                // If SS covers the target income entirely, we pull 0
                const requiredWithdrawal = Math.max(0, currentTargetIncome - currentSocialSecurity);

                // Withdraw at beginning of year (conservative approach)
                currentPortfolio -= requiredWithdrawal;

                // Did we run out of money?
                if (currentPortfolio < 0) {
                    failedYear = i;
                    currentPortfolio = 0;
                    break;
                }

                // Grow remaining portfolio over the year
                currentPortfolio *= (1 + returnDecimal);

                // Adjust for next year's inflation
                currentTargetIncome *= (1 + inflationDecimal);
                currentSocialSecurity *= (1 + inflationDecimal);
            }

            // Update UI based on success/failure
            if (failedYear !== -1) {
                outputs.statusBox.classList.remove('border-[var(--accent-color)]', 'bg-gradient-to-b', 'from-[color-mix(in_srgb,var(--accent-color)_5%,transparent)]', 'to-transparent', 'highlight');
                outputs.status.classList.remove('text-[var(--accent-color)]');
                outputs.statusBox.classList.add('border-red-500', 'bg-gradient-to-b', 'from-[color-mix(in_srgb,red_5%,transparent)]', 'to-transparent', 'danger');
                outputs.status.classList.add('text-red-500');
                outputs.status.textContent = `Depleted Year ${failedYear}`;
                outputs.statusSub.textContent = "Portfolio ran out of money";
                outputs.finalValue.textContent = "$0";
                outputs.finalSub.textContent = `After ${failedYear} years`;
            } else {
                outputs.statusBox.classList.remove('border-red-500', 'bg-gradient-to-b', 'from-[color-mix(in_srgb,red_5%,transparent)]', 'to-transparent', 'danger');
                outputs.status.classList.remove('text-red-500');
                outputs.statusBox.classList.add('border-[var(--accent-color)]', 'bg-gradient-to-b', 'from-[color-mix(in_srgb,var(--accent-color)_5%,transparent)]', 'to-transparent', 'highlight');
                outputs.status.classList.add('text-[var(--accent-color)]');
                outputs.status.textContent = `Lasts ${years} Years`;
                outputs.statusSub.textContent = "Your money survives the simulation";
                outputs.finalValue.textContent = formatCurrency(currentPortfolio);
                outputs.finalSub.textContent = `After ${years} years (Nominal value)`;
            }
        };

        // Attach event listeners
        Object.values(inputs).forEach(input => {
            input.addEventListener('input', calculateWithdrawal);
        });

        // Copy functionality
        copyButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetId = e.target.getAttribute('data-copy');
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    navigator.clipboard.writeText(targetElement.textContent).then(() => {
                        const originalText = e.target.textContent;
                        e.target.textContent = 'Copied!';
                        e.target.classList.add('bg-[var(--accent-color)]', 'text-[var(--bg-color)]', 'border-[var(--accent-color)]');
                        e.target.classList.remove('bg-transparent', 'text-[var(--text-secondary)]', 'border-[var(--border-color)]');
                        setTimeout(() => {
                            e.target.textContent = originalText;
                            e.target.classList.remove('bg-[var(--accent-color)]', 'text-[var(--bg-color)]', 'border-[var(--accent-color)]');
                        e.target.classList.add('bg-transparent', 'text-[var(--text-secondary)]', 'border-[var(--border-color)]');
                        }, 2000);
                    }).catch(err => {
                        console.error('Failed to copy text: ', err);
                    });
                }
            });
        });

        // Initial calculation
        calculateWithdrawal();
    });
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-fire-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">The Complete Guide to Financial Independence (FIRE)</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
