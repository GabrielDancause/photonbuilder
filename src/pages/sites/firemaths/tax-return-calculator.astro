  <script is:inline>
    const CONFIG = {
      standardDeductions: {
        single: 14600,
        married: 29200,
        head: 21900
      },
      brackets: {
        single: [
          { rate: 0.10, max: 11600 },
          { rate: 0.12, max: 47150 },
          { rate: 0.22, max: 100525 },
          { rate: 0.24, max: 191950 },
          { rate: 0.32, max: 243725 },
          { rate: 0.35, max: 609350 },
          { rate: 0.37, max: Infinity }
        ],
        married: [
          { rate: 0.10, max: 23200 },
          { rate: 0.12, max: 94300 },
          { rate: 0.22, max: 201050 },
          { rate: 0.24, max: 383900 },
          { rate: 0.32, max: 487450 },
          { rate: 0.35, max: 731200 },
          { rate: 0.37, max: Infinity }
        ],
        head: [
          { rate: 0.10, max: 16550 },
          { rate: 0.12, max: 63100 },
          { rate: 0.22, max: 100500 },
          { rate: 0.24, max: 191950 },
          { rate: 0.32, max: 243700 },
          { rate: 0.35, max: 609350 },
          { rate: 0.37, max: Infinity }
        ]
      }
    };

    const formatMoney = (amount) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(amount);
    };

    const getVal = (id) => {
      const val = parseFloat(document.getElementById(id).value);
      return isNaN(val) ? 0 : val;
    };

    const calculateReturn = () => {
      // 1. Basics
      const filingStatus = document.getElementById('filingStatus').value;
      const w2Income = getVal('w2Income');
      const bizIncome = getVal('bizIncome');
      const interestIncome = getVal('interestIncome');
      const stcgIncome = getVal('stcgIncome');

      const totalIncome = w2Income + bizIncome + interestIncome + stcgIncome;

      // 2. Adjustments
      const tradIra = getVal('tradIra');
      const hsaContrib = getVal('hsaContrib');
      const studentLoan = getVal('studentLoan');
      const otherAdjust = getVal('otherAdjust');

      const adjustments = tradIra + hsaContrib + studentLoan + otherAdjust;
      let agi = totalIncome - adjustments;
      if (agi < 0) agi = 0;

      // 3. Deductions
      const stateTaxes = Math.min(getVal('stateTaxes'), 10000); // SALT Cap
      const mortgageInt = getVal('mortgageInt');
      const charity = getVal('charity');

      const itemizedTotal = stateTaxes + mortgageInt + charity;
      const standardDeduction = CONFIG.standardDeductions[filingStatus];

      let usingItemized = itemizedTotal > standardDeduction;
      let finalDeduction = usingItemized ? itemizedTotal : standardDeduction;

      let taxableIncome = agi - finalDeduction;
      if (taxableIncome < 0) taxableIncome = 0;

      // 4. Liability
      let taxLiability = 0;
      let remainingIncome = taxableIncome;
      let prevMax = 0;
      const brackets = CONFIG.brackets[filingStatus];

      for (const bracket of brackets) {
        if (remainingIncome <= 0) break;
        const bracketRange = bracket.max - prevMax;
        const incomeInBracket = Math.min(remainingIncome, bracketRange);
        taxLiability += incomeInBracket * bracket.rate;
        remainingIncome -= incomeInBracket;
        prevMax = bracket.max;
      }

      // 5. Credits & Payments
      const credits = getVal('taxCredits');
      const withheld = getVal('taxesWithheld');

      let finalTax = taxLiability - credits;
      if (finalTax < 0) finalTax = 0; // Assuming non-refundable for this tool

      const difference = withheld - finalTax;
      const isRefund = difference >= 0;
      const absDiff = Math.abs(difference);

      // Update UI
      document.getElementById('sumTotalIncome').textContent = formatMoney(totalIncome);
      document.getElementById('sumAdjustments').textContent = `-${formatMoney(adjustments)}`;
      document.getElementById('sumAGI').textContent = formatMoney(agi);

      document.getElementById('deductionTypeLabel').textContent = usingItemized ? "Itemized Deduction" : "Standard Deduction";
      document.getElementById('sumDeduction').textContent = `-${formatMoney(finalDeduction)}`;

      document.getElementById('sumTaxable').textContent = formatMoney(taxableIncome);
      document.getElementById('sumLiability').textContent = formatMoney(taxLiability);
      document.getElementById('sumCredits').textContent = `-${formatMoney(credits)}`;
      document.getElementById('sumTotalTax').textContent = formatMoney(finalTax);
      document.getElementById('sumPayments').textContent = `-${formatMoney(withheld)}`;

      const highlightBox = document.getElementById('finalHighlight');
      const finalLabel = document.getElementById('finalLabel');
      const finalValue = document.getElementById('finalValue');

      finalValue.textContent = formatMoney(absDiff);

      if (isRefund) {
        highlightBox.classList.remove('owed');
        finalLabel.textContent = "Expected Tax Refund";
      } else {
        highlightBox.classList.add('owed');
        finalLabel.textContent = "Estimated Amount Owed";
      }
    };

    // Bind events
    const inputs = [
      'filingStatus', 'w2Income', 'bizIncome', 'interestIncome', 'stcgIncome',
      'tradIra', 'hsaContrib', 'studentLoan', 'otherAdjust',
      'stateTaxes', 'mortgageInt', 'charity', 'taxCredits', 'taxesWithheld'
    ];

    inputs.forEach(id => {
      document.getElementById(id).addEventListener('input', calculateReturn);
      if(document.getElementById(id).tagName === 'SELECT') {
         document.getElementById(id).addEventListener('change', calculateReturn);
      }
    });

    // Init
    calculateReturn();
  </script>

