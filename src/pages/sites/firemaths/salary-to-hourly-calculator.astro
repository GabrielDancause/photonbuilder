---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Salary to Hourly Calculator | Firemaths',
  description: 'Convert your annual salary to an hourly wage or calculate your yearly salary from an hourly rate. Instantly see daily, weekly, and monthly breakdowns.',
  category: 'tool',
  keywords: ['salary to hourly calculator', 'hourly to salary converter', 'wage calculator', 'paycheck breakdown', 'annual income calculator', 'hourly rate to annual salary']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "firemaths.info" },
    "publisher": { "@type": "Organization", "name": "firemaths.info" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I calculate my hourly rate from my salary?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To calculate your hourly rate from an annual salary, divide your yearly salary by the total number of hours you work in a year. For a standard 40-hour workweek, there are 2,080 working hours in a year (40 hours × 52 weeks). So, if you make $52,000 a year, your hourly rate is $52,000 / 2,080 = $25 per hour."
        }
      },
      {
        "@type": "Question",
        "name": "How much is $50,000 a year hourly?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you earn a $50,000 salary and work a standard 40-hour week for 52 weeks a year (2,080 hours total), your hourly rate is approximately $24.04 per hour."
        }
      },
      {
        "@type": "Question",
        "name": "How many working hours are in a year?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In a standard 40-hour workweek over 52 weeks, there are 2,080 working hours in a year. This assumes you are paid for 52 weeks, which usually includes paid time off (PTO) and holidays."
        }
      },
      {
        "@type": "Question",
        "name": "How do I convert an hourly wage to an annual salary?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To convert an hourly wage to an annual salary, multiply your hourly rate by the number of hours you work per week, and then multiply that number by 52 (the number of weeks in a year). For example, $20 per hour × 40 hours/week × 52 weeks = $41,600 per year."
        }
      },
      {
        "@type": "Question",
        "name": "Does my salaried hourly rate include paid time off (PTO)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, when calculating an hourly rate from an annual salary assuming 52 working weeks, the calculation inherently includes paid time off and paid holidays, as you are still being compensated for those hours as part of your total annual salary."
        }
      }
    ]
  }
]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description} canonical="https://firemaths.info/salary-to-hourly-calculator">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
    <style is:inline>
      .calc-hero {
        text-align: center;
        padding: 4rem 1rem;
        background: linear-gradient(135deg, rgba(var(--accent-color-rgb, 212, 160, 23), 0.1) 0%, transparent 100%);
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 3rem;
        border-radius: 0 0 24px 24px;
      }
      .calc-hero h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
        color: var(--text-primary);
        line-height: 1.2;
      }
      .calc-hero p {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 600px;
        margin: 0 auto 2rem;
      }
      .calc-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        align-items: start;
      }
      @media (max-width: 900px) {
        .calc-container { grid-template-columns: 1fr; }
      }
      .calc-panel, .result-panel {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      }
      .calc-panel h2, .result-panel h2 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 0.5rem;
      }
      .input-group {
        margin-bottom: 1.5rem;
      }
      .input-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--text-primary);
      }
      .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
      }
      .prefix {
        position: absolute;
        left: 1rem;
        color: var(--text-secondary);
        font-weight: 600;
        z-index: 10;
      }
      .suffix {
        position: absolute;
        right: 1rem;
        color: var(--text-secondary);
      }
      input[type="number"] {
        width: 100%;
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        font-size: 1.1rem;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      input[type="number"]:focus {
        outline: none;
        border-color: var(--accent-color);
        box-shadow: 0 0 0 2px rgba(212, 160, 23, 0.2);
      }
      .has-prefix input { padding-left: 2rem; }
      .has-suffix input { padding-right: 3rem; }

      .toggle-container {
        display: flex;
        background: var(--bg-primary);
        border-radius: 8px;
        border: 1px solid var(--border-color);
        overflow: hidden;
        margin-bottom: 2rem;
      }
      .toggle-btn {
        flex: 1;
        padding: 0.75rem;
        background: transparent;
        border: none;
        color: var(--text-secondary);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }
      .toggle-btn.active {
        background: var(--accent-color);
        color: #000;
      }

      .result-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-top: 1.5rem;
      }
      .result-card {
        background: var(--bg-primary);
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--border-color);
        text-align: center;
      }
      .result-card.primary {
        grid-column: span 2;
        background: rgba(212, 160, 23, 0.05);
        border-color: var(--accent-color);
      }
      .result-label {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .result-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary);
        font-family: monospace;
      }
      .result-card.primary .result-value {
        font-size: 2.5rem;
        color: var(--accent-color);
      }

      .chart-container {
        margin-top: 2rem;
        height: 200px;
        display: flex;
        align-items: flex-end;
        gap: 1rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
      }
      .chart-bar-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        height: 100%;
        justify-content: flex-end;
      }
      .chart-bar {
        width: 100%;
        background: var(--accent-color);
        border-radius: 4px 4px 0 0;
        transition: height 0.5s ease-out;
        min-height: 2px;
        max-height: 150px;
        opacity: 0.8;
      }
      .chart-bar:hover { opacity: 1; }
      .chart-label {
        margin-top: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-secondary);
      }
      .chart-val {
        margin-bottom: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-primary);
        font-weight: 600;
      }

      .content-section {
        max-width: 800px;
        margin: 4rem auto;
        padding: 0 1rem;
      }
      .content-section h2 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
        color: var(--text-primary);
      }
      .content-section p {
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
      }
      .info-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin: 2rem 0;
      }
      .info-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        padding: 1.5rem;
        border-radius: 12px;
      }
      .info-card h3 {
        margin-top: 0;
        color: var(--accent-color);
        margin-bottom: 1rem;
      }

      .faq-section {
        max-width: 800px;
        margin: 4rem auto;
        padding: 0 1rem;
      }
      .faq-item {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1rem;
      }
      .faq-item h3 {
        margin-top: 0;
        font-size: 1.2rem;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
      }
      .faq-item p {
        margin-bottom: 0;
        color: var(--text-secondary);
        line-height: 1.6;
      }

      .related-tools {
        max-width: 1200px;
        margin: 4rem auto;
        padding: 0 1rem;
        text-align: center;
      }
      .related-tools h2 {
        margin-bottom: 2rem;
      }
      .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
      }
      .related-card {
        display: block;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s, border-color 0.2s;
      }
      .related-card:hover {
        transform: translateY(-5px);
        border-color: var(--accent-color);
      }
      .related-card h3 {
        color: var(--text-primary);
        margin-top: 0;
        margin-bottom: 0.5rem;
      }
      .related-card p {
        color: var(--text-secondary);
        margin: 0;
        font-size: 0.9rem;
      }

      .error-msg {
        color: #ef4444;
        font-size: 0.85rem;
        margin-top: 0.5rem;
        display: none;
      }
