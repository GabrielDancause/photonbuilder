  <script is:inline>
    (function() {
      // Elements
      const btnSalToHr = document.getElementById('btn-sal-to-hr');
      const btnHrToSal = document.getElementById('btn-hr-to-sal');
      const modeSalary = document.getElementById('mode-salary');
      const modeHourly = document.getElementById('mode-hourly');

      const inputAnnual = document.getElementById('annual-salary');
      const inputHourly = document.getElementById('hourly-rate');
      const inputHours = document.getElementById('hours-per-week');
      const inputWeeks = document.getElementById('weeks-per-year');

      const errAnnual = document.getElementById('err-annual');
      const errHourly = document.getElementById('err-hourly');
      const errHours = document.getElementById('err-hours');

      const lblPrimary = document.getElementById('primary-label');
      const resPrimary = document.getElementById('res-primary');

      const lblSecondary1 = document.getElementById('secondary-label-1');
      const resAnnual = document.getElementById('res-annual');
      const resMonthly = document.getElementById('res-monthly');
      const resBiweekly = document.getElementById('res-biweekly');
      const resWeekly = document.getElementById('res-weekly');
      const resDaily = document.getElementById('res-daily');

      // State
      let mode = 'sal-to-hr'; // 'sal-to-hr' or 'hr-to-sal'

      // Formatting helpers
      const fmtMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: val % 1 === 0 ? 0 : 2 }).format(val);
      const fmtMoneyExact = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);

      // Tab Switching
      btnSalToHr.addEventListener('click', () => {
        mode = 'sal-to-hr';
        btnSalToHr.classList.add('active');
        btnHrToSal.classList.remove('active');
        modeSalary.style.display = 'block';
        modeHourly.style.display = 'none';

        lblPrimary.textContent = 'Hourly Rate';
        lblSecondary1.textContent = 'Annual Salary';
        calculate();
      });

      btnHrToSal.addEventListener('click', () => {
        mode = 'hr-to-sal';
        btnHrToSal.classList.add('active');
        btnSalToHr.classList.remove('active');
        modeHourly.style.display = 'block';
        modeSalary.style.display = 'none';

        lblPrimary.textContent = 'Annual Salary';
        lblSecondary1.textContent = 'Hourly Rate';
        calculate();
      });

      // Input Listeners
      [inputAnnual, inputHourly, inputHours, inputWeeks].forEach(input => {
        input.addEventListener('input', calculate);
      });

      function validate() {
        let valid = true;

        if (mode === 'sal-to-hr' && (parseFloat(inputAnnual.value) <= 0 || isNaN(parseFloat(inputAnnual.value)))) {
          errAnnual.style.display = 'block';
          valid = false;
        } else {
          errAnnual.style.display = 'none';
        }

        if (mode === 'hr-to-sal' && (parseFloat(inputHourly.value) <= 0 || isNaN(parseFloat(inputHourly.value)))) {
          errHourly.style.display = 'block';
          valid = false;
        } else {
          errHourly.style.display = 'none';
        }

        if (parseFloat(inputHours.value) <= 0 || parseFloat(inputHours.value) > 168 || isNaN(parseFloat(inputHours.value))) {
          errHours.style.display = 'block';
          valid = false;
        } else {
          errHours.style.display = 'none';
        }

        return valid;
      }

      function updateChart(daily, weekly, biweekly, monthly) {
        document.getElementById('chart-val-day').textContent = fmtMoney(daily);
        document.getElementById('chart-val-week').textContent = fmtMoney(weekly);
        document.getElementById('chart-val-bi').textContent = fmtMoney(biweekly);
        document.getElementById('chart-val-mo').textContent = fmtMoney(monthly);

        // Dynamic scaling based on monthly max
        const max = monthly;
        document.getElementById('chart-bar-day').style.height = Math.max(2, (daily / max) * 100) + '%';
        document.getElementById('chart-bar-week').style.height = Math.max(2, (weekly / max) * 100) + '%';
        document.getElementById('chart-bar-bi').style.height = Math.max(2, (biweekly / max) * 100) + '%';
        document.getElementById('chart-bar-mo').style.height = '100%';
      }

      function calculate() {
        if (!validate()) return;

        const hoursPerWeek = parseFloat(inputHours.value);
        const weeksPerYear = parseFloat(inputWeeks.value) || 52;
        const totalHours = hoursPerWeek * weeksPerYear;

        let annual, hourly;

        if (mode === 'sal-to-hr') {
          annual = parseFloat(inputAnnual.value);
          hourly = annual / totalHours;

          resPrimary.textContent = fmtMoneyExact(hourly);
          resAnnual.textContent = fmtMoney(annual);

          // Sync opposite input
          inputHourly.value = hourly.toFixed(2);
        } else {
          hourly = parseFloat(inputHourly.value);
          annual = hourly * totalHours;

          resPrimary.textContent = fmtMoney(annual);
          resAnnual.textContent = fmtMoneyExact(hourly);

          // Sync opposite input
          inputAnnual.value = annual.toFixed(0);
        }

        const monthly = annual / 12;
        const weekly = hourly * hoursPerWeek;
        const biweekly = weekly * 2;
        // Assume 5 work days a week for daily rate
        const dailyHours = Math.min(24, hoursPerWeek / 5);
        const daily = hourly * dailyHours;

        resMonthly.textContent = fmtMoney(monthly);
        resBiweekly.textContent = fmtMoney(biweekly);
        resWeekly.textContent = fmtMoney(weekly);
        resDaily.textContent = fmtMoney(daily);
        document.getElementById('res-daily').previousElementSibling.textContent = `Daily (${dailyHours.toFixed(1)} hrs)`;

        updateChart(daily, weekly, biweekly, monthly);
      }

      // Init
      calculate();
    })();
  </script>
