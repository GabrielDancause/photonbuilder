---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Credit Card Payoff Calculator",
  "url": "https://firemaths.info/credit-card-payoff-calculator",
  "description": "Calculate how long it takes to pay off your credit card and how much interest you'll pay. Compare minimum payments vs fixed payments, see a payoff timeline, and explore balance transfer savings.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long will it take to pay off my credit card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The time to pay off a credit card depends on your balance, APR, and monthly payment. Paying only the minimum on a $5,000 balance at 22% APR could take over 20 years and cost thousands in interest. Increasing your payment to even $150-200/month can cut that to 2-3 years. Use our calculator to see your exact payoff timeline based on your specific balance, rate, and payment amount."
      }
    },
    {
      "@type": "Question",
      "name": "What is the minimum payment trap?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The minimum payment trap occurs when you only pay the minimum required by your credit card company, which is typically 1-3% of your balance or a flat $25-35. Because most of the minimum goes toward interest rather than principal, it can take decades to pay off a moderate balance. On a $5,000 balance at 20% APR, paying only the minimum could mean paying over $8,000 in interest alone. The calculator shows you exactly how the minimum payment trap affects your specific balance."
      }
    },
    {
      "@type": "Question",
      "name": "How much interest will I pay on my credit card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Total interest depends on your balance, APR, and how quickly you pay it off. At 22% APR on a $5,000 balance, paying $150/month means about $1,700 in total interest over 3.5 years. Paying only the minimum ($100) increases total interest to over $4,000 over 9+ years. Every extra dollar you pay reduces both time and total interest. Our calculator shows your exact interest cost for any payment amount."
      }
    },
    {
      "@type": "Question",
      "name": "Is a balance transfer worth it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A balance transfer to a 0% intro APR card can save significant money if you can pay off the balance during the promotional period (typically 12-21 months). However, you need to factor in the balance transfer fee (usually 3-5% of the transferred amount) and make sure you can pay off the balance before the regular APR kicks in. Our balance transfer comparison section shows you the exact savings for your situation, including the transfer fee."
      }
    },
    {
      "@type": "Question",
      "name": "How is credit card interest calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Credit card interest is calculated using your Annual Percentage Rate (APR) divided by 12 to get the monthly rate, then multiplied by your outstanding balance. For example, a 24% APR means a 2% monthly rate. On a $5,000 balance, that's $100 in interest the first month. As you pay down the balance, the interest charge decreases each month. This calculator uses this standard monthly compounding method to project your payoff timeline."
      }
    },
    {
      "@type": "Question",
      "name": "How can I pay off my credit card faster?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most effective strategies include: paying more than the minimum every month (even $50 extra makes a big difference), making bi-weekly payments instead of monthly, applying windfalls like tax refunds or bonuses to your balance, transferring to a lower-rate card, negotiating a lower APR with your card issuer, and stopping new charges on the card while paying it down. Use the what-if section of our calculator to see how different payment amounts change your payoff timeline."
      }
    },
    {
      "@type": "Question",
      "name": "Should I pay more than the minimum payment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. Paying more than the minimum is one of the most impactful financial decisions you can make. On a $5,000 balance at 22% APR, paying $200/month instead of the $100 minimum saves over $3,000 in interest and gets you debt-free years sooner. Even an extra $25-50/month makes a meaningful difference. The calculator's what-if comparison shows you exactly how much time and money you save with different payment amounts."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I only make minimum payments on my credit card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Making only minimum payments means most of your payment goes to interest rather than reducing your balance. A $5,000 balance at 20% APR with a 2% minimum payment ($100 initial, declining over time) can take over 30 years to pay off and cost more in interest than the original balance. Credit card companies are required to show on your statement how long it will take to pay off at the minimum — and the numbers are often shocking."
      }
    }
  ]
};

export const meta = {
  title: "Credit Card Payoff Calculator — How Long to Pay Off Credit Card | firemaths.info",
  description: "Calculate how long to pay off your credit card, total interest paid, and compare payment strategies. See the minimum payment trap, what-if scenarios, balance transfer savings, and a visual payoff timeline.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Credit Card Payoff Calculator — How Long to Pay Off Credit Card | firemaths.info"
  description="Calculate how long to pay off your credit card, total interest paid, and compare payment strategies. See the minimum payment trap, what-if scenarios, balance transfer savings, and a visual payoff timeline."
  canonical="https://firemaths.info/credit-card-payoff-calculator" schema={schema}
>
  <style>
:root {
    --color-primary: #4A90E2;
    --color-danger: #E25C5C;
    --color-saved: #50E3C2;
    --color-warning: #D4A017;
    --color-whatif: #9B59B6;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.25rem;
}

@media (max-width: 767px) {
    .input-row {
        grid-template-columns: 1fr;
    }
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], input[type="text"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus {
    outline: none;
    border-color: var(--accent-color);
}

select {
    font-family: var(--font-ui);
    cursor: pointer;
}

select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

/* Results grid */
.results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

@media (max-width: 767px) {
    .results-grid {
        grid-template-columns: 1fr;
    }
}

.result-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
}

.result-card-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
}

.result-card-value {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
}

.result-card-sub {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

.result-card.highlight {
    border-color: var(--color-danger);
    border-width: 2px;
}

.result-card.highlight .result-card-value {
    color: var(--color-danger);
}

/* Minimum payment trap */
.trap-banner {
    background: linear-gradient(135deg, rgba(226, 92, 92, 0.08), rgba(226, 92, 92, 0.02));
    border: 1px solid rgba(226, 92, 92, 0.25);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.trap-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-danger);
    margin-bottom: 1rem;
}

.trap-comparison {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    align-items: center;
}

@media (max-width: 767px) {
    .trap-comparison {
        grid-template-columns: 1fr;
        text-align: center;
    }
    .trap-vs { display: none; }
}

.trap-col {
    text-align: center;
}

.trap-col-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.trap-col-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
}

.trap-col-sub {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

.trap-vs {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-secondary);
}

/* What-if section */
.whatif-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-top: 3px solid var(--color-whatif);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.whatif-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--color-whatif);
}

.whatif-results {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-top: 1.25rem;
}

@media (max-width: 767px) {
    .whatif-results {
        grid-template-columns: 1fr;
    }
}

.whatif-result {
    text-align: center;
    padding: 1rem;
    background: rgba(155, 89, 182, 0.06);
    border-radius: 8px;
}

.whatif-result-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.whatif-result-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-whatif);
}

.whatif-result-sub {
    font-size: 0.75rem;
    color: var(--color-saved);
    margin-top: 0.25rem;
    font-weight: 600;
}

/* Balance transfer */
.bt-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-top: 3px solid var(--color-saved);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.bt-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--color-saved);
}

.bt-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.25rem;
}

@media (max-width: 767px) {
    .bt-inputs {
        grid-template-columns: 1fr;
    }
}

.bt-results {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
}

@media (max-width: 767px) {
    .bt-results {
        grid-template-columns: 1fr;
    }
}

.bt-method {
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.bt-method-title {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
}

.bt-method.current .bt-method-title { color: var(--text-secondary); }
.bt-method.transfer .bt-method-title { color: var(--color-saved); }

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
}

.bt-savings {
    text-align: center;
    padding: 1rem;
    margin-top: 1rem;
    background: rgba(80, 227, 194, 0.08);
    border-radius: 8px;
    border: 1px solid rgba(80, 227, 194, 0.2);
}

.bt-savings-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
}

.bt-savings-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-saved);
}

/* Chart */
.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.chart-section h2 {
    text-align: center;
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
}

.chart-container {
    width: 100%;
    height: 400px;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
}

.chart-legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
}

.chart-legend-color {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
}

/* Schedule table */
.section-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.section-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
}

.export-btn {
    padding: 0.5rem 1rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 6px;
    transition: all 0.2s;
}

.export-btn:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

.amort-table-wrap {
    overflow-x: auto;
    max-height: 500px;
    overflow-y: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.amort-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    white-space: nowrap;
}

.amort-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
}

.amort-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    text-align: right;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--border-color);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.amort-table th:first-child {
    text-align: center;
}

.amort-table td {
    padding: 0.5rem 0.75rem;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-secondary);
}

.amort-table td:first-child {
    text-align: center;
    color: var(--text-primary);
}

.amort-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

/* Tips */
.tips-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.tips-section h2 {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.tip-item {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.tip-item:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
}

.tip-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(74, 144, 226, 0.15);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
}

.tip-content h3 {
    font-size: 0.9375rem;
    margin-bottom: 0.25rem;
}

.tip-content p {
    font-size: 0.875rem;
    color: var(--text-secondary);
}

/* SEO content */
.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

/* FAQ */
.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.25rem 0;
}

.faq-question {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-size: 1rem;
}

.faq-answer {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
}

/* Related links */
.related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
    margin-bottom: 4rem;
}

.related-link {
    display: block;
    padding: 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    transition: border-color 0.2s;
}

.related-link:hover {
    border-color: var(--accent-color);
}

.related-link span {
    display: block;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Credit Card Payoff Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:3rem;">See how long it takes to pay off your credit card, total interest cost, and how to get debt-free faster.</p>

    <main>
        <!-- Card inputs -->
        <div class="scenario-card">
            <div class="scenario-header">
                <h2>Your Credit Card</h2>
            </div>
            <div class="input-row">
                <div class="input-group">
                    <label for="balance">Current Balance</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="balance" value="5000" min="0" step="100">
                    </div>
                </div>
                <div class="input-group">
                    <label for="apr">Annual Percentage Rate (APR)</label>
                    <div class="input-wrapper has-suffix">
                        <span class="suffix">%</span>
                        <input type="number" id="apr" value="22.99" min="0" max="50" step="0.01">
                    </div>
                </div>
                <div class="input-group">
                    <label for="payment-type">Payment Type</label>
                    <select id="payment-type">
                        <option value="fixed">Fixed Monthly Payment</option>
                        <option value="minimum">Minimum Payment Only</option>
                    </select>
                </div>
            </div>
            <div class="input-row" id="payment-inputs">
                <div class="input-group" id="fixed-payment-group">
                    <label for="monthly-payment">Monthly Payment</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="monthly-payment" value="200" min="0" step="10">
                    </div>
                </div>
                <div class="input-group" id="min-payment-group" style="display:none;">
