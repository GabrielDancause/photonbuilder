</div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let currentMode = 'payment';
let schedule = [];

function setMode(mode) {
    currentMode = mode;
    document.getElementById('mode-payment').classList.toggle('active', mode === 'payment');
    document.getElementById('mode-target').classList.toggle('active', mode === 'target');
    document.getElementById('payment-inputs').style.display = mode === 'payment' ? 'block' : 'none';
    document.getElementById('target-inputs').style.display = mode === 'target' ? 'block' : 'none';

    if (mode === 'payment') {
        document.getElementById('res-fourth-label').innerText = 'Monthly Payment';
    } else {
        document.getElementById('res-fourth-label').innerText = 'Required Payment';
    }

    calculate();
}
window.setMode = setMode;

function calculatePayoff(balance, apr, monthlyPayment) {
    if (balance <= 0 || monthlyPayment <= 0) return { schedule: [], totalInterest: 0, months: 0 };

    const monthlyRate = apr / 100 / 12;

    // Check if payment covers interest
    const firstInterest = balance * monthlyRate;
    if (monthlyPayment <= firstInterest && apr > 0) {
        return { schedule: [], totalInterest: -1, months: -1 }; // never pays off
    }

    const rows = [];
    let remaining = balance;
    let totalInterest = 0;
    let month = 0;
    const maxMonths = 600;

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        const interest = remaining * monthlyRate;
        let payment = Math.min(monthlyPayment, remaining + interest);
        const principal = payment - interest;
        remaining -= principal;
        if (remaining < 0.01) remaining = 0;
        totalInterest += interest;

        rows.push({
            month,
            payment,
            principal,
            interest,
            balance: remaining,
            totalInterest
        });
    }

    return { schedule: rows, totalInterest, months: month };
}

function calculateRequiredPayment(balance, apr, targetMonths) {
    if (balance <= 0 || targetMonths <= 0) return 0;
    if (apr === 0) return balance / targetMonths;

    const monthlyRate = apr / 100 / 12;
    // PMT formula: P * r * (1+r)^n / ((1+r)^n - 1)
    const pow = Math.pow(1 + monthlyRate, targetMonths);
    return balance * monthlyRate * pow / (pow - 1);
}

function calculateMinPayment(balance, apr) {
    // Simulate minimum payments: 2% of balance or $25, whichever is greater
    if (balance <= 0) return { totalInterest: 0, months: 0 };

    const monthlyRate = apr / 100 / 12;
    let remaining = balance;
    let totalInterest = 0;
    let month = 0;
    const maxMonths = 600;

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        const interest = remaining * monthlyRate;
        const minPayment = Math.max(remaining * 0.02, 25);
        let payment = Math.min(minPayment, remaining + interest);

        if (payment <= interest && apr > 0) {
            return { totalInterest: -1, months: -1 };
        }

        const principal = payment - interest;
        remaining -= principal;
        if (remaining < 0.01) remaining = 0;
        totalInterest += interest;
    }

    return { totalInterest, months: month };
}

function formatMonths(m) {
    if (m <= 0) return 'Never';
    const years = Math.floor(m / 12);
    const months = m % 12;
    if (years === 0) return months + ' mo';
    if (months === 0) return years + ' yr';
    return years + ' yr ' + months + ' mo';
}

function futureDate(monthsFromNow) {
    if (monthsFromNow <= 0) return '—';
    const d = new Date();
    d.setMonth(d.getMonth() + monthsFromNow);
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function calculate() {
    let balance, apr, monthlyPayment, targetMonths;

    if (currentMode === 'payment') {
        balance = parseFloat(document.getElementById('balance').value) || 0;
        apr = parseFloat(document.getElementById('apr').value) || 0;
        monthlyPayment = parseFloat(document.getElementById('monthly-payment').value) || 0;
    } else {
        balance = parseFloat(document.getElementById('balance-t').value) || 0;
        apr = parseFloat(document.getElementById('apr-t').value) || 0;
        targetMonths = parseInt(document.getElementById('target-months').value) || 0;
        monthlyPayment = calculateRequiredPayment(balance, apr, targetMonths);
    }

    if (balance <= 0) {
        clearResults();
        return;
    }

    const result = calculatePayoff(balance, apr, monthlyPayment);
    schedule = result.schedule;

    if (result.months === -1) {
        // Payment doesn't cover interest
        document.getElementById('res-months').innerText = 'Never';
        document.getElementById('res-date').innerText = 'Payment too low';
        document.getElementById('res-interest').innerText = '\u221E';
        document.getElementById('res-interest-pct').innerText = 'exceeds payment';
        document.getElementById('res-total').innerText = '\u221E';
        document.getElementById('res-fourth').innerText = fmt(monthlyPayment);
        document.getElementById('res-fourth-sub').innerText = 'covers interest only';
        document.getElementById('trap-section').style.display = 'none';
        document.getElementById('amort-tbody').innerHTML = '';
        return;
    }

    // Update results
    document.getElementById('res-months').innerText = formatMonths(result.months);
    document.getElementById('res-date').innerText = futureDate(result.months);
    document.getElementById('res-interest').innerText = fmt(result.totalInterest);
    const pct = balance > 0 ? Math.round(result.totalInterest / balance * 100) : 0;
    document.getElementById('res-interest-pct').innerText = pct + '% of balance';
    document.getElementById('res-total').innerText = fmt(balance + result.totalInterest);

    if (currentMode === 'payment') {
        document.getElementById('res-fourth').innerText = fmt(monthlyPayment);
        document.getElementById('res-fourth-sub').innerText = 'per month';
    } else {
        document.getElementById('res-fourth').innerText = fmt2(monthlyPayment);
        document.getElementById('res-fourth-sub').innerText = 'per month needed';
    }

    // Minimum payment trap
    const minResult = calculateMinPayment(balance, apr);
    const trapSection = document.getElementById('trap-section');

    if (minResult.months > 0 && minResult.months !== result.months) {
        trapSection.style.display = 'block';

        document.getElementById('trap-min-time').innerText = formatMonths(minResult.months);
        document.getElementById('trap-min-interest').innerText = fmt(minResult.totalInterest) + ' in interest';
        document.getElementById('trap-fix-time').innerText = formatMonths(result.months);
        document.getElementById('trap-fix-interest').innerText = fmt(result.totalInterest) + ' in interest';

        const savedInterest = minResult.totalInterest - result.totalInterest;
        const savedMonths = minResult.months - result.months;
        if (savedInterest > 0) {
            document.getElementById('trap-savings').innerText =
                'Your fixed payment saves you ' + fmt(savedInterest) + ' in interest and ' + formatMonths(savedMonths) + ' of payments';
        } else {
            document.getElementById('trap-savings').innerText = '';
        }
    } else if (minResult.months === -1) {
        trapSection.style.display = 'block';
        document.getElementById('trap-min-time').innerText = '30+ years';
        document.getElementById('trap-min-interest').innerText = 'effectively never pays off';
        document.getElementById('trap-fix-time').innerText = formatMonths(result.months);
        document.getElementById('trap-fix-interest').innerText = fmt(result.totalInterest) + ' in interest';
        document.getElementById('trap-savings').innerText = 'Your fixed payment gets you out of debt \u2014 minimum payments never will';
    } else {
        trapSection.style.display = 'none';
    }

    renderAmortTable();
    drawChart();
}

function clearResults() {
    document.getElementById('res-months').innerText = '0';
    document.getElementById('res-date').innerText = '\u2014';
    document.getElementById('res-interest').innerText = '$0';
    document.getElementById('res-interest-pct').innerText = '0% of balance';
    document.getElementById('res-total').innerText = '$0';
    document.getElementById('res-fourth').innerText = '$0';
    document.getElementById('res-fourth-sub').innerHTML = '&nbsp;';
    document.getElementById('trap-section').style.display = 'none';
    document.getElementById('amort-tbody').innerHTML = '';
    schedule = [];
}

function renderAmortTable() {
    const tbody = document.getElementById('amort-tbody');
    let html = '';
    for (const row of schedule) {
        html += '<tr><td>' + row.month + '</td><td>' + fmt2(row.payment) + '</td><td>' + fmt2(row.principal) + '</td><td>' + fmt2(row.interest) + '</td><td>' + fmt2(row.balance) + '</td><td>' + fmt2(row.totalInterest) + '</td></tr>';
    }
    tbody.innerHTML = html;
}

function drawChart() {
    const canvas = document.getElementById('balanceChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    if (schedule.length === 0) return;

    const padding = { top: 30, right: 20, bottom: 40, left: 65 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    const maxMonths = schedule.length;
    const startBalance = schedule[0].balance + schedule[0].principal;
    const maxInterest = schedule[schedule.length - 1].totalInterest;
    const maxVal = Math.max(startBalance, maxInterest) * 1.05;

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    var gridLines = 5;
    for (var i = 0; i <= gridLines; i++) {
        var y = padding.top + (chartH / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();

        var val = maxVal - (maxVal / gridLines) * i;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        if (val >= 1000) {
            ctx.fillText('$' + Math.round(val / 1000) + 'k', padding.left - 8, y);
        } else {
            ctx.fillText('$' + Math.round(val), padding.left - 8, y);
        }
    }

    // X-axis labels
    var xStep = maxMonths > 60 ? 12 : maxMonths > 24 ? 6 : maxMonths > 12 ? 3 : 1;
    for (var m = 0; m <= maxMonths; m += xStep) {
        if (m === 0) continue;
        var x = padding.left + (m / maxMonths) * chartW;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText(m >= 12 ? Math.round(m / 12) + 'yr' : m + 'mo', x, padding.top + chartH + 8);
    }

    // Draw balance line
    ctx.beginPath();
    ctx.strokeStyle = '#4A90E2';
    ctx.lineWidth = 2.5;
    ctx.moveTo(padding.left, padding.top + chartH - (startBalance / maxVal) * chartH);
    for (var i = 0; i < schedule.length; i++) {
        var x = padding.left + ((i + 1) / maxMonths) * chartW;
        var y = padding.top + chartH - (schedule[i].balance / maxVal) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Draw cumulative interest line
    ctx.beginPath();
    ctx.strokeStyle = '#E25C5C';
    ctx.lineWidth = 2.5;
    ctx.moveTo(padding.left, padding.top + chartH);
    for (var i = 0; i < schedule.length; i++) {
        var x = padding.left + ((i + 1) / maxMonths) * chartW;
        var y = padding.top + chartH - (schedule[i].totalInterest / maxVal) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Fill area under balance line
    ctx.beginPath();
    ctx.fillStyle = 'rgba(74, 144, 226, 0.08)';
    ctx.moveTo(padding.left, padding.top + chartH - (startBalance / maxVal) * chartH);
    for (var i = 0; i < schedule.length; i++) {
        var x = padding.left + ((i + 1) / maxMonths) * chartW;
        var y = padding.top + chartH - (schedule[i].balance / maxVal) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.lineTo(padding.left + chartW, padding.top + chartH);
    ctx.lineTo(padding.left, padding.top + chartH);
    ctx.closePath();
    ctx.fill();
}

window.exportCSV = function() {
    if (schedule.length === 0) return;
    var csv = 'Month,Payment,Principal,Interest,Balance,Cumulative Interest\n';
    for (var i = 0; i < schedule.length; i++) {
        var row = schedule[i];
        csv += row.month + ',' + row.payment.toFixed(2) + ',' + row.principal.toFixed(2) + ',' + row.interest.toFixed(2) + ',' + row.balance.toFixed(2) + ',' + row.totalInterest.toFixed(2) + '\n';
    }
    var blob = new Blob([csv], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'credit-card-payoff-schedule.csv';
    a.click();
    URL.revokeObjectURL(url);
};

// Attach input listeners
['balance', 'apr', 'monthly-payment', 'balance-t', 'apr-t', 'target-months'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', calculate);
});

window.addEventListener('resize', function() {
    if (schedule.length > 0) drawChart();
});

// Initial calculation
calculate();
  </script>
</SiteLayout>
