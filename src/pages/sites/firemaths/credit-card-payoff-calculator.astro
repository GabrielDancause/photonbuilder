  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let scheduleData = [];

function simulatePayoff(balance, apr, monthlyPayment) {
    if (balance <= 0 || monthlyPayment <= 0) return { schedule: [], totalInterest: 0, months: 0 };

    const monthlyRate = apr / 100 / 12;
    const firstInterest = balance * monthlyRate;
    if (monthlyPayment <= firstInterest) {
        return { schedule: [], totalInterest: Infinity, months: Infinity };
    }

    const schedule = [];
    let remaining = balance;
    let totalInterest = 0;
    let totalPrincipal = 0;
    let month = 0;
    const maxMonths = 600;

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        const interest = remaining * monthlyRate;
        let payment = Math.min(monthlyPayment, remaining + interest);
        const principal = payment - interest;

        remaining -= principal;
        if (remaining < 0.01) remaining = 0;

        totalInterest += interest;
        totalPrincipal += principal;

        schedule.push({
            month,
            payment,
            principal,
            interest,
            balance: remaining,
            totalInterest,
            totalPrincipal
        });
    }

    return { schedule, totalInterest, months: month };
}

function simulateMinPayment(balance, apr) {
    if (balance <= 0) return { totalInterest: 0, months: 0, totalPaid: 0 };

    const monthlyRate = apr / 100 / 12;
    let remaining = balance;
    let totalInterest = 0;
    let totalPaid = 0;
    let month = 0;
    const maxMonths = 600;

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        const interest = remaining * monthlyRate;
        let minPayment = Math.max(remaining * 0.02, 25);
        let payment = Math.min(minPayment, remaining + interest);

        if (payment <= interest && remaining > 0.01) {
            return { totalInterest: Infinity, months: Infinity, totalPaid: Infinity };
        }

        const principal = payment - interest;
        remaining -= principal;
        if (remaining < 0.01) remaining = 0;

        totalInterest += interest;
        totalPaid += payment;
    }

    return { totalInterest, months: month, totalPaid };
}

function formatMonths(m) {
    if (m === Infinity || m >= 600) return '30+ years';
    if (m === 0) return '0';
    const years = Math.floor(m / 12);
    const months = m % 12;
    if (years === 0) return months + ' mo';
    if (months === 0) return years + ' yr';
    return years + ' yr ' + months + ' mo';
}

function futureDate(monthsFromNow) {
    if (monthsFromNow === 0 || monthsFromNow === Infinity) return '—';
    const d = new Date();
    d.setMonth(d.getMonth() + monthsFromNow);
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function calculate() {
    const balance = parseFloat(document.getElementById('balance').value) || 0;
    const apr = parseFloat(document.getElementById('apr').value) || 0;
    const payment = parseFloat(document.getElementById('payment').value) || 0;

    if (balance <= 0 || payment <= 0) {
        document.getElementById('res-months').innerText = '0';
        document.getElementById('res-date').innerText = '—';
        document.getElementById('res-interest').innerText = '$0';
        document.getElementById('res-interest-pct').innerText = '0% of balance';
        document.getElementById('res-total').innerText = '$0';
        document.getElementById('res-principal-ratio').innerText = '$0 principal + $0 interest';
        document.getElementById('whatif-tbody').innerHTML = '';
        document.getElementById('amort-tbody').innerHTML = '';
        scheduleData = [];
        return;
    }

    const result = simulatePayoff(balance, apr, payment);
    scheduleData = result.schedule;

    if (result.months === Infinity) {
        document.getElementById('res-months').innerText = 'Never';
        document.getElementById('res-date').innerText = 'Payment too low';
        document.getElementById('res-interest').innerText = '\u221E';
        document.getElementById('res-interest-pct').innerText = "Payment doesn't cover interest";
        document.getElementById('res-total').innerText = '\u221E';
        document.getElementById('res-principal-ratio').innerText = 'Increase your monthly payment';
    } else {
        document.getElementById('res-months').innerText = formatMonths(result.months);
        document.getElementById('res-date').innerText = 'Debt-free ' + futureDate(result.months);
        document.getElementById('res-interest').innerText = fmt(result.totalInterest);
        const pct = balance > 0 ? Math.round(result.totalInterest / balance * 100) : 0;
        document.getElementById('res-interest-pct').innerText = pct + '% of your balance';
        document.getElementById('res-total').innerText = fmt(balance + result.totalInterest);
        document.getElementById('res-principal-ratio').innerText = fmt(balance) + ' principal + ' + fmt(result.totalInterest) + ' interest';
    }

    buildWhatIfTable(balance, apr, payment);
    buildAmortTable(result.schedule);
    drawChart(result.schedule, balance);
    buildTrapSection(balance, apr, payment, result);
}

function buildWhatIfTable(balance, apr, currentPayment) {
    const monthlyRate = apr / 100 / 12;
    const minInterest = balance * monthlyRate;
    const minPay = Math.max(balance * 0.02, 25);
    const amounts = new Set();

    if (minPay > minInterest) amounts.add(Math.round(minPay));

    const candidates = [50, 100, 150, 200, 250, 300, 400, 500, 750, 1000];
    for (const c of candidates) {
        if (c > minInterest && c <= balance * 1.1) amounts.add(c);
    }

    amounts.add(Math.round(currentPayment));

    const sortedAmounts = [...amounts].sort((a, b) => a - b);
    const baseResult = simulatePayoff(balance, apr, sortedAmounts[0]);

    const tbody = document.getElementById('whatif-tbody');
    let html = '';

    for (const amt of sortedAmounts) {
        const r = simulatePayoff(balance, apr, amt);
        const isCurrent = amt === Math.round(currentPayment);
        const isMin = amt === Math.round(minPay);
        let rowClass = '';
        if (isCurrent) rowClass = 'current-row';
        else if (isMin) rowClass = 'min-row';

        if (r.months === Infinity) {
            html += '<tr class="' + rowClass + '"><td>' + fmt(amt) + (isMin ? ' (min)' : '') + (isCurrent ? ' \u2190' : '') + '</td><td>Never</td><td>\u221E</td><td>\u221E</td><td>\u2014</td></tr>';
        } else {
            const baseInterest = baseResult.totalInterest === Infinity ? r.totalInterest : baseResult.totalInterest;
            const saved = baseInterest - r.totalInterest;
            html += '<tr class="' + rowClass + '">' +
                '<td>' + fmt(amt) + (isMin ? ' (min)' : '') + (isCurrent ? ' \u2190' : '') + '</td>' +
                '<td>' + formatMonths(r.months) + '</td>' +
                '<td>' + fmt(r.totalInterest) + '</td>' +
                '<td>' + fmt(balance + r.totalInterest) + '</td>' +
                '<td class="' + (saved > 0 ? 'savings-cell' : '') + '">' + (saved > 0 ? fmt(saved) : '\u2014') + '</td>' +
                '</tr>';
        }
    }

    tbody.innerHTML = html;
}

function buildAmortTable(schedule) {
    const tbody = document.getElementById('amort-tbody');
    let html = '';
    for (const row of schedule) {
        html += '<tr>' +
            '<td>' + row.month + '</td>' +
            '<td>' + fmt2(row.payment) + '</td>' +
            '<td>' + fmt2(row.principal) + '</td>' +
            '<td>' + fmt2(row.interest) + '</td>' +
            '<td>' + fmt2(row.balance) + '</td>' +
            '<td>' + fmt2(row.totalInterest) + '</td>' +
            '</tr>';
    }
    tbody.innerHTML = html;
}

function buildTrapSection(balance, apr, userPayment, userResult) {
    const minResult = simulateMinPayment(balance, apr);
    const monthlyRate = apr / 100 / 12;
    const firstInterest = balance * monthlyRate;
    const minPay = Math.max(balance * 0.02, 25);

    if (minResult.months === Infinity) {
        document.getElementById('trap-min-months').innerText = '30+ years';
        document.getElementById('trap-min-interest').innerText = '\u221E';
        document.getElementById('trap-min-total').innerText = '\u221E';
    } else {
        document.getElementById('trap-min-months').innerText = formatMonths(minResult.months);
        document.getElementById('trap-min-interest').innerText = fmt(minResult.totalInterest);
        document.getElementById('trap-min-total').innerText = fmt(minResult.totalPaid);
    }

    if (userResult.months === Infinity) {
        document.getElementById('trap-your-months').innerText = 'Never';
        document.getElementById('trap-your-interest').innerText = '\u221E';
        document.getElementById('trap-savings').innerText = '\u2014';
    } else {
        document.getElementById('trap-your-months').innerText = formatMonths(userResult.months);
        document.getElementById('trap-your-interest').innerText = fmt(userResult.totalInterest);
        if (minResult.totalInterest !== Infinity) {
            const saved = minResult.totalInterest - userResult.totalInterest;
            document.getElementById('trap-savings').innerText = saved > 0 ? fmt(saved) + ' in interest' : '\u2014';
        } else {
            document.getElementById('trap-savings').innerText = 'You actually pay it off';
        }
    }

    const firstPrincipal = minPay - firstInterest;
    const principalPct = minPay > 0 ? Math.round((firstPrincipal / minPay) * 100) : 0;
    const interestPct = 100 - principalPct;

    document.getElementById('trap-explanation').innerHTML =
        'With a <strong>' + fmt2(balance) + '</strong> balance at <strong>' + apr + '% APR</strong>, the minimum payment starts at <strong>' + fmt2(minPay) + '</strong>. ' +
        'Of that first minimum payment, <strong>' + fmt2(firstInterest) + '</strong> (' + interestPct + '%) goes to interest and only <strong>' + fmt2(Math.max(0, firstPrincipal)) + '</strong> (' + Math.max(0, principalPct) + '%) goes to principal. ' +
        (minResult.months !== Infinity
            ? 'At minimum payments, it takes <strong>' + formatMonths(minResult.months) + '</strong> and you pay <strong>' + fmt(minResult.totalInterest) + '</strong> in interest \u2014 that\'s <strong>' + Math.round(minResult.totalInterest / balance * 100) + '%</strong> of your original balance in pure interest charges.'
            : 'At this rate, the minimum payment barely covers interest \u2014 you\'d be paying for decades.');

    document.getElementById('trap-math').innerHTML =
        '<strong>Monthly rate:</strong> ' + apr + '% \u00F7 12 = ' + (apr / 12).toFixed(4) + '%<br>' +
        '<strong>First month interest:</strong> ' + fmt2(balance) + ' \u00D7 ' + (apr / 12).toFixed(4) + '% = ' + fmt2(firstInterest) + '<br>' +
        '<strong>Min payment (2% of balance):</strong> ' + fmt2(balance) + ' \u00D7 2% = ' + fmt2(balance * 0.02) + (balance * 0.02 < 25 ? ' \u2192 $25.00 floor' : '') + '<br>' +
        '<strong>Principal paid:</strong> ' + fmt2(minPay) + ' \u2212 ' + fmt2(firstInterest) + ' = ' + fmt2(Math.max(0, firstPrincipal));
}

function drawChart(data, initialBalance) {
    const canvas = document.getElementById('payoffChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    if (data.length === 0) return;

    const padding = { top: 30, right: 20, bottom: 40, left: 65 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    const maxMonths = data.length;
    const maxValue = initialBalance * 1.1;

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    const gridLines = 5;
    for (let i = 0; i <= gridLines; i++) {
        const y = padding.top + (chartH / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();

        const val = maxValue - (maxValue / gridLines) * i;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        if (val >= 1000) {
            ctx.fillText('$' + Math.round(val / 1000) + 'k', padding.left - 8, y);
        } else {
            ctx.fillText('$' + Math.round(val), padding.left - 8, y);
        }
    }

    // X-axis labels
    const xStep = maxMonths > 60 ? 12 : maxMonths > 24 ? 6 : maxMonths > 12 ? 3 : 1;
    for (let m = 0; m <= maxMonths; m += xStep) {
        if (m === 0) continue;
        const x = padding.left + (m / maxMonths) * chartW;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText(m >= 12 ? Math.round(m / 12) + 'yr' : m + 'mo', x, padding.top + chartH + 8);
    }

    function drawLine(getData, color, fill) {
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2.5;

        const startX = padding.left;
        const startVal = getData(-1);
        const startY = padding.top + chartH - (startVal / maxValue) * chartH;
        ctx.moveTo(startX, startY);

        for (let i = 0; i < data.length; i++) {
            const x = padding.left + ((i + 1) / maxMonths) * chartW;
            const val = getData(i);
            const y = padding.top + chartH - (val / maxValue) * chartH;
            ctx.lineTo(x, y);
        }
        ctx.stroke();

        if (fill) {
            ctx.lineTo(padding.left + chartW, padding.top + chartH);
            ctx.lineTo(padding.left, padding.top + chartH);
            ctx.closePath();
            ctx.fillStyle = fill;
            ctx.fill();
        }
    }

    // Balance line with fill
    drawLine(
        function(i) { return i === -1 ? initialBalance : data[i].balance; },
        '#4A90E2',
        'rgba(74, 144, 226, 0.08)'
    );

    // Cumulative interest line
    drawLine(
        function(i) { return i === -1 ? 0 : data[i].totalInterest; },
        '#E25C5C',
        false
    );

    // Cumulative principal line
    drawLine(
        function(i) { return i === -1 ? 0 : data[i].totalPrincipal; },
        '#50E3C2',
        false
    );
}

window.exportCSV = function() {
    if (scheduleData.length === 0) return;

    var csv = 'Month,Payment,Principal,Interest,Balance,Total Interest\n';
    for (var j = 0; j < scheduleData.length; j++) {
        var row = scheduleData[j];
        csv += row.month + ',' + row.payment.toFixed(2) + ',' + row.principal.toFixed(2) + ',' + row.interest.toFixed(2) + ',' + row.balance.toFixed(2) + ',' + row.totalInterest.toFixed(2) + '\n';
    }

    var blob = new Blob([csv], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'credit-card-payoff-schedule.csv';
    a.click();
    URL.revokeObjectURL(url);
};

// Attach listeners
document.getElementById('balance').addEventListener('input', calculate);
document.getElementById('apr').addEventListener('input', calculate);
document.getElementById('payment').addEventListener('input', calculate);

window.addEventListener('resize', function() {
    if (scheduleData.length > 0) {
        var balance = parseFloat(document.getElementById('balance').value) || 0;
        drawChart(scheduleData, balance);
    }
});

// Initialize
calculate();
  </script>
