---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Credit Card Payoff Calculator",
  "url": "https://firemaths.info/credit-card-payoff-calculator",
  "description": "Calculate how long it takes to pay off your credit card or find the monthly payment needed to be debt-free by a target date. See total interest, payoff chart, and the real cost of minimum payments.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long will it take to pay off my credit card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The time to pay off a credit card depends on your balance, APR, and monthly payment. For example, a $5,000 balance at 22% APR with $150/month payments takes about 46 months and costs over $1,800 in interest. Paying only the minimum (2% of balance, $25 floor) could take over 20 years and cost more than the original balance in interest alone. Use this calculator to see your exact timeline."
      }
    },
    {
      "@type": "Question",
      "name": "How is credit card interest calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Credit card interest is calculated using your Annual Percentage Rate (APR) divided by 12 to get the monthly rate. Each month, the monthly rate is multiplied by your outstanding balance to determine that month's interest charge. For a 22% APR, the monthly rate is about 1.83%. On a $5,000 balance, that's roughly $91.67 in interest the first month. As you pay down the balance, the interest charge decreases each month."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I only make minimum payments on my credit card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Making only minimum payments is the most expensive way to pay off credit card debt. Most card issuers set the minimum at 1-3% of your balance or a flat floor (typically $25-35), whichever is greater. Because the payment shrinks as your balance drops, most of each payment goes to interest rather than principal. A $5,000 balance at 22% APR with 2% minimum payments could take over 20 years and cost $7,000+ in total interest — more than the original debt."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I pay on my credit card each month?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pay as much as you can afford beyond the minimum. Even an extra $50-100 per month makes a dramatic difference. On a $5,000 balance at 22% APR, paying $200/month instead of the $100 minimum saves you over $3,000 in interest and gets you debt-free 8+ years sooner. Use the 'Impact of Paying More' table in this calculator to see exactly how much each extra dollar saves you."
      }
    },
    {
      "@type": "Question",
      "name": "What is the credit card minimum payment trap?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The minimum payment trap occurs because credit card minimums are designed to keep you in debt as long as possible. As your balance decreases, so does your minimum payment, meaning less goes toward principal each month. This creates a self-reinforcing cycle where payoff takes decades. Card companies profit from this because you end up paying far more in interest than your original purchase. The CARD Act of 2009 now requires issuers to show how long minimum payments take on your statement."
      }
    },
    {
      "@type": "Question",
      "name": "Should I pay off my credit card or save money first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In most cases, pay off high-interest credit card debt first. Credit card APRs (typically 18-28%) far exceed savings account returns (4-5%). Every dollar used to pay down a 22% APR card effectively 'earns' 22% — far better than any savings account. The exception: keep a small emergency fund ($500-1,000) before aggressively paying debt, so unexpected expenses don't force you back onto the credit card."
      }
    },
    {
      "@type": "Question",
      "name": "Does paying more than the minimum hurt my credit score?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No — paying more than the minimum helps your credit score. It reduces your credit utilization ratio (the percentage of your credit limit you're using), which is the second most important factor in your credit score after payment history. Lower utilization signals responsible credit use. Aim to keep utilization below 30%, and ideally below 10%, for the best score impact."
      }
    }
  ]
};

export const meta = {
  title: "Credit Card Payoff Calculator — How Long to Pay Off Credit Card | firemaths.info",
  description: "Calculate how long to pay off your credit card, find the payment needed to be debt-free by a target date, and see total interest paid. Includes payoff chart and minimum payment trap analysis.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Credit Card Payoff Calculator — How Long to Pay Off Credit Card | firemaths.info"
  description="Calculate how long to pay off your credit card, find the payment needed to be debt-free by a target date, and see total interest paid. Includes payoff chart and minimum payment trap analysis."
  canonical="https://firemaths.info/credit-card-payoff-calculator" schema={schema}
>
  <style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 640px;
    margin: 0 auto;
}

.card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.card-title {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.input-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
}

@media (min-width: 640px) {
    .input-row { grid-template-columns: 1fr 1fr; }
    .input-row.three-col { grid-template-columns: 1fr 1fr 1fr; }
}

.input-group {
    margin-bottom: 0.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

select {
    font-family: var(--font-ui);
    cursor: pointer;
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

/* Mode Tabs */
.mode-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-color);
}

.mode-tab {
    flex: 1;
    padding: 0.75rem 1rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    background-color: var(--bg-color);
    color: var(--text-secondary);
    transition: all 0.2s;
    text-align: center;
}

.mode-tab:not(:last-child) {
    border-right: 1px solid var(--border-color);
}

.mode-tab.active {
    background-color: var(--accent-color);
    color: #fff;
}

.mode-tab:hover:not(.active) {
    background-color: var(--card-bg);
    color: var(--text-primary);
}

.mode-section { display: none; }
.mode-section.active { display: block; }

/* Results */
.results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
}

@media (max-width: 639px) {
    .results-grid { grid-template-columns: 1fr; }
}

.result-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
}

.result-card .label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
}

.result-card .value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.result-card .sub {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

.result-card.highlight {
    border-color: var(--accent-color);
}

.error-msg {
    color: #ff6b6b;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    display: none;
}

/* Chart */
.chart-container {
    position: relative;
    height: 300px;
    margin-bottom: 0.5rem;
}

.chart-canvas {
    width: 100%;
    height: 100%;
}

/* Impact Table */
.impact-table-wrap {
    overflow-x: auto;
}

.impact-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.impact-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    background-color: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 2px solid var(--border-color);
}

.impact-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.85rem;
}

.impact-table tr:hover td {
    background-color: var(--bg-color);
}

.impact-table .saved {
    color: #50E3C2;
    font-weight: 600;
}

.impact-table .current-row td {
    background-color: rgba(99,102,241,0.08);
    font-weight: 600;
}

/* Min Payment Trap Visual */
.trap-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 1.5rem 0;
}

@media (max-width: 639px) {
    .trap-visual { grid-template-columns: 1fr; }
}

.trap-bar-group {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
}

.trap-bar-group h4 {
    font-size: 0.9rem;
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.trap-bar {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
    gap: 0.75rem;
}

.trap-bar:last-child { margin-bottom: 0; }

.trap-bar-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    min-width: 80px;
    text-align: right;
}

.trap-bar-track {
    flex: 1;
    height: 28px;
    background-color: var(--bg-color);
    border-radius: 6px;
    overflow: hidden;
    position: relative;
}

.trap-bar-fill {
    height: 100%;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-mono);
    color: #fff;
    transition: width 0.6s ease;
    min-width: fit-content;
}

.fill-interest { background-color: #E25C5C; }
.fill-principal { background-color: #50E3C2; }
.fill-time { background-color: var(--accent-color); }

.trap-callout {
    background: linear-gradient(135deg, rgba(226,92,92,0.1) 0%, rgba(226,92,92,0.02) 100%);
    border: 1px solid rgba(226,92,92,0.3);
    border-radius: 12px;
    padding: 1.25rem;
    margin-top: 1.5rem;
}

.trap-callout h4 {
    color: #E25C5C;
    font-size: 1rem;
    margin-bottom: 0.5rem;
}

.trap-callout p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.trap-callout .big-number {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: #E25C5C;
    display: block;
    margin: 0.5rem 0;
}

/* FAQ */
.faq-section { margin-bottom: 2rem; }

.faq-item {
    border-bottom: 1px solid var(--border-color);
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    padding: 1.25rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-ui);
    gap: 1rem;
}

.faq-question:hover { color: var(--accent-color); }

.faq-icon {
    flex-shrink: 0;
    transition: transform 0.2s;
    color: var(--text-secondary);
    font-size: 1.25rem;
}

.faq-item.open .faq-icon { transform: rotate(45deg); }

.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
}

.faq-answer-inner {
    padding: 0 0 1.25rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
}

/* SEO Content */
.seo-content { margin-bottom: 3rem; }

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content h3 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul, .seo-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li { margin-bottom: 0.5rem; }

.related-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
}

@media (max-width: 639px) {
    .related-links { grid-template-columns: 1fr; }
}

.related-link {
    display: block;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    transition: all 0.2s;
}

.related-link:hover {
    border-color: var(--accent-color);
    transform: translateY(-2px);
}

.related-link h4 {
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
}

.related-link p {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin: 0;
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
}

footer a:hover {
    text-decoration: underline;
}
  </style>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="container">
    <header>
      <h1>Credit Card Payoff Calculator</h1>
      <p>See how long it takes to pay off your credit card, find the payment to be debt-free by a target date, and understand the true cost of minimum payments.</p>
    </header>

    <main>
      <!-- Inputs -->
      <div class="card">
        <h2 class="card-title">Your Credit Card Details</h2>
        <div class="input-row three-col">
          <div class="input-group">
            <label for="balance">Current Balance</label>
            <div class="input-wrapper has-prefix">
              <span class="prefix">$</span>
              <input type="number" id="balance" value="5000" min="0" step="100">
            </div>
          </div>
          <div class="input-group">
            <label for="apr">Annual Percentage Rate (APR)</label>
            <div class="input-wrapper has-suffix">
              <span class="suffix">%</span>
              <input type="number" id="apr" value="22" min="0" max="100" step="0.1">
            </div>
          </div>
          <div class="input-group">
            <label for="min-type">Minimum Payment Type</label>
            <select id="min-type">
              <option value="percent">Percentage of Balance</option>
              <option value="fixed">Fixed Dollar Amount</option>
            </select>
          </div>
        </div>
        <div class="input-row" style="margin-top:1rem;">
          <div class="input-group" id="min-percent-group">
            <label for="min-percent">Minimum Payment Rate</label>
            <div class="input-wrapper has-suffix">
              <span class="suffix">%</span>
              <input type="number" id="min-percent" value="2" min="1" max="100" step="0.5">
            </div>
          </div>
          <div class="input-group" id="min-fixed-group" style="display:none;">
            <label for="min-fixed">Fixed Minimum Payment</label>
            <div class="input-wrapper has-prefix">
              <span class="prefix">$</span>
              <input type="number" id="min-fixed" value="50" min="1" step="5">
            </div>
          </div>
          <div class="input-group">
            <label for="min-floor">Minimum Payment Floor</label>
            <div class="input-wrapper has-prefix">
              <span class="prefix">$</span>
              <input type="number" id="min-floor" value="25" min="0" step="5">
            </div>
          </div>
        </div>
      </div>

      <!-- Mode Tabs -->
      <div class="mode-tabs">
        <button class="mode-tab active" data-mode="payoff-time" onclick="switchMode('payoff-time')">How Long to Pay Off</button>
        <button class="mode-tab" data-mode="target-payment" onclick="switchMode('target-payment')">Payment for Target Date</button>
      </div>

      <!-- Mode 1: How long at current payment -->
      <div class="mode-section active" id="mode-payoff-time">
        <div class="card">
          <h2 class="card-title">Your Monthly Payment</h2>
          <div class="input-row">
            <div class="input-group">
              <label for="monthly-payment">Fixed Monthly Payment</label>
              <div class="input-wrapper has-prefix">
                <span class="prefix">$</span>
                <input type="number" id="monthly-payment" value="200" min="0" step="10">
              </div>
              <div id="payment-error" class="error-msg">Payment is too low to cover monthly interest.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mode 2: Payment to pay off in X months -->
      <div class="mode-section" id="mode-target-payment">
        <div class="card">
          <h2 class="card-title">Target Payoff Timeline</h2>
          <div class="input-row">
            <div class="input-group">
              <label for="target-months">Pay Off In</label>
              <div class="input-wrapper has-suffix">
                <span class="suffix">months</span>
                <input type="number" id="target-months" value="24" min="1" max="360" step="1" style="padding-right:5rem;">
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div class="results-grid" id="results">
        <div class="result-card highlight">
          <div class="label" id="primary-label">Time to Payoff</div>
          <div class="value" id="primary-value">--</div>
          <div class="sub" id="primary-sub"></div>
        </div>
        <div class="result-card">
          <div class="label">Total Interest</div>
          <div class="value" id="result-interest">--</div>
          <div class="sub" id="interest-sub"></div>
        </div>
        <div class="result-card">
          <div class="label">Total Amount Paid</div>
          <div class="value" id="result-total">--</div>
          <div class="sub" id="total-sub"></div>
        </div>
      </div>

      <!-- Payoff Chart -->
      <div class="card">
        <h2 class="card-title">Balance Over Time</h2>
        <div class="chart-container">
          <canvas id="payoff-chart" class="chart-canvas"></canvas>
        </div>
      </div>

      <!-- Impact of Paying More -->
      <div class="card">
        <h2 class="card-title">Impact of Paying More</h2>
        <p style="color:var(--text-secondary);font-size:0.9rem;margin-bottom:1.25rem;">See how extra monthly payments accelerate your payoff and reduce interest.</p>
        <div class="impact-table-wrap">
          <table class="impact-table" id="impact-table">
            <thead>
              <tr>
                <th>Monthly Payment</th>
                <th>Payoff Time</th>
                <th>Total Interest</th>
                <th>Interest Saved</th>
                <th>Time Saved</th>
              </tr>
            </thead>
            <tbody id="impact-body"></tbody>
          </table>
        </div>
      </div>

      <!-- Minimum Payment Trap -->
      <div class="card">
        <h2 class="card-title">The Minimum Payment Trap</h2>
        <p style="color:var(--text-secondary);font-size:0.9rem;margin-bottom:1rem;">Here's what happens to your first minimum payment — and why it keeps you in debt.</p>

        <div class="trap-visual">
          <div class="trap-bar-group">
            <h4>Where Your First Minimum Payment Goes</h4>
            <div class="trap-bar">
              <span class="trap-bar-label">Interest</span>
              <div class="trap-bar-track">
                <div class="trap-bar-fill fill-interest" id="trap-interest-bar" style="width:0%"></div>
              </div>
            </div>
            <div class="trap-bar">
              <span class="trap-bar-label">Principal</span>
              <div class="trap-bar-track">
                <div class="trap-bar-fill fill-principal" id="trap-principal-bar" style="width:0%"></div>
              </div>
            </div>
          </div>

          <div class="trap-bar-group">
            <h4>Payoff Timeline Comparison</h4>
            <div class="trap-bar">
              <span class="trap-bar-label">Minimum</span>
              <div class="trap-bar-track">
                <div class="trap-bar-fill fill-interest" id="trap-min-time-bar" style="width:0%"></div>
              </div>
            </div>
            <div class="trap-bar">
              <span class="trap-bar-label">Double</span>
              <div class="trap-bar-track">
                <div class="trap-bar-fill fill-time" id="trap-double-time-bar" style="width:0%"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="trap-callout">
          <h4>The Real Cost of Minimum Payments</h4>
          <p>With minimum payments only, you'll pay a total of:</p>
          <span class="big-number" id="trap-total-cost">--</span>
          <p>That's <strong id="trap-multiplier">--</strong> your original balance of <strong id="trap-original">--</strong> in total interest alone.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="card faq-section">
        <h2 class="card-title">Frequently Asked Questions</h2>
        <div id="faq-list">
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
              <span>How long will it take to pay off my credit card?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">The time to pay off a credit card depends on your balance, APR, and monthly payment. For example, a $5,000 balance at 22% APR with $150/month payments takes about 46 months and costs over $1,800 in interest. Paying only the minimum (2% of balance, $25 floor) could take over 20 years and cost more than the original balance in interest alone. Use this calculator to see your exact timeline.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
              <span>How is credit card interest calculated?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">Credit card interest is calculated using your Annual Percentage Rate (APR) divided by 12 to get the monthly rate. Each month, the monthly rate is multiplied by your outstanding balance to determine that month's interest charge. For a 22% APR, the monthly rate is about 1.83%. On a $5,000 balance, that's roughly $91.67 in interest the first month. As you pay down the balance, the interest charge decreases.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
              <span>What happens if I only make minimum payments?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">Making only minimum payments is the most expensive way to pay off credit card debt. Most issuers set the minimum at 1-3% of your balance or a flat floor (typically $25-35), whichever is greater. Because the payment shrinks as your balance drops, most of each payment goes to interest rather than principal. A $5,000 balance at 22% APR with 2% minimum payments could take over 20 years and cost $7,000+ in total interest.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
              <span>How much should I pay on my credit card each month?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">Pay as much as you can afford beyond the minimum. Even an extra $50-100 per month makes a dramatic difference. On a $5,000 balance at 22% APR, paying $200/month instead of the $100 minimum saves you over $3,000 in interest and gets you debt-free 8+ years sooner. Use the "Impact of Paying More" table above to see exactly how much each extra dollar saves you.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
              <span>What is the credit card minimum payment trap?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">The minimum payment trap occurs because credit card minimums are designed to keep you in debt as long as possible. As your balance decreases, so does your minimum payment, meaning less goes toward principal each month. This creates a self-reinforcing cycle where payoff takes decades. Card companies profit because you end up paying far more in interest than your original purchases. The CARD Act of 2009 now requires issuers to show how long minimum payments take on your statement.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
              <span>Should I pay off my credit card or save money first?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">In most cases, pay off high-interest credit card debt first. Credit card APRs (typically 18-28%) far exceed savings account returns (4-5%). Every dollar used to pay down a 22% APR card effectively "earns" 22%. The exception: keep a small emergency fund ($500-1,000) before aggressively paying debt, so unexpected expenses don't force you back onto the credit card.</div>
            </div>
          </div>
          <div class="faq-item">
            <button class="faq-question" onclick="toggleFaq(this)">
              <span>Does paying more than the minimum hurt my credit score?</span>
              <span class="faq-icon">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">No — paying more than the minimum helps your credit score. It reduces your credit utilization ratio (the percentage of your credit limit you're using), which is the second most important factor in your credit score after payment history. Lower utilization signals responsible credit use. Aim to keep utilization below 30%, and ideally below 10%, for the best score impact.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- SEO Content -->
      <div class="seo-content">
        <h2>How to Pay Off Credit Card Debt Faster</h2>
        <p>Credit card debt is one of the most expensive forms of consumer debt, with average APRs exceeding 22% in 2026. The compounding nature of credit card interest means that even moderate balances can take decades to pay off when you stick to minimum payments. Understanding how your payments break down between interest and principal is the first step toward a faster payoff strategy.</p>
        <p>This credit card payoff calculator helps you see exactly how long your current payment plan will take, how much interest you'll pay, and — most importantly — how much you can save by increasing your monthly payment even slightly.</p>

        <h2>Understanding Credit Card Interest</h2>
        <p>Credit card interest compounds monthly. Your APR is divided by 12 to get the monthly periodic rate, which is then applied to your outstanding balance. For a card with 22% APR:</p>
        <ul>
          <li><strong>Monthly rate:</strong> 22% / 12 = 1.833%</li>
          <li><strong>First month interest on $5,000:</strong> $5,000 x 1.833% = $91.67</li>
          <li><strong>At $200/month payment:</strong> Only $108.33 goes to principal in month one</li>
        </ul>
        <p>As your balance decreases, more of each payment goes toward principal and less toward interest, which is why payoff accelerates over time — but only if you maintain a fixed payment amount rather than letting it drop with the minimum.</p>

        <h3>Why Minimum Payments Keep You in Debt</h3>
        <p>Credit card minimum payments are typically calculated as a percentage of your balance (usually 1-3%) or a flat floor amount ($25-35), whichever is greater. This design means your required payment shrinks as your balance shrinks, creating a cycle that can stretch payoff to 20+ years. On a $5,000 balance at 22% APR, minimum payments (2%, $25 floor) result in paying more in interest than the original balance.</p>

        <h2>Strategies to Accelerate Credit Card Payoff</h2>
        <ul>
          <li><strong>Set a fixed payment above the minimum:</strong> Even $50 extra per month cuts years off your timeline and saves thousands in interest.</li>
          <li><strong>Use the debt avalanche method:</strong> If you have multiple cards, pay minimums on all and put extra toward the highest-APR card first to minimize total interest.</li>
          <li><strong>Use the debt snowball method:</strong> Pay off smallest balances first for quick psychological wins that keep you motivated.</li>
          <li><strong>Balance transfer:</strong> Move high-APR debt to a 0% introductory rate card, but pay it off before the promotional period ends.</li>
          <li><strong>Bi-weekly payments:</strong> Pay half your monthly amount every two weeks — you'll make 26 half-payments (13 full payments) per year instead of 12.</li>
        </ul>

        <h2>Related Calculators</h2>
        <div class="related-links">
          <a href="/debt-snowball-calculator" class="related-link">
            <h4>Debt Snowball Calculator</h4>
            <p>Compare snowball vs avalanche strategies for multiple debts.</p>
          </a>
          <a href="/amortization-schedule-calculator" class="related-link">
            <h4>Amortization Schedule Calculator</h4>
            <p>See a month-by-month breakdown of any loan's payments.</p>
          </a>
        </div>
      </div>
    </main>
  </div>

  <script is:inline>
    const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 2 }).format(v);
    const fmtMonths = (m) => {
      if (!isFinite(m) || m <= 0) return 'Never';
      const y = Math.floor(m / 12), mo = Math.ceil(m % 12);
      const parts = [];
      if (y > 0) parts.push(`${y} yr${y !== 1 ? 's' : ''}`);
      if (mo > 0 || y === 0) parts.push(`${mo} mo${mo !== 1 ? 's' : ''}`);
      return parts.join(' ');
    };

    let currentMode = 'payoff-time';

    window.switchMode = (mode) => {
      currentMode = mode;
      document.querySelectorAll('.mode-tab').forEach(t => t.classList.toggle('active', t.dataset.mode === mode));
      document.querySelectorAll('.mode-section').forEach(s => s.classList.remove('active'));
      document.getElementById('mode-' + mode).classList.add('active');
      calculate();
    };

    window.toggleFaq = (btn) => {
      const item = btn.closest('.faq-item');
      const answer = item.querySelector('.faq-answer');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-answer').style.maxHeight = '0';
      });
      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    };

    function getMinPayment(balance) {
      const minType = document.getElementById('min-type').value;
      const floor = parseFloat(document.getElementById('min-floor').value) || 25;
      if (minType === 'fixed') {
        return parseFloat(document.getElementById('min-fixed').value) || 50;
      }
      const pct = (parseFloat(document.getElementById('min-percent').value) || 2) / 100;
      return Math.max(balance * pct, floor);
    }

    function calcPayoff(balance, apr, payment) {
      const r = (apr / 100) / 12;
      let bal = balance, months = 0, totalInt = 0;
      const balances = [balance];
      if (payment <= bal * r && r > 0) return { months: Infinity, interest: Infinity, total: Infinity, valid: false, balances };
      while (bal > 0.01 && months < 1200) {
        const interest = bal * r;
        totalInt += interest;
        const pmt = Math.min(payment, bal + interest);
        bal -= (pmt - interest);
        if (bal < 0) bal = 0;
        months++;
        balances.push(bal);
      }
      return { months, interest: totalInt, total: balance + totalInt, valid: true, balances };
    }

    function calcMinPayoff(balance, apr) {
      const r = (apr / 100) / 12;
      let bal = balance, months = 0, totalInt = 0, totalPaid = 0;
      const balances = [balance];
      while (bal > 0.01 && months < 1200) {
        const interest = bal * r;
        totalInt += interest;
        let pmt = getMinPayment(bal);
        if (pmt <= interest) pmt = interest + bal * 0.01;
        const floor = parseFloat(document.getElementById('min-floor').value) || 25;
        if (pmt < floor) pmt = floor;
        if (pmt > bal + interest) pmt = bal + interest;
        totalPaid += pmt;
        bal -= (pmt - interest);
        if (bal < 0) bal = 0;
        months++;
        balances.push(bal);
      }
      return { months, interest: totalInt, total: totalPaid, balances, firstPayment: getMinPayment(balance) };
    }

    function calcTargetPayment(balance, apr, months) {
      const r = (apr / 100) / 12;
      if (r === 0) return balance / months;
      return (r * balance) / (1 - Math.pow(1 + r, -months));
    }

    function drawChart(balances) {
      const canvas = document.getElementById('payoff-chart');
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.scale(dpr, dpr);
      const w = rect.width, h = rect.height;
      const pad = { top: 20, right: 20, bottom: 40, left: 70 };

      ctx.clearRect(0, 0, w, h);
      if (balances.length < 2) return;

      const maxBal = Math.max(...balances);
      const totalMonths = balances.length - 1;
      const plotW = w - pad.left - pad.right;
      const plotH = h - pad.top - pad.bottom;

      const styles = getComputedStyle(document.documentElement);
      const borderColor = styles.getPropertyValue('--border-color').trim() || '#333';
      const textSecondary = styles.getPropertyValue('--text-secondary').trim() || '#888';
      const accent = styles.getPropertyValue('--accent-color').trim() || '#6366f1';

      // Grid
      const gridLines = 5;
      ctx.strokeStyle = borderColor;
      ctx.lineWidth = 0.5;
      ctx.font = '11px system-ui, sans-serif';
      ctx.fillStyle = textSecondary;
      ctx.textAlign = 'right';

      for (let i = 0; i <= gridLines; i++) {
        const y = pad.top + (plotH / gridLines) * i;
        const val = maxBal - (maxBal / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(w - pad.right, y);
        ctx.stroke();
        ctx.fillText('$' + Math.round(val).toLocaleString(), pad.left - 8, y + 4);
      }

      // X-axis
      ctx.textAlign = 'center';
      const xTicks = Math.min(totalMonths, 8);
      for (let i = 0; i <= xTicks; i++) {
        const mo = Math.round((totalMonths / xTicks) * i);
        const x = pad.left + (mo / totalMonths) * plotW;
        ctx.fillText(mo + 'mo', x, h - pad.bottom + 20);
      }

      // Area fill
      ctx.beginPath();
      ctx.moveTo(pad.left, pad.top + plotH);
      for (let i = 0; i < balances.length; i++) {
        const x = pad.left + (i / totalMonths) * plotW;
        const y = pad.top + plotH - (balances[i] / maxBal) * plotH;
        ctx.lineTo(x, y);
      }
      ctx.lineTo(pad.left + plotW, pad.top + plotH);
      ctx.closePath();
      const grad = ctx.createLinearGradient(0, pad.top, 0, pad.top + plotH);
      grad.addColorStop(0, accent + '30');
      grad.addColorStop(1, accent + '05');
      ctx.fillStyle = grad;
      ctx.fill();

      // Line
      ctx.beginPath();
      for (let i = 0; i < balances.length; i++) {
        const x = pad.left + (i / totalMonths) * plotW;
        const y = pad.top + plotH - (balances[i] / maxBal) * plotH;
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.strokeStyle = accent;
      ctx.lineWidth = 2.5;
      ctx.stroke();
    }

    function buildImpactTable(balance, apr) {
      const tbody = document.getElementById('impact-body');
      tbody.innerHTML = '';
      const r = (apr / 100) / 12;
      if (r === 0 || balance <= 0) return;

      const minRes = calcMinPayoff(balance, apr);
      const firstMin = minRes.firstPayment;
      const roundedMin = Math.ceil(firstMin / 10) * 10;

      const payments = [];
      // Build list: min-based increments
      const step = balance < 2000 ? 25 : balance < 10000 ? 50 : 100;
      for (let p = roundedMin; p <= balance; p += step) {
        if (p <= balance * r) continue;
        payments.push(p);
        if (payments.length >= 10) break;
      }

      // Include current payment if in payoff-time mode
      const currentPmt = currentMode === 'payoff-time' ? parseFloat(document.getElementById('monthly-payment').value) || 0 : 0;
      if (currentPmt > balance * r && !payments.includes(currentPmt)) {
        payments.push(currentPmt);
        payments.sort((a, b) => a - b);
      }

      payments.forEach(pmt => {
        const res = calcPayoff(balance, apr, pmt);
        if (!res.valid) return;
        const tr = document.createElement('tr');
        const isCurrent = currentMode === 'payoff-time' && pmt === currentPmt;
        if (isCurrent) tr.className = 'current-row';

        const timeSaved = minRes.months - res.months;
        const intSaved = minRes.interest - res.interest;

        tr.innerHTML = `
          <td>${fmt(pmt)}/mo</td>
          <td>${fmtMonths(res.months)}</td>
          <td>${fmt(res.interest)}</td>
          <td class="saved">${intSaved > 0 ? '-' + fmt(intSaved) : '--'}</td>
          <td class="saved">${timeSaved > 0 ? fmtMonths(timeSaved) : '--'}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    function updateTrap(balance, apr) {
      const r = (apr / 100) / 12;
      if (r === 0 || balance <= 0) return;

      const minRes = calcMinPayoff(balance, apr);
      const firstPmt = minRes.firstPayment;
      const firstInterest = balance * r;
      const firstPrincipal = Math.max(firstPmt - firstInterest, 0);

      // Where first payment goes
      const intPct = (firstInterest / firstPmt) * 100;
      const prinPct = (firstPrincipal / firstPmt) * 100;
      document.getElementById('trap-interest-bar').style.width = Math.min(intPct, 100) + '%';
      document.getElementById('trap-interest-bar').textContent = fmt(firstInterest);
      document.getElementById('trap-principal-bar').style.width = Math.max(prinPct, 2) + '%';
      document.getElementById('trap-principal-bar').textContent = fmt(firstPrincipal);

      // Time comparison
      const doubleRes = calcPayoff(balance, apr, firstPmt * 2);
      document.getElementById('trap-min-time-bar').style.width = '100%';
      document.getElementById('trap-min-time-bar').textContent = fmtMonths(minRes.months);
      const doublePct = doubleRes.valid ? Math.max((doubleRes.months / minRes.months) * 100, 5) : 50;
      document.getElementById('trap-double-time-bar').style.width = doublePct + '%';
      document.getElementById('trap-double-time-bar').textContent = doubleRes.valid ? fmtMonths(doubleRes.months) : '--';

      // Callout
      document.getElementById('trap-total-cost').textContent = fmt(minRes.total);
      document.getElementById('trap-original').textContent = fmt(balance);
      const multiplier = balance > 0 ? (minRes.interest / balance).toFixed(1) : 0;
      document.getElementById('trap-multiplier').textContent = multiplier + 'x';
    }

    function calculate() {
      const balance = parseFloat(document.getElementById('balance').value) || 0;
      const apr = parseFloat(document.getElementById('apr').value) || 0;
      if (balance <= 0) return;

      const errEl = document.getElementById('payment-error');

      if (currentMode === 'payoff-time') {
        const pmt = parseFloat(document.getElementById('monthly-payment').value) || 0;
        const res = calcPayoff(balance, apr, pmt);

        if (!res.valid) {
          errEl.style.display = 'block';
          document.getElementById('primary-label').textContent = 'Time to Payoff';
          document.getElementById('primary-value').textContent = 'Never';
          document.getElementById('primary-sub').textContent = 'Payment doesn\'t cover interest';
          document.getElementById('result-interest').textContent = '--';
          document.getElementById('interest-sub').textContent = '';
          document.getElementById('result-total').textContent = '--';
          document.getElementById('total-sub').textContent = '';
          return;
        }

        errEl.style.display = 'none';
        document.getElementById('primary-label').textContent = 'Time to Payoff';
        document.getElementById('primary-value').textContent = fmtMonths(res.months);
        document.getElementById('primary-sub').textContent = `at ${fmt(pmt)}/mo`;
        document.getElementById('result-interest').textContent = fmt(res.interest);
        document.getElementById('interest-sub').textContent = `${((res.interest / balance) * 100).toFixed(0)}% of balance`;
        document.getElementById('result-total').textContent = fmt(res.total);
        document.getElementById('total-sub').textContent = `${fmt(balance)} principal + interest`;

        drawChart(res.balances);

      } else {
        const months = parseInt(document.getElementById('target-months').value) || 1;
        const pmt = calcTargetPayment(balance, apr, months);
        const res = calcPayoff(balance, apr, pmt);

        document.getElementById('primary-label').textContent = 'Required Payment';
        document.getElementById('primary-value').textContent = fmt(pmt);
        document.getElementById('primary-sub').textContent = `to pay off in ${fmtMonths(months)}`;
        document.getElementById('result-interest').textContent = fmt(res.interest);
        document.getElementById('interest-sub').textContent = `${((res.interest / balance) * 100).toFixed(0)}% of balance`;
        document.getElementById('result-total').textContent = fmt(res.total);
        document.getElementById('total-sub').textContent = `${fmt(balance)} principal + interest`;
        errEl.style.display = 'none';

        drawChart(res.balances);
      }

      buildImpactTable(balance, apr);
      updateTrap(balance, apr);
    }

    // Min type toggle
    document.getElementById('min-type').addEventListener('change', (e) => {
      const isFixed = e.target.value === 'fixed';
      document.getElementById('min-percent-group').style.display = isFixed ? 'none' : '';
      document.getElementById('min-fixed-group').style.display = isFixed ? '' : 'none';
      calculate();
    });

    // Event listeners
    document.querySelectorAll('input[type="number"], select').forEach(el => {
      el.addEventListener('input', calculate);
    });

    // Resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(calculate, 150);
    });

    // Init
    calculate();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">Complete Guide</p>
      <a href="/guide-debt-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">How to Get Out of Debt: The Complete Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide &rarr;</p>
      </a>
    </div>
  </div>
</SiteLayout>
