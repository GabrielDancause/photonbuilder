}

function renderSchedule() {
    const tbody = document.getElementById('schedule-tbody');
    let html = '';
    for (const row of scheduleData) {
        html += '<tr><td>' + row.month + '</td><td>' + fmt2(row.payment) + '</td><td>' + fmt2(row.principal) + '</td><td>' + fmt2(row.interest) + '</td><td>' + fmt(row.balance) + '</td></tr>';
    }
    tbody.innerHTML = html;
}

function drawChart(data) {
    const canvas = document.getElementById('payoffChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    if (data.length === 0) return;

    const padding = { top: 30, right: 20, bottom: 40, left: 65 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    const maxMonths = data.length;
    const startBalance = data[0].balance + data[0].principal;
    const maxVal = Math.max(startBalance, data[data.length - 1].totalInterest) * 1.1;

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    var gridLines = 5;
    for (var i = 0; i <= gridLines; i++) {
        var y = padding.top + (chartH / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();

        var val = maxVal - (maxVal / gridLines) * i;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        if (val >= 1000) {
            ctx.fillText('$' + Math.round(val / 1000) + 'k', padding.left - 8, y);
        } else {
            ctx.fillText('$' + Math.round(val), padding.left - 8, y);
        }
    }

    // X-axis labels
    var xStep = maxMonths > 60 ? 12 : maxMonths > 24 ? 6 : maxMonths > 12 ? 3 : 1;
    for (var m = 0; m <= maxMonths; m += xStep) {
        if (m === 0) continue;
        var x = padding.left + (m / maxMonths) * chartW;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText(m >= 12 ? Math.round(m / 12) + 'yr' : m + 'mo', x, padding.top + chartH + 8);
    }

    // Balance line
    ctx.beginPath();
    ctx.strokeStyle = '#4A90E2';
    ctx.lineWidth = 2.5;
    ctx.moveTo(padding.left, padding.top + chartH - (startBalance / maxVal) * chartH);
    for (var i = 0; i < data.length; i++) {
        var x = padding.left + ((i + 1) / maxMonths) * chartW;
        var y = padding.top + chartH - (data[i].balance / maxVal) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Fill under balance line
    ctx.lineTo(padding.left + chartW, padding.top + chartH);
    ctx.lineTo(padding.left, padding.top + chartH);
    ctx.closePath();
    ctx.fillStyle = 'rgba(74, 144, 226, 0.08)';
    ctx.fill();

    // Cumulative interest line
    ctx.beginPath();
    ctx.strokeStyle = '#E25C5C';
    ctx.lineWidth = 2.5;
    ctx.moveTo(padding.left, padding.top + chartH);
    for (var i = 0; i < data.length; i++) {
        var x = padding.left + ((i + 1) / maxMonths) * chartW;
        var y = padding.top + chartH - (data[i].totalInterest / maxVal) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.stroke();
}

window.exportCSV = function() {
    if (scheduleData.length === 0) return;
    var csv = 'Month,Payment,Principal,Interest,Remaining Balance\n';
    for (var i = 0; i < scheduleData.length; i++) {
        var row = scheduleData[i];
        csv += row.month + ',' + row.payment.toFixed(2) + ',' + row.principal.toFixed(2) + ',' + row.interest.toFixed(2) + ',' + row.balance.toFixed(2) + '\n';
    }
    var blob = new Blob([csv], { type: 'text/csv' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'credit-card-payoff-schedule.csv';
    a.click();
    URL.revokeObjectURL(url);
};

