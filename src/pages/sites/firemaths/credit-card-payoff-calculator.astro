  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let scheduleData = [];

function simulatePayoff(balance, apr, paymentAmount, isFixed) {
    if (balance <= 0 || (isFixed && paymentAmount <= 0)) return { schedule: [], totalInterest: 0, months: 0 };

    const monthlyRate = apr / 100 / 12;
    const schedule = [];
    let totalInterest = 0;
    let remaining = balance;
    let month = 0;
    const maxMonths = 600;

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        const interest = remaining * monthlyRate;
        totalInterest += interest;

        let payment;
        if (isFixed) {
            payment = paymentAmount;
        } else {
            const minType = document.getElementById('min-type').value;
            if (minType === 'flat') {
                payment = parseFloat(document.getElementById('min-flat').value) || 25;
            } else {
                const pct = (parseFloat(document.getElementById('min-percent').value) || 2) / 100;
                payment = Math.max(remaining * pct, 25);
            }
        }

        payment = Math.min(payment, remaining + interest);

        if (payment <= interest && !isFixed) {
            payment = Math.max(payment, 25);
        }

        const principal = payment - interest;
        if (principal <= 0 && isFixed) {
            return { schedule: [], totalInterest: 0, months: -1 };
        }

        remaining = Math.max(0, remaining - principal);

        schedule.push({
            month,
            payment,
            principal: Math.max(0, principal),
            interest,
            balance: remaining,
            totalInterest
        });
    }

    return { schedule, totalInterest, months: month };
}

function simulateFixed(balance, apr, payment) {
    return simulatePayoff(balance, apr, payment, true);
}

function simulateMinimum(balance, apr) {
    return simulatePayoff(balance, apr, 0, false);
}

function simulateBalanceTransfer(balance, payment, introMonths, fee, postApr) {
    const transferFee = balance * (fee / 100);
    let remaining = balance + transferFee;
    let totalInterest = 0;
    let month = 0;
    const maxMonths = 600;

    while (remaining > 0.01 && month < maxMonths) {
        month++;
        let interest = 0;
        if (month > introMonths) {
            interest = remaining * (postApr / 100 / 12);
        }
        totalInterest += interest;

        const pmt = Math.min(payment, remaining + interest);
        const principal = pmt - interest;
        if (principal <= 0) return { totalInterest, totalFee: transferFee, totalPaid: 0, months: -1 };
        remaining = Math.max(0, remaining - principal);
    }

    return {
        totalInterest,
        totalFee: transferFee,
        totalPaid: balance + transferFee + totalInterest,
        months: month
    };
}

function formatMonths(m) {
    if (m <= 0) return 'N/A';
    const years = Math.floor(m / 12);
    const months = m % 12;
    if (years === 0) return months + ' mo';
    if (months === 0) return years + ' yr';
    return years + ' yr ' + months + ' mo';
}

function futureDate(monthsFromNow) {
    if (monthsFromNow <= 0) return '\u2014';
    const d = new Date();
    d.setMonth(d.getMonth() + monthsFromNow);
    return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function togglePaymentInputs() {
    const type = document.getElementById('payment-type').value;
    const fixedGroup = document.getElementById('fixed-payment-group');
    const minGroup = document.getElementById('min-payment-group');
    const minPercentGroup = document.getElementById('min-percent-group');
    const minFlatGroup = document.getElementById('min-flat-group');

    if (type === 'fixed') {
        fixedGroup.style.display = '';
        minGroup.style.display = 'none';
        minPercentGroup.style.display = 'none';
        minFlatGroup.style.display = 'none';
    } else {
        fixedGroup.style.display = 'none';
        minGroup.style.display = '';
        toggleMinInputs();
    }
    calculate();
}

function toggleMinInputs() {
    const minType = document.getElementById('min-type').value;
    const minPercentGroup = document.getElementById('min-percent-group');
    const minFlatGroup = document.getElementById('min-flat-group');

    if (minType === 'percent') {
        minPercentGroup.style.display = '';
        minFlatGroup.style.display = 'none';
    } else {
        minPercentGroup.style.display = 'none';
        minFlatGroup.style.display = '';
    }
    calculate();
}

function calculate() {
    const balance = parseFloat(document.getElementById('balance').value) || 0;
    const apr = parseFloat(document.getElementById('apr').value) || 0;
    const paymentType = document.getElementById('payment-type').value;
    const isFixed = paymentType === 'fixed';

    if (balance <= 0) {
        clearResults();
        return;
    }

    let result;
    let currentPayment;
    if (isFixed) {
        currentPayment = parseFloat(document.getElementById('monthly-payment').value) || 0;
        result = simulateFixed(balance, apr, currentPayment);
    } else {
        result = simulateMinimum(balance, apr);
        currentPayment = 0;
    }

    scheduleData = result.schedule;

    if (result.months <= 0 || result.schedule.length === 0) {
        document.getElementById('res-months').innerText = 'Never';
        document.getElementById('res-date').innerText = 'Payment too low';
        document.getElementById('res-interest').innerText = '\u2014';
        document.getElementById('res-interest-pct').innerText = '\u2014';
        document.getElementById('res-total').innerText = '\u2014';
        document.getElementById('res-effective-rate').innerText = '\u2014';
        return;
    }

    document.getElementById('res-months').innerText = formatMonths(result.months);
    document.getElementById('res-date').innerText = futureDate(result.months);
    document.getElementById('res-interest').innerText = fmt(result.totalInterest);
    document.getElementById('res-interest-pct').innerText = Math.round(result.totalInterest / balance * 100) + '% of balance';
    const totalPaid = balance + result.totalInterest;
    document.getElementById('res-total').innerText = fmt(totalPaid);
    document.getElementById('res-effective-rate').innerText = 'Effective cost: ' + Math.round(totalPaid / balance * 100) + '%';

    // Minimum payment trap
    const trapSection = document.getElementById('trap-section');
    if (isFixed && apr > 0) {
        const minResult = simulateMinimum(balance, apr);
        if (minResult.months > 0 && minResult.months > result.months) {
            trapSection.style.display = '';
            document.getElementById('trap-min-time').innerText = formatMonths(minResult.months);
            document.getElementById('trap-min-interest').innerText = fmt(minResult.totalInterest) + ' interest';
            document.getElementById('trap-your-time').innerText = formatMonths(result.months);
            document.getElementById('trap-your-interest').innerText = fmt(result.totalInterest) + ' interest';
            const interestSaved = minResult.totalInterest - result.totalInterest;
            const monthsSaved = minResult.months - result.months;
            document.getElementById('trap-savings').innerText = 'You save ' + fmt(interestSaved) + ' and get debt-free ' + formatMonths(monthsSaved) + ' sooner';
        } else {
            trapSection.style.display = 'none';
        }
    } else {
        trapSection.style.display = 'none';
    }

    calculateWhatIf(balance, apr, result);
    calculateBalanceTransfer(balance, apr, result, isFixed ? currentPayment : (result.schedule.length > 0 ? result.schedule[0].payment : 0));
    drawChart(result.schedule);
    renderSchedule();
}

function calculateWhatIf(balance, apr, baseResult) {
    const whatifPayment = parseFloat(document.getElementById('whatif-payment').value) || 0;
    const whatifResult = simulateFixed(balance, apr, whatifPayment);

    if (whatifResult.months <= 0) {
        document.getElementById('whatif-months').innerText = 'N/A';
        document.getElementById('whatif-interest').innerText = 'N/A';
        document.getElementById('whatif-total').innerText = 'N/A';
        document.getElementById('whatif-time-saved').innerText = '';
        document.getElementById('whatif-interest-saved').innerText = '';
        document.getElementById('whatif-total-saved').innerText = '';
        return;
    }

    document.getElementById('whatif-months').innerText = formatMonths(whatifResult.months);
    document.getElementById('whatif-interest').innerText = fmt(whatifResult.totalInterest);
    document.getElementById('whatif-total').innerText = fmt(balance + whatifResult.totalInterest);

    if (baseResult.months > 0) {
        const monthsDiff = baseResult.months - whatifResult.months;
        const interestDiff = baseResult.totalInterest - whatifResult.totalInterest;
        const timeSavedEl = document.getElementById('whatif-time-saved');
        const interestSavedEl = document.getElementById('whatif-interest-saved');

        if (monthsDiff > 0) {
            timeSavedEl.innerText = formatMonths(monthsDiff) + ' faster';
            timeSavedEl.style.color = '';
        } else if (monthsDiff < 0) {
            timeSavedEl.innerText = formatMonths(-monthsDiff) + ' slower';
            timeSavedEl.style.color = 'var(--color-danger)';
        } else {
            timeSavedEl.innerText = 'Same time';
            timeSavedEl.style.color = '';
        }

        if (interestDiff > 0) {
            interestSavedEl.innerText = 'Save ' + fmt(interestDiff);
            interestSavedEl.style.color = '';
        } else if (interestDiff < 0) {
            interestSavedEl.innerText = fmt(-interestDiff) + ' more';
            interestSavedEl.style.color = 'var(--color-danger)';
        } else {
            interestSavedEl.innerText = 'Same interest';
            interestSavedEl.style.color = '';
        }

        const totalDiff = baseResult.totalInterest - whatifResult.totalInterest;
        if (totalDiff > 0) {
            document.getElementById('whatif-total-saved').innerText = 'Save ' + fmt(totalDiff) + ' total';
            document.getElementById('whatif-total-saved').style.color = '';
        } else {
            document.getElementById('whatif-total-saved').innerText = '';
        }
    } else {
        document.getElementById('whatif-time-saved').innerText = '';
        document.getElementById('whatif-interest-saved').innerText = '';
        document.getElementById('whatif-total-saved').innerText = '';
    }
}

function calculateBalanceTransfer(balance, apr, baseResult, monthlyPayment) {
    const introMonths = parseInt(document.getElementById('bt-intro-months').value) || 0;
    const fee = parseFloat(document.getElementById('bt-fee').value) || 0;
    const postApr = parseFloat(document.getElementById('bt-post-apr').value) || 0;

    document.getElementById('bt-cur-interest').innerText = fmt(baseResult.totalInterest);
    document.getElementById('bt-cur-total').innerText = fmt(balance + baseResult.totalInterest);
    document.getElementById('bt-cur-months').innerText = formatMonths(baseResult.months);

    const payment = monthlyPayment > 0 ? monthlyPayment : 200;
    const btResult = simulateBalanceTransfer(balance, payment, introMonths, fee, postApr);

    const transferFee = balance * (fee / 100);
    document.getElementById('bt-fee-amount').innerText = fmt(transferFee);
    document.getElementById('bt-transfer-interest').innerText = fmt(btResult.totalInterest + transferFee);
    document.getElementById('bt-transfer-total').innerText = fmt(btResult.totalPaid);
    document.getElementById('bt-transfer-months').innerText = formatMonths(btResult.months);

    const savings = (balance + baseResult.totalInterest) - btResult.totalPaid;
    const savingsBox = document.getElementById('bt-savings-box');
    if (savings > 0) {
        document.getElementById('bt-savings-amount').innerText = fmt(savings);
        document.getElementById('bt-savings-amount').style.color = 'var(--color-saved)';
        savingsBox.querySelector('.bt-savings-label').innerText = 'Balance Transfer Saves You';
    } else if (savings < 0) {
        document.getElementById('bt-savings-amount').innerText = fmt(-savings);
        document.getElementById('bt-savings-amount').style.color = 'var(--color-danger)';
        savingsBox.querySelector('.bt-savings-label').innerText = 'Balance Transfer Costs You More';
    } else {
        document.getElementById('bt-savings-amount').innerText = '$0';
        savingsBox.querySelector('.bt-savings-label').innerText = 'No Difference';
    }
}

function clearResults() {
    document.getElementById('res-months').innerText = '0';
    document.getElementById('res-date').innerText = '\u2014';
    document.getElementById('res-interest').innerText = '$0';
    document.getElementById('res-interest-pct').innerText = '0% of balance';
