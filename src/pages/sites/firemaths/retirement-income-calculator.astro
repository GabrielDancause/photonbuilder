---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Retirement Income Calculator: How Long Will Your Savings Last?",
  "description": "Most retirees underestimate this crucial expense\u2014find out exactly when your portfolio might hit zero. Adjust your withdrawal rate and see the surprising results instantly.",
  "datePublished": "2026-03-11T00:00:00Z",
  "publisher": {
    "@type": "Organization",
    "name": "FireMaths",
    "url": "https://firemaths.info"
  },
  "author": {
    "@type": "Organization",
    "name": "FireMaths"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Retirement Income Calculator: How Long Will Your Savings Last?"
  description="Most retirees underestimate this crucial expense—find out exactly when your portfolio might hit zero. Adjust your withdrawal rate and see the surprising results instantly."
  canonical="https://firemaths.info/retirement-income-calculator.html" schema={schema}
>
  <!-- Sticky Navigation -->




<main class="max-w-4xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <!-- Inputs -->
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-6 shadow-sm">
            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="portfolio">Portfolio Size</label>
                <div class="relative flex items-center">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="portfolio" value="1000000" min="1000" step="10000">
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="withdrawal">Annual Withdrawal (Year 1)</label>
                <div class="relative flex items-center">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="withdrawal" value="40000" min="1000" step="1000">
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="returns">Expected Return (Nominal)</label>
                <div class="relative flex items-center">
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="inflation">Inflation Rate</label>
                <div class="relative flex items-center">
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="volatility">Market Volatility</label>
                <div class="relative flex items-center">
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                </div>
            </div>
        </div>

        <!-- Results -->
        <div class="results-container">
            <div class="kpi-grid">
                <div class="result-box highlight">
                    <div class="text-[var(--text-secondary)] text-sm font-semibold">Money Lasts</div>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2" id="res-years">30+ Years</div>
                    <div class="result-sub">Based on average returns</div>
                </div>

                <div class="result-box">
                    <div class="text-[var(--text-secondary)] text-sm font-semibold">Monte Carlo Success Rate</div>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2" id="res-success">92%</div>
                    <div class="result-sub">Probability of not running out</div>
                </div>
            </div>

            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <canvas id="portfolioChart"></canvas>
            </div>
        </div>
    </div>

    <!-- SEO Content & FAQ -->
    <article class="mt-16 mb-16">
        <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Retirement Drawdown Calculator: The 4% Rule Explained</h2>
        <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The <strong>4% rule</strong> is a widely discussed guideline for retirement withdrawals. It suggests that you can withdraw 4% of your initial portfolio value in your first year of retirement, then adjust that dollar amount for inflation every year thereafter, with a high probability that your money will last for a 30-year retirement.</p>
        <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">However, the 4% rule isn't perfect for everyone. If you retire early and need your money to last 40 or 50 years, a 4% withdrawal rate might be too aggressive. Testing your specific numbers using our retirement income calculator helps you visualize how different withdrawal rates, inflation, and market returns impact your portfolio's longevity.</p>

        <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Frequently Asked Questions</h2>

        <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
            <h3 class="text-xl font-bold text-white mt-6 mb-3">What is a retirement income calculator?</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">A retirement income calculator is a tool that projects how your savings and investments will perform over time when you start taking regular withdrawals. It accounts for market returns and inflation to estimate when your money might run out.</p>
        </div>

        <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
            <h3 class="text-xl font-bold text-white mt-6 mb-3">How long will my retirement savings last?</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">How long your retirement savings last depends on your starting portfolio size, your annual withdrawal amount, the inflation rate, and your investment returns. Using a Monte Carlo simulation can help provide a statistical probability of success, factoring in sequence of returns risk.</p>
        </div>

        <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
            <h3 class="text-xl font-bold text-white mt-6 mb-3">How do I use a retirement drawdown calculator?</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">To use a retirement drawdown calculator, input your total savings, the amount you plan to withdraw each year, and your expected rate of return and inflation. The calculator will model the drawdown phase of your retirement, showing you year-by-year balances.</p>
        </div>

        <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
            <h3 class="text-xl font-bold text-white mt-6 mb-3">Does the 4% rule work for early retirement?</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The 4% rule was designed for a 30-year traditional retirement. For early retirees planning for 40 to 50 years of withdrawals, a more conservative rate like 3% to 3.5% is often recommended to reduce the risk of outliving your money due to a longer timeline and inflation risk.</p>
        </div>

        <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
            <h3 class="text-xl font-bold text-white mt-6 mb-3">What happens if inflation is higher than expected?</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">High inflation erodes your purchasing power, meaning you have to withdraw more money to maintain your standard of living. This increases your withdrawal rate and significantly depletes your portfolio faster. Factoring in accurate inflation estimates is crucial for any retirement plan.</p>
        </div>
    </article>
</main>
  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
        const inputs = {
            portfolio: document.getElementById('portfolio'),
            withdrawal: document.getElementById('withdrawal'),
            returns: document.getElementById('returns'),
            inflation: document.getElementById('inflation'),
            volatility: document.getElementById('volatility')
        };

        const outputs = {
            years: document.getElementById('res-years'),
            success: document.getElementById('res-success')
        };

        const canvas = document.getElementById('portfolioChart');
        const ctx = canvas.getContext('2d');

        // Setup high-DPI canvas
        function resizeCanvas() {
            const rect = canvas.parentElement.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            canvas.width = rect.width * dpr;
            canvas.height = rect.height * dpr;
            ctx.scale(dpr, dpr);
            canvas.style.width = `${rect.width}px`;
            canvas.style.height = `${rect.height}px`;
        }

        window.addEventListener('resize', () => {
            resizeCanvas();
            calculate();
        });

        // Box-Muller transform for normal distribution
        function randomNormal() {
            let u = 0, v = 0;
            while(u === 0) u = Math.random();
            while(v === 0) v = Math.random();
            return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
        }

        function calculate() {
            const initialPortfolio = parseFloat(inputs.portfolio.value) || 0;
            const initialWithdrawal = parseFloat(inputs.withdrawal.value) || 0;
            const expectedReturn = (parseFloat(inputs.returns.value) || 0) / 100;
            const inflationRate = (parseFloat(inputs.inflation.value) || 0) / 100;
            const volatility = (parseFloat(inputs.volatility.value) || 0) / 100;

            const MAX_YEARS = 50;

            // 1. Deterministic Calculation (Average Returns)
            let balance = initialPortfolio;
            let withdrawal = initialWithdrawal;
            let yearsLasted = 0;
            const averageTrajectory = [balance];

            for (let i = 1; i <= MAX_YEARS; i++) {
                if (balance <= 0) break;

                // Withdraw at start of year
                balance -= withdrawal;
                if (balance < 0) balance = 0;

                // Grow remaining balance
                balance *= (1 + expectedReturn);

                averageTrajectory.push(balance);

                // Adjust withdrawal for inflation for next year
                withdrawal *= (1 + inflationRate);
                yearsLasted = i;
            }

            if (balance > 0) {
                outputs.years.textContent = `${MAX_YEARS}+ Years`;
            } else {
                outputs.years.textContent = `${yearsLasted} Years`;
            }

            // 2. Monte Carlo Simulation
            const SIMULATIONS = 1000;
            let successCount = 0;

            for (let s = 0; s < SIMULATIONS; s++) {
                let simBalance = initialPortfolio;
                let simWithdrawal = initialWithdrawal;
                let failed = false;

                for (let i = 1; i <= 30; i++) { // Test for 30-year success
                    if (simBalance <= 0) {
                        failed = true;
                        break;
                    }

                    simBalance -= simWithdrawal;
                    if (simBalance <= 0) {
                        failed = true;
                        break;
                    }

                    // Random return based on normal distribution
                    const randomReturn = expectedReturn + (randomNormal() * volatility);
                    simBalance *= (1 + randomReturn);

                    simWithdrawal *= (1 + inflationRate);
                }

                if (!failed) successCount++;
            }

            const successRate = Math.round((successCount / SIMULATIONS) * 100);
            outputs.success.textContent = `${successRate}%`;

            // Color code success rate
            if (successRate >= 90) {
                outputs.success.style.color = '#4ade80'; // Green
            } else if (successRate >= 75) {
                outputs.success.style.color = '#D4A017'; // Yellow
            } else {
                outputs.success.style.color = '#f87171'; // Red
            }

            // 3. Draw Chart
            drawChart(averageTrajectory, initialPortfolio, MAX_YEARS);
        }

        function drawChart(data, maxVal, maxYears) {
            const rect = canvas.parentElement.getBoundingClientRect();
            const width = rect.width;
            const height = rect.height;

            ctx.clearRect(0, 0, width, height);

            const padding = { top: 20, right: 20, bottom: 40, left: 60 };
            const chartWidth = width - padding.left - padding.right;
            const chartHeight = height - padding.top - padding.bottom;

            // Determine Y max scale
            const maxY = Math.max(maxVal * 1.2, ...data); // Give 20% headroom or max value if growing

            // Draw axes
            ctx.strokeStyle = '#152040';
            ctx.lineWidth = 1;
            ctx.beginPath();

            // Y-axis grid lines
            const ySteps = 5;
            ctx.fillStyle = '#a0a8c0';
            ctx.font = '12px "JetBrains Mono"';
            ctx.textAlign = 'right';
            ctx.textBaseline = 'middle';

            for (let i = 0; i <= ySteps; i++) {
                const yPos = padding.top + chartHeight - (i / ySteps) * chartHeight;
                const val = (i / ySteps) * maxY;

                ctx.moveTo(padding.left, yPos);
                ctx.lineTo(width - padding.right, yPos);

                // Format Y axis labels (k/M)
                let label = '';
                if (val >= 1000000) label = '$' + (val/1000000).toFixed(1) + 'M';
                else if (val >= 1000) label = '$' + Math.round(val/1000) + 'k';
                else label = '$' + Math.round(val);

                ctx.fillText(label, padding.left - 10, yPos);
            }
            ctx.stroke();

            // X-axis labels
            ctx.textAlign = 'center';
            ctx.textBaseline = 'top';
            const xSteps = 5;
            for (let i = 0; i <= xSteps; i++) {
                const year = Math.round((i / xSteps) * maxYears);
                const xPos = padding.left + (i / xSteps) * chartWidth;
                ctx.fillText(`Year ${year}`, xPos, height - padding.bottom + 10);
            }

            // Draw line
            ctx.beginPath();
            ctx.strokeStyle = '#D4A017';
            ctx.lineWidth = 3;

            for (let i = 0; i < data.length; i++) {
                const xPos = padding.left + (i / maxYears) * chartWidth;
                const yPos = padding.top + chartHeight - (data[i] / maxY) * chartHeight;

                if (i === 0) ctx.moveTo(xPos, yPos);
                else ctx.lineTo(xPos, yPos);
            }
            ctx.stroke();

            // Fill under line
            ctx.lineTo(padding.left + ((data.length - 1) / maxYears) * chartWidth, padding.top + chartHeight);
            ctx.lineTo(padding.left, padding.top + chartHeight);
            ctx.closePath();

            const gradient = ctx.createLinearGradient(0, padding.top, 0, height - padding.bottom);
            gradient.addColorStop(0, 'rgba(212, 160, 23, 0.2)');
            gradient.addColorStop(1, 'rgba(212, 160, 23, 0)');
            ctx.fillStyle = gradient;
            ctx.fill();
        }

        // Attach events
        Object.values(inputs).forEach(input => {
            input.addEventListener('input', calculate);
        });

        // Init
        resizeCanvas();
        calculate();
    });
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-fire-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">The Complete Guide to Financial Independence (FIRE)</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
