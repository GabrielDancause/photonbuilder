---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Tax Bracket Calculator",
  "url": "https://firemaths.info/tax-bracket",
  "description": "Calculate your effective and marginal tax rates based on US federal tax brackets.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Tax Bracket Calculator | firemaths.info"
  description="Calculate your effective and marginal tax rates based on 2024 US federal tax brackets. Compare single vs married filing statuses with a detailed breakdown."
  canonical="https://firemaths.info/tax-bracket" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Input Section -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Tax Details</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="income">Gross Annual Income</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="income" value="100000" min="0" step="1000">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="filing-status">Filing Status</label>
                        <div class="relative flex items-center">
                            <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="filing-status">
                                <option value="single">Single</option>
                                <option value="married">Married Filing Jointly</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Estimated Taxes</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="total-tax">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('total-tax', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Take-Home Pay</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="take-home-pay">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Effective Tax Rate</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="effective-rate">0%</span>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Marginal Tax Rate</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="marginal-rate">0%</span>
                    </div>
                </div>
            </div>

            <!-- Breakdown Section -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Tax Bracket Breakdown</h2>
                </div>

                <div style="overflow-x: auto;">
                    <table class="w-full text-left border-collapse whitespace-nowrap" class="bracket-table">
                        <th class="p-4 font-mediumead  bg-[var(--bg-color)] border-b border-[var(--border-color)] text-[var(--text-secondary)] text-sm uppercase tracking-wide"">
                            <tr class="hover:bg-[var(--bg-color)] transition-colors">
                                <th class="p-4 font-medium">Tax Rate</th>
                                <th class="p-4 font-medium">Bracket Range</th>
                                <th class="p-4 font-medium">Income in Bracket</th>
                                <th class="p-4 font-medium">Tax Owed</th>
                            </tr>
                        </thead>
                        <tbody id="bracket-body">
                            <!-- Filled via JS -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding Marginal vs. Effective Tax Rates</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">One of the most common misconceptions about taxes is how tax brackets work. When you move into a higher tax bracket, you don't pay that higher rate on your <em>entire</em> income. Instead, the US uses a progressive tax system.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Your <strong>marginal tax rate</strong> is the rate paid on your last dollar of income (the highest bracket your income reaches). Your <strong>effective tax rate</strong> is the actual percentage of your total income paid in taxes. For example, even if your marginal rate is 24%, your effective rate might only be 15% because portions of your income were taxed at lower 10%, 12%, and 22% rates.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">2024 US Federal Tax Brackets</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">For the 2024 tax year (taxes filed in early 2025), the IRS slightly adjusted the tax brackets to account for inflation. The seven federal income tax rates remain 10%, 12%, 22%, 24%, 32%, 35%, and 37%.</p>
            <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc space-y-2">
                <li><strong>Single Filers:</strong> The top 37% rate applies to individuals earning over $609,350.</li>
                <li><strong>Married Filing Jointly:</strong> The top 37% rate applies to couples earning over $731,200.</li>
            </ul>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Our calculator automatically segments your income into these respective buckets to show you exactly how your final tax bill is calculated, dollar by dollar.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">How to Use This Calculator</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Using the Tax Bracket Calculator is simple and all computations run securely in your browser. Enter your gross annual income before deductions and select your filing status. The calculator instantly breaks down your estimated federal tax liability, your total take-home pay, and your effective and marginal rates.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><em>Note: This calculator estimates federal income tax based on standard brackets. It does not account for the standard deduction, itemized deductions, state taxes, FICA (Social Security and Medicare), or specific tax credits.</em></p>
        </div>

    </main>

    
</div>
  <script is:inline>
// 2024 US Federal Tax Brackets
    const taxBrackets = {
        single: [
            { rate: 0.10, max: 11600 },
            { rate: 0.12, max: 47150 },
            { rate: 0.22, max: 100525 },
            { rate: 0.24, max: 191950 },
            { rate: 0.32, max: 243725 },
            { rate: 0.35, max: 609350 },
            { rate: 0.37, max: Infinity }
        ],
        married: [
            { rate: 0.10, max: 23200 },
            { rate: 0.12, max: 94300 },
            { rate: 0.22, max: 201050 },
            { rate: 0.24, max: 383900 },
            { rate: 0.32, max: 487450 },
            { rate: 0.35, max: 731200 },
            { rate: 0.37, max: Infinity }
        ]
    };

    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    const formatPercent = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'percent',
            minimumFractionDigits: 1,
            maximumFractionDigits: 2
        }).format(value);
    };

    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const updateCalculator = () => {
        const income = parseFloat(document.getElementById('income').value) || 0;
        const filingStatus = document.getElementById('filing-status').value;
        const brackets = taxBrackets[filingStatus];

        let remainingIncome = income;
        let totalTax = 0;
        let previousMax = 0;
        let marginalRate = 0;

        const breakdownHTML = [];

        for (let i = 0; i < brackets.length; i++) {
            const bracket = brackets[i];
            const rate = bracket.rate;
            const max = bracket.max;

            // The size of this bracket
            const bracketSize = max === Infinity ? Infinity : max - previousMax;

            // How much of the income falls into this bracket
            const incomeInBracket = Math.min(remainingIncome, bracketSize);

            if (incomeInBracket > 0) {
                const taxForBracket = incomeInBracket * rate;
                totalTax += taxForBracket;
                marginalRate = rate;

                const rangeText = max === Infinity
                    ? `Over ${formatCurrency(previousMax)}`
                    : `${formatCurrency(previousMax)} - ${formatCurrency(max)}`;

                breakdownHTML.push(`
                    <tr class="active">
                        <td class="p-4">${(rate * 100).toFixed(0)}%</td>
                        <td class="p-4">${rangeText}</td>
                        <td class="p-4">${formatCurrency(incomeInBracket)}</td>
                        <td class="p-4">${formatCurrency(taxForBracket)}</td>
                    </tr>
                `);
            } else {
                // Bracket not reached
                const rangeText = max === Infinity
                    ? `Over ${formatCurrency(previousMax)}`
                    : `${formatCurrency(previousMax)} - ${formatCurrency(max)}`;

                breakdownHTML.push(`
                    <tr class="hover:bg-[var(--bg-color)] transition-colors">
                        <td class="p-4">${(rate * 100).toFixed(0)}%</td>
                        <td class="p-4">${rangeText}</td>
                        <td class="p-4">$0</td>
                        <td class="p-4">$0</td>
                    </tr>
                `);
            }

            remainingIncome -= incomeInBracket;
            previousMax = max;
        }

        const effectiveRate = income > 0 ? totalTax / income : 0;
        const takeHomePay = income - totalTax;

        // Update UI
        document.getElementById('total-tax').innerText = formatCurrency(totalTax);
        document.getElementById('take-home-pay').innerText = formatCurrency(takeHomePay);
        document.getElementById('effective-rate').innerText = formatPercent(effectiveRate);
        document.getElementById('marginal-rate').innerText = formatPercent(marginalRate);
        document.getElementById('bracket-body').innerHTML = breakdownHTML.join('');
    };

    // Event listeners
    document.getElementById('income').addEventListener('input', updateCalculator);
    document.getElementById('filing-status').addEventListener('change', updateCalculator);

    // Initial calc
    updateCalculator();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-taxes-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Understanding Your Taxes: A Complete Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
