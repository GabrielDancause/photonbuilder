                        <span class="feature-value">Cash Flow Focus</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Bank Sync</span>
                        <span class="feature-value check-icon">✓</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Investment Tracking</span>
                        <span class="feature-value check-icon">✓</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Bill Tracking</span>
                        <span class="feature-value check-icon">✓</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Family Sharing</span>
                        <span class="feature-value check-icon">✓</span>
                    </div>
                </div>
                <p class="app-description">Simplifi focuses on a forward-looking cash flow approach, highlighting what you have left to spend rather than obsessing over past categories. It's highly affordable and offers excellent reporting features.</p>
            </div>

            <!-- Copilot -->
            <div class="app-card">
                <div class="app-header">
                    <div class="app-title-section">
                        <h2>Copilot</h2>
                        <span class="verdict-badge">Best for iOS Users</span>
                    </div>
                    <div style="font-weight:bold; font-size:1.1rem;">$13.00/mo</div>
                </div>
                <div class="app-features">
                    <div class="feature-row">
                        <span class="feature-label">Method</span>
                        <span class="feature-value">AI-Assisted</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Bank Sync</span>
                        <span class="feature-value check-icon">✓</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Investment Tracking</span>
                        <span class="feature-value check-icon">✓</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Bill Tracking</span>
                        <span class="feature-value check-icon">✓ (Subscriptions)</span>
                    </div>
                    <div class="feature-row">
                        <span class="feature-label">Family Sharing</span>
                        <span class="feature-value cross-icon">✗</span>
                    </div>
                </div>
                <p class="app-description">Copilot boasts a stunning, highly visual interface exclusive to Apple devices (iOS/Mac). It uses AI effectively to categorize transactions automatically and presents spending trends in a beautifully digestible format.</p>
            </div>

            <!-- Goodbudget -->
            <div class="app-card">
                <div class="app-header">
                    <div class="app-title-section">
                        <h2>Goodbudget</h2>
                        <span class="verdict-badge">Best for Envelope System</span>
