            </div>
            <div class="result-item">
              <span class="result-label">Avg. Annual Inflation Rate</span>
              <span class="result-value" id="hist-annual">0%</span>
            </div>
          </div>
        </div>

        <!-- Future mode -->
        <div class="mode-panel" id="panel-future">
          <h2>Future Purchasing Power</h2>
          <div class="input-row">
            <div class="input-group">
              <label for="fut-amount">Today's Dollar Amount</label>
              <div class="input-wrapper has-prefix">
                <span class="prefix">$</span>
                <input type="number" id="fut-amount" value="100" min="0" step="1">
              </div>
            </div>
            <div class="input-group">
              <label for="fut-years">Years From Now</label>
              <div class="input-wrapper">
                <input type="number" id="fut-years" value="10" min="1" max="50" step="1">
              </div>
            </div>
          </div>
          <div class="input-group">
            <label for="fut-rate">Assumed Annual Inflation Rate</label>
            <div class="input-wrapper has-suffix">
              <span class="suffix">%</span>
              <input type="number" id="fut-rate" value="3" min="0" max="30" step="0.1">
            </div>
          </div>

          <div class="results">
            <div class="result-item result-final">
              <span class="result-label">Future Purchasing Power</span>
              <div class="result-value">
                <span id="fut-result">$0</span>
                <button class="copy-btn" onclick="copyVal('fut-result', this)">Copy</button>
              </div>
            </div>
            <div class="result-item">
              <span class="result-label">You'd Need This Much to Equal $100 Today</span>
              <span class="result-value" id="fut-needed">$0</span>
