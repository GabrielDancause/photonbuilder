---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'CPM Calculator | Firemaths',
  description: 'Easily calculate Cost Per Mille (CPM), total cost, and impressions for your ad campaigns. Our interactive CPM calculator helps you optimize ad spend instantly.',
  category: 'tool',
  keywords: ['cpm calculator', 'cost per mille calculator', 'ad impressions calculator', 'cpm cost calculator', 'cpm marketing calculator', 'calculate cpm formula']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "firemaths.info" },
    "publisher": { "@type": "Organization", "name": "firemaths.info" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you calculate CPM?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CPM (Cost Per Mille) is calculated by dividing the total cost of an advertising campaign by the number of impressions, and then multiplying the result by 1,000. The formula is: CPM = (Total Cost / Total Impressions) * 1000."
        }
      },
      {
        "@type": "Question",
        "name": "What is a good CPM rate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good CPM rate varies heavily by industry, platform, and ad format. For display ads, a CPM of $2 to $10 is common. For premium video or niche B2B audiences, it can range from $15 to over $50. Always compare your CPM against your specific industry benchmarks and overall campaign ROI."
        }
      },
      {
        "@type": "Question",
        "name": "What does CPM stand for in marketing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CPM stands for Cost Per Mille, where 'mille' is the Latin word for thousand. In marketing and advertising, it represents the cost an advertiser pays for one thousand views or impressions of an advertisement."
        }
      },
      {
        "@type": "Question",
        "name": "How do I calculate total cost from CPM and impressions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To calculate the total cost when you know the CPM and the number of impressions, divide the total impressions by 1,000, and then multiply that number by the CPM rate. Formula: Total Cost = (Impressions / 1000) * CPM."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between CPM, CPC, and CPA?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CPM (Cost Per Mille) is the cost per 1,000 impressions (views). CPC (Cost Per Click) is the amount you pay each time a user clicks on your ad. CPA (Cost Per Acquisition or Action) is the cost you pay when a user completes a specific action, like a purchase or sign-up."
        }
      }
    ]
  }
]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <div class="cpm-page-wrapper">
    <!-- Hero Section -->
    <header class="cpm-hero">
      <div class="cpm-container">
        <div class="hero-content">
          <span class="hero-badge">Advertising Tool</span>
          <h1 class="hero-title">Free Interactive <span>CPM Calculator</span></h1>
          <p class="hero-description">
            Optimize your ad campaigns instantly. Input any two values (Total Cost, Impressions, or CPM) and we'll calculate the rest. Perfect for marketers, publishers, and media buyers planning their next big campaign.
          </p>
          <div class="hero-stats">
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Free to Use</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">0</span>
              <span class="stat-label">Data Saved</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">Instant</span>
              <span class="stat-label">Results</span>
            </div>
          </div>
          <a href="#calculator" class="hero-cta">Calculate Your CPM Now</a>
        </div>
      </div>
    </header>

    <div class="cpm-container">
      <div class="main-content-grid">
        <!-- Left Column: Calculator -->
        <main class="calculator-section" id="calculator">
          <div class="calculator-card">
            <div class="card-header">
              <h2>Ad Campaign Calculator</h2>
              <p>Enter any <strong>two</strong> of the following metrics to calculate the third.</p>
            </div>

            <div class="calc-body">
              <!-- Inputs -->
              <div class="input-group">
                <label for="calc-cost">Total Cost ($)</label>
                <div class="input-wrapper">
                  <span class="input-prefix">$</span>
                  <input type="number" id="calc-cost" placeholder="e.g. 500" min="0" step="0.01">
                </div>
                <span class="error-msg" id="err-cost">Please enter a valid positive number.</span>
              </div>

              <div class="input-group">
                <label for="calc-impressions">Total Impressions</label>
                <div class="input-wrapper">
                  <span class="input-prefix">👁️</span>
                  <input type="number" id="calc-impressions" placeholder="e.g. 100000" min="0" step="1">
                </div>
                <span class="error-msg" id="err-impressions">Please enter a valid positive whole number.</span>
              </div>

              <div class="input-group">
                <label for="calc-cpm">CPM (Cost Per Mille) ($)</label>
                <div class="input-wrapper">
                  <span class="input-prefix">$</span>
                  <input type="number" id="calc-cpm" placeholder="e.g. 5.00" min="0" step="0.01">
                </div>
                <span class="error-msg" id="err-cpm">Please enter a valid positive number.</span>
              </div>

              <!-- Action Buttons -->
              <div class="calc-actions">
                <button id="btn-calculate" class="btn-primary">Calculate</button>
                <button id="btn-reset" class="btn-secondary">Clear Fields</button>
              </div>

              <!-- Results Area -->
              <div class="results-area" id="results-display">
                <div class="result-box primary-result">
                  <span class="result-label" id="primary-result-label">Calculated Result</span>
                  <span class="result-value" id="primary-result-value">--</span>
                </div>

                <div class="advanced-metrics">
                  <h3>Advanced Estimates (Optional)</h3>
                  <p class="small-text">Fill these out to estimate CPC and CTR based on your base metrics.</p>

                  <div class="input-row">
                    <div class="input-group">
                      <label for="calc-clicks">Total Clicks</label>
                      <input type="number" id="calc-clicks" placeholder="e.g. 1500" min="0" step="1">
                    </div>
                  </div>

                  <div class="secondary-results">
                    <div class="result-box">
                      <span class="result-label">Est. CTR (Click-Through Rate)</span>
                      <span class="result-value" id="result-ctr">--</span>
                    </div>
                    <div class="result-box">
                      <span class="result-label">Est. CPC (Cost Per Click)</span>
                      <span class="result-value" id="result-cpc">--</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Visual Chart Section -->
          <div class="visual-section">
            <h2>Average CPM Benchmarks by Platform</h2>
            <p>Compare typical advertising costs across major digital platforms (2024 Estimates). Costs vary widely by industry, targeting, and ad format.</p>

            <div class="chart-container">
              <div class="chart-bars">
                <!-- Google Display -->
                <div class="bar-group">
                  <div class="bar-label">Google Display</div>
                  <div class="bar-wrapper">
                    <div class="bar google-bar" style="width: 35%;"></div>
                    <span class="bar-value">$2.80 - $3.50</span>
                  </div>
                </div>

                <!-- Facebook -->
                <div class="bar-group">
                  <div class="bar-label">Facebook</div>
                  <div class="bar-wrapper">
                    <div class="bar fb-bar" style="width: 71%;"></div>
                    <span class="bar-value">$7.19 - $8.50</span>
                  </div>
                </div>

                <!-- Instagram -->
                <div class="bar-group">
                  <div class="bar-label">Instagram</div>
                  <div class="bar-wrapper">
                    <div class="bar ig-bar" style="width: 79%;"></div>
                    <span class="bar-value">$7.91 - $9.20</span>
                  </div>
                </div>

                <!-- TikTok -->
                <div class="bar-group">
                  <div class="bar-label">TikTok</div>
                  <div class="bar-wrapper">
                    <div class="bar tiktok-bar" style="width: 60%;"></div>
                    <span class="bar-value">$6.06 - $7.50</span>
                  </div>
                </div>

                <!-- LinkedIn -->
                <div class="bar-group">
                  <div class="bar-label">LinkedIn (B2B)</div>
                  <div class="bar-wrapper">
                    <div class="bar linkedin-bar" style="width: 100%;"></div>
                    <span class="bar-value">$30.00+</span>
                  </div>
                </div>
              </div>
              <div class="chart-legend">
                <p><em>*Data represents broad industry averages for standard campaign types. Highly targeted or premium inventory will exceed these averages.</em></p>
              </div>
            </div>
          </div>
        </main>

        <!-- Right Column: Educational Content -->
        <aside class="educational-section">
          <!-- Section 1 -->
          <div class="edu-card">
            <div class="edu-icon">📈</div>
            <h3>What is CPM?</h3>
            <p><strong>Cost Per Mille (CPM)</strong>, also called cost per thousand, is a marketing term used to denote the price of 1,000 advertisement impressions on one webpage. If a website publisher charges $2.00 CPM, that means an advertiser must pay $2.00 for every 1,000 views of its ad.</p>
            <p>The "M" in CPM represents the Roman numeral for 1,000.</p>
          </div>

          <!-- Section 2 -->
          <div class="edu-card">
            <div class="edu-icon">🧮</div>
            <h3>The CPM Formulas</h3>
            <p>Depending on what data you have, you can use the following formulas to calculate your missing metric:</p>
            <ul class="formula-list">
              <li><strong>Find CPM:</strong> <span>(Total Cost / Impressions) × 1000</span></li>
              <li><strong>Find Cost:</strong> <span>(Impressions / 1000) × CPM</span></li>
              <li><strong>Find Impressions:</strong> <span>(Total Cost / CPM) × 1000</span></li>
            </ul>
          </div>

          <!-- Section 3 -->
          <div class="edu-card">
            <div class="edu-icon">🎯</div>
            <h3>Why is CPM Important?</h3>
            <p>CPM is the standard metric used to measure the cost-effectiveness and value of an advertising campaign. It's particularly useful for brand awareness campaigns where the primary goal is getting your message in front of as many eyeballs as possible, rather than driving immediate clicks or conversions.</p>
            <p>It allows advertisers to compare costs across different media types and platforms fairly.</p>
          </div>

          <!-- Section 4 -->
          <div class="edu-card">
            <div class="edu-icon">⚖️</div>
            <h3>CPM vs. CPC vs. CPA</h3>
            <div class="comparison-grid">
              <div class="comp-item">
                <h4>CPM</h4>
                <p>Best for <strong>Brand Awareness</strong>. You pay for views, regardless of interaction.</p>
              </div>
              <div class="comp-item">
                <h4>CPC</h4>
                <p>Best for <strong>Traffic</strong>. You pay only when someone clicks your ad.</p>
              </div>
              <div class="comp-item">
                <h4>CPA</h4>
                <p>Best for <strong>Conversions</strong>. You pay only when a specific action (sale/lead) occurs.</p>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <!-- FAQ Section -->
      <section class="faq-container">
        <div class="section-heading">
          <h2>Frequently Asked Questions</h2>
          <p>Everything you need to know about Cost Per Mille and ad spend optimization.</p>
        </div>

        <div class="faq-list">
          <details class="faq-item">
            <summary>How do you calculate CPM?</summary>
            <div class="faq-content">
              <p>CPM (Cost Per Mille) is calculated by dividing the total cost of an advertising campaign by the number of impressions, and then multiplying the result by 1,000. The formula is: <strong>CPM = (Total Cost / Total Impressions) * 1000</strong>.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>What is a good CPM rate?</summary>
            <div class="faq-content">
              <p>A good CPM rate varies heavily by industry, platform, and ad format. For standard display ads, a CPM of $2 to $10 is common. For premium video or niche B2B audiences, it can range from $15 to over $50. Always compare your CPM against your specific industry benchmarks and overall campaign ROI rather than an arbitrary number.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>What does CPM stand for in marketing?</summary>
            <div class="faq-content">
              <p>CPM stands for Cost Per Mille, where "mille" is the Latin word for thousand. In marketing and advertising, it represents the cost an advertiser pays for one thousand views or impressions of an advertisement.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>How do I calculate total cost from CPM and impressions?</summary>
            <div class="faq-content">
              <p>To calculate the total cost when you know the CPM and the number of impressions, divide the total impressions by 1,000, and then multiply that number by the CPM rate. Formula: <strong>Total Cost = (Impressions / 1000) * CPM</strong>.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>What is the difference between CPM, CPC, and CPA?</summary>
            <div class="faq-content">
              <p><strong>CPM</strong> (Cost Per Mille) is the cost per 1,000 impressions (views). <strong>CPC</strong> (Cost Per Click) is the amount you pay each time a user clicks on your ad. <strong>CPA</strong> (Cost Per Acquisition or Action) is the cost you pay when a user completes a specific action, like a purchase or sign-up. Advertisers choose the model that best aligns with their campaign goals.</p>
            </div>
          </details>
        </div>
      </section>

      <!-- Related Tools Section -->
      <section class="related-tools">
        <h2>More Financial & Business Tools</h2>
        <div class="tools-grid">
          <a href="/roi-calculator" class="tool-card">
            <div class="tool-icon">📊</div>
            <h3>ROI Calculator</h3>
            <p>Calculate the Return on Investment for your marketing campaigns and business decisions.</p>
          </a>
          <a href="/markup-calculator" class="tool-card">
            <div class="tool-icon">🏷️</div>
            <h3>Markup Calculator</h3>
            <p>Determine the correct selling price for your products based on cost and desired profit margin.</p>
          </a>
          <a href="/profit-margin" class="tool-card">
            <div class="tool-icon">💵</div>
            <h3>Profit Margin Calculator</h3>
            <p>Calculate gross margin, net margin, and markup percentage quickly and easily.</p>
          </a>
          <a href="/freelance-rate" class="tool-card">
            <div class="tool-icon">💼</div>
            <h3>Freelance Rate Calculator</h3>
            <p>Figure out exactly what you need to charge per hour to meet your income goals.</p>
          </a>
        </div>
      </section>
    </div>
  </div>

  <style is:inline>
    /* Scoped CSS using provided variables */
    .cpm-page-wrapper {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
      color: var(--text-primary);
      background-color: var(--bg-primary);
      line-height: 1.6;
    }

    .cpm-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* Hero Styles */
    .cpm-hero {
      background: linear-gradient(135deg, var(--card-bg) 0%, var(--bg-primary) 100%);
      border-bottom: 1px solid var(--border-color);
      padding: 4rem 0 3rem;
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero-content {
      max-width: 800px;
      margin: 0 auto;
    }

    .hero-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      background-color: color-mix(in srgb, var(--accent-color) 15%, transparent);
      color: var(--accent-color);
      border-radius: 999px;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .hero-title {
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 800;
      margin-bottom: 1.5rem;
      line-height: 1.2;
      color: var(--text-primary);
    }

    .hero-title span {
      color: var(--accent-color);
    }

    .hero-description {
      font-size: 1.125rem;
      color: var(--text-secondary);
      margin-bottom: 2.5rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 3rem;
      margin-bottom: 2.5rem;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .stat-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .hero-cta {
      display: inline-block;
      background-color: var(--accent-color);
      color: white !important;
      padding: 1rem 2rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 1.125rem;
      text-decoration: none !important;
      transition: transform 0.2s, opacity 0.2s;
      box-shadow: 0 4px 6px -1px color-mix(in srgb, var(--accent-color) 30%, transparent);
    }

    .hero-cta:hover {
      transform: translateY(-2px);
      opacity: 0.9;
    }

    /* Layout */
    .main-content-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 3rem;
      margin-bottom: 4rem;
    }

    @media (max-width: 992px) {
      .main-content-grid {
        grid-template-columns: 1fr;
      }
      .hero-stats {
        gap: 1.5rem;
        flex-wrap: wrap;
      }
    }

    /* Calculator Styles */
    .calculator-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
      margin-bottom: 3rem;
    }

    .card-header {
      background: color-mix(in srgb, var(--accent-color) 5%, transparent);
      padding: 1.5rem 2rem;
      border-bottom: 1px solid var(--border-color);
    }

    .card-header h2 {
      margin: 0 0 0.5rem 0;
      font-size: 1.5rem;
      color: var(--text-primary);
    }

    .card-header p {
      margin: 0;
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    .calc-body {
      padding: 2rem;
    }

    .input-group {
      margin-bottom: 1.5rem;
    }

    .input-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    .input-prefix {
      position: absolute;
      left: 1rem;
      color: var(--text-secondary);
      font-weight: 600;
      pointer-events: none;
    }

    .input-wrapper input {
      width: 100%;
      padding: 0.875rem 1rem 0.875rem 2.5rem;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 1rem;
      transition: all 0.2s;
    }

    .input-wrapper input:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .input-wrapper input.has-value {
      background-color: color-mix(in srgb, var(--accent-color) 5%, transparent);
      border-color: color-mix(in srgb, var(--accent-color) 40%, transparent);
    }

    .error-msg {
      display: none;
      color: #ef4444;
      font-size: 0.85rem;
      margin-top: 0.5rem;
    }

    .calc-actions {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      margin-bottom: 2rem;
    }

    .btn-primary {
      flex: 2;
      background: var(--accent-color);
      color: white;
      border: none;
      padding: 1rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: 1.125rem;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .btn-secondary {
      flex: 1;
      background: transparent;
      color: var(--text-secondary);
      border: 1px solid var(--border-color);
      padding: 1rem;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary:hover { background: var(--bg-primary); color: var(--text-primary); }

    /* Results Area */
    .results-area {
      display: none; /* Shown via JS */
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      animation: fadeIn 0.3s ease-in-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .primary-result {
      text-align: center;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      margin-bottom: 1.5rem;
    }

    .result-label {
      display: block;
      color: var(--text-secondary);
      font-size: 0.95rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .result-value {
      display: block;
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent-color);
      word-break: break-all;
    }

    .advanced-metrics h3 {
      font-size: 1.1rem;
      margin: 0 0 0.25rem 0;
      color: var(--text-primary);
    }

    .small-text {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin: 0 0 1rem 0;
    }

    .secondary-results {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1rem;
      background: var(--card-bg);
      padding: 1rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .secondary-results .result-value {
      font-size: 1.5rem;
      color: var(--text-primary);
    }

    /* Visual Chart */
    .visual-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2rem;
    }

    .visual-section h2 {
      margin-top: 0;
      font-size: 1.5rem;
      color: var(--text-primary);
    }

    .visual-section p {
      color: var(--text-secondary);
      margin-bottom: 2rem;
    }

    .chart-container {
      width: 100%;
    }

    .bar-group {
      margin-bottom: 1.25rem;
    }

    .bar-label {
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      font-size: 0.95rem;
    }

    .bar-wrapper {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .bar {
      height: 24px;
      border-radius: 4px;
      background: var(--accent-color);
      transition: width 1s ease-in-out;
    }

    .google-bar { background: #4285F4; }
    .fb-bar { background: #1877F2; }
    .ig-bar { background: #E1306C; }
    .tiktok-bar { background: #000000; border: 1px solid #69C9D0; }
    .linkedin-bar { background: #0A66C2; }

    .bar-value {
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--text-secondary);
      white-space: nowrap;
    }

    .chart-legend {
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border-color);
      font-size: 0.85rem;
      color: var(--text-secondary);
    }

    /* Educational Section */
    .educational-section {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .edu-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .edu-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 12px -3px rgba(0,0,0,0.05);
    }

    .edu-icon {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .edu-card h3 {
      margin: 0 0 1rem 0;
      font-size: 1.25rem;
      color: var(--text-primary);
    }

    .edu-card p {
      color: var(--text-secondary);
      margin-bottom: 0.75rem;
      line-height: 1.6;
    }

    .edu-card p:last-child {
      margin-bottom: 0;
    }

    .formula-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .formula-list li {
      background: var(--bg-primary);
      padding: 0.75rem 1rem;
      border-radius: 6px;
      margin-bottom: 0.5rem;
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
    }

    .formula-list li strong {
      color: var(--accent-color);
      margin-bottom: 0.25rem;
    }

    .formula-list li span {
      font-family: monospace;
      font-size: 0.95rem;
      color: var(--text-primary);
    }

    .comparison-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 1rem;
    }

    .comp-item {
      background: var(--bg-primary);
      padding: 1rem;
      border-radius: 8px;
      border-left: 4px solid var(--accent-color);
    }

    .comp-item h4 {
      margin: 0 0 0.5rem 0;
      color: var(--text-primary);
    }

    .comp-item p {
      margin: 0;
      font-size: 0.9rem;
    }

    /* FAQ Section */
    .faq-container {
      margin: 4rem 0;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .section-heading {
      text-align: center;
      margin-bottom: 2rem;
    }

    .section-heading h2 {
      font-size: 2rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .section-heading p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      overflow: hidden;
    }

    .faq-item summary {
      padding: 1.25rem 1.5rem;
      font-weight: 600;
      font-size: 1.1rem;
      cursor: pointer;
      color: var(--text-primary);
      list-style-position: inside;
      background: color-mix(in srgb, var(--accent-color) 3%, transparent);
    }

    .faq-item summary:hover {
      background: color-mix(in srgb, var(--accent-color) 6%, transparent);
    }

    .faq-content {
      padding: 0 1.5rem 1.25rem 1.5rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .faq-content p {
      margin-top: 1rem;
      margin-bottom: 0;
    }

    /* Related Tools */
    .related-tools {
      margin-top: 4rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border-color);
    }

    .related-tools h2 {
      font-size: 1.75rem;
      color: var(--text-primary);
      margin-bottom: 2rem;
      text-align: center;
    }

    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }

    .tool-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      text-decoration: none !important;
      transition: all 0.2s;
      display: flex;
      flex-direction: column;
    }

    .tool-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
      border-color: var(--accent-color);
    }

    .tool-icon {
      font-size: 2rem;
      margin-bottom: 1rem;
    }

    .tool-card h3 {
      color: var(--text-primary);
      margin: 0 0 0.5rem 0;
      font-size: 1.25rem;
    }

    .tool-card p {
      color: var(--text-secondary);
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.5;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Inputs
      const costInput = document.getElementById('calc-cost');
      const impInput = document.getElementById('calc-impressions');
      const cpmInput = document.getElementById('calc-cpm');
      const clicksInput = document.getElementById('calc-clicks');

      // Errors
      const costErr = document.getElementById('err-cost');
      const impErr = document.getElementById('err-impressions');
      const cpmErr = document.getElementById('err-cpm');

      // Buttons
      const btnCalc = document.getElementById('btn-calculate');
      const btnReset = document.getElementById('btn-reset');

      // Results
      const resultsDisplay = document.getElementById('results-display');
      const primaryLabel = document.getElementById('primary-result-label');
      const primaryValue = document.getElementById('primary-result-value');
      const ctrValue = document.getElementById('result-ctr');
      const cpcValue = document.getElementById('result-cpc');

      // Input highlighting logic
      const inputs = [costInput, impInput, cpmInput];

      inputs.forEach(input => {
        input.addEventListener('input', () => {
          if (input.value.trim() !== '') {
            input.classList.add('has-value');
          } else {
            input.classList.remove('has-value');
          }
        });
      });

      // Format currency
      const formatCurrency = (val) => {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      };

      // Format number
      const formatNumber = (val) => {
        return new Intl.NumberFormat('en-US').format(val);
      };

      // Validation
      const validateInputs = () => {
        let isValid = true;
        let filledCount = 0;

        costErr.style.display = 'none';
        impErr.style.display = 'none';
        cpmErr.style.display = 'none';

        if (costInput.value !== '') {
          filledCount++;
          if (parseFloat(costInput.value) < 0 || isNaN(parseFloat(costInput.value))) {
            costErr.style.display = 'block';
            isValid = false;
          }
        }

        if (impInput.value !== '') {
          filledCount++;
          if (parseInt(impInput.value) <= 0 || isNaN(parseInt(impInput.value))) {
            impErr.style.display = 'block';
            isValid = false;
          }
        }

        if (cpmInput.value !== '') {
          filledCount++;
          if (parseFloat(cpmInput.value) < 0 || isNaN(parseFloat(cpmInput.value))) {
            cpmErr.style.display = 'block';
            isValid = false;
          }
        }

        if (filledCount < 2) {
          alert('Please enter at least TWO values to calculate the third.');
          return false;
        }

        if (filledCount === 3) {
           alert('Please clear one field to calculate it based on the other two.');
           return false;
        }

        return isValid;
      };

      // Calculate Logic
      const calculate = () => {
        if (!validateInputs()) return;

        const cost = costInput.value ? parseFloat(costInput.value) : null;
        const imp = impInput.value ? parseInt(impInput.value) : null;
        const cpm = cpmInput.value ? parseFloat(cpmInput.value) : null;
        const clicks = clicksInput.value ? parseInt(clicksInput.value) : null;

        let calcCost = cost;
        let calcImp = imp;
        let calcCpm = cpm;

        // Perform calculation
        if (cost === null && imp !== null && cpm !== null) {
          // Find Cost: (Impressions / 1000) * CPM
          calcCost = (imp / 1000) * cpm;
          primaryLabel.textContent = "Estimated Total Cost";
          primaryValue.textContent = formatCurrency(calcCost);
          costInput.value = calcCost.toFixed(2);
        } else if (imp === null && cost !== null && cpm !== null) {
          // Find Impressions: (Cost / CPM) * 1000
          if (cpm === 0) {
             alert("CPM cannot be zero when calculating impressions.");
             return;
          }
          calcImp = Math.round((cost / cpm) * 1000);
          primaryLabel.textContent = "Estimated Total Impressions";
          primaryValue.textContent = formatNumber(calcImp);
          impInput.value = calcImp;
        } else if (cpm === null && cost !== null && imp !== null) {
          // Find CPM: (Cost / Impressions) * 1000
          if (imp === 0) {
             alert("Impressions cannot be zero when calculating CPM.");
             return;
          }
          calcCpm = (cost / imp) * 1000;
          primaryLabel.textContent = "Calculated CPM";
          primaryValue.textContent = formatCurrency(calcCpm);
          cpmInput.value = calcCpm.toFixed(2);
        }

        // Add 'has-value' class to dynamically filled input
        inputs.forEach(input => {
          if (input.value !== '') input.classList.add('has-value');
        });

        // Advanced Metrics
        if (clicks && clicks > 0 && calcImp && calcImp > 0) {
          const ctr = (clicks / calcImp) * 100;
          ctrValue.textContent = ctr.toFixed(2) + '%';

          if (calcCost && calcCost > 0) {
            const cpc = calcCost / clicks;
            cpcValue.textContent = formatCurrency(cpc);
          } else {
             cpcValue.textContent = '--';
          }
        } else {
          ctrValue.textContent = '--';
          cpcValue.textContent = '--';
        }

        // Show results
        resultsDisplay.style.display = 'block';

        // Scroll to results on mobile
        if (window.innerWidth < 768) {
           resultsDisplay.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      };

      // Reset Logic
      const reset = () => {
        costInput.value = '';
        impInput.value = '';
        cpmInput.value = '';
        clicksInput.value = '';

        costErr.style.display = 'none';
        impErr.style.display = 'none';
        cpmErr.style.display = 'none';

        inputs.forEach(input => input.classList.remove('has-value'));
        resultsDisplay.style.display = 'none';
      };

      // Event Listeners
      btnCalc.addEventListener('click', calculate);
      btnReset.addEventListener('click', reset);

      // Allow Enter key to calculate
      document.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && (document.activeElement === costInput || document.activeElement === impInput || document.activeElement === cpmInput || document.activeElement === clicksInput)) {
          calculate();
        }
      });
    });
  </script>
</SiteLayout>
