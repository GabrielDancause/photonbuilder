---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Break-Even Calculator",
  "url": "https://firemaths.info/break-even",
  "description": "Calculate your break-even point in units and revenue. Understand your fixed and variable costs.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Break-Even Calculator | firemaths.info"
  description="Calculate your break-even point in units and revenue. Understand your fixed and variable costs, and visualize your path to profitability with our free interactive chart."
  canonical="https://firemaths.info/break-even" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="calculator-card">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
                <div class="inputs">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="fixed-costs">Total Fixed Costs</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="fixed-costs" value="10000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="variable-cost">Variable Cost per Unit</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="variable-cost" value="15" min="0" step="0.01" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="selling-price">Selling Price per Unit</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="selling-price" value="40" min="0" step="0.01" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                        <div id="error-msg" class="text-red-500 text-sm mt-2 !hidden">Selling price must be greater than variable cost.</div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Break-Even Point (Units)</span>
                        <div class="flex items-center gap-4">
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="be-units">0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('be-units', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Break-Even Revenue</span>
                        <div class="flex items-center gap-4">
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="be-revenue">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('be-revenue', this)">Copy</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-16 shadow-sm">
            <div class="mb-6 text-center">
                <h2>Profitability Visualization</h2>
            </div>
            <div class="w-full h-[400px] relative">
                <canvas id="breakEvenChart"></canvas>
            </div>
            <div class="flex justify-center gap-6 mt-4 text-sm text-[var(--text-secondary)]">
                <div class="flex items-center gap-2">
                    <div class="legend-color" style="background-color: var(--chart-revenue)"></div>
                    <span>Total Revenue</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="legend-color" style="background-color: var(--chart-costs)"></div>
                    <span>Total Costs</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="legend-color" style="background-color: var(--chart-fixed)"></div>
                    <span>Fixed Costs</span>
                </div>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">What is a Break-Even Point?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The break-even point is the exact moment when a business's total revenues equal its total expenses. At this specific point, the business is neither making a profit nor suffering a loss—it has simply "broken even." Understanding this metric is crucial for any business owner, entrepreneur, or manager to set sales targets and price products effectively.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Knowing your break-even point helps you answer critical questions like: "How many units do I need to sell to cover my rent and payroll?" or "If I lower my price by 10%, how many more items do I need to sell to maintain the same profitability?"</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Understanding Fixed and Variable Costs</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">To calculate your break-even point accurately, you need to understand the difference between fixed and variable costs:</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>Fixed Costs:</strong> Expenses that remain constant regardless of how much you produce or sell. Examples include rent, insurance, salaries of permanent staff, and software subscriptions.</li>
                <li><strong>Variable Costs:</strong> Expenses that fluctuate directly in proportion to your production or sales volume. Examples include raw materials, direct labor, packaging, and shipping fees per unit.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">How to Calculate Your Break-Even Point</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The standard formula for calculating the break-even point in units is straightforward:</p>
            <p style="font-family: var(--font-mono); background-color: var(--card-bg); padding: 1rem; border-radius: 6px; border: 1px solid var(--border-color); text-align: center; margin: 1.5rem 0;">
                Break-Even Units = Fixed Costs / (Selling Price - Variable Cost)
            </p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The difference between the selling price and the variable cost is known as the <strong>contribution margin</strong>. This is the amount of money each sale "contributes" toward paying off your fixed costs. Once fixed costs are fully covered, this margin contributes directly to your profit.</p>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 2
        }).format(value);
    };

    const formatNumber = (value) => {
        return new Intl.NumberFormat('en-US', {
            maximumFractionDigits: 1
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // Chart logic
    let chartCanvas = document.getElementById('breakEvenChart');
    let ctx = chartCanvas.getContext('2d');

    const drawChart = (fixedCost, varCost, price, beUnits) => {
        const dpr = window.devicePixelRatio || 1;
        const rect = chartCanvas.parentElement.getBoundingClientRect();

        chartCanvas.width = rect.width * dpr;
        chartCanvas.height = rect.height * dpr;

        ctx.setTransform(1, 0, 0, 1, 0, 0); // reset transform
        ctx.scale(dpr, dpr);

        const width = rect.width;
        const height = rect.height;

        ctx.clearRect(0, 0, width, height);

        const padding = { top: 20, right: 20, bottom: 40, left: 80 };
        const chartWidth = width - padding.left - padding.right;
        const chartHeight = height - padding.top - padding.bottom;

        // If data is invalid, don't draw chart
        if (price <= varCost || beUnits <= 0 || !isFinite(beUnits)) {
            ctx.fillStyle = '#888888';
            ctx.font = '14px Inter, sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('Please enter valid data to view the chart', width / 2, height / 2);
            return;
        }

        // We want to show 0 to 2x the break-even units to give a good visual
        const maxUnits = beUnits * 2;
        const maxRevenue = maxUnits * price;
        const maxCost = fixedCost + (maxUnits * varCost);
        const maxVal = Math.max(maxRevenue, maxCost);

        // Draw grid and axes
        ctx.strokeStyle = '#2a2010';
        ctx.lineWidth = 1;
        ctx.font = '12px Inter, sans-serif';
        ctx.fillStyle = '#888888';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        // Y-axis (Currency)
        const yTicks = 5;
        for (let i = 0; i <= yTicks; i++) {
            const val = maxVal * (i / yTicks);
            const y = height - padding.bottom - (chartHeight * (i / yTicks));

            ctx.beginPath();
            ctx.moveTo(padding.left, y);
            ctx.lineTo(width - padding.right, y);
            ctx.stroke();

            let label = val >= 1000000 ? '$' + (val / 1000000).toFixed(1) + 'M' :
                        val >= 1000 ? '$' + (val / 1000).toFixed(0) + 'k' : '$' + val.toFixed(0);
            ctx.fillText(label, padding.left - 10, y);
        }

        // X-axis (Units)
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const xTicks = 5;
        for (let i = 0; i <= xTicks; i++) {
            const val = maxUnits * (i / xTicks);
            const x = padding.left + (chartWidth * (i / xTicks));

            ctx.beginPath();
            ctx.moveTo(x, height - padding.bottom);
            ctx.lineTo(x, height - padding.bottom + 5);
            ctx.stroke();

            ctx.fillText(formatNumber(val), x, height - padding.bottom + 10);
        }

        const getCoord = (units, val) => ({
            x: padding.left + (chartWidth * (units / maxUnits)),
            y: height - padding.bottom - (chartHeight * (val / maxVal))
        });

        // Fixed Costs Line
        const fcStyle = getComputedStyle(document.body).getPropertyValue('--chart-fixed').trim() || '#888888';
        ctx.beginPath();
        ctx.strokeStyle = fcStyle;
        ctx.lineWidth = 2;
        ctx.setLineDash([5, 5]); // Dashed line
        const p1FC = getCoord(0, fixedCost);
        const p2FC = getCoord(maxUnits, fixedCost);
        ctx.moveTo(p1FC.x, p1FC.y);
        ctx.lineTo(p2FC.x, p2FC.y);
        ctx.stroke();
        ctx.setLineDash([]); // Reset

        // Total Costs Line
        const tcStyle = getComputedStyle(document.body).getPropertyValue('--chart-costs').trim() || '#E24A4A';
        ctx.beginPath();
        ctx.strokeStyle = tcStyle;
        ctx.lineWidth = 3;
        const p1TC = getCoord(0, fixedCost);
        const p2TC = getCoord(maxUnits, maxCost);
        ctx.moveTo(p1TC.x, p1TC.y);
        ctx.lineTo(p2TC.x, p2TC.y);
        ctx.stroke();

        // Total Revenue Line
        const trStyle = getComputedStyle(document.body).getPropertyValue('--chart-revenue').trim() || '#4A90E2';
        ctx.beginPath();
        ctx.strokeStyle = trStyle;
        ctx.lineWidth = 3;
        const p1TR = getCoord(0, 0);
        const p2TR = getCoord(maxUnits, maxRevenue);
        ctx.moveTo(p1TR.x, p1TR.y);
        ctx.lineTo(p2TR.x, p2TR.y);
        ctx.stroke();

        // Draw Break-Even Point dot
        const beCoord = getCoord(beUnits, beUnits * price);
        ctx.beginPath();
        ctx.fillStyle = '#D4A017'; // Accent color
        ctx.arc(beCoord.x, beCoord.y, 6, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = '#0c0a00'; // Background color
        ctx.lineWidth = 2;
        ctx.stroke();

        // BEP Label
        ctx.fillStyle = '#D4A017';
        ctx.textAlign = 'left';
        ctx.textBaseline = 'bottom';
        ctx.font = 'bold 12px Inter, sans-serif';
        ctx.fillText('Break-Even', beCoord.x + 10, beCoord.y - 10);
    };

    const calculateBreakEven = () => {
        const fixedCosts = parseFloat(document.getElementById('fixed-costs').value) || 0;
        const variableCost = parseFloat(document.getElementById('variable-cost').value) || 0;
        const sellingPrice = parseFloat(document.getElementById('selling-price').value) || 0;

        const errorMsg = document.getElementById('error-msg');

        if (sellingPrice <= variableCost && sellingPrice > 0 && variableCost > 0) {
            errorMsg.style.display = 'block';
            document.getElementById('be-units').innerText = '0';
            document.getElementById('be-revenue').innerText = '$0.00';
            drawChart(fixedCosts, variableCost, sellingPrice, 0);
            return;
        }

        errorMsg.style.display = 'none';

        let beUnits = 0;
        let beRevenue = 0;

        if (sellingPrice > variableCost) {
            beUnits = fixedCosts / (sellingPrice - variableCost);
            beRevenue = beUnits * sellingPrice;
        }

        document.getElementById('be-units').innerText = formatNumber(Math.ceil(beUnits)); // usually units are whole
        document.getElementById('be-revenue').innerText = formatCurrency(beRevenue);

        drawChart(fixedCosts, variableCost, sellingPrice, beUnits);
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"]');
    inputs.forEach(input => {
        input.addEventListener('input', calculateBreakEven);
    });

    // Handle window resize for canvas
    window.addEventListener('resize', calculateBreakEven);

    // Initial calculation
    setTimeout(() => {
        calculateBreakEven();
    }, 0);
  </script>
</SiteLayout>
