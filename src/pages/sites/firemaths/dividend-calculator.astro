---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Dividend Reinvestment Calculator",
  "url": "https://firemaths.info/dividend-calculator",
  "description": "Calculate DRIP (Dividend Reinvestment Plan) growth projections over time based on stock price, yield, and holding period.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Dividend Reinvestment Calculator | firemaths.info"
  description="Calculate dividend reinvestment plan (DRIP) growth projections over time based on stock price, dividend yield, and holding period."
  canonical="https://firemaths.info/dividend-calculator" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" id="inputs-card">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Investment Details</h2>
                </div>

                <div class="inputs">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="shares">Initial Number of Shares</label>
                        <div class="relative flex items-center">
                            <input type="number" id="shares" value="100" min="0" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="stock-price">Stock Price</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="stock-price" value="150" min="0" step="0.01" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="dividend-yield">Annual Dividend Yield</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                            <input type="number" id="dividend-yield" value="3.5" min="0" step="0.1" max="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="holding-period">Holding Period (Years)</label>
                        <div class="relative flex items-center">
                            <input type="number" id="holding-period" value="10" min="1" max="50" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" id="results-card">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2"><span class="w-3 h-3 rounded-full inline-block bg-[var(--chart-color-a)]"></span> DRIP Projection</h2>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full" style="margin-top: 0; padding-top: 0; border-top: none;">
                    <div class="flex justify-between items-center mb-8 pb-6 border-b border-[var(--border-color)]">
                        <span class="text-[var(--text-secondary)] text-base font-medium">Final Portfolio Value</span>
                        <div class="font-mono text-2xl md:text-3xl font-bold text-[var(--accent-color)] flex items-center gap-3">
                            <span id="final-value">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('final-value', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Initial Portfolio Value</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="initial-value">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Total Shares Owned</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-shares">0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Final Annual Dividend Income</span>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                            <span id="annual-dividend">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('annual-dividend', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Total Dividends Reinvested</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-dividends">$0</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-16 shadow-sm">
            <div class="mb-6 text-center">
                <h2>Compound Growth Over Time</h2>
            </div>
            <div class="w-full h-[400px] relative">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">What is a DRIP (Dividend Reinvestment Plan)?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">A Dividend Reinvestment Plan, commonly known as a DRIP, is an investment strategy where the cash dividends you receive from owning a stock are automatically used to purchase more shares of that same stock. This creates a compounding effect, as your growing number of shares will pay increasingly larger dividends over time.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">By reinvesting dividends, you continuously put your earnings back to work, which is one of the fundamental principles of building long-term wealth.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">The Power of Compounding Dividends</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Compounding is often referred to as the "eighth wonder of the world." When you reinvest dividends, you earn "dividends on your dividends." Over long holding periods, this exponential growth can dramatically increase your total portfolio value and your annual passive income stream.</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>Accelerated Share Accumulation:</strong> Every dividend payment increases your total share count, even if you never add more out-of-pocket cash.</li>
                <li><strong>Passive Income Growth:</strong> As your share count grows, your future dividend payments grow proportionally, accelerating your path to financial independence.</li>
                <li><strong>Dollar-Cost Averaging:</strong> Reinvesting dividends automatically buys more shares when prices are low and fewer shares when prices are high, which can be an effective long-term strategy.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">How to Use This Calculator</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">To project your dividend growth, simply enter the initial number of shares you own, the current stock price, the annual dividend yield (as a percentage), and your expected holding period in years. The calculator will assume that dividends are paid and reinvested annually, compounding your returns over the specified timeframe.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The chart visualizes your portfolio's growth, demonstrating how reinvested dividends significantly boost your total value compared to taking the dividends as cash.</p>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    // Format number (for shares)
    const formatNumber = (value) => {
        return new Intl.NumberFormat('en-US', {
            maximumFractionDigits: 2
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // Calculation logic
    const calculateDRIP = (initialShares, stockPrice, dividendYieldPercent, years) => {
        const annualYield = dividendYieldPercent / 100;

        let currentShares = initialShares;
        let totalDividends = 0;

        const history = [];

        // Initial state (Year 0)
        history.push({
            year: 0,
            shares: currentShares,
            value: currentShares * stockPrice
        });

        for (let i = 1; i <= years; i++) {
            // Calculate dividend for the year based on current shares and stock price
            const annualDividendAmount = currentShares * stockPrice * annualYield;
            totalDividends += annualDividendAmount;

            // Calculate new shares purchased with the dividend
            const newShares = annualDividendAmount / stockPrice;
            currentShares += newShares;

            // Record state at the end of the year
            history.push({
                year: i,
                shares: currentShares,
                value: currentShares * stockPrice
            });
        }

        const initialValue = initialShares * stockPrice;
        const finalValue = currentShares * stockPrice;
        const finalAnnualDividend = currentShares * stockPrice * annualYield;

        return {
            initialValue,
            finalValue,
            finalShares: currentShares,
            finalAnnualDividend,
            totalDividends,
            history
        };
    };

    // Charting logic using vanilla canvas
    let chartCanvas = document.getElementById('growthChart');
    let ctx = chartCanvas.getContext('2d');

    const drawChart = (history, years) => {
        // Handle DPI for crisp text
        const dpr = window.devicePixelRatio || 1;
        const rect = chartCanvas.parentElement.getBoundingClientRect();

        chartCanvas.width = rect.width * dpr;
        chartCanvas.height = rect.height * dpr;

        ctx.setTransform(1, 0, 0, 1, 0, 0); // reset transform
        ctx.scale(dpr, dpr);

        const width = rect.width;
        const height = rect.height;

        ctx.clearRect(0, 0, width, height);

        const padding = { top: 20, right: 20, bottom: 40, left: 80 };
        const chartWidth = width - padding.left - padding.right;
        const chartHeight = height - padding.top - padding.bottom;

        const maxYears = years;
        const maxVal = history[history.length - 1].value;

        // Draw grid and axes
        ctx.strokeStyle = '#2a2010';
        ctx.lineWidth = 1;
        ctx.font = '12px Inter, sans-serif';
        ctx.fillStyle = '#888888';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        // Y-axis
        const yTicks = 5;
        for (let i = 0; i <= yTicks; i++) {
            const val = maxVal * (i / yTicks);
            const y = height - padding.bottom - (chartHeight * (i / yTicks));

            ctx.beginPath();
            ctx.moveTo(padding.left, y);
            ctx.lineTo(width - padding.right, y);
            ctx.stroke();

            let label = val >= 1000000 ? '$' + (val / 1000000).toFixed(1) + 'M' :
                        val >= 1000 ? '$' + (val / 1000).toFixed(0) + 'k' : '$' + val.toFixed(0);
            ctx.fillText(label, padding.left - 10, y);
        }

        // X-axis
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const xTicks = Math.min(maxYears, 10);
        for (let i = 0; i <= xTicks; i++) {
            const yearIndex = Math.round((maxYears / xTicks) * i);
            const x = padding.left + (chartWidth * (yearIndex / maxYears));

            ctx.beginPath();
            ctx.moveTo(x, height - padding.bottom);
            ctx.lineTo(x, height - padding.bottom + 5);
            ctx.stroke();

            ctx.fillText('Yr ' + yearIndex, x, height - padding.bottom + 10);
        }

        // Draw line
        const drawLine = (data, color) => {
            ctx.beginPath();
            ctx.strokeStyle = color;
            ctx.lineWidth = 3;
            ctx.lineJoin = 'round';

            // map data to maxYears to ensure it stops at correct year visually
            data.forEach((point, i) => {
                const x = padding.left + (chartWidth * (point.year / maxYears));
                const y = height - padding.bottom - (chartHeight * (point.value / maxVal));

                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.stroke();

            // Fill area under line
            ctx.lineTo(padding.left + chartWidth, height - padding.bottom);
            ctx.lineTo(padding.left, height - padding.bottom);
            ctx.closePath();

            const gradient = ctx.createLinearGradient(0, padding.top, 0, height - padding.bottom);
            const r = parseInt(color.slice(1,3), 16);
            const g = parseInt(color.slice(3,5), 16);
            const b = parseInt(color.slice(5,7), 16);

            gradient.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0.2)`);
            gradient.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);

            ctx.fillStyle = gradient;
            ctx.fill();
        };

        // Draw scenario A
        drawLine(history, '#D4A017');
    };

    const updateCalculator = () => {
        const initialShares = parseFloat(document.getElementById('shares').value) || 0;
        const stockPrice = parseFloat(document.getElementById('stock-price').value) || 0;
        const dividendYield = parseFloat(document.getElementById('dividend-yield').value) || 0;
        const years = parseInt(document.getElementById('holding-period').value) || 0;

        const results = calculateDRIP(initialShares, stockPrice, dividendYield, years);

        document.getElementById('final-value').innerText = formatCurrency(results.finalValue);
        document.getElementById('initial-value').innerText = formatCurrency(results.initialValue);
        document.getElementById('total-shares').innerText = formatNumber(results.finalShares);
        document.getElementById('annual-dividend').innerText = formatCurrency(results.finalAnnualDividend);
        document.getElementById('total-dividends').innerText = formatCurrency(results.totalDividends);

        drawChart(results.history, years);
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"]');
    inputs.forEach(input => {
        input.addEventListener('input', updateCalculator);
    });

    // Handle window resize for canvas
    window.addEventListener('resize', () => {
        updateCalculator();
    });

    // Initial calculation
    // Timeout added to ensure layout is done for canvas size
    setTimeout(() => {
        updateCalculator();
    }, 0);
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-investing-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Beginner's Guide to Investing Your Money</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
