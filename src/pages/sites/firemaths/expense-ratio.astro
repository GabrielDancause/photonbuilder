---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Expense Ratio Calculator",
  "url": "https://firemaths.info/expense-ratio",
  "description": "Calculate the impact of fund expense ratios on your investment returns over time. Compare the cost of fees between different funds side by side.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Expense Ratio Calculator | firemaths.info"
  description="Calculate the impact of fund expense ratios on your investment returns over time. Compare the cost of fees between different funds side by side."
  canonical="https://firemaths.info/expense-ratio" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <!-- Scenario A -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" id="scenario-a">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2"><span class="w-3 h-3 rounded-full inline-block bg-[var(--chart-color-a)]"></span> Fund A</h2>
                </div>

                <div class="inputs">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="initial-a">Initial Investment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="initial-a" value="10000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="monthly-a">Monthly Contribution</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="monthly-a" value="500" min="0" step="50" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="rate-a">Expected Annual Return</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                            <input type="number" id="rate-a" value="8" min="0" step="0.1" max="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="expense-a">Expense Ratio</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                            <input type="number" id="expense-a" value="0.04" min="0" step="0.01" max="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="years-a">Years to Grow</label>
                        <div class="relative flex items-center">
                            <input type="number" id="years-a" value="30" min="1" max="50" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                    <div class="flex justify-between items-center mb-8 pb-6 border-b border-[var(--border-color)]">
                        <span class="text-[var(--text-secondary)] text-base font-medium">Final Balance</span>
                        <div class="font-mono text-2xl md:text-3xl font-bold text-[var(--accent-color)] flex items-center gap-3">
                            <span id="final-balance-a">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('final-balance-a', this)">Copy</button>
                        </div>
                    </div>
                    <div class="result-item result-error">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Cost of Fees</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-fees-a">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Total Contributions</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-contributions-a">$0</span>
                    </div>
                </div>
            </div>

            <!-- Scenario B -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" id="scenario-b">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2"><span class="w-3 h-3 rounded-full inline-block bg-[var(--chart-color-b)]"></span> Fund B</h2>
                </div>

                <div class="inputs">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="initial-b">Initial Investment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="initial-b" value="10000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="monthly-b">Monthly Contribution</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="monthly-b" value="500" min="0" step="50" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="rate-b">Expected Annual Return</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                            <input type="number" id="rate-b" value="8" min="0" step="0.1" max="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="expense-b">Expense Ratio</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                            <input type="number" id="expense-b" value="0.75" min="0" step="0.01" max="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="years-b">Years to Grow</label>
                        <div class="relative flex items-center">
                            <input type="number" id="years-b" value="30" min="1" max="50" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                    <div class="flex justify-between items-center mb-8 pb-6 border-b border-[var(--border-color)]">
                        <span class="text-[var(--text-secondary)] text-base font-medium">Final Balance</span>
                        <div class="font-mono text-2xl md:text-3xl font-bold text-[var(--accent-color)] flex items-center gap-3">
                            <span id="final-balance-b">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('final-balance-b', this)">Copy</button>
                        </div>
                    </div>
                    <div class="result-item result-error">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Cost of Fees</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-fees-b">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Total Contributions</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-contributions-b">$0</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-16 shadow-sm">
            <div class="mb-6 text-center">
                <h2>Net Balance Comparison</h2>
            </div>
            <div class="w-full h-[400px] relative">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">What is an Expense Ratio?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">An expense ratio is the annual fee that all funds or ETFs charge their shareholders. It represents the percentage of your investment that goes toward the fund's operational costs, management fees, and administrative expenses. For example, if you invest $10,000 in a mutual fund with an expense ratio of 1%, you will pay $100 in fees for that year.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">While an expense ratio like 0.50% or 1% may seem small, it is charged every year on your entire portfolio balance, not just the profits. Over decades, this recurring fee compounds and can dramatically reduce your final portfolio value.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">How Fees Impact Compounding</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When you pay fees, you are not just losing the amount of the fee itself; you are also losing all the future growth that money would have generated if it remained invested. This is known as the "opportunity cost" of fees.</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>The 1% Difference:</strong> Over a 30-year period, paying a 1% higher expense ratio can cost you hundreds of thousands of dollars in lost compounding.</li>
                <li><strong>Passive vs. Active:</strong> Passive index funds typically have very low expense ratios (e.g., 0.03% to 0.10%), while actively managed funds often charge significantly more (e.g., 0.50% to 1.50%).</li>
                <li><strong>Net Returns Matter:</strong> A fund that earns an 8% return but charges a 1% expense ratio leaves you with a 7% net return. Always evaluate your investments based on net returns.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Comparing Fund Costs</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Using our expense ratio calculator, you can visualize the impact of fees over time. Try comparing a low-cost index fund (Fund A) with an expense ratio of 0.04% to an actively managed fund (Fund B) with an expense ratio of 0.75%, assuming the same gross return. You'll quickly see how much wealth is transferred from your pocket to the fund manager's over a lifetime of investing.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">By keeping your investment costs low, you can keep more of your hard-earned money and reach your financial independence goals faster.</p>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // Calculation logic
    const calculateExpenseRatio = (initial, monthly, rate, expense, years) => {
        const grossMonthlyRate = (rate / 100) / 12;
        const netMonthlyRate = ((Math.max(0, rate - expense)) / 100) / 12;
        const totalMonths = years * 12;

        let grossBalance = initial;
        let netBalance = initial;
        let totalContributions = initial;

        const history = [netBalance];

        for (let i = 1; i <= totalMonths; i++) {
            grossBalance = grossBalance * (1 + grossMonthlyRate) + monthly;
            netBalance = netBalance * (1 + netMonthlyRate) + monthly;
            totalContributions += monthly;

            if (i % 12 === 0) {
                history.push(netBalance);
            }
        }

        return {
            finalBalance: netBalance,
            totalContributions: totalContributions,
            totalFees: grossBalance - netBalance,
            history: history
        };
    };

    // Charting logic using vanilla canvas
    let chartCanvas = document.getElementById('growthChart');
    let ctx = chartCanvas.getContext('2d');

    const drawChart = (dataA, dataB, yearsA, yearsB) => {
        // Handle DPI for crisp text
        const dpr = window.devicePixelRatio || 1;
        const rect = chartCanvas.parentElement.getBoundingClientRect();

        chartCanvas.width = rect.width * dpr;
        chartCanvas.height = rect.height * dpr;

        ctx.setTransform(1, 0, 0, 1, 0, 0); // reset transform
        ctx.scale(dpr, dpr);

        const width = rect.width;
        const height = rect.height;

        ctx.clearRect(0, 0, width, height);

        const padding = { top: 20, right: 20, bottom: 40, left: 80 };
        const chartWidth = width - padding.left - padding.right;
        const chartHeight = height - padding.top - padding.bottom;

        const maxYears = Math.max(yearsA, yearsB);
        const maxVal = Math.max(...dataA, ...dataB);

        // Draw grid and axes
        ctx.strokeStyle = '#2a2010';
        ctx.lineWidth = 1;
        ctx.font = '12px Inter, sans-serif';
        ctx.fillStyle = '#888888';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        // Y-axis
        const yTicks = 5;
        for (let i = 0; i <= yTicks; i++) {
            const val = maxVal * (i / yTicks);
            const y = height - padding.bottom - (chartHeight * (i / yTicks));

            ctx.beginPath();
            ctx.moveTo(padding.left, y);
            ctx.lineTo(width - padding.right, y);
            ctx.stroke();

            let label = val >= 1000000 ? '$' + (val / 1000000).toFixed(1) + 'M' :
                        val >= 1000 ? '$' + (val / 1000).toFixed(0) + 'k' : '$' + val.toFixed(0);
            ctx.fillText(label, padding.left - 10, y);
        }

        // X-axis
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const xTicks = Math.min(maxYears, 10);
        for (let i = 0; i <= xTicks; i++) {
            const yearIndex = Math.round((maxYears / xTicks) * i);
            const x = padding.left + (chartWidth * (yearIndex / maxYears));

            ctx.beginPath();
            ctx.moveTo(x, height - padding.bottom);
            ctx.lineTo(x, height - padding.bottom + 5);
            ctx.stroke();

            ctx.fillText('Yr ' + yearIndex, x, height - padding.bottom + 10);
        }

        // Draw lines
        const drawLine = (data, color, maxDataYears) => {
            ctx.beginPath();
            ctx.strokeStyle = color;
            ctx.lineWidth = 3;
            ctx.lineJoin = 'round';

            // map data to maxYears to ensure it stops at correct year visually
            data.forEach((val, i) => {
                const x = padding.left + (chartWidth * (i / maxYears));
                const y = height - padding.bottom - (chartHeight * (val / maxVal));

                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.stroke();

            // Fill area under line
            ctx.lineTo(padding.left + (chartWidth * (data.length - 1) / maxYears), height - padding.bottom);
            ctx.lineTo(padding.left, height - padding.bottom);
            ctx.closePath();

            const gradient = ctx.createLinearGradient(0, padding.top, 0, height - padding.bottom);
            const r = parseInt(color.slice(1,3), 16);
            const g = parseInt(color.slice(3,5), 16);
            const b = parseInt(color.slice(5,7), 16);

            gradient.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0.2)`);
            gradient.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);

            ctx.fillStyle = gradient;
            ctx.fill();
        };

        // Draw scenario B first (so A can be on top if needed)
        drawLine(dataB, '#4A90E2', yearsB);
        drawLine(dataA, '#D4A017', yearsA);
    };

    const updateCalculator = () => {
        const getVals = (prefix) => ({
            initial: parseFloat(document.getElementById(`initial-${prefix}`).value) || 0,
            monthly: parseFloat(document.getElementById(`monthly-${prefix}`).value) || 0,
            rate: parseFloat(document.getElementById(`rate-${prefix}`).value) || 0,
            expense: parseFloat(document.getElementById(`expense-${prefix}`).value) || 0,
            years: parseInt(document.getElementById(`years-${prefix}`).value) || 0
        });

        const valA = getVals('a');
        const valB = getVals('b');

        const resA = calculateExpenseRatio(valA.initial, valA.monthly, valA.rate, valA.expense, valA.years);
        const resB = calculateExpenseRatio(valB.initial, valB.monthly, valB.rate, valB.expense, valB.years);

        const updateUI = (prefix, res) => {
            document.getElementById(`final-balance-${prefix}`).innerText = formatCurrency(res.finalBalance);
            document.getElementById(`total-contributions-${prefix}`).innerText = formatCurrency(res.totalContributions);
            document.getElementById(`total-fees-${prefix}`).innerText = formatCurrency(res.totalFees);
        };

        updateUI('a', resA);
        updateUI('b', resB);

        drawChart(resA.history, resB.history, valA.years, valB.years);
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"]');
    inputs.forEach(input => {
        input.addEventListener('input', updateCalculator);
    });

    // Handle window resize for canvas
    window.addEventListener('resize', () => {
        updateCalculator();
    });

    // Initial calculation
    // Timeout added to ensure layout is done for canvas size
    setTimeout(() => {
        updateCalculator();
    }, 0);
  </script>
</SiteLayout>
