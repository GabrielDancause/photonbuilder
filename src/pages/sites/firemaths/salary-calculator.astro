---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Salary Calculator: Convert Hourly, Weekly, Monthly, and Annual Pay",
  description: "Free salary calculator to convert your income into hourly, daily, weekly, bi-weekly, monthly, and annual equivalents. Calculate gross and estimated net pay.",
  category: "tool",
  published: true
};

const schemaObj = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate my annual salary from an hourly rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply your hourly rate by the number of hours you work per week, and then multiply that result by 52 weeks in a year. For a standard 40-hour work week, multiply your hourly rate by 2,080."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between gross pay and net pay?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gross pay is your total earnings before any taxes or deductions are taken out. Net pay, also known as take-home pay, is the amount you actually receive after taxes, benefits, and other deductions are subtracted from your gross pay."
      }
    },
    {
      "@type": "Question",
      "name": "How many pay periods are in a year?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There are 52 weekly pay periods, 26 bi-weekly pay periods, 24 semi-monthly pay periods, and 12 monthly pay periods in a standard calendar year."
      }
    },
    {
      "@type": "Question",
      "name": "How is daily rate calculated from an annual salary?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To find your daily rate, divide your annual salary by the number of days you work in a year. For a standard 5-day work week, there are typically 260 working days in a year."
      }
    },
    {
      "@type": "Question",
      "name": "Does this calculator account for taxes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This calculator provides an option to enter an estimated tax rate to calculate your net pay. Keep in mind that actual taxes depend on your specific location, tax bracket, filing status, and other personal deductions."
      }
    }
  ]
};

const schema = JSON.stringify(schemaObj);
---
<SiteLayout site="firemaths" title={meta.title} description={meta.description} canonical="https://firemaths.com/salary-calculator" schema={schema}>
  <div class="page-content">
    <div class="container">
      <h1>Salary Calculator</h1>
      <p>Convert your salary into hourly, daily, weekly, bi-weekly, monthly, and annual equivalents. See the difference between gross earnings and estimated net pay after deductions.</p>

      <div class="calculator-card">
        <h3>Income Details</h3>

        <div class="input-grid">
          <div class="input-group">
            <label for="payAmount">Amount</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="payAmount" value="50000" min="0" step="1000">
            </div>
          </div>

          <div class="input-group">
            <label for="payPeriod">Per</label>
            <select id="payPeriod" class="custom-select">
              <option value="year" selected>Year</option>
              <option value="month">Month</option>
              <option value="biweek">Bi-Week</option>
              <option value="week">Week</option>
              <option value="day">Day</option>
              <option value="hour">Hour</option>
            </select>
          </div>

          <div class="input-group">
            <label for="hoursPerWeek">Hours/Week</label>
            <div class="input-wrapper">
              <input type="number" id="hoursPerWeek" value="40" min="1" max="168" step="1">
              <span class="suffix">hrs</span>
            </div>
          </div>

          <div class="input-group">
            <label for="daysPerWeek">Days/Week</label>
            <div class="input-wrapper">
              <input type="number" id="daysPerWeek" value="5" min="1" max="7" step="1">
              <span class="suffix">days</span>
            </div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="input-group deductions">
          <label for="taxRate">Estimated Taxes & Deductions</label>
          <div class="input-wrapper">
            <input type="number" id="taxRate" value="25" min="0" max="100" step="1">
            <span class="suffix">%</span>
          </div>
          <small class="helper-text">Enter an estimated percentage for taxes, insurance, and other deductions to see net pay.</small>
        </div>
      </div>

      <div class="results-section">
        <h2 class="results-title">Salary Breakdown</h2>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Frequency</th>
                <th>Gross Pay</th>
                <th>Net Pay <span class="tax-note">(After <span id="taxDisplay">25</span>%)</span></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Hourly</td>
                <td id="resHourlyGross" class="gross-val">$0.00</td>
                <td id="resHourlyNet" class="net-val">$0.00</td>
              </tr>
              <tr>
                <td>Daily</td>
                <td id="resDailyGross" class="gross-val">$0.00</td>
                <td id="resDailyNet" class="net-val">$0.00</td>
              </tr>
              <tr>
                <td>Weekly</td>
                <td id="resWeeklyGross" class="gross-val">$0.00</td>
                <td id="resWeeklyNet" class="net-val">$0.00</td>
              </tr>
              <tr>
                <td>Bi-Weekly</td>
                <td id="resBiWeeklyGross" class="gross-val">$0.00</td>
                <td id="resBiWeeklyNet" class="net-val">$0.00</td>
              </tr>
              <tr>
                <td>Monthly</td>
                <td id="resMonthlyGross" class="gross-val">$0.00</td>
                <td id="resMonthlyNet" class="net-val">$0.00</td>
              </tr>
              <tr class="highlight-row">
                <td>Annually</td>
                <td id="resAnnuallyGross" class="gross-val">$0.00</td>
                <td id="resAnnuallyNet" class="net-val">$0.00</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="content-section">
        <h2>Understanding the Math Behind Your Paycheck</h2>
        <p>A salary calculator helps you translate a specific income figure into other timeframes. Whether you're trying to figure out how much an hourly wage equates to annually or how much of your yearly salary you take home each month, the math involves standardizing units.</p>

        <h3>Core Conversions</h3>
        <p>To ensure accuracy across all conversions, the calculator first standardizes any inputted amount into an annual figure. From there, it breaks it down:</p>
        <ul>
          <li><strong>Hourly Rate:</strong> Annual Salary ÷ (Hours per Week × 52 Weeks)</li>
          <li><strong>Daily Rate:</strong> Hourly Rate × (Hours per Week ÷ Days per Week)</li>
          <li><strong>Weekly Rate:</strong> Annual Salary ÷ 52</li>
          <li><strong>Bi-Weekly Rate:</strong> Annual Salary ÷ 26</li>
          <li><strong>Monthly Rate:</strong> Annual Salary ÷ 12</li>
        </ul>
        <p>For example, if you work 40 hours a week and 5 days a week, a $50,000 annual salary converts to $24.04 per hour ($50,000 ÷ 2,080 working hours).</p>

        <h3>Gross vs. Net Pay</h3>
        <p>Your <strong>gross pay</strong> is the total amount you earn before any deductions. The <strong>net pay</strong> is your "take-home" amount—what actually hits your bank account after taxes (federal, state, and local), Social Security, Medicare, retirement contributions, and insurance premiums are subtracted.</p>
        <p>By default, this calculator applies a rough 25% deduction rate to estimate net pay, but you can adjust this percentage based on your actual tax brackets and deductions.</p>
      </div>

      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>

        <details class="faq-details">
          <summary>How do I calculate my annual salary from an hourly rate?</summary>
          <div class="faq-content">
            <p>Multiply your hourly rate by the number of hours you work per week, and then multiply that result by 52 weeks in a year. For a standard 40-hour work week, multiply your hourly rate by 2,080.</p>
          </div>
        </details>

        <details class="faq-details">
          <summary>What is the difference between gross pay and net pay?</summary>
          <div class="faq-content">
            <p>Gross pay is your total earnings before any taxes or deductions are taken out. Net pay, also known as take-home pay, is the amount you actually receive after taxes, benefits, and other deductions are subtracted from your gross pay.</p>
          </div>
        </details>

        <details class="faq-details">
          <summary>How many pay periods are in a year?</summary>
          <div class="faq-content">
            <p>There are 52 weekly pay periods, 26 bi-weekly pay periods, 24 semi-monthly pay periods, and 12 monthly pay periods in a standard calendar year.</p>
          </div>
        </details>

        <details class="faq-details">
          <summary>How is daily rate calculated from an annual salary?</summary>
          <div class="faq-content">
            <p>To find your daily rate, divide your annual salary by the number of days you work in a year. For a standard 5-day work week, there are typically 260 working days in a year.</p>
          </div>
        </details>

        <details class="faq-details">
          <summary>Does this calculator account for taxes?</summary>
          <div class="faq-content">
            <p>This calculator provides an option to enter an estimated tax rate to calculate your net pay. Keep in mind that actual taxes depend on your specific location, tax bracket, filing status, and other personal deductions.</p>
          </div>
        </details>
      </div>
    </div>
  </div>
</SiteLayout>
<script>
  function initSalaryCalculator() {
    const payAmountInput = document.getElementById('payAmount');
    const payPeriodInput = document.getElementById('payPeriod');
    const hoursPerWeekInput = document.getElementById('hoursPerWeek');
    const daysPerWeekInput = document.getElementById('daysPerWeek');
    const taxRateInput = document.getElementById('taxRate');

    const taxDisplay = document.getElementById('taxDisplay');

    const resHourlyGross = document.getElementById('resHourlyGross');
    const resHourlyNet = document.getElementById('resHourlyNet');

    const resDailyGross = document.getElementById('resDailyGross');
    const resDailyNet = document.getElementById('resDailyNet');

    const resWeeklyGross = document.getElementById('resWeeklyGross');
    const resWeeklyNet = document.getElementById('resWeeklyNet');

    const resBiWeeklyGross = document.getElementById('resBiWeeklyGross');
    const resBiWeeklyNet = document.getElementById('resBiWeeklyNet');

    const resMonthlyGross = document.getElementById('resMonthlyGross');
    const resMonthlyNet = document.getElementById('resMonthlyNet');

    const resAnnuallyGross = document.getElementById('resAnnuallyGross');
    const resAnnuallyNet = document.getElementById('resAnnuallyNet');

    if (!payAmountInput || !payPeriodInput || !hoursPerWeekInput || !daysPerWeekInput || !taxRateInput) {
      return;
    }

    if (payAmountInput.dataset.initialized) {
      return;
    }
    payAmountInput.dataset.initialized = "true";

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value);
    }

    function calculate() {
      const amount = parseFloat(payAmountInput.value) || 0;
      const period = payPeriodInput.value;
      const hoursPerWeek = parseFloat(hoursPerWeekInput.value) || 40;
      const daysPerWeek = parseFloat(daysPerWeekInput.value) || 5;
      const taxRate = parseFloat(taxRateInput.value) || 0;

      taxDisplay.textContent = taxRate.toString();

      const weeksPerYear = 52;
      const monthsPerYear = 12;
      const hoursPerYear = hoursPerWeek * weeksPerYear;

      let annualGross = 0;

      // Standardize input to annual gross
      switch(period) {
        case 'year':
          annualGross = amount;
          break;
        case 'month':
          annualGross = amount * monthsPerYear;
          break;
        case 'biweek':
          annualGross = amount * (weeksPerYear / 2);
          break;
        case 'week':
          annualGross = amount * weeksPerYear;
          break;
        case 'day': {
          const daysPerYear = daysPerWeek * weeksPerYear;
          annualGross = amount * daysPerYear;
          break;
        }
        case 'hour':
          annualGross = amount * hoursPerYear;
          break;
      }

      const hourlyGross = annualGross / hoursPerYear;
      const dailyGross = hourlyGross * (hoursPerWeek / daysPerWeek);
      const weeklyGross = annualGross / weeksPerYear;
      const biWeeklyGross = annualGross / (weeksPerYear / 2);
      const monthlyGross = annualGross / monthsPerYear;

      const netMultiplier = 1 - (taxRate / 100);

      const hourlyNet = hourlyGross * netMultiplier;
      const dailyNet = dailyGross * netMultiplier;
      const weeklyNet = weeklyGross * netMultiplier;
      const biWeeklyNet = biWeeklyGross * netMultiplier;
      const monthlyNet = monthlyGross * netMultiplier;
      const annualNet = annualGross * netMultiplier;

      resHourlyGross.textContent = formatCurrency(hourlyGross);
      resHourlyNet.textContent = formatCurrency(hourlyNet);

      resDailyGross.textContent = formatCurrency(dailyGross);
      resDailyNet.textContent = formatCurrency(dailyNet);

      resWeeklyGross.textContent = formatCurrency(weeklyGross);
      resWeeklyNet.textContent = formatCurrency(weeklyNet);

      resBiWeeklyGross.textContent = formatCurrency(biWeeklyGross);
      resBiWeeklyNet.textContent = formatCurrency(biWeeklyNet);

      resMonthlyGross.textContent = formatCurrency(monthlyGross);
      resMonthlyNet.textContent = formatCurrency(monthlyNet);

      resAnnuallyGross.textContent = formatCurrency(annualGross);
      resAnnuallyNet.textContent = formatCurrency(annualNet);
    }

    const inputs = [payAmountInput, payPeriodInput, hoursPerWeekInput, daysPerWeekInput, taxRateInput];
    inputs.forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  }

  document.addEventListener('DOMContentLoaded', initSalaryCalculator);
  document.addEventListener('astro:page-load', initSalaryCalculator);
</script>

<style>
  .page-content {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    font-family: var(--font-ui, system-ui, sans-serif);
    color: var(--text-primary);
  }

  .container {
    width: 100%;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
    text-align: center;
    font-weight: 700;
  }

  h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
    font-weight: 700;
  }

  h3 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    font-weight: 600;
  }

  p {
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
  }

  li {
    margin-bottom: 0.5rem;
  }

  strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .calculator-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    margin: 2.5rem 0;
    box-shadow: 0 4px 6px -1px color-mix(in srgb, var(--text-primary) 10%, transparent);
  }

  .calculator-card h3 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    text-align: center;
    font-size: 1.5rem;
    color: var(--text-primary);
  }

  .input-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .input-group {
    margin-bottom: 1rem;
  }

  .input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .prefix {
    position: absolute;
    left: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-mono, monospace);
    font-size: 1rem;
    pointer-events: none;
  }

  .suffix {
    position: absolute;
    right: 1rem;
    color: var(--text-secondary);
    font-family: var(--font-mono, monospace);
    font-size: 1rem;
    pointer-events: none;
  }

  input[type="number"], .custom-select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono, monospace);
    font-size: 1.1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: border-color 0.2s;
    appearance: none;
    -moz-appearance: textfield;
  }

  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  input[type="number"]:focus, .custom-select:focus {
    outline: none;
    border-color: var(--accent-color);
  }

  input[type="number"] {
    padding-right: 3rem;
  }

  #payAmount {
    padding-left: 2rem;
  }

  .custom-select {
    background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%239CA3AF%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E");
    background-repeat: no-repeat;
    background-position: right 1rem top 50%;
    background-size: 0.65rem auto;
    padding-right: 2.5rem;
  }

  .divider {
    height: 1px;
    background-color: var(--border-color);
    margin: 1.5rem 0;
  }

  .deductions {
    max-width: 300px;
    margin: 0 auto;
    text-align: center;
  }

  .deductions label {
    text-align: center;
  }

  .helper-text {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-align: center;
  }

  .results-section {
    margin-top: 3rem;
  }

  .results-title {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .table-container {
    overflow-x: auto;
    margin-bottom: 2rem;
    border-radius: 12px;
    border: 1px solid var(--border-color);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background-color: var(--card-bg);
  }

  th, td {
    padding: 1rem 1.5rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }

  th {
    background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
    color: var(--accent-color);
    font-weight: 600;
  }

  td {
    color: var(--text-primary);
  }

  .tax-note {
    font-weight: normal;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-left: 0.5rem;
  }

  .gross-val, .net-val {
    font-family: var(--font-mono, monospace);
    font-weight: 600;
  }

  .net-val {
    color: var(--accent-color);
  }

  tr:last-child td {
    border-bottom: none;
  }

  .highlight-row {
    background-color: color-mix(in srgb, var(--accent-color) 5%, transparent);
  }

  .highlight-row td {
    font-weight: 700;
    font-size: 1.1rem;
  }

  .content-section {
    margin-top: 4rem;
  }

  .faq-section {
    margin-top: 4rem;
  }

  .faq-details {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .faq-details summary {
    padding: 1.25rem 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-details summary::-webkit-details-marker {
    display: none;
  }

  .faq-details summary::after {
    content: "+";
    color: var(--accent-color);
    font-size: 1.25rem;
    transition: transform 0.2s;
  }

  .faq-details[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-content {
    padding: 0 1.5rem 1.25rem;
    border-top: 1px solid var(--border-color);
    margin-top: 0.5rem;
    padding-top: 1rem;
  }

  .faq-content p {
    margin-bottom: 0;
  }

  @media (max-width: 600px) {
    .page-content {
      padding: 2rem 1rem;
    }

    h1 {
      font-size: 2rem;
    }

    h2 {
      font-size: 1.5rem;
    }

    .input-grid {
      grid-template-columns: 1fr;
    }

    th, td {
      padding: 0.75rem 1rem;
    }
  }
</style>
