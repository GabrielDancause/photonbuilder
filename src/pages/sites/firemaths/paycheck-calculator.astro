---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Paycheck Calculator",
  "url": "https://firemaths.info/paycheck-calculator",
  "description": "Estimate your net paycheck after deductions. Calculate federal tax, state tax, and benefits to find your true take-home pay.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Paycheck Calculator | firemaths.info"
  description="Estimate your net paycheck after deductions. Calculate federal tax, state tax, and benefits to find your true take-home pay."
  canonical="https://firemaths.info/paycheck-calculator" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Income & Frequency</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="gross-pay">Gross Pay (Annual)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="gross-pay" value="80000" min="0" step="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="pay-frequency">Pay Frequency</label>
                        <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="pay-frequency">
                            <option value="annual" selected>Annual</option>
                            <option value="monthly">Monthly</option>
                            <option value="semimonthly">Semi-monthly (twice a month)</option>
                            <option value="biweekly">Bi-weekly (every 2 weeks)</option>
                            <option value="weekly">Weekly</option>
                        </select>
                    </div>

                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]" style="margin-top: 2rem;">
                        <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Taxes & Deductions</h2>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="federal-tax">Federal Tax Rate (Effective)</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="state-tax">State Tax Rate (Effective)</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="fica-tax">FICA Tax (Social Security & Medicare)</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="benefits-deduction">Benefits & Other Deductions (per paycheck)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="benefits-deduction" value="150" min="0" step="10">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Paycheck Breakdown</h2>
                </div>

                <div class="bg-[var(--accent-color)] bg-opacity-10 border border-[var(--accent-color)] rounded-xl p-6 mb-8 text-center">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold">Estimated Net Paycheck</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="res-net-pay">$0.00</span>
                        <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-net-pay', this)">Copy</button>
                    </div>
                    <div class="text-[var(--text-secondary)] text-sm mt-2" id="res-frequency-note">Per pay period</div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Gross Paycheck</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-gross-pay">$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-gross-pay', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 deduction">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Federal Tax</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-federal-tax">-$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-federal-tax', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 deduction">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">State Tax</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-state-tax">-$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-state-tax', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 deduction">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">FICA Tax</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-fica-tax">-$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-fica-tax', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 deduction">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Benefits & Deductions</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-benefits">-$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-benefits', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-white text-sm font-bold">Total Deductions</span>
                        <div class="font-mono text-lg font-medium text-red-400 flex items-center gap-2">
                            <span id="res-total-deductions">-$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-total-deductions', this)">Copy</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding Your Paycheck and Deductions</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">A paycheck calculator is a vital tool for understanding exactly how much money you will take home after taxes and other deductions. The difference between your <strong>gross pay</strong> (the total amount you earn) and your <strong>net pay</strong> (the amount that actually hits your bank account) can be substantial, depending on your tax bracket and benefit elections.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">By simulating different gross income amounts, tax rates, and pay frequencies, you can better plan your personal finances, budget for expenses, and prepare for tax season.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Common Paycheck Deductions Explained</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Several standard deductions usually come out of your gross paycheck before you receive your net pay:</p>
            <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc space-y-2">
                <li><strong>Federal Income Tax:</strong> The largest deduction for most workers. It is based on your income level, filing status, and information provided on your W-4 form. The tax system is progressive, meaning higher income portions are taxed at higher rates.</li>
                <li><strong>State Income Tax:</strong> Most U.S. states impose an income tax, though the rates and structures vary widely. A few states have no income tax at all.</li>
                <li><strong>FICA Taxes (Social Security & Medicare):</strong> These are mandatory payroll taxes. Generally, employees pay 6.2% for Social Security (up to a certain wage base limit) and 1.45% for Medicare. Your employer matches these contributions.</li>
                <li><strong>Benefits and Pre-tax Deductions:</strong> Contributions to health insurance premiums, retirement accounts (like a 401(k)), and flexible spending accounts (FSAs) often come out of your paycheck. These are often deducted <em>before</em> income taxes are calculated, which can lower your taxable income.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">How Often Should I Be Paid?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Pay frequency affects the size of your individual paychecks, but not your total annual earnings. Common pay schedules include:</p>
            <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc space-y-2">
                <li><strong>Weekly:</strong> 52 paychecks per year.</li>
                <li><strong>Bi-weekly:</strong> Every two weeks, resulting in 26 paychecks per year. This is the most common schedule in the U.S.</li>
                <li><strong>Semi-monthly:</strong> Twice a month (e.g., on the 15th and the last day of the month), resulting in 24 paychecks per year.</li>
                <li><strong>Monthly:</strong> 12 paychecks per year.</li>
            </ul>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value, isNegative = false) => {
        const formatted = new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(Math.abs(value));
        return isNegative ? `-${formatted}` : formatted;
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const textElement = document.getElementById(elementId);
        let text = textElement.innerText;
        // Clean up text if it starts with minus for copying (optional, but usually helpful to keep minus)
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const updateCalculator = () => {
        const grossPayInput = parseFloat(document.getElementById('gross-pay').value) || 0;
        const payFreq = document.getElementById('pay-frequency').value;
        const fedTaxRate = parseFloat(document.getElementById('federal-tax').value) || 0;
        const stateTaxRate = parseFloat(document.getElementById('state-tax').value) || 0;
        const ficaTaxRate = parseFloat(document.getElementById('fica-tax').value) || 0;
        const benefitsDeduction = parseFloat(document.getElementById('benefits-deduction').value) || 0;

        let payPeriods = 1;

        switch (payFreq) {
            case 'annual':
                payPeriods = 1;
                document.getElementById('res-frequency-note').innerText = 'Per year';
                break;
            case 'monthly':
                payPeriods = 12;
                document.getElementById('res-frequency-note').innerText = 'Per month';
                break;
            case 'semimonthly':
                payPeriods = 24;
                document.getElementById('res-frequency-note').innerText = 'Per pay period (twice a month)';
                break;
            case 'biweekly':
                payPeriods = 26;
                document.getElementById('res-frequency-note').innerText = 'Per pay period (every 2 weeks)';
                break;
            case 'weekly':
                payPeriods = 52;
                document.getElementById('res-frequency-note').innerText = 'Per week';
                break;
        }

        // Treat Gross Pay input as Annual Gross
        const annualGross = grossPayInput;
        const grossPerPeriod = annualGross / payPeriods;

        const fedTax = grossPerPeriod * (fedTaxRate / 100);
        const stateTax = grossPerPeriod * (stateTaxRate / 100);
        const ficaTax = grossPerPeriod * (ficaTaxRate / 100);

        const totalDeductions = fedTax + stateTax + ficaTax + benefitsDeduction;
        const netPay = grossPerPeriod - totalDeductions;

        // Update UI
        document.getElementById('res-gross-pay').innerText = formatCurrency(grossPerPeriod);
        document.getElementById('res-federal-tax').innerText = formatCurrency(fedTax, true);
        document.getElementById('res-state-tax').innerText = formatCurrency(stateTax, true);
        document.getElementById('res-fica-tax').innerText = formatCurrency(ficaTax, true);
        document.getElementById('res-benefits').innerText = formatCurrency(benefitsDeduction, true);
        document.getElementById('res-total-deductions').innerText = formatCurrency(totalDeductions, true);
        document.getElementById('res-net-pay').innerText = formatCurrency(netPay);
    };

    // Attach event listeners
    const inputs = ['gross-pay', 'pay-frequency', 'federal-tax', 'state-tax', 'fica-tax', 'benefits-deduction'];
    inputs.forEach(id => {
        document.getElementById(id).addEventListener('input', updateCalculator);
        if(id === 'pay-frequency') {
            document.getElementById(id).addEventListener('change', updateCalculator);
        }
    });

    // Initial calculation
    updateCalculator();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-budgeting-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Budgeting for Beginners: Build Your Financial Foundation</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
