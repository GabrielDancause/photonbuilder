---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Paycheck Calculator",
  "url": "https://firemaths.info/paycheck-calculator",
  "description": "Free paycheck calculator to estimate your take home pay after federal and state taxes, Social Security, Medicare, 401k, and health insurance deductions.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How is federal income tax calculated on my paycheck?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Federal income tax uses a progressive bracket system. Your taxable income (gross pay minus pre-tax deductions like 401k and health insurance) is divided into brackets, each taxed at increasing rates from 10% to 37%. For example, a single filer earning $60,000 in 2024 pays 10% on the first $11,600, 12% on income from $11,601 to $47,150, and 22% on the remainder. The standard deduction ($14,600 for single filers) reduces your taxable income before brackets are applied."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between gross pay and net pay?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gross pay is your total earnings before any deductions — your salary or hourly wages times hours worked. Net pay (also called take-home pay) is what you actually receive after all deductions: federal income tax, state income tax, Social Security tax (6.2%), Medicare tax (1.45%), and voluntary deductions like 401k contributions and health insurance premiums. For most workers, net pay is 60-80% of gross pay depending on income level and state of residence."
      }
    },
    {
      "@type": "Question",
      "name": "How much does Social Security and Medicare take from my paycheck?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Social Security tax (FICA) is 6.2% of your gross wages up to the wage base limit of $168,600 in 2024. Medicare tax is 1.45% on all wages with no cap. If you earn over $200,000 (single) or $250,000 (married filing jointly), an additional 0.9% Medicare surtax applies to wages above those thresholds. Combined, most workers pay 7.65% of gross wages in FICA taxes, which is matched by your employer."
      }
    },
    {
      "@type": "Question",
      "name": "Which states have no income tax?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nine states have no state income tax: Alaska, Florida, Nevada, New Hampshire, South Dakota, Tennessee, Texas, Washington, and Wyoming. Note that New Hampshire and Tennessee historically taxed investment income but have phased those taxes out. Living in a no-income-tax state can significantly increase your take-home pay — a worker earning $75,000 could save $3,000-5,000 per year compared to living in a high-tax state like California or New York."
      }
    },
    {
      "@type": "Question",
      "name": "How do 401k contributions affect my paycheck?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Traditional 401k contributions are made pre-tax, meaning they reduce your taxable income for federal and state income taxes. However, they do not reduce your wages for Social Security and Medicare (FICA) tax purposes. For example, if you earn $80,000 and contribute 10% ($8,000) to your 401k, your federal and state taxes are calculated on $72,000, but FICA taxes are still calculated on $80,000. This tax deferral makes 401k contributions effectively cheaper than they appear — a $100 contribution might only reduce your take-home pay by $65-75."
      }
    },
    {
      "@type": "Question",
      "name": "How often do I get paid and does pay frequency affect my taxes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common pay frequencies are weekly (52 paychecks/year), biweekly (26 paychecks), semi-monthly (24 paychecks), and monthly (12 paychecks). Pay frequency does not change your total annual tax burden — it only affects the amount withheld per paycheck. However, biweekly pay can feel like a bonus twice a year since two months will have three paychecks instead of two. Semi-monthly and monthly pay result in larger individual checks but fewer of them."
      }
    },
    {
      "@type": "Question",
      "name": "What is the standard deduction for 2024?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard deduction for 2024 is $14,600 for single filers and married filing separately, $29,200 for married filing jointly, and $21,900 for head of household. The standard deduction reduces your taxable income before federal tax brackets are applied. Most taxpayers (about 90%) take the standard deduction rather than itemizing. If you have significant mortgage interest, state and local taxes, or charitable donations, you may benefit from itemizing instead."
      }
    },
    {
      "@type": "Question",
      "name": "How can I increase my take-home pay without a raise?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Several strategies can increase your net pay: (1) Review your W-4 withholding — if you consistently get large tax refunds, you may be over-withholding. (2) Contribute to a Flexible Spending Account (FSA) for healthcare or dependent care expenses to reduce taxable income. (3) If your employer offers a Health Savings Account (HSA), contributions are triple tax-advantaged. (4) Consider moving to a state with lower or no income tax. (5) Maximize employer-matched 401k contributions — while this reduces take-home pay, the match is free money that more than compensates."
      }
    }
  ]
};

export const meta = {
  title: "Paycheck Calculator | firemaths.info",
  description: "Free paycheck calculator to estimate your take home pay after federal tax, state tax, Social Security, Medicare, 401k, and health insurance deductions.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Paycheck Calculator | firemaths.info"
  description="Free paycheck calculator to estimate your take home pay after federal tax, state tax, Social Security, Medicare, 401k, and health insurance deductions."
  canonical="https://firemaths.info/paycheck-calculator" schema={schema}
>
  <style>
:root {
    --color-federal: #4A90E2;
    --color-state: #9B59B6;
    --color-ss: #E67E22;
    --color-medicare: #E74C3C;
    --color-deductions: #1ABC9C;
    --color-takehome: #2ECC71;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

select {
    font-family: var(--font-ui);
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23888888' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1em;
    padding-right: 2.5rem;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.chart-section h2 {
    text-align: center;
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
}

.chart-container {
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
}

.chart-legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
}

.chart-legend-color {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
}

.section-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.section-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.toggle-group {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
}

.toggle-btn {
    flex: 1;
    padding: 0.6rem 1rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    transition: all 0.2s;
}

.toggle-btn:first-child { border-radius: 6px 0 0 6px; }
.toggle-btn:last-child { border-radius: 0 6px 6px 0; }

.toggle-btn.active {
    background: var(--accent-color);
    color: #0c0a00;
    border-color: var(--accent-color);
    font-weight: 600;
}

.summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

@media (min-width: 768px) {
    .summary-grid {
        grid-template-columns: 1fr 1fr 1fr;
    }
}

.summary-item {
    padding: 1rem;
    background: var(--bg-color);
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.summary-item-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.summary-item-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--accent-color);
}

.breakdown-table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.breakdown-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.breakdown-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    text-align: right;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--border-color);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.breakdown-table th:first-child {
    text-align: left;
}

.breakdown-table td {
    padding: 0.6rem 0.75rem;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
}

.breakdown-table td:first-child {
    text-align: left;
    color: var(--text-primary);
    font-family: var(--font-ui);
}

.breakdown-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

.breakdown-table tfoot td {
    font-weight: 700;
    border-top: 2px solid var(--border-color);
    color: var(--accent-color);
}

.state-table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.state-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.state-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--border-color);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-align: left;
}

.state-table th:not(:first-child) {
    text-align: right;
}

.state-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
}

.state-table td:first-child {
    font-family: var(--font-ui);
    color: var(--text-primary);
}

.state-table td:not(:first-child) {
    text-align: right;
}

.state-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

.state-table .no-tax {
    color: var(--color-takehome);
}

.state-table .high-tax {
    color: var(--color-medicare);
}

.two-col-tables {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

@media (min-width: 768px) {
    .two-col-tables {
        grid-template-columns: 1fr 1fr;
    }
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.25rem 0;
}

.faq-question {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-size: 1rem;
}

.faq-answer {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
}

.related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
    margin-bottom: 4rem;
}

.related-link {
    display: block;
    padding: 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    transition: border-color 0.2s;
}

.related-link:hover {
    border-color: var(--accent-color);
}

.related-link span {
    display: block;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Paycheck Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:3rem;">Estimate your take home pay after federal and state taxes, Social Security, Medicare, and other deductions.</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Income Details</h2>
                </div>

                <div class="input-group">
                    <label for="gross-salary">Gross Salary</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="gross-salary" value="75000" min="0" step="1000">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="salary-type">Salary Type</label>
                        <select id="salary-type">
                            <option value="annual" selected>Annual</option>
                            <option value="per-paycheck">Per Paycheck</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label for="pay-frequency">Pay Frequency</label>
                        <select id="pay-frequency">
                            <option value="weekly">Weekly (52)</option>
                            <option value="biweekly" selected>Biweekly (26)</option>
                            <option value="semimonthly">Semi-Monthly (24)</option>
                            <option value="monthly">Monthly (12)</option>
                        </select>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="filing-status">Filing Status</label>
                        <select id="filing-status">
                            <option value="single" selected>Single</option>
                            <option value="married">Married Filing Jointly</option>
                            <option value="hoh">Head of Household</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label for="state">State</label>
                        <select id="state"></select>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="federal-allowances">Federal Allowances</label>
                        <input type="number" id="federal-allowances" value="0" min="0" max="10" step="1">
                    </div>
                    <div class="input-group">
                        <label for="contrib-401k">401(k) Contribution</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="contrib-401k" value="0" min="0" max="100" step="1">
                        </div>
                    </div>
                </div>

                <div class="input-group">
                    <label for="health-insurance">Health Insurance (per paycheck)</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="health-insurance" value="0" min="0" step="25">
                    </div>
                </div>
            </div>

            <!-- Results Summary -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your Take Home Pay</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Per Paycheck</span>
                        <div class="result-value">
                            <span id="res-per-paycheck">$0</span>
                            <button class="copy-btn" onclick="copyValue('res-per-paycheck', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Annual Take Home</span>
                        <span class="result-value" id="res-annual-net" style="font-size: 0.9375rem; color: var(--color-takehome);">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Annual Gross Pay</span>
                        <span class="result-value" id="res-annual-gross" style="font-size: 0.9375rem;">$0</span>
                    </div>

                    <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--border-color);">
                        <div class="result-item">
                            <span class="result-label">Federal Tax</span>
                            <span class="result-value" id="res-federal" style="font-size: 0.9375rem; color: var(--color-federal);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">State Tax</span>
                            <span class="result-value" id="res-state" style="font-size: 0.9375rem; color: var(--color-state);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Social Security</span>
                            <span class="result-value" id="res-ss" style="font-size: 0.9375rem; color: var(--color-ss);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Medicare</span>
                            <span class="result-value" id="res-medicare" style="font-size: 0.9375rem; color: var(--color-medicare);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">401(k) + Insurance</span>
                            <span class="result-value" id="res-pretax" style="font-size: 0.9375rem; color: var(--color-deductions);">$0</span>
                        </div>
