        <!-- Related -->
        <h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Related Calculators</h2>
        <div class="related-links">
            <a href="/retirement-savings-calculator" class="related-link">
                Retirement Savings Calculator
                <span>See how your 401(k) and IRA contributions grow over time toward your retirement goal</span>
            </a>
            <a href="/investment-calculator" class="related-link">
                Investment Calculator
                <span>Calculate potential returns on your investments with compound growth projections</span>
            </a>
        </div>
    </main>
</div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

window.copyValue = async (id, btn) => {
    const text = document.getElementById(id).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => btn.innerText = orig, 2000);
    } catch(e) {}
};

// State tax data — effective flat rate approximation for simplicity
const STATE_TAXES = {
    'Alabama': 0.05, 'Alaska': 0, 'Arizona': 0.025, 'Arkansas': 0.044,
    'California': 0.0725, 'Colorado': 0.044, 'Connecticut': 0.055, 'Delaware': 0.055,
    'Florida': 0, 'Georgia': 0.055, 'Hawaii': 0.068, 'Idaho': 0.058,
    'Illinois': 0.0495, 'Indiana': 0.0305, 'Iowa': 0.044, 'Kansas': 0.046,
    'Kentucky': 0.04, 'Louisiana': 0.0425, 'Maine': 0.0575, 'Maryland': 0.0575,
    'Massachusetts': 0.05, 'Michigan': 0.0425, 'Minnesota': 0.0685, 'Mississippi': 0.047,
    'Missouri': 0.048, 'Montana': 0.059, 'Nebraska': 0.0564, 'Nevada': 0,
    'New Hampshire': 0, 'New Jersey': 0.0547, 'New Mexico': 0.039, 'New York': 0.0685,
    'North Carolina': 0.045, 'North Dakota': 0.0195, 'Ohio': 0.035, 'Oklahoma': 0.0475,
    'Oregon': 0.0875, 'Pennsylvania': 0.0307, 'Rhode Island': 0.0525, 'South Carolina': 0.05,
    'South Dakota': 0, 'Tennessee': 0, 'Texas': 0, 'Utah': 0.0465,
    'Vermont': 0.066, 'Virginia': 0.0575, 'Washington': 0, 'West Virginia': 0.052,
    'Wisconsin': 0.0565, 'Wyoming': 0
};

// Populate state dropdown
const stateSelect = document.getElementById('state');
Object.keys(STATE_TAXES).sort().forEach(s => {
    const opt = document.createElement('option');
    opt.value = s;
    opt.textContent = s;
    if (s === 'California') opt.selected = true;
    stateSelect.appendChild(opt);
});

// 2024 Federal tax brackets
const BRACKETS = {
    single: [
        [11600, 0.10], [47150, 0.12], [100525, 0.22],
        [191950, 0.24], [243725, 0.32], [609350, 0.35], [Infinity, 0.37]
    ],
    married: [
        [23200, 0.10], [94300, 0.12], [201050, 0.22],
        [383900, 0.24], [487450, 0.32], [731200, 0.35], [Infinity, 0.37]
    ],
    hoh: [
        [16550, 0.10], [63100, 0.12], [100500, 0.22],
        [191950, 0.24], [243700, 0.32], [609350, 0.35], [Infinity, 0.37]
    ]
};

const STANDARD_DEDUCTION = { single: 14600, married: 29200, hoh: 21900 };
const SS_RATE = 0.062;
const SS_WAGE_BASE = 168600;
const MEDICARE_RATE = 0.0145;
const MEDICARE_SURTAX_THRESHOLD = { single: 200000, married: 250000, hoh: 200000 };
const MEDICARE_SURTAX_RATE = 0.009;

const FREQ_MAP = { weekly: 52, biweekly: 26, semimonthly: 24, monthly: 12 };

let breakdownView = 'paycheck';

function calcFederalTax(taxableIncome, status) {
    const brackets = BRACKETS[status];
    let tax = 0;
    let prev = 0;
    let marginalRate = 0.10;
    for (const [limit, rate] of brackets) {
        if (taxableIncome <= prev) break;
        const taxable = Math.min(taxableIncome, limit) - prev;
        tax += taxable * rate;
        if (taxableIncome <= limit) marginalRate = rate;
        prev = limit;
    }
    return { tax: Math.max(0, tax), marginalRate };
}

function calculate() {
    const grossInput = parseFloat(document.getElementById('gross-salary').value) || 0;
    const salaryType = document.getElementById('salary-type').value;
    const freq = document.getElementById('pay-frequency').value;
    const status = document.getElementById('filing-status').value;
    const state = document.getElementById('state').value;
    const allowances = parseInt(document.getElementById('federal-allowances').value) || 0;
    const contrib401k = (parseFloat(document.getElementById('contrib-401k').value) || 0) / 100;
    const healthIns = parseFloat(document.getElementById('health-insurance').value) || 0;
    const periodsPerYear = FREQ_MAP[freq];

    // Calculate annual gross
    const annualGross = salaryType === 'annual' ? grossInput : grossInput * periodsPerYear;
    const perPaycheckGross = annualGross / periodsPerYear;

    // Pre-tax deductions (annual)
    const annual401k = annualGross * contrib401k;
    const annualHealthIns = healthIns * periodsPerYear;
    const totalPreTax = annual401k + annualHealthIns;

    // Federal taxable income
    const stdDeduction = STANDARD_DEDUCTION[status];
    const allowanceDeduction = allowances * 4300;
    const federalTaxableIncome = Math.max(0, annualGross - totalPreTax - stdDeduction - allowanceDeduction);
    const { tax: annualFederalTax, marginalRate } = calcFederalTax(federalTaxableIncome, status);

    // State tax
    const stateTaxRate = STATE_TAXES[state] || 0;
    const stateTaxableIncome = Math.max(0, annualGross - totalPreTax);
    const annualStateTax = stateTaxableIncome * stateTaxRate;

    // FICA — calculated on gross (not reduced by 401k/health for income tax, but FICA is on gross)
    const ssTaxable = Math.min(annualGross, SS_WAGE_BASE);
    const annualSS = ssTaxable * SS_RATE;
    const annualMedicare = annualGross * MEDICARE_RATE +
        Math.max(0, annualGross - MEDICARE_SURTAX_THRESHOLD[status]) * MEDICARE_SURTAX_RATE;

    // Totals
    const totalTaxes = annualFederalTax + annualStateTax + annualSS + annualMedicare;
    const totalDeductions = totalTaxes + totalPreTax;
    const annualNet = annualGross - totalDeductions;
    const perPaycheckNet = annualNet / periodsPerYear;

    const effectiveRate = annualGross > 0 ? (totalTaxes / annualGross * 100) : 0;

    // Update results
    document.getElementById('res-per-paycheck').textContent = fmt2(perPaycheckNet);
    document.getElementById('res-annual-net').textContent = fmt(annualNet);
    document.getElementById('res-annual-gross').textContent = fmt(annualGross);
    document.getElementById('res-federal').textContent = '-' + fmt(annualFederalTax / periodsPerYear);
    document.getElementById('res-state').textContent = '-' + fmt(annualStateTax / periodsPerYear);
    document.getElementById('res-ss').textContent = '-' + fmt(annualSS / periodsPerYear);
    document.getElementById('res-medicare').textContent = '-' + fmt(annualMedicare / periodsPerYear);
    document.getElementById('res-pretax').textContent = '-' + fmt(totalPreTax / periodsPerYear);
    document.getElementById('res-effective-rate').textContent = effectiveRate.toFixed(1) + '%';
    document.getElementById('res-marginal-rate').textContent = (marginalRate * 100).toFixed(0) + '%';

    // Summary cards
    document.getElementById('sum-gross').textContent = fmt(annualGross);
    document.getElementById('sum-taxes').textContent = fmt(totalTaxes);
    document.getElementById('sum-deductions').textContent = fmt(totalPreTax);
    document.getElementById('sum-net').textContent = fmt(annualNet);
    document.getElementById('sum-monthly').textContent = fmt(annualNet / 12);
    document.getElementById('sum-rate').textContent = effectiveRate.toFixed(1) + '%';

    // Breakdown table
    renderBreakdown({
        gross: annualGross,
        federal: annualFederalTax,
        state: annualStateTax,
        ss: annualSS,
        medicare: annualMedicare,
        contrib401k: annual401k,
        healthIns: annualHealthIns,
        net: annualNet,
        periodsPerYear
    });

    // Pie chart
    drawPieChart({
        net: annualNet,
        federal: annualFederalTax,
        state: annualStateTax,
        ss: annualSS,
        medicare: annualMedicare,
        pretax: totalPreTax
    });

    // State comparison
    renderStateComparison(annualGross, totalPreTax, status, allowances, annualSS, annualMedicare);
}

function renderBreakdown(d) {
    const div = breakdownView === 'paycheck' ? d.periodsPerYear : 1;
    const rows = [
        ['Gross Pay', d.gross / div, 100],
        ['Federal Income Tax', -d.federal / div, d.federal / d.gross * 100],
        ['State Income Tax', -d.state / div, d.state / d.gross * 100],
        ['Social Security', -d.ss / div, d.ss / d.gross * 100],
        ['Medicare', -d.medicare / div, d.medicare / d.gross * 100],
        ['401(k) Contribution', -d.contrib401k / div, d.contrib401k / d.gross * 100],
        ['Health Insurance', -d.healthIns / div, d.healthIns / d.gross * 100],
    ];

    const tbody = document.getElementById('breakdown-tbody');
    tbody.innerHTML = rows.map(([label, amount, pct]) =>
        `<tr><td>${label}</td><td>${amount >= 0 ? fmt2(amount) : '-' + fmt2(Math.abs(amount))}</td><td>${pct.toFixed(1)}%</td></tr>`
    ).join('');

    const tfoot = document.getElementById('breakdown-tfoot');
    tfoot.innerHTML = `<tr><td>Net Take Home Pay</td><td>${fmt2(d.net / div)}</td><td>${(d.net / d.gross * 100).toFixed(1)}%</td></tr>`;
}

window.setBreakdownView = function(view) {
    breakdownView = view;
    document.getElementById('btn-paycheck').classList.toggle('active', view === 'paycheck');
    document.getElementById('btn-annual').classList.toggle('active', view === 'annual');
    calculate();
};

function drawPieChart(d) {
    const canvas = document.getElementById('pieChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    canvas.width = 400 * dpr;
    canvas.height = 400 * dpr;
    ctx.scale(dpr, dpr);

    const total = d.net + d.federal + d.state + d.ss + d.medicare + d.pretax;
    if (total <= 0) return;

    const slices = [
        { value: d.net, color: getComputedStyle(document.documentElement).getPropertyValue('--color-takehome').trim() || '#2ECC71' },
        { value: d.federal, color: getComputedStyle(document.documentElement).getPropertyValue('--color-federal').trim() || '#4A90E2' },
        { value: d.state, color: getComputedStyle(document.documentElement).getPropertyValue('--color-state').trim() || '#9B59B6' },
        { value: d.ss, color: getComputedStyle(document.documentElement).getPropertyValue('--color-ss').trim() || '#E67E22' },
        { value: d.medicare, color: getComputedStyle(document.documentElement).getPropertyValue('--color-medicare').trim() || '#E74C3C' },
        { value: d.pretax, color: getComputedStyle(document.documentElement).getPropertyValue('--color-deductions').trim() || '#1ABC9C' },
    ].filter(s => s.value > 0);

    const cx = 200, cy = 200, r = 160, ir = 90;
    let startAngle = -Math.PI / 2;

    ctx.clearRect(0, 0, 400, 400);

    slices.forEach(slice => {
        const sliceAngle = (slice.value / total) * Math.PI * 2;
        ctx.beginPath();
        ctx.moveTo(cx + ir * Math.cos(startAngle), cy + ir * Math.sin(startAngle));
        ctx.arc(cx, cy, r, startAngle, startAngle + sliceAngle);
        ctx.arc(cx, cy, ir, startAngle + sliceAngle, startAngle, true);
        ctx.closePath();
        ctx.fillStyle = slice.color;
        ctx.fill();

        // Draw percentage label if slice is large enough
        if (slice.value / total > 0.05) {
            const midAngle = startAngle + sliceAngle / 2;
            const labelR = (r + ir) / 2;
            const lx = cx + labelR * Math.cos(midAngle);
            const ly = cy + labelR * Math.sin(midAngle);
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 13px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(Math.round(slice.value / total * 100) + '%', lx, ly);
        }

        startAngle += sliceAngle;
    });

    // Center text
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim() || '#fff';
    ctx.font = 'bold 18px sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('Net Pay', cx, cy - 12);
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--accent-color').trim() || '#D4A017';
    ctx.font = 'bold 22px sans-serif';
    ctx.fillText(fmt(d.net), cx, cy + 14);
}

function renderStateComparison(annualGross, totalPreTax, status, allowances, annualSS, annualMedicare) {
    const stdDeduction = STANDARD_DEDUCTION[status];
    const allowanceDeduction = allowances * 4300;
    const federalTaxableIncome = Math.max(0, annualGross - totalPreTax - stdDeduction - allowanceDeduction);
    const { tax: annualFederalTax } = calcFederalTax(federalTaxableIncome, status);

    const stateData = Object.entries(STATE_TAXES).map(([name, rate]) => {
        const stateTax = Math.max(0, annualGross - totalPreTax) * rate;
        const totalTax = annualFederalTax + stateTax + annualSS + annualMedicare;
        const takeHome = annualGross - totalTax - totalPreTax;
        return { name, rate, stateTax, takeHome };
    });

    stateData.sort((a, b) => a.stateTax - b.stateTax);

    const lowest = stateData.slice(0, 10);
    const highest = stateData.slice(-10).reverse();

    const renderRows = (data, cls) => data.map(s =>
        `<tr><td>${s.name}</td><td class="${cls}">${(s.rate * 100).toFixed(1)}%</td><td>${fmt(s.stateTax)}</td><td>${fmt(s.takeHome)}</td></tr>`
    ).join('');

    document.getElementById('low-tax-tbody').innerHTML = renderRows(lowest, 'no-tax');
    document.getElementById('high-tax-tbody').innerHTML = renderRows(highest, 'high-tax');
}

// Bind events
['gross-salary', 'salary-type', 'pay-frequency', 'filing-status', 'state',
 'federal-allowances', 'contrib-401k', 'health-insurance'].forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
    document.getElementById(id).addEventListener('change', calculate);
});

calculate();
  </script>
