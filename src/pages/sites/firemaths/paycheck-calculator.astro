  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let payType = 'annual';

window.setPayType = (type) => {
    payType = type;
    document.getElementById('btn-annual').classList.toggle('active', type === 'annual');
    document.getElementById('btn-hourly').classList.toggle('active', type === 'hourly');
    document.getElementById('annual-input').style.display = type === 'annual' ? 'block' : 'none';
    document.getElementById('hourly-input').style.display = type === 'hourly' ? 'block' : 'none';
    updateAll();
};

window.copyValue = async (elementId, btn) => {
    const text = document.getElementById(elementId).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => { btn.innerText = orig; }, 2000);
    } catch (err) { /* noop */ }
};

window.toggleFaq = (btn) => {
    btn.parentElement.classList.toggle('open');
};

// State tax rates (simplified flat effective rates)
const stateTax = {
    AL: 0.0500, AK: 0, AZ: 0.0250, AR: 0.0390, CA: 0.0930,
    CO: 0.0440, CT: 0.0500, DE: 0.0660, FL: 0, GA: 0.0549,
    HI: 0.0720, ID: 0.0580, IL: 0.0495, IN: 0.0305, IA: 0.0570,
    KS: 0.0570, KY: 0.0400, LA: 0.0425, ME: 0.0715, MD: 0.0575,
    MA: 0.0500, MI: 0.0425, MN: 0.0985, MS: 0.0500, MO: 0.0480,
    MT: 0.0675, NE: 0.0664, NV: 0, NH: 0, NJ: 0.0637,
    NM: 0.0590, NY: 0.0685, NC: 0.0450, ND: 0.0195, OH: 0.0350,
    OK: 0.0475, OR: 0.0990, PA: 0.0307, RI: 0.0599, SC: 0.0640,
    SD: 0, TN: 0, TX: 0, UT: 0.0465, VT: 0.0875,
    VA: 0.0575, WA: 0, WV: 0.0512, WI: 0.0765, WY: 0
};

// 2026 federal tax brackets
const brackets = {
    single: [
        [11925, 0.10],
        [48475, 0.12],
        [103350, 0.22],
        [197300, 0.24],
        [250525, 0.32],
        [626350, 0.35],
        [Infinity, 0.37]
    ],
    married: [
        [23850, 0.10],
        [96950, 0.12],
        [206700, 0.22],
        [394600, 0.24],
        [501050, 0.32],
        [751600, 0.35],
        [Infinity, 0.37]
    ],
    hoh: [
        [17000, 0.10],
        [64850, 0.12],
        [103350, 0.22],
        [197300, 0.24],
        [250500, 0.32],
        [626350, 0.35],
        [Infinity, 0.37]
    ]
};

const standardDeduction = { single: 15000, married: 30000, hoh: 22500 };

// SS wage base 2026
const ssWageBase = 176600;
const ssRate = 0.062;
const medRate = 0.0145;
const addlMedThreshold = { single: 200000, married: 250000, hoh: 200000 };
const addlMedRate = 0.009;

function calcFederalTax(taxableIncome, filingStatus) {
    const brkts = brackets[filingStatus];
    let tax = 0;
    let prev = 0;
    let marginalRate = 0.10;

    for (const [limit, rate] of brkts) {
        if (taxableIncome <= prev) break;
        const taxable = Math.min(taxableIncome, limit) - prev;
        tax += taxable * rate;
        marginalRate = rate;
        prev = limit;
    }

    return { tax: Math.max(0, tax), marginalRate };
}

function getAnnualGross() {
    if (payType === 'annual') {
        return parseFloat(document.getElementById('gross-salary').value) || 0;
    } else {
        const rate = parseFloat(document.getElementById('hourly-rate').value) || 0;
        const hours = parseFloat(document.getElementById('hours-week').value) || 40;
        return rate * hours * 52;
    }
}

function calcPaycheck(annualGross, freq, filingStatus, stateCode, k401Pct, healthPerMonth) {
    const periods = freq;

    // Pre-tax deductions (annual)
    const k401Annual = annualGross * (k401Pct / 100);
    const healthAnnual = healthPerMonth * 12;
    const totalPreTaxDeductions = k401Annual + healthAnnual;

    // Taxable income for federal/state
    const stdDed = standardDeduction[filingStatus];
    const taxableIncome = Math.max(0, annualGross - totalPreTaxDeductions - stdDed);

    // Federal tax
    const { tax: fedTax, marginalRate } = calcFederalTax(taxableIncome, filingStatus);

    // State tax (on income after pre-tax deductions, simplified)
    const stateRate = stateTax[stateCode] || 0;
    const stateTaxAmt = Math.max(0, (annualGross - totalPreTaxDeductions) * stateRate);

    // FICA (on gross, before pre-tax deductions for income tax but FICA applies to gross)
    const ssTax = Math.min(annualGross, ssWageBase) * ssRate;
    const medTax = annualGross * medRate;
    const addlMedThresholdVal = addlMedThreshold[filingStatus];
    const addlMed = Math.max(0, annualGross - addlMedThresholdVal) * addlMedRate;
    const totalMed = medTax + addlMed;
    const totalFica = ssTax + totalMed;

    // Net
    const totalTaxes = fedTax + stateTaxAmt + totalFica;
    const annualNet = annualGross - totalTaxes - totalPreTaxDeductions;
    const effectiveRate = annualGross > 0 ? ((totalTaxes) / annualGross * 100) : 0;

    return {
        annualGross,
        fedTax,
        stateTax: stateTaxAmt,
        ssTax,
        medTax: totalMed,
        fica: totalFica,
        k401: k401Annual,
        health: healthAnnual,
        deductions: totalPreTaxDeductions,
        totalTaxes,
        annualNet,
        effectiveRate,
        marginalRate: marginalRate * 100,
        periods,
        perPeriod: {
            gross: annualGross / periods,
            fedTax: fedTax / periods,
            stateTax: stateTaxAmt / periods,
            ssTax: ssTax / periods,
            medTax: totalMed / periods,
            fica: totalFica / periods,
            k401: k401Annual / periods,
            health: healthAnnual / periods,
            deductions: totalPreTaxDeductions / periods,
            net: annualNet / periods
        }
    };
}

function updateAll() {
    const annualGross = getAnnualGross();
    const freq = parseInt(document.getElementById('pay-frequency').value);
    const filingStatus = document.getElementById('filing-status').value;
    const stateCode = document.getElementById('state').value;
    const k401Pct = parseFloat(document.getElementById('contrib-401k').value) || 0;
    const healthPerMonth = parseFloat(document.getElementById('health-insurance').value) || 0;

    const r = calcPaycheck(annualGross, freq, filingStatus, stateCode, k401Pct, healthPerMonth);

    // Per-period results
    document.getElementById('net-per-period').innerText = fmt2(r.perPeriod.net);
    document.getElementById('gross-per-period').innerText = fmt2(r.perPeriod.gross);
    document.getElementById('fed-tax-period').innerText = '-' + fmt2(r.perPeriod.fedTax);
    document.getElementById('state-tax-period').innerText = '-' + fmt2(r.perPeriod.stateTax);
    document.getElementById('ss-tax-period').innerText = '-' + fmt2(r.perPeriod.ssTax);
    document.getElementById('med-tax-period').innerText = '-' + fmt2(r.perPeriod.medTax);
    document.getElementById('k401-period').innerText = '-' + fmt2(r.perPeriod.k401);
    document.getElementById('health-period').innerText = '-' + fmt2(r.perPeriod.health);

    document.getElementById('annual-net').innerText = fmt(r.annualNet);
    document.getElementById('effective-rate').innerText = r.effectiveRate.toFixed(1) + '%';
    document.getElementById('marginal-rate').innerText = r.marginalRate.toFixed(0) + '%';

    // Comparison table
    [52, 26, 24, 12, 1].forEach(p => {
        const div = p === 1 ? 1 : p;
        document.getElementById('cmp-gross-' + p).innerText = p === 1 ? fmt(r.annualGross) : fmt2(r.annualGross / div);
        document.getElementById('cmp-fed-' + p).innerText = p === 1 ? fmt(r.fedTax) : fmt2(r.fedTax / div);
        document.getElementById('cmp-state-' + p).innerText = p === 1 ? fmt(r.stateTax) : fmt2(r.stateTax / div);
        document.getElementById('cmp-fica-' + p).innerText = p === 1 ? fmt(r.fica) : fmt2(r.fica / div);
        document.getElementById('cmp-ded-' + p).innerText = p === 1 ? fmt(r.deductions) : fmt2(r.deductions / div);
        document.getElementById('cmp-net-' + p).innerText = p === 1 ? fmt(r.annualNet) : fmt2(r.annualNet / div);
    });

    // Pie chart
    drawPieChart(r);
}

// Pie Chart
const pieCanvas = document.getElementById('pieChart');
const pieCtx = pieCanvas.getContext('2d');

function drawPieChart(r) {
    const dpr = window.devicePixelRatio || 1;
    const rect = pieCanvas.parentElement.getBoundingClientRect();
    pieCanvas.width = rect.width * dpr;
    pieCanvas.height = rect.height * dpr;
    pieCtx.setTransform(1, 0, 0, 1, 0, 0);
    pieCtx.scale(dpr, dpr);

    const width = rect.width;
    const height = rect.height;
    pieCtx.clearRect(0, 0, width, height);

    const total = r.annualGross;
    if (total <= 0) return;

    const slices = [
        { value: r.annualNet, color: '#50E3C2', label: 'Take-Home' },
        { value: r.fedTax, color: '#4A90E2', label: 'Federal Tax' },
        { value: r.stateTax, color: '#E85D75', label: 'State Tax' },
        { value: r.ssTax, color: '#D4A017', label: 'Social Security' },
        { value: r.medTax, color: '#9B59B6', label: 'Medicare' },
        { value: r.deductions, color: '#F39C12', label: 'Deductions' }
    ].filter(s => s.value > 0);

    const cx = width / 2;
    const cy = height / 2;
    const radius = Math.min(cx, cy) - 30;

    let startAngle = -Math.PI / 2;

    slices.forEach(slice => {
        const sliceAngle = (slice.value / total) * 2 * Math.PI;
        const endAngle = startAngle + sliceAngle;

        pieCtx.beginPath();
        pieCtx.moveTo(cx, cy);
        pieCtx.arc(cx, cy, radius, startAngle, endAngle);
        pieCtx.closePath();
        pieCtx.fillStyle = slice.color;
        pieCtx.fill();

        // Label
        if (sliceAngle > 0.15) {
            const midAngle = startAngle + sliceAngle / 2;
            const labelR = radius * 0.65;
            const lx = cx + Math.cos(midAngle) * labelR;
            const ly = cy + Math.sin(midAngle) * labelR;
            const pct = ((slice.value / total) * 100).toFixed(1) + '%';

            pieCtx.fillStyle = '#000';
            pieCtx.font = 'bold 13px Inter, sans-serif';
            pieCtx.textAlign = 'center';
            pieCtx.textBaseline = 'middle';
            pieCtx.fillText(pct, lx, ly);
        }

        startAngle = endAngle;
    });

    // Center hole (donut)
    pieCtx.beginPath();
    pieCtx.arc(cx, cy, radius * 0.4, 0, 2 * Math.PI);
    pieCtx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--card-bg').trim() || '#1a1a1a';
    pieCtx.fill();

    // Center text
    pieCtx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim() || '#fff';
    pieCtx.font = 'bold 14px Inter, sans-serif';
    pieCtx.textAlign = 'center';
    pieCtx.textBaseline = 'middle';
    pieCtx.fillText('Net', cx, cy - 10);
    pieCtx.font = 'bold 16px "JetBrains Mono", monospace';
    pieCtx.fillText(fmt(r.annualNet), cx, cy + 12);
}

// Attach listeners
document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', updateAll);
    el.addEventListener('change', updateAll);
});

// Resize handler
let resizeTimer;
window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(updateAll, 100);
});

// Initial calc
updateAll();
  </script>

