---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Interactive Mortgage Calculator | Compare 15 vs 30 Year Rates',
  description: 'See the true cost of your home. Interactive mortgage calculator with amortization schedule, comparison mode, and extra payment impact analysis.',
  category: 'tool',
  keywords: ['mortgage calculator', 'amortization schedule', 'home loan calculator', '15 vs 30 year mortgage', 'extra mortgage payments', 'interest breakdown']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Firemaths" },
    "publisher": { "@type": "Organization", "name": "Firemaths" },
    "datePublished": "2026-04-10",
    "dateModified": "2026-04-10"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is my monthly mortgage payment calculated?",
        "acceptedAnswer": { "@type": "Answer", "text": "Your monthly payment includes principal and interest. It's calculated using the formula: M = P [ i(1 + i)^n ] / [ (1 + i)^n - 1 ], where P is the loan amount, i is the monthly interest rate, and n is the total number of payments." }
      },
      {
        "@type": "Question",
        "name": "What is an amortization schedule?",
        "acceptedAnswer": { "@type": "Answer", "text": "An amortization schedule is a complete table of periodic loan payments, showing the amount of principal and the amount of interest that comprise each payment until the loan is paid off." }
      },
      {
        "@type": "Question",
        "name": "How does a 15-year mortgage compare to a 30-year mortgage?",
        "acceptedAnswer": { "@type": "Answer", "text": "A 15-year mortgage has higher monthly payments but costs significantly less in total interest compared to a 30-year mortgage. It also allows you to build equity faster." }
      },
      {
        "@type": "Question",
        "name": "How do extra payments affect my mortgage?",
        "acceptedAnswer": { "@type": "Answer", "text": "Making extra payments towards your principal balance reduces the total interest you will pay over the life of the loan and shortens the time it takes to pay off the mortgage entirely." }
      },
      {
        "@type": "Question",
        "name": "What are typical mortgage closing costs?",
        "acceptedAnswer": { "@type": "Answer", "text": "Closing costs typically range from 2% to 5% of the loan amount and include fees for appraisal, title search, origination, and taxes." }
      }
    ]
  }
]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <section class="mill-hero">
    <div class="mill-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>The True Cost of Your Home Loan</h1>
    <p class="mill-hero-hook">The average American pays <strong>$165,000 in mortgage interest</strong> over 30 years. <br/>See exactly where your money goes.</p>
    <div class="mill-hero-stats">
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-payment"></span>
        <span class="mill-stat-label">Monthly P&I</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-interest"></span>
        <span class="mill-stat-label">Total Interest</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-ratio"></span>
        <span class="mill-stat-label">Interest to Principal</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="mill-section">
    <h2 class="mill-section-title">Mortgage Calculator</h2>
    <p class="mill-section-sub">Adjust your loan details to see the breakdown of principal and interest.</p>

    <div class="mill-calc-container">
      <div class="mill-calc-inputs">
        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="input-loan">Loan Amount</label>
            <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="input-loan" min="10000" max="10000000" step="5000" value="400000" /></div>
          </div>
          <div class="mill-input-group">
            <label for="input-rate">Interest Rate (%)</label>
            <div class="mill-input-wrap"><input type="number" id="input-rate" min="0.1" max="20" step="0.1" value="7.0" /></div>
          </div>
          <div class="mill-input-group">
            <label for="input-term">Loan Term (Years)</label>
            <select id="input-term">
              <option value="30" selected>30 Years</option>
              <option value="20">20 Years</option>
              <option value="15">15 Years</option>
              <option value="10">10 Years</option>
            </select>
          </div>
        </div>

        <div class="mill-input-group">
          <label for="input-extra">Extra Monthly Payment</label>
          <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="input-extra" min="0" max="10000" step="50" value="0" /></div>
        </div>

        <button id="calc-btn" class="mill-btn">Calculate My Mortgage</button>
      </div>

      <!-- RESULTS -->
      <div class="mill-calc-results" id="results-panel" style="display:none;">
        <div class="mill-result-header">
          <div class="mill-result-title">Monthly Payment (P&I)</div>
          <div class="mill-result-age"><strong id="result-monthly">—</strong></div>
          <div class="mill-result-years">Payoff in <span id="result-payoff-years">—</span> years and <span id="result-payoff-months">—</span> months</div>
        </div>

        <!-- MILESTONES -->
        <div class="mill-milestones" id="milestones-container">
          <div class="mill-milestone">
            <div class="mill-milestone-amt" id="milestone-principal"></div>
            <div class="mill-milestone-age">Principal Paid</div>
          </div>
          <div class="mill-milestone">
            <div class="mill-milestone-amt" id="milestone-interest"></div>
            <div class="mill-milestone-age">Total Interest</div>
          </div>
          <div class="mill-milestone">
            <div class="mill-milestone-amt" id="milestone-total"></div>
            <div class="mill-milestone-age">Total Cost</div>
          </div>
          <div class="mill-milestone" id="milestone-savings-container">
            <div class="mill-milestone-amt" id="milestone-savings"></div>
            <div class="mill-milestone-age">Interest Saved</div>
          </div>
        </div>

        <!-- ANIMATED PIE/BAR CHART -->
        <div class="mill-chart-wrap">
          <div class="mill-chart-title">Principal vs Interest Over Time</div>
          <div class="mill-chart" id="wealth-chart"></div>
          <div class="mill-chart-legend">
            <span><i class="mill-legend-dot contributions"></i> Principal Balance</span>
            <span><i class="mill-legend-dot growth"></i> Cumulative Interest</span>
          </div>
        </div>

        <div class="mill-insight" id="result-insight"></div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="mill-section">
    <h2 class="mill-section-title">15 vs 30 Year Comparison</h2>
    <p class="mill-section-sub">See how much you save with a shorter loan term.</p>

    <div class="mill-compare-controls">
      <div class="mill-input-group" style="flex: 1;">
        <label for="compare-loan">Loan Amount</label>
        <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="compare-loan" value="400000" /></div>
      </div>
      <div class="mill-input-group" style="flex: 1;">
        <label for="compare-rate">Interest Rate (%)</label>
        <div class="mill-input-wrap"><input type="number" id="compare-rate" value="7.0" step="0.1" /></div>
      </div>
      <button id="compare-btn" class="mill-btn" style="flex: 1; margin-top: 1.4rem;">Compare Terms</button>
    </div>

    <div class="mill-compare-results" id="compare-results" style="display:none;">
      <div class="mill-compare-cards">
        <div class="mill-compare-card" id="compare-card-30"></div>
        <div class="mill-compare-card" id="compare-card-15"></div>
      </div>
      <div class="mill-compare-race" id="compare-race"></div>
    </div>
  </section>

  <!-- AMORTIZATION SCHEDULE -->
  <section class="mill-section">
    <h2 class="mill-section-title">Amortization Schedule</h2>
    <p class="mill-section-sub">Year-by-year breakdown of your payments.</p>
    <div class="mill-rankings" style="max-height: 500px; overflow-y: auto;">
      <table style="width: 100%; border-collapse: collapse; color: var(--text-primary, #c8d0de); font-size: 0.9rem;" id="amortization-table">
        <thead>
          <tr style="border-bottom: 1px solid var(--border-color, #152040); text-align: right;">
            <th style="padding: 0.75rem; text-align: left;">Year</th>
            <th style="padding: 0.75rem;">Principal Paid</th>
            <th style="padding: 0.75rem;">Interest Paid</th>
            <th style="padding: 0.75rem;">Total Interest</th>
            <th style="padding: 0.75rem;">Remaining Balance</th>
          </tr>
        </thead>
        <tbody>
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>
  </section>

  <!-- THE 3 LEVERS -->
  <section class="mill-section">
    <h2 class="mill-section-title">How to Save on Your Mortgage</h2>
    <div class="mill-levers">
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="16" stroke="currentColor" stroke-width="1.5" opacity="0.2"/><path d="M18 8v4M18 24v4M8 18h4M24 18h4" stroke="var(--accent-color, #D4A017)" stroke-width="2" stroke-linecap="round"/><circle cx="18" cy="18" r="5" fill="var(--accent-color, #D4A017)" opacity="0.2" stroke="var(--accent-color, #D4A017)" stroke-width="1.5"/></svg>
        </div>
        <h3>Make Extra Payments</h3>
        <p>Even an extra $100 per month can shave years off your loan and save tens of thousands in interest by accelerating principal reduction.</p>
        <div class="mill-lever-impact">Impact: <strong>High</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><rect x="4" y="22" width="6" height="10" rx="1" fill="var(--accent-color, #D4A017)" opacity="0.25"/><rect x="13" y="16" width="6" height="16" rx="1" fill="var(--accent-color, #D4A017)" opacity="0.5"/><rect x="22" y="8" width="6" height="24" rx="1" fill="var(--accent-color, #D4A017)" opacity="0.8"/></svg>
        </div>
        <h3>Refinance for a Lower Rate</h3>
        <p>Dropping your interest rate by just 1% can drastically lower your monthly payment and total interest paid over the life of the loan.</p>
        <div class="mill-lever-impact">Impact: <strong>High</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="14" stroke="var(--accent-color, #D4A017)" stroke-width="1.5" opacity="0.3"/><circle cx="18" cy="18" r="14" stroke="var(--accent-color, #D4A017)" stroke-width="2.5" stroke-dasharray="88" stroke-dashoffset="22" stroke-linecap="round"/><line x1="18" y1="18" x2="18" y2="10" stroke="var(--accent-color, #D4A017)" stroke-width="2" stroke-linecap="round"/><line x1="18" y1="18" x2="24" y2="18" stroke="var(--accent-color, #D4A017)" stroke-width="1.5" stroke-linecap="round"/><circle cx="18" cy="18" r="2" fill="var(--accent-color, #D4A017)"/></svg>
        </div>
        <h3>Choose a Shorter Term</h3>
        <p>Opting for a 15-year instead of a 30-year term forces you to pay down principal faster, saving you massive amounts of interest.</p>
        <div class="mill-lever-impact">Impact: <strong>Highest</strong></div>
      </div>
    </div>
  </section>


  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/mortgage-payment-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Mortgage Payment Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Calculate your monthly mortgage payment with amortization schedule, payment breakdown pie chart, extra payment savings, ...</p>
      </a>
      <a href="https://westmountfundamentals.com/etf-fee-comparison" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">ETF Fee Comparison Calculator: The Hidden Cost of Investing</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Compare ETF fees across categories and use our interactive calculator to see how Management Expense Ratios (MER) impact ...</p>
      </a>
      <a href="https://ijustwantto.live/rent-vs-buy-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Rent vs Buy Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Compare the true cost of renting vs buying a home. Factor in mortgage, taxes, maintenance, opportunity cost, and investm...</p>
      </a>
    </div>
  </div>
</SiteLayout>

<style is:global>
  :root {
    --accent-color: #D4A017;
    --text-primary: #c8d0de;
    --text-secondary: #94a3b8;
    --border-color: #152040;
    --card-bg: #0a1020;
    --bg-color: #060a12;
  }

  /* HERO */
  .mill-hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
  }
  .mill-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 80vw;
    height: 80vw;
    background: radial-gradient(circle, rgba(212,160,23,0.08) 0%, transparent 60%);
    z-index: -1;
    pointer-events: none;
  }
  .mill-hero-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: rgba(212,160,23,0.1);
    color: var(--accent-color);
    border: 1px solid rgba(212,160,23,0.2);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
    animation: mill-fadeUp 0.6s ease both;
  }
  .mill-hero h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    margin: 0 auto 1rem;
    max-width: 700px;
    color: var(--text-primary);
    animation: mill-fadeUp 0.6s 0.1s ease both;
  }
  .mill-hero h1 em {
    color: var(--accent-color);
    font-style: italic;
  }
  .mill-hero-hook {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    animation: mill-fadeUp 0.6s 0.2s ease both;
  }
  .mill-hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    animation: mill-fadeUp 0.6s 0.3s ease both;
  }
  .mill-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .mill-stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent-color);
    white-space: nowrap;
  }
  .mill-stat-label {
    font-size: 0.7rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* SECTIONS */
  .mill-section {
    padding: 2.5rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .mill-section-title {
    font-size: 1.6rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .mill-section-sub {
    color: var(--text-secondary);
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  /* CALCULATOR */
  .mill-calc-container {
    display: grid;
    gap: 2rem;
  }
  .mill-calc-inputs {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
  }
  .mill-input-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .mill-input-row { grid-template-columns: 1fr; }
    .mill-compare-controls { flex-direction: column; }
  }
  .mill-input-group {
    margin-bottom: 1.25rem;
  }
  .mill-input-group label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .mill-input-group select,
  .mill-input-group input[type="number"] {
    width: 100%;
    padding: 0.65rem 0.75rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .mill-input-group select:focus,
  .mill-input-group input:focus {
    outline: none;
    border-color: var(--accent-color);
    box-shadow: 0 0 0 3px rgba(212,160,23,0.1);
  }
  .mill-input-wrap {
    position: relative;
  }
  .mill-input-prefix {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
    font-size: 0.95rem;
    pointer-events: none;
  }
  .mill-input-wrap input {
    padding-left: 1.5rem !important;
  }

  /* BUTTON */
  .mill-btn {
    width: 100%;
    padding: 0.85rem;
    border: none;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--accent-color), #b28512);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    margin-top: 0.5rem;
    position: relative;
    overflow: hidden;
  }
  .mill-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.1) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: transform 0.5s;
  }
  .mill-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(212,160,23,0.35);
  }
  .mill-btn:hover::after {
    transform: translateX(100%);
  }
  .mill-btn:active {
    transform: translateY(0);
  }

  /* RESULTS */
  .mill-calc-results {
    animation: mill-fadeUp 0.5s ease;
  }
  @keyframes mill-fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .mill-result-header {
    text-align: center;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(212,160,23,0.12), rgba(212,160,23,0.03));
    border: 1px solid var(--border-color);
    border-radius: 12px;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .mill-result-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent-color), transparent);
  }
  .mill-result-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
  .mill-result-age {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .mill-result-age strong {
    font-size: 2.4rem;
    color: var(--accent-color);
    text-shadow: 0 0 30px rgba(212,160,23,0.3);
  }
  .mill-result-years {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  .mill-result-years span {
    color: var(--accent-color);
    font-weight: 700;
  }

  /* MILESTONES */
  .mill-milestones {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 600px) {
    .mill-milestones { grid-template-columns: repeat(2, 1fr); }
  }
  .mill-milestone {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .mill-milestone-amt {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }
  .mill-milestone-age {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  /* CHARTS */
  .mill-chart-wrap {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .mill-chart-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .mill-chart {
    height: 240px;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    position: relative;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-color);
  }
  .mill-chart-bar-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    height: 100%;
  }
  .mill-chart-bar {
    width: 100%;
    transition: height 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }
  .mill-chart-bar.contributions {
    background: rgba(212,160,23,0.3);
    border-top: 1px solid rgba(212,160,23,0.5);
  }
  .mill-chart-bar.growth {
    background: var(--accent-color);
    box-shadow: 0 0 10px rgba(212,160,23,0.2);
    border-radius: 2px 2px 0 0;
  }
  .mill-chart-label {
    position: absolute;
    bottom: -22px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.65rem;
