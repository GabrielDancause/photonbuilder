  }
  .mill-chart-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
    background: #000;
    border: 1px solid #333;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.75rem;
    color: #fff;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 10;
  }
  .mill-chart-bar-group:hover .mill-chart-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(-5px);
  }
  .mill-chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }
  .mill-legend-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    margin-right: 0.4rem;
  }
  .mill-legend-dot.contributions { background: rgba(212,160,23,0.4); }
  .mill-legend-dot.growth { background: var(--accent-color); }

  .mill-insight {
    padding: 1rem 1.5rem;
    background: rgba(212,160,23,0.08);
    border-left: 3px solid var(--accent-color);
    border-radius: 0 8px 8px 0;
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.5;
  }

  /* COMPARISON */
  .mill-compare-controls {
    display: flex;
    gap: 1rem;
    align-items: center;
    background: var(--card-bg);
    padding: 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
  }
  .mill-vs {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-secondary);
    padding: 0.5rem;
    background: var(--bg-color);
    border-radius: 50%;
    border: 1px solid var(--border-color);
  }
  .mill-compare-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  @media (max-width: 600px) {
    .mill-compare-cards { grid-template-columns: 1fr; }
  }
  .mill-compare-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .mill-compare-card.winner {
    border-color: var(--accent-color);
  }
  .mill-compare-card h3 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }
  .mill-compare-stat {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }
  .mill-compare-stat .label { color: var(--text-secondary); }
  .mill-compare-stat .val { color: var(--text-primary); font-weight: 600; }
  .mill-compare-race {
    margin-top: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .mill-race-track {
    height: 12px;
    background: var(--bg-color);
    border-radius: 6px;
    margin-bottom: 1rem;
    position: relative;
    overflow: hidden;
  }
  .mill-race-bar {
    height: 100%;
    border-radius: 6px;
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* LEVERS */
  .mill-levers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 768px) {
    .mill-levers { grid-template-columns: 1fr; }
  }
  .mill-lever-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    transition: transform 0.2s, border-color 0.2s;
  }
  .mill-lever-card:hover {
    transform: translateY(-5px);
    border-color: rgba(212,160,23,0.3);
  }
  .mill-lever-icon {
    color: var(--accent-color);
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }
  .mill-lever-card h3 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }
  .mill-lever-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 1rem;
  }
  .mill-lever-impact {
    font-size: 0.8rem;
    color: var(--text-secondary);
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }
  .mill-lever-impact strong {
    color: var(--accent-color);
  }
  #amortization-table td {
    padding: 0.75rem;
    border-bottom: 1px solid rgba(21, 32, 64, 0.5);
  }
  #amortization-table td:first-child { text-align: left; }
  #amortization-table td { text-align: right; }
</style>

<script is:inline>
  function formatMoney(num) {
    return '$' + Math.round(num).toLocaleString();
  }

  function calculateMortgage(principal, annualRate, years, extraMonthly = 0) {
    var monthlyRate = (annualRate / 100) / 12;
    var n = years * 12;
    var p = principal;

    // M = P [ i(1 + i)^n ] / [ (1 + i)^n - 1 ]
    var monthlyPI = 0;
    if (monthlyRate === 0) {
      monthlyPI = p / n;
    } else {
      monthlyPI = p * (monthlyRate * Math.pow(1 + monthlyRate, n)) / (Math.pow(1 + monthlyRate, n) - 1);
    }

    var schedule = [];
    var balance = p;
    var totalInterest = 0;
    var month = 0;

    while (balance > 0 && month < 1200) { // max 100 years safeguard
      var interestPayment = balance * monthlyRate;
      var principalPayment = monthlyPI - interestPayment + extraMonthly;

      if (principalPayment > balance) {
        principalPayment = balance;
      }

      if (balance <= 0) break;

      balance -= principalPayment;
      if (balance < 0) balance = 0;

      totalInterest += interestPayment;
      month++;

      if (month % 12 === 0 || balance === 0) {
        schedule.push({
          year: Math.ceil(month / 12),
          balance: balance,
          totalInterest: totalInterest,
          cumulativePrincipal: p - balance
        });
      }
    }

    return {
      monthlyPI: monthlyPI,
      totalInterest: totalInterest,
      totalCost: p + totalInterest,
      months: month,
      schedule: schedule
    };
  }

  // Initial Hero Stats
  var initData = calculateMortgage(400000, 7.0, 30, 0);
  document.getElementById('hero-payment').textContent = formatMoney(initData.monthlyPI);
  document.getElementById('hero-interest').textContent = formatMoney(initData.totalInterest);
  document.getElementById('hero-ratio').textContent = (initData.totalInterest / 400000).toFixed(2) + 'x';

  document.getElementById('calc-btn').addEventListener('click', function() {
    var loan = parseFloat(document.getElementById('input-loan').value) || 0;
    var rate = parseFloat(document.getElementById('input-rate').value) || 0;
    var term = parseInt(document.getElementById('input-term').value) || 30;
    var extra = parseFloat(document.getElementById('input-extra').value) || 0;

    var baseData = calculateMortgage(loan, rate, term, 0);
    var data = calculateMortgage(loan, rate, term, extra);

    document.getElementById('results-panel').style.display = 'block';
    document.getElementById('result-monthly').textContent = formatMoney(data.monthlyPI + extra);

    var yearsToPayoff = Math.floor(data.months / 12);
    var monthsToPayoff = data.months % 12;
    document.getElementById('result-payoff-years').textContent = yearsToPayoff;
    document.getElementById('result-payoff-months').textContent = monthsToPayoff;

    document.getElementById('milestone-principal').textContent = formatMoney(loan);
    document.getElementById('milestone-interest').textContent = formatMoney(data.totalInterest);
    document.getElementById('milestone-total').textContent = formatMoney(data.totalCost);

    var savingsContainer = document.getElementById('milestone-savings-container');
    if (extra > 0) {
      savingsContainer.style.display = 'block';
      document.getElementById('milestone-savings').textContent = formatMoney(baseData.totalInterest - data.totalInterest);
    } else {
      savingsContainer.style.display = 'none';
    }

    renderChart(data.schedule, loan);
    renderTable(data.schedule, loan);

    var insightEl = document.getElementById('result-insight');
    var ratio = data.totalInterest / loan;
    if (extra > 0) {
      insightEl.innerHTML = 'By paying an extra ' + formatMoney(extra) + ' a month, you save <strong>' + formatMoney(baseData.totalInterest - data.totalInterest) + '</strong> in interest and pay off your loan <strong>' + (baseData.months - data.months) + ' months</strong> earlier.';
    } else if (ratio > 0.8) {
      insightEl.innerHTML = 'You are paying <strong>' + Math.round(ratio * 100) + '%</strong> of your home\'s value purely in interest over the life of the loan. Consider making extra payments to reduce this.';
    } else {
      insightEl.innerHTML = 'Your total interest is ' + formatMoney(data.totalInterest) + ' over ' + yearsToPayoff + ' years.';
    }
  });

  function renderChart(schedule, initialLoan) {
    var chart = document.getElementById('wealth-chart');
    chart.innerHTML = '';

    var maxVal = initialLoan + schedule[schedule.length-1].totalInterest;
    var chartH = 214;

    var maxBars = 30;
    var step = Math.max(1, Math.floor(schedule.length / maxBars));

    for (var i = 0; i < schedule.length; i += step) {
      if (i !== 0 && i !== schedule.length - 1 && i % step !== 0) continue;

      var d = schedule[i];
      var group = document.createElement('div');
      group.className = 'mill-chart-bar-group';

      var hBal = (d.balance / maxVal) * chartH;
      var hInt = (d.totalInterest / maxVal) * chartH;

      var barInt = document.createElement('div');
      barInt.className = 'mill-chart-bar growth';
      barInt.style.height = hInt + 'px';

      var barBal = document.createElement('div');
      barBal.className = 'mill-chart-bar contributions';
      barBal.style.height = hBal + 'px';

      var lbl = document.createElement('div');
      lbl.className = 'mill-chart-label';
      lbl.textContent = 'Yr ' + d.year;

      var tip = document.createElement('div');
      tip.className = 'mill-chart-tooltip';
      tip.innerHTML = 'Year ' + d.year + '<br>Balance: ' + formatMoney(d.balance) + '<br>Cum. Interest: ' + formatMoney(d.totalInterest);

      group.appendChild(barInt);
      group.appendChild(barBal);
      group.appendChild(lbl);
      group.appendChild(tip);
      chart.appendChild(group);
    }
  }

  function renderTable(schedule, loan) {
    var tbody = document.querySelector('#amortization-table tbody');
    tbody.innerHTML = '';

    var prevCumulativePrincipal = 0;
    var prevTotalInterest = 0;

    schedule.forEach(function(d) {
      var principalPaidYear = d.cumulativePrincipal - prevCumulativePrincipal;
      var interestPaidYear = d.totalInterest - prevTotalInterest;

      var tr = document.createElement('tr');
      tr.innerHTML = '<td>Year ' + d.year + '</td>' +
                     '<td>' + formatMoney(principalPaidYear) + '</td>' +
                     '<td>' + formatMoney(interestPaidYear) + '</td>' +
                     '<td>' + formatMoney(d.totalInterest) + '</td>' +
                     '<td>' + formatMoney(d.balance) + '</td>';
      tbody.appendChild(tr);

      prevCumulativePrincipal = d.cumulativePrincipal;
      prevTotalInterest = d.totalInterest;
    });
  }

  document.getElementById('compare-btn').addEventListener('click', function() {
    var loan = parseFloat(document.getElementById('compare-loan').value) || 0;
    var rate = parseFloat(document.getElementById('compare-rate').value) || 0;

    var data30 = calculateMortgage(loan, rate, 30, 0);
    var data15 = calculateMortgage(loan, rate, 15, 0);

    document.getElementById('compare-results').style.display = 'block';

    function buildCard(term, data) {
      return '<h3>' + term + ' Year Mortgage</h3>' +
             '<div class="mill-compare-stat"><span class="label">Monthly P&I:</span><span class="val">' + formatMoney(data.monthlyPI) + '</span></div>' +
             '<div class="mill-compare-stat"><span class="label">Total Interest:</span><span class="val">' + formatMoney(data.totalInterest) + '</span></div>' +
             '<div class="mill-compare-stat"><span class="label">Total Cost:</span><span class="val">' + formatMoney(data.totalCost) + '</span></div>';
    }

    document.getElementById('compare-card-30').innerHTML = buildCard(30, data30);
    document.getElementById('compare-card-15').innerHTML = buildCard(15, data15);
    document.getElementById('compare-card-15').classList.add('winner');
    document.getElementById('compare-card-30').classList.remove('winner');

    var race = document.getElementById('compare-race');
    var int30 = data30.totalInterest;
    var int15 = data15.totalInterest;
    var maxInt = Math.max(int30, int15);

    var pct30 = (int30 / maxInt) * 100;
    var pct15 = (int15 / maxInt) * 100;

    race.innerHTML = '<div style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:0.5rem;">Total Interest Comparison</div>' +
                     '<div class="mill-race-track"><div class="mill-race-bar" style="width:0; background:rgba(212,160,23,0.4);" data-w="' + pct30 + '%"></div></div>' +
                     '<div style="font-size:0.8rem; text-align:right; margin-top:-10px; margin-bottom:1rem; color:var(--text-secondary);">30 Year: ' + formatMoney(int30) + '</div>' +
                     '<div class="mill-race-track"><div class="mill-race-bar" style="width:0; background:var(--accent-color);" data-w="' + pct15 + '%"></div></div>' +
                     '<div style="font-size:0.8rem; text-align:right; margin-top:-10px; color:var(--accent-color);">15 Year: ' + formatMoney(int15) + '</div>' +
                     '<div style="margin-top: 1rem; font-size: 0.9rem; text-align: center; color: var(--text-primary);">A 15-year mortgage saves you <strong>' + formatMoney(int30 - int15) + '</strong> in interest.</div>';

    setTimeout(function() {
      var bars = race.querySelectorAll('.mill-race-bar');
      bars.forEach(function(b) {
        b.style.width = b.getAttribute('data-w');
      });
    }, 50);
  });
</script>
