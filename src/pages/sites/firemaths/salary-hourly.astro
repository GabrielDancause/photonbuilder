---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Salary to Hourly Converter",
  "url": "https://firemaths.info/salary-hourly",
  "description": "Convert your annual salary to an hourly wage, or vice versa. Adjust for work hours and paid time off (PTO) to find your real hourly rate.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Salary to Hourly Converter | firemaths.info"
  description="Convert your annual salary to an hourly wage, or vice versa. Adjust for work hours and paid time off (PTO) to find your real hourly rate."
  canonical="https://firemaths.info/salary-hourly" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Income Details</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="pay-amount">Pay Amount</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="pay-amount" value="80000" min="0" step="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="pay-frequency">Pay Frequency</label>
                        <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="pay-frequency">
                            <option value="annual" selected>Annual (per year)</option>
                            <option value="monthly">Monthly (per month)</option>
                            <option value="biweekly">Bi-weekly (every 2 weeks)</option>
                            <option value="weekly">Weekly (per week)</option>
                            <option value="daily">Daily (per day)</option>
                            <option value="hourly">Hourly (per hour)</option>
                        </select>
                    </div>

                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]" style="margin-top: 2rem;">
                        <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Work Schedule</h2>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="hours-week">Hours per Week</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="pto-days">Paid Time Off (PTO) Days per Year</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pr-10"
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Conversion Results</h2>
                </div>

                <div class="bg-[var(--accent-color)] bg-opacity-10 border border-[var(--accent-color)] rounded-xl p-6 mb-8 text-center">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold" id="main-result-label">Hourly Rate</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="main-result-value">$0.00</span>
                        <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('main-result-value', this)">Copy</button>
                    </div>
                    <div class="text-[var(--text-secondary)] text-sm mt-2" id="main-result-note">Based on 40 hours per week.</div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Annual</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-annual">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-annual', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Monthly</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-monthly">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-monthly', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Bi-weekly</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-biweekly">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-biweekly', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Weekly</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-weekly">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-weekly', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Daily</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-daily">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-daily', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Hourly</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-hourly">$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-hourly', this)">Copy</button>
                        </div>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]" style="margin-top: 2rem;">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">PTO Analysis</h2>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]" style="margin-top: 1rem; border-top: none; padding-top: 0;">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Real Hourly Wage (Adjusted for PTO)</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2" style="color: var(--accent-color);">
                            <span id="res-real-hourly">$0.00</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-real-hourly', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Work Hours / Year</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-work-hours">0</span>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">PTO Value</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="res-pto-value">$0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Salary vs. Hourly: What's the Difference?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Understanding the difference between being a salaried employee and an hourly worker is crucial for financial planning. A <strong>salaried employee</strong> generally receives a fixed amount of money per year, regardless of the exact number of hours worked. An <strong>hourly employee</strong> is paid a specific rate for every hour they work.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When comparing job offers, converting an annual salary to an hourly wage (or vice versa) helps you evaluate the true value of your time. For example, a $80,000 salary might seem great, but if you're working 60 hours a week, your equivalent hourly rate is much lower than someone making $70,000 but only working 40 hours.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">How Paid Time Off (PTO) Affects Your Real Hourly Wage</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Many standard salary calculators divide your annual pay by 2,080 hours (52 weeks × 40 hours). However, this assumes you work every single weekday of the year, including holidays and vacation time.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">If you get Paid Time Off (PTO), including vacation days, sick leave, and paid holidays, you are actually working fewer hours for the same annual salary. By subtracting your PTO hours from the standard 2,080 hours, you can calculate your <strong>Real Hourly Wage</strong>—the actual amount you earn for every hour you physically work. The more PTO you have, the higher your real hourly wage becomes.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Standard Work Hour Assumptions</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When calculating pay conversions, certain standard assumptions are typically used:</p>
            <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc space-y-2">
                <li><strong>Work Weeks:</strong> There are 52 weeks in a standard year.</li>
                <li><strong>Work Days:</strong> A typical full-time job consists of 5 days per week (260 work days per year).</li>
                <li><strong>Work Hours:</strong> Full-time is generally considered 40 hours per week (2,080 hours per year).</li>
                <li><strong>Months:</strong> Monthly pay is calculated by dividing annual salary by 12, not by multiplying weekly pay by 4 (since most months have more than 28 days).</li>
                <li><strong>Bi-weekly:</strong> Being paid every two weeks results in 26 paychecks per year.</li>
            </ul>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value, isHourly = false) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            minimumFractionDigits: isHourly ? 2 : 0,
            maximumFractionDigits: isHourly ? 2 : 0
        }).format(value);
    };

    // Format number
    const formatNumber = (value) => {
        return new Intl.NumberFormat('en-US', {
            maximumFractionDigits: 1
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const updateCalculator = () => {
        const payAmount = parseFloat(document.getElementById('pay-amount').value) || 0;
        const payFreq = document.getElementById('pay-frequency').value;
        const hoursWeek = parseFloat(document.getElementById('hours-week').value) || 40;
        const ptoDays = parseFloat(document.getElementById('pto-days').value) || 0;

        let annualSalary = 0;
        const weeksPerYear = 52;
        const standardHoursPerYear = weeksPerYear * hoursWeek;
        const hoursPerDay = hoursWeek / 5; // Assuming 5-day work week for daily calc

        // 1. Normalize input to Annual Salary
        switch (payFreq) {
            case 'annual':
                annualSalary = payAmount;
                break;
            case 'monthly':
                annualSalary = payAmount * 12;
                break;
            case 'biweekly':
                annualSalary = payAmount * 26;
                break;
            case 'weekly':
                annualSalary = payAmount * 52;
                break;
            case 'daily':
                annualSalary = payAmount * 5 * 52;
                break;
            case 'hourly':
                annualSalary = payAmount * hoursWeek * 52;
                break;
        }

        // 2. Calculate standard frequencies
        const monthly = annualSalary / 12;
        const biweekly = annualSalary / 26;
        const weekly = annualSalary / 52;
        const daily = weekly / 5;
        const hourly = weekly / hoursWeek;

        // 3. Update standard results
        document.getElementById('res-annual').innerText = formatCurrency(annualSalary);
        document.getElementById('res-monthly').innerText = formatCurrency(monthly);
        document.getElementById('res-biweekly').innerText = formatCurrency(biweekly);
        document.getElementById('res-weekly').innerText = formatCurrency(weekly);
        document.getElementById('res-daily').innerText = formatCurrency(daily, true);
        document.getElementById('res-hourly').innerText = formatCurrency(hourly, true);

        // 4. Update Main Result depending on input frequency
        const mainLabelEl = document.getElementById('main-result-label');
        const mainValueEl = document.getElementById('main-result-value');
        const mainNoteEl = document.getElementById('main-result-note');

        if (payFreq === 'hourly') {
            mainLabelEl.innerText = 'Annual Salary';
            mainValueEl.innerText = formatCurrency(annualSalary);
            mainNoteEl.innerText = `Based on ${hoursWeek} hours per week.`;
        } else {
            mainLabelEl.innerText = 'Hourly Rate';
            mainValueEl.innerText = formatCurrency(hourly, true);
            mainNoteEl.innerText = `Based on ${hoursWeek} hours per week.`;
        }

        // 5. PTO Analysis
        const ptoHours = ptoDays * hoursPerDay;
        const actualWorkHours = standardHoursPerYear - ptoHours;

        let realHourlyWage = 0;
        if (actualWorkHours > 0) {
            realHourlyWage = annualSalary / actualWorkHours;
        }

        const ptoValue = ptoHours * hourly; // Value of the PTO based on standard hourly rate

        document.getElementById('res-real-hourly').innerText = formatCurrency(realHourlyWage, true);
        document.getElementById('res-work-hours').innerText = formatNumber(actualWorkHours);
        document.getElementById('res-pto-value').innerText = formatCurrency(ptoValue);
    };

    // Attach event listeners
    document.getElementById('pay-amount').addEventListener('input', updateCalculator);
    document.getElementById('pay-frequency').addEventListener('change', updateCalculator);
    document.getElementById('hours-week').addEventListener('input', updateCalculator);
    document.getElementById('pto-days').addEventListener('input', updateCalculator);

    // Initial calculation
    updateCalculator();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-taxes-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Understanding Your Taxes: A Complete Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
