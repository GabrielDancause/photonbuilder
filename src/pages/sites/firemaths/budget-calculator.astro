---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Budget Calculator: Free Monthly Expense Tracker & Planner",
  description: "Take control of your finances with our free interactive budget calculator. Track income and expenses to instantly see where your money goes.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Budget Calculator: Free Monthly Expense Tracker & Planner",
      "description": "Take control of your finances with our free interactive budget calculator. Track income and expenses to instantly see where your money goes. Start planning your financial future today.",
      "author": {
        "@type": "Organization",
        "name": "Siliconbased"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Siliconbased",
        "logo": {
          "@type": "ImageObject",
          "url": "https://firemaths.info/logo.png"
        }
      },
      "datePublished": "2026-03-15T00:00:00Z",
      "dateModified": "2026-03-15T00:00:00Z"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the 50/30/20 budget rule?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 50/30/20 rule is a simple budgeting framework that recommends allocating 50% of your after-tax income to needs (housing, groceries, utilities), 30% to wants (entertainment, dining out), and 20% to savings and debt repayment. It serves as a practical baseline for financial planning."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I update my budget?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "It is recommended to review and update your budget at least once a month. However, checking your progress weekly or even daily for variable expenses can help you stay on track and prevent overspending before it becomes a problem."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between fixed and variable expenses?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Fixed expenses remain constant each month, such as rent, mortgage payments, or car loans. Variable expenses fluctuate depending on your lifestyle and choices, including groceries, entertainment, dining out, and utility bills."
          }
        },
        {
          "@type": "Question",
          "name": "How can a budget calculator help me save money?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A budget calculator provides a clear visual breakdown of your income versus expenses. By categorizing your spending, it highlights areas where you may be overspending, allowing you to make informed adjustments and redirect those funds toward your savings goals."
          }
        },
        {
          "@type": "Question",
          "name": "Should I budget based on gross or net income?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You should always base your budget on your net income (your take-home pay after taxes and deductions). Budgeting based on gross income can lead to a false sense of financial security and potential overspending, as it does not reflect the actual amount of money available to you."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description} canonical="https://firemaths.info/budget-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Monthly Budget Calculator</h1>
      <p class="subtitle">Take control of your finances. Track income, manage expenses, and see your financial health instantly.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-section">
          <h3>Income (Monthly)</h3>
          <div class="input-group">
            <label for="primary-income">Primary Income</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="primary-income" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="secondary-income">Secondary Income / Side Hustle</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="secondary-income" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="other-income">Other Income</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="other-income" min="0" step="1" placeholder="0">
            </div>
          </div>

          <h3 class="mt-4">Fixed Expenses (Needs)</h3>
          <div class="input-group">
            <label for="housing">Housing (Rent/Mortgage)</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="housing" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="utilities">Utilities & Bills</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="utilities" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="groceries">Groceries</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="groceries" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="transportation">Transportation</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="transportation" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="debt">Debt Repayment / Loans</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="debt" min="0" step="1" placeholder="0">
            </div>
          </div>

          <h3 class="mt-4">Variable Expenses (Wants)</h3>
          <div class="input-group">
            <label for="dining">Dining & Entertainment</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="dining" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="shopping">Shopping & Personal Care</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="shopping" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="subscriptions">Subscriptions & Memberships</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="subscriptions" min="0" step="1" placeholder="0">
            </div>
          </div>
          <div class="input-group">
            <label for="savings-contributions">Savings & Investments</label>
            <div class="input-wrapper">
              <span class="currency-prefix">$</span>
              <input type="number" id="savings-contributions" min="0" step="1" placeholder="0">
            </div>
          </div>

          <div id="error-message" class="error-msg" style="display: none;">Please enter valid numerical values.</div>
        </div>

        <div class="results-section">
          <h3>Budget Summary</h3>
          <div class="result-card">
            <div class="result-label">Total Income</div>
            <div class="result-value" id="res-total-income">$0.00</div>
          </div>
          <div class="result-card">
            <div class="result-label">Total Expenses</div>
            <div class="result-value" id="res-total-expenses">$0.00</div>
          </div>
          <div class="result-card main-result">
            <div class="result-label">Net Balance (Leftover)</div>
            <div class="result-value" id="res-net-balance">$0.00</div>
            <div class="status-indicator" id="status-indicator">Enter your numbers to see your balance</div>
          </div>

          <h4 class="mt-4 mb-2">Expense Breakdown</h4>
          <div class="progress-bar-container">
            <div class="progress-bar-label">
              <span>Needs (<span id="pct-needs">0</span>%)</span>
              <span id="amt-needs">$0.00</span>
            </div>
            <div class="progress-track"><div class="progress-fill fill-needs" id="bar-needs" style="width: 0%"></div></div>
          </div>
          <div class="progress-bar-container">
            <div class="progress-bar-label">
              <span>Wants (<span id="pct-wants">0</span>%)</span>
              <span id="amt-wants">$0.00</span>
            </div>
            <div class="progress-track"><div class="progress-fill fill-wants" id="bar-wants" style="width: 0%"></div></div>
          </div>
          <div class="progress-bar-container">
            <div class="progress-bar-label">
              <span>Savings/Debt (<span id="pct-savings">0</span>%)</span>
              <span id="amt-savings">$0.00</span>
            </div>
            <div class="progress-track"><div class="progress-fill fill-savings" id="bar-savings" style="width: 0%"></div></div>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Your Personal Budget</h2>
      <p>Managing personal finances effectively is a fundamental pillar of long-term stability and wealth creation. Our interactive budget calculator is designed to provide you with a comprehensive, real-time snapshot of your financial health. By aggregating your income streams and categorizing your monthly expenditures, the tool empowers you to identify spending patterns, mitigate unnecessary costs, and strategically allocate funds toward your financial goals.</p>

      <h3>The Core Components of a Budget</h3>
      <p>At its essence, a budget is a mathematical representation of cash flow—the relationship between the money flowing into your accounts and the money flowing out. To construct an accurate and actionable budget, you must meticulously categorize these flows.</p>

      <p><strong>1. Income Streams:</strong> This encompasses all reliable sources of financial inflow. For most individuals, this is their primary salary or wages. However, a robust budget also accounts for secondary income, such as freelance work, rental income, dividends, or side hustles. It is crucial to calculate your budget based on your <em>net income</em>—the amount remaining after taxes and mandatory deductions. Budgeting based on gross income inevitably leads to overestimating available funds and subsequent shortfalls.</p>

      <p><strong>2. Fixed Expenses (Needs):</strong> These are recurring, non-negotiable costs required for basic living and financial obligations. They typically remain constant from month to month, providing a stable baseline for your budget. Key examples include housing (rent or mortgage), essential utilities (electricity, water, heating), mandatory insurance premiums, basic groceries, and minimum debt repayments. These expenses form the foundation of your financial obligations.</p>

      <p><strong>3. Variable Expenses (Wants):</strong> Variable expenses fluctuate based on personal choices and lifestyle preferences. While some degree of spending in these categories is expected, they represent the primary area where individuals can exercise control and enact significant financial changes. This category includes dining out, entertainment, subscription services, luxury shopping, and discretionary travel. Carefully monitoring these expenses is critical, as they are often the source of "budget leaks" where money is spent without deliberate intention.</p>

      <p><strong>4. Savings and Investments:</strong> Often overlooked in traditional budgeting models, treating savings as a non-negotiable expense—paying yourself first—is a proven strategy for wealth accumulation. This category includes contributions to emergency funds, retirement accounts (like IRAs or 401ks), and investments in the stock market or other asset classes. A healthy budget inherently prioritizes this category.</p>

      <h3>Budgeting Methodologies and the 50/30/20 Rule</h3>
      <p>While there are numerous budgeting frameworks—such as zero-based budgeting, where every dollar is assigned a specific job—the 50/30/20 rule remains one of the most accessible and widely adopted paradigms. Popularized by Senator Elizabeth Warren, this rule offers a straightforward proportional breakdown of your net income.</p>

      <ul>
        <li><strong>50% for Needs:</strong> Half of your after-tax income is allocated to absolute essentials. If your needs consistently exceed 50%, you may be living beyond your means and should consider downsizing housing or reducing transportation costs.</li>
        <li><strong>30% for Wants:</strong> This portion is dedicated to lifestyle choices and discretionary spending. It allows for flexibility and enjoyment without compromising financial security.</li>
        <li><strong>20% for Savings and Debt Repayment:</strong> The final fifth of your income is reserved for building financial resilience. This includes paying down high-interest debt beyond minimum payments, building an emergency fund, and investing for the future.</li>
      </ul>

      <p>Our budget calculator automatically categorizes your inputs into these three distinct buckets, providing a visual representation of how closely your current spending aligns with the 50/30/20 ideal. This immediate feedback loop is invaluable for recognizing imbalances and making proactive adjustments.</p>

      <h3>The Mathematical Framework of Budgeting</h3>
      <p>The calculations underlying personal budgeting are straightforward arithmetic, yet their consistent application is profoundly impactful.</p>

      <p>The primary equation governing financial solvency is the calculation of Net Cash Flow:</p>
      <div class="highlight-box">
        <p><strong>Net Cash Flow = Total Income - Total Expenses</strong></p>
      </div>

      <p>Where:</p>
      <ul>
        <li><strong>Total Income</strong> = Primary Income + Secondary Income + Other Income</li>
        <li><strong>Total Expenses</strong> = Fixed Expenses + Variable Expenses + Savings Contributions</li>
      </ul>

      <p>The resulting Net Cash Flow determines your financial trajectory:</p>
      <ul>
        <li>A <strong>positive net cash flow</strong> (surplus) indicates that you are living within your means and generating excess capital that can be deployed toward accelerated debt payoff or increased investments.</li>
        <li>A <strong>negative net cash flow</strong> (deficit) indicates that you are spending more than you earn, leading to the accumulation of debt and financial instability. Immediate corrective action—either increasing income or decreasing expenses—is required.</li>
      </ul>

      <p>Furthermore, calculating the proportion of income consumed by specific expense categories is essential for evaluating financial health. For instance, the housing expense ratio is calculated as:</p>

      <div class="highlight-box">
        <p><strong>Housing Ratio = (Total Housing Costs / Total Net Income) &times; 100</strong></p>
      </div>

      <p>Financial advisors generally recommend keeping housing costs below 30% of your gross income, or correspondingly lower as a percentage of your net income, to avoid being "house poor."</p>

      <h3>Implementing a Sustainable Budgeting Strategy</h3>
      <p>Creating a budget is merely the first step; adhering to it requires discipline and regular maintenance. A static budget quickly becomes obsolete in the face of changing circumstances. It is highly recommended to review and reconcile your budget at the end of each month. Compare your projected expenses against your actual spending to identify discrepancies. If you consistently overspend in a specific category, such as dining out, you must decide whether to adjust your lifestyle choices or reallocate funds from another category to accommodate the increased spending. The goal is not punitive restriction, but conscious, intentional allocation of resources to maximize your financial well-being over time. Cross-referencing your strategy with tools like our Percent Off Calculator can also help you optimize your spending by ensuring you accurately assess discounts and sales before making discretionary purchases.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is the 50/30/20 budget rule?</summary>
        <p>The 50/30/20 rule is a simple budgeting framework that recommends allocating 50% of your after-tax income to needs (housing, groceries, utilities), 30% to wants (entertainment, dining out), and 20% to savings and debt repayment. It serves as a practical baseline for financial planning.</p>
      </details>
      <details>
        <summary>How often should I update my budget?</summary>
        <p>It is recommended to review and update your budget at least once a month. However, checking your progress weekly or even daily for variable expenses can help you stay on track and prevent overspending before it becomes a problem.</p>
      </details>
      <details>
        <summary>What is the difference between fixed and variable expenses?</summary>
        <p>Fixed expenses remain constant each month, such as rent, mortgage payments, or car loans. Variable expenses fluctuate depending on your lifestyle and choices, including groceries, entertainment, dining out, and utility bills.</p>
      </details>
      <details>
        <summary>How can a budget calculator help me save money?</summary>
        <p>A budget calculator provides a clear visual breakdown of your income versus expenses. By categorizing your spending, it highlights areas where you may be overspending, allowing you to make informed adjustments and redirect those funds toward your savings goals.</p>
      </details>
      <details>
        <summary>Should I budget based on gross or net income?</summary>
        <p>You should always base your budget on your net income (your take-home pay after taxes and deductions). Budgeting based on gross income can lead to a false sense of financial security and potential overspending, as it does not reflect the actual amount of money available to you.</p>
      </details>
    </section>
  </div>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

    .input-section h3, .results-section h3 { font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.5rem; margin-top: 0; }
    .mt-4 { margin-top: 2rem; }
    .mb-2 { margin-bottom: 1rem; }

    .input-group { margin-bottom: 1rem; }
    .input-group label { display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text-secondary); }
    .input-wrapper { position: relative; display: flex; align-items: center; }
    .currency-prefix { position: absolute; left: 1rem; color: var(--text-secondary); font-weight: 600; }

    input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem 0.75rem 2.5rem; border-radius: 8px; width: 100%; font-size: 1rem; font-family: var(--font-mono); }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    input::-webkit-outer-spin-button, input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    input[type=number] { -moz-appearance: textfield; }

    .error-msg { color: #ef4444; background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; padding: 0.75rem; border-radius: 8px; margin-top: 1rem; font-size: 0.9rem; text-align: center; }

    .results-section { background: var(--bg-color); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border-color); }
    .result-card { display: flex; justify-content: space-between; align-items: center; padding: 1rem; border-bottom: 1px solid var(--border-color); }
    .result-card:last-of-type { border-bottom: none; }
    .result-label { font-weight: 600; color: var(--text-secondary); }
    .result-value { font-weight: 800; font-size: 1.25rem; font-family: var(--font-mono); }

    .main-result { flex-direction: column; align-items: center; justify-content: center; background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .main-result .result-label { color: var(--text-primary); margin-bottom: 0.5rem; }
    .main-result .result-value { font-size: 2.5rem; color: var(--accent-color); }
    .status-indicator { font-size: 0.9rem; margin-top: 0.5rem; font-weight: 600; color: var(--text-secondary); }
    .status-positive { color: #22c55e; }
    .status-negative { color: #ef4444; }

    .progress-bar-container { margin-bottom: 1rem; }
    .progress-bar-label { display: flex; justify-content: space-between; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.3rem; color: var(--text-secondary); }
    .progress-track { background: var(--border-color); height: 8px; border-radius: 4px; overflow: hidden; width: 100%; }
    .progress-fill { height: 100%; transition: width 0.3s ease, background-color 0.3s ease; }
    .fill-needs { background-color: #3b82f6; }
    .fill-wants { background-color: #a855f7; }
    .fill-savings { background-color: #10b981; }

    .explainer { margin-top: 3rem; }
    .faq-section { margin-top: 3rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); }

    @media (max-width: 768px) {
      .calc-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Inputs
      const incomeInputs = ['primary-income', 'secondary-income', 'other-income'];
      const needsInputs = ['housing', 'utilities', 'groceries', 'transportation'];
      const wantsInputs = ['dining', 'shopping', 'subscriptions'];
      const savingsInputs = ['savings-contributions', 'debt'];

      const allInputs = [...incomeInputs, ...needsInputs, ...wantsInputs, ...savingsInputs];

      // Outputs
      const resTotalIncome = document.getElementById('res-total-income');
      const resTotalExpenses = document.getElementById('res-total-expenses');
      const resNetBalance = document.getElementById('res-net-balance');
      const statusIndicator = document.getElementById('status-indicator');
      const errorMsg = document.getElementById('error-message');

      // Progress Bars
      const barNeeds = document.getElementById('bar-needs');
      const barWants = document.getElementById('bar-wants');
      const barSavings = document.getElementById('bar-savings');

      const pctNeeds = document.getElementById('pct-needs');
      const pctWants = document.getElementById('pct-wants');
      const pctSavings = document.getElementById('pct-savings');

      const amtNeeds = document.getElementById('amt-needs');
      const amtWants = document.getElementById('amt-wants');
      const amtSavings = document.getElementById('amt-savings');

      const formatCurrency = (val) => {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      };

      const getSum = (ids) => {
        return ids.reduce((sum, id) => {
          const val = parseFloat(document.getElementById(id).value) || 0;
          return sum + Math.max(0, val);
        }, 0);
      };

      const calculate = () => {
        errorMsg.style.display = 'none';

        let hasInvalidInput = false;
        allInputs.forEach(id => {
          const val = document.getElementById(id).value;
          if (val && (isNaN(val) || parseFloat(val) < 0)) {
            hasInvalidInput = true;
          }
        });

        if (hasInvalidInput) {
          errorMsg.style.display = 'block';
          errorMsg.textContent = 'Please enter positive numerical values only.';
          return;
        }

        const totalIncome = getSum(incomeInputs);
        const totalNeeds = getSum(needsInputs);
        const totalWants = getSum(wantsInputs);
        const totalSavings = getSum(savingsInputs);

        const totalExpenses = totalNeeds + totalWants + totalSavings;
        const netBalance = totalIncome - totalExpenses;

        // Update Results
        resTotalIncome.textContent = formatCurrency(totalIncome);
        resTotalExpenses.textContent = formatCurrency(totalExpenses);
        resNetBalance.textContent = formatCurrency(netBalance);

        // Update Status Indicator
        if (totalIncome === 0 && totalExpenses === 0) {
          statusIndicator.textContent = "Enter your numbers to see your balance";
          statusIndicator.className = "status-indicator";
          resNetBalance.style.color = 'var(--accent-color)';
        } else if (netBalance > 0) {
          statusIndicator.textContent = "Great! You have a surplus.";
          statusIndicator.className = "status-indicator status-positive";
          resNetBalance.style.color = '#22c55e';
        } else if (netBalance < 0) {
          statusIndicator.textContent = "Warning: You are over budget.";
          statusIndicator.className = "status-indicator status-negative";
          resNetBalance.style.color = '#ef4444';
        } else {
          statusIndicator.textContent = "Your budget is perfectly balanced.";
          statusIndicator.className = "status-indicator";
          resNetBalance.style.color = 'var(--text-primary)';
        }

        // Update Progress Bars
        const incomeBase = totalIncome > 0 ? totalIncome : totalExpenses > 0 ? totalExpenses : 1;

        const needsPct = Math.min(100, Math.round((totalNeeds / incomeBase) * 100)) || 0;
        const wantsPct = Math.min(100, Math.round((totalWants / incomeBase) * 100)) || 0;
        const savingsPct = Math.min(100, Math.round((totalSavings / incomeBase) * 100)) || 0;

        barNeeds.style.width = needsPct + '%';
        barWants.style.width = wantsPct + '%';
        barSavings.style.width = savingsPct + '%';

        // Warn if over 50/30/20 guidelines
        barNeeds.style.backgroundColor = needsPct > 50 ? '#ef4444' : '#3b82f6';
        barWants.style.backgroundColor = wantsPct > 30 ? '#ef4444' : '#a855f7';

        pctNeeds.textContent = needsPct;
        pctWants.textContent = wantsPct;
        pctSavings.textContent = savingsPct;

        amtNeeds.textContent = formatCurrency(totalNeeds);
        amtWants.textContent = formatCurrency(totalWants);
        amtSavings.textContent = formatCurrency(totalSavings);
      };

      allInputs.forEach(id => {
        document.getElementById(id).addEventListener('input', calculate);
      });

      calculate(); // Initial state
    });
  </script>
</SiteLayout>