---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Rental Yield Calculator",
  "url": "https://firemaths.info/rental-yield-calculator",
  "description": "Calculate gross yield, net yield, cap rate, and cash-on-cash return for rental properties.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Rental Yield Calculator | firemaths.info"
  description="Calculate gross yield, net yield, cap rate, and cash-on-cash return for rental properties. Analyze real estate investments with our free interactive tool."
  canonical="https://firemaths.info/rental-yield-calculator" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Property & Income</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="purchasePrice">Purchase Price</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="purchasePrice" value="350000" min="0" step="1000">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="monthlyRent">Monthly Rent</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="monthlyRent" value="2200" min="0" step="50">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="monthlyExpenses">Monthly Expenses (Taxes, Ins, HOA, Maint)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="monthlyExpenses" value="650" min="0" step="10">
                        </div>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]" style="margin-top: 2.5rem;">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Financing</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="downPayment">Down Payment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="downPayment" value="70000" min="0" step="1000">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="interestRate">Interest Rate</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">%</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="interestRate" value="6.5" min="0" step="0.1" max="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="loanTerm">Loan Term</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">Yrs</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="loanTerm" value="30" min="1" max="50" step="1">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Yields & Returns</h2>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Gross Yield</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="grossYield">0.00%</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('grossYield', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Cap Rate (Net Yield)</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="capRate">0.00%</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('capRate', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final" id="cashOnCashContainer">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Cash-on-Cash Return</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="cashOnCash">0.00%</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('cashOnCash', this)">Copy</button>
                        </div>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]" style="margin-top: 2.5rem;">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Cash Flow Metrics</h2>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final" id="monthlyCashFlowContainer">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Monthly Cash Flow</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="monthlyCashFlow">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('monthlyCashFlow', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Net Operating Income (NOI) / Yr</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="noi">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Annual Debt Service</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="annualDebtService">$0</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding Rental Yields</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When analyzing a real estate investment, yield metrics help you determine if a property will be profitable. <strong>Gross Yield</strong> is your total annual rent divided by the purchase price. It provides a quick, high-level snapshot but ignores expenses. <strong>Cap Rate (or Net Yield)</strong> is much more accurate. It takes your Net Operating Income (NOI)—which is rent minus operating expenses like taxes, insurance, and maintenance—and divides it by the purchase price. A higher cap rate typically means a better return, though it can also indicate higher risk.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">What is Cash-on-Cash Return?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">While cap rate evaluates a property independently of how it's financed, <strong>Cash-on-Cash Return</strong> measures the specific return on your actual out-of-pocket cash invested (your down payment). It is calculated by taking your total annual cash flow (NOI minus your mortgage payments) and dividing it by your total initial investment. For investors using leverage (a mortgage), this is often the most important metric because it shows the immediate cash yield on their actual invested capital.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Tips for Real Estate Investors</h2>
            <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc space-y-2">
                <li><strong>Don't Forget Hidden Expenses:</strong> Always account for vacancy rates, property management fees, and a maintenance reserve when estimating monthly expenses. Assuming 100% occupancy with no repairs is a common pitfall.</li>
                <li><strong>Leverage Wisely:</strong> Taking out a mortgage can boost your cash-on-cash return significantly, but it also increases your debt obligations. Ensure your monthly cash flow provides a comfortable buffer above $0.</li>
                <li><strong>Focus on Cash Flow First:</strong> Properties that generate solid positive monthly cash flow offer safety against market downturns. Appreciation is great, but cash flow pays the bills.</li>
            </ul>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // Calculation logic
    const updateCalculator = () => {
        const purchasePrice = parseFloat(document.getElementById('purchasePrice').value) || 0;
        const monthlyRent = parseFloat(document.getElementById('monthlyRent').value) || 0;
        const monthlyExpenses = parseFloat(document.getElementById('monthlyExpenses').value) || 0;
        const downPayment = parseFloat(document.getElementById('downPayment').value) || 0;
        const interestRate = parseFloat(document.getElementById('interestRate').value) || 0;
        const loanTerm = parseFloat(document.getElementById('loanTerm').value) || 0;

        // Income & Expenses
        const annualRent = monthlyRent * 12;
        const annualExpenses = monthlyExpenses * 12;
        const noi = annualRent - annualExpenses;

        // Yields
        const grossYield = purchasePrice > 0 ? (annualRent / purchasePrice) * 100 : 0;
        const capRate = purchasePrice > 0 ? (noi / purchasePrice) * 100 : 0;

        // Financing
        const principal = Math.max(0, purchasePrice - downPayment);
        const monthlyRate = interestRate / 100 / 12;
        const totalMonths = loanTerm * 12;

        let monthlyMortgage = 0;
        if (principal > 0 && monthlyRate > 0 && totalMonths > 0) {
            monthlyMortgage = principal * (monthlyRate * Math.pow(1 + monthlyRate, totalMonths)) / (Math.pow(1 + monthlyRate, totalMonths) - 1);
        } else if (principal > 0 && totalMonths > 0) {
            monthlyMortgage = principal / totalMonths;
        }

        const annualDebtService = monthlyMortgage * 12;
        const annualCashFlow = noi - annualDebtService;
        const monthlyCashFlow = annualCashFlow / 12;

        const cashOnCash = downPayment > 0 ? (annualCashFlow / downPayment) * 100 : 0;

        // Update UI
        document.getElementById('grossYield').innerText = grossYield.toFixed(2) + '%';
        document.getElementById('capRate').innerText = capRate.toFixed(2) + '%';
        document.getElementById('cashOnCash').innerText = cashOnCash.toFixed(2) + '%';

        document.getElementById('monthlyCashFlow').innerText = formatCurrency(monthlyCashFlow);
        document.getElementById('noi').innerText = formatCurrency(noi);
        document.getElementById('annualDebtService').innerText = formatCurrency(annualDebtService);

        // Styling for negative values
        const cashOnCashContainer = document.getElementById('cashOnCashContainer');
        if (cashOnCash < 0) {
            cashOnCashContainer.classList.add('result-negative');
        } else {
            cashOnCashContainer.classList.remove('result-negative');
        }

        const monthlyCashFlowContainer = document.getElementById('monthlyCashFlowContainer');
        if (monthlyCashFlow < 0) {
            monthlyCashFlowContainer.classList.add('result-negative');
        } else {
            monthlyCashFlowContainer.classList.remove('result-negative');
        }
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"]');
    inputs.forEach(input => {
        input.addEventListener('input', updateCalculator);
    });

    // Initial calculation
    updateCalculator();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-real-estate-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Real Estate Investing: Complete Beginner's Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
