    .content-section h3 { font-size: 1.4rem; margin: 2rem 0 1rem; }
    .content-section ul, .content-section ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .content-section li { margin-bottom: 0.5rem; }
    .content-section a { color: var(--accent-color); text-decoration: none; }
    .content-section a:hover { text-decoration: underline; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; text-align: center; }
    .faq-item { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); }
    .faq-item:last-child { border-bottom: none; }
    .faq-item h3 { font-size: 1.2rem; margin-bottom: 0.8rem; }
    .faq-item p { color: var(--text-secondary); line-height: 1.6; }

    @media (max-width: 600px) {
      .results-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
