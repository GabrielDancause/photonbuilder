---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Home Affordability Calculator",
  "url": "https://firemaths.info/home-affordability-calculator",
  "description": "Calculate how much house you can afford based on income, debts, down payment, and interest rates. See monthly payment breakdowns and affordability at different price points.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much house can I afford on a $100,000 salary?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On a $100,000 annual salary with no other debts, you can typically afford a home priced between $300,000 and $450,000, depending on your down payment, interest rate, and location. Lenders generally use the 28/36 rule: your mortgage payment should not exceed 28% of gross monthly income, and total debt payments should stay below 36%."
      }
    },
    {
      "@type": "Question",
      "name": "What is the 28/36 rule for mortgage affordability?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 28/36 rule is a guideline lenders use to determine how much you can borrow. The front-end ratio (28%) means your total housing costs — including mortgage principal, interest, taxes, and insurance — should not exceed 28% of your gross monthly income. The back-end ratio (36%) means your total monthly debt payments, including housing costs plus car loans, student loans, and credit cards, should not exceed 36% of gross monthly income."
      }
    },
    {
      "@type": "Question",
      "name": "How does my down payment affect how much house I can afford?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A larger down payment reduces your loan amount, which lowers your monthly payment and may qualify you for a better interest rate. With 20% down, you also avoid private mortgage insurance (PMI), saving $100–$300+ per month. For example, on a $400,000 home, putting 20% down ($80,000) versus 5% ($20,000) could save you over $500/month in combined PMI and principal/interest payments."
      }
    },
    {
      "@type": "Question",
      "name": "Should I choose a 15-year or 30-year mortgage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 15-year mortgage has higher monthly payments but saves significantly on total interest — often 50–60% less than a 30-year loan. A 30-year mortgage offers lower monthly payments and more flexibility. Choose 15 years if you can comfortably afford the higher payment and want to build equity faster. Choose 30 years if you need lower payments or want to invest the difference elsewhere."
      }
    },
    {
      "@type": "Question",
      "name": "What hidden costs should I budget for when buying a home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beyond the mortgage payment, budget for: closing costs (2–5% of home price), property taxes (0.5–2.5% annually), homeowners insurance ($1,000–$3,000/year), private mortgage insurance if under 20% down, HOA fees ($200–$500+/month in some areas), maintenance and repairs (1–2% of home value per year), utilities, and potential special assessments. These can add $500–$1,500+ to your monthly housing costs."
      }
    },
    {
      "@type": "Question",
      "name": "How do interest rates affect my home buying power?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Interest rates have a dramatic impact on affordability. For every 1% increase in rate, your buying power drops roughly 10%. For example, at 6% interest on a 30-year loan, a $2,000/month payment supports about a $333,000 mortgage. At 7%, that same payment only supports about $300,000. A 2% rate difference on a $350,000 loan can mean over $150,000 more in total interest paid over 30 years."
      }
    },
    {
      "@type": "Question",
      "name": "What credit score do I need to buy a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For a conventional mortgage, most lenders require a minimum credit score of 620, though 740+ gets you the best rates. FHA loans accept scores as low as 580 with 3.5% down, or 500 with 10% down. VA and USDA loans don't have official minimums but most lenders want 620+. Every 20-point increase in your score can save 0.125–0.25% on your rate, potentially saving tens of thousands over the life of the loan."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I save before buying a house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Plan to save: your down payment (3.5–20% of purchase price), closing costs (2–5% of purchase price), an emergency fund covering 3–6 months of housing costs, and a moving/furnishing budget. For a $350,000 home with 10% down, this means roughly $35,000 down payment + $10,000–$17,500 closing costs + $7,000–$14,000 emergency fund = $52,000–$66,500 minimum."
      }
    }
  ]
};

export const meta = {
  title: "Home Affordability Calculator",
  description: "Calculate how much house you can afford based on income, debts, and down payment. See monthly payment breakdowns and compare down payment scenarios.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Home Affordability Calculator — How Much House Can I Afford? | firemaths.info"
  description="Calculate how much house you can afford based on your income, debts, and down payment. See monthly payment breakdowns, compare down payment scenarios, and get a clear affordability picture."
  canonical="https://firemaths.info/home-affordability-calculator" schema={[schema, faqSchema]}
>
  <style>
:root {
    --color-pi: #4A90E2;
    --color-tax: #D4A017;
    --color-ins: #50E3C2;
    --color-hoa: #E25C5C;
    --color-pmi: #9B59B6;
    --gauge-conservative: #50E3C2;
    --gauge-comfortable: #4A90E2;
    --gauge-stretch: #D4A017;
    --gauge-risky: #E25C5C;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

select {
    font-family: var(--font-ui);
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23888888' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1em;
    padding-right: 2.5rem;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.chart-header {
    margin-bottom: 1.5rem;
    text-align: center;
}

.chart-header h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
}

.pie-container {
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
    aspect-ratio: 1;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

/* Gauge */
.gauge-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
    text-align: center;
}

.gauge-container {
    max-width: 400px;
    margin: 1.5rem auto;
    position: relative;
}

.gauge-bar {
    height: 24px;
    border-radius: 12px;
    display: flex;
    overflow: hidden;
    margin-bottom: 0.5rem;
}

.gauge-segment {
    height: 100%;
}

.gauge-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-secondary);
}

.gauge-needle {
    position: absolute;
    top: 0;
    width: 4px;
    height: 24px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: left 0.5s ease;
}

.gauge-value {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 1rem;
}

/* Comparison cards */
.comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .comparison-grid {
        grid-template-columns: 1fr;
    }
}

.compare-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
}

.compare-card h3 {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
}

.compare-card .big-number {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
    margin-bottom: 0.5rem;
}

.compare-card .detail {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.compare-card.highlight {
    border-color: var(--accent-color);
}

/* Table */
.table-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
    overflow-x: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

th, td {
    padding: 0.75rem 1rem;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
}

th {
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

th:first-child, td:first-child {
    text-align: left;
}

td {
    font-family: var(--font-mono);
    color: var(--text-primary);
}

tr:last-child td {
    border-bottom: none;
}

tr.table-highlight td {
    color: var(--accent-color);
    font-weight: 600;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content h3 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul, .seo-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.25rem 0;
}

.faq-item:last-child {
    border-bottom: none;
}

.faq-question {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    cursor: pointer;
}

.faq-answer {
    color: var(--text-secondary);
    line-height: 1.7;
}

.related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
}

.related-link {
    display: block;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 500;
    transition: border-color 0.2s;
}

.related-link:hover {
    border-color: var(--accent-color);
}

.related-link span {
    display: block;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
    font-weight: 400;
}

.dual-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

@media (max-width: 640px) {
    .dual-col {
        grid-template-columns: 1fr;
    }
}
  </style>

<div class="container">
    <div style="background:rgba(212,160,23,0.08);border:1px solid rgba(212,160,23,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      🏠 <strong style="color:#D4A017;">Rising costs are squeezing home budgets.</strong> Energy up 7%, groceries up 15%, and mortgage rates still elevated. Every extra $100/month in living costs reduces your home buying power by ~$15,000. Calculate what you can really afford below. <a href="https://gab.ae/news/inflation-eroding-savings-compound-interest-defense-2026" style="color:#D4A017;">The full inflation picture →</a>
    </div>
    <h1>Home Affordability Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:3rem;">Find out how much house you can afford based on your income, debts, and down payment.</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your Finances</h2>
                </div>

                <div class="input-group">
                    <label for="annual-income">Annual Gross Income</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="annual-income" value="85000" min="0" step="1000">
                    </div>
                </div>

                <div class="input-group">
                    <label for="monthly-debts">Monthly Debts (car, student loans, credit cards)</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="monthly-debts" value="400" min="0" step="50">
                    </div>
                </div>

                <div class="input-group">
                    <label for="down-payment">Down Payment</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="down-payment" value="60000" min="0" step="1000">
                    </div>
                </div>

                <div class="dual-col">
                    <div class="input-group">
                        <label for="interest-rate">Interest Rate</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="interest-rate" value="6.75" min="0" max="15" step="0.125">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="loan-term">Loan Term</label>
                        <div class="input-wrapper">
                            <select id="loan-term">
                                <option value="30" selected>30 years</option>
                                <option value="20">20 years</option>
                                <option value="15">15 years</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="dual-col">
                    <div class="input-group">
                        <label for="property-tax-rate">Property Tax Rate</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="property-tax-rate" value="1.2" min="0" max="5" step="0.1">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="insurance-annual">Home Insurance / yr</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="insurance-annual" value="1800" min="0" step="100">
                        </div>
                    </div>
                </div>

                <div class="input-group">
                    <label for="hoa-monthly">HOA Fees / month</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="hoa-monthly" value="0" min="0" step="25">
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>You Can Afford</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Max Home Price</span>
                        <div class="result-value">
                            <span id="max-home-price">$0</span>
                            <button class="copy-btn" onclick="copyValue('max-home-price', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item" style="margin-bottom: 0.5rem;">
                        <span class="result-label" style="font-size: 0.8rem; color: var(--text-secondary);">Based on</span>
                        <span class="result-value" id="binding-ratio" style="font-size: 0.8rem; font-family: var(--font-ui); color: var(--text-secondary);">—</span>
                    </div>

                    <div style="margin: 1.25rem 0; padding: 1rem; border-radius: 8px; background: var(--bg-color);">
                        <div style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Monthly Payment Breakdown</div>
                        <div class="result-item">
                            <span class="result-label">Principal & Interest</span>
                            <span class="result-value" id="monthly-pi" style="color: var(--color-pi);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Property Tax</span>
                            <span class="result-value" id="monthly-tax" style="color: var(--color-tax);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Insurance</span>
                            <span class="result-value" id="monthly-ins" style="color: var(--color-ins);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">HOA</span>
                            <span class="result-value" id="monthly-hoa" style="color: var(--color-hoa);">$0</span>
                        </div>
                        <div class="result-item" id="pmi-row" style="display: none;">
                            <span class="result-label">Est. PMI</span>
                            <span class="result-value" id="monthly-pmi" style="color: var(--color-pmi);">$0</span>
                        </div>
                        <div class="result-item" style="border-top: 1px dashed var(--border-color); padding-top: 0.75rem; margin-top: 0.5rem;">
                            <span class="result-label" style="font-weight: 600; color: var(--text-primary);">Total Monthly</span>
                            <span class="result-value" id="monthly-total" style="font-weight: 700; color: var(--accent-color);">$0</span>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Loan Amount</span>
                        <span class="result-value" id="loan-amount" style="font-size: 1rem;">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Front-end Ratio (28% max)</span>
                        <span class="result-value" id="front-ratio" style="font-size: 1rem;">0%</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Back-end Ratio (36% max)</span>
                        <span class="result-value" id="back-ratio" style="font-size: 1rem;">0%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pie Chart -->
        <div class="chart-section">
            <div class="chart-header">
                <h2>Payment Breakdown</h2>
                <div class="chart-legend">
                    <div class="legend-item"><span class="indicator" style="background: var(--color-pi);"></span> Principal & Interest</div>
                    <div class="legend-item"><span class="indicator" style="background: var(--color-tax);"></span> Taxes</div>
                    <div class="legend-item"><span class="indicator" style="background: var(--color-ins);"></span> Insurance</div>
                    <div class="legend-item"><span class="indicator" style="background: var(--color-hoa);"></span> HOA</div>
                    <div class="legend-item" id="pmi-legend" style="display: none;"><span class="indicator" style="background: var(--color-pmi);"></span> PMI</div>
                </div>
            </div>
            <div class="pie-container">
                <canvas id="pieChart"></canvas>
            </div>
        </div>

        <!-- Affordability Gauge -->
        <div class="gauge-section">
            <h2 style="font-size: 1.25rem; margin-bottom: 0.5rem;">Affordability Meter</h2>
            <p style="color: var(--text-secondary); font-size: 0.9rem;">Based on your housing-cost-to-income ratio</p>
            <div class="gauge-container">
                <div class="gauge-bar">
                    <div class="gauge-segment" style="width: 25%; background: var(--gauge-conservative);"></div>
                    <div class="gauge-segment" style="width: 25%; background: var(--gauge-comfortable);"></div>
                    <div class="gauge-segment" style="width: 25%; background: var(--gauge-stretch);"></div>
                    <div class="gauge-segment" style="width: 25%; background: var(--gauge-risky);"></div>
                </div>
                <div class="gauge-needle" id="gauge-needle"></div>
                <div class="gauge-labels">
                    <span>Conservative</span>
                    <span>Comfortable</span>
                    <span>Stretch</span>
                    <span>Risky</span>
                </div>
            </div>
            <div class="gauge-value" id="gauge-label">—</div>
        </div>

        <!-- Down Payment Comparison -->
        <h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Compare Down Payment Scenarios</h2>
        <div class="comparison-grid" id="comparison-grid">
            <!-- Filled by JS -->
        </div>

        <!-- Price Table -->
        <div class="table-section">
            <h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Monthly Payment at Different Home Prices</h2>
            <table id="price-table">
                <thead>
                    <tr>
                        <th>Home Price</th>
                        <th>Down Payment</th>
                        <th>Loan Amount</th>
                        <th>Monthly P&I</th>
                        <th>Total Monthly</th>
                    </tr>
                </thead>
                <tbody id="price-table-body">
                </tbody>
            </table>
        </div>

        <!-- Tips Section -->
        <div class="seo-content">
            <h2>How the Home Affordability Calculator Works</h2>
            <p>This mortgage affordability calculator uses the industry-standard <strong>28/36 rule</strong> to determine how much house you can afford. The front-end ratio caps your total housing payment (principal, interest, taxes, insurance, and HOA) at 28% of your gross monthly income. The back-end ratio ensures your total debt load — housing costs plus existing debts — stays at or below 36%.</p>
            <p>The calculator takes the more conservative of the two limits, so if your existing debts are high, the back-end ratio may reduce your maximum home price below what the front-end ratio alone would allow.</p>

            <h2>How to Improve Your Home Affordability</h2>
            <ul>
                <li><strong>Increase your down payment:</strong> A larger down payment reduces your loan amount and eliminates PMI once you reach 20%. Even an extra $10,000 down can meaningfully lower your monthly payment.</li>
                <li><strong>Pay down existing debts:</strong> Reducing car payments, student loans, or credit card balances directly improves your back-end ratio, letting you qualify for a larger mortgage.</li>
                <li><strong>Improve your credit score:</strong> A higher credit score qualifies you for lower interest rates. Even a 0.5% rate reduction on a $300,000 loan saves roughly $100/month.</li>
                <li><strong>Consider a longer loan term:</strong> A 30-year mortgage has lower monthly payments than a 15-year, increasing the price you can afford — though you pay more in total interest.</li>
                <li><strong>Shop for better rates:</strong> Get quotes from at least 3–5 lenders. Rates can vary by 0.5% or more between lenders for the same borrower profile.</li>
                <li><strong>Look in lower-tax areas:</strong> Property taxes vary dramatically by location. A home in a 0.5% tax area costs significantly less monthly than the same-priced home in a 2.5% tax area.</li>
            </ul>

            <h2>Hidden Costs of Homeownership</h2>
            <p>Your mortgage payment is just the starting point. Budget for these often-overlooked expenses:</p>
            <ul>
                <li><strong>Closing costs:</strong> Typically 2–5% of the purchase price, paid upfront. On a $350,000 home, that is $7,000–$17,500.</li>
                <li><strong>Maintenance and repairs:</strong> Plan for 1–2% of your home's value annually. For a $350,000 home, that is $3,500–$7,000 per year.</li>
                <li><strong>Utilities:</strong> Homeowners typically pay $200–$400+/month more than renters for water, gas, electricity, trash, and internet.</li>
                <li><strong>Private mortgage insurance (PMI):</strong> Required if your down payment is less than 20%. Costs 0.5–1.5% of the loan amount annually.</li>
                <li><strong>HOA fees:</strong> Can range from $100 to $500+ per month depending on the community and amenities.</li>
                <li><strong>Landscaping and lawn care:</strong> $100–$300/month if you hire out, or significant time investment if you DIY.</li>
                <li><strong>Home warranty:</strong> $300–$600/year for basic coverage, often wise for older homes.</li>
            </ul>

            <h2>Frequently Asked Questions</h2>
            <div>
                {faqSchema.mainEntity.map((item: { name: string; acceptedAnswer: { text: string } }) => (
                    <div class="faq-item">
                        <div class="faq-question">{item.name}</div>
                        <div class="faq-answer">{item.acceptedAnswer.text}</div>
                    </div>
                ))}
            </div>

            <h2>Related Calculators</h2>
            <div class="related-links">
                <a href="/mortgage-calculator" class="related-link">
                    Mortgage Calculator
                    <span>Calculate monthly payments, amortization schedules, and total interest</span>
                </a>
                <a href="/401k-calculator" class="related-link">
                    401k Calculator
                    <span>Project your retirement savings with employer matching</span>
                </a>
                <a href="/annuity-calculator" class="related-link">
                    Annuity Calculator
                    <span>Estimate annuity payments and compare payout options</span>
                </a>
            </div>
        </div>
    </main>
</div>

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmtPct = (v) => v.toFixed(1) + '%';

window.copyValue = async (id, btn) => {
    try {
        await navigator.clipboard.writeText(document.getElementById(id).innerText);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => btn.innerText = orig, 2000);
    } catch (e) {}
};

function getInputs() {
    return {
        annualIncome: parseFloat(document.getElementById('annual-income').value) || 0,
        monthlyDebts: parseFloat(document.getElementById('monthly-debts').value) || 0,
        downPayment: parseFloat(document.getElementById('down-payment').value) || 0,
        rate: parseFloat(document.getElementById('interest-rate').value) || 0,
        term: parseInt(document.getElementById('loan-term').value) || 30,
        taxRate: parseFloat(document.getElementById('property-tax-rate').value) || 0,
        insuranceAnnual: parseFloat(document.getElementById('insurance-annual').value) || 0,
        hoaMonthly: parseFloat(document.getElementById('hoa-monthly').value) || 0,
    };
}

function calcMonthlyPI(loanAmount, annualRate, termYears) {
    if (loanAmount <= 0) return 0;
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    if (r === 0) return loanAmount / n;
    return loanAmount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function calcMaxHomePrice(inputs) {
    const monthlyIncome = inputs.annualIncome / 12;

    // Front-end: housing costs <= 28% of gross monthly income
    const maxHousingFront = monthlyIncome * 0.28;

    // Back-end: total debts <= 36% of gross monthly income
    const maxHousingBack = monthlyIncome * 0.36 - inputs.monthlyDebts;

    const maxHousing = Math.max(0, Math.min(maxHousingFront, maxHousingBack));
    const bindingRatio = maxHousingBack < maxHousingFront ? 'back-end (36%)' : 'front-end (28%)';

    // maxHousing = PI + tax + insurance + HOA + PMI
    // We need to solve for home price iteratively since tax and PMI depend on home price
    const monthlyIns = inputs.insuranceAnnual / 12;
    const monthlyHOA = inputs.hoaMonthly;

    // Available for PI + tax + PMI
    const availForPITaxPMI = maxHousing - monthlyIns - monthlyHOA;
    if (availForPITaxPMI <= 0) return { homePrice: 0, bindingRatio, breakdown: null };

    // Binary search for max home price
    let lo = 0, hi = 5000000;
    for (let i = 0; i < 50; i++) {
        const mid = (lo + hi) / 2;
        const loanAmt = Math.max(0, mid - inputs.downPayment);
        const pi = calcMonthlyPI(loanAmt, inputs.rate, inputs.term);
        const monthlyTax = (mid * inputs.taxRate / 100) / 12;
        const dpPercent = mid > 0 ? inputs.downPayment / mid : 1;
        const pmi = dpPercent < 0.2 ? (loanAmt * 0.007) / 12 : 0;
        const total = pi + monthlyTax + pmi;

        if (total <= availForPITaxPMI) lo = mid;
        else hi = mid;
    }

    const homePrice = Math.floor(lo / 100) * 100; // round down to nearest 100
    return buildBreakdown(homePrice, inputs, bindingRatio);
}

function buildBreakdown(homePrice, inputs, bindingRatio) {
    const loanAmt = Math.max(0, homePrice - inputs.downPayment);
    const pi = calcMonthlyPI(loanAmt, inputs.rate, inputs.term);
    const monthlyTax = (homePrice * inputs.taxRate / 100) / 12;
    const monthlyIns = inputs.insuranceAnnual / 12;
    const monthlyHOA = inputs.hoaMonthly;
    const dpPercent = homePrice > 0 ? inputs.downPayment / homePrice : 1;
    const pmi = dpPercent < 0.2 ? (loanAmt * 0.007) / 12 : 0;
    const total = pi + monthlyTax + monthlyIns + monthlyHOA + pmi;
    const monthlyIncome = inputs.annualIncome / 12;
    const frontRatio = monthlyIncome > 0 ? (total / monthlyIncome) * 100 : 0;
    const backRatio = monthlyIncome > 0 ? ((total + inputs.monthlyDebts) / monthlyIncome) * 100 : 0;

    return {
        homePrice,
        loanAmt,
        pi,
        monthlyTax,
        monthlyIns,
        monthlyHOA,
        pmi,
        total,
        frontRatio,
        backRatio,
        bindingRatio,
        dpPercent
    };
}

function updateResults() {
    const inputs = getInputs();
    const result = calcMaxHomePrice(inputs);

    document.getElementById('max-home-price').innerText = fmt(result.homePrice);
    const bd = result.bindingRatio;

    if (result.homePrice === 0) {
        document.getElementById('binding-ratio').innerText = '—';
        document.getElementById('monthly-pi').innerText = '$0';
        document.getElementById('monthly-tax').innerText = '$0';
        document.getElementById('monthly-ins').innerText = '$0';
        document.getElementById('monthly-hoa').innerText = '$0';
        document.getElementById('monthly-total').innerText = '$0';
        document.getElementById('loan-amount').innerText = '$0';
        document.getElementById('front-ratio').innerText = '0%';
        document.getElementById('back-ratio').innerText = '0%';
        return result;
    }

    document.getElementById('binding-ratio').innerText = bd + ' ratio';
    document.getElementById('monthly-pi').innerText = fmt(result.pi);
    document.getElementById('monthly-tax').innerText = fmt(result.monthlyTax);
    document.getElementById('monthly-ins').innerText = fmt(result.monthlyIns);
    document.getElementById('monthly-hoa').innerText = fmt(result.monthlyHOA);
    document.getElementById('loan-amount').innerText = fmt(result.loanAmt);
    document.getElementById('front-ratio').innerText = fmtPct(result.frontRatio);
    document.getElementById('back-ratio').innerText = fmtPct(result.backRatio);

    const pmiRow = document.getElementById('pmi-row');
    const pmiLegend = document.getElementById('pmi-legend');
    if (result.pmi > 0) {
        pmiRow.style.display = 'flex';
        pmiLegend.style.display = 'flex';
        document.getElementById('monthly-pmi').innerText = fmt(result.pmi);
    } else {
        pmiRow.style.display = 'none';
        pmiLegend.style.display = 'none';
    }

    document.getElementById('monthly-total').innerText = fmt(result.total);

    return result;
}

// Pie chart
function drawPie(result) {
    const canvas = document.getElementById('pieChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.parentElement.getBoundingClientRect();

    canvas.width = rect.width * dpr;
    canvas.height = rect.width * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);

    const size = rect.width;
    const cx = size / 2;
    const cy = size / 2;
    const radius = size * 0.4;

    ctx.clearRect(0, 0, size, size);

    if (!result || result.homePrice === 0 || result.total === 0) return;

    const slices = [
        { value: result.pi, color: getComputedStyle(document.documentElement).getPropertyValue('--color-pi').trim(), label: 'P&I' },
        { value: result.monthlyTax, color: getComputedStyle(document.documentElement).getPropertyValue('--color-tax').trim(), label: 'Tax' },
        { value: result.monthlyIns, color: getComputedStyle(document.documentElement).getPropertyValue('--color-ins').trim(), label: 'Ins' },
        { value: result.monthlyHOA, color: getComputedStyle(document.documentElement).getPropertyValue('--color-hoa').trim(), label: 'HOA' },
    ];
    if (result.pmi > 0) {
        slices.push({ value: result.pmi, color: getComputedStyle(document.documentElement).getPropertyValue('--color-pmi').trim(), label: 'PMI' });
    }

    const total = slices.reduce((s, sl) => s + sl.value, 0);
    let startAngle = -Math.PI / 2;

    slices.forEach(slice => {
        if (slice.value <= 0) return;
        const sliceAngle = (slice.value / total) * Math.PI * 2;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, radius, startAngle, startAngle + sliceAngle);
        ctx.closePath();
        ctx.fillStyle = slice.color;
        ctx.fill();

        // Label
        if (sliceAngle > 0.2) {
            const midAngle = startAngle + sliceAngle / 2;
            const lx = cx + Math.cos(midAngle) * radius * 0.65;
            const ly = cy + Math.sin(midAngle) * radius * 0.65;
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 13px Inter, sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(Math.round((slice.value / total) * 100) + '%', lx, ly);
        }

        startAngle += sliceAngle;
    });

    // Center hole (donut)
    ctx.beginPath();
    ctx.arc(cx, cy, radius * 0.5, 0, Math.PI * 2);
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--card-bg').trim() || '#1a1a1a';
    ctx.fill();

    // Center text
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim() || '#fff';
    ctx.font = 'bold 18px Inter, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(fmt(total), cx, cy - 8);
    ctx.font = '12px Inter, sans-serif';
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#888';
    ctx.fillText('/month', cx, cy + 12);
}

// Gauge
function updateGauge(result) {
    const needle = document.getElementById('gauge-needle');
    const label = document.getElementById('gauge-label');

    if (!result || result.homePrice === 0) {
        needle.style.left = '0%';
        label.innerText = '—';
        label.style.color = 'var(--text-secondary)';
        return;
    }

    const ratio = result.frontRatio;
    // 0-20% conservative, 20-28% comfortable, 28-35% stretch, 35%+ risky
    let pct, text, color;
    if (ratio <= 20) {
        pct = (ratio / 20) * 25;
        text = fmtPct(ratio) + ' — Conservative';
        color = 'var(--gauge-conservative)';
    } else if (ratio <= 28) {
        pct = 25 + ((ratio - 20) / 8) * 25;
        text = fmtPct(ratio) + ' — Comfortable';
        color = 'var(--gauge-comfortable)';
    } else if (ratio <= 35) {
        pct = 50 + ((ratio - 28) / 7) * 25;
        text = fmtPct(ratio) + ' — Stretch';
        color = 'var(--gauge-stretch)';
    } else {
        pct = Math.min(100, 75 + ((ratio - 35) / 15) * 25);
        text = fmtPct(ratio) + ' — Risky';
        color = 'var(--gauge-risky)';
    }

    needle.style.left = 'calc(' + pct + '% - 2px)';
    label.innerText = text;
    label.style.color = color;
}

// Down payment comparison
function updateComparison() {
    const inputs = getInputs();
    const grid = document.getElementById('comparison-grid');
    const scenarios = [5, 10, 20];

    grid.innerHTML = scenarios.map(dpPct => {
        // Use same max home calculation but with different down payment
        // Instead: for same max home price, show what happens at each DP level
        // Actually: calculate max home price for each DP percentage
        const modInputs = Object.assign({}, inputs);

        // For each scenario, show what the user's current down payment would be as a %
        // and calculate the max home where DP = dpPct% of that home price
        // dp = dpPct/100 * homePrice => homePrice = dp / (dpPct/100)
        const impliedHomePrice = inputs.downPayment / (dpPct / 100);
        const bd = buildBreakdown(Math.floor(impliedHomePrice / 100) * 100, inputs, '');
        const isHighlight = dpPct === 20;

        return '<div class="compare-card' + (isHighlight ? ' highlight' : '') + '">' +
            '<h3>' + dpPct + '% Down' + (isHighlight ? ' (No PMI)' : '') + '</h3>' +
            '<div class="big-number">' + fmt(bd.homePrice) + '</div>' +
            '<div class="detail">Down: ' + fmt(inputs.downPayment) + '</div>' +
            '<div class="detail">Loan: ' + fmt(bd.loanAmt) + '</div>' +
            '<div class="detail">Monthly: ' + fmt(bd.total) + '</div>' +
            (bd.pmi > 0 ? '<div class="detail" style="color: var(--color-pmi);">PMI: ' + fmt(bd.pmi) + '/mo</div>' : '') +
            '</div>';
    }).join('');
}

// Price table
function updateTable() {
    const inputs = getInputs();
    const tbody = document.getElementById('price-table-body');
    const maxResult = calcMaxHomePrice(inputs);
    const maxPrice = maxResult.homePrice;
    const prices = [];
    for (let p = 200000; p <= 800000; p += 50000) prices.push(p);

    tbody.innerHTML = prices.map(price => {
        const loanAmt = Math.max(0, price - inputs.downPayment);
        const pi = calcMonthlyPI(loanAmt, inputs.rate, inputs.term);
        const monthlyTax = (price * inputs.taxRate / 100) / 12;
        const monthlyIns = inputs.insuranceAnnual / 12;
        const dpPct = price > 0 ? inputs.downPayment / price : 1;
        const pmi = dpPct < 0.2 ? (loanAmt * 0.007) / 12 : 0;
        const total = pi + monthlyTax + monthlyIns + inputs.hoaMonthly + pmi;
        const isClosest = Math.abs(price - maxPrice) < 50000 && price <= maxPrice + 25000 && price >= maxPrice - 25000;

        return '<tr' + (isClosest ? ' class="table-highlight"' : '') + '>' +
            '<td>' + fmt(price) + (isClosest ? ' ~' : '') + '</td>' +
            '<td>' + fmt(inputs.downPayment) + '</td>' +
            '<td>' + fmt(loanAmt) + '</td>' +
            '<td>' + fmt(pi) + '</td>' +
            '<td>' + fmt(total) + '</td>' +
            '</tr>';
    }).join('');
}

function updateAll() {
    const result = updateResults();
    drawPie(result);
    updateGauge(result);
    updateComparison();
    updateTable();
}

document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', updateAll);
});

window.addEventListener('resize', updateAll);
setTimeout(updateAll, 0);
  </script>

