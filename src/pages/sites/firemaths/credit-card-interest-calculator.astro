<SiteLayout site="firemaths" title="Credit Card Interest Calculator - FireMaths" description="See exactly how much credit card interest is costing you. Our calculator shows the total interest paid and helps you find the fastest path to becoming." canonical="https://firemaths.info/credit-card-interest-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Credit Card Interest Calculator</h1>
      <p class="subtitle">Calculate total interest and payoff time for your credit card balances.</p>
    </div>

    <div class="calculator-container">
      <div class="input-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
        <div>
          <label for="balance" style="display:block; margin-bottom:0.5rem; font-weight:600;">Current Balance ($)</label>
