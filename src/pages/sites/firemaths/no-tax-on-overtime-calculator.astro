    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .explainer { line-height: 1.6; margin-bottom: 3rem; }
    .explainer h2, .explainer h3 { margin-top: 2rem; margin-bottom: 1rem; }
    .explainer p { margin-bottom: 1rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; list-style-position: inside; }
    .faq-section p { margin-top: 1rem; line-height: 1.6; }
    .toggle-container { display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; margin-bottom: 1.5rem; }
    .toggle-label { font-weight: 600; }
    .switch { position: relative; display: inline-block; width: 50px; height: 28px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 28px; }
    .slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background-color: var(--accent-color); }
    input:checked + .slider:before { transform: translateX(22px); }
    @media (max-width: 640px) {
      .calculator-container > div:first-child { grid-template-columns: 1fr !important; }
      .result-card > div:last-child { grid-template-columns: 1fr !important; gap: 0.5rem !important; }
      .result-card > div:last-child > div { border: none !important; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem; }
      .result-card > div:last-child > div:last-child { border-bottom: none; padding-bottom: 0; margin-bottom: 0; }
    }
  </style>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/overtime-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Overtime Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Find out exactly how much extra you</p>
      </a>
      <a href="https://westmountfundamentals.com/present-value-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Present Value Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Curious what future cash is actually worth today? Discover the true value of tomorrow</p>
      </a>
      <a href="https://westmountfundamentals.com/mutual-fund-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
