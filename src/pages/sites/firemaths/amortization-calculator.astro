---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Amortization Calculator | Firemaths',
  description: 'Discover our free amortization calculator. Calculate monthly payments, visualize your principal vs interest, and see how extra payments save you money.',
  category: 'tool',
  keywords: ['amortization calculator', 'loan schedule', 'monthly payment breakdown', 'principal and interest', 'payoff date', 'extra payments']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Amortization Calculator | Firemaths",
    "description": "Discover our free amortization calculator. Calculate monthly payments, visualize your principal and interest over time, and learn how to pay off debt faster.",
    "author": {
      "@type": "Organization",
      "name": "firemaths.info"
    },
    "publisher": {
      "@type": "Organization",
      "name": "firemaths.info"
    },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is an amortization schedule?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An amortization schedule is a complete table of periodic loan payments showing the amount of principal and the amount of interest that comprise each payment until the loan is paid off at the end of its term."
        }
      },
      {
        "@type": "Question",
        "name": "How is loan amortization calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Amortization is calculated using the loan principal, the interest rate, and the term of the loan. The formula determines a fixed monthly payment, where early payments cover mostly interest, and later payments cover mostly principal."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I make extra payments on an amortized loan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Making extra payments goes directly toward reducing the principal balance. This decreases the total interest paid over the life of the loan and shortens the loan term, saving you money in the long run."
        }
      },
      {
        "@type": "Question",
        "name": "Does an amortization schedule change if interest rates change?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For fixed-rate loans, the amortization schedule remains exactly the same throughout the loan term. For adjustable-rate mortgages (ARMs), the schedule will be recalculated each time the interest rate adjusts."
        }
      },
      {
        "@type": "Question",
        "name": "Can an amortization calculator help me pay off my mortgage faster?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. By using an amortization calculator to see how extra monthly payments reduce your principal, you can create a strategy to pay off your mortgage faster and see exactly how much interest you will save."
        }
      }
    ]
  }
]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <main class="page-container">
    <section class="hero-section">
      <div class="hero-content">
        <h1 class="hero-title">Amortization Calculator</h1>
        <p class="hero-subtitle">Visualize your loan payoff journey. See how every payment reduces your principal and how extra payments can save you thousands in interest.</p>
        <div class="hero-stats">
          <div class="stat-card">
            <span class="stat-value">100%</span>
            <span class="stat-label">Free to Use</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">Instant</span>
            <span class="stat-label">Calculations</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">Visual</span>
            <span class="stat-label">Schedule Chart</span>
          </div>
        </div>
        <a href="#calculator" class="cta-button">Calculate Your Loan Now</a>
      </div>
    </section>

    <section id="calculator" class="calculator-section">
      <div class="calculator-grid">
        <div class="input-panel card">
          <h2 class="panel-title">Loan Details</h2>

          <div class="input-group">
            <label for="loanAmount">Loan Amount ($)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="loanAmount" value="300000" min="0" step="1000">
            </div>
            <span class="error-msg" id="loanAmountError">Please enter a valid amount greater than 0.</span>
          </div>

          <div class="input-group">
            <label for="interestRate">Interest Rate (%)</label>
            <div class="input-wrapper">
              <input type="number" id="interestRate" value="6.5" min="0" max="100" step="0.1">
              <span class="suffix">%</span>
            </div>
            <span class="error-msg" id="interestRateError">Please enter a rate between 0 and 100.</span>
          </div>

          <div class="input-group">
            <label for="loanTerm">Loan Term (Years)</label>
            <div class="input-wrapper">
              <input type="number" id="loanTerm" value="30" min="1" max="50" step="1">
              <span class="suffix">Years</span>
            </div>
            <span class="error-msg" id="loanTermError">Please enter a term between 1 and 50 years.</span>
          </div>

          <div class="input-group">
            <label for="extraPayment">Extra Monthly Payment ($)</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="extraPayment" value="0" min="0" step="50">
            </div>
            <span class="help-text">Optional: See how extra payments speed up payoff.</span>
          </div>

          <button id="calculateBtn" class="calc-button">Calculate Amortization</button>
        </div>

        <div class="results-panel card">
          <h2 class="panel-title">Your Results</h2>

          <div class="results-summary">
            <div class="result-box primary-result">
              <span class="result-label">Monthly Payment</span>
              <span class="result-value" id="monthlyPaymentResult">$0.00</span>
            </div>
            <div class="result-box">
              <span class="result-label">Total Interest Paid</span>
              <span class="result-value" id="totalInterestResult">$0.00</span>
            </div>
            <div class="result-box">
              <span class="result-label">Total Cost of Loan</span>
              <span class="result-value" id="totalCostResult">$0.00</span>
            </div>
            <div class="result-box">
              <span class="result-label">Payoff Date</span>
              <span class="result-value" id="payoffDateResult">-</span>
            </div>
          </div>

          <div id="savingsAlert" class="savings-alert hidden">
            <span class="savings-icon">💡</span>
            <div class="savings-content">
              <h4>Extra Payment Impact</h4>
              <p>By paying an extra <strong id="extraPaymentAmount"></strong> per month, you will save <strong id="interestSaved"></strong> in interest and pay off your loan <strong id="yearsSaved"></strong> earlier!</p>
            </div>
          </div>

          <div class="chart-container">
            <h3 class="chart-title">Balance Over Time</h3>
            <div class="css-chart" id="balanceChart">
              <!-- Bars generated by JS -->
            </div>
            <div class="chart-legend">
              <span class="legend-item"><span class="legend-color balance-color"></span> Remaining Balance</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="schedule-section card">
      <div class="schedule-header">
        <h2 class="panel-title">Amortization Schedule (Yearly Summary)</h2>
        <button id="toggleScheduleBtn" class="secondary-button">Show Monthly Details</button>
      </div>
      <div class="table-container">
        <table class="amortization-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Payment</th>
              <th>Principal</th>
              <th>Interest</th>
              <th>Total Interest</th>
              <th>Balance</th>
            </tr>
          </thead>
          <tbody id="scheduleBody">
            <!-- Rows generated by JS -->
          </tbody>
        </table>
      </div>
    </section>

    <section class="educational-section">
      <h2 class="section-title">Understanding Loan Amortization</h2>
      <div class="cards-grid">
        <div class="edu-card">
          <div class="edu-icon">📈</div>
          <h3>What is Amortization?</h3>
          <p>Amortization is the process of spreading out a loan into a series of fixed payments over time. You'll pay the same amount every month, but the breakdown of what goes toward principal versus interest changes over the life of the loan.</p>
        </div>
        <div class="edu-card">
          <div class="edu-icon">⚖️</div>
          <h3>Principal vs. Interest</h3>
          <p>Early in your loan term, a large portion of your monthly payment goes toward paying interest. As you slowly pay down the principal balance, the interest charged decreases, meaning more of your payment goes toward principal in later years.</p>
        </div>
        <div class="edu-card">
          <div class="edu-icon">🚀</div>
          <h3>The Power of Extra Payments</h3>
          <p>Because interest is calculated on your remaining balance, making even small extra payments toward your principal early on can save you thousands of dollars in interest and shave years off your loan term.</p>
        </div>
        <div class="edu-card">
          <div class="edu-icon">📊</div>
          <h3>Why Use a Schedule?</h3>
          <p>An amortization schedule provides a clear roadmap of your debt payoff journey. It shows exactly how much you owe at any given point and helps you plan strategies for refinancing or early payoff.</p>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>What is an amortization schedule?</h3>
          <p>An amortization schedule is a complete table of periodic loan payments showing the amount of principal and the amount of interest that comprise each payment until the loan is paid off at the end of its term.</p>
        </div>
        <div class="faq-item">
          <h3>How is loan amortization calculated?</h3>
          <p>Amortization is calculated using the loan principal, the interest rate, and the term of the loan. The formula determines a fixed monthly payment, where early payments cover mostly interest, and later payments cover mostly principal.</p>
        </div>
        <div class="faq-item">
          <h3>What happens if I make extra payments on an amortized loan?</h3>
          <p>Making extra payments goes directly toward reducing the principal balance. This decreases the total interest paid over the life of the loan and shortens the loan term, saving you money in the long run.</p>
        </div>
        <div class="faq-item">
          <h3>Does an amortization schedule change if interest rates change?</h3>
          <p>For fixed-rate loans, the amortization schedule remains exactly the same throughout the loan term. For adjustable-rate mortgages (ARMs), the schedule will be recalculated each time the interest rate adjusts.</p>
        </div>
        <div class="faq-item">
          <h3>Can an amortization calculator help me pay off my mortgage faster?</h3>
          <p>Yes. By using an amortization calculator to see how extra monthly payments reduce your principal, you can create a strategy to pay off your mortgage faster and see exactly how much interest you will save.</p>
        </div>
      </div>
    </section>

    <section class="related-tools">
      <h2 class="section-title">Related Financial Tools</h2>
      <div class="tools-grid">
        <a href="/mortgage-calculator" class="tool-card">
          <h3>Mortgage Calculator</h3>
          <p>Calculate your monthly mortgage payments including taxes and insurance.</p>
        </a>
        <a href="/loan-amortization-calculator" class="tool-card">
          <h3>Loan Payoff Calculator</h3>
          <p>Determine exactly when you will be debt-free.</p>
        </a>
        <a href="/rent-vs-buy-calculator" class="tool-card">
          <h3>Rent vs. Buy Calculator</h3>
          <p>Decide whether renting or buying a home makes more financial sense.</p>
        </a>
        <a href="/debt-payoff-calculator" class="tool-card">
          <h3>Debt Snowball Calculator</h3>
          <p>Plan your strategy to eliminate multiple debts efficiently.</p>
        </a>
      </div>
    </section>
  </main>

  <style is:inline>
    .page-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
      font-family: system-ui, -apple-system, sans-serif;
      color: var(--text-primary);
    }

    /* Hero Section */
    .hero-section {
      text-align: center;
      padding: 4rem 1rem;
      background: var(--bg-primary);
      border-radius: 16px;
      margin-bottom: 3rem;
      border: 1px solid var(--border-color);
    }
    .hero-title {
      font-size: 3rem;
      font-weight: 800;
      margin-bottom: 1rem;
      color: var(--text-primary);
      line-height: 1.2;
    }
    .hero-subtitle {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 800px;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
    }
    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }
    .stat-card {
      background: var(--card-bg);
      padding: 1.5rem 2rem;
      border-radius: 12px;
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 150px;
    }
    .stat-value {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 0.5rem;
    }
    .stat-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .cta-button {
      display: inline-block;
      background: var(--accent-color);
      color: white;
      padding: 1rem 2.5rem;
      font-size: 1.125rem;
      font-weight: 600;
      border-radius: 8px;
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .cta-button:hover {
      opacity: 0.9;
    }

    /* General Layout */
    .card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
    }
    .section-title {
      font-size: 2rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 2.5rem;
      color: var(--text-primary);
    }
    .panel-title {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      color: var(--text-primary);
      border-bottom: 2px solid var(--bg-primary);
      padding-bottom: 0.5rem;
    }

    /* Calculator Grid */
    .calculator-section {
      margin-bottom: 3rem;
    }
    .calculator-grid {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 2rem;
    }
    @media (max-width: 900px) {
      .calculator-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Inputs */
    .input-group {
      margin-bottom: 1.5rem;
    }
    .input-group label {
      display: block;
      font-weight: 500;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }
    .input-wrapper {
      display: flex;
      align-items: center;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .input-wrapper:focus-within {
      border-color: var(--accent-color);
    }
    .prefix, .suffix {
      padding: 0.75rem 1rem;
      background: var(--bg-primary);
      color: var(--text-secondary);
      font-weight: 500;
    }
    .prefix { border-right: 1px solid var(--border-color); }
    .suffix { border-left: 1px solid var(--border-color); }
    input[type="number"] {
      flex: 1;
      border: none;
      padding: 0.75rem 1rem;
      font-size: 1rem;
      background: transparent;
      color: var(--text-primary);
      width: 100%;
      outline: none;
    }
    .help-text {
      display: block;
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 0.5rem;
    }
    .error-msg {
      display: none;
      color: #ef4444;
      font-size: 0.875rem;
      margin-top: 0.5rem;
    }
    .input-group.invalid .error-msg {
      display: block;
    }
    .input-group.invalid .input-wrapper {
      border-color: #ef4444;
    }
    .calc-button {
      width: 100%;
      background: var(--accent-color);
      color: white;
      border: none;
      padding: 1rem;
      font-size: 1.125rem;
      font-weight: 600;
      border-radius: 8px;
      cursor: pointer;
      transition: opacity 0.2s;
      margin-top: 1rem;
    }
    .calc-button:hover {
      opacity: 0.9;
    }

    /* Results */
    .results-summary {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    @media (max-width: 600px) {
      .results-summary {
        grid-template-columns: 1fr;
      }
    }
    .result-box {
      background: var(--bg-primary);
      padding: 1.5rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
    }
    .primary-result {
      grid-column: 1 / -1;
      background: rgba(var(--accent-color-rgb, 59, 130, 246), 0.1);
      border-color: var(--accent-color);
    }
    .result-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .result-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
    }
    .primary-result .result-value {
      font-size: 2.5rem;
      color: var(--accent-color);
    }

    /* Savings Alert */
    .savings-alert {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      background: #ecfdf5;
      border: 1px solid #10b981;
      padding: 1rem 1.5rem;
      border-radius: 8px;
      margin-bottom: 2rem;
    }
    .savings-alert.hidden {
      display: none;
    }
    .savings-icon {
      font-size: 1.5rem;
    }
    .savings-content h4 {
      margin: 0 0 0.5rem;
      color: #065f46;
      font-size: 1rem;
    }
    .savings-content p {
      margin: 0;
      color: #064e3b;
      font-size: 0.95rem;
      line-height: 1.5;
    }

    /* Chart */
    .chart-container {
      margin-top: 2rem;
    }
    .chart-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      text-align: center;
    }
    .css-chart {
      height: 250px;
      display: flex;
      align-items: flex-end;
      gap: 2px;
      padding-top: 20px;
      border-bottom: 2px solid var(--border-color);
      border-left: 2px solid var(--border-color);
      position: relative;
    }
    .chart-bar {
      flex: 1;
      background: var(--accent-color);
      border-radius: 2px 2px 0 0;
      transition: height 0.5s ease;
      position: relative;
    }
    .chart-bar:hover::after {
      content: attr(data-tooltip);
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%);
      background: var(--card-bg);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      white-space: nowrap;
      z-index: 10;
      margin-bottom: 5px;
      pointer-events: none;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .chart-legend {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-top: 1rem;
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-secondary);
    }
    .legend-color {
      width: 12px;
      height: 12px;
      border-radius: 2px;
    }
    .balance-color { background: var(--accent-color); }

    /* Schedule Table */
    .schedule-section {
      margin-bottom: 4rem;
    }
    .schedule-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .schedule-header .panel-title {
      margin-bottom: 0;
      border-bottom: none;
      padding-bottom: 0;
    }
    .secondary-button {
      background: transparent;
      border: 1px solid var(--accent-color);
      color: var(--accent-color);
      padding: 0.5rem 1rem;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s;
    }
    .secondary-button:hover {
      background: var(--accent-color);
      color: white;
    }
    .table-container {
      overflow-x: auto;
    }
    .amortization-table {
      width: 100%;
      border-collapse: collapse;
      text-align: right;
    }
    .amortization-table th, .amortization-table td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-color);
    }
    .amortization-table th {
      text-align: right;
      font-weight: 600;
      color: var(--text-secondary);
      background: var(--bg-primary);
      position: sticky;
      top: 0;
    }
    .amortization-table th:first-child, .amortization-table td:first-child {
      text-align: left;
    }
    .amortization-table tr:hover td {
      background: var(--bg-primary);
    }
    .monthly-row {
      display: none;
      background: rgba(var(--bg-primary-rgb, 0,0,0), 0.02);
      font-size: 0.9em;
    }
    .monthly-row td {
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
      color: var(--text-secondary);
    }
    .monthly-row.visible {
      display: table-row;
    }
    .yearly-row td {
      font-weight: 500;
    }

    /* Educational Sections */
    .educational-section {
      margin-bottom: 4rem;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }
    .edu-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
    }
    .edu-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .edu-card h3 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }
    .edu-card p {
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* FAQ */
    .faq-section {
      margin-bottom: 4rem;
    }
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
    }
    .faq-item h3 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }
    .faq-item p {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    /* Related Tools */
    .related-tools {
      margin-bottom: 2rem;
    }
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }
    .tool-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      text-decoration: none;
      transition: transform 0.2s, border-color 0.2s;
    }
    .tool-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }
    .tool-card h3 {
      color: var(--accent-color);
      margin-bottom: 0.5rem;
      font-size: 1.125rem;
    }
    .tool-card p {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
      margin: 0;
    }

    /* Utility */
    .hidden { display: none !important; }
  </style>

  <script is:inline>
    // Utility functions for formatting
    const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
    const formatDate = (date) => {
      const d = new Date(date);
      return new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(d);
    };

    document.addEventListener('DOMContentLoaded', () => {
      // DOM Elements
      const inputs = {
        amount: document.getElementById('loanAmount'),
        rate: document.getElementById('interestRate'),
        term: document.getElementById('loanTerm'),
        extra: document.getElementById('extraPayment')
      };

      const errors = {
        amount: document.getElementById('loanAmountError'),
        rate: document.getElementById('interestRateError'),
        term: document.getElementById('loanTermError')
      };

      const results = {
        monthly: document.getElementById('monthlyPaymentResult'),
        totalInterest: document.getElementById('totalInterestResult'),
        totalCost: document.getElementById('totalCostResult'),
        payoffDate: document.getElementById('payoffDateResult')
      };

      const savingsAlert = document.getElementById('savingsAlert');
      const extraAmtSpan = document.getElementById('extraPaymentAmount');
      const intSavedSpan = document.getElementById('interestSaved');
      const yearsSavedSpan = document.getElementById('yearsSaved');

      const calcBtn = document.getElementById('calculateBtn');
      const chartContainer = document.getElementById('balanceChart');
      const scheduleBody = document.getElementById('scheduleBody');
      const toggleScheduleBtn = document.getElementById('toggleScheduleBtn');

      let currentSchedule = [];
      let isMonthlyView = false;

      // Validation
      function validateInputs() {
        let isValid = true;

        const amount = parseFloat(inputs.amount.value);
        if (isNaN(amount) || amount <= 0) {
          inputs.amount.closest('.input-group').classList.add('invalid');
          isValid = false;
        } else {
          inputs.amount.closest('.input-group').classList.remove('invalid');
        }

        const rate = parseFloat(inputs.rate.value);
        if (isNaN(rate) || rate < 0 || rate > 100) {
          inputs.rate.closest('.input-group').classList.add('invalid');
          isValid = false;
        } else {
          inputs.rate.closest('.input-group').classList.remove('invalid');
        }

        const term = parseFloat(inputs.term.value);
        if (isNaN(term) || term < 1 || term > 50 || !Number.isInteger(term)) {
          inputs.term.closest('.input-group').classList.add('invalid');
          isValid = false;
        } else {
          inputs.term.closest('.input-group').classList.remove('invalid');
        }

        return isValid;
      }

      // Core Calculation Engine
      function generateAmortizationSchedule(principal, annualRate, years, extraMonthly) {
        const monthlyRate = (annualRate / 100) / 12;
        const totalMonths = years * 12;

        // Base monthly payment calculation
        let basePayment = 0;
        if (monthlyRate === 0) {
          basePayment = principal / totalMonths;
        } else {
          basePayment = principal * (monthlyRate * Math.pow(1 + monthlyRate, totalMonths)) / (Math.pow(1 + monthlyRate, totalMonths) - 1);
        }

        const actualPayment = basePayment + extraMonthly;

        let balance = principal;
        let totalInterestPaid = 0;
        let schedule = [];
        let monthCount = 0;

        const startDate = new Date();
        // Move to next month
        startDate.setMonth(startDate.getMonth() + 1);

        while (balance > 0.01 && monthCount < totalMonths * 2) { // Prevent infinite loop
          monthCount++;

          let interestForMonth = balance * monthlyRate;
          let principalForMonth = actualPayment - interestForMonth;

          // Final payment check
          if (balance < principalForMonth) {
            principalForMonth = balance;
            // Payment might be less than regular actualPayment
          }

          totalInterestPaid += interestForMonth;
          balance -= principalForMonth;

          if (balance < 0) balance = 0;

          const paymentDate = new Date(startDate);
          paymentDate.setMonth(startDate.getMonth() + (monthCount - 1));

          schedule.push({
            month: monthCount,
            date: paymentDate,
            payment: principalForMonth + interestForMonth,
            principal: principalForMonth,
            interest: interestForMonth,
            totalInterest: totalInterestPaid,
            balance: balance
          });
        }

        return {
          basePayment: basePayment,
          totalMonths: monthCount,
          totalInterest: totalInterestPaid,
          schedule: schedule
        };
      }

      // Update UI
      function updateUI() {
        if (!validateInputs()) return;

        const principal = parseFloat(inputs.amount.value);
        const rate = parseFloat(inputs.rate.value);
        const term = parseFloat(inputs.term.value);
        const extra = parseFloat(inputs.extra.value) || 0;

        // Calculate baseline (no extra)
        const baseline = generateAmortizationSchedule(principal, rate, term, 0);
        // Calculate actual
        const actual = generateAmortizationSchedule(principal, rate, term, extra);

        currentSchedule = actual.schedule;

        // Update Summary Cards
        results.monthly.textContent = formatCurrency(actual.basePayment); // Show required payment
        results.totalInterest.textContent = formatCurrency(actual.totalInterest);
        results.totalCost.textContent = formatCurrency(principal + actual.totalInterest);

        if (actual.schedule.length > 0) {
          const lastPayment = actual.schedule[actual.schedule.length - 1];
          results.payoffDate.textContent = formatDate(lastPayment.date);
        }

        // Savings Alert
        if (extra > 0) {
          const intSaved = baseline.totalInterest - actual.totalInterest;
          const monthsSaved = baseline.totalMonths - actual.totalMonths;

          if (intSaved > 0 || monthsSaved > 0) {
            extraAmtSpan.textContent = formatCurrency(extra);
            intSavedSpan.textContent = formatCurrency(intSaved);

            let timeSavedText = "";
            const yearsSaved = Math.floor(monthsSaved / 12);
            const rMonths = monthsSaved % 12;
            if (yearsSaved > 0) timeSavedText += `${yearsSaved} year${yearsSaved !== 1 ? 's' : ''}`;
            if (yearsSaved > 0 && rMonths > 0) timeSavedText += " and ";
            if (rMonths > 0) timeSavedText += `${rMonths} month${rMonths !== 1 ? 's' : ''}`;
            if (timeSavedText === "") timeSavedText = "0 months"; // fallback

            yearsSavedSpan.textContent = timeSavedText;
            savingsAlert.classList.remove('hidden');
          } else {
            savingsAlert.classList.add('hidden');
          }
        } else {
          savingsAlert.classList.add('hidden');
        }

        renderChart(actual.schedule, principal);
        renderTable(actual.schedule);
      }

      // Render CSS Chart
      function renderChart(schedule, initialPrincipal) {
        chartContainer.innerHTML = '';

        if (schedule.length === 0) return;

        // Group by year for charting to avoid too many bars
        const yearlyBalances = [];
        for (let i = 0; i < schedule.length; i += 12) {
          // Take the balance at the end of the year (or last payment)
          let idx = Math.min(i + 11, schedule.length - 1);
          yearlyBalances.push({
            year: Math.floor(i/12) + 1,
            balance: schedule[idx].balance
          });
        }

        // Ensure initial state is represented implicitly or explicitly
        // CSS chart will render bars based on percentage of max
        const maxBalance = initialPrincipal;

        yearlyBalances.forEach((yr, index) => {
          const bar = document.createElement('div');
          bar.className = 'chart-bar';
          const heightPct = (yr.balance / maxBalance) * 100;
          bar.style.height = `${heightPct}%`;
          bar.setAttribute('data-tooltip', `Year ${yr.year}: ${formatCurrency(yr.balance)}`);
          chartContainer.appendChild(bar);
        });
      }

      // Render Table
      function renderTable(schedule) {
        scheduleBody.innerHTML = '';
        if (schedule.length === 0) return;

        let currentYear = 1;
        let yearPrincipal = 0;
        let yearInterest = 0;
        let yearPayment = 0;
        let yearRows = [];

        schedule.forEach((pmt, index) => {
          yearPrincipal += pmt.principal;
          yearInterest += pmt.interest;
          yearPayment += pmt.payment;

          yearRows.push(pmt);

          // End of year or end of loan
          if ((index + 1) % 12 === 0 || index === schedule.length - 1) {
            // Add Year Row
            const trYear = document.createElement('tr');
            trYear.className = 'yearly-row';
            trYear.innerHTML = `
              <td>Year ${currentYear}</td>
              <td>${formatCurrency(yearPayment)}</td>
              <td>${formatCurrency(yearPrincipal)}</td>
              <td>${formatCurrency(yearInterest)}</td>
              <td>${formatCurrency(pmt.totalInterest)}</td>
              <td>${formatCurrency(pmt.balance)}</td>
            `;
            scheduleBody.appendChild(trYear);

            // Add Monthly Rows for this year
            yearRows.forEach((mPmt) => {
              const trMonth = document.createElement('tr');
              trMonth.className = `monthly-row ${isMonthlyView ? 'visible' : ''}`;
              trMonth.innerHTML = `
                <td style="padding-left: 2rem;">${formatDate(mPmt.date)}</td>
                <td>${formatCurrency(mPmt.payment)}</td>
                <td>${formatCurrency(mPmt.principal)}</td>
                <td>${formatCurrency(mPmt.interest)}</td>
                <td>${formatCurrency(mPmt.totalInterest)}</td>
                <td>${formatCurrency(mPmt.balance)}</td>
              `;
              scheduleBody.appendChild(trMonth);
            });

            // Reset for next year
            currentYear++;
            yearPrincipal = 0;
            yearInterest = 0;
            yearPayment = 0;
            yearRows = [];
          }
        });
      }

      // Event Listeners
      calcBtn.addEventListener('click', updateUI);

      toggleScheduleBtn.addEventListener('click', () => {
        isMonthlyView = !isMonthlyView;
        toggleScheduleBtn.textContent = isMonthlyView ? 'Hide Monthly Details' : 'Show Monthly Details';
        const monthlyRows = document.querySelectorAll('.monthly-row');
        monthlyRows.forEach(row => {
          if (isMonthlyView) {
            row.classList.add('visible');
          } else {
            row.classList.remove('visible');
          }
        });
      });

      // Auto-calculate on load
      updateUI();
    });
  </script>
</SiteLayout>
