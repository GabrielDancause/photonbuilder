---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Tax-Loss Harvesting Tool",
  "description": "Calculate potential tax savings from harvesting capital losses and understand the wash sale rules.",
  "author": {
    "@type": "Organization",
    "name": "FireMaths"
  },
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is tax-loss harvesting?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tax-loss harvesting is the practice of selling an investment that has lost value, replacing it with a reasonably similar investment, and then using the investment loss to offset realized gains or ordinary income."
        }
      },
      {
        "@type": "Question",
        "name": "What is the wash sale rule?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The wash sale rule prohibits you from claiming a tax loss if you buy a 'substantially identical' security within 30 days before or after the sale. If you violate this rule, the loss is disallowed and added to the cost basis of the new security."
        }
      },
      {
        "@type": "Question",
        "name": "How much ordinary income can I offset with capital losses?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can offset up to $3,000 of ordinary income per year ($1,500 if married filing separately). Any remaining losses are carried forward indefinitely to future tax years."
        }
      }
    ]
  }
};

export const meta = {
  title: "Tax-Loss Harvesting Tool",
  description: "Calculate your potential tax savings from harvesting investment losses. Enter your gains, losses, and tax bracket to see how much you could save.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="firemaths"
  title="Tax-Loss Harvesting Tool"
  description="Calculate your potential tax savings from harvesting investment losses."
  canonical="https://firemaths.info/tax-loss-harvesting-tool"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Tax-Loss Harvesting Tool</h1>
      <p>Turn market downturns into tax savings.</p>
    </div>

    <div class="card">
      <h2>Calculate Tax Savings</h2>
      <p>Estimate the immediate tax savings of realizing a loss.</p>

      <div class="calculator-form">
        <div class="input-group">
          <label for="capitalLoss">Total Unrealized Capital Losses</label>
          <div class="input-prefix">
            <span>$</span>
            <input type="number" id="capitalLoss" value="5000" min="0" step="1000" />
          </div>
        </div>

        <div class="input-group">
          <label for="capitalGains">Current Year Capital Gains to Offset</label>
          <div class="input-prefix">
            <span>$</span>
            <input type="number" id="capitalGains" value="1000" min="0" step="1000" />
          </div>
        </div>

        <div class="input-group">
          <label for="marginalRate">Your Marginal Tax Rate (on Ordinary Income)</label>
          <div class="input-prefix">
            <span>%</span>
            <input type="number" id="marginalRate" value="24" min="0" max="37" step="1" />
          </div>
        </div>

        <div class="input-group">
          <label for="gainsRate">Your Capital Gains Tax Rate</label>
          <select id="gainsRate">
            <option value="0">0%</option>
            <option value="15" selected>15%</option>
            <option value="20">20%</option>
          </select>
        </div>

        <button id="calcBtn" class="calc-btn">Calculate Savings</button>
      </div>

      <div class="results" id="results" style="display:none;">
        <div style="background: rgba(255,255,255,0.05); padding: 1.5rem; border-radius: 8px; border-left: 4px solid var(--accent-color);">
          <h3 style="margin-top: 0">Estimated First-Year Tax Savings: <span id="taxSavings" style="color:var(--accent-color)">$0</span></h3>
          <p id="savingsBreakdown" style="color:var(--text-secondary); margin-bottom: 0;">You offset $0 in capital gains and $0 in ordinary income.</p>
          <p id="carryForward" style="color:var(--text-secondary); margin-top: 0.5rem; font-weight: bold;"></p>
        </div>
      </div>
    </div>

    <div class="card content-section">
      <h2>The Mathematics of Tax-Loss Harvesting</h2>
      <p>As detailed in our <a href="/tax-optimization-fire-guide">Tax Optimization FIRE Guide</a>, tax-loss harvesting allows you to generate a "tax alpha" by turning market volatility into tangible cash flow via tax savings.</p>

      <h3>The Order of Operations</h3>
      <ol>
        <li>Losses first offset gains of the same type (short-term vs. short-term, long-term vs. long-term).</li>
        <li>Excess losses then offset gains of the opposite type.</li>
        <li>If net losses remain, up to $3,000 offsets ordinary income (your highest marginal rate).</li>
        <li>Any remaining losses carry forward to future years indefinitely.</li>
      </ol>

      <h3>Navigating the Wash Sale Rule</h3>
      <p>The IRS requires you to wait 30 days before buying a "substantially identical" security. If you don't, the loss is disallowed. For index investors, a common strategy is swapping between two different but highly correlated funds, such as switching from an S&P 500 fund to a Total US Stock Market fund. The performance will be nearly identical, but the IRS views them as different securities.</p>

      <h3>Robo-Advisors</h3>
      <p>Many robo-advisors offer automated daily tax-loss harvesting. While this sounds great in theory, remember that automated harvesting across hundreds of micro-lots can make your tax return extremely complicated and lock you into their platform.</p>
    </div>
  </div>

  <script is:inline>
    document.getElementById('calcBtn').addEventListener('click', function() {
      const losses = parseFloat(document.getElementById('capitalLoss').value) || 0;
      const gains = parseFloat(document.getElementById('capitalGains').value) || 0;
      const marginalRate = parseFloat(document.getElementById('marginalRate').value) / 100 || 0;
      const gainsRate = parseFloat(document.getElementById('gainsRate').value) / 100 || 0;

      let savingsFromGains = 0;
      let savingsFromOrdinary = 0;
      let carryForwardLosses = 0;

      // Step 1: Offset gains
      const offsetGains = Math.min(losses, gains);
      savingsFromGains = offsetGains * gainsRate;

      let remainingLosses = losses - offsetGains;

      // Step 2: Offset ordinary income (up to $3,000 max)
      let offsetOrdinary = 0;
      if (remainingLosses > 0) {
        offsetOrdinary = Math.min(remainingLosses, 3000);
        savingsFromOrdinary = offsetOrdinary * marginalRate;
        remainingLosses -= offsetOrdinary;
      }

      // Step 3: Carry forward
      carryForwardLosses = remainingLosses;

      const totalSavings = savingsFromGains + savingsFromOrdinary;

      document.getElementById('taxSavings').innerText = '$' + totalSavings.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});

      document.getElementById('savingsBreakdown').innerText = `You offset $${offsetGains.toLocaleString()} in capital gains (saving $${savingsFromGains.toLocaleString()}) and $${offsetOrdinary.toLocaleString()} in ordinary income (saving $${savingsFromOrdinary.toLocaleString()}).`;

      if (carryForwardLosses > 0) {
        document.getElementById('carryForward').innerText = `You also generate $${carryForwardLosses.toLocaleString()} in carry-forward losses for future years!`;
      } else {
        document.getElementById('carryForward').innerText = "";
      }

      document.getElementById('results').style.display = 'block';
    });
  </script>

