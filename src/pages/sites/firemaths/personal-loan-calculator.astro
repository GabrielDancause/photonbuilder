<section class="related-links">
      <h2>Explore Other Calculators</h2>
      <div class="links-grid">
        <a href="/debt-payoff-calculator">Debt Payoff Calculator</a>
        <a href="/credit-card-payoff-calculator">Credit Card Payoff</a>
        <a href="/auto-loan-calculator">Auto Loan Calculator</a>
        <a href="/budget-calculator">Budget Calculator</a>
      </div>
    </section>
  </div>

    <script is:inline>
    // Format currency
    const formatCurrency = (value) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value);
    };

    // Calculate loan details
    const calculateLoan = (principal, ratePercent, months) => {
      const monthlyRate = (ratePercent / 100) / 12;
      let monthlyPayment = 0;
      let totalCost = 0;
      let totalInterest = 0;

      if (monthlyRate === 0) {
        monthlyPayment = principal / months;
        totalCost = principal;
      } else {
        monthlyPayment = principal * (monthlyRate * Math.pow(1 + monthlyRate, months)) / (Math.pow(1 + monthlyRate, months) - 1);
        totalCost = monthlyPayment * months;
        totalInterest = totalCost - principal;
      }

      return {
        monthlyPayment: isNaN(monthlyPayment) || !isFinite(monthlyPayment) ? 0 : monthlyPayment,
        totalInterest: isNaN(totalInterest) || totalInterest < 0 ? 0 : totalInterest,
        totalCost: isNaN(totalCost) || totalCost < 0 ? 0 : totalCost
      };
    };

    // Validation Logic
    const validateInput = (input, min, max) => {
      const val = parseFloat(input.value);
      const group = input.closest('.input-group');
      if (isNaN(val) || val < min || val > max) {
        group.classList.add('error');
        input.classList.add('input-error');
        return false;
      }
      group.classList.remove('error');
      input.classList.remove('input-error');
      return true;
    };

    const updateAmortizationTable = (principal, ratePercent, months, viewType = 'yearly') => {
      const tbody = document.getElementById('amortizationTableBody');
      tbody.innerHTML = '';

      const { monthlyPayment } = calculateLoan(principal, ratePercent, months);
      const monthlyRate = (ratePercent / 100) / 12;

      let balance = principal;
      let totalInterestToDate = 0;
      let totalPrincipalToDate = 0;

      let yearlyInterest = 0;
      let yearlyPrincipal = 0;
      let currentYear = 1;

      if (principal > 0 && months > 0) {
        for (let i = 1; i <= months; i++) {
          let interestPayment = balance * monthlyRate;
          let principalPayment = monthlyPayment - interestPayment;

          if (i === months) {
            principalPayment = balance;
            interestPayment = (monthlyPayment * months) - principal - totalInterestToDate;
            if (interestPayment < 0) interestPayment = 0;
          }

          balance -= principalPayment;
          if (balance < 0) balance = 0;

          yearlyInterest += interestPayment;
          yearlyPrincipal += principalPayment;
          totalInterestToDate += interestPayment;
          totalPrincipalToDate += principalPayment;

          if (viewType === 'monthly') {
            const tr = document.createElement('tr');
            tr.innerHTML = `
              <td>Month ${i}</td>
              <td>${formatCurrency(interestPayment)}</td>
              <td>${formatCurrency(principalPayment)}</td>
              <td>${formatCurrency(balance)}</td>
            `;
            tbody.appendChild(tr);

            if (i % 12 === 0 && i !== months) {
              const yearRow = document.createElement('tr');
              yearRow.className = 'year-row';
              yearRow.innerHTML = `
                <td>Year ${i/12} Total</td>
                <td>${formatCurrency(yearlyInterest)}</td>
                <td>${formatCurrency(yearlyPrincipal)}</td>
                <td>${formatCurrency(balance)}</td>
              `;
              tbody.appendChild(yearRow);
              yearlyInterest = 0;
              yearlyPrincipal = 0;
            }
          } else {
            if (i % 12 === 0 || i === months) {
              const tr = document.createElement('tr');
              tr.innerHTML = `
                <td>Year ${currentYear}</td>
                <td>${formatCurrency(yearlyInterest)}</td>
                <td>${formatCurrency(yearlyPrincipal)}</td>
                <td>${formatCurrency(balance)}</td>
              `;
              tbody.appendChild(tr);
              yearlyInterest = 0;
              yearlyPrincipal = 0;
              currentYear++;
            }
          }
        }
      }
    };

    let currentAmortizationView = 'yearly';

    const updateUI = () => {
      const pInput = document.getElementById('loanAmount');
      const rInput = document.getElementById('interestRate');
      const mInput = document.getElementById('loanTerm');

      const isPValid = validateInput(pInput, 100, 1000000);
      const isRValid = validateInput(rInput, 0, 100);
      const isMValid = validateInput(mInput, 1, 600);

      if (!isPValid || !isRValid || !isMValid) return;

      const p = parseFloat(pInput.value);
      const r = parseFloat(rInput.value);
      const m = parseInt(mInput.value);

      const { monthlyPayment, totalInterest, totalCost } = calculateLoan(p, r, m);

      document.getElementById('monthlyPayment').textContent = formatCurrency(monthlyPayment);
      document.getElementById('totalInterest').textContent = formatCurrency(totalInterest);
      document.getElementById('totalCost').textContent = formatCurrency(totalCost);

      const pPct = totalCost > 0 ? (p / totalCost) * 100 : 100;
      const iPct = totalCost > 0 ? (totalInterest / totalCost) * 100 : 0;

      document.getElementById('barPrincipal').style.width = pPct + '%';
      document.getElementById('barInterest').style.width = iPct + '%';

      const scenarioGrid = document.getElementById('scenarioGrid');
      if (scenarioGrid) {
        scenarioGrid.innerHTML = '';
        const scenarios = [
          { name: 'Aggressive Payoff', term: Math.max(12, Math.floor(m * 0.5)) },
          { name: 'Current Schedule', term: m },
          { name: 'Extended Term', term: Math.floor(m * 1.5) },
          { name: 'Maximum Term', term: Math.floor(m * 2) }
        ];

        scenarios.forEach(scen => {
          if (scen.term > 120 && scen.name !== 'Current Schedule') return;
          const res = calculateLoan(p, r, scen.term);
          const div = document.createElement('div');
          div.className = 'scenario-card';
          const savings = totalInterest - res.totalInterest;
          let savingsHtml = '';
          if (savings > 0) {
            savingsHtml = `<div style="color: #10b981; font-size: 0.85rem; font-weight: 600; margin-top: 0.5rem;">Saves ${formatCurrency(savings)} in interest</div>`;
          } else if (savings < 0) {
            savingsHtml = `<div style="color: #ef4444; font-size: 0.85rem; font-weight: 600; margin-top: 0.5rem;">Costs ${formatCurrency(Math.abs(savings))} more in interest</div>`;
          } else {
            savingsHtml = `<div style="color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; margin-top: 0.5rem;">Baseline</div>`;
          }

          div.innerHTML = `
            <div class="scenario-title">${scen.name} (${scen.term} mo)</div>
            <div class="scenario-payment">${formatCurrency(res.monthlyPayment)}/mo</div>
            <div class="scenario-detail">Total Interest: ${formatCurrency(res.totalInterest)}</div>
            ${savingsHtml}
          `;
          scenarioGrid.appendChild(div);
        });
      }

      updateAmortizationTable(p, r, m, currentAmortizationView);
    };

    // Amortization View Toggles
    const setupAmortizationToggles = () => {
      const container = document.querySelector('.table-section h2');
      if (!container) return;
      const controls = document.createElement('div');
      controls.className = 'amortization-controls';
      controls.innerHTML = `
        <span style="color: var(--text-secondary); font-size: 0.9rem;">View by:</span>
        <button id="btnYearly" class="active">Yearly</button>
        <button id="btnMonthly">Monthly</button>
      `;
      container.parentNode.insertBefore(controls, container.nextSibling);

      document.getElementById('btnYearly').addEventListener('click', () => {
        currentAmortizationView = 'yearly';
        document.getElementById('btnYearly').classList.add('active');
        document.getElementById('btnMonthly').classList.remove('active');
        updateUI();
      });

      document.getElementById('btnMonthly').addEventListener('click', () => {
        currentAmortizationView = 'monthly';
        document.getElementById('btnMonthly').classList.add('active');
        document.getElementById('btnYearly').classList.remove('active');
        updateUI();
      });
    };

    // Setup input listeners
    const setupInputListeners = () => {
      const pairs = [
        { id: 'loanAmount', slider: 'loanAmountSlider' },
        { id: 'interestRate', slider: 'interestRateSlider' },
        { id: 'loanTerm', slider: 'loanTermSlider' }
      ];

      pairs.forEach(pair => {
        const input = document.getElementById(pair.id);
        const slider = document.getElementById(pair.slider);

        if (!input || !slider) return;

        input.addEventListener('input', (e) => {
          let val = parseFloat(e.target.value);
          if (pair.id === 'interestRate' && val > 36) val = 36;
          if (pair.id === 'loanTerm' && val > 120) val = 120;
          slider.value = val;
          updateUI();
        });

        slider.addEventListener('input', (e) => {
          input.value = e.target.value;
          updateUI();
        });
      });
    };

    document.addEventListener('DOMContentLoaded', () => {
      setupAmortizationToggles();
      setupInputListeners();
      updateUI();
    });
  </script>
</SiteLayout>
