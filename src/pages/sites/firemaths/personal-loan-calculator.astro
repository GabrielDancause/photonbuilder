---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Personal Loan Calculator | Firemaths',
  description: 'Calculate your personal loan monthly payments, total interest, and overall costs with our interactive personal loan calculator. Compare terms instantly.',
  category: 'tool',
  keywords: ['personal loan calculator', 'loan payment calculator', 'personal loan interest calculator', 'loan amortization calculator', 'monthly payment calculator']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "firemaths.info" },
    "publisher": { "@type": "Organization", "name": "firemaths.info" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is a personal loan monthly payment calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A personal loan payment is calculated using an amortization formula that accounts for your loan amount, interest rate, and term length. The formula ensures that your monthly payment remains the same, but the portion going toward principal and interest changes over time."
        }
      },
      {
        "@type": "Question",
        "name": "What is a good interest rate for a personal loan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good interest rate on a personal loan depends heavily on your credit score. Generally, borrowers with excellent credit (720+) can secure rates between 6% and 10%. Average credit scores might see rates from 12% to 18%, while poor credit can result in rates exceeding 25%."
        }
      },
      {
        "@type": "Question",
        "name": "Should I choose a longer or shorter personal loan term?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Shorter loan terms (e.g., 2-3 years) typically have higher monthly payments but cost much less in total interest. Longer terms (e.g., 5-7 years) lower your monthly payment but increase the total interest paid over the life of the loan. Choose the shortest term with a monthly payment you can comfortably afford."
        }
      },
      {
        "@type": "Question",
        "name": "Does applying for a personal loan hurt my credit score?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "When you apply for a personal loan, lenders usually perform a hard credit inquiry, which can temporarily lower your credit score by a few points. However, making consistent on-time payments can ultimately improve your credit score by building a positive payment history."
        }
      },
      {
        "@type": "Question",
        "name": "Can I pay off my personal loan early?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most personal loans allow you to pay off the balance early, which can save you a significant amount in interest. However, you should always check your loan agreement for a 'prepayment penalty,' which is a fee some lenders charge if you pay the loan off before the term ends."
        }
      }
    ]
  }
]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description} canonical="https://firemaths.info/personal-loan-calculator">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <style is:inline>
    .calculator-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero-section {
      text-align: center;
      margin-bottom: 3rem;
      padding: 3rem 1rem;
      background: var(--card-bg);
      border-radius: 16px;
      border: 1px solid var(--border-color);
    }

    .hero-section h1 {
      font-size: 2.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }

    .hero-section p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 1.5rem;
    }

    .main-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    @media (max-width: 768px) {
      .main-grid {
        grid-template-columns: 1fr;
      }
    }

    .input-panel {
      background: var(--card-bg);
      padding: 2rem;
      border-radius: 16px;
      border: 1px solid var(--border-color);
    }

    .input-group {
      margin-bottom: 1.5rem;
    }

    .input-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: var(--text-primary);
    }

    .input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }

    .prefix, .suffix {
      position: absolute;
      color: var(--text-secondary);
      padding: 0 1rem;
      pointer-events: none;
    }

    .prefix { left: 0; }
    .suffix { right: 0; }

    input[type="number"] {
      width: 100%;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.75rem 1rem;
      border-radius: 8px;
      font-size: 1.1rem;
      transition: border-color 0.2s;
      -moz-appearance: textfield;
    }

    input.has-prefix { padding-left: 2rem; }
    input.has-suffix { padding-right: 2.5rem; }

    input[type="number"]::-webkit-outer-spin-button,
    input[type="number"]::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }

    input[type="number"]:focus {
      outline: none;
      border-color: var(--accent-color);
    }

    .range-slider {
      width: 100%;
      margin-top: 1rem;
      accent-color: var(--accent-color);
    }

    .results-panel {
      background: var(--card-bg);
      padding: 2rem;
      border-radius: 16px;
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
    }

    .primary-result {
      text-align: center;
      margin-bottom: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border-color);
    }

    .primary-result-label {
      color: var(--text-secondary);
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
    }

    .primary-result-value {
      font-size: 3.5rem;
      font-weight: 700;
      color: var(--accent-color);
      line-height: 1;
    }

    .secondary-results {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .result-item {
      text-align: center;
      padding: 1rem;
      background: var(--bg-primary);
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .result-label {
      color: var(--text-secondary);
      font-size: 0.9rem;
      margin-bottom: 0.25rem;
    }

    .result-value {
      color: var(--text-primary);
      font-size: 1.5rem;
      font-weight: 600;
    }

    /* CSS Chart */
    .chart-container {
      margin-top: auto;
      padding-top: 1rem;
    }

    .bar-chart {
      height: 30px;
      width: 100%;
      display: flex;
      border-radius: 15px;
      overflow: hidden;
      margin-bottom: 1rem;
    }

    .bar-principal {
      background-color: var(--accent-color);
      transition: width 0.3s ease;
    }

    .bar-interest {
      background-color: #ef4444;
      transition: width 0.3s ease;
    }

    .chart-legend {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .dot.principal { background-color: var(--accent-color); }
    .dot.interest { background-color: #ef4444; }

    /* Scenario Comparison */
    .scenario-section {
      margin-bottom: 3rem;
    }

    .scenario-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .scenario-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }

    .scenario-title {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }

    .scenario-payment {
      font-size: 2rem;
      color: var(--accent-color);
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .scenario-detail {
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    /* Amortization Table */
    .table-section {
      margin-bottom: 3rem;
    }

    .table-wrapper {
      overflow-x: auto;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: right;
    }

    th, td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: rgba(0,0,0,0.2);
      color: var(--text-primary);
      font-weight: 600;
      position: sticky;
      top: 0;
    }

    th:first-child, td:first-child { text-align: center; }

    tr:last-child td { border-bottom: none; }

    .educational-section {
      margin-bottom: 3rem;
    }

    .edu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .edu-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .edu-card h3 {
      color: var(--accent-color);
      margin-bottom: 1rem;
    }

    .edu-card p {
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* FAQ */
    .faq-section {
      margin-bottom: 3rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-item h3 {
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .faq-item p {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    .related-links {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
    }

    .related-links h2 {
      margin-bottom: 1rem;
      color: var(--text-primary);
    }

    .links-grid {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .links-grid a {
      color: var(--accent-color);
      text-decoration: none;
      padding: 0.5rem 1rem;
      border: 1px solid var(--accent-color);
      border-radius: 8px;
      transition: all 0.2s;
    }

    .links-grid a:hover {
      background: var(--accent-color);
      color: #fff;
    }

    /* Extended Amortization Table Styles */
    .amortization-container {
      margin-top: 2rem;
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow: hidden;
      background: var(--card-bg);
    }
    .amortization-header {
      padding: 1.5rem;
      background: rgba(0,0,0,0.1);
      border-bottom: 1px solid var(--border-color);
    }
    .amortization-header h3 {
      margin: 0;
      color: var(--text-primary);
    }
    .amortization-controls {
      display: flex;
      gap: 1rem;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      align-items: center;
    }
    .amortization-controls button {
      padding: 0.5rem 1rem;
      border: 1px solid var(--accent-color);
      background: transparent;
      color: var(--accent-color);
      border-radius: 6px;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s;
    }
    .amortization-controls button.active {
      background: var(--accent-color);
      color: #fff;
    }
    .table-scroll {
      max-height: 500px;
      overflow-y: auto;
    }
    .amortization-table {
      width: 100%;
      border-collapse: collapse;
      font-variant-numeric: tabular-nums;
    }
    .amortization-table th {
      position: sticky;
      top: 0;
      background: var(--card-bg);
      z-index: 10;
      padding: 1rem;
      text-align: right;
      font-size: 0.9rem;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color);
    }
    .amortization-table th:first-child { text-align: center; }
    .amortization-table td {
      padding: 0.75rem 1rem;
      text-align: right;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }
    .amortization-table td:first-child { text-align: center; color: var(--text-secondary); }
    .amortization-table tr:hover td { background: rgba(255,255,255,0.02); }
    .amortization-table tr.year-row td {
      background: rgba(0,0,0,0.2);
      font-weight: 600;
      color: var(--accent-color);
    }

    /* Additional Educational Content Styles */
    .deep-dive-section {
      margin-top: 4rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border-color);
    }
    .deep-dive-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      margin-top: 2rem;
    }
    @media (max-width: 768px) {
      .deep-dive-grid { grid-template-columns: 1fr; gap: 2rem; }
    }
    .deep-dive-content h3 {
      font-size: 1.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }
    .deep-dive-content p {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .deep-dive-content ul {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }
    .deep-dive-content li {
      margin-bottom: 0.5rem;
    }

    /* Extra spacing for inputs */
    .input-help {
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
      display: block;
    }

    /* Error states */
    .input-error {
      border-color: #ef4444 !important;
    }
    .error-message {
      color: #ef4444;
      font-size: 0.8rem;
      margin-top: 0.25rem;
      display: none;
    }
    .input-group.error .error-message {
      display: block;
    }

  </style>


  <div class="calculator-container">

    <section class="hero-section">
      <h1>Personal Loan Calculator</h1>
      <p>Calculate your monthly payments, see how much interest you'll pay, and compare different loan terms to find the right fit for your budget.</p>

    </section>

    <section class="deep-dive-section">
      <h2 style="color: var(--text-primary); text-align: center; margin-bottom: 2rem;">A Deep Dive Into Personal Loans</h2>
      <div class="deep-dive-grid">
        <div class="deep-dive-content">
          <h3>How Personal Loans Work</h3>
          <p>A personal loan is a lump sum of money you borrow from a bank, credit union, or online lender. You repay the loan in fixed monthly installments over a set period, typically ranging from 12 to 84 months. Most personal loans are unsecured, meaning you don't have to put up collateral like a car or house to get approved.</p>
          <p>Because they are unsecured, lenders rely heavily on your credit score, income, and debt-to-income (DTI) ratio to determine whether you qualify and what interest rate to charge you. Borrowers with excellent credit (usually a FICO score of 720 or higher) receive the lowest rates, while those with fair or poor credit may face rates that make borrowing significantly more expensive.</p>

          <h3>Common Uses for Personal Loans</h3>
          <p>Unlike auto loans or mortgages, which are earmarked for specific purchases, personal loans can be used for almost anything. Common uses include:</p>
          <ul>
            <li><strong>Debt Consolidation:</strong> Rolling high-interest credit card debt into a single, lower-interest personal loan.</li>
            <li><strong>Home Improvements:</strong> Funding a kitchen remodel, roof repair, or new HVAC system.</li>
            <li><strong>Medical Bills:</strong> Covering unexpected healthcare costs.</li>
            <li><strong>Large Purchases:</strong> Paying for a wedding, moving expenses, or a major appliance.</li>
          </ul>
        </div>

        <div class="deep-dive-content">
          <h3>Understanding the Cost of Borrowing</h3>
          <p>When you take out a personal loan, you repay the principal (the amount you borrowed) plus interest. The interest rate is expressed as an Annual Percentage Rate (APR), which includes the interest rate plus any fees the lender charges, such as an origination fee.</p>
          <p>For example, if you borrow $10,000 at a 10% APR for 36 months, your monthly payment will be roughly $323. Over the life of the loan, you'll pay about $1,616 in interest, bringing the total cost to $11,616.</p>

          <h3>Origination Fees and Prepayment Penalties</h3>
          <p>Always read the fine print before signing a loan agreement. Many lenders charge an origination fee, which is deducted from the loan amount before you receive the funds. If you need exactly $10,000 to pay off debt and the lender charges a 5% origination fee ($500), you'll only receive $9,500. You may need to borrow a slightly higher amount to cover the fee.</p>
          <p>Additionally, check for prepayment penalties. These are fees lenders charge if you pay off the loan early, as it cuts into the interest they expected to earn. Fortunately, many modern online lenders have eliminated prepayment penalties, giving you the flexibility to save money on interest if you can pay off the loan ahead of schedule.</p>
        </div>
      </div>
    </section>


    <div class="main-grid">
      <div class="input-panel">
        <div class="input-group">
          <label for="loanAmount">Loan Amount</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="loanAmount" class="has-prefix" value="10000" min="1000" max="100000" step="500">
          </div>
          <div class="error-message">Please enter a valid loan amount between $100 and $1,000,000</div>
          <input type="range" id="loanAmountSlider" class="range-slider" min="1000" max="100000" step="500" value="10000">
        </div>

        <div class="input-group">
          <label for="interestRate">Interest Rate (APR)</label>
          <div class="input-wrapper">
            <input type="number" id="interestRate" class="has-suffix" value="8.5" min="0.1" max="36" step="0.1">
            <span class="suffix">%</span>
          </div>
          <div class="error-message">Please enter a valid interest rate between 0% and 100%</div>
          <input type="range" id="interestRateSlider" class="range-slider" min="1" max="36" step="0.1" value="8.5">
        </div>

        <div class="input-group">
          <label for="loanTerm">Loan Term</label>
          <div class="input-wrapper">
            <input type="number" id="loanTerm" class="has-suffix" value="36" min="6" max="120" step="1">
            <span class="suffix">Months</span>
          </div>
          <div class="error-message">Please enter a valid loan term between 1 and 600 months</div>
          <input type="range" id="loanTermSlider" class="range-slider" min="6" max="120" step="6" value="36">
        </div>
      </div>

      <div class="results-panel">
        <div class="primary-result">
          <div class="primary-result-label">Estimated Monthly Payment</div>
          <div class="primary-result-value" id="monthlyPayment">$0.00</div>
        </div>

        <div class="secondary-results">
          <div class="result-item">
            <div class="result-label">Total Interest Paid</div>
            <div class="result-value" id="totalInterest">$0.00</div>
          </div>
          <div class="result-item">
            <div class="result-label">Total Cost of Loan</div>
            <div class="result-value" id="totalCost">$0.00</div>
          </div>
        </div>

        <div class="chart-container">
          <div class="result-label" style="text-align: center; margin-bottom: 0.5rem;">Principal vs Interest</div>
          <div class="bar-chart">
            <div class="bar-principal" id="barPrincipal" style="width: 80%"></div>
            <div class="bar-interest" id="barInterest" style="width: 20%"></div>
          </div>
          <div class="chart-legend">
            <div class="legend-item"><div class="dot principal"></div> Principal</div>
            <div class="legend-item"><div class="dot interest"></div> Interest</div>
          </div>
        </div>
      </div>
    </div>

    <section class="scenario-section">
      <h2 style="color: var(--text-primary); margin-bottom: 0.5rem;">Compare Loan Terms</h2>
      <p style="color: var(--text-secondary);">See how different loan lengths affect your monthly payment and total interest.</p>
      <div class="scenario-grid" id="scenarioGrid">
        <!-- Scenarios generated via JS -->
      </div>
    </section>

    <section class="table-section">
      <h2 style="color: var(--text-primary); margin-bottom: 1rem;">Amortization Schedule</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Year</th>
              <th>Interest Paid</th>
              <th>Principal Paid</th>
              <th>Remaining Balance</th>
            </tr>
          </thead>
          <tbody id="amortizationTableBody">
            <!-- Table rows generated via JS -->
          </tbody>
        </table>
      </div>
    </section>

    <section class="educational-section">
      <h2 style="color: var(--text-primary);">Understanding Personal Loans</h2>
      <div class="edu-grid">
        <div class="edu-card">
          <h3>The Impact of Interest Rates</h3>
          <p>Your interest rate (APR) is the cost of borrowing money. Even a 1% or 2% difference can save or cost you hundreds of dollars over the life of a loan. Always shop around and improve your credit score before applying to secure the best possible rate.</p>
        </div>
        <div class="edu-card">
          <h3>Term Length Trade-offs</h3>
          <p>Choosing a longer loan term reduces your monthly payment, making it easier to fit into your budget. However, you pay interest for a longer period, significantly increasing the total cost of the loan. Choose the shortest term you can comfortably afford.</p>
        </div>
        <div class="edu-card">
          <h3>Watch Out for Fees</h3>
          <p>Many personal loans come with origination fees (typically 1% to 8% of the loan amount), which are deducted from your loan proceeds. Ensure you factor this into your borrowing amount so you receive the cash you actually need.</p>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2 style="color: var(--text-primary); margin-bottom: 1rem;">Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>How is a personal loan monthly payment calculated?</h3>
        <p>A personal loan payment is calculated using an amortization formula that accounts for your loan amount, interest rate, and term length. The formula ensures that your monthly payment remains the same, but the portion going toward principal and interest changes over time.</p>
      </div>

      <div class="faq-item">
        <h3>What is a good interest rate for a personal loan?</h3>
        <p>A good interest rate on a personal loan depends heavily on your credit score. Generally, borrowers with excellent credit (720+) can secure rates between 6% and 10%. Average credit scores might see rates from 12% to 18%, while poor credit can result in rates exceeding 25%.</p>
      </div>

      <div class="faq-item">
        <h3>Should I choose a longer or shorter personal loan term?</h3>
        <p>Shorter loan terms (e.g., 2-3 years) typically have higher monthly payments but cost much less in total interest. Longer terms (e.g., 5-7 years) lower your monthly payment but increase the total interest paid over the life of the loan. Choose the shortest term with a monthly payment you can comfortably afford.</p>
      </div>

      <div class="faq-item">
        <h3>Does applying for a personal loan hurt my credit score?</h3>
        <p>When you apply for a personal loan, lenders usually perform a hard credit inquiry, which can temporarily lower your credit score by a few points. However, making consistent on-time payments can ultimately improve your credit score by building a positive payment history.</p>
      </div>

      <div class="faq-item">
        <h3>Can I pay off my personal loan early?</h3>
        <p>Most personal loans allow you to pay off the balance early, which can save you a significant amount in interest. However, you should always check your loan agreement for a 'prepayment penalty,' which is a fee some lenders charge if you pay the loan off before the term ends.</p>
      </div>
    </section>


    <section class="educational-content">
      <h2>Understanding Your Personal Loan Credit Requirements</h2>
      <div class="info-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-top: 1.5rem;">
        <div class="info-card" style="background: var(--card-bg); padding: 1.5rem; border: 1px solid var(--border-color); border-radius: 8px;">
          <h3 style="color: var(--accent-color); margin-bottom: 1rem; margin-top: 0;">Excellent Credit (720+)</h3>
          <p style="color: var(--text-secondary); line-height: 1.6;">Borrowers with excellent credit scores typically qualify for the lowest interest rates available. Lenders view these applicants as low-risk. You might see rates ranging from 6% to 10%.</p>
          <ul style="color: var(--text-secondary); margin-top: 1rem; padding-left: 1.2rem;">
            <li style="margin-bottom: 0.5rem;">Highest approval odds</li>
            <li style="margin-bottom: 0.5rem;">Access to the largest loan amounts</li>
            <li style="margin-bottom: 0.5rem;">Most favorable repayment terms</li>
          </ul>
        </div>
        <div class="info-card" style="background: var(--card-bg); padding: 1.5rem; border: 1px solid var(--border-color); border-radius: 8px;">
          <h3 style="color: var(--accent-color); margin-bottom: 1rem; margin-top: 0;">Good Credit (690-719)</h3>
          <p style="color: var(--text-secondary); line-height: 1.6;">A good credit score still provides strong options. You'll likely be approved by most lenders, though your interest rate will be slightly higher than those in the top tier. Expect rates around 10% to 15%.</p>
          <ul style="color: var(--text-secondary); margin-top: 1rem; padding-left: 1.2rem;">
            <li style="margin-bottom: 0.5rem;">Solid approval odds</li>
            <li style="margin-bottom: 0.5rem;">Competitive rates</li>
            <li style="margin-bottom: 0.5rem;">May require proving strong income</li>
          </ul>
        </div>
        <div class="info-card" style="background: var(--card-bg); padding: 1.5rem; border: 1px solid var(--border-color); border-radius: 8px;">
          <h3 style="color: var(--accent-color); margin-bottom: 1rem; margin-top: 0;">Fair/Average Credit (630-689)</h3>
          <p style="color: var(--text-secondary); line-height: 1.6;">Borrowers with average credit can still secure personal loans, but the cost of borrowing increases significantly. You might face interest rates between 15% and 25%, and some lenders may charge higher origination fees.</p>
          <ul style="color: var(--text-secondary); margin-top: 1rem; padding-left: 1.2rem;">
            <li style="margin-bottom: 0.5rem;">Limited lender options</li>
            <li style="margin-bottom: 0.5rem;">Higher origination fees</li>
            <li style="margin-bottom: 0.5rem;">Smaller maximum loan amounts</li>
          </ul>
        </div>
        <div class="info-card" style="background: var(--card-bg); padding: 1.5rem; border: 1px solid var(--border-color); border-radius: 8px;">
          <h3 style="color: var(--accent-color); margin-bottom: 1rem; margin-top: 0;">Bad/Poor Credit (Below 630)</h3>
          <p style="color: var(--text-secondary); line-height: 1.6;">Securing a personal loan with bad credit is challenging but not impossible. Specialized lenders exist, but they offset their risk by charging high interest rates—often up to 36%—and substantial fees.</p>
          <ul style="color: var(--text-secondary); margin-top: 1rem; padding-left: 1.2rem;">
            <li style="margin-bottom: 0.5rem;">High likelihood of denial from traditional banks</li>
            <li style="margin-bottom: 0.5rem;">Maximum APR limits (usually 36%)</li>
            <li style="margin-bottom: 0.5rem;">May require a co-signer or collateral</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="educational-content" style="margin-top: 3rem;">
      <h2>Alternatives to Personal Loans</h2>
      <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem;">Before committing to a personal loan, consider if one of these alternatives might better suit your financial needs:</p>

      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div style="background: var(--card-bg); padding: 1.5rem; border-left: 4px solid var(--accent-color); border-radius: 4px;">
          <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">0% Intro APR Credit Cards</h3>
          <p style="margin: 0; color: var(--text-secondary); line-height: 1.5;">If you have excellent credit and can pay off your balance within 12 to 21 months, a 0% APR credit card offers free financing. Unlike personal loans, you only borrow exactly what you need.</p>
        </div>

        <div style="background: var(--card-bg); padding: 1.5rem; border-left: 4px solid var(--accent-color); border-radius: 4px;">
          <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">Home Equity Loans or Lines of Credit (HELOC)</h3>
          <p style="margin: 0; color: var(--text-secondary); line-height: 1.5;">Homeowners can borrow against their home's equity. Because these loans are secured by your property, they typically offer much lower interest rates than unsecured personal loans. However, your home is at risk if you default.</p>
        </div>

        <div style="background: var(--card-bg); padding: 1.5rem; border-left: 4px solid var(--accent-color); border-radius: 4px;">
          <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">401(k) Loans</h3>
          <p style="margin: 0; color: var(--text-secondary); line-height: 1.5;">You can borrow from your own retirement savings. The interest you pay goes back into your account. However, you miss out on potential market gains, and if you leave your job, the loan may become due immediately.</p>
        </div>

        <div style="background: var(--card-bg); padding: 1.5rem; border-left: 4px solid var(--accent-color); border-radius: 4px;">
          <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">Personal Line of Credit</h3>
          <p style="margin: 0; color: var(--text-secondary); line-height: 1.5;">Similar to a credit card, a personal line of credit gives you a borrowing limit. You can draw funds as needed and only pay interest on the amount you borrow. This is ideal for ongoing or unpredictable expenses.</p>
        </div>
      </div>
    </section>

    <section class="educational-content" style="margin-top: 3rem;">
      <h2>Step-by-Step Guide: How to Apply for a Personal Loan</h2>
      <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1.5rem;">

        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="background: var(--accent-color); color: var(--bg-primary); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; font-size: 1.2rem;">1</div>
          <div>
            <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">Check Your Credit Score</h3>
            <p style="margin: 0; color: var(--text-secondary); line-height: 1.6;">Before you apply, know where your credit stands. You can get a free credit report from AnnualCreditReport.com. Checking your own score is a 'soft pull' and won't hurt your credit. Correct any errors you find on your report to improve your chances of getting the best rate.</p>
          </div>
        </div>

        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="background: var(--accent-color); color: var(--bg-primary); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; font-size: 1.2rem;">2</div>
          <div>
            <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">Determine How Much You Need</h3>
            <p style="margin: 0; color: var(--text-secondary); line-height: 1.6;">Calculate exactly how much money you need to borrow. Remember that you will have to pay interest on every dollar, plus potential origination fees (which are often deducted from your loan payout). Don't borrow more than necessary.</p>
          </div>
        </div>

        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="background: var(--accent-color); color: var(--bg-primary); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; font-size: 1.2rem;">3</div>
          <div>
            <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">Pre-qualify with Multiple Lenders</h3>
            <p style="margin: 0; color: var(--text-secondary); line-height: 1.6;">Many lenders offer pre-qualification processes that use a soft credit inquiry. This allows you to see estimated rates and terms without impacting your credit score. Shop around with traditional banks, credit unions, and online lenders to compare offers.</p>
          </div>
        </div>

        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="background: var(--accent-color); color: var(--bg-primary); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; font-size: 1.2rem;">4</div>
          <div>
            <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">Submit a Formal Application</h3>
            <p style="margin: 0; color: var(--text-secondary); line-height: 1.6;">Once you've selected the best offer, submit your formal application. This will trigger a hard credit inquiry. Be prepared to provide documentation such as proof of identity (driver's license, passport), proof of address (utility bill), and proof of income (pay stubs, W-2s, or tax returns).</p>
          </div>
        </div>

        <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
          <div style="background: var(--accent-color); color: var(--bg-primary); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; font-size: 1.2rem;">5</div>
          <div>
            <h3 style="margin: 0 0 0.5rem 0; color: var(--text-primary);">Receive Your Funds</h3>
            <p style="margin: 0; color: var(--text-secondary); line-height: 1.6;">If approved, the lender will send you the loan agreement. Review it carefully, checking the APR, repayment schedule, and any fees. Once you sign, the funds are typically deposited into your bank account within one to three business days. Setup automatic payments to ensure you never miss a due date.</p>
          </div>
        </div>

      </div>
    </section>

