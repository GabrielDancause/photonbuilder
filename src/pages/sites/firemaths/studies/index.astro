---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const contentPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/firemaths_studies.html');
const htmlContent = fs.readFileSync(contentPath, 'utf-8');

const cssPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/firemaths_studies.css');
let cssContent = '';
try { cssContent = fs.readFileSync(cssPath, 'utf-8'); } catch {}
---

<SiteLayout
  site="firemaths"
  title="Studies - firemaths.info"
  description="Original financial research: savings rates, tax brackets, cap rates, and market data compared across countries and cities."
  canonical="https://{}/studies/"
>
  <Fragment set:html={htmlContent} />
  {cssContent && <style is:inline set:html={cssContent} />}
</SiteLayout>
