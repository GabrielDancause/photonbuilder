---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Bond Yield Calculator",
  "url": "https://firemaths.info/bond-yield",
  "description": "Calculate yield to maturity (YTM), current yield, and yield to call (YTC) for bonds.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Bond Yield Calculator | firemaths.info"
  description="Calculate yield to maturity (YTM), current yield, and yield to call (YTC) for bonds with this interactive calculator."
  canonical="https://firemaths.info/bond-yield" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Bond Parameters</h2>
                </div>

                <div class="inputs">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="face-value">Face Value (Par Value)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="face-value" value="1000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="coupon-rate">Annual Coupon Rate</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                            <input type="number" id="coupon-rate" value="5" min="0" step="0.125" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="current-price">Current Price</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="current-price" value="950" min="0" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="years-maturity">Years to Maturity</label>
                        <div class="relative flex items-center">
                            <input type="number" id="years-maturity" value="10" min="0" step="0.5" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="payment-frequency">Payment Frequency</label>
                        <div class="relative flex items-center">
                            <select id="payment-frequency" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                                <option value="1">Annually (1x/yr)</option>
                                <option value="2" selected>Semi-Annually (2x/yr)</option>
                                <option value="4">Quarterly (4x/yr)</option>
                                <option value="12">Monthly (12x/yr)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-8 pt-6 border-t border-dashed border-[var(--border-color)]">
                        <div class="flex justify-between items-center mb-4 text-[var(--text-secondary)] text-sm font-semibold uppercase tracking-wider">
                            <span>Call Features (Optional)</span>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="call-price">Call Price</label>
                            <div class="relative flex items-center">
                                <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                <input type="number" id="call-price" placeholder="e.g. 1050" min="0" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                            </div>
                        </div>

                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="years-call">Years to Call</label>
                            <div class="relative flex items-center">
                                <input type="number" id="years-call" placeholder="e.g. 5" min="0" step="0.5" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Yield Results</h2>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                    <div class="flex justify-between items-center mb-4 p-4 bg-[var(--accent-color)]/5 border border-[var(--accent-color)] rounded-lg">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Yield to Maturity (YTM)</span>
                        <div class="flex items-center gap-4">
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="res-ytm">0.00%</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('res-ytm', this)">Copy</button>
                        </div>
                    </div>

                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Current Yield</span>
                        <div class="flex items-center gap-4">
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="res-current-yield">0.00%</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('res-current-yield', this)">Copy</button>
                        </div>
                    </div>

                    <div class="flex justify-between items-center mb-4" id="ytc-container">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Yield to Call (YTC)</span>
                        <div class="flex items-center gap-4">
                            <span class="result-value disabled-text" id="res-ytc">N/A</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" id="btn-copy-ytc" onclick="copyValue('res-ytc', this)" disabled>Copy</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Understanding Yield to Maturity (YTM)</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Yield to Maturity (YTM) is the total return anticipated on a bond if it is held until its maturity date. YTM is considered a long-term bond yield but is expressed as an annual rate. It factors in the bond's current market price, par value, coupon interest rate, and time to maturity.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">YTM is a complex calculation because it assumes that all coupon payments are reinvested at the same rate as the bond's current yield. Because of this, it is often considered the most accurate measure of a bond's return.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Current Yield vs. YTM</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">While YTM accounts for the time value of money and the bond's eventual return to par value at maturity, the <strong>Current Yield</strong> is a simpler calculation. It measures the annual income (interest or dividends) divided by the current price of the security.</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>Premium Bonds:</strong> When a bond is priced above its par value, the Current Yield will be higher than the YTM, as the investor will experience a capital loss when the bond matures at par.</li>
                <li><strong>Discount Bonds:</strong> When a bond is priced below its par value, the YTM will be higher than the Current Yield, as the investor will experience a capital gain at maturity.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">What is Yield to Call (YTC)?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Some bonds have a callable feature, allowing the issuer to redeem the bond before it matures, usually at a slight premium to par value. The Yield to Call (YTC) calculates the investor's yield assuming the bond is called at the earliest possible date.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Investors should look at both YTM and YTC, often focusing on the "Yield to Worst" (YTW)&mdash;which is simply the lower of the two yields&mdash;to understand their minimum expected return.</p>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format percentage
    const formatPercent = (value) => {
        if (isNaN(value) || !isFinite(value)) return 'N/A';
        return value.toFixed(2) + '%';
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        if (btn.disabled) return;
        const text = document.getElementById(elementId).innerText;
        if (text === 'N/A') return;

        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // Calculation logic for YTM / YTC
    const solveYield = (price, faceValue, redemptionValue, annualCouponRate, years, frequency) => {
        if (price <= 0 || faceValue <= 0 || redemptionValue <= 0 || years <= 0 || frequency <= 0) return NaN;

        const coupon = (faceValue * (annualCouponRate / 100)) / frequency;
        const periods = years * frequency;

        let low = -0.9999;
        let high = 10; // 1000% per period
        let mid = 0;

        for (let i = 0; i < 100; i++) {
            mid = (low + high) / 2;
            let presentValue = 0;

            if (mid === 0) {
                presentValue = (coupon * periods) + redemptionValue;
            } else {
                presentValue = coupon * (1 - Math.pow(1 + mid, -periods)) / mid + redemptionValue * Math.pow(1 + mid, -periods);
            }

            if (presentValue > price) {
                low = mid;
            } else {
                high = mid;
            }
        }

        return mid * frequency * 100;
    };

    const updateCalculator = () => {
        const faceValue = parseFloat(document.getElementById('face-value').value);
        const couponRate = parseFloat(document.getElementById('coupon-rate').value);
        const currentPrice = parseFloat(document.getElementById('current-price').value);
        const yearsMaturity = parseFloat(document.getElementById('years-maturity').value);
        const frequency = parseInt(document.getElementById('payment-frequency').value);

        const callPriceRaw = document.getElementById('call-price').value;
        const yearsCallRaw = document.getElementById('years-call').value;

        const callPrice = callPriceRaw !== '' ? parseFloat(callPriceRaw) : NaN;
        const yearsCall = yearsCallRaw !== '' ? parseFloat(yearsCallRaw) : NaN;

        // Current Yield
        let currentYield = NaN;
        if (currentPrice > 0 && !isNaN(faceValue) && !isNaN(couponRate)) {
            const annualCoupon = faceValue * (couponRate / 100);
            currentYield = (annualCoupon / currentPrice) * 100;
        }

        // YTM
        const ytm = solveYield(currentPrice, faceValue, faceValue, couponRate, yearsMaturity, frequency);

        // YTC
        let ytc = NaN;
        if (!isNaN(callPrice) && !isNaN(yearsCall) && yearsCall > 0) {
            ytc = solveYield(currentPrice, faceValue, callPrice, couponRate, yearsCall, frequency);
        }

        // Update UI
        document.getElementById('res-current-yield').innerText = formatPercent(currentYield);
        document.getElementById('res-ytm').innerText = formatPercent(ytm);

        const ytcEl = document.getElementById('res-ytc');
        const ytcBtn = document.getElementById('btn-copy-ytc');

        if (!isNaN(ytc)) {
            ytcEl.innerText = formatPercent(ytc);
            ytcEl.classList.remove('disabled-text');
            ytcBtn.disabled = false;
        } else {
            ytcEl.innerText = 'N/A';
            ytcEl.classList.add('disabled-text');
            ytcBtn.disabled = true;
        }
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"], select');
    inputs.forEach(input => {
        input.addEventListener('input', updateCalculator);
    });

    // Initial calculation
    updateCalculator();
  </script>
</SiteLayout>
