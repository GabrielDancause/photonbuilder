---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "DCA vs Lump Sum Calculator",
  "url": "https://firemaths.info/dca-calculator.html",
  "description": "Compare Dollar Cost Averaging (DCA) vs Lump Sum investing strategies.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Dollar Cost Averaging (DCA) vs Lump Sum Calculator | firemaths.info"
  description="Compare Dollar Cost Averaging (DCA) against Lump Sum investing. Calculate final portfolio value, average cost basis, and see which strategy wins."
  canonical="https://firemaths.info/dca-calculator" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="totalAmount">Total Investment Amount</label>
                    <div class="relative flex items-center">
                        <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                        <input type="number" id="totalAmount" value="12000" min="0" step="1000" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="dcaMonths">DCA Duration (Months)</label>
                    <div class="relative flex items-center">
                        <input type="number" id="dcaMonths" value="12" min="1" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="years">Total Time Horizon (Years)</label>
                    <div class="relative flex items-center">
                        <input type="number" id="years" value="10" min="1" max="50" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="returnRate">Expected Annual Return</label>
                    <div class="relative flex items-center">
                        <input type="number" id="returnRate" value="7" min="-100" max="100" step="0.1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="results-grid">
                    <!-- Lump Sum Result -->
                    <div class="result-card" id="card-lump">
                        <div class="result-header">
                            <span class="indicator indicator-lump"></span> Lump Sum
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Final Portfolio Value</span>
                            <div class="result-value main-val">
                                <span id="res-lump-val">$23,605</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" data-copy="res-lump-val">Copy</button>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Average Cost Basis</span>
                            <div class="result-value small" id="res-lump-cost">$100.00</div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Shares</span>
                            <div class="result-value small" id="res-lump-shares">120.00</div>
                        </div>
                    </div>

                    <!-- DCA Result -->
                    <div class="result-card" id="card-dca">
                        <div class="result-header">
                            <span class="indicator indicator-dca"></span> DCA
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Final Portfolio Value</span>
                            <div class="result-value main-val">
                                <span id="res-dca-val">$22,810</span>
                                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" data-copy="res-dca-val">Copy</button>
                            </div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Average Cost Basis</span>
                            <div class="result-value small" id="res-dca-cost">$103.54</div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Shares</span>
                            <div class="result-value small" id="res-dca-shares">115.89</div>
                        </div>
                    </div>
                </div>

                <div class="comparison-banner" id="comparison-banner">
                    Lump Sum outperforms DCA by $795
                </div>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Dollar Cost Averaging (DCA) vs Lump Sum</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When you have a large sum of money to invest, you typically face a common dilemma: should you invest it all at once (Lump Sum) or spread it out over time (Dollar Cost Averaging)?</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Lump Sum Investing</strong> means taking your entire available capital and investing it immediately. This approach maximizes your "time in the market," allowing your money to start compounding and earning returns right away.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Dollar Cost Averaging (DCA)</strong> involves dividing your total investment amount into smaller, equal chunks and investing them at regular intervals (e.g., monthly). This strategy reduces the risk of investing right before a market drop and can lower your average cost basis during volatile periods.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Which Strategy is Better?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Historically, because markets tend to go up over time, <strong>Lump Sum investing outperforms DCA about 66% to 75% of the time</strong>. By investing everything upfront, you benefit from upward market trends earlier.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">However, DCA offers significant psychological benefits. If the market drops shortly after a lump sum investment, it can be stressful. DCA minimizes this regret risk. If the market falls during your DCA period, your subsequent investments will purchase shares at lower prices, effectively reducing your average cost basis.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Understanding Average Cost Basis</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Your average cost basis is the total amount invested divided by the total number of shares purchased. Our calculator simulates an initial share price of $100 that grows steadily at your expected annual return rate. In a steadily rising market, DCA will result in a higher average cost basis compared to a Lump Sum investment because you are buying shares at progressively higher prices over your DCA duration.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Tips for Your Strategy</h2>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>Have the cash?</strong> If you already have the cash available (e.g., from a windfall or bonus), statistically, investing it as a lump sum yields the best expected return.</li>
                <li><strong>Investing from paycheck?</strong> If you are investing a portion of your monthly income, you are technically already doing DCA! Keep making consistent contributions regardless of market conditions.</li>
                <li><strong>Fear of regret?</strong> If a 20% market drop immediately after a lump sum investment would cause you to panic sell, DCA is the better choice for your peace of mind.</li>
            </ul>
        </div>
    </main>

    
</div>
  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
        const inputs = {
            totalAmount: document.getElementById('totalAmount'),
            dcaMonths: document.getElementById('dcaMonths'),
            years: document.getElementById('years'),
            returnRate: document.getElementById('returnRate')
        };

        const outputs = {
            lumpVal: document.getElementById('res-lump-val'),
            lumpCost: document.getElementById('res-lump-cost'),
            lumpShares: document.getElementById('res-lump-shares'),
            dcaVal: document.getElementById('res-dca-val'),
            dcaCost: document.getElementById('res-dca-cost'),
            dcaShares: document.getElementById('res-dca-shares'),
            banner: document.getElementById('comparison-banner'),
            cardLump: document.getElementById('card-lump'),
            cardDca: document.getElementById('card-dca')
        };

        const copyButtons = document.querySelectorAll('.copy-btn');

        const formatCurrency = (value) => {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(value);
        };

        const formatNumber = (value) => {
            return new Intl.NumberFormat('en-US', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(value);
        };

        const calculate = () => {
            const totalAmount = parseFloat(inputs.totalAmount.value) || 0;
            const dcaMonths = parseInt(inputs.dcaMonths.value) || 1;
            const years = parseFloat(inputs.years.value) || 0;
            const returnRate = parseFloat(inputs.returnRate.value) || 0;

            const totalMonths = years * 12;
            const monthlyRate = (returnRate / 100) / 12;
            const initialPrice = 100; // arbitrary starting price

            // --- Lump Sum Calculation ---
            const lumpShares = totalAmount / initialPrice;
            const lumpCostBasis = initialPrice;
            const lumpFinalPrice = initialPrice * Math.pow(1 + monthlyRate, totalMonths);
            const lumpFinalValue = lumpShares * lumpFinalPrice;

            // --- DCA Calculation ---
            let dcaShares = 0;
            const validDcaMonths = Math.max(1, dcaMonths);
            const monthlyInvestment = totalAmount / validDcaMonths;

            for (let m = 0; m < validDcaMonths; m++) {
                // Price at month m
                const priceAtMonth = initialPrice * Math.pow(1 + monthlyRate, m);
                dcaShares += monthlyInvestment / priceAtMonth;
            }

            // The remaining months after DCA period
            // (Final price is the same for both strategies, evaluated at totalMonths)
            const dcaFinalValue = dcaShares * lumpFinalPrice;
            const dcaCostBasis = dcaShares > 0 ? (totalAmount / dcaShares) : 0;

            // Update UI
            outputs.lumpVal.textContent = formatCurrency(lumpFinalValue);
            outputs.lumpCost.textContent = formatCurrency(lumpCostBasis);
            outputs.lumpShares.textContent = formatNumber(lumpShares);

            outputs.dcaVal.textContent = formatCurrency(dcaFinalValue);
            outputs.dcaCost.textContent = formatCurrency(dcaCostBasis);
            outputs.dcaShares.textContent = formatNumber(dcaShares);

            // Comparison
            const diff = lumpFinalValue - dcaFinalValue;
            outputs.cardLump.classList.remove('highlight');
            outputs.cardDca.classList.remove('highlight');

            if (diff > 0) {
                outputs.cardLump.classList.add('highlight');
                outputs.banner.textContent = `Lump Sum outperforms DCA by ${formatCurrency(diff)}`;
                outputs.banner.style.color = 'var(--chart-color-b)';
                outputs.banner.style.borderColor = 'var(--chart-color-b)';
                outputs.banner.style.backgroundColor = 'rgba(74, 144, 226, 0.1)';
            } else if (diff < 0) {
                outputs.cardDca.classList.add('highlight');
                outputs.banner.textContent = `DCA outperforms Lump Sum by ${formatCurrency(Math.abs(diff))}`;
                outputs.banner.style.color = 'var(--chart-color-a)';
                outputs.banner.style.borderColor = 'var(--chart-color-a)';
                outputs.banner.style.backgroundColor = 'rgba(212, 160, 23, 0.1)';
            } else {
                outputs.banner.textContent = `Both strategies yield the same result`;
                outputs.banner.style.color = 'var(--text-primary)';
                outputs.banner.style.borderColor = 'var(--border-color)';
                outputs.banner.style.backgroundColor = 'transparent';
            }
        };

        // Attach event listeners
        Object.values(inputs).forEach(input => {
            input.addEventListener('input', calculate);
        });

        // Copy functionality
        copyButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetId = e.target.getAttribute('data-copy');
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    navigator.clipboard.writeText(targetElement.textContent).then(() => {
                        const originalText = e.target.textContent;
                        e.target.textContent = 'Copied!';
                        e.target.classList.add('copied');
                        setTimeout(() => {
                            e.target.textContent = originalText;
                            e.target.classList.remove('copied');
                        }, 2000);
                    }).catch(err => {
                        console.error('Failed to copy text: ', err);
                    });
                }
            });
        });

        // Initial calculation
        calculate();
    });
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-investing-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Beginner's Guide to Investing Your Money</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
