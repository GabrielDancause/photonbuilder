---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'APY Calculator | Firemaths',
  description: 'Calculate Annual Percentage Yield (APY) and see how compounding frequency affects your earnings. Compare APY vs APR with this free interactive calculator.',
  category: 'tool',
  keywords: ['apy calculator', 'annual percentage yield', 'compound interest calculator', 'apr vs apy', 'savings calculator', 'interest compounding']
};

const schema = JSON.stringify([{"@context":"https://schema.org","@type":"Article","headline":"APY Calculator | Firemaths","description":"Calculate Annual Percentage Yield (APY) and see how compounding frequency affects your earnings. Compare APY vs APR with this free interactive calculator.","author":{"@type":"Organization","name":"firemaths.info"},"publisher":{"@type":"Organization","name":"firemaths.info"},"datePublished":"2026-03-23","dateModified":"2026-03-23"},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the difference between APY and APR?","acceptedAnswer":{"@type":"Answer","text":"APR (Annual Percentage Rate) is the simple interest rate you earn in a year without considering compounding. APY (Annual Percentage Yield) takes into account the effect of compounding interest, giving you a more accurate measure of your actual earnings over a year."}},{"@type":"Question","name":"Why is APY always higher than APR?","acceptedAnswer":{"@type":"Answer","text":"APY is higher than APR (unless interest is only compounded annually) because APY includes the interest you earn on your previously accumulated interest. The more frequently interest compounds (daily vs. monthly), the higher the APY will be compared to the stated APR."}},{"@type":"Question","name":"How is APY calculated?","acceptedAnswer":{"@type":"Answer","text":"The formula for APY is: APY = (1 + r/n)^n - 1, where 'r' is the nominal interest rate (APR) expressed as a decimal, and 'n' is the number of compounding periods per year."}},{"@type":"Question","name":"Is daily compounding better than monthly?","acceptedAnswer":{"@type":"Answer","text":"Yes, for savings and investments, daily compounding is better than monthly compounding because your interest is added to your balance every day, allowing it to start earning its own interest sooner. This results in a slightly higher APY."}},{"@type":"Question","name":"What is a good APY for a savings account?","acceptedAnswer":{"@type":"Answer","text":"A good APY changes depending on the current federal funds rate. High-yield savings accounts (HYSA) offered by online banks typically provide the best APYs, often 10-15 times higher than the national average rate offered by traditional brick-and-mortar banks."}}]}]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description} canonical="https://firemaths.info/apy-calculator">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <style is:inline>
    .calculator-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
      color: var(--text-primary);
    }
    .hero-section {
      text-align: center;
      margin-bottom: 3rem;
      padding: 4rem 2rem;
      background: var(--card-bg);
      border-radius: 16px;
      border: 1px solid var(--border-color);
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    .hero-title {
      font-size: 3rem;
      margin-bottom: 1rem;
      color: var(--accent-color);
    }
    .hero-subtitle {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 800px;
      margin: 0 auto 2rem;
    }
    .stats-container {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
      margin-top: 2rem;
    }
    .stat-box {
      background: var(--bg-primary);
      padding: 1.5rem;
      border-radius: 12px;
      border: 1px solid var(--border-color);
      min-width: 200px;
    }
    .stat-value {
      font-size: 2rem;
      font-weight: bold;
      color: var(--accent-color);
    }
    .stat-label {
      font-size: 0.9rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 4rem;
    }
    @media (max-width: 900px) {
      .main-grid {
        grid-template-columns: 1fr;
      }
    }
    .input-panel {
      background: var(--card-bg);
      padding: 2rem;
      border-radius: 16px;
      border: 1px solid var(--border-color);
    }
    .results-panel {
      background: var(--card-bg);
      padding: 2rem;
      border-radius: 16px;
      border: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
    }
    .form-group {
      margin-bottom: 1.5rem;
    }
    .form-label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: var(--text-primary);
    }
    .form-input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      background: var(--bg-primary);
      color: var(--text-primary);
      font-size: 1rem;
    }
    .form-input:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 2px rgba(212, 160, 23, 0.2);
    }
    .input-group {
      position: relative;
    }
    .prefix {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
    }
    .suffix {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
    }
    .has-prefix {
      padding-left: 2rem;
    }
    .has-suffix {
      padding-right: 2rem;
    }
    .result-card {
      background: var(--bg-primary);
      padding: 1.5rem;
      border-radius: 12px;
      border: 1px solid var(--border-color);
      margin-bottom: 1.5rem;
      text-align: center;
    }
    .result-title {
      font-size: 1.1rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }
    .result-value {
      font-size: 3rem;
      font-weight: bold;
      color: var(--accent-color);
      line-height: 1;
    }
    .chart-container {
      flex-grow: 1;
      min-height: 300px;
      margin-top: 2rem;
      position: relative;
    }
    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 2rem;
    }
    .comparison-table th,
    .comparison-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }
    .comparison-table th {
      color: var(--text-secondary);
      font-weight: 600;
    }
    .comparison-table tr:last-child td {
      border-bottom: none;
    }
    .comparison-table tr:hover td {
      background: var(--bg-primary);
    }
    .highlight-row td {
      color: var(--accent-color);
      font-weight: bold;
    }
    .educational-section {
      margin-bottom: 4rem;
    }
    .section-title {
      font-size: 2rem;
      margin-bottom: 2rem;
      color: var(--accent-color);
      text-align: center;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }
    .info-card {
      background: var(--card-bg);
      padding: 2rem;
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }
    .info-card h3 {
      color: var(--accent-color);
      margin-bottom: 1rem;
      font-size: 1.25rem;
    }
    .info-card p {
      color: var(--text-secondary);
      line-height: 1.6;
    }
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      margin-bottom: 1rem;
      overflow: hidden;
    }
    .faq-question {
      padding: 1.5rem;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
      color: var(--text-primary);
      user-select: none;
    }
    .faq-question:hover {
      background: var(--bg-primary);
    }
    .faq-answer {
      padding: 0 1.5rem;
      max-height: 0;
      overflow: hidden;
      transition: all 0.3s ease-out;
      color: var(--text-secondary);
      line-height: 1.6;
    }
    .faq-item.active .faq-answer {
      padding: 0 1.5rem 1.5rem;
      max-height: 500px;
    }
    .faq-icon {
      transition: transform 0.3s ease;
    }
    .faq-item.active .faq-icon {
      transform: rotate(180deg);
    }
    .related-tools {
      margin-top: 4rem;
      padding-top: 4rem;
      border-top: 1px solid var(--border-color);
    }
    .error-message {
      color: #ef4444;
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
    }

    /* CSS Bar Chart */
    .css-chart {
      display: flex;
      align-items: flex-end;
      height: 250px;
      gap: 10px;
      padding: 20px 0;
      border-bottom: 1px solid var(--border-color);
      margin-top: 2rem;
    }
    .chart-bar-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      height: 100%;
      justify-content: flex-end;
      position: relative;
      group: hover;
    }
    .chart-bar {
      width: 100%;
      max-width: 60px;
      background: var(--accent-color);
      border-radius: 4px 4px 0 0;
