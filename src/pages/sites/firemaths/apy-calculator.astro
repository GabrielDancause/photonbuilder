      opacity: 1;
    }

    .cta-button {
      display: inline-block;
      padding: 1rem 2rem;
      background: var(--accent-color);
      color: #000;
      text-decoration: none;
      border-radius: 8px;
      font-weight: bold;
      font-size: 1.1rem;
      transition: opacity 0.2s;
      margin-top: 1.5rem;
    }
    .cta-button:hover {
      opacity: 0.9;
    }
    .diff-badge {
      display: inline-block;
      padding: 0.25rem 0.5rem;
      background: rgba(74, 255, 138, 0.1);
      color: #4aff8a;
      border-radius: 4px;
      font-size: 0.8rem;
      margin-left: 0.5rem;
      vertical-align: middle;
    }
  </style>

  <div class="calculator-container">
    <div class="hero-section">
      <h1 class="hero-title">APY vs APR Calculator</h1>
      <p class="hero-subtitle">Discover the true earning potential of your investments. See exactly how different compounding frequencies transform your baseline APR into a higher APY, maximizing your wealth over time.</p>

      <div class="stats-container">
        <div class="stat-box">
          <div class="stat-value">365x</div>
          <div class="stat-label">Daily Compounding</div>
        </div>
        <div class="stat-box">
          <div class="stat-value">12x</div>
          <div class="stat-label">Monthly Compounding</div>
        </div>
        <div class="stat-box">
          <div class="stat-value" id="hero-diff">+0.00%</div>
          <div class="stat-label">Max APY Boost</div>
        </div>
      </div>

      <a href="#calculator" class="cta-button">Calculate Your APY Now</a>
    </div>

    <div id="calculator" class="main-grid">
      <div class="input-panel">
        <h2 style="margin-bottom: 1.5rem; color: var(--accent-color);">Investment Details</h2>

        <div class="form-group">
          <label class="form-label" for="principal">Initial Deposit</label>
          <div class="input-group">
            <span class="prefix">$</span>
            <input type="number" id="principal" class="form-input has-prefix" value="10000" min="0" step="100">
          </div>
          <div class="error-message" id="principal-error">Please enter a valid amount greater than 0.</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="apr">Interest Rate (APR)</label>
          <div class="input-group">
            <input type="number" id="apr" class="form-input has-suffix" value="5.0" min="0" max="100" step="0.1">
            <span class="suffix">%</span>
          </div>
          <div class="error-message" id="apr-error">Please enter a rate between 0 and 100.</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="years">Time Period</label>
          <div class="input-group">
            <input type="number" id="years" class="form-input has-suffix" value="5" min="1" max="100" step="1">
            <span class="suffix">Years</span>
          </div>
          <div class="error-message" id="years-error">Please enter a period between 1 and 100 years.</div>
        </div>

        <div class="form-group">
          <label class="form-label" for="compounding">Compounding Frequency</label>
          <select id="compounding" class="form-input">
            <option value="365">Daily (365/year)</option>
            <option value="12" selected>Monthly (12/year)</option>
            <option value="4">Quarterly (4/year)</option>
            <option value="2">Semi-Annually (2/year)</option>
            <option value="1">Annually (1/year)</option>
          </select>
        </div>
      </div>

      <div class="results-panel">
        <h2 style="margin-bottom: 1.5rem; color: var(--accent-color);">Your Returns</h2>

        <div class="result-card">
          <div class="result-title">Effective APY</div>
          <div class="result-value" id="result-apy">0.00%</div>
          <div style="color: var(--text-secondary); margin-top: 0.5rem; font-size: 0.9rem;">
            vs stated APR of <span id="result-apr">0.00%</span>
            <span class="diff-badge" id="result-diff">+0.00%</span>
          </div>
        </div>

        <div class="main-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 0;">
          <div class="result-card" style="padding: 1rem;">
            <div class="result-title">Total Interest</div>
            <div class="result-value" id="result-interest" style="font-size: 2rem;">$0</div>
          </div>
          <div class="result-card" style="padding: 1rem;">
            <div class="result-title">Final Balance</div>
            <div class="result-value" id="result-total" style="font-size: 2rem;">$0</div>
          </div>
        </div>

        <h3 style="margin-top: 2rem; color: var(--text-secondary); text-align: center; font-size: 1rem;">Balance Growth Over Time</h3>
        <div class="css-chart" id="growth-chart">
          <!-- Chart bars generated by JS -->
        </div>
      </div>
    </div>

    <div class="educational-section">
      <h2 class="section-title">Compounding Frequency Comparison</h2>
      <p style="text-align: center; color: var(--text-secondary); margin-bottom: 2rem; max-width: 800px; margin-left: auto; margin-right: auto;">
        See how the exact same APR yields different final balances depending purely on how often the bank calculates and adds the interest to your account.
      </p>

      <div style="overflow-x: auto; background: var(--card-bg); border-radius: 12px; border: 1px solid var(--border-color);">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Frequency</th>
              <th>Periods/Year</th>
              <th>Effective APY</th>
              <th>Final Balance</th>
              <th>Extra Earned*</th>
            </tr>
          </thead>
          <tbody id="comparison-tbody">
            <!-- Table rows generated by JS -->
          </tbody>
        </table>
      </div>
      <p style="text-align: right; font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.5rem;">*Compared to simple annual compounding</p>
    </div>

    <div class="educational-section">
      <h2 class="section-title">Understanding APY vs APR</h2>
      <div class="cards-grid">
        <div class="info-card">
          <h3>What is APR?</h3>
          <p>APR stands for <strong>Annual Percentage Rate</strong>. It is the basic, simple interest rate applied to an account over a full year, completely ignoring the effects of compounding. If you earn 5% APR and interest is only paid once at the end of the year, your APY is exactly 5%.</p>
        </div>
        <div class="info-card">
          <h3>What is APY?</h3>
          <p>APY stands for <strong>Annual Percentage Yield</strong>. It represents the true, total amount of interest earned in a year because it accounts for compounding—earning interest on your previously earned interest. The more often interest compounds, the higher the APY climbs above the APR.</p>
        </div>
        <div class="info-card">
          <h3>The Magic of Compounding</h3>
          <p>Compounding is what makes wealth accelerate. When a bank compounds monthly, they calculate 1/12th of your annual interest every month and add it to your balance. The very next month, you earn interest on your original money <em>plus</em> that tiny bit of new interest.</p>
        </div>
        <div class="info-card">
          <h3>Why Banks Use Both</h3>
          <p>Banks often heavily advertise the <strong>APY</strong> for savings accounts because it's the higher number, making the account look more attractive. Conversely, for loans and credit cards, they advertise the <strong>APR</strong> because it's the lower number, making the debt seem cheaper.</p>
        </div>
      </div>
    </div>

    <div class="faq-section">
      <h2 class="section-title">Frequently Asked Questions</h2>

      <div class="faq-item">
        <div class="faq-question">
          What is the difference between APY and APR?
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="faq-answer">
          <p>APR (Annual Percentage Rate) is the simple interest rate you earn in a year without considering compounding. APY (Annual Percentage Yield) takes into account the effect of compounding interest, giving you a more accurate measure of your actual earnings over a year.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">
          Why is APY always higher than APR?
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="faq-answer">
          <p>APY is higher than APR (unless interest is only compounded annually) because APY includes the interest you earn on your previously accumulated interest. The more frequently interest compounds (daily vs. monthly), the higher the APY will be compared to the stated APR.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">
          How is APY calculated?
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="faq-answer">
          <p>The formula for APY is: APY = (1 + r/n)^n - 1, where 'r' is the nominal interest rate (APR) expressed as a decimal, and 'n' is the number of compounding periods per year.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">
          Is daily compounding better than monthly?
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="faq-answer">
          <p>Yes, for savings and investments, daily compounding is better than monthly compounding because your interest is added to your balance every day, allowing it to start earning its own interest sooner. This results in a slightly higher APY.</p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">
          What is a good APY for a savings account?
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="faq-answer">
          <p>A good APY changes depending on the current federal funds rate. High-yield savings accounts (HYSA) offered by online banks typically provide the best APYs, often 10-15 times higher than the national average rate offered by traditional brick-and-mortar banks.</p>
        </div>
      </div>
    </div>

    <div class="related-tools">
      <h2 style="font-size: 1.5rem; color: var(--text-primary); margin-bottom: 1.5rem;">Related Calculators</h2>
      <div class="cards-grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
        <a href="/investment-calculator" style="text-decoration: none;">
          <div class="info-card" style="padding: 1.5rem; transition: transform 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
            <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Investment Calculator</h3>
            <p style="font-size: 0.9rem;">Model long-term portfolio growth with regular monthly contributions and inflation.</p>
          </div>
        </a>
        <a href="/savings-goal-calculator" style="text-decoration: none;">
          <div class="info-card" style="padding: 1.5rem; transition: transform 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
            <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Savings Goal Calculator</h3>
            <p style="font-size: 0.9rem;">Find out exactly how much you need to save each month to reach your target number.</p>
          </div>
        </a>
        <a href="/roi-calculator" style="text-decoration: none;">
          <div class="info-card" style="padding: 1.5rem; transition: transform 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-4px)'" onmouseout="this.style.transform='translateY(0)'">
            <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">ROI Calculator</h3>
            <p style="font-size: 0.9rem;">Calculate the exact return on investment and CAGR for any asset.</p>
          </div>
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    // Utility functions for formatting
    const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
    const formatPercent = (val) => new Intl.NumberFormat('en-US', { style: 'percent', minimumFractionDigits: 2, maximumFractionDigits: 3 }).format(val / 100);

    // DOM Elements
    const elPrincipal = document.getElementById('principal');
    const elApr = document.getElementById('apr');
    const elYears = document.getElementById('years');
    const elCompounding = document.getElementById('compounding');

    const errPrincipal = document.getElementById('principal-error');
    const errApr = document.getElementById('apr-error');
    const errYears = document.getElementById('years-error');

    const resApy = document.getElementById('result-apy');
    const resApr = document.getElementById('result-apr');
    const resDiff = document.getElementById('result-diff');
    const resInterest = document.getElementById('result-interest');
    const resTotal = document.getElementById('result-total');

    const chartContainer = document.getElementById('growth-chart');
    const comparisonTbody = document.getElementById('comparison-tbody');
    const heroDiff = document.getElementById('hero-diff');

    // Calculation Logic
    function calculateAPY(aprDecimal, periodsPerYear) {
      return Math.pow(1 + (aprDecimal / periodsPerYear), periodsPerYear) - 1;
    }

    function calculateFinalBalance(principal, aprDecimal, periodsPerYear, years) {
      return principal * Math.pow(1 + (aprDecimal / periodsPerYear), periodsPerYear * years);
    }

    function validateInputs() {
      let isValid = true;
      const p = parseFloat(elPrincipal.value);
      const a = parseFloat(elApr.value);
      const y = parseInt(elYears.value);

      if (isNaN(p) || p <= 0) {
        errPrincipal.style.display = 'block';
        isValid = false;
      } else {
        errPrincipal.style.display = 'none';
      }

      if (isNaN(a) || a < 0 || a > 100) {
        errApr.style.display = 'block';
        isValid = false;
      } else {
        errApr.style.display = 'none';
      }

      if (isNaN(y) || y < 1 || y > 100) {
        errYears.style.display = 'block';
        isValid = false;
      } else {
        errYears.style.display = 'none';
      }

      return isValid;
    }

    function updateComparisonTable(principal, aprDecimal, years, selectedPeriods) {
      const frequencies = [
        { name: 'Daily', periods: 365 },
        { name: 'Monthly', periods: 12 },
        { name: 'Quarterly', periods: 4 },
        { name: 'Semi-Annually', periods: 2 },
        { name: 'Annually', periods: 1 }
      ];

      const baselineBalance = calculateFinalBalance(principal, aprDecimal, 1, years);
      let html = '';

      frequencies.forEach(f => {
        const apy = calculateAPY(aprDecimal, f.periods);
        const balance = calculateFinalBalance(principal, aprDecimal, f.periods, years);
        const extra = balance - baselineBalance;
        const isSelected = f.periods === parseInt(selectedPeriods);

        html += `
          <tr class="${isSelected ? 'highlight-row' : ''}">
            <td>${f.name}</td>
            <td>${f.periods}</td>
            <td>${formatPercent(apy * 100)}</td>
            <td>${formatCurrency(balance)}</td>
            <td>${f.periods === 1 ? '-' : '+' + formatCurrency(extra)}</td>
          </tr>
        `;
      });

      comparisonTbody.innerHTML = html;

      // Update hero stat
      const maxApy = calculateAPY(aprDecimal, 365);
      const diff = maxApy - aprDecimal;
      heroDiff.textContent = `+${formatPercent(diff * 100)}`;
    }

    function renderChart(principal, aprDecimal, periodsPerYear, totalYears) {
      chartContainer.innerHTML = '';

      // Generate yearly data points
      const dataPoints = [];
      let maxBalance = 0;

      // Keep chart to max 10 bars for readability
      const step = Math.max(1, Math.floor(totalYears / 10));

      for (let i = 0; i <= totalYears; i += step) {
        const year = i;
        const balance = calculateFinalBalance(principal, aprDecimal, periodsPerYear, year);
        dataPoints.push({ year, balance });
        if (balance > maxBalance) maxBalance = balance;
      }

      // Ensure final year is included if not covered by step
      if (dataPoints[dataPoints.length - 1].year !== totalYears) {
        const balance = calculateFinalBalance(principal, aprDecimal, periodsPerYear, totalYears);
        dataPoints.push({ year: totalYears, balance });
        maxBalance = balance;
      }

      // Render CSS bars
      dataPoints.forEach(dp => {
        const heightPercent = (dp.balance / maxBalance) * 100;

        const group = document.createElement('div');
        group.className = 'chart-bar-group';

        const tooltip = document.createElement('div');
        tooltip.className = 'chart-tooltip';
        tooltip.textContent = `Year ${dp.year}: ${formatCurrency(dp.balance)}`;

        const bar = document.createElement('div');
        bar.className = 'chart-bar';
        bar.style.height = `${heightPercent}%`;

        const label = document.createElement('div');
        label.className = 'chart-bar-label';
        label.textContent = dp.year === 0 ? 'Now' : `Y${dp.year}`;

        group.appendChild(tooltip);
        group.appendChild(bar);
        group.appendChild(label);
        chartContainer.appendChild(group);
      });
    }

    function calculate() {
      if (!validateInputs()) return;

      const principal = parseFloat(elPrincipal.value);
      const aprStr = elApr.value;
      const apr = parseFloat(aprStr);
      const aprDecimal = apr / 100;
      const years = parseInt(elYears.value);
      const periodsPerYear = parseInt(elCompounding.value);

      const apyDecimal = calculateAPY(aprDecimal, periodsPerYear);
      const apy = apyDecimal * 100;

      const finalBalance = calculateFinalBalance(principal, aprDecimal, periodsPerYear, years);
      const totalInterest = finalBalance - principal;
      const diff = apy - apr;

      // Update UI
      resApy.textContent = formatPercent(apy);
      resApr.textContent = `${aprStr}%`;
      resDiff.textContent = `+${formatPercent(diff)}`;
      resInterest.textContent = formatCurrency(totalInterest);
      resTotal.textContent = formatCurrency(finalBalance);

      renderChart(principal, aprDecimal, periodsPerYear, years);
      updateComparisonTable(principal, aprDecimal, years, periodsPerYear);
    }

    // Setup FAQ interactions
    document.querySelectorAll('.faq-question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        item.classList.toggle('active');
      });
    });

    // Event Listeners
    elPrincipal.addEventListener('input', calculate);
    elApr.addEventListener('input', calculate);
    elYears.addEventListener('input', calculate);
    elCompounding.addEventListener('change', calculate);

    // Initial calculation
    calculate();
