---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const contentPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/firemaths_guides.html');
const htmlContent = fs.readFileSync(contentPath, 'utf-8');

const cssPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/firemaths_guides.css');
let cssContent = '';
try { cssContent = fs.readFileSync(cssPath, 'utf-8'); } catch {}
---

<SiteLayout
  site="firemaths"
  title="Financial Guides | firemaths.info"
  description="Comprehensive guides for financial independence, FIRE movement, investing, and budgeting."
  canonical="https://{}/guides/"
>
  <Fragment set:html={htmlContent} />
  {cssContent && <style is:inline set:html={cssContent} />}
</SiteLayout>
