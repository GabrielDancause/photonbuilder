        brackets: {
          single: [
            { rate: 0.10, max: 11925 },
            { rate: 0.12, max: 48475 },
            { rate: 0.22, max: 103350 },
            { rate: 0.24, max: 197300 },
            { rate: 0.32, max: 250525 },
            { rate: 0.35, max: 626350 },
            { rate: 0.37, max: Infinity }
          ],
          married: [
            { rate: 0.10, max: 23850 },
            { rate: 0.12, max: 96950 },
            { rate: 0.22, max: 206700 },
            { rate: 0.24, max: 394600 },
            { rate: 0.32, max: 501050 },
            { rate: 0.35, max: 751600 },
            { rate: 0.37, max: Infinity }
          ],
          head: [
            { rate: 0.10, max: 17000 },
            { rate: 0.12, max: 64850 },
            { rate: 0.22, max: 103350 },
            { rate: 0.24, max: 197300 },
            { rate: 0.32, max: 250500 },
            { rate: 0.35, max: 626350 },
            { rate: 0.37, max: Infinity }
          ]
        }
      }
    };

    function calculateTax() {
      const year = document.getElementById('taxYear').value;
      const status = document.getElementById('filingStatus').value;
      const incomeInput = document.getElementById('grossIncome');
      const grossIncome = parseFloat(incomeInput.value);

      const estimatedTaxResult = document.getElementById('estimatedTaxResult');
      const takeHomeResult = document.getElementById('takeHomeResult');
      const effectiveRateResult = document.getElementById('effectiveRateResult');
      const marginalBracketResult = document.getElementById('marginalBracketResult');

      if (isNaN(grossIncome) || grossIncome <= 0) {
        estimatedTaxResult.textContent = '$0.00';
        takeHomeResult.textContent = '$0.00';
        effectiveRateResult.textContent = '0%';
        marginalBracketResult.textContent = '0%';
        return;
      }

      const yearData = taxData[year];
      const standardDeduction = yearData.standardDeduction[status];
      const brackets = yearData.brackets[status];

      let taxableIncome = Math.max(0, grossIncome - standardDeduction);
      let totalTax = 0;
      let previousMax = 0;
      let marginalRate = 0;

      for (const bracket of brackets) {
        const taxableAmountInBracket = Math.min(Math.max(0, taxableIncome - previousMax), bracket.max - previousMax);

        if (taxableAmountInBracket > 0) {
          totalTax += taxableAmountInBracket * bracket.rate;
          marginalRate = bracket.rate;
        }

        previousMax = bracket.max;
        if (taxableIncome <= previousMax) {
          break;
        }
      }

      const formatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD'
      });

      const effectiveRate = totalTax > 0 ? (totalTax / grossIncome) * 100 : 0;

      estimatedTaxResult.textContent = formatter.format(totalTax);
      takeHomeResult.textContent = formatter.format(grossIncome - totalTax);
      effectiveRateResult.textContent = effectiveRate.toFixed(1) + '%';
      marginalBracketResult.textContent = (marginalRate * 100).toFixed(0) + '%';
    }

    document.getElementById('taxYear').addEventListener('change', calculateTax);
    document.getElementById('filingStatus').addEventListener('change', calculateTax);
    document.getElementById('grossIncome').addEventListener('input', calculateTax);

    // Initial calculation
    calculateTax();
  </script>

