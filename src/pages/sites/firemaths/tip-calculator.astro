---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tip Calculator | Free Gratuity & Bill Splitter",
  description: "Calculate tips instantly. Choose your percentage, split the bill, and round up — the fastest free tip calculator online.",
  category: "tool",
  published: "2026-03-26"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Tip Calculator",
      "description": "Free online tip calculator and bill splitter tool",
      "url": "https://firemaths.info/tip-calculator",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Any",
      "publisher": {
        "@type": "Organization",
        "name": "Fire Maths",
        "url": "https://firemaths.info"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much should I tip at a restaurant?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For restaurants, the standard tip is 15-20% of the total bill before tax. 18% is commonly considered appropriate for good service."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate a 20% tip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To calculate a 20% tip mentally, move the decimal point one place to the left (10%) and multiply by 2. For $50.00: $5.00 × 2 = $10.00 tip."
          }
        },
        {
          "@type": "Question",
          "name": "Should I tip on the pre-tax or post-tax amount?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "It's generally acceptable to tip on either the pre-tax or post-tax amount. Most people tip on the pre-tax total, but tipping on the full amount including tax is also common and appreciated."
          }
        },
        {
          "@type": "Question",
          "name": "How do I split a tip between multiple people?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Calculate the total tip amount first, then divide by the number of people. Our tip calculator automatically shows the per-person amount when you enter the number of people splitting the bill."
          }
        },
        {
          "@type": "Question",
          "name": "Is it okay to round up the tip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, rounding up the total amount to the nearest dollar is perfectly acceptable and often appreciated. It makes the math easier and shows generosity."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description} canonical="https://firemaths.info/tip-calculator" schema={schema}>
  <div class="min-h-screen bg-[var(--bg-color)] text-[var(--text-primary)] py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Tip Calculator</h1>
        <p class="text-[var(--text-secondary)] text-lg">Calculate tips instantly, split bills, and round up — the fastest free gratuity calculator online.</p>
      </div>

      <!-- Main Calculator -->
      <div class="bg-[var(--card-bg)] rounded-xl p-6 md:p-8 border border-[var(--border-color)] mb-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Input Section -->
          <div class="space-y-6">
            <div>
              <label for="billAmount" class="block text-sm font-medium mb-2">Bill Amount</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-[var(--text-secondary)]">$</span>
                <input type="number" id="billAmount" step="0.01" min="0" placeholder="0.00" 
                       class="w-full pl-8 pr-4 py-3 border border-[var(--border-color)] rounded-lg bg-[var(--bg-color)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] focus:border-transparent">
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium mb-3">Tip Percentage</label>
              <div class="grid grid-cols-5 gap-2 mb-3">
                <button type="button" class="tip-btn py-2 px-3 border border-[var(--border-color)] rounded-lg text-center hover:bg-[var(--accent-color)] hover:text-white transition-colors" data-tip="10">10%</button>
                <button type="button" class="tip-btn py-2 px-3 border border-[var(--border-color)] rounded-lg text-center hover:bg-[var(--accent-color)] hover:text-white transition-colors" data-tip="15">15%</button>
                <button type="button" class="tip-btn py-2 px-3 border border-[var(--border-color)] rounded-lg text-center hover:bg-[var(--accent-color)] hover:text-white transition-colors" data-tip="18">18%</button>
                <button type="button" class="tip-btn py-2 px-3 border border-[var(--border-color)] rounded-lg text-center hover:bg-[var(--accent-color)] hover:text-white transition-colors" data-tip="20">20%</button>
                <button type="button" class="tip-btn py-2 px-3 border border-[var(--border-color)] rounded-lg text-center hover:bg-[var(--accent-color)] hover:text-white transition-colors" data-tip="25">25%</button>
              </div>
              <div class="relative">
                <input type="number" id="customTip" step="0.1" min="0" max="100" placeholder="Custom %"
                       class="w-full px-4 py-3 border border-[var(--border-color)] rounded-lg bg-[var(--bg-color)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] focus:border-transparent">
              </div>
            </div>

            <div>
              <label for="numPeople" class="block text-sm font-medium mb-2">Number of People</label>
              <input type="number" id="numPeople" min="1" value="1"
                     class="w-full px-4 py-3 border border-[var(--border-color)] rounded-lg bg-[var(--bg-color)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] focus:border-transparent">
            </div>
          </div>

          <!-- Results Section -->
          <div class="space-y-6">
            <div class="space-y-4">
              <div class="flex justify-between items-center">
                <span class="text-[var(--text-secondary)]">Tip Amount:</span>
                <span id="tipAmount" class="text-2xl font-bold text-[var(--accent-color)]">$0.00</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-[var(--text-secondary)]">Total Amount:</span>
                <span id="totalAmount" class="text-2xl font-bold">$0.00</span>
              </div>
              <div id="perPersonSection" class="flex justify-between items-center" style="display: none;">
                <span class="text-[var(--text-secondary)]">Per Person:</span>
                <span id="perPersonAmount" class="text-xl font-semibold">$0.00</span>
              </div>
            </div>

            <div id="tipQuality" class="text-center py-3 px-4 rounded-lg bg-[var(--bg-color)] border border-[var(--border-color)]">
              <span class="text-[var(--text-secondary)]">Enter bill amount to see tip quality</span>
            </div>

            <button id="roundUpBtn" class="w-full py-3 px-4 bg-[var(--accent-color)] text-white rounded-lg font-medium hover:opacity-90 transition-opacity" style="display: none;">
              Round Up to <span id="roundedAmount">$0.00</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Content Sections -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Tipping Guide -->
        <div class="bg-[var(--card-bg)] rounded-xl p-6 border border-[var(--border-color)]">
          <h2 class="text-xl font-bold mb-4">How Much Should You Tip?</h2>
          <div class="space-y-3 text-[var(--text-secondary)]">
            <div class="flex justify-between">
              <span>Restaurants (dine-in):</span>
              <span class="font-medium">15-20%</span>
            </div>
            <div class="flex justify-between">
              <span>Food delivery:</span>
              <span class="font-medium">15-20%</span>
            </div>
            <div class="flex justify-between">
              <span>Bars:</span>
              <span class="font-medium">$1-2 per drink</span>
            </div>
            <div class="flex justify-between">
              <span>Taxi/Rideshare:</span>
              <span class="font-medium">15-20%</span>
            </div>
            <div class="flex justify-between">
              <span>Hair salon:</span>
              <span class="font-medium">15-20%</span>
            </div>
            <div class="flex justify-between">
              <span>Hotel housekeeping:</span>
              <span class="font-medium">$1-5 per night</span>
            </div>
          </div>
        </div>

        <!-- Tipping by Country -->
        <div class="bg-[var(--card-bg)] rounded-xl p-6 border border-[var(--border-color)]">
          <h2 class="text-xl font-bold mb-4">Tipping Etiquette by Country</h2>
          <div class="space-y-3 text-[var(--text-secondary)]">
            <div>
              <span class="font-medium text-[var(--text-primary)]">United States:</span>
              <p>15-20% is standard and expected in most service industries.</p>
            </div>
            <div>
              <span class="font-medium text-[var(--text-primary)]">Canada:</span>
              <p>15-20% similar to the US, slightly lower in some provinces.</p>
            </div>
            <div>
              <span class="font-medium text-[var(--text-primary)]">Europe:</span>
              <p>5-10% or round up. Service charge often included.</p>
            </div>
            <div>
              <span class="font-medium text-[var(--text-primary)]">Australia/New Zealand:</span>
              <p>Tipping not required, 10% for excellent service.</p>
            </div>
            <div>
              <span class="font-medium text-[var(--text-primary)]">Japan:</span>
              <p>Tipping not customary and may be considered rude.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Mental Math Guide -->
      <div class="bg-[var(--card-bg)] rounded-xl p-6 border border-[var(--border-color)] mt-8">
        <h2 class="text-xl font-bold mb-4">How to Calculate a Tip in Your Head</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-[var(--text-secondary)]">
          <div>
            <h3 class="font-medium text-[var(--text-primary)] mb-2">10% Tip</h3>
            <p>Move the decimal point one place to the left. $50.00 → $5.00</p>
          </div>
          <div>
            <h3 class="font-medium text-[var(--text-primary)] mb-2">15% Tip</h3>
            <p>Calculate 10%, then add half. $50.00 → $5.00 + $2.50 = $7.50</p>
          </div>
          <div>
            <h3 class="font-medium text-[var(--text-primary)] mb-2">20% Tip</h3>
            <p>Calculate 10% and double it. $50.00 → $5.00 × 2 = $10.00</p>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div class="bg-[var(--card-bg)] rounded-xl p-6 border border-[var(--border-color)] mt-8">
        <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3">
          <details class="border-b border-[var(--border-color)] pb-3">
            <summary class="cursor-pointer font-medium text-[var(--text-primary)] hover:text-[var(--accent-color)]">How much should I tip at a restaurant?</summary>
            <p class="mt-2 text-[var(--text-secondary)]">For restaurants, the standard tip is 15-20% of the total bill before tax. 18% is commonly considered appropriate for good service.</p>
          </details>
          <details class="border-b border-[var(--border-color)] pb-3">
            <summary class="cursor-pointer font-medium text-[var(--text-primary)] hover:text-[var(--accent-color)]">How do you calculate a 20% tip?</summary>
            <p class="mt-2 text-[var(--text-secondary)]">To calculate a 20% tip mentally, move the decimal point one place to the left (10%) and multiply by 2. For $50.00: $5.00 × 2 = $10.00 tip.</p>
          </details>
          <details class="border-b border-[var(--border-color)] pb-3">
            <summary class="cursor-pointer font-medium text-[var(--text-primary)] hover:text-[var(--accent-color)]">Should I tip on the pre-tax or post-tax amount?</summary>
            <p class="mt-2 text-[var(--text-secondary)]">It's generally acceptable to tip on either the pre-tax or post-tax amount. Most people tip on the pre-tax total, but tipping on the full amount including tax is also common and appreciated.</p>
          </details>
          <details class="border-b border-[var(--border-color)] pb-3">
            <summary class="cursor-pointer font-medium text-[var(--text-primary)] hover:text-[var(--accent-color)]">How do I split a tip between multiple people?</summary>
            <p class="mt-2 text-[var(--text-secondary)]">Calculate the total tip amount first, then divide by the number of people. Our tip calculator automatically shows the per-person amount when you enter the number of people splitting the bill.</p>
          </details>
          <details class="pb-3">
            <summary class="cursor-pointer font-medium text-[var(--text-primary)] hover:text-[var(--accent-color)]">Is it okay to round up the tip?</summary>
            <p class="mt-2 text-[var(--text-secondary)]">Yes, rounding up the total amount to the nearest dollar is perfectly acceptable and often appreciated. It makes the math easier and shows generosity.</p>
          </details>
        </div>
      </div>
    </div>
  </div>

  <script>
    // DOM elements
    const billAmountInput = document.getElementById('billAmount');
    const customTipInput = document.getElementById('customTip');
    const numPeopleInput = document.getElementById('numPeople');
    const tipButtons = document.querySelectorAll('.tip-btn');
    const tipAmountDisplay = document.getElementById('tipAmount');
    const totalAmountDisplay = document.getElementById('totalAmount');
    const perPersonAmountDisplay = document.getElementById('perPersonAmount');
    const perPersonSection = document.getElementById('perPersonSection');
    const tipQualityDisplay = document.getElementById('tipQuality');
    const roundUpBtn = document.getElementById('roundUpBtn');
    const roundedAmountDisplay = document.getElementById('roundedAmount');

    let currentTipPercent = 0;
    let billAmount = 0;
    let numPeople = 1;

    function calculateTip() {
      billAmount = parseFloat(billAmountInput.value) || 0;
      numPeople = parseInt(numPeopleInput.value) || 1;

      if (billAmount === 0) {
        tipAmountDisplay.textContent = '$0.00';
        totalAmountDisplay.textContent = '$0.00';
        perPersonAmountDisplay.textContent = '$0.00';
        tipQualityDisplay.innerHTML = '<span class="text-[var(--text-secondary)]">Enter bill amount to see tip quality</span>';
        roundUpBtn.style.display = 'none';
        perPersonSection.style.display = 'none';
        return;
      }

      const tipAmount = (billAmount * currentTipPercent) / 100;
      const totalAmount = billAmount + tipAmount;
      const perPersonAmount = totalAmount / numPeople;

      // Update displays
      tipAmountDisplay.textContent = '$' + tipAmount.toFixed(2);
      totalAmountDisplay.textContent = '$' + totalAmount.toFixed(2);
      perPersonAmountDisplay.textContent = '$' + perPersonAmount.toFixed(2);

      // Show/hide per person section
      perPersonSection.style.display = numPeople > 1 ? 'flex' : 'none';

      // Update tip quality indicator
      updateTipQuality(currentTipPercent);

      // Update round up button
      updateRoundUpButton(totalAmount);
    }

    function updateTipQuality(tipPercent) {
      let quality = '';
      let bgClass = 'bg-[var(--bg-color)]';
      
      if (tipPercent === 0) {
        quality = 'No tip';
        tipQualityDisplay.style.backgroundColor = 'var(--bg-color)';
      } else if (tipPercent < 15) {
        quality = 'Below Standard';
        tipQualityDisplay.style.backgroundColor = '#fee2e2';
      } else if (tipPercent < 18) {
        quality = 'Standard';
        tipQualityDisplay.style.backgroundColor = '#fef3cd';
      } else if (tipPercent < 22) {
        quality = 'Good';
        tipQualityDisplay.style.backgroundColor = '#d1f2eb';
      } else {
        quality = 'Very Generous';
        tipQualityDisplay.style.backgroundColor = '#d1f2eb';
      }

      tipQualityDisplay.innerHTML = '<span class="font-medium">' + quality + '</span>';
    }

    function updateRoundUpButton(totalAmount) {
      const roundedAmount = Math.ceil(totalAmount);
      if (roundedAmount > totalAmount && totalAmount > 0) {
        roundedAmountDisplay.textContent = '$' + roundedAmount.toFixed(2);
        roundUpBtn.style.display = 'block';
      } else {
        roundUpBtn.style.display = 'none';
      }
    }

    function setTipPercent(percent) {
      currentTipPercent = percent;
      customTipInput.value = percent > 0 ? percent.toString() : '';
      
      // Update button states
      tipButtons.forEach(btn => {
        const btnPercent = parseFloat(btn.dataset.tip);
        if (btnPercent === percent) {
          btn.style.backgroundColor = 'var(--accent-color)';
          btn.style.color = 'white';
        } else {
          btn.style.backgroundColor = '';
          btn.style.color = '';
        }
      });

      calculateTip();
    }

    // Event listeners
    billAmountInput.addEventListener('input', calculateTip);
    numPeopleInput.addEventListener('input', calculateTip);

    customTipInput.addEventListener('input', function() {
      const customPercent = parseFloat(this.value) || 0;
      setTipPercent(customPercent);
    });

    tipButtons.forEach(btn => {
      btn.addEventListener('click', function() {
        const tipPercent = parseFloat(this.dataset.tip);
        setTipPercent(tipPercent);
      });
    });

    roundUpBtn.addEventListener('click', function() {
      const currentTotal = billAmount + (billAmount * currentTipPercent / 100);
      const roundedTotal = Math.ceil(currentTotal);
      const newTipAmount = roundedTotal - billAmount;
      const newTipPercent = (newTipAmount / billAmount) * 100;
      
      customTipInput.value = newTipPercent.toFixed(1);
      setTipPercent(newTipPercent);
    });

    // Initialize with 18% tip
    setTipPercent(18);
  </script>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="https://sendnerds.photonbuilder.com/tip-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Tip Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Stop guessing! Calculate your tip and split the bill instantly. See exact tip amounts, total cost, and per-person breakd...</p>
      </a>
      <a href="https://sendnerds.photonbuilder.com/percent-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Percentage Calculator Toolkit</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Instantly calculate percent changes, find what percentage one number is of another, and determine exact percent yields.</p>
      </a>
      <a href="https://sendnerds.photonbuilder.com/percentage-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Percentage Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Stop struggling with percentage formulas. Instantly calculate percentage increases, decreases, or find out exactly what ...</p>
      </a>
    </div>
  </div>
</SiteLayout>