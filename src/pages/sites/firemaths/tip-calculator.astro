---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Tip Calculator",
  "url": "https://firemaths.info/tip-calculator",
  "description": "Calculate tips and split bills with preset percentages and easy rounding.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<SiteLayout
  site="firemaths"
  title="Tip Calculator | Fire Maths"
  description="Calculate tips and split the bill easily. Preset percentages, custom inputs, and rounding up for easy splitting."
  canonical="https://firemaths.info/tip-calculator"
  schema={schema}
>
  <style>
    .calculator-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .scenario-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .tip-buttons {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    @media (min-width: 480px) {
      .tip-buttons {
        grid-template-columns: repeat(5, 1fr);
      }
    }

    .tip-btn {
      background-color: var(--bg-color);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.75rem 0.25rem;
      border-radius: 6px;
      font-family: var(--font-mono);
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
      text-align: center;
    }

    .tip-btn:hover {
      border-color: var(--accent-color);
    }

    .tip-btn.active {
      background-color: var(--accent-color);
      color: var(--bg-color);
      border-color: var(--accent-color);
      font-weight: 600;
    }

    .custom-tip-wrapper {
      grid-column: span 2;
    }

    @media (min-width: 480px) {
      .custom-tip-wrapper {
        grid-column: span 1;
      }
    }

    .custom-tip-input {
      width: 100%;
      height: 100%;
      background-color: var(--bg-color);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      font-family: var(--font-mono);
      font-size: 1rem;
      padding: 0;
      text-align: center;
      border-radius: 6px;
      transition: border-color 0.2s;
      -moz-appearance: textfield;
    }

    .custom-tip-input:focus {
      outline: none;
      border-color: var(--accent-color);
    }

    .custom-tip-input.active {
      border-color: var(--accent-color);
    }

    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      cursor: pointer;
      margin-top: 1.5rem;
      padding: 1rem;
      background-color: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      transition: border-color 0.2s;
    }

    .checkbox-group:hover {
      border-color: var(--text-secondary);
    }

    .checkbox-group input[type="checkbox"] {
      width: 1.25rem;
      height: 1.25rem;
      accent-color: var(--accent-color);
      cursor: pointer;
    }

    .checkbox-group span {
      font-size: 0.875rem;
      color: var(--text-primary);
    }

    .results {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-color);
    }

    .result-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .result-label {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    .result-value {
      font-family: var(--font-mono);
      font-size: 1.125rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .result-final .result-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent-color);
    }

    .result-sub {
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: -0.25rem;
      display: block;
    }

    .copy-btn {
      background: none;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      cursor: pointer;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-family: var(--font-ui);
      transition: all 0.2s;
    }

    .copy-btn:hover {
      border-color: var(--accent-color);
      color: var(--text-primary);
    }

    .seo-content h2 {
      font-size: 1.75rem;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      color: var(--accent-color);
    }

    .seo-content p {
      margin-bottom: 1rem;
      color: var(--text-secondary);
    }

    .seo-content ul {
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
      color: var(--text-secondary);
    }

    .seo-content li {
      margin-bottom: 0.5rem;
    }
  </style>

  <div class="container">
    <h1>Tip Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); margin-bottom:2rem;">Calculate tips and split the bill easily.</p>

    <div class="calculator-grid">
      <div class="scenario-card" id="tip-calculator">
        <div class="inputs">
          <div class="input-group">
            <label for="bill-amount">Bill Amount</label>
            <div class="input-wrapper">
              <span class="suffix" style="left:1rem;right:auto;">$</span>
              <input type="number" id="bill-amount" value="100.00" min="0" step="0.01" style="padding-left:2rem;">
            </div>
          </div>

          <div class="input-group">
            <label>Tip Percentage</label>
            <div class="tip-buttons" id="tip-buttons">
              <button class="tip-btn" data-tip="10">10%</button>
              <button class="tip-btn" data-tip="15">15%</button>
              <button class="tip-btn active" data-tip="18">18%</button>
              <button class="tip-btn" data-tip="20">20%</button>
              <div class="custom-tip-wrapper">
                <input type="number" id="custom-tip" class="custom-tip-input" placeholder="Custom %" min="0" max="100" step="1">
              </div>
            </div>
          </div>

          <div class="input-group">
            <label for="num-people">Number of People</label>
            <div class="input-wrapper">
              <input type="number" id="num-people" value="1" min="1" step="1">
            </div>
          </div>

          <label class="checkbox-group">
            <input type="checkbox" id="round-up">
            <span>Round Up Total Bill</span>
          </label>
        </div>

        <div class="results">
          <div class="result-item">
            <div>
              <span class="result-label">Tip Amount</span>
              <span class="result-sub" id="tip-per-person-label"></span>
            </div>
            <span class="result-value" id="tip-amount">$0.00</span>
          </div>
          <div class="result-item">
            <span class="result-label">Total Bill</span>
            <div class="result-value">
              <span id="total-bill">$0.00</span>
            </div>
          </div>
          <div class="result-item result-final">
            <span class="result-label">Amount Per Person</span>
            <div class="result-value">
              <span id="amount-per-person">$0.00</span>
              <button class="copy-btn" id="copy-btn">Copy</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="seo-content">
      <h2>How to Use the Tip Calculator</h2>
      <p>Our free tip calculator makes it easy to quickly figure out how much you should leave for a tip and what your final bill will be. It's especially useful when dining out with a group and needing to split the bill evenly.</p>
      <p>Simply enter your total bill amount before tip, choose a standard tip percentage or enter your own custom amount, and indicate how many people are splitting the bill. If you select the "Round Up Total Bill" option, the calculator will automatically adjust the total tip to ensure your final bill amount is a clean, whole dollar amount.</p>

      <h2>Standard Tipping Etiquette</h2>
      <ul>
        <li><strong>15% to 20%:</strong> The standard tipping range for sit-down restaurants with good service.</li>
        <li><strong>10% to 15%:</strong> For buffet restaurants or situations where the server does less active table service.</li>
        <li><strong>10% or less:</strong> Generally reserved for poor service.</li>
        <li><strong>Takeout / Coffee Shops:</strong> Tipping is optional, but 10% or a few dollars is appreciated for large orders.</li>
      </ul>
    </div>
  </div>

  <script is:inline>
    const formatCurrency = (value) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency', currency: 'USD',
        maximumFractionDigits: 2, minimumFractionDigits: 2
      }).format(value);
    };

    const billInput = document.getElementById('bill-amount');
    const tipBtns = document.querySelectorAll('.tip-btn');
    const customTipInput = document.getElementById('custom-tip');
    const numPeopleInput = document.getElementById('num-people');
    const roundUpCheck = document.getElementById('round-up');
    const tipAmountEl = document.getElementById('tip-amount');
    const totalBillEl = document.getElementById('total-bill');
    const amountPerPersonEl = document.getElementById('amount-per-person');
    const tipPerPersonLabelEl = document.getElementById('tip-per-person-label');

    let currentTipPercentage = 18;

    const updateCalculator = () => {
      const bill = parseFloat(billInput.value) || 0;
      let people = parseInt(numPeopleInput.value) || 1;
      if (people < 1) people = 1;
      const roundUp = roundUpCheck.checked;

      let tipAmount = bill * (currentTipPercentage / 100);
      let totalBill = bill + tipAmount;

      if (roundUp && totalBill > 0) {
        const roundedTotal = Math.ceil(totalBill);
        tipAmount = roundedTotal - bill;
        totalBill = roundedTotal;
      }

      const tipPerPerson = tipAmount / people;
      const totalPerPerson = totalBill / people;

      tipAmountEl.innerText = formatCurrency(tipAmount);
      totalBillEl.innerText = formatCurrency(totalBill);
      amountPerPersonEl.innerText = formatCurrency(totalPerPerson);
      tipPerPersonLabelEl.innerText = people > 1 ? `(${formatCurrency(tipPerPerson)} / person)` : '';
    };

    billInput.addEventListener('input', updateCalculator);
    numPeopleInput.addEventListener('input', updateCalculator);
    roundUpCheck.addEventListener('change', updateCalculator);

    tipBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        tipBtns.forEach(b => b.classList.remove('active'));
        customTipInput.classList.remove('active');
        customTipInput.value = '';
        e.target.classList.add('active');
        currentTipPercentage = parseFloat(e.target.dataset.tip);
        updateCalculator();
      });
    });

    customTipInput.addEventListener('input', (e) => {
      const val = parseFloat(e.target.value);
      if (!isNaN(val)) {
        tipBtns.forEach(b => b.classList.remove('active'));
        customTipInput.classList.add('active');
        currentTipPercentage = val;
        updateCalculator();
      }
    });

    document.getElementById('copy-btn').addEventListener('click', async function() {
      const text = amountPerPersonEl.innerText;
      try {
        await navigator.clipboard.writeText(text);
        this.innerText = 'Copied!';
        setTimeout(() => { this.innerText = 'Copy'; }, 2000);
      } catch (err) { console.error('Failed to copy:', err); }
    });

    updateCalculator();
  </script>
</SiteLayout>
