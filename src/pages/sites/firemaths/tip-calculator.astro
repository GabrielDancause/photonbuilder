  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let currentTipPct = 20;

window.setTip = (pct) => {
    currentTipPct = pct;
    document.getElementById('custom-tip').value = pct;
    document.querySelectorAll('.quick-tip-btn').forEach(b => b.classList.remove('active'));
    const btn = document.getElementById('tip-' + pct);
    if (btn) btn.classList.add('active');
    updateAll();
};

window.copyValue = async (elementId, btn) => {
    const text = document.getElementById(elementId).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => { btn.innerText = orig; }, 2000);
    } catch (err) { /* noop */ }
};

window.toggleFaq = (btn) => {
    btn.parentElement.classList.toggle('open');
};

function getBillBase() {
    const bill = parseFloat(document.getElementById('bill-amount').value) || 0;
    const preTaxOn = document.getElementById('pretax-toggle').checked;
    const tax = parseFloat(document.getElementById('tax-amount').value) || 0;
    return {
        bill,
        tipBase: preTaxOn ? Math.max(0, bill - tax) : bill,
        tax: preTaxOn ? tax : 0
    };
}

function calcTip(tipBase, tipPct, bill, splitCount, roundUp) {
    let tipAmount = tipBase * (tipPct / 100);
    let total = bill + tipAmount;

    if (roundUp) {
        total = Math.ceil(total);
        tipAmount = total - bill;
    }

    const perPersonTotal = total / splitCount;
    const perPersonTip = tipAmount / splitCount;
    const perPersonShare = bill / splitCount;

    return {
        tipAmount,
        total,
        tipPct: bill > 0 ? (tipAmount / bill) * 100 : 0,
        effectivePct: tipBase > 0 ? (tipAmount / tipBase) * 100 : 0,
        perPersonTotal,
        perPersonTip,
        perPersonShare,
        splitCount
    };
}

function updateAll() {
    const { bill, tipBase } = getBillBase();
    const tipPct = parseFloat(document.getElementById('custom-tip').value) || 0;
    const splitCount = Math.max(1, parseInt(document.getElementById('split-count').value) || 1);
    const roundUp = document.getElementById('round-up-toggle').checked;

    currentTipPct = tipPct;

    // Highlight matching quick-tip button
    document.querySelectorAll('.quick-tip-btn').forEach(b => b.classList.remove('active'));
    const matchBtn = document.getElementById('tip-' + tipPct);
    if (matchBtn) matchBtn.classList.add('active');

    const r = calcTip(tipBase, tipPct, bill, splitCount, roundUp);

    // Results
    document.getElementById('total-with-tip').innerText = fmt2(r.total);
    document.getElementById('display-bill').innerText = fmt2(bill);
    document.getElementById('tip-amount').innerText = fmt2(r.tipAmount);
    document.getElementById('display-tip-pct').innerText = r.effectivePct.toFixed(1) + '%';

    // Per person
    const perPersonSection = document.getElementById('per-person-section');
    const splitBreakdown = document.getElementById('split-breakdown');

    if (splitCount > 1) {
        perPersonSection.style.display = 'block';
        document.getElementById('per-person-total').innerText = fmt2(r.perPersonTotal);
        document.getElementById('per-person-tip').innerText = fmt2(r.perPersonTip);

        // Split breakdown table
        splitBreakdown.style.display = 'block';
        const tbody = document.getElementById('split-tbody');
        tbody.innerHTML = '';
        for (let i = 1; i <= splitCount; i++) {
            const tr = document.createElement('tr');
            tr.innerHTML = '<td>' + i + '</td><td>' + fmt2(r.perPersonShare) + '</td><td>' + fmt2(r.perPersonTip) + '</td><td style="font-weight:600;color:var(--accent-color);">' + fmt2(r.perPersonTotal) + '</td>';
            tbody.appendChild(tr);
        }
    } else {
        perPersonSection.style.display = 'none';
        splitBreakdown.style.display = 'none';
    }

    // Comparison table
    updateComparison(tipBase, bill, splitCount, roundUp);
}

function updateComparison(tipBase, bill, splitCount, roundUp) {
    const pcts = [10, 15, 18, 20, 22, 25, 30];
    const tbody = document.getElementById('comparison-tbody');
    tbody.innerHTML = '';

    pcts.forEach(pct => {
        const r = calcTip(tipBase, pct, bill, splitCount, false);
        const isActive = pct === currentTipPct;
        const tr = document.createElement('tr');
        if (isActive) tr.classList.add('highlight-row');
        tr.innerHTML = '<td>' + pct + '%</td><td>' + fmt2(r.tipAmount) + '</td><td>' + fmt2(r.total) + '</td><td>' + fmt2(r.perPersonTotal) + '</td>';
        tbody.appendChild(tr);
    });
}

// Pre-tax toggle
document.getElementById('pretax-toggle').addEventListener('change', function() {
    document.getElementById('pretax-fields').classList.toggle('visible', this.checked);
    updateAll();
});

// Event listeners
document.getElementById('bill-amount').addEventListener('input', updateAll);
document.getElementById('custom-tip').addEventListener('input', function() {
    currentTipPct = parseFloat(this.value) || 0;
    document.querySelectorAll('.quick-tip-btn').forEach(b => b.classList.remove('active'));
    const matchBtn = document.getElementById('tip-' + currentTipPct);
    if (matchBtn) matchBtn.classList.add('active');
    updateAll();
});
document.getElementById('split-count').addEventListener('input', updateAll);
document.getElementById('round-up-toggle').addEventListener('change', updateAll);
document.getElementById('tax-amount').addEventListener('input', updateAll);

// Init
updateAll();
  </script>
