---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Tip Calculator",
  "url": "https://firemaths.info/tip-calculator",
  "description": "Free tip calculator — quickly figure out how much to tip, split the bill, compare tip percentages, and see per-person amounts for any group size.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much should you tip at a restaurant?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard tip at a restaurant in the United States is 15–20% of the pre-tax bill. For excellent service, 20–25% is customary. At fine dining establishments, 20% is generally the minimum. If you received poor service, 10–15% is still expected unless the experience was truly unacceptable. Always tip on the pre-tax subtotal, not the total that includes sales tax."
      }
    },
    {
      "@type": "Question",
      "name": "Should you tip on the pre-tax or post-tax amount?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Etiquette experts recommend tipping on the pre-tax subtotal, not the amount that includes sales tax. Sales tax rates vary by location (from 0% to over 10%), so tipping on the post-tax total means you'd effectively be tipping on the tax itself. However, many people tip on the total for simplicity — the difference is usually small on typical bills."
      }
    },
    {
      "@type": "Question",
      "name": "How much do you tip for delivery?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For food delivery, tip 15–20% of the order total, with a minimum of $3–5 for small orders. For large or complex orders, tip closer to 20%. If the weather is bad, the delivery is far, or the driver had to climb stairs, consider tipping more. For grocery delivery, 15–20% or $5 minimum is standard. Most delivery drivers rely heavily on tips for their income."
      }
    },
    {
      "@type": "Question",
      "name": "How do you split a tip among a group?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To split a tip evenly, calculate the total tip on the full bill, then divide by the number of people. For example, on a $120 bill with a 20% tip, the tip is $24, so each person in a group of 4 pays $6 in tip ($36 total per person including their share of the bill). Some groups prefer to have each person tip on their own items instead of splitting evenly."
      }
    },
    {
      "@type": "Question",
      "name": "How much should you tip a hairdresser or barber?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard tip for a hairdresser, barber, or salon professional is 15–20% of the service cost. For exceptional service, coloring, or complex styling, 20–25% is appropriate. If multiple stylists work on your hair (e.g., a colorist and a stylist), tip each person separately. It's also customary to tip the shampoo person $3–5."
      }
    },
    {
      "@type": "Question",
      "name": "Do you tip on takeout orders?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tipping on takeout is not traditionally required, but has become more common since 2020. A tip of 10–15% is a generous gesture for takeout, especially for large or complex orders. If the restaurant staff packaged your order carefully, included extras, or you're a regular customer, tipping shows appreciation. Many point-of-sale systems now prompt for tips on takeout."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a tip and a gratuity?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A tip and a gratuity are essentially the same thing — both refer to extra money given to a service worker beyond the bill amount. However, 'gratuity' is sometimes used for mandatory charges added to the bill (e.g., 18% auto-gratuity for large parties), while 'tip' usually implies a voluntary amount. Mandatory gratuities are common for groups of 6 or more at restaurants."
      }
    },
    {
      "@type": "Question",
      "name": "How much should you tip a taxi or rideshare driver?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For taxi drivers, tip 15–20% of the fare, with a minimum of $2–3 for short rides. For rideshare services like Uber and Lyft, 15–20% or $2–5 is standard. Tip more if the driver helped with luggage, navigated difficult traffic, or provided excellent service. For airport rides or long trips, 15–20% of the total fare is customary."
      }
    },
    {
      "@type": "Question",
      "name": "Is it rude not to tip in the United States?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In the United States, not tipping for table service at a restaurant is considered very rude, as servers typically earn a base wage of $2.13–$5.00 per hour and depend on tips for most of their income. For other services like delivery, salon visits, and taxis, tipping is strongly expected. The only situations where not tipping is acceptable are counter service, fast food, and self-service establishments."
      }
    }
  ]
};

export const meta = {
  title: "Tip Calculator — How Much to Tip | firemaths.info",
  description: "Free tip calculator — figure out how much to tip, split the bill between friends, compare tip percentages side by side, and round up to the nearest dollar.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Tip Calculator — How Much to Tip | firemaths.info"
  description="Free tip calculator — figure out how much to tip, split the bill between friends, compare tip percentages side by side, and round up to the nearest dollar."
  canonical="https://firemaths.info/tip-calculator" schema={schema}
>
  <style>
:root {
    --chart-color-a: #4A90E2;
    --chart-color-b: #E85D75;
    --chart-color-c: #50E3C2;
    --chart-color-d: #D4A017;
    --chart-color-e: #9B59B6;
    --chart-color-f: #F39C12;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.quick-tip-row {
    display: flex;
    gap: 0;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border-color);
}

.quick-tip-btn {
    flex: 1;
    padding: 0.6rem 0.5rem;
    background: var(--bg-color);
    border: none;
    color: var(--text-secondary);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.quick-tip-btn.active {
    background: var(--accent-color);
    color: #000;
}

.quick-tip-btn:not(:last-child) {
    border-right: 1px solid var(--border-color);
}

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.comparison-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 3rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
}

.comparison-table th, .comparison-table td {
    padding: 1rem 1.25rem;
    text-align: right;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border-color);
}

.comparison-table th {
    background-color: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.comparison-table th:first-child, .comparison-table td:first-child {
    text-align: left;
}

.comparison-table tr:last-child td {
    border-bottom: none;
}

.comparison-table .highlight-row td {
    font-weight: 700;
    color: var(--accent-color);
    background-color: var(--bg-color);
}

.split-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
    background-color: var(--bg-color);
    border-radius: 8px;
    overflow: hidden;
}

.split-table th, .split-table td {
    padding: 0.6rem 0.75rem;
    font-size: 0.85rem;
    border-bottom: 1px solid var(--border-color);
    text-align: right;
}

.split-table th {
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.split-table th:first-child, .split-table td:first-child {
    text-align: left;
}

.split-table tr:last-child td {
    border-bottom: none;
}

.option-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding: 0.75rem 0;
}

.option-row label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.switch {
    position: relative;
    width: 40px;
    height: 22px;
    flex-shrink: 0;
}

.switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: var(--border-color);
    border-radius: 22px;
    transition: 0.2s;
}

.slider::before {
    content: "";
    position: absolute;
    height: 16px;
    width: 16px;
    left: 3px;
    bottom: 3px;
    background-color: var(--text-primary);
    border-radius: 50%;
    transition: 0.2s;
}

.switch input:checked + .slider {
    background-color: var(--accent-color);
}

.switch input:checked + .slider::before {
    transform: translateX(18px);
    background-color: #000;
}

.tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .tips-grid {
        grid-template-columns: 1fr;
    }
}

.tip-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.tip-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.tip-card ul {
    list-style: none;
    padding: 0;
}

.tip-card li {
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
}

.tip-card li::before {
    content: "\203A";
    position: absolute;
    left: 0;
    color: var(--accent-color);
    font-weight: bold;
}

.guide-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 3rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
}

.guide-table th, .guide-table td {
    padding: 1rem 1.25rem;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border-color);
    text-align: left;
}

.guide-table th {
    background-color: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.guide-table tr:last-child td {
    border-bottom: none;
}

.guide-table td:nth-child(2) {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent-color);
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "\2212";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}

.pretax-fields {
    display: none;
    margin-top: 0.5rem;
}

.pretax-fields.visible {
    display: block;
}

@media (max-width: 640px) {
    .comparison-table {
        font-size: 0.8rem;
    }
    .comparison-table th, .comparison-table td {
        padding: 0.65rem 0.5rem;
    }
    .guide-table {
        font-size: 0.8rem;
    }
    .guide-table th, .guide-table td {
        padding: 0.65rem 0.5rem;
    }
}
  </style>

<div class="container">
    <h1>Tip Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Figure out how much to tip, split the bill, and compare tip percentages</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Bill Details</h2>
                </div>

                <div class="inputs">
                    <div class="input-group">
                        <label for="bill-amount">Bill Amount</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="bill-amount" value="85" min="0" step="0.01">
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Tip Percentage</label>
                        <div class="quick-tip-row">
                            <button class="quick-tip-btn" onclick="setTip(15)" id="tip-15">15%</button>
                            <button class="quick-tip-btn" onclick="setTip(18)" id="tip-18">18%</button>
                            <button class="quick-tip-btn active" onclick="setTip(20)" id="tip-20">20%</button>
                            <button class="quick-tip-btn" onclick="setTip(25)" id="tip-25">25%</button>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="custom-tip">Custom Tip</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="custom-tip" value="20" min="0" max="100" step="1">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="split-count">Split Between</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">people</span>
                            <input type="number" id="split-count" value="1" min="1" max="99" step="1" style="padding-right: 4.5rem;">
                        </div>
                    </div>

                    <div style="border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: 0.5rem;">
                        <div class="option-row">
                            <label for="round-up-toggle">Round up total to nearest dollar</label>
                            <div class="switch">
                                <input type="checkbox" id="round-up-toggle">
                                <span class="slider"></span>
                            </div>
                        </div>

                        <div class="option-row">
                            <label for="pretax-toggle">Tip on pre-tax amount</label>
                            <div class="switch">
                                <input type="checkbox" id="pretax-toggle">
                                <span class="slider"></span>
                            </div>
                        </div>

                        <div class="pretax-fields" id="pretax-fields">
                            <div class="input-group">
                                <label for="tax-amount">Tax Amount</label>
                                <div class="input-wrapper has-prefix">
                                    <span class="prefix">$</span>
                                    <input type="number" id="tax-amount" value="0" min="0" step="0.01">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Tip &amp; Total</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Total with Tip</span>
                        <div class="result-value">
                            <span id="total-with-tip">$0</span>
                            <button class="copy-btn" onclick="copyValue('total-with-tip', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Bill Amount</span>
                        <span class="result-value" id="display-bill" style="font-size: 1rem;">$0</span>
                    </div>

                    <div class="result-item" style="color: var(--chart-color-c);">
                        <span class="result-label">Tip Amount</span>
                        <span class="result-value" id="tip-amount" style="font-size: 1.15rem; font-weight: 700; color: var(--chart-color-c);">$0</span>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Tip Percentage</span>
                        <span class="result-value" id="display-tip-pct" style="font-size: 0.9rem; font-family: var(--font-ui); color: var(--text-secondary);">0%</span>
                    </div>

                    <div style="flex-grow: 1;"></div>

                    <div id="per-person-section" style="display: none; padding-top: 1rem; border-top: 1px dashed var(--border-color);">
                        <div class="result-item result-final">
                            <span class="result-label" style="font-size: 1rem;">Per Person</span>
