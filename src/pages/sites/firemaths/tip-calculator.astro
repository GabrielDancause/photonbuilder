---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Tip Calculator",
  "url": "https://firemaths.info/tip-calculator",
  "description": "Calculate tips and split bills with preset percentages and easy rounding.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<SiteLayout
  site="firemaths"
  title="Tip Calculator | Fire Maths"
  description="Calculate tips and split the bill easily. Preset percentages, custom inputs, and rounding up for easy splitting."
  canonical="https://firemaths.info/tip-calculator"
  schema={schema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-4xl font-bold text-center mb-4 text-[var(--accent-color)]">Tip Calculator</h1>
    <p class="text-center text-[var(--text-secondary)] mb-8">Calculate tips and split the bill easily.</p>

    <div class="grid grid-cols-1 gap-8 mb-12 max-w-xl mx-auto calculator-grid">
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 scenario-card" id="tip-calculator">
        <div class="space-y-4 inputs">
          <div class="flex flex-col gap-2 input-group">
            <label for="bill-amount" class="text-sm font-semibold text-[var(--text-secondary)]">Bill Amount</label>
            <div class="relative flex items-center w-full input-wrapper">
              <span class="absolute left-4 text-[var(--text-secondary)] font-mono">$</span>
              <input type="number" id="bill-amount" value="100.00" min="0" step="0.01" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white px-4 py-3 pl-8 rounded-lg font-mono focus:outline-none focus:border-[var(--accent-color)]">
            </div>
          </div>

          <div class="flex flex-col gap-2 input-group">
            <label class="text-sm font-semibold text-[var(--text-secondary)]">Tip Percentage</label>
            <div class="grid grid-cols-3 sm:grid-cols-5 gap-2 mb-2 tip-buttons" id="tip-buttons">
              <button class="tip-btn bg-[var(--bg-color)] border border-[var(--border-color)] text-white px-1 py-3 rounded-md font-mono text-base text-center cursor-pointer transition-colors hover:border-[var(--accent-color)]" data-tip="10">10%</button>
              <button class="tip-btn bg-[var(--bg-color)] border border-[var(--border-color)] text-white px-1 py-3 rounded-md font-mono text-base text-center cursor-pointer transition-colors hover:border-[var(--accent-color)]" data-tip="15">15%</button>
              <button class="tip-btn bg-[var(--accent-color)] text-[var(--bg-color)] border border-[var(--accent-color)] font-semibold px-1 py-3 rounded-md font-mono text-base text-center cursor-pointer transition-colors hover:border-[var(--accent-color)]" data-tip="18">18%</button>
              <button class="tip-btn bg-[var(--bg-color)] border border-[var(--border-color)] text-white px-1 py-3 rounded-md font-mono text-base text-center cursor-pointer transition-colors hover:border-[var(--accent-color)]" data-tip="20">20%</button>
              <div class="col-span-2 sm:col-span-1 custom-tip-wrapper">
                <input type="number" id="custom-tip" class="custom-tip-input w-full h-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-0 text-center rounded-md transition-colors focus:outline-none focus:border-[var(--accent-color)] [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" placeholder="Custom %" min="0" max="100" step="1">
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-2 input-group">
            <label for="num-people" class="text-sm font-semibold text-[var(--text-secondary)]">Number of People</label>
            <div class="relative flex items-center w-full input-wrapper">
              <input type="number" id="num-people" value="1" min="1" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white px-4 py-3 rounded-lg font-mono focus:outline-none focus:border-[var(--accent-color)]">
            </div>
          </div>

          <label class="flex items-center gap-3 cursor-pointer mt-6 p-4 bg-[var(--bg-color)] border border-[var(--border-color)] rounded-md transition-colors hover:border-[var(--text-secondary)] checkbox-group">
            <input type="checkbox" id="round-up" class="w-5 h-5 accent-[var(--accent-color)] cursor-pointer">
            <span class="text-sm text-white">Round Up Total Bill</span>
          </label>
        </div>

        <div class="mt-8 pt-6 border-t border-[var(--border-color)] results">
          <div class="flex justify-between items-center mb-4 result-item">
            <div>
              <span class="text-sm text-[var(--text-secondary)] result-label">Tip Amount</span>
              <span class="block text-xs text-[var(--text-secondary)] -mt-1 result-sub" id="tip-per-person-label"></span>
            </div>
            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white result-value" id="tip-amount">$0.00</span>
          </div>
          <div class="flex justify-between items-center mb-4 result-item">
            <span class="text-sm text-[var(--text-secondary)] result-label">Total Bill</span>
            <div class="font-mono text-lg font-medium flex items-center gap-2 text-white result-value">
              <span id="total-bill">$0.00</span>
            </div>
          </div>
          <div class="flex justify-between items-center mb-4 result-final">
            <span class="text-sm text-[var(--text-secondary)] result-label">Amount Per Person</span>
            <div class="font-mono text-2xl font-bold flex items-center gap-2 text-[var(--accent-color)] result-value">
              <span id="amount-per-person">$0.00</span>
              <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer px-2 py-1 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white copy-btn" id="copy-btn">Copy</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="seo-content mt-12">
      <h2 class="text-2xl mt-10 mb-4 text-[var(--accent-color)] font-bold">How to Use the Tip Calculator</h2>
      <p class="mb-4 text-[var(--text-secondary)]">Our free tip calculator makes it easy to quickly figure out how much you should leave for a tip and what your final bill will be. It's especially useful when dining out with a group and needing to split the bill evenly.</p>
      <p class="mb-4 text-[var(--text-secondary)]">Simply enter your total bill amount before tip, choose a standard tip percentage or enter your own custom amount, and indicate how many people are splitting the bill. If you select the "Round Up Total Bill" option, the calculator will automatically adjust the total tip to ensure your final bill amount is a clean, whole dollar amount.</p>

      <h2 class="text-2xl mt-10 mb-4 text-[var(--accent-color)] font-bold">Standard Tipping Etiquette</h2>
      <ul class="mb-6 pl-6 text-[var(--text-secondary)] list-disc">
        <li class="mb-2"><strong>15% to 20%:</strong> The standard tipping range for sit-down restaurants with good service.</li>
        <li class="mb-2"><strong>10% to 15%:</strong> For buffet restaurants or situations where the server does less active table service.</li>
        <li class="mb-2"><strong>10% or less:</strong> Generally reserved for poor service.</li>
        <li class="mb-2"><strong>Takeout / Coffee Shops:</strong> Tipping is optional, but 10% or a few dollars is appreciated for large orders.</li>
      </ul>
    </div>
  </div>

  <script is:inline>
    const formatCurrency = (value) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency', currency: 'USD',
        maximumFractionDigits: 2, minimumFractionDigits: 2
      }).format(value);
    };

    const billInput = document.getElementById('bill-amount');
    const tipBtns = document.querySelectorAll('.tip-btn');
    const customTipInput = document.getElementById('custom-tip');
    const numPeopleInput = document.getElementById('num-people');
    const roundUpCheck = document.getElementById('round-up');
    const tipAmountEl = document.getElementById('tip-amount');
    const totalBillEl = document.getElementById('total-bill');
    const amountPerPersonEl = document.getElementById('amount-per-person');
    const tipPerPersonLabelEl = document.getElementById('tip-per-person-label');

    let currentTipPercentage = 18;

    const updateCalculator = () => {
      const bill = parseFloat(billInput.value) || 0;
      let people = parseInt(numPeopleInput.value) || 1;
      if (people < 1) people = 1;
      const roundUp = roundUpCheck.checked;

      let tipAmount = bill * (currentTipPercentage / 100);
      let totalBill = bill + tipAmount;

      if (roundUp && totalBill > 0) {
        const roundedTotal = Math.ceil(totalBill);
        tipAmount = roundedTotal - bill;
        totalBill = roundedTotal;
      }

      const tipPerPerson = tipAmount / people;
      const totalPerPerson = totalBill / people;

      tipAmountEl.innerText = formatCurrency(tipAmount);
      totalBillEl.innerText = formatCurrency(totalBill);
      amountPerPersonEl.innerText = formatCurrency(totalPerPerson);
      tipPerPersonLabelEl.innerText = people > 1 ? `(${formatCurrency(tipPerPerson)} / person)` : '';
    };

    billInput.addEventListener('input', updateCalculator);
    numPeopleInput.addEventListener('input', updateCalculator);
    roundUpCheck.addEventListener('change', updateCalculator);

    tipBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        tipBtns.forEach(b => { b.classList.remove('bg-[var(--accent-color)]', 'text-[var(--bg-color)]', 'border-[var(--accent-color)]', 'font-semibold'); b.classList.add('bg-[var(--bg-color)]', 'text-white', 'border-[var(--border-color)]'); });
        customTipInput.classList.remove('border-[var(--accent-color)]'); customTipInput.classList.add('border-[var(--border-color)]');
        customTipInput.value = '';
        e.target.classList.remove('bg-[var(--bg-color)]', 'text-white', 'border-[var(--border-color)]'); e.target.classList.add('bg-[var(--accent-color)]', 'text-[var(--bg-color)]', 'border-[var(--accent-color)]', 'font-semibold');
        currentTipPercentage = parseFloat(e.target.dataset.tip);
        updateCalculator();
      });
    });

    customTipInput.addEventListener('input', (e) => {
      const val = parseFloat(e.target.value);
      if (!isNaN(val)) {
        tipBtns.forEach(b => { b.classList.remove('bg-[var(--accent-color)]', 'text-[var(--bg-color)]', 'border-[var(--accent-color)]', 'font-semibold'); b.classList.add('bg-[var(--bg-color)]', 'text-white', 'border-[var(--border-color)]'); });
        customTipInput.classList.remove('border-[var(--border-color)]'); customTipInput.classList.add('border-[var(--accent-color)]');
        currentTipPercentage = val;
        updateCalculator();
      }
    });

    document.getElementById('copy-btn').addEventListener('click', async function() {
      const text = amountPerPersonEl.innerText;
      try {
        await navigator.clipboard.writeText(text);
        this.innerText = 'Copied!';
        setTimeout(() => { this.innerText = 'Copy'; }, 2000);
      } catch (err) { console.error('Failed to copy:', err); }
    });

    updateCalculator();
  </script>
</SiteLayout>
