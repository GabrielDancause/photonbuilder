---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Tip Calculator",
  "url": "https://firemaths.info/tip-calculator",
  "description": "Free tip calculator — instantly calculate tip amount, total bill, and per-person split for any bill size with preset and custom tip percentages.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much should I tip at a restaurant?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard tip at a sit-down restaurant in the United States is 15–20% of the pre-tax bill. For excellent service, 20–25% is common. At a buffet or counter-service restaurant, 10% is typical. Always tip on the pre-tax subtotal rather than the total that includes sales tax for the most accurate gratuity calculation."
      }
    },
    {
      "@type": "Question",
      "name": "Should I tip on the pre-tax or post-tax amount?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Etiquette experts recommend tipping on the pre-tax subtotal. Sales tax is money owed to the government, not part of the service you received. For example, on a $100 meal with 8% tax, a 20% tip should be $20 (based on $100), not $21.60 (based on $108). That said, tipping on the post-tax total is also common and results in only a slightly higher tip."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate a tip without a calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For a quick 20% tip, move the decimal point one place to the left (that gives you 10%) and double it. For example, on a $65 bill: 10% is $6.50, so 20% is $13. For 15%, calculate 10% and add half of that: $6.50 + $3.25 = $9.75. For 25%, calculate 10% and multiply by 2.5, or just add a quarter of the bill."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I tip for delivery?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For food delivery, tip 15–20% of the order total, with a minimum of $3–5 for small orders. In bad weather or if the driver traveled a long distance, consider tipping more. For grocery delivery, 15–20% is standard, with a $5 minimum. Many delivery apps allow you to adjust the tip after delivery based on the service quality."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need to tip if a service charge or gratuity is already included?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If a service charge or automatic gratuity is already included in the bill (common for large parties of 6+), you generally do not need to tip extra. However, check whether the service charge actually goes to the server — some restaurants keep it as a fee. If the included gratuity is below 18%, you may want to add a small additional tip for great service."
      }
    },
    {
      "@type": "Question",
      "name": "How do I split a tip evenly among a group?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To split a tip evenly, first calculate the total tip on the entire bill, then divide by the number of people. For example, a $200 bill with a 20% tip is $40 in gratuity. Split among 4 people, that's $10 each in tip, or $60 each for the total ($200 + $40 = $240 ÷ 4). This calculator handles the math automatically — just enter the number of people."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a tip and a gratuity?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A tip and a gratuity are essentially the same thing — both refer to extra money given to a service worker beyond the bill amount. However, 'gratuity' is sometimes used specifically for mandatory or automatic charges added to bills for large parties, while 'tip' usually refers to a voluntary amount. In everyday use, the terms are interchangeable."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I tip at a hair salon or barbershop?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard tip at a hair salon or barbershop is 15–20% of the service cost. For a simple haircut, 15–20% is appropriate. For more complex services like coloring, highlights, or styling, 20% or more is customary. If multiple people work on your hair (e.g., a colorist and a stylist), tip each person separately based on their portion of the service."
      }
    }
  ]
};

export const meta = {
  title: "Tip Calculator — Gratuity & Bill Splitter",
  description: "Free tip calculator — instantly figure out how much to tip, the total bill, and per-person split. Quick preset buttons for 15%, 18%, 20%, 25% and custom tips.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Tip Calculator — Gratuity & Bill Splitter"
  description="Free tip calculator — instantly figure out how much to tip, the total bill, and per-person split. Quick preset buttons for 15%, 18%, 20%, 22%, 25% plus custom tip percentages."
  canonical="https://firemaths.info/tip-calculator" schema={schema}
>
  <style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"] {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.tip-presets {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
    margin-bottom: 1.25rem;
}

.tip-preset-btn {
    padding: 0.6rem 0.25rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border-radius: 6px;
    transition: all 0.2s;
    text-align: center;
}

.tip-preset-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.tip-preset-btn.active {
    background: var(--accent-color);
    color: #000;
    border-color: var(--accent-color);
}

.option-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
}

.option-row:last-child {
    border-bottom: none;
}

.option-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
}

.toggle-switch {
    position: relative;
    width: 44px;
    height: 24px;
    flex-shrink: 0;
}

.toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: var(--border-color);
    border-radius: 24px;
    transition: 0.2s;
}

.toggle-slider::before {
    content: "";
    position: absolute;
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: var(--text-primary);
    border-radius: 50%;
    transition: 0.2s;
}

.toggle-switch input:checked + .toggle-slider {
    background-color: var(--accent-color);
}

.toggle-switch input:checked + .toggle-slider::before {
    transform: translateX(20px);
}

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.split-divider {
    padding-top: 1rem;
    margin-top: 0.5rem;
    border-top: 1px dashed var(--border-color);
}

.guide-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 3rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
}

.guide-table th, .guide-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border-color);
}

.guide-table th {
    background-color: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.guide-table tr:last-child td {
    border-bottom: none;
}

.guide-table td:nth-child(2) {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent-color);
}

.tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .tips-grid {
        grid-template-columns: 1fr;
    }
}

.tip-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.tip-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.tip-card ul {
    list-style: none;
    padding: 0;
}

.tip-card li {
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
}

.tip-card li::before {
    content: "\203A";
    position: absolute;
    left: 0;
    color: var(--accent-color);
    font-weight: bold;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "\2212";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
    .tip-presets {
        grid-template-columns: repeat(3, 1fr);
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}

@media (max-width: 640px) {
    .guide-table {
        font-size: 0.8rem;
    }
    .guide-table th, .guide-table td {
        padding: 0.65rem 0.5rem;
    }
}
  </style>

<div class="container">
    <h1>Tip Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Calculate tip amount, total bill, and per-person split instantly</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Bill Details</h2>
                </div>

                <div class="inputs">
                    <div class="input-group">
                        <label for="bill-amount">Bill Amount</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="bill-amount" value="85.00" min="0" step="0.01">
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Tip Percentage</label>
                        <div class="tip-presets">
                            <button class="tip-preset-btn" data-tip="15" onclick="setTipPreset(15)">15%</button>
                            <button class="tip-preset-btn" data-tip="18" onclick="setTipPreset(18)">18%</button>
                            <button class="tip-preset-btn active" data-tip="20" onclick="setTipPreset(20)">20%</button>
                            <button class="tip-preset-btn" data-tip="22" onclick="setTipPreset(22)">22%</button>
                            <button class="tip-preset-btn" data-tip="25" onclick="setTipPreset(25)">25%</button>
                        </div>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="tip-percent" value="20" min="0" max="100" step="1">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="num-people">Split Between</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">people</span>
                            <input type="number" id="num-people" value="1" min="1" max="99" step="1" style="padding-right: 4.5rem;">
                        </div>
                    </div>

                    <div style="margin-top: 1.25rem;">
                        <div class="option-row">
                            <span class="option-label">Round up total to nearest dollar</span>
                            <label class="toggle-switch">
                                <input type="checkbox" id="round-up">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                        <div class="option-row">
                            <span class="option-label">Calculate tip on pre-tax amount</span>
                            <label class="toggle-switch">
                                <input type="checkbox" id="pre-tax-toggle">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>

                    <div id="pre-tax-input" style="display:none; margin-top: 1.25rem;">
                        <div class="input-group" style="margin-bottom:0;">
                            <label for="pre-tax-subtotal">Pre-Tax Subtotal</label>
                            <div class="input-wrapper has-prefix">
                                <span class="prefix">$</span>
                                <input type="number" id="pre-tax-subtotal" value="78.00" min="0" step="0.01">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Tip &amp; Total</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item">
                        <span class="result-label">Tip Amount</span>
                        <div class="result-value">
                            <span id="tip-amount">$0.00</span>
                            <button class="copy-btn" onclick="copyValue('tip-amount', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Total Bill</span>
                        <div class="result-value">
                            <span id="total-bill">$0.00</span>
                            <button class="copy-btn" onclick="copyValue('total-bill', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Tip as Decimal</span>
                        <span class="result-value" id="tip-decimal" style="font-size: 0.9rem; color: var(--text-secondary);">0.20</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Effective Tip %</span>
                        <span class="result-value" id="effective-tip-pct" style="font-size: 0.9rem; color: var(--text-secondary);">20.0%</span>
                    </div>

                    <div class="split-divider" id="split-section" style="display:none;">
                        <div class="result-item">
                            <span class="result-label">Per Person Tip</span>
                            <div class="result-value">
                                <span id="per-person-tip">$0.00</span>
                            </div>
                        </div>
                        <div class="result-item result-final">
                            <span class="result-label" style="font-size: 1rem;">Per Person Total</span>
                            <div class="result-value">
                                <span id="per-person-total">$0.00</span>
                                <button class="copy-btn" onclick="copyValue('per-person-total', this)">Copy</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tipping Guide -->
        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--accent-color);">Tipping Guide by Service Type</h2>
        <table class="guide-table">
            <thead>
                <tr>
                    <th>Service</th>
                    <th>Suggested Tip</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Sit-down restaurant</td>
                    <td>15–20%</td>
                    <td>20% is the new standard for good service; tip on pre-tax subtotal</td>
                </tr>
                <tr>
                    <td>Food delivery</td>
                    <td>15–20%</td>
                    <td>$3–5 minimum; tip more in bad weather or for long distances</td>
                </tr>
                <tr>
                    <td>Hair salon / barbershop</td>
                    <td>15–20%</td>
                    <td>Tip each person who works on your hair separately</td>
                </tr>
                <tr>
                    <td>Taxi / rideshare</td>
                    <td>15–20%</td>
                    <td>$2–3 minimum for short rides; tip extra for help with luggage</td>
                </tr>
                <tr>
                    <td>Hotel housekeeping</td>
                    <td>$2–5 / night</td>
                    <td>Leave daily rather than at checkout so each housekeeper is tipped</td>
                </tr>
                <tr>
                    <td>Hotel bellhop</td>
                    <td>$1–2 / bag</td>
                    <td>$5 minimum if they show you to your room</td>
                </tr>
                <tr>
                    <td>Valet parking</td>
                    <td>$2–5</td>
                    <td>Tip when the car is returned, not when dropped off</td>
                </tr>
                <tr>
                    <td>Coffee shop / takeout</td>
                    <td>$1–2 or 10%</td>
                    <td>Optional but appreciated; tip more for complex orders</td>
                </tr>
                <tr>
                    <td>Bartender</td>
                    <td>$1–2 / drink or 15–20%</td>
                    <td>$1 for beer/wine, $2 for cocktails; 20% if running a tab</td>
                </tr>
                <tr>
                    <td>Spa / massage</td>
                    <td>15–20%</td>
                    <td>Tip on the full service price, not discounted or package rates</td>
                </tr>
                <tr>
                    <td>Movers</td>
                    <td>$20–50 / person</td>
                    <td>Or 5–10% of the total moving cost; tip more for stairs or heavy items</td>
                </tr>
