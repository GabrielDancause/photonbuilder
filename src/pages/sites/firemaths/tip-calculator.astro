  <script is:inline>
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let currentTipPct = 20;

window.setTipPreset = (pct) => {
    currentTipPct = pct;
    document.getElementById('tip-percent').value = pct;
    document.querySelectorAll('.tip-preset-btn').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.tip) === pct);
    });
    updateAll();
};

window.copyValue = async (elementId, btn) => {
    const text = document.getElementById(elementId).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => { btn.innerText = orig; }, 2000);
    } catch (err) { /* noop */ }
};

window.toggleFaq = (btn) => {
    btn.parentElement.classList.toggle('open');
};

function updateAll() {
    const billAmount = parseFloat(document.getElementById('bill-amount').value) || 0;
    const tipPct = parseFloat(document.getElementById('tip-percent').value) || 0;
    const numPeople = Math.max(1, parseInt(document.getElementById('num-people').value) || 1);
    const roundUp = document.getElementById('round-up').checked;
    const preTaxEnabled = document.getElementById('pre-tax-toggle').checked;
    const preTaxSubtotal = parseFloat(document.getElementById('pre-tax-subtotal').value) || 0;

    // Determine the base amount for tip calculation
    const tipBase = preTaxEnabled ? preTaxSubtotal : billAmount;

    // Calculate tip
    let tipAmount = tipBase * (tipPct / 100);
    let totalBill = billAmount + tipAmount;

    // Round up if enabled
    if (roundUp && totalBill > 0) {
        const rounded = Math.ceil(totalBill);
        tipAmount += (rounded - totalBill);
        totalBill = rounded;
    }

    // Effective tip percentage (based on actual bill)
    const effectivePct = billAmount > 0 ? (tipAmount / billAmount * 100) : 0;

    // Update results
    document.getElementById('tip-amount').innerText = fmt2(tipAmount);
    document.getElementById('total-bill').innerText = fmt2(totalBill);
    document.getElementById('tip-decimal').innerText = (tipPct / 100).toFixed(2);
    document.getElementById('effective-tip-pct').innerText = effectivePct.toFixed(1) + '%';

    // Split section
    const splitSection = document.getElementById('split-section');
    if (numPeople > 1) {
        splitSection.style.display = 'block';
        document.getElementById('per-person-tip').innerText = fmt2(tipAmount / numPeople);
        document.getElementById('per-person-total').innerText = fmt2(totalBill / numPeople);
    } else {
        splitSection.style.display = 'none';
    }

    // Sync preset buttons with custom input
    document.querySelectorAll('.tip-preset-btn').forEach(btn => {
        btn.classList.toggle('active', parseInt(btn.dataset.tip) === tipPct);
    });
}

// Pre-tax toggle
document.getElementById('pre-tax-toggle').addEventListener('change', function() {
    document.getElementById('pre-tax-input').style.display = this.checked ? 'block' : 'none';
    updateAll();
});

// Attach listeners
document.querySelectorAll('input[type="number"]').forEach(el => {
    el.addEventListener('input', updateAll);
    el.addEventListener('change', updateAll);
});

document.getElementById('round-up').addEventListener('change', updateAll);

// Initial calc
updateAll();
  </script>
