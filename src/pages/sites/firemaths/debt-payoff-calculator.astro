---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Debt Payoff Calculator",
  "url": "https://firemaths.info/debt-payoff-calculator",
  "description": "Compare the Snowball and Avalanche debt payoff strategies. Calculate your total interest saved and debt-free date with extra monthly payments.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Debt Payoff Calculator | firemaths.info"
  description="We ran the math on Debt Snowball vs Avalanche for $50k in balances. The faster payoff strategy isn't what most experts claim. See your exact timeline."
  canonical="https://firemaths.info/debt-payoff-calculator.html" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <!-- Left Column: Inputs -->
            <div class="input-section">
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Payoff Strategy</h2>
                    </div>
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="strategy">Strategy</label>
                        <select id="strategy" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                            <option value="avalanche">Avalanche (Highest Interest First)</option>
                            <option value="snowball">Snowball (Lowest Balance First)</option>
                        </select>
                    </div>
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="extra-payment">Extra Monthly Payment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="extra-payment" value="200" min="0" step="50" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>
                </div>

                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Your Debts</h2>
                    </div>
                    <div id="debts-container">
                        <!-- Debts will be injected here -->
                    </div>
                    <button class="btn" id="add-debt-btn">+ Add Another Debt</button>
                </div>
            </div>

            <!-- Right Column: Results -->
            <div class="flex flex-col gap-6">
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" style="position: sticky; top: 2rem;">
                    <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Payoff Summary</h2>
                    </div>
                    <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                        <div class="flex justify-between items-center mb-8 pb-6 border-b border-[var(--border-color)]">
                        <span class="text-[var(--text-secondary)] text-base font-medium">Debt-Free Date</span>
                            <div class="font-mono text-2xl md:text-3xl font-bold text-[var(--accent-color)] flex items-center gap-3" id="payoff-date">-</div>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Time to Payoff</span>
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="payoff-time">-</span>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Debt</span>
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-debt">$0</span>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Total Interest Paid</span>
                            <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="total-interest">$0</span>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Interest Saved<br><small style="font-size:0.75rem;font-family:var(--font-ui)">(vs minimum payments)</small></span>
                            <span class="result-value text-green" id="interest-saved">$0</span>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-[var(--text-secondary)] text-sm font-medium">Time Saved<br><small style="font-size:0.75rem;font-family:var(--font-ui)">(vs minimum payments)</small></span>
                            <span class="result-value text-green" id="time-saved">0 mos</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-16 shadow-sm">
            <div class="mb-6 text-center">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full inline-block bg-[var(--chart-color-a)]"></span> Chosen Strategy
                </div>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full inline-block bg-[var(--chart-color-b)]"></span> Minimum Payments Only
                </div>
            </div>
            <div class="w-full h-[400px] relative">
                <canvas id="payoffChart"></canvas>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Snowball vs. Avalanche Strategy</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When you have multiple debts, choosing the right payoff strategy can help you stay motivated and save money. The two most popular methods are the <strong>Debt Snowball</strong> and the <strong>Debt Avalanche</strong>.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Both methods require you to make the minimum payment on all your debts. The difference is where you put your <em>extra</em> money.</p>

            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>The Avalanche Method:</strong> You target the debt with the highest interest rate first. Once that debt is paid off, you take the money you were paying toward it and apply it to the debt with the next highest interest rate. This mathematically saves you the most money on interest and usually results in the fastest payoff.</li>
                <li><strong>The Snowball Method:</strong> You target the debt with the lowest balance first, regardless of the interest rate. Paying off small debts quickly gives you a psychological "win," building momentum and motivation to tackle the larger balances next.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">The Power of Extra Payments</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Making only the minimum payments on your credit cards and loans is a trap that can keep you in debt for decades. Minimum payments are designed to cover mostly interest, barely touching the principal balance.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">By adding an extra monthly payment—even as little as $50 or $100—you directly reduce the principal. As your principal shrinks, less interest accumulates the following month, creating a compounding effect in reverse. Over time, extra payments can shave years off your payoff timeline and save you thousands of dollars in interest.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">How to Use This Calculator</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Enter all your current debts, including credit cards, student loans, auto loans, and personal loans. Input the total balance, current interest rate, and your minimum monthly payment for each.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Next, enter any extra money you can commit to paying each month above your minimums. Toggle between the Snowball and Avalanche strategies to see which approach works best for your situation. The calculator will show you exactly when you will become debt-free and how much money and time you will save compared to paying just the minimums.</p>
        </div>
        <div class="mt-12 mb-16">
            <h2>Frequently Asked Questions</h2>
            <div itemscope itemtype="https://schema.org/FAQPage">
                <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <h3 itemprop="name" style="margin-top: 1rem;">What is a debt payoff calculator?</h3>
                    <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p itemprop="text">A debt payoff calculator is a tool that helps you determine how long it will take to become debt-free by calculating your payoff timeline based on your current balances, interest rates, and monthly payments.</p>
                    </div>
                </div>
                <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <h3 itemprop="name" style="margin-top: 1rem;">How does a debt snowball calculator work?</h3>
                    <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p itemprop="text">A debt snowball calculator organizes your debts from smallest balance to largest. You pay the minimum on all debts while applying any extra money to the smallest balance first, giving you quick wins.</p>
                    </div>
                </div>
                <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <h3 itemprop="name" style="margin-top: 1rem;">What is the difference between debt avalanche vs snowball?</h3>
                    <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p itemprop="text">The debt avalanche method targets the debt with the highest interest rate first to save the most money. The debt snowball method targets the lowest balance first for psychological momentum. Both strategies require paying minimums on all other debts.</p>
                    </div>
                </div>
                <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <h3 itemprop="name" style="margin-top: 1rem;">Which strategy saves more money?</h3>
                    <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p itemprop="text">Mathematically, the debt avalanche strategy will always save you more money on interest and typically results in a faster overall payoff time.</p>
                    </div>
                </div>
                <div itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <h3 itemprop="name" style="margin-top: 1rem;">How much can extra payments help?</h3>
                    <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <p itemprop="text">Even a small extra monthly payment can significantly reduce your principal balance over time, which means less interest accumulates and can shave years off your payoff timeline.</p>
                    </div>
                </div>
            </div>
        </div>

    </main>

    
</div>
  <script is:inline>
// Initial state
    let debts = [
        { id: 1, name: 'Credit Card A', balance: 5000, rate: 22.9, minPayment: 150 },
        { id: 2, name: 'Car Loan', balance: 12000, rate: 6.5, minPayment: 250 },
        { id: 3, name: 'Student Loan', balance: 25000, rate: 5.8, minPayment: 300 }
    ];
    let debtCounter = 3;

    // Formatting utilities
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    const getPayoffDate = (months) => {
        if (months >= 1200) return 'Never';
        const date = new Date();
        date.setMonth(date.getMonth() + months);
        return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    };

    const formatTime = (months) => {
        if (months >= 1200) return '> 100 years';
        const y = Math.floor(months / 12);
        const m = months % 12;
        if (y > 0 && m > 0) return `${y} yrs ${m} mos`;
        if (y > 0) return `${y} yrs`;
        return `${m} mos`;
    };

    // UI rendering
    const renderDebts = () => {
        const container = document.getElementById('debts-container');
        container.innerHTML = '';

        debts.forEach((debt, index) => {
            const debtHTML = `
                <div class="debt-item" data-id="${debt.id}">
                    <div class="debt-header">
                        <input type="text" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none debt-name-input w-full border text-base transition-colors" value="${debt.name}" onchange="updateDebtName(${debt.id}, this.value)" style="background: transparent; border: none; color: var(--accent); font-size: 1.1rem; font-weight: 600; font-family: 'Inter', sans-serif; outline: none; border-bottom: 1px dashed var(--border);" placeholder="Debt Name">
                        ${debts.length > 1 ? `<button class="remove-btn" onclick="removeDebt(${debt.id})">Remove</button>` : ''}
                    </div>
                    <div class="debt-grid">
                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2">Balance</label>
                            <div class="relative flex items-center">
                                <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono debt-balance bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors" value="${debt.balance}" min="0" step="100" onchange="updateDebt(${debt.id}, 'balance', this.value)">
                            </div>
                        </div>
                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2">Interest Rate</label>
                            <div class="relative flex items-center">
                                <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                                <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono debt-rate bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors" value="${debt.rate}" min="0" step="0.1" onchange="updateDebt(${debt.id}, 'rate', this.value)">
                            </div>
                        </div>
                        <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2">Min Payment</label>
                            <div class="relative flex items-center">
                                <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                                <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border debt-min text-base transition-colors" value="${debt.minPayment}" min="0" step="10" onchange="updateDebt(${debt.id}, 'minPayment', this.value)">
                            </div>
                        </div>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', debtHTML);
        });

        calculate();
    };

    window.addDebt = () => {
        debtCounter++;
        debts.push({
            id: debtCounter,
            name: `Debt ${debts.length + 1}`,
            balance: 5000,
            rate: 15.0,
            minPayment: 100
        });
        renderDebts();
    };

    window.removeDebt = (id) => {
        debts = debts.filter(d => d.id !== id);
        renderDebts();
    };

    window.updateDebt = (id, field, value) => {
        const debt = debts.find(d => d.id === id);
        if (debt) {
            debt[field] = Math.max(0, parseFloat(value) || 0);
            calculate();
        }
    };

    window.updateDebtName = (id, value) => {
        const debt = debts.find(d => d.id === id);
        if (debt) {
            debt.name = value || "Unnamed Debt";
            calculate();
        }
    };

    document.getElementById('add-debt-btn').addEventListener('click', addDebt);
    document.getElementById('strategy').addEventListener('change', () => calculate());
    document.getElementById('extra-payment').addEventListener('input', () => calculate());

    // Calculation logic
    const simulatePayoff = (debtsData, extraPayment, strategy) => {
        // Deep copy
        let currentDebts = JSON.parse(JSON.stringify(debtsData));
        let totalMonths = 0;
        let totalInterest = 0;

        // Base minimum payment that is required every month if we still have debts
        // In snowball/avalanche, once a debt is paid off, its min payment rolls over into the extra payment
        // We handle this by saying total available cash each month is sum of ALL original min payments + extraPayment
        const initialTotalMinPayment = currentDebts.reduce((sum, d) => sum + d.minPayment, 0);

        let history = [currentDebts.reduce((sum, d) => sum + d.balance, 0)];

        // Run until all paid or hit 1200 months (100 years to prevent infinite loop)
        while (currentDebts.length > 0 && totalMonths < 1200) {
            totalMonths++;

            // The magic of snowball/avalanche is that you keep paying the same total amount every month
            // until everything is paid off.
            let totalAvailable = initialTotalMinPayment + extraPayment;

            // Add interest
            currentDebts.forEach(d => {
                const interest = d.balance * (d.rate / 100 / 12);
                d.balance += interest;
                totalInterest += interest;
            });

            // If a debt's balance is growing endlessly despite total available cash, it's a trap
            let sumBalances = currentDebts.reduce((sum, d) => sum + d.balance, 0);
            if (totalMonths > 10 && sumBalances > history[history.length - 1] * 1.5) {
                // Balances are ballooning, exit early
                totalMonths = 1200;
                break;
            }

            // First, pay minimums on all active debts
            currentDebts.forEach(d => {
                const minPay = Math.min(d.balance, d.minPayment);
                d.balance -= minPay;
                totalAvailable -= minPay;
            });

            // Apply remaining cash based on strategy to the remaining debts
            if (totalAvailable > 0.01) {
                if (strategy === 'snowball') {
                    currentDebts.sort((a, b) => a.balance - b.balance);
                } else if (strategy === 'avalanche') {
                    currentDebts.sort((a, b) => b.rate - a.rate);
                }

                for (let i = 0; i < currentDebts.length; i++) {
                    if (totalAvailable <= 0.01) break;
                    const d = currentDebts[i];
                    const pay = Math.min(d.balance, totalAvailable);
                    d.balance -= pay;
                    totalAvailable -= pay;
                }
            }

            // Remove paid off debts
            currentDebts = currentDebts.filter(d => d.balance > 0.01);
            history.push(currentDebts.reduce((sum, d) => sum + d.balance, 0));
        }

        return { months: totalMonths, interest: totalInterest, history };
    };

    const simulateBaseline = (debtsData) => {
        let currentDebts = JSON.parse(JSON.stringify(debtsData));
        let totalMonths = 0;
        let totalInterest = 0;
        let history = [currentDebts.reduce((sum, d) => sum + d.balance, 0)];

        while (currentDebts.length > 0 && totalMonths < 1200) {
            totalMonths++;

            // Add interest
            currentDebts.forEach(d => {
                const interest = d.balance * (d.rate / 100 / 12);
                d.balance += interest;
                totalInterest += interest;
            });

            // Pay minimums only. If a debt is paid off, you keep that money, it doesn't roll over.
            currentDebts.forEach(d => {
                const pay = Math.min(d.balance, d.minPayment);
                d.balance -= pay;
            });

            // Remove paid off
            currentDebts = currentDebts.filter(d => d.balance > 0.01);
            history.push(currentDebts.reduce((sum, d) => sum + d.balance, 0));
        }

        return { months: totalMonths, interest: totalInterest, history };
    };

    const calculate = () => {
        const strategy = document.getElementById('strategy').value;
        const extraPayment = Math.max(0, parseFloat(document.getElementById('extra-payment').value) || 0);

        const totalDebtInitial = debts.reduce((sum, d) => sum + d.balance, 0);

        const result = simulatePayoff(debts, extraPayment, strategy);
        const baseline = simulateBaseline(debts);

        // Update UI
        document.getElementById('payoff-date').innerText = getPayoffDate(result.months);
        document.getElementById('payoff-time').innerText = formatTime(result.months);
        document.getElementById('total-debt').innerText = formatCurrency(totalDebtInitial);
        document.getElementById('total-interest').innerText = formatCurrency(result.interest);

        let interestSaved = baseline.interest - result.interest;
        let timeSaved = baseline.months - result.months;

        // If baseline never finishes but strategy does
        if (baseline.months >= 1200 && result.months < 1200) {
            document.getElementById('interest-saved').innerHTML = `<span style="font-size:1rem">Massive</span>`;
            document.getElementById('time-saved').innerText = `Decades`;
        } else if (result.months >= 1200) {
            document.getElementById('payoff-date').innerText = 'Never';
            document.getElementById('payoff-time').innerText = '> 100 years';
            document.getElementById('total-interest').innerText = 'Infinite';
            document.getElementById('interest-saved').innerText = '$0';
            document.getElementById('time-saved').innerText = '0 mos';
        } else {
            const elIntSaved = document.getElementById('interest-saved');
            const elTimeSaved = document.getElementById('time-saved');

            elIntSaved.innerText = formatCurrency(Math.max(0, interestSaved));
            elTimeSaved.innerText = formatTime(Math.max(0, timeSaved));

            if (interestSaved <= 0) {
                elIntSaved.classList.remove('text-green');
                elTimeSaved.classList.remove('text-green');
            } else {
                elIntSaved.classList.add('text-green');
                elTimeSaved.classList.add('text-green');
            }
        }

        drawChart(result.history, baseline.history);
    };

    // Charting logic
    let chartCanvas = document.getElementById('payoffChart');
    let ctx = chartCanvas.getContext('2d');

    const drawChart = (dataStrategy, dataBaseline) => {
        const dpr = window.devicePixelRatio || 1;
        const rect = chartCanvas.parentElement.getBoundingClientRect();

        chartCanvas.width = rect.width * dpr;
        chartCanvas.height = rect.height * dpr;

        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);

        const width = rect.width;
        const height = rect.height;

        ctx.clearRect(0, 0, width, height);

        const padding = { top: 20, right: 20, bottom: 40, left: 80 };
        const chartWidth = width - padding.left - padding.right;
        const chartHeight = height - padding.top - padding.bottom;

        // Cap chart at 360 months (30 years) for readability if it goes infinite
        let maxMonths = Math.min(Math.max(dataStrategy.length, dataBaseline.length), 360);
        if (maxMonths < 12) maxMonths = 12; // Minimum 1 year

        const maxVal = Math.max(dataStrategy[0] || 0, dataBaseline[0] || 0) * 1.1; // Add 10% headroom

        // Draw grid and axes
        ctx.strokeStyle = '#2a2010';
        ctx.lineWidth = 1;
        ctx.font = '12px Inter, sans-serif';
        ctx.fillStyle = '#888888';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        // Y-axis
        const yTicks = 5;
        for (let i = 0; i <= yTicks; i++) {
            const val = maxVal * (i / yTicks);
            const y = height - padding.bottom - (chartHeight * (i / yTicks));

            ctx.beginPath();
            ctx.moveTo(padding.left, y);
            ctx.lineTo(width - padding.right, y);
            ctx.stroke();

            let label = val >= 1000000 ? '$' + (val / 1000000).toFixed(1) + 'M' :
                        val >= 1000 ? '$' + (val / 1000).toFixed(0) + 'k' : '$' + val.toFixed(0);
            ctx.fillText(label, padding.left - 10, y);
        }

        // X-axis
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const xTicks = Math.min(Math.ceil(maxMonths / 12), 10); // Show max 10 ticks for years
        for (let i = 0; i <= xTicks; i++) {
            const yearIndex = Math.round((maxMonths / 12 / xTicks) * i);
            const x = padding.left + (chartWidth * ((yearIndex * 12) / maxMonths));

            ctx.beginPath();
            ctx.moveTo(x, height - padding.bottom);
            ctx.lineTo(x, height - padding.bottom + 5);
            ctx.stroke();

            ctx.fillText('Yr ' + yearIndex, x, height - padding.bottom + 10);
        }

        const drawLine = (data, color) => {
            ctx.beginPath();
            ctx.strokeStyle = color;
            ctx.lineWidth = 3;
            ctx.lineJoin = 'round';

            for (let i = 0; i < data.length && i <= maxMonths; i++) {
                const val = data[i];
                const x = padding.left + (chartWidth * (i / maxMonths));
                const y = height - padding.bottom - (chartHeight * (val / maxVal));

                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.stroke();
        };

        // Draw baseline first, then strategy on top
        drawLine(dataBaseline, '#4A90E2');
        drawLine(dataStrategy, '#D4A017');
    };

    window.addEventListener('resize', () => {
        calculate();
    });

    // Initialize
    // Add small timeout to ensure layout completes before canvas size calculation
    setTimeout(() => {
        renderDebts();
    }, 0);
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-debt-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">How to Get Out of Debt: The Complete Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
