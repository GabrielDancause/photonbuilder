---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'The Complete Debt Payoff Calculator | Avalanche vs Snowball',
  description: 'Interactive calculator to compare debt payoff strategies. See how much interest you save with Avalanche vs Snowball, and how extra payments affect your timeline.',
  category: 'calculator',
  keywords: ['debt payoff calculator', 'debt snowball', 'debt avalanche', 'pay off debt', 'interest savings', 'extra payment calculator']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "FIRE Maths" },
    "publisher": { "@type": "Organization", "name": "FIRE Maths" },
    "datePublished": "2024-03-22",
    "dateModified": "2024-03-22"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the debt avalanche method?",
        "acceptedAnswer": { "@type": "Answer", "text": "The debt avalanche method focuses on paying off debts in order of interest rate, from highest to lowest. This strategy minimizes the total interest you pay over time, making it mathematically the fastest and cheapest way to get out of debt." }
      },
      {
        "@type": "Question",
        "name": "What is the debt snowball method?",
        "acceptedAnswer": { "@type": "Answer", "text": "The debt snowball method focuses on paying off debts from smallest balance to largest balance, regardless of interest rate. While it may cost slightly more in total interest, the psychological boost of clearing small debts quickly helps many people stay motivated." }
      },
      {
        "@type": "Question",
        "name": "Should I use avalanche or snowball?",
        "acceptedAnswer": { "@type": "Answer", "text": "If you need quick wins to stay motivated, choose snowball. If you want to pay the absolute minimum in interest and get out of debt mathematically faster, choose avalanche. Both methods are better than just paying the minimums." }
      },
      {
        "@type": "Question",
        "name": "How do extra payments help?",
        "acceptedAnswer": { "@type": "Answer", "text": "Any amount paid above the minimum payment goes entirely toward the principal balance. This reduces the balance that generates future interest, creating a compounding effect that can shave years off your payoff timeline and save thousands in interest." }
      },
      {
        "@type": "Question",
        "name": "Should I invest or pay off debt?",
        "acceptedAnswer": { "@type": "Answer", "text": "A general rule is to compare the interest rate of the debt to expected investment returns. High-interest debt (like credit cards at 15-25%) should almost always be paid off first. For low-interest debt (like a 3% mortgage), investing might yield better long-term results." }
      }
    ]
  }
]);
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <section class="debt-hero">
    <div class="debt-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>The Complete Debt Payoff Calculator</h1>
    <p class="debt-hero-hook">Americans pay <strong>$1,360/yr in credit card interest alone</strong>. <br/>Find your exact path to zero.</p>
    <div class="debt-hero-stats">
      <div class="debt-stat">
        <span class="debt-stat-num" id="hero-total-debt">$0</span>
        <span class="debt-stat-label">Total Debt</span>
      </div>
      <div class="debt-stat">
        <span class="debt-stat-num" id="hero-payoff-date">--</span>
        <span class="debt-stat-label">Debt-Free Date</span>
      </div>
      <div class="debt-stat">
        <span class="debt-stat-num" id="hero-interest-saved">$0</span>
        <span class="debt-stat-label">Extra Payment Interest Saved</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="debt-section">
    <h2 class="debt-section-title">Your Debt Dashboard</h2>
    <p class="debt-section-sub">Add your debts below. We've pre-loaded a typical American profile to start.</p>

    <div class="debt-calc-container">
      <div class="debt-calc-inputs">
        <div class="debt-list" id="debt-list">
          <!-- Debts rendered here -->
        </div>

        <button id="add-debt-btn" class="debt-btn-secondary">+ Add Another Debt</button>

        <div class="debt-settings">
          <div class="debt-input-group">
            <label for="strategy-select">Payoff Strategy</label>
            <select id="strategy-select">
              <option value="avalanche">Avalanche (Highest Interest First) - Mathematically Best</option>
              <option value="snowball">Snowball (Lowest Balance First) - Motivation Boost</option>
            </select>
          </div>

          <div class="debt-input-group">
            <label for="extra-payment">Extra Monthly Payment: $<span id="extra-payment-val">100</span></label>
            <input type="range" id="extra-payment" min="0" max="2000" step="50" value="100" />
            <div class="debt-slider-labels">
              <span>$0</span>
              <span>$2000</span>
            </div>
          </div>
        </div>

        <button id="calculate-btn" class="debt-btn">Calculate Payoff Plan</button>
      </div>

      <div class="debt-calc-results" id="results-panel">
        <div class="debt-result-header">
          <div class="debt-result-title">You will be debt-free in</div>
          <div class="debt-result-time" id="result-months"><strong>0</strong> Months</div>
          <div class="debt-result-date" id="result-date">Month Year</div>

          <div class="debt-savings-box">
            <div class="debt-savings-title">Total Interest Paid</div>
            <div class="debt-savings-amount" id="result-total-interest">$0</div>
            <div class="debt-savings-note" id="result-comparison-note"></div>
          </div>
        </div>

        <!-- SIDE BY SIDE COMPARISON -->
        <div class="debt-comparison-panel">
          <h3>Avalanche vs Snowball</h3>
          <div class="debt-compare-grid">
            <div class="debt-compare-card" id="card-avalanche">
              <div class="debt-compare-title">Avalanche</div>
              <div class="debt-compare-time" id="comp-ava-time">-- Months</div>
              <div class="debt-compare-interest" id="comp-ava-int">$0</div>
              <div class="debt-compare-label">Total Interest</div>
            </div>
            <div class="debt-compare-card" id="card-snowball">
              <div class="debt-compare-title">Snowball</div>
              <div class="debt-compare-time" id="comp-snow-time">-- Months</div>
              <div class="debt-compare-interest" id="comp-snow-int">$0</div>
              <div class="debt-compare-label">Total Interest</div>
            </div>
          </div>
        </div>

        <div class="debt-chart-wrap">
          <div class="debt-chart-title">Payoff Timeline</div>
          <div class="debt-chart" id="timeline-chart"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="debt-schedule-section">
     <h2 class="debt-section-title">Monthly Payment Schedule</h2>
     <button id="toggle-schedule-btn" class="debt-btn-secondary" style="margin-bottom: 1rem;">Expand Full Schedule</button>
     <div class="debt-table-wrap" id="schedule-container" style="display: none;">
       <table class="debt-table">
         <thead>
           <tr>
             <th>Month</th>
             <th>Starting Balance</th>
             <th>Total Payment</th>
             <th>Interest Paid</th>
             <th>Principal Paid</th>
             <th>Remaining Balance</th>
           </tr>
         </thead>
         <tbody id="schedule-body">
           <!-- Schedule injected here -->
         </tbody>
       </table>
     </div>
  </section>

  <!-- CONTENT -->
  <article class="debt-content">
    <h2>Avalanche vs. Snowball Explained</h2>
    <p>When you have multiple debts, deciding which one to tackle first can be overwhelming. The two most popular methods are the Debt Avalanche and the Debt Snowball.</p>

    <div class="debt-content-grid">
      <div class="debt-card">
        <h3>The Avalanche Method</h3>
        <p><strong>How it works:</strong> You list your debts from highest interest rate to lowest interest rate. You pay minimums on everything, and put any extra money toward the debt with the highest rate.</p>
        <p><strong>The Pros:</strong> This is the mathematically optimal way to pay off debt. You will pay the absolute least amount of interest possible and become debt-free the fastest.</p>
      </div>
      <div class="debt-card">
        <h3>The Snowball Method</h3>
        <p><strong>How it works:</strong> You list your debts from smallest balance to largest balance, regardless of interest rate. You pay minimums on everything, and put any extra money toward the smallest debt.</p>
        <p><strong>The Pros:</strong> Psychology matters. By knocking out small debts quickly, you get immediate "wins" that keep you motivated to stick to your plan.</p>
      </div>
    </div>

    <h2>The Magic of Extra Payments</h2>
    <p>When you only pay the minimum on a credit card, the majority of your payment goes toward interest, not the principal balance. This is why it can take decades to pay off a small balance.</p>
    <p>However, <strong>any amount you pay above the minimum goes 100% toward the principal</strong>. By adding just $50 or $100 extra to your monthly payments, you drastically reduce the principal, which in turn reduces the interest charged next month, creating a compounding effect in your favor.</p>


    <h2>Frequently Asked Questions</h2>
    <div class="debt-faq-list">
      <div class="debt-faq-item">
        <h4>What is the debt avalanche method?</h4>
        <p>The debt avalanche method focuses on paying off debts in order of interest rate, from highest to lowest. This strategy minimizes the total interest you pay over time, making it mathematically the fastest and cheapest way to get out of debt.</p>
      </div>
      <div class="debt-faq-item">
        <h4>What is the debt snowball method?</h4>
        <p>The debt snowball method focuses on paying off debts from smallest balance to largest balance, regardless of interest rate. While it may cost slightly more in total interest, the psychological boost of clearing small debts quickly helps many people stay motivated.</p>
      </div>
      <div class="debt-faq-item">
        <h4>Should I use avalanche or snowball?</h4>
        <p>If you need quick wins to stay motivated, choose snowball. If you want to pay the absolute minimum in interest and get out of debt mathematically faster, choose avalanche. Both methods are better than just paying the minimums.</p>
      </div>
      <div class="debt-faq-item">
        <h4>How do extra payments help?</h4>
        <p>Any amount paid above the minimum payment goes entirely toward the principal balance. This reduces the balance that generates future interest, creating a compounding effect that can shave years off your payoff timeline and save thousands in interest.</p>
      </div>
      <div class="debt-faq-item">
        <h4>Should I invest or pay off debt?</h4>
        <p>A general rule is to compare the interest rate of the debt to expected investment returns. High-interest debt (like credit cards at 15-25%) should almost always be paid off first. For low-interest debt (like a 3% mortgage), investing might yield better long-term results.</p>
      </div>
    </div>

    <h2>Methodology</h2>
    <p>This calculator assumes interest compounds monthly. The minimum payment for each debt is assumed to be fixed until the debt is paid off (though in reality, minimum credit card payments may decrease as the balance decreases). The "Extra Payment" is applied on top of the sum of all minimum payments. When a debt is paid off, its minimum payment is rolled over into the next debt in line according to your chosen strategy.</p>
  </article>
</SiteLayout>

<style is:global>
  /* ===== DEBT CALCULATOR ===== */
  .debt-hero {
    text-align: center;
    padding: 4rem 1rem;
    background: radial-gradient(circle at top, rgba(212, 160, 23, 0.15) 0%, transparent 50%);
    border-bottom: 1px solid var(--border-color, #374151);
  }
  .debt-hero-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(212, 160, 23, 0.1);
    color: var(--accent-color, #D4A017);
    border: 1px solid rgba(212, 160, 23, 0.3);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }
  .debt-hero h1 {
    font-size: 3rem;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: var(--text-primary, #f3f4f6);
  }
  .debt-hero-hook {
    font-size: 1.25rem;
    color: var(--text-secondary, #9ca3af);
    max-width: 600px;
    margin: 0 auto 2.5rem;
  }
  .debt-hero-hook strong {
    color: var(--accent-color, #D4A017);
  }

  .debt-hero-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .debt-stat {
    background: var(--surface-color, #111827);
    border: 1px solid var(--border-color, #374151);
    padding: 1.5rem 2rem;
    border-radius: 12px;
    min-width: 200px;
    position: relative;
    overflow: hidden;
  }
  .debt-stat-num {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary, #f3f4f6);
    margin-bottom: 0.25rem;
    transition: transform 0.3s;
  }
  .debt-stat-num.celebrate {
    animation: debt-pop 0.5s ease-out forwards;
    color: var(--success-color, #10b981);
  }
  @keyframes debt-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }
  .debt-stat-label {
    font-size: 0.875rem;
    color: var(--text-secondary, #9ca3af);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* SECTION */
  .debt-section {
    max-width: 1200px;
    margin: 4rem auto;
    padding: 0 1rem;
  }
  .debt-section-title {
    font-size: 2rem;
    color: var(--text-primary, #f3f4f6);
    text-align: center;
    margin: 0 0 0.5rem;
  }
  .debt-section-sub {
    text-align: center;
    color: var(--text-secondary, #9ca3af);
    margin-bottom: 3rem;
  }

  /* CALCULATOR LAYOUT */
  .debt-calc-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media(min-width: 900px) {
    .debt-calc-container {
      grid-template-columns: 1fr 1.2fr;
    }
  }

  /* INPUTS */
  .debt-calc-inputs {
    background: var(--surface-color, #111827);
    border: 1px solid var(--border-color, #374151);
    border-radius: 16px;
    padding: 2rem;
  }

  .debt-item {
    background: var(--surface-light, #1f2937);
    border: 1px solid var(--border-color, #374151);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    position: relative;
    animation: debt-fade-in 0.3s ease;
  }
  @keyframes debt-fade-in {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .debt-item-remove {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: none;
    border: none;
    color: var(--text-secondary, #9ca3af);
    cursor: pointer;
    font-size: 1.2rem;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }
  .debt-item-remove:hover {
    color: var(--danger-color, #ef4444);
    background: rgba(239, 68, 68, 0.1);
  }

  .debt-input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .debt-input-group {
    margin-bottom: 1rem;
  }
  .debt-input-group label {
    display: block;
    font-size: 0.875rem;
    color: var(--text-secondary, #9ca3af);
    margin-bottom: 0.5rem;
  }
  .debt-input-wrap {
    position: relative;
  }
  .debt-input-prefix, .debt-input-suffix {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary, #9ca3af);
  }
  .debt-input-prefix { left: 1rem; }
  .debt-input-suffix { right: 1rem; }

  .debt-input-wrap input {
    padding-left: 2rem;
  }
  .debt-input-wrap.suffix input {
    padding-left: 1rem;
    padding-right: 2rem;
  }

  .debt-calc-container input[type="text"],
  .debt-calc-container input[type="number"],
  .debt-calc-container select {
    width: 100%;
    background: var(--bg-color, #0b1120);
    border: 1px solid var(--border-color, #374151);
    color: var(--text-primary, #f3f4f6);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-size: 1rem;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }
  .debt-calc-container input:focus,
  .debt-calc-container select:focus {
    outline: none;
    border-color: var(--accent-color, #D4A017);
  }

  .debt-calc-container input[type="range"] {
    width: 100%;
    accent-color: var(--accent-color, #D4A017);
  }
  .debt-slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-secondary, #9ca3af);
    margin-top: 0.25rem;
  }

  .debt-settings {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color, #374151);
  }

  .debt-btn {
    width: 100%;
    background: var(--accent-color, #D4A017);
    color: #000;
    border: none;
    padding: 1rem;
    font-size: 1.125rem;
    font-weight: 700;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s, background 0.2s;
    margin-top: 1rem;
  }
  .debt-btn:hover {
    background: var(--accent-hover, #b38612);
    transform: translateY(-2px);
  }

  .debt-btn-secondary {
    width: 100%;
    background: transparent;
    color: var(--text-primary, #f3f4f6);
    border: 1px dashed var(--border-color, #374151);
    padding: 0.75rem;
    font-size: 1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .debt-btn-secondary:hover {
    border-color: var(--accent-color, #D4A017);
    color: var(--accent-color, #D4A017);
  }

  /* RESULTS */
  .debt-calc-results {
    animation: debt-fade-up 0.5s ease;
  }
  @keyframes debt-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .debt-result-header {
    text-align: center;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(212,160,23,0.1), rgba(212,160,23,0.02));
    border: 1px solid var(--border-color, #374151);
    border-radius: 12px;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
  }
  .debt-result-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent-color, #D4A017), transparent);
  }

  .debt-result-title {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary, #9ca3af);
    margin-bottom: 0.5rem;
  }
  .debt-result-time {
    font-size: 1.5rem;
    color: var(--text-primary, #f3f4f6);
  }
  .debt-result-time strong {
    font-size: 3rem;
    color: var(--accent-color, #D4A017);
    text-shadow: 0 0 20px rgba(212,160,23,0.3);
  }
  .debt-result-date {
    font-size: 1.125rem;
    color: var(--text-secondary, #9ca3af);
    margin-top: 0.25rem;
    margin-bottom: 1.5rem;
  }

  .debt-savings-box {
    background: var(--bg-color, #0b1120);
    border: 1px solid var(--border-color, #374151);
    padding: 1.5rem;
    border-radius: 8px;
    display: inline-block;
    min-width: 250px;
  }
  .debt-savings-title {
    font-size: 0.875rem;
    color: var(--text-secondary, #9ca3af);
  }
  .debt-savings-amount {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary, #f3f4f6);
    margin: 0.25rem 0;
  }
  .debt-savings-note {
    font-size: 0.875rem;
    color: var(--success-color, #10b981);
    font-weight: 600;
  }

  /* COMPARISON PANEL */
  .debt-comparison-panel {
    background: var(--surface-color, #111827);
    border: 1px solid var(--border-color, #374151);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .debt-comparison-panel h3 {
    text-align: center;
    margin: 0 0 1rem;
    color: var(--text-primary, #f3f4f6);
    font-size: 1.125rem;
  }
  .debt-compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .debt-compare-card {
    background: var(--surface-light, #1f2937);
    border: 1px solid var(--border-color, #374151);
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    transition: border-color 0.3s;
  }
  .debt-compare-card.winner {
    border-color: var(--success-color, #10b981);
    background: rgba(16, 185, 129, 0.05);
  }
  .debt-compare-title {
    font-weight: 700;
    color: var(--text-secondary, #9ca3af);
    margin-bottom: 0.5rem;
  }
  .debt-compare-time {
    font-size: 1.125rem;
    color: var(--text-primary, #f3f4f6);
    margin-bottom: 0.25rem;
  }
  .debt-compare-interest {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color, #D4A017);
  }
  .debt-compare-card.winner .debt-compare-interest {
    color: var(--success-color, #10b981);
  }
  .debt-compare-label {
    font-size: 0.75rem;
    color: var(--text-secondary, #9ca3af);
  }

  /* CHART */
  .debt-chart-wrap {
    background: var(--surface-color, #111827);
    border: 1px solid var(--border-color, #374151);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .debt-chart-title {
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-align: center;
    color: var(--text-primary, #f3f4f6);
  }
  .debt-chart {
    height: 300px;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    padding-top: 2rem;
    position: relative;
    border-bottom: 1px solid var(--border-color, #374151);
  }
  .debt-chart-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    height: 100%;
  }
  .debt-chart-segment {
    width: 100%;
    transition: height 0.5s ease;
    min-height: 0px;
    border-top: 1px solid rgba(0,0,0,0.2);
  }
  .debt-chart-segment:first-child {
    border-radius: 2px 2px 0 0;
    border-top: none;
  }
  .debt-chart-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    color: #fff;
    padding: 0.5rem;
    font-size: 0.75rem;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    margin-bottom: 0.5rem;
    z-index: 10;
    text-align: left;
    box-shadow: 0 4px 6px rgba(0,0,0,0.3);
  }
  .debt-chart-col:hover .debt-chart-tooltip {
    opacity: 1;
  }

  /* TABLE */
  .debt-schedule-section {
     max-width: 1000px;
     margin: 0 auto 4rem;
     padding: 0 1rem;
  }
  .debt-table-wrap {
    overflow-x: auto;
    background: var(--surface-color, #111827);
    border: 1px solid var(--border-color, #374151);
    border-radius: 12px;
  }
  .debt-table {
    width: 100%;
    border-collapse: collapse;
    text-align: right;
    color: var(--text-primary, #f3f4f6);
  }
  .debt-table th, .debt-table td {
    padding: 1rem;
    border-bottom: 1px solid var(--border-color, #374151);
  }
  .debt-table th {
    text-align: right;
    font-size: 0.875rem;
    color: var(--text-secondary, #9ca3af);
    background: rgba(0,0,0,0.2);
    font-weight: 600;
  }
  .debt-table th:first-child, .debt-table td:first-child {
    text-align: left;
  }
  .debt-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* CONTENT */
  .debt-content {
    max-width: 800px;
    margin: 4rem auto;
    padding: 0 1rem;
  }
  .debt-content h2 {
    color: var(--text-primary, #f3f4f6);
    margin-top: 3rem;
  }
  .debt-content p {
    color: var(--text-secondary, #9ca3af);
    font-size: 1.125rem;
  }

  .debt-content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }
  @media(min-width: 768px) {
    .debt-content-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .debt-card {
    background: var(--surface-color, #111827);
    border: 1px solid var(--border-color, #374151);
    padding: 2rem;
    border-radius: 12px;
  }
  .debt-card h3 {
    color: var(--accent-color, #D4A017);
    margin-top: 0;
  }
  .debt-card p {
    font-size: 1rem;
  }

  .debt-faq-list {
    margin-top: 1.5rem;
  }
  .debt-faq-item {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color, #374151);
  }
  .debt-faq-item:last-child {
    border-bottom: none;
  }
  .debt-faq-item h4 {
    color: var(--text-primary, #f3f4f6);
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.125rem;
  }
  .debt-faq-item p {
    margin: 0;
    font-size: 1rem;
  }
</style>

<script is:inline>
  // Colors for debts in chart
  const DEBT_COLORS = ['#D4A017', '#4a8fe7', '#10b981', '#ef4444', '#8b5cf6', '#f59e0b', '#ec4899', '#06b6d4'];

  // Initial State
  let debts = [
    { id: 1, name: 'Credit Card', balance: 6000, rate: 22.0, minPayment: 180, color: DEBT_COLORS[0] },
    { id: 2, name: 'Car Loan', balance: 25000, rate: 6.5, minPayment: 450, color: DEBT_COLORS[1] },
    { id: 3, name: 'Student Loan', balance: 35000, rate: 5.5, minPayment: 350, color: DEBT_COLORS[2] }
  ];
  let nextId = 4;

  // Elements
  const listEl = document.getElementById('debt-list');
  const addBtn = document.getElementById('add-debt-btn');
  const calcBtn = document.getElementById('calculate-btn');
  const extraPaymentSlider = document.getElementById('extra-payment');
  const extraPaymentVal = document.getElementById('extra-payment-val');
  const strategySelect = document.getElementById('strategy-select');

  // Formatting
  const fmtCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);

  function renderDebts() {
    listEl.innerHTML = '';
    debts.forEach((debt, index) => {
      const item = document.createElement('div');
      item.className = 'debt-item';
      item.style.borderLeft = `4px solid ${debt.color}`;

      let removeBtn = '';
      if (debts.length > 1) {
        removeBtn = `<button class="debt-item-remove" onclick="removeDebt(${debt.id})" aria-label="Remove debt">×</button>`;
      }

      item.innerHTML = `
        ${removeBtn}
        <div class="debt-input-group">
          <label>Debt Name</label>
          <input type="text" value="${debt.name}" onchange="updateDebt(${debt.id}, 'name', this.value)" />
        </div>
        <div class="debt-input-grid">
          <div class="debt-input-group">
            <label>Balance</label>
            <div class="debt-input-wrap">
              <span class="debt-input-prefix">$</span>
              <input type="number" value="${debt.balance}" onchange="updateDebt(${debt.id}, 'balance', this.value)" />
            </div>
          </div>
          <div class="debt-input-group">
            <label>Interest Rate</label>
            <div class="debt-input-wrap suffix">
              <input type="number" value="${debt.rate}" step="0.1" onchange="updateDebt(${debt.id}, 'rate', this.value)" />
              <span class="debt-input-suffix">%</span>
            </div>
          </div>
          <div class="debt-input-group">
            <label>Min Payment</label>
            <div class="debt-input-wrap">
              <span class="debt-input-prefix">$</span>
              <input type="number" value="${debt.minPayment}" onchange="updateDebt(${debt.id}, 'minPayment', this.value)" />
            </div>
          </div>
        </div>
      `;
      listEl.appendChild(item);
    });
    updateHeroStats();
  }

  window.removeDebt = function(id) {
    debts = debts.filter(d => d.id !== id);
    renderDebts();
  };

  window.updateDebt = function(id, field, value) {
    const debt = debts.find(d => d.id === id);
    if (debt) {
      if (field === 'name') debt[field] = value;
      else debt[field] = parseFloat(value) || 0;
    }
    updateHeroStats();
  };

  addBtn.addEventListener('click', () => {
    debts.push({
      id: nextId++,
      name: `Debt ${debts.length + 1}`,
      balance: 5000,
      rate: 10,
      minPayment: 100,
      color: DEBT_COLORS[debts.length % DEBT_COLORS.length]
    });
    renderDebts();
  });

  extraPaymentSlider.addEventListener('input', (e) => {
    extraPaymentVal.textContent = e.target.value;
    calculate();
  });

  function updateHeroStats() {
    const totalBalance = debts.reduce((sum, d) => sum + d.balance, 0);
    document.getElementById('hero-total-debt').textContent = fmtCurrency(totalBalance);
  }

  // Core simulation engine
  function simulatePayoff(strategy, extraMonthlyPay) {
    // Clone state deeply
    let simDebts = debts.map(d => ({ ...d }));
    let totalInterest = 0;
    let months = 0;
    let history = [];

    let totalBalance = simDebts.reduce((sum, d) => sum + d.balance, 0);

    history.push({
      month: 0,
      debts: simDebts.map(d => ({ id: d.id, name: d.name, balance: d.balance, color: d.color }))
    });

    const MAX_MONTHS = 1200;

    while (totalBalance > 0 && months < MAX_MONTHS) {
      months++;
      let startingBalance = totalBalance;
      let monthlyInterestPaid = 0;
      let monthlyPrincipalPaid = 0;

      // Sort debts based on active strategy
      if (strategy === 'avalanche') {
        simDebts.sort((a, b) => b.rate - a.rate);
      } else {
        simDebts.sort((a, b) => a.balance - b.balance);
      }

      // Available cash = all baseline minimums + extra
      let availableCash = debts.reduce((sum, d) => sum + d.minPayment, 0) + extraMonthlyPay;

      // 1. Pay minimums + interest on all remaining debts
      simDebts.forEach(d => {
        if (d.balance > 0) {
          let interest = d.balance * (d.rate / 100 / 12);
          monthlyInterestPaid += interest;
          totalInterest += interest;

          let payment = Math.min(d.balance + interest, d.minPayment);
          d.balance += interest - payment;
          monthlyPrincipalPaid += (payment - interest);
          availableCash -= payment;
        }
      });

      // 2. Apply leftover cash to target debt
      if (availableCash > 0) {
        for (let i = 0; i < simDebts.length; i++) {
          if (simDebts[i].balance > 0) {
            let target = simDebts[i];
            let payment = Math.min(target.balance, availableCash);
            target.balance -= payment;
            monthlyPrincipalPaid += payment;
            availableCash -= payment;
            if (availableCash <= 0) break;
          }
        }
      }

      totalBalance = simDebts.reduce((sum, d) => sum + d.balance, 0);

      history.push({
        month: months,
        starting: startingBalance,
        interest: monthlyInterestPaid,
        principal: monthlyPrincipalPaid,
        payment: monthlyInterestPaid + monthlyPrincipalPaid,
        remaining: totalBalance,
        debts: simDebts.map(d => ({ id: d.id, name: d.name, balance: Math.max(0, d.balance), color: d.color }))
      });
    }

    return { months, totalInterest, history };
  }

  function calculate() {
    const selectedStrategy = strategySelect.value;
    const extraPay = parseFloat(extraPaymentSlider.value) || 0;

    const result = simulatePayoff(selectedStrategy, extraPay);
    const altStrategy = selectedStrategy === 'avalanche' ? 'snowball' : 'avalanche';
    const altResult = simulatePayoff(altStrategy, extraPay);
    const zeroExtraResult = simulatePayoff(selectedStrategy, 0);

    renderDashboard(result, altResult, zeroExtraResult, selectedStrategy, extraPay);
  }

  function renderDashboard(result, altResult, zeroExtraResult, selectedStrategy, extraPay) {
    document.getElementById('result-months').innerHTML = `<strong>${result.months}</strong> Months`;

    const date = new Date();
    date.setMonth(date.getMonth() + result.months);
    const dateStr = date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    document.getElementById('result-date').textContent = dateStr;
    document.getElementById('hero-payoff-date').textContent = dateStr;
    document.getElementById('result-total-interest').textContent = fmtCurrency(result.totalInterest);

    const savingsFromExtra = zeroExtraResult.totalInterest - result.totalInterest;
    const heroSavedEl = document.getElementById('hero-interest-saved');

    if (extraPay > 0 && savingsFromExtra > 0) {
      document.getElementById('result-comparison-note').textContent = `Adding $${extraPay}/mo saves you ${fmtCurrency(savingsFromExtra)} in interest!`;
      heroSavedEl.textContent = fmtCurrency(savingsFromExtra);
      heroSavedEl.classList.remove('celebrate');
      void heroSavedEl.offsetWidth;
      heroSavedEl.classList.add('celebrate');
    } else {
      document.getElementById('result-comparison-note').textContent = '';
      heroSavedEl.textContent = '$0';
    }

    const resAva = selectedStrategy === 'avalanche' ? result : altResult;
    const resSnow = selectedStrategy === 'snowball' ? result : altResult;

    document.getElementById('comp-ava-time').textContent = `${resAva.months} Months`;
    document.getElementById('comp-ava-int').textContent = fmtCurrency(resAva.totalInterest);
    document.getElementById('comp-snow-time').textContent = `${resSnow.months} Months`;
    document.getElementById('comp-snow-int').textContent = fmtCurrency(resSnow.totalInterest);

    const cardAva = document.getElementById('card-avalanche');
    const cardSnow = document.getElementById('card-snowball');
    cardAva.className = 'debt-compare-card';
    cardSnow.className = 'debt-compare-card';

    if (resAva.totalInterest < resSnow.totalInterest) {
        cardAva.classList.add('winner');
    } else if (resSnow.totalInterest < resAva.totalInterest) {
        cardSnow.classList.add('winner');
    }

    const chart = document.getElementById('timeline-chart');
    chart.innerHTML = '';

    const totalMax = result.history[0].debts.reduce((sum, d) => sum + d.balance, 0);
    const step = Math.max(1, Math.floor(result.history.length / 30));

    let chartData = [];
    for(let i=0; i<result.history.length; i+=step) {
      chartData.push(result.history[i]);
    }
    if (chartData[chartData.length-1].month !== result.history[result.history.length-1].month) {
       chartData.push(result.history[result.history.length-1]);
    }

    chartData.forEach((snapshot, idx) => {
      const col = document.createElement('div');
      col.className = 'debt-chart-col';

      let tooltipHtml = `<strong>Month ${snapshot.month}</strong><br/>`;

      snapshot.debts.forEach(d => {
        if (d.balance > 0) {
          const seg = document.createElement('div');
          seg.className = 'debt-chart-segment';
          seg.style.backgroundColor = d.color;
          const pct = Math.max((d.balance / totalMax) * 100, 0.5);
          seg.style.height = '0%';

          setTimeout(() => {
            seg.style.height = pct + '%';
          }, 50 + idx * 30);

          col.appendChild(seg);
          tooltipHtml += `${d.name}: ${fmtCurrency(d.balance)}<br/>`;
        }
      });

      if (snapshot.month > 0) {
         tooltipHtml += `<em>Total: ${fmtCurrency(snapshot.remaining)}</em>`;
      } else {
         tooltipHtml += `<em>Total: ${fmtCurrency(totalMax)}</em>`;
      }

      const tooltip = document.createElement('div');
      tooltip.className = 'debt-chart-tooltip';
      tooltip.innerHTML = tooltipHtml;

      col.appendChild(tooltip);
      chart.appendChild(col);
    });

    const tbody = document.getElementById('schedule-body');
    let schedHtml = '';
    for(let i=1; i<result.history.length; i++) {
      const row = result.history[i];
      if (row.month <= 12 || row.month % 12 === 0 || i === result.history.length - 1) {
        schedHtml += `
          <tr>
            <td>Month ${row.month}</td>
            <td>${fmtCurrency(row.starting)}</td>
            <td>${fmtCurrency(row.payment)}</td>
            <td>${fmtCurrency(row.interest)}</td>
            <td>${fmtCurrency(row.principal)}</td>
            <td>${fmtCurrency(row.remaining)}</td>
          </tr>
        `;
      }
    }
    tbody.innerHTML = schedHtml;
  }


  // Toggle Schedule
  const toggleBtn = document.getElementById('toggle-schedule-btn');
  const scheduleContainer = document.getElementById('schedule-container');
  toggleBtn.addEventListener('click', () => {
    if (scheduleContainer.style.display === 'none') {
      scheduleContainer.style.display = 'block';
      toggleBtn.textContent = 'Collapse Schedule';
    } else {
      scheduleContainer.style.display = 'none';
      toggleBtn.textContent = 'Expand Full Schedule';
    }
  });

  // Init
  renderDebts();
  setTimeout(calculate, 100);
  calcBtn.addEventListener('click', calculate);
</script>
