  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(v);

window.toggleFaq = (btn) => {
    btn.parentElement.classList.toggle('open');
};

function updateAll() {
    const grossIncome = parseFloat(document.getElementById('gross-income').value) || 0;
    const housing = parseFloat(document.getElementById('housing-payment').value) || 0;
    const car = parseFloat(document.getElementById('car-payment').value) || 0;
    const student = parseFloat(document.getElementById('student-loans').value) || 0;
    const credit = parseFloat(document.getElementById('credit-cards').value) || 0;
    const other = parseFloat(document.getElementById('other-debts').value) || 0;

    const totalDebt = housing + car + student + credit + other;
    const nonHousingDebt = car + student + credit + other;

    // DTI calculations
    const frontendDTI = grossIncome > 0 ? (housing / grossIncome) * 100 : 0;
    const backendDTI = grossIncome > 0 ? (totalDebt / grossIncome) * 100 : 0;

    // Update display
    document.getElementById('frontend-dti').innerText = frontendDTI.toFixed(1) + '%';
    document.getElementById('backend-dti').innerText = backendDTI.toFixed(1) + '%';
    document.getElementById('total-debt').innerText = fmt(totalDebt);

    // Update gauge marker (0-60% range mapped to 0-100% width)
    const gaugePos = Math.min(backendDTI / 60 * 100, 100);
    document.getElementById('gauge-marker').style.left = gaugePos + '%';

    // Conventional qualification (28/36 rule)
    const convFrontOk = frontendDTI <= 28;
    const convBackOk = backendDTI <= 36;
    const convBadge = document.getElementById('conv-badge');
    const convStatus = document.getElementById('conv-status');

    if (convFrontOk && convBackOk) {
        convBadge.className = 'qual-badge qual-pass';
        convStatus.innerText = 'Likely Qualifies';
    } else if (convFrontOk || convBackOk) {
        convBadge.className = 'qual-badge qual-warn';
        convStatus.innerText = 'Borderline';
    } else {
        convBadge.className = 'qual-badge qual-fail';
        convStatus.innerText = 'Unlikely';
    }

    // FHA qualification (31/43 rule)
    const fhaFrontOk = frontendDTI <= 31;
    const fhaBackOk = backendDTI <= 43;
    const fhaBadge = document.getElementById('fha-badge');
    const fhaStatus = document.getElementById('fha-status');

    if (fhaFrontOk && fhaBackOk) {
        fhaBadge.className = 'qual-badge qual-pass';
        fhaStatus.innerText = 'Likely Qualifies';
    } else if (fhaFrontOk || fhaBackOk) {
        fhaBadge.className = 'qual-badge qual-warn';
        fhaStatus.innerText = 'Borderline';
    } else {
        fhaBadge.className = 'qual-badge qual-fail';
        fhaStatus.innerText = 'Unlikely';
    }

    // Max affordable mortgage at current back-end DTI level
    // If back-end DTI is 43%, that means at this DTI, the current housing is what it is
    // "Max mortgage at current DTI" = housing payment that keeps back-end at 43% (conventional limit)
    const maxConvBackend = Math.max(0, (grossIncome * 0.36) - nonHousingDebt);
    document.getElementById('max-current-dti').innerText = fmt(maxConvBackend) + '/mo';

    // Max housing payments (front-end limits)
    const maxConvHousing = grossIncome * 0.28;
    const maxFhaHousing = grossIncome * 0.31;
    document.getElementById('max-conv').innerText = fmt(maxConvHousing) + '/mo';
    document.getElementById('max-fha').innerText = fmt(maxFhaHousing) + '/mo';

    // Debt payoff to reach target DTI
    const targetDti = parseFloat(document.getElementById('target-dti').value) || 36;
    const targetMaxDebt = grossIncome * (targetDti / 100);
    const debtToPayOff = Math.max(0, totalDebt - targetMaxDebt);
    document.getElementById('debt-payoff').innerText = debtToPayOff > 0
        ? fmt(debtToPayOff) + '/mo to eliminate'
        : 'Already at target!';
}

// Attach listeners
document.querySelectorAll('input[type="number"]').forEach(el => {
    el.addEventListener('input', updateAll);
    el.addEventListener('change', updateAll);
});

// Initial calc
updateAll();
  </script>
