---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Debt-to-Income Ratio Calculator",
  "url": "https://firemaths.info/debt-to-income-calculator",
  "description": "Free debt-to-income ratio calculator — instantly calculate your front-end and back-end DTI ratio, check FHA and conventional mortgage qualification, and see how much house you can afford.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a good debt-to-income ratio for a mortgage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For a conventional mortgage, lenders typically want a front-end DTI (housing costs only) of 28% or less and a back-end DTI (all debts) of 36% or less — known as the 28/36 rule. FHA loans are more flexible, allowing up to 31% front-end and 43% back-end DTI. Some lenders may approve borrowers with higher ratios if they have strong credit scores, large down payments, or significant cash reserves."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between front-end and back-end DTI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Front-end DTI (also called the housing ratio) measures only your housing-related expenses — mortgage payment, property taxes, homeowner's insurance, and HOA fees — as a percentage of gross monthly income. Back-end DTI includes all monthly debt obligations: housing costs plus car payments, student loans, credit card minimums, personal loans, and any other recurring debt. Lenders evaluate both ratios when deciding mortgage approval."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my debt-to-income ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate your DTI ratio, add up all your monthly debt payments (rent or mortgage, car loans, student loans, credit card minimums, and other debt payments) and divide by your gross monthly income (before taxes). Multiply by 100 to get a percentage. For example, if your monthly debts total $2,000 and your gross monthly income is $6,000, your DTI is $2,000 ÷ $6,000 = 0.333, or 33.3%."
      }
    },
    {
      "@type": "Question",
      "name": "Does rent count in debt-to-income ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When applying for a mortgage, your current rent payment is typically not included in DTI calculations because it will be replaced by the new mortgage payment. Instead, lenders use your projected mortgage payment (including taxes and insurance) for the front-end DTI. However, if you plan to keep paying rent on a separate property while also paying a mortgage, both payments would count toward your back-end DTI."
      }
    },
    {
      "@type": "Question",
      "name": "How can I lower my debt-to-income ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There are two main strategies to lower your DTI: reduce your monthly debt payments or increase your gross income. To reduce debt, pay off credit cards and small loans, refinance existing loans for lower payments, or avoid taking on new debt. To increase income, negotiate a raise, take on a side job, or include a co-borrower on your mortgage application. Even small changes can make a big difference — paying off a $300/month car loan drops your DTI by 5% on a $6,000 monthly income."
      }
    }
  ]
};

export const meta = {
  title: "Debt-to-Income Ratio Calculator — DTI for Mortgage Qualification | firemaths.info",
  description: "Free DTI calculator — instantly calculate your front-end and back-end debt-to-income ratio, check FHA and conventional loan qualification, and see how much house you can afford.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Debt-to-Income Ratio Calculator — DTI for Mortgage Qualification | firemaths.info"
  description="Free DTI calculator — instantly calculate your front-end and back-end debt-to-income ratio, check FHA and conventional loan qualification, and see how much house you can afford."
  canonical="https://firemaths.info/debt-to-income-calculator" schema={schema}
>
  <style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"] {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.split-divider {
    padding-top: 1rem;
    margin-top: 0.5rem;
    border-top: 1px dashed var(--border-color);
}

/* DTI Gauge */
.gauge-container {
    margin: 1.5rem 0;
}

.gauge-bar {
    width: 100%;
    height: 24px;
    border-radius: 12px;
    background: linear-gradient(to right, #22c55e 0%, #22c55e 60%, #eab308 60%, #eab308 71.67%, #ef4444 71.67%, #ef4444 100%);
    position: relative;
    overflow: visible;
}

.gauge-marker {
    position: absolute;
    top: -6px;
    width: 4px;
    height: 36px;
    background: var(--text-primary);
    border-radius: 2px;
    transform: translateX(-50%);
    transition: left 0.4s ease;
    box-shadow: 0 0 6px rgba(0,0,0,0.4);
}

.gauge-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
}

.gauge-zone-labels {
    display: flex;
    margin-top: 0.25rem;
    font-size: 0.7rem;
    color: var(--text-secondary);
}

.gauge-zone-labels span {
    text-align: center;
}

.gauge-zone-labels .zone-green { width: 60%; color: #22c55e; }
.gauge-zone-labels .zone-yellow { width: 12%; color: #eab308; }
.gauge-zone-labels .zone-red { width: 28%; color: #ef4444; }

/* Qualification badges */
.qual-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 1rem 0;
}

.qual-badge {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    text-align: center;
    border: 1px solid var(--border-color);
    background: var(--bg-color);
}

.qual-badge .qual-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    display: block;
    margin-bottom: 0.25rem;
}

.qual-badge .qual-status {
    font-weight: 700;
    font-size: 0.9rem;
}

.qual-pass { border-color: #22c55e; }
.qual-pass .qual-status { color: #22c55e; }
.qual-warn { border-color: #eab308; }
.qual-warn .qual-status { color: #eab308; }
.qual-fail { border-color: #ef4444; }
.qual-fail .qual-status { color: #ef4444; }

.guide-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 3rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
}

.guide-table th, .guide-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border-color);
}

.guide-table th {
    background-color: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.guide-table tr:last-child td {
    border-bottom: none;
}

.guide-table td:nth-child(2),
.guide-table td:nth-child(3) {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent-color);
    font-size: 0.85rem;
}

.tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .tips-grid {
        grid-template-columns: 1fr;
    }
}

.tip-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.tip-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.tip-card ul {
    list-style: none;
    padding: 0;
}

.tip-card li {
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
}

.tip-card li::before {
    content: "\203A";
    position: absolute;
    left: 0;
    color: var(--accent-color);
    font-weight: bold;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "\2212";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
    .qual-grid {
        grid-template-columns: 1fr;
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}

@media (max-width: 640px) {
    .guide-table {
        font-size: 0.8rem;
    }
    .guide-table th, .guide-table td {
        padding: 0.65rem 0.5rem;
    }
}
  </style>

<div class="container">
    <h1>Debt-to-Income Ratio Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Calculate your DTI ratio and check mortgage qualification instantly</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Income &amp; Debts</h2>
                </div>

                <div class="inputs">
                    <div class="input-group">
                        <label for="gross-income">Gross Monthly Income (before taxes)</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="gross-income" value="6000" min="0" step="100">
                        </div>
                    </div>

                    <div style="margin-top: 0.5rem; margin-bottom: 0.5rem; font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Housing Costs</div>

                    <div class="input-group">
                        <label for="housing-payment">Rent / Mortgage Payment</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="housing-payment" value="1400" min="0" step="50">
                        </div>
                    </div>

                    <div style="margin-top: 0.5rem; margin-bottom: 0.5rem; font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Other Debt Payments</div>

                    <div class="input-group">
                        <label for="car-payment">Car Payments</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="car-payment" value="350" min="0" step="25">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="student-loans">Student Loans</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="student-loans" value="250" min="0" step="25">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="credit-cards">Credit Card Minimums</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="credit-cards" value="150" min="0" step="25">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="other-debts">Other Debt Payments</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="other-debts" value="0" min="0" step="25">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your DTI Results</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 0.5rem;">
                        <span class="result-label" style="font-size: 1rem;">Back-End DTI (All Debt)</span>
                        <div class="result-value">
                            <span id="backend-dti">0%</span>
                        </div>
                    </div>

                    <div class="gauge-container">
                        <div class="gauge-bar">
                            <div class="gauge-marker" id="gauge-marker"></div>
                        </div>
                        <div class="gauge-labels">
                            <span>0%</span>
                            <span>36%</span>
                            <span>43%</span>
                            <span>60%+</span>
                        </div>
                        <div class="gauge-zone-labels">
                            <span class="zone-green">Good (&lt;36%)</span>
                            <span class="zone-yellow">Caution</span>
                            <span class="zone-red">High (&gt;43%)</span>
                        </div>
                    </div>

                    <div class="result-item" style="margin-top: 0.5rem;">
                        <span class="result-label">Front-End DTI (Housing Only)</span>
                        <div class="result-value">
                            <span id="frontend-dti">0%</span>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Total Monthly Debt</span>
                        <div class="result-value">
                            <span id="total-debt">$0</span>
                        </div>
                    </div>

                    <div class="split-divider">
                        <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Mortgage Qualification</div>

                        <div class="qual-grid">
                            <div class="qual-badge" id="conv-badge">
                                <span class="qual-label">Conventional (28/36)</span>
                                <span class="qual-status" id="conv-status">--</span>
                            </div>
                            <div class="qual-badge" id="fha-badge">
                                <span class="qual-label">FHA (31/43)</span>
                                <span class="qual-status" id="fha-status">--</span>
                            </div>
                        </div>
                    </div>

                    <div class="split-divider">
                        <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Max Affordable Mortgage</div>

                        <div class="result-item">
                            <span class="result-label">At Current DTI (back-end)</span>
                            <div class="result-value" style="font-size: 1rem; color: var(--accent-color);">
                                <span id="max-current-dti">$0</span>
                            </div>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Conv. Front-End (28%)</span>
                            <div class="result-value" style="font-size: 1rem;">
                                <span id="max-conv">$0</span>
                            </div>
                        </div>
                        <div class="result-item">
                            <span class="result-label">FHA Front-End (31%)</span>
                            <div class="result-value" style="font-size: 1rem;">
                                <span id="max-fha">$0</span>
                            </div>
                        </div>
                    </div>

                    <div class="split-divider">
                        <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Debt Payoff to Reach Target DTI</div>

                        <div class="input-group" style="margin-bottom: 0.75rem;">
                            <label for="target-dti">Target Back-End DTI</label>
                            <div class="input-wrapper has-suffix">
                                <span class="suffix">%</span>
                                <input type="number" id="target-dti" value="36" min="1" max="100" step="1">
                            </div>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Monthly Debt to Eliminate</span>
                            <div class="result-value" style="font-size: 1rem; color: var(--accent-color);">
                                <span id="debt-payoff">$0/mo</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FHA vs Conventional -->
        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--accent-color);">FHA vs Conventional DTI Requirements</h2>
        <table class="guide-table">
            <thead>
                <tr>
                    <th>Requirement</th>
                    <th>Conventional</th>
                    <th>FHA</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Front-End DTI Limit</td>
                    <td>28%</td>
                    <td>31%</td>
                </tr>
                <tr>
                    <td>Back-End DTI Limit</td>
                    <td>36%</td>
                    <td>43%</td>
                </tr>
                <tr>
                    <td>Max DTI with Compensating Factors</td>
