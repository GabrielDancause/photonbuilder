</div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);

function getInputs() {
    return {
        homePrice: parseFloat(document.getElementById('home-price').value) || 0,
        downPercent: parseFloat(document.getElementById('down-percent').value) || 0,
        mortgageRate: parseFloat(document.getElementById('mortgage-rate').value) || 0,
        propertyTaxRate: parseFloat(document.getElementById('property-tax').value) || 0,
        homeInsurance: parseFloat(document.getElementById('home-insurance').value) || 0,
        maintenanceRate: parseFloat(document.getElementById('maintenance').value) || 0,
        hoaFee: parseFloat(document.getElementById('hoa-fee').value) || 0,
        homeAppreciation: parseFloat(document.getElementById('home-appreciation').value) || 0,
        monthlyRent: parseFloat(document.getElementById('monthly-rent').value) || 0,
        rentIncrease: parseFloat(document.getElementById('rent-increase').value) || 0,
        rentersInsurance: parseFloat(document.getElementById('renters-insurance').value) || 0,
        investmentReturn: parseFloat(document.getElementById('investment-return').value) || 0,
        yearsCompare: parseInt(document.getElementById('years-compare').value) || 10,
        taxBracket: parseFloat(document.getElementById('tax-bracket').value) || 0,
        closingCostsPct: parseFloat(document.getElementById('closing-costs').value) || 0,
        sellingCostsPct: parseFloat(document.getElementById('selling-costs').value) || 0,
    };
}

function calcMonthlyPI(loanAmount, annualRate, termYears) {
    if (loanAmount <= 0) return 0;
    if (annualRate <= 0) return loanAmount / (termYears * 12);
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    return loanAmount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function calculate() {
    const inp = getInputs();
    const downPayment = inp.homePrice * inp.downPercent / 100;
    const loanAmount = inp.homePrice - downPayment;
    const closingCosts = inp.homePrice * inp.closingCostsPct / 100;
    const monthlyPI = calcMonthlyPI(loanAmount, inp.mortgageRate, 30);
    const monthlyRate = inp.mortgageRate / 100 / 12;
    const monthlyInvestReturn = inp.investmentReturn / 100 / 12;

    const yearlyData = [];
    let mortgageBalance = loanAmount;
    let homeValue = inp.homePrice;
    let renterPortfolio = downPayment + closingCosts;
    let cumulativeBuyCost = downPayment + closingCosts;
    let cumulativeRentCost = 0;
    let currentRent = inp.monthlyRent;
    let breakEvenYear = null;

    for (let year = 1; year <= inp.yearsCompare; year++) {
        let yearBuyCost = 0;
        let yearRentCost = 0;

        for (let month = 1; month <= 12; month++) {
            // Buying costs
            const interestPayment = mortgageBalance * monthlyRate;
            let principalPayment = monthlyPI - interestPayment;
            if (principalPayment > mortgageBalance) principalPayment = mortgageBalance;
            mortgageBalance = Math.max(0, mortgageBalance - principalPayment);

            const monthlyPropertyTax = (homeValue * inp.propertyTaxRate / 100) / 12;
            const monthlyInsurance = inp.homeInsurance / 12;
            const monthlyMaintenance = (homeValue * inp.maintenanceRate / 100) / 12;
            const needsPMI = inp.downPercent < 20 && (mortgageBalance / homeValue) > 0.8;
            const monthlyPMI = needsPMI ? (loanAmount * 0.5 / 100) / 12 : 0;

            const totalBuyMonthly = monthlyPI + monthlyPropertyTax + monthlyInsurance + monthlyMaintenance + monthlyPMI + inp.hoaFee;
            yearBuyCost += totalBuyMonthly;

            // Renting costs
            const totalRentMonthly = currentRent + inp.rentersInsurance / 12;
            yearRentCost += totalRentMonthly;

            // Renter invests the difference
            const monthlySavings = totalBuyMonthly - totalRentMonthly;
            if (monthlySavings > 0) {
                renterPortfolio += monthlySavings;
            }
            renterPortfolio *= (1 + monthlyInvestReturn);
        }

        // End of year adjustments
        homeValue *= (1 + inp.homeAppreciation / 100);
        currentRent *= (1 + inp.rentIncrease / 100);

        cumulativeBuyCost += yearBuyCost;
        cumulativeRentCost += yearRentCost;

        // Buyer net worth: home value - mortgage - selling costs
        const sellingCosts = homeValue * inp.sellingCostsPct / 100;
        const buyerNetWorth = homeValue - mortgageBalance - sellingCosts;
        const homeEquity = homeValue - mortgageBalance;

        const renterNetWorth = renterPortfolio;
        const advantage = buyerNetWorth - renterNetWorth;

        if (breakEvenYear === null && advantage > 0) {
            breakEvenYear = year;
        }

        yearlyData.push({
            year,
            yearBuyCost,
            yearRentCost,
            cumulativeBuyCost,
            cumulativeRentCost,
            homeEquity,
            renterPortfolio: renterNetWorth,
            buyerNetWorth,
            renterNetWorth,
            advantage,
        });
    }

    // Update results
    const finalYear = yearlyData[yearlyData.length - 1];
    document.getElementById('res-years').innerText = inp.yearsCompare;
    document.getElementById('res-total-buy').innerText = fmt(finalYear.cumulativeBuyCost);
    document.getElementById('res-total-rent').innerText = fmt(finalYear.cumulativeRentCost);
    document.getElementById('res-nw-buy').innerText = fmt(finalYear.buyerNetWorth);
    document.getElementById('res-nw-rent').innerText = fmt(finalYear.renterNetWorth);

    const netDiff = Math.abs(finalYear.advantage);
    const isBuyBetter = finalYear.advantage > 0;
    document.getElementById('res-verdict').innerText = isBuyBetter ? 'Buying' : 'Renting';
    document.getElementById('res-verdict-sub').innerText = 'by ' + fmt(netDiff) + ' in net worth';
    document.getElementById('res-net-diff').innerText = (isBuyBetter ? '+' : '-') + fmt(netDiff);
    document.getElementById('res-breakeven').innerText = breakEvenYear ? 'Year ' + breakEvenYear : 'Never';

    renderTable(yearlyData, breakEvenYear);
    drawChart('nwChart', yearlyData, 'buyerNetWorth', 'renterNetWorth');
    drawChart('costChart', yearlyData, 'cumulativeBuyCost', 'cumulativeRentCost');
}

function renderTable(data, breakEvenYear) {
    const tbody = document.getElementById('breakdown-tbody');
    let html = '';
    for (const row of data) {
        const rowClass = row.year === breakEvenYear ? ' class="breakeven-row"' : '';
        const advLabel = row.advantage >= 0 ? 'Buy +' + fmt(row.advantage) : 'Rent +' + fmt(Math.abs(row.advantage));
        html += `<tr${rowClass}>
            <td>${row.year}</td>
            <td>${fmt(row.yearBuyCost)}</td>
            <td>${fmt(row.yearRentCost)}</td>
            <td>${fmt(row.homeEquity)}</td>
            <td>${fmt(row.renterPortfolio)}</td>
            <td>${fmt(row.buyerNetWorth)}</td>
            <td>${fmt(row.renterNetWorth)}</td>
            <td>${advLabel}</td>
        </tr>`;
    }
    tbody.innerHTML = html;
}

function drawChart(canvasId, data, key1, key2) {
    const canvas = document.getElementById(canvasId);
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const w = container.getBoundingClientRect().width;
    const h = container.getBoundingClientRect().height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    if (data.length === 0) return;

    const padding = { top: 30, right: 20, bottom: 40, left: 70 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    let allValues = [];
    for (const d of data) {
        allValues.push(d[key1], d[key2]);
    }
    let minVal = Math.min(0, ...allValues);
    let maxVal = Math.max(...allValues);
    const range = maxVal - minVal;
    if (range === 0) { maxVal = minVal + 1; }
    minVal -= range * 0.05;
    maxVal += range * 0.05;

    const xScale = (i) => padding.left + (i / (data.length - 1 || 1)) * chartW;
    const yScale = (v) => padding.top + chartH - ((v - minVal) / (maxVal - minVal)) * chartH;

    // Grid lines
    ctx.strokeStyle = 'rgba(128,128,128,0.15)';
    ctx.lineWidth = 1;
    const gridLines = 5;
    ctx.font = '11px Inter, sans-serif';
    ctx.fillStyle = '#888888';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    for (let i = 0; i <= gridLines; i++) {
        const val = minVal + (maxVal - minVal) * (i / gridLines);
        const y = yScale(val);
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();
        const lbl = val >= 1000000 ? (val / 1000000).toFixed(1) + 'M' : val >= 1000 ? Math.round(val / 1000) + 'k' : Math.round(val);
        ctx.fillText('$' + lbl, padding.left - 8, y);
    }

    // X labels
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    for (let i = 0; i < data.length; i++) {
        const step = data.length > 20 ? 5 : data.length > 10 ? 2 : 1;
        if (i % step === 0 || i === data.length - 1) {
            ctx.fillText('Yr ' + data[i].year, xScale(i), h - padding.bottom + 8);
        }
    }

    // Draw lines
    function drawLine(key, color) {
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2.5;
        ctx.lineJoin = 'round';
        for (let i = 0; i < data.length; i++) {
            const x = xScale(i);
            const y = yScale(data[i][key]);
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        }
        ctx.stroke();

        for (let i = 0; i < data.length; i++) {
            ctx.beginPath();
            ctx.arc(xScale(i), yScale(data[i][key]), 4, 0, Math.PI * 2);
            ctx.fillStyle = color;
            ctx.fill();
        }
    }

    drawLine(key1, '#4A90E2');
    drawLine(key2, '#50E3C2');

    // Zero line
    if (minVal < 0 && maxVal > 0) {
        ctx.strokeStyle = 'rgba(128,128,128,0.4)';
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 4]);
        ctx.beginPath();
        ctx.moveTo(padding.left, yScale(0));
        ctx.lineTo(w - padding.right, yScale(0));
        ctx.stroke();
        ctx.setLineDash([]);
    }
}

// Attach listeners
const allInputs = [
    'home-price', 'down-percent', 'mortgage-rate', 'property-tax', 'home-insurance',
    'maintenance', 'hoa-fee', 'home-appreciation', 'monthly-rent', 'rent-increase',
    'renters-insurance', 'investment-return', 'years-compare', 'tax-bracket',
    'closing-costs', 'selling-costs'
];
allInputs.forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
});

window.addEventListener('resize', calculate);

setTimeout(calculate, 0);
  </script>
</SiteLayout>
