---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Fire Maths — Financial Independence Tools",
  "url": "https://firemaths.info/",
  "description": "Free financial calculators, guides, and research. FIRE planning, budgeting, investing, taxes, and real estate."
};
