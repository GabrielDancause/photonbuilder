---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "FIRE Calculator: Calculate Your Financial Independence Number",
  description: "Calculate when you can retire early with our free FIRE (Financial Independence, Retire Early) calculator. Plan your path to financial freedom using real math.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the FIRE movement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "FIRE stands for Financial Independence, Retire Early. It's a movement focused on aggressive savings and investment to achieve financial independence well before traditional retirement age."
      }
    },
    {
      "@type": "Question",
      "name": "How is my FIRE number calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your FIRE number is typically calculated by taking your annual expenses and dividing them by your safe withdrawal rate (often 4%, which is the same as multiplying expenses by 25)."
      }
    },
    {
      "@type": "Question",
      "name": "What is the 4% rule?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 4% rule is a guideline stating you can safely withdraw 4% of your initial retirement portfolio value each year (adjusted for inflation) without running out of money over a 30-year period."
      }
    },
    {
      "@type": "Question",
      "name": "What are Lean FIRE and Fat FIRE?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lean FIRE refers to retiring with a minimalist lifestyle and lower expenses. Fat FIRE refers to retiring with a larger portfolio that supports a more luxurious lifestyle and higher spending."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use this calculator for traditional retirement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, the math behind compound interest and safe withdrawal rates applies to traditional retirement planning just as it does to early retirement."
      }
    }
  ]
});
---

<SiteLayout site="firemaths" title={meta.title} description={meta.description} canonical="https://firemaths.info/fire-calculator" schema={schema}>
  <div class="page-content">
    <div class="container">
      <h1>FIRE Calculator</h1>
      <p style="text-align: center; margin-bottom: 2rem;">Calculate exactly how much you need to achieve Financial Independence and Retire Early.</p>

      <div class="calculator-card">
        <div class="calc-grid">
          <div class="input-section">
            <div class="input-group">
              <label for="annualExpenses">Estimated Annual Expenses in Retirement</label>
              <div class="input-wrapper">
                <span class="prefix">$</span>
                <input type="number" id="annualExpenses" value="60000" min="1000" step="1000">
              </div>
            </div>

            <div class="input-group">
              <label for="currentAge">Current Age</label>
              <div class="input-wrapper">
                <input type="number" id="currentAge" value="30" min="18" max="100" step="1">
              </div>
            </div>

            <div class="input-group">
              <label for="currentSavings">Current Invested Savings</label>
              <div class="input-wrapper">
                <span class="prefix">$</span>
                <input type="number" id="currentSavings" value="50000" min="0" step="1000">
              </div>
            </div>

            <div class="input-group">
              <label for="monthlyContribution">Monthly Investment Contribution</label>
              <div class="input-wrapper">
                <span class="prefix">$</span>
                <input type="number" id="monthlyContribution" value="1500" min="0" step="100">
              </div>
            </div>

            <div class="input-group">
              <label for="expectedReturn">Expected Annual Return</label>
              <div class="input-wrapper">
                <input type="number" id="expectedReturn" value="7" min="1" max="20" step="0.1">
                <span class="suffix">%</span>
              </div>
            </div>

            <div class="input-group">
              <label for="withdrawalRate">Safe Withdrawal Rate (SWR)</label>
              <div class="input-wrapper">
                <input type="number" id="withdrawalRate" value="4" min="1" max="10" step="0.1">
                <span class="suffix">%</span>
              </div>
            </div>
          </div>

          <div class="results-section">
            <div class="primary-result">
              <span class="result-label">Your FIRE Target Number</span>
              <div class="result-value" id="fireNumberResult">$1,500,000</div>
            </div>

            <div class="stats-grid" style="margin-top: 1.5rem;">
              <div class="stat-card">
                <span class="result-label">Years to FIRE</span>
                <div class="result-value secondary" id="yearsToFireResult">22</div>
              </div>
              <div class="stat-card">
                <span class="result-label">Age at FIRE</span>
                <div class="result-value secondary" id="ageAtFireResult">52</div>
              </div>
            </div>

            <div class="stat-card" style="margin-top: 1.5rem;">
               <span class="result-label">Required Savings Rate (To hit target)</span>
               <div class="result-value secondary" id="savingsRateResult" style="font-size: 1.5rem; color: var(--text-primary);">N/A</div>
               <p style="font-size: 0.8rem; margin-top: 0.5rem; text-align:center;">Based on income matching expenses + contributions</p>
            </div>
          </div>
        </div>
      </div>

      <h3>Growth Projection</h3>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Age</th>
              <th>Year</th>
              <th>Total Contributions</th>
              <th>Investment Returns</th>
              <th>Portfolio Value</th>
            </tr>
          </thead>
          <tbody id="projectionTableBody">
            <!-- Populated by JS -->
          </tbody>
        </table>
      </div>
      <div class="content-section" style="margin-top: 4rem;">
        <h2>What is the FIRE Movement?</h2>
        <p>The <strong>FIRE movement</strong> (Financial Independence, Retire Early) is a lifestyle movement with the goal of gaining financial independence and retiring early. The model became particularly popular among millennials in the 2010s, gaining traction through online communities.</p>
        <p>Those seeking to attain FIRE intentionally maximize their savings rate by finding ways to increase income and/or decrease expenses. The objective is to accumulate assets until the resulting passive income provides enough money for living expenses in perpetuity.</p>

        <h2>How the FIRE Calculator Works</h2>
        <p>This calculator determines your FIRE number and the time it will take to reach it based on two core mathematical principles: the Safe Withdrawal Rate and Compound Interest.</p>

        <h3>The Safe Withdrawal Rate (The 4% Rule)</h3>
        <p>Your FIRE target number is calculated using the Safe Withdrawal Rate (SWR). The most famous SWR is the "4% Rule," which originated from the Trinity Study. The study found that withdrawing 4% of a portfolio's initial value annually (adjusted for inflation) historically resulted in a high probability of the portfolio lasting for a 30-year retirement without running out of money.</p>
        <p>The formula to calculate your FIRE number is:</p>
        <code>FIRE Number = Annual Expenses ÷ Safe Withdrawal Rate</code>
        <p style="margin-top: 1rem;">For example, if your annual expenses are $60,000 and you use a 4% (0.04) withdrawal rate: <code>$60,000 ÷ 0.04 = $1,500,000</code>. This is mathematically equivalent to multiplying your annual expenses by 25.</p>

        <h3>Compound Interest</h3>
        <p>To project when you will reach your FIRE number, the calculator uses the formula for compound interest with regular monthly contributions:</p>
        <code>A = P(1 + r/n)^(nt) + PMT × {'{[(1 + r/n)^(nt) - 1] / (r/n)}'}</code>
        <ul>
          <li><strong>A</strong> = the future value of the investment/loan, including interest</li>
          <li><strong>P</strong> = the principal investment amount (the initial deposit or loan amount)</li>
          <li><strong>PMT</strong> = the monthly payment</li>
          <li><strong>r</strong> = the annual interest rate (decimal)</li>
          <li><strong>n</strong> = the number of times that interest is compounded per unit t</li>
          <li><strong>t</strong> = the time the money is invested or borrowed for</li>
        </ul>
        <p>By solving for <em>t</em> iteratively until <em>A</em> equals or exceeds your FIRE number, the calculator determines how many years it will take to reach financial independence.</p>

        <h2>Types of FIRE</h2>
        <p>The FIRE movement has evolved into several different variations based on individual goals and lifestyle preferences:</p>
        <ul>
          <li><strong>Lean FIRE:</strong> Requires extreme frugality and minimalism. Adherents plan to live on a very strict budget in retirement, often requiring a smaller portfolio (e.g., $500,000 to $1 million).</li>
          <li><strong>Fat FIRE:</strong> For individuals aiming for a higher standard of living in retirement. This requires a significantly larger portfolio (often $2.5 million or more) to support a more traditional or luxurious lifestyle.</li>
          <li><strong>Barista FIRE:</strong> A hybrid approach where individuals save enough to quit their high-stress careers but continue working part-time (like a barista) to cover living expenses and maintain health insurance benefits while their investments continue to grow.</li>
          <li><strong>Coast FIRE:</strong> Occurs when you have saved enough at a relatively young age that, without any further contributions, your investments will grow to support your traditional retirement. You still need to work to cover current living expenses, but you no longer need to save for retirement.</li>
        </ul>

        <div class="faq-section">
          <h2>Frequently Asked Questions</h2>
          <details>
            <summary>What is the FIRE movement?</summary>
            <div class="faq-answer">
              <p>FIRE stands for Financial Independence, Retire Early. It's a movement focused on aggressive savings and investment to achieve financial independence well before traditional retirement age.</p>
            </div>
          </details>
          <details>
            <summary>How is my FIRE number calculated?</summary>
            <div class="faq-answer">
              <p>Your FIRE number is typically calculated by taking your annual expenses and dividing them by your safe withdrawal rate (often 4%, which is the same as multiplying expenses by 25).</p>
            </div>
          </details>
          <details>
            <summary>What is the 4% rule?</summary>
            <div class="faq-answer">
              <p>The 4% rule is a guideline stating you can safely withdraw 4% of your initial retirement portfolio value each year (adjusted for inflation) without running out of money over a 30-year period.</p>
            </div>
          </details>
          <details>
            <summary>What are Lean FIRE and Fat FIRE?</summary>
            <div class="faq-answer">
              <p>Lean FIRE refers to retiring with a minimalist lifestyle and lower expenses. Fat FIRE refers to retiring with a larger portfolio that supports a more luxurious lifestyle and higher spending.</p>
            </div>
          </details>
          <details>
            <summary>Can I use this calculator for traditional retirement?</summary>
            <div class="faq-answer">
              <p>Yes, the math behind compound interest and safe withdrawal rates applies to traditional retirement planning just as it does to early retirement.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</SiteLayout>

<script>
  function initCalculator() {
    const container = document.querySelector('.calculator-card');
    if (!container || container.dataset.initialized) return;
    container.dataset.initialized = 'true';

    // Inputs
    const annualExpensesEl = document.getElementById('annualExpenses');
    const currentAgeEl = document.getElementById('currentAge');
    const currentSavingsEl = document.getElementById('currentSavings');
    const monthlyContributionEl = document.getElementById('monthlyContribution');
    const expectedReturnEl = document.getElementById('expectedReturn');
    const withdrawalRateEl = document.getElementById('withdrawalRate');

    // Results
    const fireNumberResult = document.getElementById('fireNumberResult');
    const yearsToFireResult = document.getElementById('yearsToFireResult');
    const ageAtFireResult = document.getElementById('ageAtFireResult');
    const savingsRateResult = document.getElementById('savingsRateResult');
    const projectionTableBody = document.getElementById('projectionTableBody');

    function calculate() {
      // Get Values
      const annualExpenses = parseFloat(annualExpensesEl.value) || 0;
      const currentAge = parseFloat(currentAgeEl.value) || 0;
      let currentSavings = parseFloat(currentSavingsEl.value) || 0;
      const monthlyContribution = parseFloat(monthlyContributionEl.value) || 0;
      const expectedReturn = parseFloat(expectedReturnEl.value) || 0;
      const withdrawalRate = parseFloat(withdrawalRateEl.value) || 0;

      // Formatters
      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
      const formatPercent = (val) => new Intl.NumberFormat('en-US', { style: 'percent', minimumFractionDigits: 1, maximumFractionDigits: 1 }).format(val / 100);

      // Handle edge cases
      if (withdrawalRate <= 0 || expectedReturn <= 0 || annualExpenses <= 0) {
        fireNumberResult.textContent = '$0';
        yearsToFireResult.textContent = 'N/A';
        ageAtFireResult.textContent = 'N/A';
        savingsRateResult.textContent = 'N/A';
        if (projectionTableBody) projectionTableBody.innerHTML = '';
        return;
      }

      // Calculate FIRE Number
      const decimalWithdrawalRate = withdrawalRate / 100;
      const fireNumber = annualExpenses / decimalWithdrawalRate;

      // Calculate Required Savings Rate
      // Implied Income = Annual Expenses + (Monthly Contribution * 12)
      const annualContribution = monthlyContribution * 12;
      const impliedIncome = annualExpenses + annualContribution;
      let savingsRate = 0;
      if (impliedIncome > 0) {
        savingsRate = (annualContribution / impliedIncome) * 100;
      }

      fireNumberResult.textContent = formatCurrency(fireNumber);
      savingsRateResult.textContent = formatPercent(savingsRate);

      // Simulation
      let years = 0;
      let balance = currentSavings;
      const annualRate = expectedReturn / 100;
      const monthlyRate = annualRate / 12;
      let totalContributions = currentSavings;
      let totalReturns = 0;
      let maxYears = 100; // Cap simulation years

      const projectionData = [];

      // If already at FIRE number
      if (balance >= fireNumber) {
          yearsToFireResult.textContent = '0';
          ageAtFireResult.textContent = currentAge.toString();

          projectionData.push({
            age: currentAge,
            year: 0,
            contributions: totalContributions,
            returns: totalReturns,
            balance: balance
          });
      } else {
          projectionData.push({
            age: currentAge,
            year: 0,
            contributions: totalContributions,
            returns: totalReturns,
            balance: balance
          });

          while (balance < fireNumber && years < maxYears) {
            years++;
            let yearlyInterest = 0;

            // Compound monthly over the year
            for(let m = 0; m < 12; m++) {
               let interest = balance * monthlyRate;
               balance += interest + monthlyContribution;
               yearlyInterest += interest;
               totalContributions += monthlyContribution;
            }
            totalReturns += yearlyInterest;

            projectionData.push({
              age: currentAge + years,
              year: years,
              contributions: totalContributions,
              returns: totalReturns,
              balance: balance
            });
          }

          if (balance >= fireNumber) {
              yearsToFireResult.textContent = years.toString();
              ageAtFireResult.textContent = (currentAge + years).toString();
          } else {
              yearsToFireResult.textContent = '100+';
              ageAtFireResult.textContent = 'N/A';
          }
      }

      // Update Table (Show every 5 years, plus first and last)
      let tableHTML = '';
      if (projectionTableBody) {
          projectionData.forEach((row, index) => {
            if (index === 0 || index === projectionData.length - 1 || row.year % 5 === 0) {
              tableHTML += `
                <tr>
                  <td>${row.age}</td>
                  <td>Year ${row.year}</td>
                  <td>${formatCurrency(row.contributions)}</td>
                  <td>${formatCurrency(row.returns)}</td>
                  <td style="color: var(--text-primary); font-weight: 600;">${formatCurrency(row.balance)}</td>
                </tr>
              `;
            }
          });
          projectionTableBody.innerHTML = tableHTML;
      }
    }

    // Attach listeners
    [annualExpensesEl, currentAgeEl, currentSavingsEl, monthlyContributionEl, expectedReturnEl, withdrawalRateEl].forEach(el => {
      if (el) el.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  }

  // Setup for Astro View Transitions & initial load
  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>

<style>
  .calc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .calc-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .primary-result {
    background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-color) 30%, transparent);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }

  .result-label {
    display: block;
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .result-value {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--accent-color);
  }

  .result-value.secondary {
    font-size: 2rem;
    color: var(--text-primary);
  }

  .faq-answer p {
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  details {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  summary {
    font-weight: 600;
    cursor: pointer;
    color: var(--text-primary);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '+';
    color: var(--accent-color);
    font-size: 1.5rem;
    font-weight: normal;
  }

  details[open] summary::after {
    content: '−';
  }
</style>
