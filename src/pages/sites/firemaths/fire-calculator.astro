---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "FIRE Calculator",
  "description": "Calculate your Financial Independence, Retire Early (FIRE) number, estimated retirement date, and required savings.",
  "url": "https://firemaths.info/fire-calculator.html",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Any"
};
---

<SiteLayout
  site="firemaths"
  title="FIRE Calculator — Find Your Financial Independence Number"
  description="Calculate your FIRE number (Financial Independence, Retire Early). See your retirement date and required savings based on expenses, savings rate, and returns."
  canonical="https://firemaths.info/fire-calculator" schema={schema}
>


<main class="max-w-4xl mx-auto px-5 py-12 text-white">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
        <!-- Inputs -->
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
            <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="expenses">Annual Expenses</label>
                <div class="relative flex items-center">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                    <input type="number" id="expenses" value="40000" min="0" step="1000" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                </div>
            </div>

            <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="savingsRate">Savings Rate</label>
                <div class="relative flex items-center">
                    <input type="number" id="savingsRate" value="25" min="0" max="99" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                    <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                </div>
            </div>

            <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="portfolio">Current Portfolio</label>
                <div class="relative flex items-center">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                    <input type="number" id="portfolio" value="100000" min="0" step="1000" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                </div>
            </div>

            <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="returns">Expected Annual Returns (Real)</label>
                <div class="relative flex items-center">
                    <input type="number" id="returns" value="7" min="0" max="30" step="0.1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                    <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                </div>
            </div>
        </div>

        <!-- Results -->
        <div class="card results">
            <div class="result-box highlight">
                <div class="text-[var(--text-secondary)] text-sm font-medium">Your FIRE Number</div>
                <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="res-fire-number">$1,000,000</div>
                <div class="result-sub">Based on the 4% Safe Withdrawal Rate</div>
                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" data-copy="res-fire-number" aria-label="Copy FIRE Number">Copy</button>
            </div>

            <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-5 flex justify-between items-center transition-all hover:-translate-y-0.5 hover:border-[var(--accent-color)]">
                <div class="text-[var(--text-secondary)] text-sm font-medium">Estimated FIRE Date</div>
                <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="res-date">Oct 2045</div>
                <div class="result-sub" id="res-time-left">in 20 years and 4 months</div>
                <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" data-copy="res-date" aria-label="Copy Date">Copy</button>
            </div>

            <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-5 flex justify-between items-center transition-all hover:-translate-y-0.5 hover:border-[var(--accent-color)]">
                <div class="text-[var(--text-secondary)] text-sm font-medium">Annual Savings Generated</div>
                <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="res-savings">$13,333</div>
                <div class="result-sub">Based on your expenses and savings rate</div>
            </div>
        </div>
    </div>

    <!-- SEO Content Section -->
    <article class="content-section">
        <h2>What is a FIRE Number?</h2>
        <p>Your FIRE (Financial Independence, Retire Early) number is the total amount of invested money you need to cover your living expenses indefinitely. Once your portfolio reaches this threshold, the returns generated by your investments should be enough to sustain your lifestyle without needing to actively work.</p>
        <p>Most FIRE calculations are based on the <strong>4% Rule</strong> (originating from the Trinity Study). This rule suggests that you can safely withdraw 4% of your initial portfolio value each year, adjusted for inflation, with a high probability that your money will last for at least 30 years.</p>

        <h2>How to Calculate Your FIRE Number</h2>
        <p>The simplest way to determine your target is to multiply your annual expenses by 25. For example, if you spend $40,000 per year:</p>
        <ul>
            <li>$40,000 × 25 = $1,000,000 FIRE Number</li>
        </ul>
        <p>If you want to be more conservative and use a 3% or 3.5% withdrawal rate, you would multiply your expenses by 33.3 or 28.5, respectively.</p>

        <h2>Tips to Reach Financial Independence Faster</h2>
        <p>Reaching your FIRE number is a function of three main levers: how much you spend, how much you earn (and therefore save), and the return on your investments.</p>
        <ul>
            <li><strong>Increase your savings rate:</strong> Your savings rate is the most powerful predictor of when you will reach financial independence. A higher rate means you are both saving more and learning to live on less.</li>
            <li><strong>Optimize your expenses:</strong> Focus on the "Big Three" — housing, transportation, and food. Cutting costs in these areas yields the highest impact on your bottom line.</li>
            <li><strong>Invest consistently:</strong> Time in the market beats timing the market. Automate your investments into low-cost, broad-market index funds to capture long-term growth.</li>
        </ul>
    </article>
</main>
  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
        const inputs = {
            expenses: document.getElementById('expenses'),
            savingsRate: document.getElementById('savingsRate'),
            portfolio: document.getElementById('portfolio'),
            returns: document.getElementById('returns')
        };

        const outputs = {
            fireNumber: document.getElementById('res-fire-number'),
            date: document.getElementById('res-date'),
            timeLeft: document.getElementById('res-time-left'),
            savings: document.getElementById('res-savings')
        };

        const copyButtons = document.querySelectorAll('.copy-btn');

        const formatCurrency = (value) => {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(value);
        };

        const calculateFIRE = () => {
            const expenses = parseFloat(inputs.expenses.value) || 0;
            const savingsRate = parseFloat(inputs.savingsRate.value) || 0;
            const portfolio = parseFloat(inputs.portfolio.value) || 0;
            const returns = parseFloat(inputs.returns.value) || 0;

            // Calculations
            const fireNumber = expenses * 25; // 4% rule

            // If savings rate is X%, it means Savings = Income * X%, Expenses = Income * (1 - X%)
            // So Income = Expenses / (1 - X%)
            // Savings = Income - Expenses = Expenses / (1 - X%) * X% = Expenses * X% / (1 - X%)
            let annualSavings = 0;
            if (savingsRate >= 100) {
                annualSavings = 0; // Invalid, but let's avoid infinity
            } else if (savingsRate > 0) {
                const sr = savingsRate / 100;
                annualSavings = expenses * (sr / (1 - sr));
            }

            const monthlySavings = annualSavings / 12;
            const monthlyReturn = (returns / 100) / 12;

            let current = portfolio;
            let months = 0;
            const maxMonths = 1200; // 100 years max to prevent infinite loops

            if (current < fireNumber) {
                if (monthlySavings > 0 || monthlyReturn > 0) {
                    while (current < fireNumber && months < maxMonths) {
                        current += current * monthlyReturn + monthlySavings;
                        months++;
                    }
                } else {
                    months = maxMonths; // Never reach
                }
            }

            // Update UI
            outputs.fireNumber.textContent = formatCurrency(fireNumber);
            outputs.savings.textContent = formatCurrency(annualSavings);

            if (current >= fireNumber && months === 0) {
                outputs.date.textContent = "FI Reached!";
                outputs.timeLeft.textContent = "Congratulations!";
            } else if (months >= maxMonths) {
                outputs.date.textContent = "Never";
                outputs.timeLeft.textContent = "Increase savings or returns";
            } else {
                const targetDate = new Date();
                targetDate.setMonth(targetDate.getMonth() + months);

                const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
                outputs.date.textContent = `${monthNames[targetDate.getMonth()]} ${targetDate.getFullYear()}`;

                const years = Math.floor(months / 12);
                const remainingMonths = months % 12;

                let timeStr = "in ";
                if (years > 0) timeStr += `${years} year${years > 1 ? 's' : ''}`;
                if (years > 0 && remainingMonths > 0) timeStr += " and ";
                if (remainingMonths > 0) timeStr += `${remainingMonths} month${remainingMonths > 1 ? 's' : ''}`;
                if (years === 0 && remainingMonths === 0) timeStr = "This month!";

                outputs.timeLeft.textContent = timeStr;
            }
        };

        // Attach event listeners
        Object.values(inputs).forEach(input => {
            input.addEventListener('input', calculateFIRE);
        });

        // Copy functionality
        copyButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const targetId = e.target.getAttribute('data-copy');
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    navigator.clipboard.writeText(targetElement.textContent).then(() => {
                        const originalText = e.target.textContent;
                        e.target.textContent = 'Copied!';
                        e.target.classList.add('copied');
                        setTimeout(() => {
                            e.target.textContent = originalText;
                            e.target.classList.remove('copied');
                        }, 2000);
                    }).catch(err => {
                        console.error('Failed to copy text: ', err);
                    });
                }
            });
        });

        // Initial calculation
        calculateFIRE();
    });
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-fire-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">The Complete Guide to Financial Independence (FIRE)</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
