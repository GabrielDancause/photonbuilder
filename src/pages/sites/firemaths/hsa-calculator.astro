---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "HSA Calculator",
  "url": "https://firemaths.info/hsa-calculator",
  "description": "Health Savings Account calculator — project your HSA balance at retirement, see triple tax advantage savings, and compare HSA investing vs paying out of pocket.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the triple tax advantage of an HSA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An HSA offers three distinct tax benefits: (1) Contributions are tax-deductible or made pre-tax through payroll, reducing your taxable income. (2) Investments grow tax-free — no capital gains or dividend taxes. (3) Withdrawals for qualified medical expenses are completely tax-free. No other account in the U.S. tax code offers all three benefits. After age 65, you can withdraw for any purpose penalty-free (though non-medical withdrawals are taxed as income, similar to a traditional IRA)."
      }
    },
    {
      "@type": "Question",
      "name": "What are the 2026 HSA contribution limits?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2026, the HSA contribution limits are $4,300 for individual (self-only) coverage and $8,550 for family coverage. If you are 55 or older, you can contribute an additional $1,000 catch-up contribution on top of the standard limit. These limits include both your personal contributions and any employer contributions. Excess contributions are subject to a 6% excise tax."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use my HSA as a retirement account?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, an HSA is one of the best retirement savings vehicles available. You can invest your HSA funds in stocks, bonds, and mutual funds for long-term growth. After age 65, you can withdraw funds for any purpose without penalty — non-medical withdrawals are simply taxed as ordinary income (like a traditional IRA). For medical expenses, withdrawals remain tax-free at any age. Many financial planners recommend maxing out your HSA before contributing to a traditional IRA due to the superior tax treatment."
      }
    },
    {
      "@type": "Question",
      "name": "Who is eligible for a Health Savings Account?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To be eligible for an HSA, you must be enrolled in a High Deductible Health Plan (HDHP). For 2026, an HDHP must have a minimum deductible of $1,650 for self-only coverage or $3,300 for family coverage, and maximum out-of-pocket costs of $8,300 (self-only) or $16,600 (family). You cannot be enrolled in Medicare, claimed as a dependent on someone else's tax return, or have other non-HDHP health coverage."
      }
    },
    {
      "@type": "Question",
      "name": "Should I invest my HSA or keep it in cash?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you can afford to pay current medical expenses out of pocket and let your HSA grow, investing is generally the better strategy. HSA investments grow tax-free, making them extremely powerful over long time horizons. A common approach is to keep 1-2 years of expected medical expenses in cash within your HSA for near-term needs, and invest the rest in a diversified portfolio of index funds. Over 20-30 years, invested HSA funds can grow significantly compared to cash, potentially adding hundreds of thousands of dollars to your retirement savings."
      }
    }
  ]
};

export const meta = {
  title: "HSA Calculator | firemaths.info",
  description: "Free HSA calculator — project your Health Savings Account balance at retirement. See triple tax savings and compare investing vs paying out of pocket.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="HSA Calculator | firemaths.info"
  description="Free HSA calculator — project your Health Savings Account balance at retirement, see triple tax advantage savings, compare HSA investing vs paying out of pocket."
  canonical="https://firemaths.info/hsa-calculator" schema={schema}
>
  <style>
:root {
    --chart-color-a: #D4A017;
    --chart-color-b: #4A90E2;
    --chart-color-c: #50E3C2;
    --chart-color-d: #E85D75;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.chart-header {
    margin-bottom: 1.5rem;
    text-align: center;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
}

.indicator-a { background-color: var(--chart-color-a); }
.indicator-b { background-color: var(--chart-color-b); }
.indicator-c { background-color: var(--chart-color-c); }
.indicator-d { background-color: var(--chart-color-d); }

.chart-container {
    width: 100%;
    height: 400px;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

.tax-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .tax-cards {
        grid-template-columns: 1fr;
    }
}

.tax-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
}

.tax-card h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
}

.tax-card .subtitle {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
}

.tax-card .amount {
    font-family: var(--font-mono);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.tax-card .detail {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.tax-deduction { border-top: 3px solid #50E3C2; }
.tax-growth { border-top: 3px solid #4A90E2; }
.tax-withdrawal { border-top: 3px solid #D4A017; }

.tax-deduction .amount { color: #50E3C2; }
.tax-growth .amount { color: #4A90E2; }
.tax-withdrawal .amount { color: #D4A017; }

.comparison-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.comparison-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

@media (max-width: 640px) {
    .comparison-grid {
        grid-template-columns: 1fr;
    }
}

.comparison-result {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.comparison-result .result-value {
    font-size: 1rem;
}

.status-surplus { color: #50E3C2; }
.status-gap { color: #E85D75; }

.limits-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.limits-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.limits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem 2rem;
}

@media (max-width: 640px) {
    .limits-grid {
        grid-template-columns: 1fr;
    }
}

.limits-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--border-color);
}

.limits-item .label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.limits-item .value {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--text-primary);
}

.projection-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin-top: 1rem;
}

.projection-table th {
    text-align: left;
    padding: 0.75rem 0.5rem;
    border-bottom: 2px solid var(--border-color);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    white-space: nowrap;
}

.projection-table td {
    padding: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    font-family: var(--font-mono);
    font-size: 0.8rem;
}

.projection-table tr:hover {
    background-color: var(--bg-color);
}

.projection-table .text-right {
    text-align: right;
}

.table-wrapper {
    overflow-x: auto;
    margin-bottom: 3rem;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.table-wrapper h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .tips-grid {
        grid-template-columns: 1fr;
    }
}

.tip-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.tip-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.tip-card ul {
    list-style: none;
    padding: 0;
}

.tip-card li {
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
}

.tip-card li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--accent-color);
    font-weight: bold;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "−";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>HSA Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Project your Health Savings Account balance and see your triple tax advantage savings</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your HSA Details</h2>
                </div>

                <div class="inputs">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="input-group">
                            <label for="current-age">Current Age</label>
                            <div class="input-wrapper">
                                <input type="number" id="current-age" value="30" min="18" max="80" step="1">
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="retire-age">Retirement Age</label>
                            <div class="input-wrapper">
                                <input type="number" id="retire-age" value="65" min="30" max="90" step="1">
                            </div>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="current-balance">Current HSA Balance</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="current-balance" value="5000" min="0" step="500">
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="input-group">
                            <label for="annual-contribution">Your Annual Contribution</label>
                            <div class="input-wrapper has-prefix">
                                <span class="prefix">$</span>
                                <input type="number" id="annual-contribution" value="3500" min="0" step="100">
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="employer-contribution">Employer Contribution</label>
                            <div class="input-wrapper has-prefix">
                                <span class="prefix">$</span>
                                <input type="number" id="employer-contribution" value="500" min="0" step="100">
                            </div>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="annual-return">Expected Annual Return</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="annual-return" value="7" min="0" max="15" step="0.5">
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="input-group">
                            <label for="current-medical">Annual Medical Expenses Now</label>
                            <div class="input-wrapper has-prefix">
                                <span class="prefix">$</span>
                                <input type="number" id="current-medical" value="2000" min="0" step="250">
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="retirement-medical">Annual Medical in Retirement</label>
                            <div class="input-wrapper has-prefix">
                                <span class="prefix">$</span>
                                <input type="number" id="retirement-medical" value="8000" min="0" step="500">
                            </div>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="tax-rate">Marginal Tax Rate (Federal + State)</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="tax-rate" value="30" min="0" max="55" step="1">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>HSA Projections</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Projected HSA Balance at Retirement</span>
                        <div class="result-value">
                            <span id="projected-balance">$0</span>
                            <button class="copy-btn" onclick="copyValue('projected-balance', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Total Contributions</span>
                        <span class="result-value" id="total-contributions" style="font-size: 1rem;">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Investment Growth</span>
                        <span class="result-value" id="total-growth" style="font-size: 1rem; color: var(--chart-color-a);">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Total Tax Savings (Lifetime)</span>
                        <span class="result-value" id="total-tax-savings" style="font-size: 1rem; color: var(--chart-color-c);">$0</span>
                    </div>

                    <div style="flex-grow: 1;"></div>

                    <div class="result-item" style="padding-top: 1rem; border-top: 1px dashed var(--border-color);">
                        <span class="result-label">Years of Retirement Medical Covered</span>
                        <span class="result-value" id="years-medical" style="font-size: 1rem; color: var(--chart-color-b);">0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">HSA Advantage vs Out-of-Pocket</span>
                        <span class="result-value status-surplus" id="hsa-advantage" style="font-size: 1rem;">$0</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart -->
        <div class="chart-section">
            <div class="chart-header">
                <h2>HSA Balance Growth Projection</h2>
