  <script is:inline>
const formatCurrency = (value) => {
    return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
    }).format(value);
};

window.copyValue = async (elementId, btn) => {
    const text = document.getElementById(elementId).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => { btn.innerText = orig; }, 2000);
    } catch (err) {
        console.error('Failed to copy: ', err);
    }
};

window.toggleFaq = (btn) => {
    const item = btn.parentElement;
    item.classList.toggle('open');
};

function getInputs() {
    return {
        currentAge: parseInt(document.getElementById('current-age').value) || 30,
        retireAge: parseInt(document.getElementById('retire-age').value) || 65,
        currentBalance: parseFloat(document.getElementById('current-balance').value) || 0,
        annualContribution: parseFloat(document.getElementById('annual-contribution').value) || 0,
        employerContribution: parseFloat(document.getElementById('employer-contribution').value) || 0,
        annualReturn: parseFloat(document.getElementById('annual-return').value) || 7,
        currentMedical: parseFloat(document.getElementById('current-medical').value) || 0,
        retirementMedical: parseFloat(document.getElementById('retirement-medical').value) || 0,
        taxRate: parseFloat(document.getElementById('tax-rate').value) || 30,
    };
}

function projectHSA(inputs) {
    const years = Math.max(0, inputs.retireAge - inputs.currentAge);
    const monthlyReturn = (inputs.annualReturn / 100) / 12;
    const totalAnnualContrib = inputs.annualContribution + inputs.employerContribution;

    let balance = inputs.currentBalance;
    let totalContributed = inputs.currentBalance;
    let totalGrowth = 0;
    let cumulativeTaxSaved = 0;
    const history = [];

    history.push({
        age: inputs.currentAge,
        contribution: 0,
        growth: 0,
        balance: balance,
        taxSaved: 0,
        cumulativeTaxSaved: 0,
        totalContributed: inputs.currentBalance,
    });

    for (let y = 1; y <= years; y++) {
        const age = inputs.currentAge + y;
        // Catch-up contribution if 55+
        const catchUp = (age - 1 >= 55) ? 1000 : 0;
        const yearContrib = totalAnnualContrib + catchUp;
        const monthlyContrib = yearContrib / 12;

        const startBalance = balance;
        for (let m = 0; m < 12; m++) {
            balance = balance * (1 + monthlyReturn) + monthlyContrib;
        }

        const yearGrowth = balance - startBalance - yearContrib;
        totalContributed += yearContrib;
        totalGrowth += yearGrowth;

        // Tax savings: deduction on contributions (employee portion + catch-up only, not employer)
        const employeeContrib = inputs.annualContribution + catchUp;
        const yearTaxSaved = employeeContrib * (inputs.taxRate / 100);
        cumulativeTaxSaved += yearTaxSaved;

        history.push({
            age: age,
            contribution: yearContrib,
            growth: yearGrowth,
            balance: balance,
            taxSaved: yearTaxSaved,
            cumulativeTaxSaved: cumulativeTaxSaved,
            totalContributed: totalContributed,
        });
    }

    return { balance, totalContributed, totalGrowth, cumulativeTaxSaved, history, years };
}

function updateAll() {
    const inputs = getInputs();
    const proj = projectHSA(inputs);
    const taxRate = inputs.taxRate / 100;

    // Main results
    document.getElementById('projected-balance').innerText = formatCurrency(proj.balance);
    document.getElementById('total-contributions').innerText = formatCurrency(proj.totalContributed);
    document.getElementById('total-growth').innerText = formatCurrency(proj.totalGrowth);

    // Tax savings breakdown
    // 1. Contribution deduction savings
    const deductionSavings = proj.cumulativeTaxSaved;

    // 2. Tax-free growth savings (what capital gains tax would have been)
    const capitalGainsTaxRate = 0.15; // assume 15% LTCG
    const growthTaxSavings = proj.totalGrowth * capitalGainsTaxRate;

    // 3. Tax-free withdrawal savings on medical expenses in retirement
    const yearsInRetirement = Math.max(0, 90 - inputs.retireAge);
    const totalRetirementMedical = inputs.retirementMedical * yearsInRetirement;
    const withdrawalTaxSavings = Math.min(proj.balance, totalRetirementMedical) * taxRate;

    const totalTaxSavings = deductionSavings + growthTaxSavings + withdrawalTaxSavings;
    document.getElementById('total-tax-savings').innerText = formatCurrency(totalTaxSavings);

    // Triple tax cards
    document.getElementById('tax-deduction-amount').innerText = formatCurrency(deductionSavings);
    document.getElementById('tax-deduction-detail').innerText = formatCurrency(inputs.annualContribution) + '/yr deducted at ' + inputs.taxRate + '% rate';

    document.getElementById('tax-growth-amount').innerText = formatCurrency(growthTaxSavings);
    document.getElementById('tax-growth-detail').innerText = formatCurrency(proj.totalGrowth) + ' growth, 15% LTCG avoided';

    document.getElementById('tax-withdrawal-amount').innerText = formatCurrency(withdrawalTaxSavings);
    document.getElementById('tax-withdrawal-detail').innerText = 'On ' + formatCurrency(Math.min(proj.balance, totalRetirementMedical)) + ' medical withdrawals';

    // Years of medical covered
    if (inputs.retirementMedical > 0) {
        // Account for continued growth during retirement
        let retireBalance = proj.balance;
        const monthlyReturnRetire = (inputs.annualReturn / 100) / 12;
        const monthlyMedical = inputs.retirementMedical / 12;
        let months = 0;
        const maxMonths = 50 * 12;
        while (retireBalance > 0 && months < maxMonths) {
            retireBalance = retireBalance * (1 + monthlyReturnRetire) - monthlyMedical;
            months++;
        }
        const yearsCovered = months / 12;
        document.getElementById('years-medical').innerText = yearsCovered >= 49 ? '49+ years' : yearsCovered.toFixed(1) + ' years';
    } else {
        document.getElementById('years-medical').innerText = 'N/A';
    }

    // HSA vs Out-of-Pocket comparison
    // HSA strategy: contribute max, invest, pay medical OOP, reimburse later
    const hsaValue = proj.balance + totalTaxSavings;

    // Out-of-pocket: pay medical with after-tax dollars, no HSA
    const totalPreRetirementMedical = inputs.currentMedical * proj.years;
    // Out of pocket needs pre-tax earnings to cover medical
    const oopCost = totalPreRetirementMedical / (1 - taxRate);
    // If they'd invested the contributions instead in a taxable account
    const afterTaxContribRate = (1 - taxRate);
    const taxableReturn = inputs.annualReturn / 100 * (1 - capitalGainsTaxRate);
    const monthlyTaxableReturn = taxableReturn / 12;
    let taxableBalance = 0;
    const totalAnnualContrib = inputs.annualContribution + inputs.employerContribution;
    for (let y = 0; y < proj.years; y++) {
        const yearContrib = totalAnnualContrib * afterTaxContribRate;
        const monthlyContrib = yearContrib / 12;
        for (let m = 0; m < 12; m++) {
            taxableBalance = taxableBalance * (1 + monthlyTaxableReturn) + monthlyContrib;
        }
    }

    document.getElementById('cmp-hsa-strategy').innerText = formatCurrency(proj.balance);
    document.getElementById('cmp-out-of-pocket').innerText = formatCurrency(taxableBalance);
    document.getElementById('cmp-total-medical').innerText = formatCurrency(totalPreRetirementMedical);

    const advantage = proj.balance - taxableBalance;
    const advEl = document.getElementById('cmp-advantage');
    advEl.innerText = (advantage >= 0 ? '+' : '-') + formatCurrency(Math.abs(advantage));
    advEl.className = 'result-value ' + (advantage >= 0 ? 'status-surplus' : 'status-gap');

    document.getElementById('hsa-advantage').innerText = '+' + formatCurrency(Math.max(0, advantage));

    // Projection table
    const tbody = document.getElementById('projection-tbody');
    tbody.innerHTML = '';
    for (let i = 1; i < proj.history.length; i++) {
        const row = proj.history[i];
        const tr = document.createElement('tr');
        tr.innerHTML =
            '<td>' + row.age + '</td>' +
            '<td class="text-right">' + formatCurrency(row.contribution) + '</td>' +
            '<td class="text-right">' + formatCurrency(row.growth) + '</td>' +
            '<td class="text-right">' + formatCurrency(row.balance) + '</td>' +
            '<td class="text-right">' + formatCurrency(row.taxSaved) + '</td>' +
            '<td class="text-right">' + formatCurrency(row.cumulativeTaxSaved) + '</td>';
        tbody.appendChild(tr);
    }

    // Draw chart
    drawChart(proj);
}

// Chart
let chartCanvas = document.getElementById('hsaChart');
let ctx = chartCanvas.getContext('2d');

function drawChart(proj) {
    const history = proj.history;
    if (history.length <= 1) {
        ctx.clearRect(0, 0, chartCanvas.width, chartCanvas.height);
        return;
    }

    const maxBalance = Math.max(...history.map(p => p.balance));
    const minAge = history[0].age;
    const maxAge = history[history.length - 1].age;

    const dpr = window.devicePixelRatio || 1;
    const rect = chartCanvas.parentElement.getBoundingClientRect();
    chartCanvas.width = rect.width * dpr;
    chartCanvas.height = rect.height * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);

    const width = rect.width;
    const height = rect.height;
    ctx.clearRect(0, 0, width, height);

    const padding = { top: 20, right: 20, bottom: 40, left: 80 };
    const cw = width - padding.left - padding.right;
    const ch = height - padding.top - padding.bottom;

    const ageSpan = maxAge - minAge || 1;
    const xOf = (age) => padding.left + cw * ((age - minAge) / ageSpan);
    const yOf = (val) => height - padding.bottom - ch * (val / (maxBalance || 1));

    // Grid
    ctx.strokeStyle = '#2a2010';
    ctx.lineWidth = 1;
    ctx.font = '12px Inter, sans-serif';
    ctx.fillStyle = '#888888';

    // Y-axis
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    const yTicks = 5;
    for (let i = 0; i <= yTicks; i++) {
        const val = maxBalance * (i / yTicks);
        const y = yOf(val);
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(width - padding.right, y);
        ctx.stroke();
        const label = val >= 1e6 ? '$' + (val / 1e6).toFixed(1) + 'M' :
                      val >= 1e3 ? '$' + (val / 1e3).toFixed(0) + 'k' : '$' + val.toFixed(0);
        ctx.fillText(label, padding.left - 10, y);
    }

    // X-axis
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    const xTicks = Math.min(ageSpan, 10);
    for (let i = 0; i <= xTicks; i++) {
        const age = Math.round(minAge + ageSpan * (i / xTicks));
        const x = xOf(age);
        ctx.beginPath();
        ctx.moveTo(x, height - padding.bottom);
        ctx.lineTo(x, height - padding.bottom + 5);
        ctx.stroke();
        ctx.fillText('Age ' + age, x, height - padding.bottom + 10);
    }

    // Stacked area: contributions on bottom, growth on top
    // Contribution area
    ctx.beginPath();
    ctx.moveTo(xOf(history[0].age), yOf(0));
    for (let i = 0; i < history.length; i++) {
        ctx.lineTo(xOf(history[i].age), yOf(history[i].totalContributed));
    }
    ctx.lineTo(xOf(history[history.length - 1].age), yOf(0));
    ctx.closePath();
    ctx.fillStyle = 'rgba(74, 144, 226, 0.3)';
    ctx.fill();

    // Total balance area (growth portion is between totalContributed and balance)
    ctx.beginPath();
    for (let i = 0; i < history.length; i++) {
        ctx.lineTo(xOf(history[i].age), yOf(history[i].balance));
    }
    for (let i = history.length - 1; i >= 0; i--) {
        ctx.lineTo(xOf(history[i].age), yOf(history[i].totalContributed));
    }
    ctx.closePath();
    ctx.fillStyle = 'rgba(212, 160, 23, 0.3)';
    ctx.fill();

    // Balance line
    ctx.beginPath();
    ctx.strokeStyle = '#D4A017';
    ctx.lineWidth = 2.5;
    for (let i = 0; i < history.length; i++) {
        const x = xOf(history[i].age);
        const y = yOf(history[i].balance);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Contributions line
    ctx.beginPath();
    ctx.strokeStyle = '#4A90E2';
    ctx.lineWidth = 2;
    ctx.setLineDash([5, 3]);
    for (let i = 0; i < history.length; i++) {
        const x = xOf(history[i].age);
        const y = yOf(history[i].totalContributed);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    }
    ctx.stroke();
    ctx.setLineDash([]);
}

// Event listeners
document.querySelectorAll('input[type="number"]').forEach(input => {
    input.addEventListener('input', updateAll);
});

// Initial calculation
updateAll();
window.addEventListener('resize', updateAll);
  </script>
</SiteLayout>
