  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

window.copyValue = async (id, btn) => {
    const text = document.getElementById(id).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => btn.innerText = orig, 2000);
    } catch(e) {}
};

let amortView = 'monthly';
let amortData = [];
let currentResult = null;

function getInputs() {
    const homePrice = parseFloat(document.getElementById('home-price').value) || 0;
    const downPayment = parseFloat(document.getElementById('down-payment').value) || 0;
    const interestRate = parseFloat(document.getElementById('interest-rate').value) || 0;
    const loanTerm = parseInt(document.getElementById('loan-term').value) || 30;
    const propertyTaxRate = parseFloat(document.getElementById('property-tax').value) || 0;
    const homeInsurance = parseFloat(document.getElementById('home-insurance').value) || 0;
    const pmiRate = parseFloat(document.getElementById('pmi-rate').value) || 0;
    const hoaFee = parseFloat(document.getElementById('hoa-fee').value) || 0;
    const extraMonthly = parseFloat(document.getElementById('extra-monthly').value) || 0;
    const extraYearly = parseFloat(document.getElementById('extra-yearly').value) || 0;

    const loanAmount = Math.max(0, homePrice - downPayment);
    const downPercent = homePrice > 0 ? (downPayment / homePrice) * 100 : 0;

    return { homePrice, downPayment, interestRate, loanTerm, propertyTaxRate, homeInsurance, pmiRate, hoaFee, extraMonthly, extraYearly, loanAmount, downPercent };
}

function calcPI(loanAmount, annualRate, termYears) {
    if (loanAmount <= 0) return 0;
    if (annualRate <= 0) return loanAmount / (termYears * 12);
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    return loanAmount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function buildAmortization(loanAmount, annualRate, termYears, extraMonthly, extraYearly) {
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    const basePI = calcPI(loanAmount, annualRate, termYears);
    let balance = loanAmount;
    const schedule = [];
    let totalInterest = 0;
    let totalPrincipal = 0;

    for (let month = 1; month <= n && balance > 0.01; month++) {
        const interestPayment = balance * r;
        let principalPayment = basePI - interestPayment;
        let extra = extraMonthly;
        if (month % 12 === 0) extra += extraYearly;

        principalPayment += extra;
        if (principalPayment > balance) principalPayment = balance;

        balance -= principalPayment;
        if (balance < 0) balance = 0;

        totalInterest += interestPayment;
        totalPrincipal += principalPayment;

        schedule.push({
            month,
            payment: interestPayment + principalPayment,
            principal: principalPayment,
            interest: interestPayment,
            balance,
            totalInterest,
            totalPrincipal
        });

        if (balance <= 0) break;
    }

    return schedule;
}

function calculate() {
    const inp = getInputs();
    const { homePrice, loanAmount, interestRate, loanTerm, propertyTaxRate, homeInsurance, pmiRate, hoaFee, extraMonthly, extraYearly, downPercent } = inp;

    const pi = calcPI(loanAmount, interestRate, loanTerm);
    const monthlyTax = (homePrice * propertyTaxRate / 100) / 12;
    const monthlyIns = homeInsurance / 12;
    const needsPMI = downPercent < 20 && loanAmount > 0;
    const monthlyPMI = needsPMI ? (loanAmount * pmiRate / 100) / 12 : 0;
    const total = pi + monthlyTax + monthlyIns + monthlyPMI + hoaFee;

    // Base amortization (no extra)
    const baseSchedule = buildAmortization(loanAmount, interestRate, loanTerm, 0, 0);
    const baseTotalInterest = baseSchedule.length > 0 ? baseSchedule[baseSchedule.length - 1].totalInterest : 0;

    // With extra payments
    const extraSchedule = buildAmortization(loanAmount, interestRate, loanTerm, extraMonthly, extraYearly);
    const extraTotalInterest = extraSchedule.length > 0 ? extraSchedule[extraSchedule.length - 1].totalInterest : 0;

    const totalCost = loanAmount + baseTotalInterest;

    // Payoff date
    const now = new Date();
    const basePayoffDate = new Date(now.getFullYear(), now.getMonth() + baseSchedule.length, 1);
    const extraPayoffDate = new Date(now.getFullYear(), now.getMonth() + extraSchedule.length, 1);

    const formatDate = (d) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

    // Update results
    document.getElementById('total-monthly').innerText = fmt(total);
    document.getElementById('res-pi').innerText = fmt(pi);
    document.getElementById('res-tax').innerText = fmt(monthlyTax);
    document.getElementById('res-ins').innerText = fmt(monthlyIns);
    document.getElementById('res-pmi').innerText = needsPMI ? fmt(monthlyPMI) : '$0';
    document.getElementById('res-hoa').innerText = hoaFee > 0 ? fmt(hoaFee) : '$0';
    document.getElementById('res-loan-amt').innerText = fmt(loanAmount);
    document.getElementById('res-total-interest').innerText = fmt(baseTotalInterest);
    document.getElementById('res-total-cost').innerText = fmt(totalCost);
    document.getElementById('res-payoff').innerText = formatDate(basePayoffDate);

    // Extra payment results
    const monthsSaved = baseSchedule.length - extraSchedule.length;
    const yearsSaved = Math.floor(monthsSaved / 12);
    const remMonths = monthsSaved % 12;
    const timeSavedStr = monthsSaved > 0 ? (yearsSaved > 0 ? yearsSaved + 'yr ' + remMonths + 'mo' : remMonths + ' months') : 'None';
    const interestSaved = baseTotalInterest - extraTotalInterest;

    document.getElementById('extra-payoff').innerText = formatDate(extraPayoffDate);
    document.getElementById('extra-time-saved').innerText = timeSavedStr;
    document.getElementById('extra-interest-saved').innerText = interestSaved > 0 ? fmt(interestSaved) : '$0';
    document.getElementById('extra-new-interest').innerText = fmt(extraTotalInterest);

    amortData = extraSchedule;
    currentResult = { pi, monthlyTax, monthlyIns, monthlyPMI, hoaFee, total, needsPMI };

    renderAmortTable();
    drawPie(currentResult);
    renderComparison(inp);
}

function renderAmortTable() {
    const thead = document.getElementById('amort-thead');
    const tbody = document.getElementById('amort-tbody');

    if (amortView === 'monthly') {
        thead.innerHTML = '<tr><th>#</th><th>Payment</th><th>Principal</th><th>Interest</th><th>Balance</th></tr>';
        let html = '';
        for (const row of amortData) {
            html += `<tr><td>${row.month}</td><td>${fmt2(row.payment)}</td><td>${fmt2(row.principal)}</td><td>${fmt2(row.interest)}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    } else {
        thead.innerHTML = '<tr><th>Year</th><th>Total Paid</th><th>Principal</th><th>Interest</th><th>End Balance</th></tr>';
        const yearly = [];
        let yearPayment = 0, yearPrincipal = 0, yearInterest = 0, yearEnd = 0;
        for (const row of amortData) {
            yearPayment += row.payment;
            yearPrincipal += row.principal;
            yearInterest += row.interest;
            yearEnd = row.balance;
            if (row.month % 12 === 0 || row === amortData[amortData.length - 1]) {
                yearly.push({ year: Math.ceil(row.month / 12), payment: yearPayment, principal: yearPrincipal, interest: yearInterest, balance: yearEnd });
                yearPayment = 0; yearPrincipal = 0; yearInterest = 0;
            }
        }
        let html = '';
        for (const row of yearly) {
            html += `<tr><td>${row.year}</td><td>${fmt(row.payment)}</td><td>${fmt(row.principal)}</td><td>${fmt(row.interest)}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    }
}

window.setAmortView = (view) => {
    amortView = view;
    document.getElementById('btn-monthly').classList.toggle('active', view === 'monthly');
    document.getElementById('btn-yearly').classList.toggle('active', view === 'yearly');
    renderAmortTable();
};

function drawPie(res) {
    const canvas = document.getElementById('pieChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const size = container.getBoundingClientRect().width;

    canvas.width = size * dpr;
    canvas.height = size * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, size, size);

    const slices = [
        { value: res.pi, color: 'var(--color-pi)', hex: '#4A90E2', label: 'Principal & Interest' },
        { value: res.monthlyTax, color: 'var(--color-tax)', hex: '#D4A017', label: 'Property Tax' },
        { value: res.monthlyIns, color: 'var(--color-ins)', hex: '#50E3C2', label: 'Home Insurance' },
    ];
    if (res.needsPMI && res.monthlyPMI > 0) slices.push({ value: res.monthlyPMI, hex: '#9B59B6', label: 'PMI' });
    if (res.hoaFee > 0) slices.push({ value: res.hoaFee, hex: '#E25C5C', label: 'HOA' });

    const total = slices.reduce((s, sl) => s + sl.value, 0);
    if (total <= 0) return;

    const cx = size / 2;
    const cy = size / 2;
    const outerR = (size / 2) - 10;
    const innerR = outerR * 0.55;

    let startAngle = -Math.PI / 2;
    for (const slice of slices) {
        const sliceAngle = (slice.value / total) * Math.PI * 2;
        ctx.beginPath();
        ctx.arc(cx, cy, outerR, startAngle, startAngle + sliceAngle);
        ctx.arc(cx, cy, innerR, startAngle + sliceAngle, startAngle, true);
        ctx.closePath();
        ctx.fillStyle = slice.hex;
        ctx.fill();
        startAngle += sliceAngle;
    }

    // Center text
    ctx.fillStyle = '#e0d8c8';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = `bold ${size * 0.09}px Inter, sans-serif`;
    ctx.fillText(fmt(total), cx, cy - 8);
    ctx.font = `${size * 0.045}px Inter, sans-serif`;
    ctx.fillStyle = '#888888';
    ctx.fillText('/month', cx, cy + size * 0.055);

    // Legend
    const legendEl = document.getElementById('pieLegend');
    legendEl.innerHTML = slices.map(s =>
        `<div class="pie-legend-item">
            <span class="pie-legend-color" style="background:${s.hex}"></span>
            <span class="pie-legend-label">${s.label}</span>
            <span class="pie-legend-value">${fmt(s.value)} <span style="color:var(--text-secondary);font-size:0.75rem;font-weight:400;">(${(s.value/total*100).toFixed(1)}%)</span></span>
        </div>`
    ).join('');
}

function renderComparison(inp) {
    const terms = [15, 20, 30];
    const selectedTerm = inp.loanTerm;
    const rows = [
        { label: 'Monthly P&I', key: 'pi' },
        { label: 'Total P&I Payments', key: 'totalPI' },
        { label: 'Total Interest', key: 'totalInterest' },
        { label: 'Interest Savings vs 30yr', key: 'savings' },
    ];

    const data = {};
    for (const t of terms) {
        const pi = calcPI(inp.loanAmount, inp.interestRate, t);
        const totalPI = pi * t * 12;
        const totalInterest = totalPI - inp.loanAmount;
        data[t] = { pi, totalPI, totalInterest };
    }

    const savings30 = data[30].totalInterest;
    for (const t of terms) {
        data[t].savings = savings30 - data[t].totalInterest;
    }

    const tbody = document.getElementById('comparison-tbody');
    let html = '';
    for (const row of rows) {
        html += '<tr>';
        html += `<td>${row.label}</td>`;
        for (const t of terms) {
            const val = data[t][row.key];
            const highlight = t === selectedTerm ? ' class="highlight-row"' : '';
            if (row.key === 'savings' && t === 30) {
                html += `<td${highlight}>—</td>`;
            } else {
                html += `<td${highlight}>${fmt(val)}</td>`;
            }
        }
        html += '</tr>';
    }
    tbody.innerHTML = html;
}

// Sync down payment $ <-> %
let syncLock = false;
document.getElementById('down-payment').addEventListener('input', () => {
    if (syncLock) return;
    syncLock = true;
    const hp = parseFloat(document.getElementById('home-price').value) || 0;
    const dp = parseFloat(document.getElementById('down-payment').value) || 0;
    if (hp > 0) document.getElementById('down-percent').value = ((dp / hp) * 100).toFixed(1);
    syncLock = false;
    calculate();
});

document.getElementById('down-percent').addEventListener('input', () => {
    if (syncLock) return;
    syncLock = true;
    const hp = parseFloat(document.getElementById('home-price').value) || 0;
    const pct = parseFloat(document.getElementById('down-percent').value) || 0;
    document.getElementById('down-payment').value = Math.round(hp * pct / 100);
    syncLock = false;
    calculate();
});

document.getElementById('home-price').addEventListener('input', () => {
    const hp = parseFloat(document.getElementById('home-price').value) || 0;
    const pct = parseFloat(document.getElementById('down-percent').value) || 0;
    document.getElementById('down-payment').value = Math.round(hp * pct / 100);
    calculate();
});

// Attach listeners to remaining inputs
const calcInputs = ['interest-rate', 'loan-term', 'property-tax', 'home-insurance', 'pmi-rate', 'hoa-fee', 'extra-monthly', 'extra-yearly'];
calcInputs.forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
});

window.addEventListener('resize', () => {
    if (currentResult) drawPie(currentResult);
});

setTimeout(calculate, 0);
  </script>

