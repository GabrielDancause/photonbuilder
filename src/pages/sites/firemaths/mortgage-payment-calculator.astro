}

.related-link:hover {
    border-color: var(--accent-color);
}

.related-link span {
    display: block;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

.payoff-date {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    font-family: var(--font-ui);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Mortgage Payment Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:3rem;">Calculate your monthly mortgage payment, view a full amortization schedule, and see how extra payments save you money.</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Loan Details</h2>
                </div>

                <div class="input-group">
                    <label for="home-price">Home Price</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="home-price" value="350000" min="0" step="5000">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="down-payment">Down Payment</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="down-payment" value="70000" min="0" step="1000">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="down-percent">Down Payment %</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="down-percent" value="20" min="0" max="100" step="0.5">
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="interest-rate">Interest Rate</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="interest-rate" value="6.5" min="0" max="20" step="0.125">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="loan-term">Loan Term</label>
                        <div class="input-wrapper">
                            <select id="loan-term">
                                <option value="30" selected>30 years</option>
                                <option value="20">20 years</option>
                                <option value="15">15 years</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="property-tax">Property Tax Rate</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="property-tax" value="1.2" min="0" max="5" step="0.1">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="home-insurance">Home Insurance / yr</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="home-insurance" value="1800" min="0" step="100">
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="pmi-rate">PMI Rate (if &lt;20% down)</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="pmi-rate" value="0.5" min="0" max="3" step="0.1">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="hoa-fee">HOA / month</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="hoa-fee" value="0" min="0" step="25">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Monthly Payment</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Total Monthly Payment</span>
                        <div class="result-value">
                            <span id="total-monthly">$0</span>
                            <button class="copy-btn" onclick="copyValue('total-monthly', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Principal & Interest</span>
                        <span class="result-value" id="res-pi" style="color: var(--color-pi);">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Property Tax</span>
                        <span class="result-value" id="res-tax" style="color: var(--color-tax);">$0</span>
                    </div>
                    <div class="result-item">
