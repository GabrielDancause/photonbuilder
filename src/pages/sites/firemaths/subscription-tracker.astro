---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Subscription Cost Tracker",
  "url": "https://firemaths.info/subscription-tracker",
  "description": "Free subscription cost tracker — add all your recurring subscriptions, see the true monthly and annual cost, breakdown by category, and identify potential savings.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does the average person spend on subscriptions per month?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Studies show that the average American spends between $200 and $300 per month on subscriptions, though most people underestimate their spending by 2–3x. Common subscriptions include streaming services ($10–20 each), music ($10–11), cloud storage ($1–10), software ($5–30), gym memberships ($30–60), and meal kits ($40–80). Using a subscription tracker helps reveal the true total and find forgotten or underused subscriptions you could cancel."
      }
    },
    {
      "@type": "Question",
      "name": "How do I find all my active subscriptions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by checking your bank and credit card statements for the last 3 months — look for any recurring charges. Then check your email for subscription confirmation or renewal notices. Review your app store subscriptions (Apple App Store > Settings > Subscriptions, or Google Play > Payments & subscriptions). Finally, check services like PayPal, Venmo, or any payment platforms for recurring payments. Add each one to a tracker like this to see the full picture."
      }
    },
    {
      "@type": "Question",
      "name": "What subscriptions should I cancel to save money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start by identifying subscriptions you haven't used in the past month — these are the easiest to cut. Next, look for overlapping services (e.g., multiple streaming platforms with similar content, or both iCloud and Google One for storage). Consider downgrading annual plans to lower tiers instead of canceling entirely. Mark subscriptions as 'nice to have' vs. 'essential' to see your potential savings at a glance. Many people save $50–150/month just by auditing their subscriptions."
      }
    },
    {
      "@type": "Question",
      "name": "Is it cheaper to pay for subscriptions annually or monthly?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Annual billing is almost always cheaper — most services offer a 15–20% discount for paying yearly instead of monthly. For example, a $12.99/month service might cost $129.99/year (saving about $26). However, annual plans require a larger upfront payment and lock you in for a year. If you're unsure you'll keep a service, start with monthly billing and switch to annual once you know you'll stick with it. This tracker normalizes all billing cycles so you can compare costs easily."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I review my subscriptions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Financial experts recommend reviewing your subscriptions at least once every 3 months. Set a calendar reminder to audit your list — check for price increases (many services raise prices without prominent notice), unused services, free alternatives, and whether you're on the best available plan. A quarterly review can save hundreds of dollars per year. Some people also do a 'subscription reset' once a year where they cancel everything non-essential and only re-subscribe to services they actively miss."
      }
    }
  ]
};

export const meta = {
  title: "Subscription Tracker — Monthly & Annual Cost",
  description: "Free subscription tracker — add all your recurring subscriptions, see total monthly and annual cost, breakdown by category, and identify potential savings.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Subscription Cost Tracker — Monthly & Annual Cost Calculator | firemaths.info"
  description="Free subscription tracker — add all your recurring subscriptions, see total monthly and annual cost, breakdown by category, and identify potential savings."
  canonical="https://firemaths.info/subscription-tracker" schema={schema}
>
  <style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
}

@media (max-width: 640px) {
    .summary-grid {
        grid-template-columns: 1fr;
    }
}

.summary-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
}

.summary-card .label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    font-weight: 600;
    margin-bottom: 0.25rem;
}

.summary-card .value {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--accent-color);
}

.summary-card .sub {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

.tracker-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .tracker-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"],
input[type="text"] {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus,
input[type="text"]:focus {
    outline: none;
    border-color: var(--accent-color);
}

select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    cursor: pointer;
}

select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }

.btn-row {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
}

.btn-primary {
    flex: 1;
    padding: 0.75rem 1rem;
    background: var(--accent-color);
    color: #000;
    border: none;
    border-radius: 6px;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
}

.btn-primary:hover {
    opacity: 0.85;
}

.btn-secondary {
    padding: 0.75rem 1rem;
    background: var(--bg-color);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-secondary:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.quick-add-section {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
}

.quick-add-section h3 {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    font-weight: 600;
}

.quick-add-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
}

.quick-add-btn {
    padding: 0.4rem 0.75rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    border-radius: 6px;
    transition: all 0.2s;
    white-space: nowrap;
}

.quick-add-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.quick-add-btn.added {
    opacity: 0.4;
    pointer-events: none;
}

/* Pie chart */
.pie-chart-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.pie-chart {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    position: relative;
}

.pie-empty {
    background: var(--border-color);
}

.pie-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 100px;
    background: var(--card-bg);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.pie-center-label {
    font-size: 0.65rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.pie-center-value {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent-color);
}

.pie-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    justify-content: center;
}

.pie-legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
}

.pie-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
}

/* Subscription list */
.sub-list {
    margin-top: 1rem;
}

.sub-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
    gap: 0.75rem;
}

.sub-item:last-child {
    border-bottom: none;
}

.sub-info {
    flex: 1;
    min-width: 0;
}

.sub-name {
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
}

.sub-name .essential-badge {
    font-size: 0.65rem;
    background: var(--accent-color);
    color: #000;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}

.sub-name .nice-badge {
    font-size: 0.65rem;
    background: var(--border-color);
    color: var(--text-secondary);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-weight: 600;
}

.sub-meta {
    font-size: 0.8rem;
    color: var(--text-secondary);
}

.sub-cost {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    text-align: right;
}

.sub-cost .monthly {
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-weight: 400;
}

.sub-actions {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
}

.sub-action-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.sub-action-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.sub-action-btn.delete:hover {
    border-color: #e74c3c;
    color: #e74c3c;
}

.empty-state {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

/* Savings view */
.savings-section {
    margin-bottom: 3rem;
}

.savings-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.savings-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.savings-header h2 {
    font-size: 1.25rem;
    color: var(--accent-color);
}

.savings-amount {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.savings-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
}

.option-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
}

.option-row:last-child {
    border-bottom: none;
}

.option-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
}

.toggle-switch {
    position: relative;
    width: 44px;
    height: 24px;
    flex-shrink: 0;
}

.toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: var(--border-color);
    border-radius: 24px;
    transition: 0.2s;
}

.toggle-slider::before {
    content: "";
    position: absolute;
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background-color: var(--text-primary);
    border-radius: 50%;
    transition: 0.2s;
}

.toggle-switch input:checked + .toggle-slider {
    background-color: var(--accent-color);
}

.toggle-switch input:checked + .toggle-slider::before {
    transform: translateX(20px);
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "\2212";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Subscription Cost Tracker</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Track all your subscriptions and see the true annual cost</p>

    <main>
        <!-- Summary Cards -->
        <div class="summary-grid">
            <div class="summary-card">
                <div class="label">Monthly Cost</div>
                <div class="value" id="total-monthly">$0.00</div>
                <div class="sub" id="sub-count">0 subscriptions</div>
            </div>
            <div class="summary-card">
                <div class="label">Annual Cost</div>
                <div class="value" id="total-annual">$0.00</div>
                <div class="sub" id="daily-cost">$0.00/day</div>
            </div>
            <div class="summary-card">
                <div class="label">Potential Savings</div>
                <div class="value" id="potential-savings">$0.00</div>
                <div class="sub">per year (nice-to-have)</div>
            </div>
        </div>

        <div class="tracker-grid">
            <!-- Add Subscription -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Add Subscription</h2>
                </div>

                <div class="inputs">
                    <div class="input-group">
                        <label for="sub-name-input">Subscription Name</label>
                        <input type="text" id="sub-name-input" placeholder="e.g. Netflix" style="font-family: var(--font-ui);">
                    </div>

                    <div class="input-group">
                        <label for="sub-cost-input">Cost</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="sub-cost-input" value="" min="0" step="0.01" placeholder="9.99">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="sub-cycle-input">Billing Cycle</label>
                        <select id="sub-cycle-input">
                            <option value="monthly">Monthly</option>
                            <option value="weekly">Weekly</option>
                            <option value="quarterly">Quarterly</option>
                            <option value="yearly">Yearly</option>
                        </select>
                    </div>

                    <div class="input-group">
                        <label for="sub-category-input">Category</label>
                        <select id="sub-category-input">
                            <option value="streaming">Streaming</option>
                            <option value="music">Music</option>
                            <option value="software">Software</option>
                            <option value="cloud storage">Cloud Storage</option>
                            <option value="fitness">Fitness</option>
                            <option value="news">News</option>
                            <option value="gaming">Gaming</option>
                            <option value="food delivery">Food Delivery</option>
                            <option value="other">Other</option>
                        </select>
                    </div>

                    <div class="input-group" style="margin-bottom: 0;">
                        <label for="sub-priority-input">Priority</label>
                        <select id="sub-priority-input">
                            <option value="essential">Essential</option>
                            <option value="nice">Nice to Have</option>
                        </select>
                    </div>

                    <div class="btn-row" style="margin-top: 1.25rem;">
                        <button class="btn-primary" onclick="addSubscription()">Add Subscription</button>
                        <button class="btn-secondary" onclick="clearForm()">Clear</button>
                    </div>
                </div>

                <!-- Quick Add -->
                <div class="quick-add-section">
                    <h3>Quick Add Popular Services</h3>
                    <div class="quick-add-grid" id="quick-add-grid"></div>
                </div>
            </div>

            <!-- Category Breakdown -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Category Breakdown</h2>
                </div>

                <div class="pie-chart-container">
                    <div class="pie-chart pie-empty" id="pie-chart">
                        <div class="pie-center">
                            <span class="pie-center-label">Monthly</span>
                            <span class="pie-center-value" id="pie-center-val">$0</span>
                        </div>
                    </div>
                    <div class="pie-legend" id="pie-legend"></div>
                </div>

                <div style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
                    <div class="option-row">
                        <span class="option-label">Show only "nice to have"</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="filter-nice" onchange="renderAll()">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div class="option-row">
                        <span class="option-label">Sort by monthly cost (high to low)</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="sort-cost" checked onchange="renderAll()">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Subscription List -->
        <div class="scenario-card" style="margin-bottom: 3rem;">
            <div class="scenario-header">
                <h2>Your Subscriptions</h2>
                <button class="btn-secondary" onclick="clearAllSubs()" style="font-size: 0.8rem; padding: 0.4rem 0.75rem;">Clear All</button>
            </div>
            <div class="sub-list" id="sub-list">
                <div class="empty-state">No subscriptions added yet. Use the form above or quick-add buttons to get started.</div>
            </div>
        </div>

        <!-- SEO Content -->
        <div class="seo-content">
            <h2>Why Track Your Subscriptions?</h2>
            <p>The average person has 12 or more active subscriptions, and studies show most people underestimate their <strong>total subscription spending</strong> by 2 to 3 times the actual amount. Streaming services, music platforms, cloud storage, gym memberships, software tools, meal kits, and news sites all add up quickly — often exceeding $200–300 per month without you realizing it.</p>
            <p>A subscription cost tracker helps you see the <strong>true annual cost</strong> of all your recurring payments in one place. By normalizing weekly, monthly, quarterly, and yearly subscriptions to a common timeframe, you can compare costs accurately and identify which services are worth keeping and which ones are draining your budget.</p>

            <h2>How to Audit Your Subscriptions</h2>
            <p>Start by gathering all your recurring charges. Check your <strong>bank and credit card statements</strong> for the last 3 months, review your email for subscription confirmations, and check your app store subscriptions (both Apple and Google). Don't forget services billed through PayPal, Venmo, or other payment platforms.</p>
            <p>Add each subscription to this tracker with its exact cost and billing cycle. The calculator will normalize everything to monthly and annual totals. Then, mark each subscription as <strong>"essential"</strong> (something you'd re-subscribe to immediately if it disappeared) or <strong>"nice to have"</strong> (something you enjoy but could live without). The potential savings view shows you exactly how much you'd save by cutting non-essential subscriptions.</p>

            <h2>Tips for Reducing Subscription Costs</h2>
            <ul>
                <li><strong>Cancel unused services</strong> — if you haven't used it in the past month, cancel it. You can always re-subscribe later.</li>
                <li><strong>Eliminate overlapping services</strong> — do you really need Netflix, Hulu, Disney+, and HBO Max? Rotate between them instead.</li>
                <li><strong>Switch to annual billing</strong> — most services offer 15–20% discounts for yearly plans.</li>
                <li><strong>Downgrade plans</strong> — you might be paying for a premium tier when a basic plan would suffice.</li>
                <li><strong>Share family plans</strong> — many services offer family or group plans that cost less per person.</li>
                <li><strong>Use free alternatives</strong> — consider free tiers or open-source alternatives for software and storage.</li>
            </ul>

            <h2>Understanding Billing Cycles</h2>
            <p>Subscriptions come in various billing cycles, making it hard to compare costs at a glance. This tracker converts everything to a <strong>monthly equivalent</strong> so you can see the true cost. A $120/year subscription is $10/month, while a $3.99/week subscription is actually $17.29/month — or $207.48/year. Seeing these normalized costs often reveals surprising differences in what you're really paying.</p>
        </div>

        <!-- FAQ -->
        <div class="faq-section">
            <h2>Frequently Asked Questions</h2>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">How much does the average person spend on subscriptions per month?</button>
                <div class="faq-answer">Studies show that the average American spends between $200 and $300 per month on subscriptions, though most people underestimate their spending by 2–3x. Common subscriptions include streaming services ($10–20 each), music ($10–11), cloud storage ($1–10), software ($5–30), gym memberships ($30–60), and meal kits ($40–80). Using a subscription tracker helps reveal the true total and find forgotten or underused subscriptions you could cancel.</div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">How do I find all my active subscriptions?</button>
                <div class="faq-answer">Start by checking your bank and credit card statements for the last 3 months — look for any recurring charges. Then check your email for subscription confirmation or renewal notices. Review your app store subscriptions (Apple App Store > Settings > Subscriptions, or Google Play > Payments & subscriptions). Finally, check services like PayPal, Venmo, or any payment platforms for recurring payments. Add each one to a tracker like this to see the full picture.</div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">What subscriptions should I cancel to save money?</button>
                <div class="faq-answer">Start by identifying subscriptions you haven't used in the past month — these are the easiest to cut. Next, look for overlapping services (e.g., multiple streaming platforms with similar content, or both iCloud and Google One for storage). Consider downgrading annual plans to lower tiers instead of canceling entirely. Mark subscriptions as 'nice to have' vs. 'essential' to see your potential savings at a glance. Many people save $50–150/month just by auditing their subscriptions.</div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">Is it cheaper to pay for subscriptions annually or monthly?</button>
                <div class="faq-answer">Annual billing is almost always cheaper — most services offer a 15–20% discount for paying yearly instead of monthly. For example, a $12.99/month service might cost $129.99/year (saving about $26). However, annual plans require a larger upfront payment and lock you in for a year. If you're unsure you'll keep a service, start with monthly billing and switch to annual once you know you'll stick with it. This tracker normalizes all billing cycles so you can compare costs easily.</div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="toggleFaq(this)">How often should I review my subscriptions?</button>
                <div class="faq-answer">Financial experts recommend reviewing your subscriptions at least once every 3 months. Set a calendar reminder to audit your list — check for price increases (many services raise prices without prominent notice), unused services, free alternatives, and whether you're on the best available plan. A quarterly review can save hundreds of dollars per year. Some people also do a 'subscription reset' once a year where they cancel everything non-essential and only re-subscribe to services they actively miss.</div>
            </div>
        </div>

        <!-- Related -->
        <div class="related-links">
            <h2>Related Calculators</h2>
            <div class="related-grid">
                <a href="/tip-calculator">Tip Calculator</a>
                <a href="/investment-calculator">Investment Calculator</a>
            </div>
        </div>
    </main>
</div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

const STORAGE_KEY = 'firemaths_subscriptions';

const CATEGORY_COLORS = {
    streaming: '#e74c3c',
    music: '#9b59b6',
    software: '#3498db',
    'cloud storage': '#1abc9c',
    fitness: '#e67e22',
    news: '#f1c40f',
    gaming: '#2ecc71',
    'food delivery': '#e91e63',
    other: '#95a5a6'
};

const PRESETS = [
    { name: 'Netflix', cost: 15.49, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'Spotify', cost: 11.99, cycle: 'monthly', category: 'music', priority: 'nice' },
    { name: 'Disney+', cost: 9.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'YouTube Premium', cost: 13.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'HBO Max', cost: 16.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'Hulu', cost: 9.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'Apple Music', cost: 10.99, cycle: 'monthly', category: 'music', priority: 'nice' },
    { name: 'Amazon Prime', cost: 14.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'Apple TV+', cost: 9.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'iCloud+ 200GB', cost: 2.99, cycle: 'monthly', category: 'cloud storage', priority: 'essential' },
    { name: 'Google One 100GB', cost: 1.99, cycle: 'monthly', category: 'cloud storage', priority: 'essential' },
    { name: 'Dropbox Plus', cost: 11.99, cycle: 'monthly', category: 'cloud storage', priority: 'nice' },
    { name: 'Microsoft 365', cost: 9.99, cycle: 'monthly', category: 'software', priority: 'essential' },
    { name: 'Adobe Creative Cloud', cost: 59.99, cycle: 'monthly', category: 'software', priority: 'essential' },
    { name: 'ChatGPT Plus', cost: 20.00, cycle: 'monthly', category: 'software', priority: 'nice' },
    { name: 'Gym Membership', cost: 40.00, cycle: 'monthly', category: 'fitness', priority: 'nice' },
    { name: 'NYT Digital', cost: 4.25, cycle: 'weekly', category: 'news', priority: 'nice' },
    { name: 'Xbox Game Pass', cost: 16.99, cycle: 'monthly', category: 'gaming', priority: 'nice' },
    { name: 'PlayStation Plus', cost: 59.99, cycle: 'yearly', category: 'gaming', priority: 'nice' },
    { name: 'DoorDash DashPass', cost: 9.99, cycle: 'monthly', category: 'food delivery', priority: 'nice' },
    { name: 'Paramount+', cost: 7.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
    { name: 'Peacock Premium', cost: 7.99, cycle: 'monthly', category: 'streaming', priority: 'nice' },
];

function loadSubs() {
    try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
    } catch { return []; }
}

function saveSubs(subs) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(subs));
}

function toMonthly(cost, cycle) {
    switch (cycle) {
        case 'weekly': return cost * 52 / 12;
        case 'monthly': return cost;
        case 'quarterly': return cost / 3;
        case 'yearly': return cost / 12;
        default: return cost;
    }
}

function cycleName(cycle) {
    switch (cycle) {
        case 'weekly': return 'week';
        case 'monthly': return 'month';
        case 'quarterly': return 'quarter';
        case 'yearly': return 'year';
        default: return cycle;
    }
}

window.addSubscription = function() {
    const name = document.getElementById('sub-name-input').value.trim();
    const cost = parseFloat(document.getElementById('sub-cost-input').value);
    const cycle = document.getElementById('sub-cycle-input').value;
    const category = document.getElementById('sub-category-input').value;
    const priority = document.getElementById('sub-priority-input').value;

    if (!name || isNaN(cost) || cost <= 0) return;

    const subs = loadSubs();
    subs.push({ id: Date.now(), name, cost, cycle, category, priority });
    saveSubs(subs);
    clearForm();
    renderAll();
};

window.clearForm = function() {
    document.getElementById('sub-name-input').value = '';
    document.getElementById('sub-cost-input').value = '';
    document.getElementById('sub-cycle-input').value = 'monthly';
    document.getElementById('sub-category-input').value = 'streaming';
    document.getElementById('sub-priority-input').value = 'essential';
};

window.deleteSub = function(id) {
    const subs = loadSubs().filter(s => s.id !== id);
    saveSubs(subs);
    renderAll();
};

window.togglePriority = function(id) {
    const subs = loadSubs();
    const sub = subs.find(s => s.id === id);
    if (sub) {
        sub.priority = sub.priority === 'essential' ? 'nice' : 'essential';
        saveSubs(subs);
        renderAll();
    }
};

window.quickAdd = function(idx) {
    const preset = PRESETS[idx];
    const subs = loadSubs();
    // Check for duplicate
    if (subs.some(s => s.name.toLowerCase() === preset.name.toLowerCase())) return;
    subs.push({ id: Date.now() + idx, name: preset.name, cost: preset.cost, cycle: preset.cycle, category: preset.category, priority: preset.priority });
    saveSubs(subs);
    renderAll();
};

window.clearAllSubs = function() {
    if (!confirm('Remove all subscriptions?')) return;
    saveSubs([]);
    renderAll();
};

window.toggleFaq = function(btn) {
    btn.parentElement.classList.toggle('open');
};

function renderQuickAdd() {
    const subs = loadSubs();
    const grid = document.getElementById('quick-add-grid');
    grid.innerHTML = PRESETS.map((p, i) => {
        const added = subs.some(s => s.name.toLowerCase() === p.name.toLowerCase());
        return '<button class="quick-add-btn' + (added ? ' added' : '') + '" onclick="quickAdd(' + i + ')">' + p.name + ' (' + fmt(p.cost) + '/' + cycleName(p.cycle).charAt(0) + ')</button>';
    }).join('');
}

function renderSummary(subs) {
    let totalMonthly = 0;
    let niceSavings = 0;
    subs.forEach(s => {
        const m = toMonthly(s.cost, s.cycle);
        totalMonthly += m;
        if (s.priority === 'nice') niceSavings += m;
    });
    const totalAnnual = totalMonthly * 12;
    const daily = totalAnnual / 365;

    document.getElementById('total-monthly').innerText = fmt(totalMonthly);
    document.getElementById('total-annual').innerText = fmt(totalAnnual);
    document.getElementById('daily-cost').innerText = fmt(daily) + '/day';
    document.getElementById('sub-count').innerText = subs.length + ' subscription' + (subs.length !== 1 ? 's' : '');
    document.getElementById('potential-savings').innerText = fmt(niceSavings * 12);
}

function renderPieChart(subs) {
    const categoryTotals = {};
    let totalMonthly = 0;
    subs.forEach(s => {
        const m = toMonthly(s.cost, s.cycle);
        totalMonthly += m;
        categoryTotals[s.category] = (categoryTotals[s.category] || 0) + m;
    });

    const chart = document.getElementById('pie-chart');
    const legend = document.getElementById('pie-legend');
    document.getElementById('pie-center-val').innerText = fmt(totalMonthly);

    if (totalMonthly === 0) {
        chart.style.background = '';
        chart.className = 'pie-chart pie-empty';
        legend.innerHTML = '';
        return;
    }

    chart.className = 'pie-chart';

    // Build conic-gradient
    const entries = Object.entries(categoryTotals).sort((a, b) => b[1] - a[1]);
    let gradientParts = [];
    let cumPct = 0;
    entries.forEach(([cat, val]) => {
        const pct = (val / totalMonthly) * 100;
        const color = CATEGORY_COLORS[cat] || '#95a5a6';
        gradientParts.push(color + ' ' + cumPct.toFixed(2) + '% ' + (cumPct + pct).toFixed(2) + '%');
        cumPct += pct;
    });
    chart.style.background = 'conic-gradient(' + gradientParts.join(', ') + ')';

    // Legend
    legend.innerHTML = entries.map(([cat, val]) => {
        const color = CATEGORY_COLORS[cat] || '#95a5a6';
        const pct = ((val / totalMonthly) * 100).toFixed(0);
        return '<span class="pie-legend-item"><span class="pie-legend-dot" style="background:' + color + '"></span>' + cat + ' ' + pct + '% (' + fmt(val) + ')</span>';
    }).join('');
}

function renderList(subs) {
    const filterNice = document.getElementById('filter-nice').checked;
    const sortByCost = document.getElementById('sort-cost').checked;

    let filtered = filterNice ? subs.filter(s => s.priority === 'nice') : [...subs];

    if (sortByCost) {
        filtered.sort((a, b) => toMonthly(b.cost, b.cycle) - toMonthly(a.cost, a.cycle));
    }

    const list = document.getElementById('sub-list');
    if (filtered.length === 0) {
        list.innerHTML = '<div class="empty-state">' + (filterNice ? 'No "nice to have" subscriptions.' : 'No subscriptions added yet. Use the form above or quick-add buttons to get started.') + '</div>';
        return;
    }

    list.innerHTML = filtered.map(s => {
        const m = toMonthly(s.cost, s.cycle);
        const badge = s.priority === 'essential'
            ? '<span class="essential-badge">Essential</span>'
            : '<span class="nice-badge">Nice to Have</span>';
        return '<div class="sub-item">' +
            '<div class="sub-info">' +
                '<div class="sub-name">' + s.name + ' ' + badge + '</div>' +
                '<div class="sub-meta">' + s.category + ' &middot; ' + fmt(s.cost) + '/' + cycleName(s.cycle) + '</div>' +
            '</div>' +
            '<div class="sub-cost">' + fmt(m) + '<br><span class="monthly">/month</span></div>' +
            '<div class="sub-actions">' +
                '<button class="sub-action-btn" onclick="togglePriority(' + s.id + ')" title="Toggle priority">' + (s.priority === 'essential' ? 'Nice?' : 'Ess.?') + '</button>' +
                '<button class="sub-action-btn delete" onclick="deleteSub(' + s.id + ')" title="Remove">X</button>' +
            '</div>' +
        '</div>';
    }).join('');
}

window.renderAll = function() {
    const subs = loadSubs();
    renderSummary(subs);
    renderPieChart(subs);
    renderList(subs);
    renderQuickAdd();
};

// Initial render
renderAll();
  </script>
</SiteLayout>
