---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Savings Goal Calculator",
  "url": "https://firemaths.info/savings-goal-calculator.html",
  "description": "Interactive savings timeline calculator to determine how long to save for your financial targets.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Savings Goal Calculator: How Long Until You Hit Your Target? | firemaths.info"
  description="Find out exactly when you'll hit your financial target. Your timeline might be years shorter than you think—discover the math that makes it happen."
  canonical="https://firemaths.info/savings-goal-calculator.html" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Your Parameters</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="goal-amount"><span>Savings Goal</span> <span id="goal-val-display" style="font-family: var(--font-mono);">$100,000</span></label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="goal-amount" value="100000" min="1000" step="1000">
                        </div>
                        <input type="range" class="w-full h-2 bg-[var(--border-color)] rounded-lg appearance-none cursor-pointer accent-[var(--accent-color)] mt-2" id="goal-slider" min="1000" max="1000000" step="1000" value="100000">
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="current-savings"><span>Current Savings</span> <span id="current-val-display" style="font-family: var(--font-mono);">$10,000</span></label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="current-savings" value="10000" min="0" step="100">
                        </div>
                        <input type="range" class="w-full h-2 bg-[var(--border-color)] rounded-lg appearance-none cursor-pointer accent-[var(--accent-color)] mt-2" id="current-slider" min="0" max="500000" step="1000" value="10000">
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="monthly-contrib"><span>Monthly Contribution</span> <span id="monthly-val-display" style="font-family: var(--font-mono);">$500</span></label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="monthly-contrib" value="500" min="0" step="50">
                        </div>
                        <input type="range" class="w-full h-2 bg-[var(--border-color)] rounded-lg appearance-none cursor-pointer accent-[var(--accent-color)] mt-2" id="monthly-slider" min="0" max="10000" step="50" value="500">
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="expected-return"><span>Expected Annual Return</span> <span id="return-val-display" style="font-family: var(--font-mono);">7.0%</span></label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">%</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="expected-return" value="7" min="0" step="0.1" max="30">
                        </div>
                        <input type="range" class="w-full h-2 bg-[var(--border-color)] rounded-lg appearance-none cursor-pointer accent-[var(--accent-color)] mt-2" id="return-slider" min="0" max="15" step="0.1" value="7">
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="adjust-inflation" checked>
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="adjust-inflation">Adjust for 3% annual inflation</label>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Your Timeline</h2>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Time to Goal</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="time-to-goal">0 yrs 0 mos</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('time-to-goal', this)">Copy</button>
                        </div>
                    </div>

                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Contributions</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="total-contributions">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Interest Earned</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="total-interest">$0</span>
                    </div>

                    <div class="milestones">
                        <h3 style="font-size: 1rem; margin-bottom: 1rem; color: var(--text-primary);">Milestones</h3>

                        <div class="milestone-item">
                            <div class="milestone-marker">25%</div>
                            <div class="milestone-bar-container"><div class="milestone-bar" style="width: 25%"></div></div>
                            <div class="milestone-time" id="time-25">--</div>
                        </div>
                        <div class="milestone-item">
                            <div class="milestone-marker">50%</div>
                            <div class="milestone-bar-container"><div class="milestone-bar" style="width: 50%"></div></div>
                            <div class="milestone-time" id="time-50">--</div>
                        </div>
                        <div class="milestone-item">
                            <div class="milestone-marker">75%</div>
                            <div class="milestone-bar-container"><div class="milestone-bar" style="width: 75%"></div></div>
                            <div class="milestone-time" id="time-75">--</div>
                        </div>
                    </div>

                    <div class="what-if-scenarios">
                        <h3 style="font-size: 1rem; margin-bottom: 1rem; color: var(--text-primary);">What If?</h3>
                        <div class="what-if-item">
                            <span>Add $100/mo to contribution:</span>
                            <span class="what-if-val" id="what-if-add-100">--</span>
                        </div>
                        <div class="what-if-item">
                            <span>Return drops by 2%:</span>
                            <span class="what-if-val" id="what-if-drop-return">--</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="chart-section">
            <div class="chart-header">
                <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Savings Growth Over Time</h2>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding Your Savings Timeline</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">A savings timeline calculator helps you bridge the gap between where you are today and where you want to be financially. Whether you're saving for a house down payment, a wedding, or aiming for early retirement (FIRE), knowing exactly how long to save for your target gives you a concrete roadmap.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The math is simple but powerful: it combines your current starting amount with your ongoing monthly contributions, and then applies compound interest over time. If your expected return is higher than inflation, your money works for you, dramatically shortening your savings timeline.</p>

            <div class="faq-section">
                <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Frequently Asked Questions</h2>

                <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                    <h3 class="text-xl font-bold text-white mt-6 mb-3">How does a savings goal calculator work?</h3>
                    <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">A savings goal calculator determines how long it takes to reach a specific financial target by compounding your current savings and regular monthly contributions at an expected annual return rate.</p>
                </div>

                <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                    <h3 class="text-xl font-bold text-white mt-6 mb-3">How long to save for a down payment or major purchase?</h3>
                    <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The timeline depends on your initial savings, monthly contributions, and where you invest the money. Use this savings timeline calculator to instantly see how many months or years you need to save.</p>
                </div>

                <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                    <h3 class="text-xl font-bold text-white mt-6 mb-3">What is the best savings timeline calculator?</h3>
                    <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The best calculators account for current savings, monthly contributions, compound interest, and inflation to give you an accurate real-world timeline for reaching your goals.</p>
                </div>

                <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                    <h3 class="text-xl font-bold text-white mt-6 mb-3">Should I adjust my savings goal calculator for inflation?</h3>
                    <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Yes. If your goal is years away, inflation reduces your purchasing power. Adjusting for inflation ensures that your target amount will actually buy what you need when you finally reach it.</p>
                </div>

                <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                    <h3 class="text-xl font-bold text-white mt-6 mb-3">How can I speed up my savings timeline?</h3>
                    <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">You can hit your target faster by increasing your monthly contributions, starting with a larger initial amount, or investing in assets with a higher expected return rate.</p>
                </div>
            </div>
        </div>
    </main>

    
</div>
  <script is:inline>
const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    const formatTime = (months) => {
        if (!isFinite(months)) return "Never";
        const y = Math.floor(months / 12);
        const m = Math.round(months % 12);
        if (y === 0) return `${m} mo${m !== 1 ? 's' : ''}`;
        if (m === 0) return `${y} yr${y !== 1 ? 's' : ''}`;
        return `${y} yr${y !== 1 ? 's' : ''} ${m} mo${m !== 1 ? 's' : ''}`;
    };

    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const calculateTimeline = (goal, current, monthly, rate, adjustInflation) => {
        const actualRate = adjustInflation ? Math.max(0, rate - 3) : rate;
        const monthlyRate = (actualRate / 100) / 12;

        let balance = current;
        let months = 0;
        let totalContributions = current;
        const history = [balance];

        let m25 = current >= goal * 0.25 ? 0 : -1;
        let m50 = current >= goal * 0.50 ? 0 : -1;
        let m75 = current >= goal * 0.75 ? 0 : -1;

        if (balance >= goal) {
            return {
                months: 0,
                totalContributions: balance,
                totalInterest: 0,
                history: [balance],
                m25: 0, m50: 0, m75: 0, finalBalance: balance
            };
        }

        if (monthlyRate === 0 && monthly === 0) {
            return { months: Infinity, history: [balance], totalContributions: current, totalInterest: 0, m25: -1, m50: -1, m75: -1, finalBalance: balance };
        }

        const maxMonths = 1200; // 100 years max loop
        while (balance < goal && months < maxMonths) {
            months++;
            balance = balance * (1 + monthlyRate) + monthly;
            totalContributions += monthly;

            if (months % 12 === 0 || balance >= goal) {
                history.push(balance);
            }

            if (m25 === -1 && balance >= goal * 0.25) m25 = months;
            if (m50 === -1 && balance >= goal * 0.50) m50 = months;
            if (m75 === -1 && balance >= goal * 0.75) m75 = months;
        }

        return {
            months: months >= maxMonths ? Infinity : months,
            totalContributions: totalContributions,
            totalInterest: balance - totalContributions,
            history: history,
            m25: m25,
            m50: m50,
            m75: m75,
            finalBalance: balance
        };
    };

    let chartCanvas = document.getElementById('growthChart');
    let ctx = chartCanvas.getContext('2d');

    const drawChart = (data, years, goal) => {
        const dpr = window.devicePixelRatio || 1;
        const rect = chartCanvas.parentElement.getBoundingClientRect();

        chartCanvas.width = rect.width * dpr;
        chartCanvas.height = rect.height * dpr;

        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);

        const width = rect.width;
        const height = rect.height;

        ctx.clearRect(0, 0, width, height);

        const padding = { top: 20, right: 20, bottom: 40, left: 80 };
        const chartWidth = width - padding.left - padding.right;
        const chartHeight = height - padding.top - padding.bottom;

        if (years <= 0 || !isFinite(years)) return;

        const maxVal = Math.max(goal, ...data) * 1.05;

        // Draw grid
        ctx.strokeStyle = '#2a2010';
        ctx.lineWidth = 1;
        ctx.font = '12px Inter, sans-serif';
        ctx.fillStyle = '#888888';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        // Y-axis
        const yTicks = 5;
        for (let i = 0; i <= yTicks; i++) {
            const val = maxVal * (i / yTicks);
            const y = height - padding.bottom - (chartHeight * (i / yTicks));

            ctx.beginPath();
            ctx.moveTo(padding.left, y);
            ctx.lineTo(width - padding.right, y);
            ctx.stroke();

            let label = val >= 1000000 ? '$' + (val / 1000000).toFixed(1) + 'M' :
                        val >= 1000 ? '$' + (val / 1000).toFixed(0) + 'k' : '$' + val.toFixed(0);
            ctx.fillText(label, padding.left - 10, y);
        }

        // X-axis
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const xTicks = Math.min(years, 10);
        for (let i = 0; i <= xTicks; i++) {
            const yearIndex = Math.round((years / xTicks) * i);
            const x = padding.left + (chartWidth * (yearIndex / years));

            ctx.beginPath();
            ctx.moveTo(x, height - padding.bottom);
            ctx.lineTo(x, height - padding.bottom + 5);
            ctx.stroke();

            ctx.fillText('Yr ' + yearIndex, x, height - padding.bottom + 10);
        }

        // Draw Goal Line
        const goalY = height - padding.bottom - (chartHeight * (goal / maxVal));
        ctx.beginPath();
        ctx.strokeStyle = '#888888';
        ctx.setLineDash([5, 5]);
        ctx.moveTo(padding.left, goalY);
        ctx.lineTo(width - padding.right, goalY);
        ctx.stroke();
        ctx.setLineDash([]);

        ctx.fillStyle = '#888888';
        ctx.textAlign = 'left';
        ctx.textBaseline = 'bottom';
        ctx.fillText('Goal Target', padding.left + 10, goalY - 5);

        // Draw trajectory
        ctx.beginPath();
        ctx.strokeStyle = '#D4A017';
        ctx.lineWidth = 3;
        ctx.lineJoin = 'round';

        data.forEach((val, i) => {
            const x = padding.left + (chartWidth * (i / years));
            const y = height - padding.bottom - (chartHeight * (val / maxVal));

            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        });
        ctx.stroke();

        // Fill area
        ctx.lineTo(padding.left + chartWidth, height - padding.bottom);
        ctx.lineTo(padding.left, height - padding.bottom);
        ctx.closePath();

        const gradient = ctx.createLinearGradient(0, padding.top, 0, height - padding.bottom);
        gradient.addColorStop(0, `rgba(212, 160, 23, 0.2)`);
        gradient.addColorStop(1, `rgba(212, 160, 23, 0)`);

        ctx.fillStyle = gradient;
        ctx.fill();
    };

    const syncInputs = (id) => {
        const numInput = document.getElementById(id);
        const sliderInput = document.getElementById(id.replace(/amount|savings|contrib|expected-return/, 'slider'));
        const displaySpan = document.getElementById(id.replace(/amount|savings|contrib|expected-return/, 'val-display'));

        if (!sliderInput) return;

        numInput.addEventListener('input', () => {
            sliderInput.value = numInput.value;
            updateCalculator();
        });

        sliderInput.addEventListener('input', () => {
            numInput.value = sliderInput.value;
            updateCalculator();
        });
    };

    const updateCalculator = () => {
        const goal = parseFloat(document.getElementById('goal-amount').value) || 0;
        const current = parseFloat(document.getElementById('current-savings').value) || 0;
        const monthly = parseFloat(document.getElementById('monthly-contrib').value) || 0;
        const rate = parseFloat(document.getElementById('expected-return').value) || 0;
        const adjustInflation = document.getElementById('adjust-inflation').checked;

        document.getElementById('goal-val-display').innerText = formatCurrency(goal);
        document.getElementById('current-val-display').innerText = formatCurrency(current);
        document.getElementById('monthly-val-display').innerText = formatCurrency(monthly);
        document.getElementById('return-val-display').innerText = rate.toFixed(1) + '%';

        const res = calculateTimeline(goal, current, monthly, rate, adjustInflation);

        if (res.months === Infinity) {
            document.getElementById('time-to-goal').innerText = "Never (Increase savings)";
            document.getElementById('total-contributions').innerText = "--";
            document.getElementById('total-interest').innerText = "--";
            drawChart([current], 1, goal);
            document.getElementById('time-25').innerText = "--";
            document.getElementById('time-50').innerText = "--";
            document.getElementById('time-75').innerText = "--";
        } else {
            document.getElementById('time-to-goal').innerText = formatTime(res.months);
            document.getElementById('total-contributions').innerText = formatCurrency(res.totalContributions);
            document.getElementById('total-interest').innerText = formatCurrency(res.totalInterest);

            const years = Math.max(1, Math.ceil(res.months / 12));
            drawChart(res.history, years, goal);

            document.getElementById('time-25').innerText = res.m25 !== -1 ? (res.m25 === 0 ? "Achieved" : formatTime(res.m25)) : "--";
            document.getElementById('time-50').innerText = res.m50 !== -1 ? (res.m50 === 0 ? "Achieved" : formatTime(res.m50)) : "--";
            document.getElementById('time-75').innerText = res.m75 !== -1 ? (res.m75 === 0 ? "Achieved" : formatTime(res.m75)) : "--";
        }

        // What if scenarios
        const if100 = calculateTimeline(goal, current, monthly + 100, rate, adjustInflation);
        const ifDrop = calculateTimeline(goal, current, monthly, rate - 2, adjustInflation);

        if(res.months === Infinity || if100.months === Infinity) {
            document.getElementById('what-if-add-100').innerText = "--";
        } else {
            const diff = res.months - if100.months;
            document.getElementById('what-if-add-100').innerText = `Reach goal ${formatTime(diff)} faster`;
            document.getElementById('what-if-add-100').style.color = 'var(--accent-color)';
        }

        if(res.months === Infinity || ifDrop.months === Infinity) {
            document.getElementById('what-if-drop-return').innerText = "--";
        } else {
            const diff = ifDrop.months - res.months;
            document.getElementById('what-if-drop-return').innerText = `Takes ${formatTime(diff)} longer`;
            document.getElementById('what-if-drop-return').style.color = '#e24a4a'; // Reddish for negative impact
        }
    };

    ['goal-amount', 'current-savings', 'monthly-contrib', 'expected-return'].forEach(syncInputs);
    document.getElementById('adjust-inflation').addEventListener('change', updateCalculator);

    window.addEventListener('resize', updateCalculator);

    setTimeout(() => {
        updateCalculator();
    }, 0);
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-budgeting-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Budgeting for Beginners: Build Your Financial Foundation</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
