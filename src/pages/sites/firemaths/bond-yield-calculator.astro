---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Bond Yield Calculator",
  "url": "https://firemaths.info/bond-yield-calculator.html",
  "description": "Interactive bond yield calculator computing Yield to Maturity (YTM), current yield, pricing tables, duration, and convexity.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Bond Yield Calculator | Current Yield, YTM & Price Relationship"
  description="Why does a $1,000 bond rarely sell for $1,000? Uncover the true relationship between price and yield to maturity, and see what your fixed-income investments are actually returning."
  canonical="https://firemaths.info/bond-yield-calculator.html" schema={schema}
>


<main>
        

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <h2 class="text-2xl font-bold text-white mb-6 pb-2 border-b border-[var(--border-color)]">Bond Details</h2>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="faceValue">Face Value (Par Value)</label>
                    <div class="relative flex items-center">
                        <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                        <input type="number" id="faceValue" value="1000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors pl-10 pr-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] text-white focus:border-[var(--accent-color)] rounded-lg focus:outline-none w-full border text-base pr-4 pl-10 transition-colors">
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="couponRate">Annual Coupon Rate</label>
                    <div class="relative flex items-center">
                        <input type="number" id="couponRate" value="5" min="0" step="0.1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors pl-4 pr-10 font-mono pr-10 bg-[var(--bg-color)] py-3 border-[var(--border-color)] text-white focus:border-[var(--accent-color)] rounded-lg focus:outline-none w-full border text-base pl-4 transition-colors">
                        <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="currentPrice">Current Market Price</label>
                    <div class="relative flex items-center">
                        <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                        <input type="number" id="currentPrice" value="950" min="0" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors pl-10 pr-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] text-white focus:border-[var(--accent-color)] rounded-lg focus:outline-none w-full border text-base pr-4 pl-10 transition-colors">
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="yearsToMaturity">Years to Maturity</label>
                    <div class="relative flex items-center">
                        <input type="number" id="yearsToMaturity" value="10" min="0.1" step="0.5" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors pl-4 pr-10 font-mono pr-10 bg-[var(--bg-color)] py-3 border-[var(--border-color)] text-white focus:border-[var(--accent-color)] rounded-lg focus:outline-none w-full border text-base pl-4 transition-colors">
                        <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">Yrs</span>
                    </div>
                </div>

                <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="paymentFrequency">Payment Frequency</label>
                    <select id="paymentFrequency" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                        <option value="1">Annual (1x/yr)</option>
                        <option value="2" selected>Semi-Annual (2x/yr)</option>
                        <option value="4">Quarterly (4x/yr)</option>
                        <option value="12">Monthly (12x/yr)</option>
                    </select>
                </div>

                <div class="mt-4 pt-4 border-t border-[var(--border-color)]">
                    <label class="flex items-center cursor-pointer text-sm text-[var(--text-secondary)]">
                        <input type="checkbox" id="enableCallable" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        Bond is Callable
                    </label>
                </div>

                <div id="callableInputs" class="hidden !important" style="margin-top: 1rem;">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="yearsToCall">Years to Call</label>
                        <div class="relative flex items-center">
                            <input type="number" id="yearsToCall" value="5" min="0.1" step="0.5" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors pl-4 pr-10 font-mono pr-10 bg-[var(--bg-color)] py-3 border-[var(--border-color)] text-white focus:border-[var(--accent-color)] rounded-lg focus:outline-none w-full border text-base pl-4 transition-colors">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">Yrs</span>
                        </div>
                    </div>
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="callPrice">Call Price</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="callPrice" value="1020" min="0" step="1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors pl-10 pr-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] text-white focus:border-[var(--accent-color)] rounded-lg focus:outline-none w-full border text-base pr-4 pl-10 transition-colors">
                        </div>
                    </div>
                </div>
            </div>

            <div class="card results-section">
                <h2 class="text-2xl font-bold text-white mb-6 pb-2 border-b border-[var(--border-color)]">Yield Results</h2>

                <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-5 flex justify-between items-center transition-all hover:-translate-y-0.5 hover:border-[var(--accent-color)]">
                    <div class="text-[var(--text-secondary)] text-sm font-medium">Yield to Maturity (YTM)</div>
                    <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="resYTM">--%</div>
                </div>

                <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-5 flex justify-between items-center transition-all hover:-translate-y-0.5 hover:border-[var(--accent-color)]">
                    <div class="text-[var(--text-secondary)] text-sm font-medium">Current Yield</div>
                    <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="resCurrentYield" style="color: var(--text-main);">--%</div>
                </div>

                <div class="result-box hidden" id="resYTCBox">
                    <div class="text-[var(--text-secondary)] text-sm font-medium">Yield to Call (YTC)</div>
                    <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="resYTC">--%</div>
                </div>

                <h2 class="text-2xl font-bold text-white mb-6 pb-2 border-b border-[var(--border-color)] text-xl my-4">Risk Metrics</h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4">
                        <div class="text-[var(--text-secondary)] text-sm font-medium">Macaulay Duration</div>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="resMacD">-- yrs</div>
                    </div>
                    <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4">
                        <div class="text-[var(--text-secondary)] text-sm font-medium">Modified Duration</div>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="resModD">-- %</div>
                    </div>
                    <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4">
                        <div class="text-[var(--text-secondary)] text-sm font-medium">Convexity</div>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="resConv">--</div>
                    </div>
                    <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4">
                        <div class="text-[var(--text-secondary)] text-sm font-medium">Annual Coupon</div>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="resCouponAmt">$0.00</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-white mb-6 pb-2 border-b border-[var(--border-color)]">Price vs. Yield Relationship</h2>
            <p class="text-sm text-[var(--text-secondary)] mb-4">
                This chart illustrates the inverse relationship between a bond's yield and its price. The dot represents your current bond setup.
            </p>
            <div class="w-full h-[400px] relative">
                <canvas id="yieldChart"></canvas>
            </div>
        </div>

        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm" style="margin-top: 2rem;">
            <h2 class="text-2xl font-bold text-white mb-6 pb-2 border-b border-[var(--border-color)]">Bond Pricing Table</h2>
            <p class="text-sm text-[var(--text-secondary)]">
                Estimated bond prices if market yield (YTM) changes.
            </p>
            <div class="overflow-x-auto mt-8">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-[var(--card-bg)] border-b border-[var(--border-color)]">
                        <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                            <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Market Yield (YTM)</th>
                            <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Bond Price</th>
                            <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Change in Price</th>
                        </tr>
                    </thead>
                    <tbody id="pricingTableBody">
                        <!-- Filled by JS -->
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-16">
            <h2 class="text-2xl font-bold text-white mb-6 pb-2 border-b border-[var(--border-color)]">Frequently Asked Questions</h2>

            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <h3 class="text-xl font-bold text-white mb-3">How do you use a bond yield calculator?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">To use a bond yield calculator, you need to input the bond's current market price, its face value (usually $1,000), the annual coupon rate, the number of years until maturity, and the coupon payment frequency. The calculator will then determine the current yield and the yield to maturity (YTM).</p>
            </div>

            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <h3 class="text-xl font-bold text-white mb-3">What is the difference between current yield and yield to maturity?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">Current yield only looks at the annual coupon payment divided by the current market price, ignoring the bond's face value at maturity. A yield to maturity calculator accounts for all future cash flows plus the difference between the current price and the face value received at maturity, offering a more comprehensive measure of return.</p>
            </div>

            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <h3 class="text-xl font-bold text-white mb-3">How does a bond price calculator work?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">A bond price calculator uses the discounted cash flow method. It takes all future cash flows (regular coupon payments and the final face value repayment) and discounts them back to present value using a target yield rate. The sum of these present values equals the fair bond price.</p>
            </div>

            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <h3 class="text-xl font-bold text-white mb-3">Why do bond prices go down when yields go up?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">There is an inverse relationship between bond prices and yields. When interest rates in the market rise, newly issued bonds pay higher coupons. To make an older, lower-paying bond attractive to investors, its price must drop until its overall yield matches the new higher market rates.</p>
            </div>

            <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <h3 class="text-xl font-bold text-white mb-3">What does a yield to maturity calculator tell you?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">A yield to maturity calculator reveals the total annualized return an investor will earn if they buy the bond at the current price, hold it until maturity, and reinvest all coupon payments at that same yield rate.</p>
            </div>
        </div>
    </main>
  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
            const inputs = ['faceValue', 'couponRate', 'currentPrice', 'yearsToMaturity', 'paymentFrequency', 'yearsToCall', 'callPrice'];
            inputs.forEach(id => document.getElementById(id).addEventListener('input', calculateAll));
            document.getElementById('enableCallable').addEventListener('change', (e) => {
                document.getElementById('callableInputs').classList.toggle('!hidden', !e.target.checked);
                document.getElementById('resYTCBox').classList.toggle('!hidden', !e.target.checked);
                calculateAll();
            });

            const canvas = document.getElementById('yieldChart');
            const ctx = canvas.getContext('2d');

            function calculatePrice(yieldRate, faceValue, couponRate, yearsToMaturity, freq) {
                const periods = yearsToMaturity * freq;
                const r = yieldRate / freq;
                const c = (couponRate / 100) * faceValue / freq;

                let price = 0;
                if (r === 0) {
                    return (c * periods) + faceValue;
                }

                for (let i = 1; i <= periods; i++) {
                    price += c / Math.pow(1 + r, i);
                }
                price += faceValue / Math.pow(1 + r, periods);
                return price;
            }

            function calculateYTM(price, faceValue, couponRate, yearsToMaturity, freq, isCall = false, callPrice = 0) {
                const periods = yearsToMaturity * freq;
                const c = (couponRate / 100) * faceValue / freq;
                const finalValue = isCall ? callPrice : faceValue;

                // Bisection method to find YTM
                let low = -0.99;
                let high = 2.0;
                let ytm = 0;
                let guessPrice = 0;

                for (let i = 0; i < 100; i++) {
                    ytm = (low + high) / 2;
                    let r = ytm / freq;

                    guessPrice = 0;
                    if (r === 0) {
                        guessPrice = (c * periods) + finalValue;
                    } else {
                        // closed form sum
                        guessPrice = c * ((1 - Math.pow(1 + r, -periods)) / r) + finalValue * Math.pow(1 + r, -periods);
                    }

                    if (Math.abs(guessPrice - price) < 0.0001) break;

                    if (guessPrice > price) {
                        low = ytm;
                    } else {
                        high = ytm;
                    }
                }
                return ytm;
            }

            function calculateAll() {
                const fv = parseFloat(document.getElementById('faceValue').value) || 0;
                const cr = parseFloat(document.getElementById('couponRate').value) || 0;
                const price = parseFloat(document.getElementById('currentPrice').value) || 0;
                const ytm_years = parseFloat(document.getElementById('yearsToMaturity').value) || 0;
                const freq = parseInt(document.getElementById('paymentFrequency').value) || 2;

                const isCallable = document.getElementById('enableCallable').checked;
                const callYears = parseFloat(document.getElementById('yearsToCall').value) || 0;
                const callPrice = parseFloat(document.getElementById('callPrice').value) || 0;

                if (fv <= 0 || price <= 0 || ytm_years <= 0) return;

                // Current Yield
                const annualCoupon = fv * (cr / 100);
                const currentYield = (annualCoupon / price) * 100;
                document.getElementById('resCurrentYield').textContent = currentYield.toFixed(2) + '%';
                document.getElementById('resCouponAmt').textContent = '$' + annualCoupon.toFixed(2);

                // YTM
                const ytm = calculateYTM(price, fv, cr, ytm_years, freq);
                document.getElementById('resYTM').textContent = (ytm * 100).toFixed(2) + '%';

                // YTC
                if (isCallable && callYears > 0 && callPrice > 0) {
                    const ytc = calculateYTM(price, fv, cr, callYears, freq, true, callPrice);
                    document.getElementById('resYTC').textContent = (ytc * 100).toFixed(2) + '%';
                }

                // Duration & Convexity
                const r = ytm / freq;
                const c = annualCoupon / freq;
                const periods = ytm_years * freq;

                let macD_sum = 0;
                let conv_sum = 0;

                for (let i = 1; i <= periods; i++) {
                    const t = i / freq;
                    const cf = (i === periods) ? (c + fv) : c;
                    const pv = cf / Math.pow(1 + r, i);

                    macD_sum += t * pv;
                    conv_sum += (t * (t + 1/freq)) * pv;
                }

                const macD = macD_sum / price;
                const modD = macD / (1 + r);
                const convexity = conv_sum / (price * Math.pow(1 + r, 2));

                document.getElementById('resMacD').textContent = macD.toFixed(2) + ' yrs';
                document.getElementById('resModD').textContent = modD.toFixed(2) + '%';
                document.getElementById('resConv').textContent = convexity.toFixed(2);

                drawChart(ytm, fv, cr, ytm_years, freq, price);
                updateTable(ytm, fv, cr, ytm_years, freq, price);
            }

            function drawChart(currentYTM, fv, cr, years, freq, currentPrice) {
                const rect = canvas.parentElement.getBoundingClientRect();
                const dpr = window.devicePixelRatio || 1;
                canvas.width = rect.width * dpr;
                canvas.height = rect.height * dpr;
                ctx.scale(dpr, dpr);

                const w = rect.width;
                const h = rect.height;
                const padding = 40;

                ctx.clearRect(0, 0, w, h);

                // Generate points
                const minYield = Math.max(0.001, currentYTM - 0.05);
                const maxYield = currentYTM + 0.05;
                const points = [];
                let minPrice = Infinity;
                let maxPrice = 0;

                for (let i = 0; i <= 50; i++) {
                    const yld = minYield + (maxYield - minYield) * (i / 50);
                    const p = calculatePrice(yld, fv, cr, years, freq);
                    points.push({y: yld, p: p});
                    if (p < minPrice) minPrice = p;
                    if (p > maxPrice) maxPrice = p;
                }

                // Scales
                const getX = (yld) => padding + ((yld - minYield) / (maxYield - minYield)) * (w - padding * 2);
                const getY = (p) => h - padding - ((p - minPrice) / (maxPrice - minPrice)) * (h - padding * 2);

                // Axes
                ctx.strokeStyle = '#152040';
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.moveTo(padding, padding);
                ctx.lineTo(padding, h - padding);
                ctx.lineTo(w - padding, h - padding);
                ctx.stroke();

                // Labels
                ctx.fillStyle = '#94a3b8';
                ctx.font = '12px Inter';
                ctx.textAlign = 'center';
                ctx.fillText((minYield*100).toFixed(1) + '%', padding, h - padding + 20);
                ctx.fillText((maxYield*100).toFixed(1) + '%', w - padding, h - padding + 20);

                ctx.textAlign = 'right';
                ctx.textBaseline = 'middle';
                ctx.fillText('$' + Math.round(minPrice), padding - 10, h - padding);
                ctx.fillText('$' + Math.round(maxPrice), padding - 10, padding);

                // Curve
                ctx.beginPath();
                ctx.strokeStyle = '#D4A017';
                ctx.lineWidth = 3;
                points.forEach((pt, i) => {
                    if (i === 0) ctx.moveTo(getX(pt.y), getY(pt.p));
                    else ctx.lineTo(getX(pt.y), getY(pt.p));
                });
                ctx.stroke();

                // Current Point
                const cx = getX(currentYTM);
                const cy = getY(currentPrice);
                ctx.beginPath();
                ctx.arc(cx, cy, 6, 0, Math.PI * 2);
                ctx.fillStyle = '#D4A017';
                ctx.fill();
                ctx.strokeStyle = '#060a12';
                ctx.lineWidth = 2;
                ctx.stroke();

                // Point Label
                ctx.fillStyle = '#e2e8f0';
                ctx.textAlign = 'left';
                ctx.fillText('$' + currentPrice.toFixed(2), cx + 10, cy - 10);
            }

            function updateTable(currentYTM, fv, cr, years, freq, currentPrice) {
                const tbody = document.getElementById('pricingTableBody');
                tbody.innerHTML = '';

                // Create steps: -2%, -1%, 0, +1%, +2%
                const steps = [-0.02, -0.01, 0, 0.01, 0.02];

                steps.forEach(step => {
                    const targetYield = Math.max(0.0001, currentYTM + step);
                    const p = calculatePrice(targetYield, fv, cr, years, freq);
                    const diff = p - currentPrice;

                    const tr = document.createElement('tr');
                    if (step === 0) tr.className = 'highlight';

                    const tdYield = document.createElement('td');
                    tdYield.textContent = (targetYield * 100).toFixed(2) + '%';

                    const tdPrice = document.createElement('td');
                    tdPrice.textContent = '$' + p.toFixed(2);

                    const tdDiff = document.createElement('td');
                    if (step === 0) {
                        tdDiff.textContent = '-';
                    } else {
                        const sign = diff > 0 ? '+' : '';
                        tdDiff.textContent = sign + diff.toFixed(2);
                        tdDiff.style.color = diff > 0 ? 'var(--success-color)' : 'var(--error-color)';
                    }

                    tr.appendChild(tdYield);
                    tr.appendChild(tdPrice);
                    tr.appendChild(tdDiff);
                    tbody.appendChild(tr);
                });
            }

            // Initial calculation
            setTimeout(calculateAll, 100);
            window.addEventListener('resize', calculateAll);
        });
  </script>
</SiteLayout>
