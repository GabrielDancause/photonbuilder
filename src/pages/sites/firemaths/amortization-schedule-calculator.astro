  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

window.copyValue = async (id, btn) => {
    const text = document.getElementById(id).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => btn.innerText = orig, 2000);
    } catch(e) {}
};

let amortView = 'monthly';
let amortData = [];
let startDate = null;

// Set default start date to next month's 1st
(function() {
    const now = new Date();
    const nextMonth = new Date(now.getFullYear(), now.getMonth() + 1, 1);
    const dateStr = nextMonth.toISOString().split('T')[0];
    document.getElementById('start-date').value = dateStr;
})();

function getInputs() {
    const loanAmount = parseFloat(document.getElementById('loan-amount').value) || 0;
    const interestRate = parseFloat(document.getElementById('interest-rate').value) || 0;
    const loanTerm = parseInt(document.getElementById('loan-term').value) || 30;
    const extraPayment = parseFloat(document.getElementById('extra-payment').value) || 0;
    const dateVal = document.getElementById('start-date').value;
    startDate = dateVal ? new Date(dateVal + 'T00:00:00') : new Date();
    return { loanAmount, interestRate, loanTerm, extraPayment };
}

function calcMonthlyPayment(principal, annualRate, termYears) {
    if (principal <= 0) return 0;
    if (annualRate <= 0) return principal / (termYears * 12);
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    return principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function buildSchedule(loanAmount, annualRate, termYears, extraMonthly) {
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    const basePayment = calcMonthlyPayment(loanAmount, annualRate, termYears);
    let balance = loanAmount;
    const schedule = [];
    let totalInterest = 0;
    let totalPrincipal = 0;
    let totalExtra = 0;

    for (let month = 1; month <= n && balance > 0.01; month++) {
        const interestPayment = balance * r;
        let principalPayment = basePayment - interestPayment;
        let extra = extraMonthly;

        if (principalPayment + extra > balance) {
            const totalPay = balance;
            extra = Math.max(0, totalPay - principalPayment);
            principalPayment = totalPay - extra;
        }

        balance -= (principalPayment + extra);
        if (balance < 0.01) balance = 0;

        totalInterest += interestPayment;
        totalPrincipal += principalPayment;
        totalExtra += extra;

        // Calculate date
        const payDate = new Date(startDate.getFullYear(), startDate.getMonth() + month, 1);

        schedule.push({
            month,
            date: payDate,
            payment: interestPayment + principalPayment + extra,
            principal: principalPayment,
            interest: interestPayment,
            extra,
            balance,
            totalInterest,
            totalPrincipal,
            totalExtra
        });

        if (balance <= 0) break;
    }

    return schedule;
}

function calculate() {
    const inp = getInputs();
    const { loanAmount, interestRate, loanTerm, extraPayment } = inp;

    const basePayment = calcMonthlyPayment(loanAmount, interestRate, loanTerm);

    // Base schedule (no extra)
    const baseSchedule = buildSchedule(loanAmount, interestRate, loanTerm, 0);
    const baseTotalInterest = baseSchedule.length > 0 ? baseSchedule[baseSchedule.length - 1].totalInterest : 0;

    // Schedule with extra payments
    const extraSchedule = buildSchedule(loanAmount, interestRate, loanTerm, extraPayment);
    const extraTotalInterest = extraSchedule.length > 0 ? extraSchedule[extraSchedule.length - 1].totalInterest : 0;
    const extraTotalExtra = extraSchedule.length > 0 ? extraSchedule[extraSchedule.length - 1].totalExtra : 0;

    const activeSchedule = extraPayment > 0 ? extraSchedule : baseSchedule;
    const activeTotalInterest = extraPayment > 0 ? extraTotalInterest : baseTotalInterest;
    const totalPayments = loanAmount + activeTotalInterest + extraTotalExtra;

    // Monthly payment display
    const displayPayment = basePayment + extraPayment;
    document.getElementById('res-monthly').innerText = fmt(displayPayment);
    document.getElementById('res-total-payments').innerText = fmt(totalPayments);
    document.getElementById('res-total-interest').innerText = fmt(activeTotalInterest);

    // Payoff date
    const formatDate = (d) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

    if (activeSchedule.length > 0) {
        document.getElementById('res-payoff').innerText = formatDate(activeSchedule[activeSchedule.length - 1].date);
    }

    // Extra payment savings
    const savingsSection = document.getElementById('savings-section');
    if (extraPayment > 0 && baseSchedule.length > extraSchedule.length) {
        savingsSection.style.display = 'block';
        const monthsSaved = baseSchedule.length - extraSchedule.length;
        const yearsSaved = Math.floor(monthsSaved / 12);
        const remMonths = monthsSaved % 12;
        const timeSavedStr = yearsSaved > 0 ? yearsSaved + 'yr ' + remMonths + 'mo' : monthsSaved + ' months';
        const interestSaved = baseTotalInterest - extraTotalInterest;

        document.getElementById('res-interest-saved').innerText = fmt(interestSaved);
        document.getElementById('res-time-saved').innerText = timeSavedStr;
        document.getElementById('res-new-payoff').innerText = extraSchedule.length > 0 ? formatDate(extraSchedule[extraSchedule.length - 1].date) : '—';
    } else {
        savingsSection.style.display = 'none';
    }

    // Summary cards
    document.getElementById('sum-principal').innerText = fmt(loanAmount);
    document.getElementById('sum-interest').innerText = fmt(activeTotalInterest);
    document.getElementById('sum-total').innerText = fmt(totalPayments);
    document.getElementById('sum-ratio').innerText = loanAmount > 0 ? (activeTotalInterest / loanAmount * 100).toFixed(1) + '%' : '0%';
    document.getElementById('sum-extra').innerText = fmt(extraTotalExtra);
    document.getElementById('sum-payments').innerText = activeSchedule.length;

    amortData = activeSchedule;
    renderAmortTable();
    drawPayoffChart(activeSchedule);
}

function renderAmortTable() {
    const thead = document.getElementById('amort-thead');
    const tbody = document.getElementById('amort-tbody');
    const formatD = (d) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

    if (amortView === 'monthly') {
        thead.innerHTML = '<tr><th>#</th><th>Date</th><th>Payment</th><th>Principal</th><th>Interest</th><th>Extra</th><th>Balance</th></tr>';
        let html = '';
        for (const row of amortData) {
            html += `<tr><td>${row.month}</td><td style="text-align:left;font-family:var(--font-ui);">${formatD(row.date)}</td><td>${fmt2(row.payment)}</td><td>${fmt2(row.principal)}</td><td>${fmt2(row.interest)}</td><td>${row.extra > 0 ? fmt2(row.extra) : '—'}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    } else {
        thead.innerHTML = '<tr><th>Year</th><th>Total Paid</th><th>Principal</th><th>Interest</th><th>Extra</th><th>End Balance</th></tr>';
        const yearly = [];
        let yPay = 0, yPrin = 0, yInt = 0, yExtra = 0, yEnd = 0;
        for (const row of amortData) {
            yPay += row.payment;
            yPrin += row.principal;
            yInt += row.interest;
            yExtra += row.extra;
            yEnd = row.balance;
            if (row.month % 12 === 0 || row === amortData[amortData.length - 1]) {
                yearly.push({ year: Math.ceil(row.month / 12), payment: yPay, principal: yPrin, interest: yInt, extra: yExtra, balance: yEnd });
                yPay = 0; yPrin = 0; yInt = 0; yExtra = 0;
            }
        }
        let html = '';
        for (const row of yearly) {
            html += `<tr><td>${row.year}</td><td>${fmt(row.payment)}</td><td>${fmt(row.principal)}</td><td>${fmt(row.interest)}</td><td>${row.extra > 0 ? fmt(row.extra) : '—'}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    }
}

window.setAmortView = (view) => {
    amortView = view;
    document.getElementById('btn-monthly').classList.toggle('active', view === 'monthly');
    document.getElementById('btn-yearly').classList.toggle('active', view === 'yearly');
    renderAmortTable();
};

function drawPayoffChart(schedule) {
    const canvas = document.getElementById('payoffChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    canvas.width = w * dpr;
    canvas.height = h * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, w, h);

    if (schedule.length === 0) return;

    // Build yearly data for cleaner chart
    const yearlyData = [];
    let yPrin = 0, yInt = 0;
    for (const row of schedule) {
        yPrin += row.principal + row.extra;
        yInt += row.interest;
        if (row.month % 12 === 0 || row === schedule[schedule.length - 1]) {
            yearlyData.push({ year: Math.ceil(row.month / 12), principal: yPrin, interest: yInt, balance: row.balance });
            yPrin = 0; yInt = 0;
        }
    }

    const padding = { top: 30, right: 20, bottom: 40, left: 65 };
    const chartW = w - padding.left - padding.right;
    const chartH = h - padding.top - padding.bottom;

    // Find max values
    const maxPayment = Math.max(...yearlyData.map(d => d.principal + d.interest));
    const maxBalance = schedule[0].balance + schedule[0].interest;
    const maxY = Math.max(maxPayment, maxBalance) * 1.1;

    const barW = Math.max(4, (chartW / yearlyData.length) - 3);

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    const gridLines = 5;
    for (let i = 0; i <= gridLines; i++) {
        const y = padding.top + (chartH / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();

        // Y-axis labels
        const val = maxY - (maxY / gridLines) * i;
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        if (val >= 1000) {
            ctx.fillText('$' + Math.round(val / 1000) + 'k', padding.left - 8, y);
        } else {
            ctx.fillText('$' + Math.round(val), padding.left - 8, y);
        }
    }

    // Stacked bars: principal (bottom) + interest (top)
    for (let i = 0; i < yearlyData.length; i++) {
        const d = yearlyData[i];
        const x = padding.left + (i / yearlyData.length) * chartW + ((chartW / yearlyData.length) - barW) / 2;
        const prinH = (d.principal / maxY) * chartH;
        const intH = (d.interest / maxY) * chartH;

        // Principal bar
        ctx.fillStyle = '#4A90E2';
        ctx.fillRect(x, padding.top + chartH - prinH - intH, barW, prinH);

        // Interest bar
        ctx.fillStyle = '#E25C5C';
        ctx.fillRect(x, padding.top + chartH - intH, barW, intH);

        // X-axis labels (every few years)
        const step = yearlyData.length > 20 ? 5 : yearlyData.length > 10 ? 2 : 1;
        if (d.year % step === 0 || d.year === 1) {
            ctx.fillStyle = '#888888';
            ctx.font = '11px Inter, sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'top';
            ctx.fillText('Yr ' + d.year, x + barW / 2, padding.top + chartH + 8);
        }
    }

    // Balance line
    ctx.beginPath();
    ctx.strokeStyle = '#D4A017';
    ctx.lineWidth = 2.5;
    for (let i = 0; i < yearlyData.length; i++) {
        const d = yearlyData[i];
        const x = padding.left + (i / yearlyData.length) * chartW + (chartW / yearlyData.length) / 2;
        const y = padding.top + chartH - (d.balance / maxY) * chartH;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
    }
    ctx.stroke();
}

window.exportCSV = () => {
    if (amortData.length === 0) return;

    const formatD = (d) => d.toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: 'numeric' });
    let csv = 'Payment #,Date,Payment,Principal,Interest,Extra Payment,Remaining Balance\n';
    for (const row of amortData) {
        csv += `${row.month},${formatD(row.date)},${row.payment.toFixed(2)},${row.principal.toFixed(2)},${row.interest.toFixed(2)},${row.extra.toFixed(2)},${row.balance.toFixed(2)}\n`;
    }

    const blob = new Blob([csv], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'amortization-schedule.csv';
    a.click();
    URL.revokeObjectURL(url);
};

// Attach listeners
const allInputs = ['loan-amount', 'interest-rate', 'loan-term', 'start-date', 'extra-payment'];
allInputs.forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
});

window.addEventListener('resize', () => {
    if (amortData.length > 0) drawPayoffChart(amortData);
});

setTimeout(calculate, 0);
  </script>

