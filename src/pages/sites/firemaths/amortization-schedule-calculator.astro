    color: var(--text-primary);
}

.amort-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

.extra-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

@media (min-width: 768px) {
    .extra-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

@media (min-width: 768px) {
    .summary-grid {
        grid-template-columns: 1fr 1fr 1fr;
    }
}

.summary-item {
    padding: 1rem;
    background: var(--bg-color);
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.summary-item-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.summary-item-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--accent-color);
}

.summary-item-value.green {
    color: var(--color-extra);
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.25rem 0;
}

.faq-question {
    font-weight: 600;
