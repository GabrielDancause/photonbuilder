---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Capital Gains Tax Calculator",
  "url": "https://firemaths.info/capital-gains",
  "description": "Calculate your short-term and long-term capital gains tax on stocks, crypto, and real estate.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Capital Gains Tax Calculator | firemaths.info"
  description="Calculate your short-term and long-term capital gains tax on stocks, crypto, and real estate based on 2024 US tax brackets."
  canonical="https://firemaths.info/capital-gains" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <!-- Input Section -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Asset Details</h2>
                </div>

                <div class="inputs">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="purchase-price">Purchase Price</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="purchase-price" value="10000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="sale-price">Sale Price</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="sale-price" value="15000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="holding-period">Holding Period</label>
                        <div class="relative flex items-center">
                            <select id="holding-period" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                                <option value="long">Long-term (Over 1 year)</option>
                                <option value="short">Short-term (1 year or less)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-5" style="margin-top: 2rem;">
                        <label for="filing-status">Filing Status</label>
                        <div class="relative flex items-center">
                            <select id="filing-status" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                                <option value="single">Single</option>
                                <option value="married">Married Filing Jointly</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="ordinary-income">Annual Ordinary Income</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="ordinary-income" value="80000" min="0" step="1000" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Total Capital Gain</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="capital-gain">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-8 pb-6 border-b border-[var(--border-color)]">
                        <span class="text-[var(--text-secondary)] text-base font-medium">Estimated Tax</span>
                        <div class="font-mono text-2xl md:text-3xl font-bold text-[var(--accent-color)] flex items-center gap-3">
                            <span id="estimated-tax">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('estimated-tax', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Net Profit After Tax</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="net-profit">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">Effective Tax Rate (on gain)</span>
                        <span class="font-mono text-lg font-medium flex items-center gap-2 text-white" id="effective-rate">0%</span>
                    </div>
                </div>
            </div>

            <!-- Breakdown Section -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Tax Breakdown on Gain</h2>
                </div>

                <div style="overflow-x: auto;">
                    <table class="bracket-table">
                        <thead class="bg-[var(--card-bg)] border-b border-[var(--border-color)]">
                            <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Tax Rate</th>
                                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Bracket Range</th>
                                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Gain in Bracket</th>
                                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Tax Owed</th>
                            </tr>
                        </thead>
                        <tbody id="bracket-body">
                            <!-- Filled via JS -->
                        </tbody>
                    </table>
                </div>

                <p style="margin-top: 1.5rem; font-size: 0.875rem; color: var(--text-secondary); line-height: 1.5;">
                    Your capital gain is added to your regular income to determine which tax brackets it falls into. The table above shows how your gain is distributed across the applicable tax brackets.
                </p>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Understanding Capital Gains Tax</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When you sell an asset—such as stocks, cryptocurrencies, or real estate—for more than you paid for it, the profit is known as a capital gain. The US government taxes this profit, but the rate you pay depends heavily on how long you owned the asset before selling it.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Short-Term vs. Long-Term Capital Gains</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The holding period of your asset determines the tax brackets used:</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>Short-Term Capital Gains:</strong> If you hold an asset for one year or less before selling, the profits are considered short-term gains. These are taxed at your ordinary income tax rates (which range from 10% to 37% for 2024).</li>
                <li><strong>Long-Term Capital Gains:</strong> If you hold an asset for more than one year, you benefit from lower long-term capital gains tax rates (0%, 15%, or 20% for 2024).</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">How Your Income Affects Your Capital Gains Rate</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Your capital gains are "stacked" on top of your ordinary income. This means your regular annual income dictates your starting tax bracket for your capital gains.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">For example, if you are a Single filer earning $40,000 a year in ordinary income, you fall into the 0% long-term capital gains bracket (which goes up to $47,025 for 2024). If you have a $10,000 long-term capital gain, the first $7,025 is taxed at 0%, and the remaining $2,975 spills over into the 15% bracket.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Using This Calculator</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Our calculator automatically segments your capital gain into the correct 2024 tax brackets. Enter your purchase and sale prices, select your holding period, and provide your estimated annual income. The calculator will detail exactly how much tax you owe on your profit and what your final take-home amount will be.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><em>Note: This tool provides federal estimates only. It does not include state capital gains taxes or the Net Investment Income Tax (NIIT).</em></p>
        </div>

    </main>

    
</div>
  <script is:inline>
// 2024 US Federal Tax Brackets (Short-term / Ordinary Income)
    const ordinaryBrackets = {
        single: [
            { rate: 0.10, max: 11600 },
            { rate: 0.12, max: 47150 },
            { rate: 0.22, max: 100525 },
            { rate: 0.24, max: 191950 },
            { rate: 0.32, max: 243725 },
            { rate: 0.35, max: 609350 },
            { rate: 0.37, max: Infinity }
        ],
        married: [
            { rate: 0.10, max: 23200 },
            { rate: 0.12, max: 94300 },
            { rate: 0.22, max: 201050 },
            { rate: 0.24, max: 383900 },
            { rate: 0.32, max: 487450 },
            { rate: 0.35, max: 731200 },
            { rate: 0.37, max: Infinity }
        ]
    };

    // 2024 Long-Term Capital Gains Tax Brackets
    const longTermBrackets = {
        single: [
            { rate: 0.00, max: 47025 },
            { rate: 0.15, max: 518900 },
            { rate: 0.20, max: Infinity }
        ],
        married: [
            { rate: 0.00, max: 94050 },
            { rate: 0.15, max: 583750 },
            { rate: 0.20, max: Infinity }
        ]
    };

    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    const formatPercent = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'percent',
            minimumFractionDigits: 1,
            maximumFractionDigits: 2
        }).format(value);
    };

    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const updateCalculator = () => {
        const purchasePrice = parseFloat(document.getElementById('purchase-price').value) || 0;
        const salePrice = parseFloat(document.getElementById('sale-price').value) || 0;
        const ordinaryIncome = parseFloat(document.getElementById('ordinary-income').value) || 0;
        const filingStatus = document.getElementById('filing-status').value;
        const holdingPeriod = document.getElementById('holding-period').value;

        const capitalGain = Math.max(0, salePrice - purchasePrice);

        let brackets;
        if (holdingPeriod === 'long') {
            brackets = longTermBrackets[filingStatus];
        } else {
            brackets = ordinaryBrackets[filingStatus];
        }

        let remainingGain = capitalGain;
        let baseIncome = ordinaryIncome;
        let totalTax = 0;
        let previousMax = 0;

        const breakdownHTML = [];

        for (let i = 0; i < brackets.length; i++) {
            const bracket = brackets[i];
            const rate = bracket.rate;
            const max = bracket.max;

            // Determine if the user's base income puts them past this bracket entirely
            if (baseIncome >= max) {
                previousMax = max;
                continue;
            }

            // The space available in this bracket on top of the base income
            const spaceInBracket = max === Infinity ? Infinity : max - Math.max(baseIncome, previousMax);

            // How much of the remaining gain falls into this bracket
            const gainInBracket = Math.min(remainingGain, spaceInBracket);

            if (gainInBracket > 0) {
                const taxForBracket = gainInBracket * rate;
                totalTax += taxForBracket;

                const rangeText = max === Infinity
                    ? `Over ${formatCurrency(previousMax)}`
                    : `${formatCurrency(previousMax)} - ${formatCurrency(max)}`;

                breakdownHTML.push(`
                    <tr class="active">
                        <td class="p-4 text-white font-mono">${(rate * 100).toFixed(0)}%</td>
                        <td class="p-4 text-white font-mono">${rangeText}</td>
                        <td class="p-4 text-white font-mono">${formatCurrency(gainInBracket)}</td>
                        <td class="p-4 text-white font-mono">${formatCurrency(taxForBracket)}</td>
                    </tr>
                `);
            } else if (remainingGain === 0 && capitalGain === 0 && breakdownHTML.length === 0 && i === 0) {
                // If there's no gain at all, just show the first applicable bracket as $0
                const rangeText = max === Infinity
                    ? `Over ${formatCurrency(previousMax)}`
                    : `${formatCurrency(previousMax)} - ${formatCurrency(max)}`;

                breakdownHTML.push(`
                    <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
                        <td class="p-4 text-white font-mono">${(rate * 100).toFixed(0)}%</td>
                        <td class="p-4 text-white font-mono">${rangeText}</td>
                        <td class="p-4 text-white font-mono">$0</td>
                        <td class="p-4 text-white font-mono">$0</td>
                    </tr>
                `);
            }

            remainingGain -= gainInBracket;
            previousMax = max;
            baseIncome = Math.max(baseIncome, max); // Move base income up to the end of the bracket

            if (remainingGain <= 0 && capitalGain > 0) {
                break; // We've taxed all the gain
            }
        }

        const effectiveRate = capitalGain > 0 ? totalTax / capitalGain : 0;
        const netProfit = capitalGain - totalTax;

        // Update UI
        document.getElementById('capital-gain').innerText = formatCurrency(capitalGain);
        document.getElementById('estimated-tax').innerText = formatCurrency(totalTax);
        document.getElementById('net-profit').innerText = formatCurrency(netProfit);
        document.getElementById('effective-rate').innerText = formatPercent(effectiveRate);
        document.getElementById('bracket-body').innerHTML = breakdownHTML.join('');
    };

    // Event listeners
    const inputs = ['purchase-price', 'sale-price', 'holding-period', 'filing-status', 'ordinary-income'];
    inputs.forEach(id => {
        document.getElementById(id).addEventListener('input', updateCalculator);
        document.getElementById(id).addEventListener('change', updateCalculator);
    });

    // Initial calc
    updateCalculator();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-taxes-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Understanding Your Taxes: A Complete Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
