---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Present Value Calculator",
  "url": "https://firemaths.info/present-value",
  "description": "Calculate the present value of future cash flows, single amounts, and annuities.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Present Value Calculator | firemaths.info"
  description="Calculate the present value of future cash flows, including single amounts and annuities, based on your expected discount rate."
  canonical="https://firemaths.info/present-value" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Single Amount -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm" id="card-single">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[var(--chart-color-a,var(--accent-color))] inline-block mr-2"></span> Single Amount</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="fv-single">Future Value</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="fv-single" value="10000" min="0" step="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="rate-single">Discount Rate (Annual)</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">%</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="rate-single" value="5" min="0" step="0.1" max="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="years-single">Years</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="years-single" value="10" min="1" max="100" step="1">
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Present Value</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="pv-single-result">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('pv-single-result', this)">Copy</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Annuity -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm" id="card-annuity">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-[#4A90E2] inline-block mr-2"></span> Annuity</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="pmt-annuity">Periodic Payment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="pmt-annuity" value="1000" min="0" step="50">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="freq-annuity">Payment Frequency</label>
                        <div class="relative flex items-center">
                            <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="freq-annuity">
                                <option value="1">Annually</option>
                                <option value="2">Semi-Annually</option>
                                <option value="4">Quarterly</option>
                                <option value="12" selected>Monthly</option>
                            </select>
                            <span class="absolute right-4 text-[var(--text-secondary)] pointer-events-none">▼</span>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="rate-annuity">Discount Rate (Annual)</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">%</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="rate-annuity" value="5" min="0" step="0.1" max="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="years-annuity">Years</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="years-annuity" value="10" min="1" max="100" step="1">
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Present Value</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="pv-annuity-result">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('pv-annuity-result', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Payments</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="total-pmt-annuity">$0</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">What is Present Value?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Present value (PV) is the current value of a future sum of money or stream of cash flows given a specified rate of return. Future cash flows are discounted at the discount rate; the higher the discount rate, the lower the present value of the future cash flows. Determining the appropriate discount rate is the key to properly valuing future cash flows, whether they be earnings or debt obligations.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Single Amount vs. Annuity</h2>
            <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc space-y-2">
                <li><strong>Single Amount:</strong> A one-time lump sum received or paid at a future date. The present value calculates what that single future amount is worth in today's dollars.</li>
                <li><strong>Annuity:</strong> A series of equal payments made at regular intervals over a period of time. The present value of an annuity calculates the current value of all those future payments combined.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding the Discount Rate</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The discount rate represents the time value of money. It is the rate of return you could earn on an investment with similar risk. Because money today can be invested to earn a return, a dollar received today is worth more than a dollar received in the future. The discount rate reflects this opportunity cost.</p>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 2
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const updateCalculator = () => {
        // Single Amount Calculation
        const fvSingle = parseFloat(document.getElementById('fv-single').value) || 0;
        const rateSingle = parseFloat(document.getElementById('rate-single').value) || 0;
        const yearsSingle = parseFloat(document.getElementById('years-single').value) || 0;

        const rSingle = rateSingle / 100;
        let pvSingle = 0;
        if (rSingle === 0) {
            pvSingle = fvSingle;
        } else {
            pvSingle = fvSingle / Math.pow(1 + rSingle, yearsSingle);
        }
        document.getElementById('pv-single-result').innerText = formatCurrency(pvSingle);

        // Annuity Calculation
        const pmtAnnuity = parseFloat(document.getElementById('pmt-annuity').value) || 0;
        const freqAnnuity = parseInt(document.getElementById('freq-annuity').value) || 1;
        const rateAnnuity = parseFloat(document.getElementById('rate-annuity').value) || 0;
        const yearsAnnuity = parseFloat(document.getElementById('years-annuity').value) || 0;

        const totalPeriods = yearsAnnuity * freqAnnuity;
        const rAnnuity = (rateAnnuity / 100) / freqAnnuity;

        let pvAnnuity = 0;
        if (rAnnuity === 0) {
            pvAnnuity = pmtAnnuity * totalPeriods;
        } else {
            pvAnnuity = pmtAnnuity * ((1 - Math.pow(1 + rAnnuity, -totalPeriods)) / rAnnuity);
        }

        const totalPmt = pmtAnnuity * totalPeriods;

        document.getElementById('pv-annuity-result').innerText = formatCurrency(pvAnnuity);
        document.getElementById('total-pmt-annuity').innerText = formatCurrency(totalPmt);
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"], select');
    inputs.forEach(input => {
        input.addEventListener('input', updateCalculator);
        input.addEventListener('change', updateCalculator);
    });

    // Initial calculation
    updateCalculator();
  </script>
</SiteLayout>
