---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Reverse Mortgage Calculator",
  "url": "https://firemaths.info/reverse-mortgage-calculator",
  "description": "Estimate reverse mortgage proceeds based on home value, age, interest rates, and existing mortgage balance. Compare lump sum, monthly, and line of credit payout options.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a reverse mortgage and how does it work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A reverse mortgage (most commonly a Home Equity Conversion Mortgage or HECM) allows homeowners aged 62 or older to convert part of their home equity into cash without selling the home or making monthly mortgage payments. Instead, the lender pays you — as a lump sum, monthly payments, or a line of credit. The loan balance grows over time as interest accrues and is repaid when the borrower sells, moves out, or passes away."
      }
    },
    {
      "@type": "Question",
      "name": "How much money can I get from a reverse mortgage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The amount depends on your age, home value, current interest rates, and the HECM lending limit ($1,149,825 in 2024). Generally, older borrowers with more valuable homes and lower interest rates receive higher proceeds. The principal limit factor (PLF) determines the percentage of your home's value you can access, typically ranging from 40% to 75%. Any existing mortgage must be paid off first from the proceeds."
      }
    },
    {
      "@type": "Question",
      "name": "What are the different reverse mortgage payout options?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "HECM reverse mortgages offer several payout options: (1) Lump sum — receive all proceeds at once at a fixed rate; (2) Tenure — equal monthly payments for as long as you live in the home; (3) Term — equal monthly payments for a fixed period; (4) Line of credit — draw funds as needed, with the unused portion growing over time; (5) Modified tenure/term — a combination of monthly payments and a line of credit."
      }
    },
    {
      "@type": "Question",
      "name": "Can I owe more than my home is worth with a reverse mortgage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. HECM reverse mortgages are 'non-recourse' loans, meaning you (or your heirs) will never owe more than the home's appraised value at the time of repayment, even if the loan balance exceeds the home's value. FHA mortgage insurance covers the difference. This protection is one of the key features of government-insured reverse mortgages."
      }
    },
    {
      "@type": "Question",
      "name": "What are the costs and fees associated with a reverse mortgage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Reverse mortgage costs include: an origination fee (up to $6,000), FHA mortgage insurance premium (2% upfront plus 0.5% annually), closing costs (appraisal, title search, inspections), and ongoing interest charges. The upfront MIP and origination fee can typically be financed into the loan. Total upfront costs often range from 3-5% of the home's value, which reduces the net proceeds available to the borrower."
      }
    }
  ]
};

export const meta = {
  title: "Reverse Mortgage Calculator | firemaths.info",
  description: "Free reverse mortgage calculator — estimate your proceeds based on home value, age, and interest rates. Compare lump sum, monthly, and line of credit payout options with equity projection tables.",
  category: "tool",
  published: "2026-03-21",
};
