      ))}
    </section>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script>
    const $ = (id) => document.getElementById(id);
    const fmt = (n) => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const pct = (n) => n.toFixed(1) + '%';

    const HECM_LIMIT = 1149825;
    const UPFRONT_MIP_RATE = 0.02;
    const ANNUAL_MIP_RATE = 0.005;

    // Approximate PLF based on age and expected rate
    // Real PLFs come from HUD tables; this is a reasonable approximation
    function getPLF(age, expectedRate) {
      const ageFactor = 0.42 + (age - 62) * 0.013;
      const rateFactor = 1 - (expectedRate - 5) * 0.03;
      let plf = ageFactor * rateFactor;
      return Math.max(0.10, Math.min(0.75, plf));
    }

    function calculate() {
      const homeValue = parseFloat($('homeValue').value) || 0;
      const existingMortgage = parseFloat($('existingMortgage').value) || 0;
      const age = parseInt($('borrowerAge').value) || 70;
      const interestRate = parseFloat($('interestRate').value) || 6.5;
      const appreciationRate = parseFloat($('appreciationRate').value) || 3;
      const projectionYears = parseInt($('projectionYears').value) || 15;
      const closingCostPct = parseFloat($('closingCostPct').value) || 3;

      const clampedAge = Math.max(62, Math.min(100, age));
      const expectedRate = interestRate;

      // Max claim amount (lesser of home value or HECM limit)
      const maxClaim = Math.min(homeValue, HECM_LIMIT);
      const plf = getPLF(clampedAge, expectedRate);

      // Gross principal limit
      const grossPL = maxClaim * plf;

      // Deductions from proceeds
      const upfrontMIP = maxClaim * UPFRONT_MIP_RATE;
      const closingCosts = homeValue * (closingCostPct / 100);
      const totalDeductions = existingMortgage + upfrontMIP + closingCosts;

      // Net available to borrower
      const netAvailable = Math.max(0, grossPL - totalDeductions);

      // Display summary results
      $('lendingLimit').textContent = fmt(maxClaim);
      $('plfDisplay').textContent = (plf * 100).toFixed(1) + '%';
      $('grossPrincipal').textContent = fmt(grossPL);
      $('netEquity').textContent = fmt(netAvailable);

      // --- Payout Options ---

      // Lump sum: HECM limits first-year draw to 60% of principal limit
      const maxFirstYear = grossPL * 0.6;
      const lumpSumNet = Math.max(0, Math.min(netAvailable, maxFirstYear - totalDeductions));

      // Monthly tenure: annuity payment over life expectancy
      const monthlyRate = interestRate / 100 / 12;
      const lifeExpectancy = Math.max(1, 100 - clampedAge);
      const tenureMonths = lifeExpectancy * 12;
      let monthlyPayment = 0;
      if (monthlyRate > 0 && netAvailable > 0) {
        monthlyPayment = (netAvailable * monthlyRate) / (1 - Math.pow(1 + monthlyRate, -tenureMonths));
      } else if (netAvailable > 0) {
        monthlyPayment = netAvailable / tenureMonths;
      }

      // Line of credit: unused portion grows at interest rate + MIP
      const locGrowthRate = interestRate / 100 + ANNUAL_MIP_RATE;
      const locAfter10 = netAvailable * Math.pow(1 + locGrowthRate, 10);

      // Update payout display
      $('lumpSum').textContent = fmt(lumpSumNet);
      const compoundRate = interestRate / 100 + ANNUAL_MIP_RATE;
      const lumpBalance1yr = lumpSumNet * (1 + compoundRate);
      $('lumpBalance').textContent = 'Balance after 1 yr: ' + fmt(lumpBalance1yr);
      const totalLumpInterest = lumpSumNet * Math.pow(1 + compoundRate, projectionYears) - lumpSumNet;
      $('lumpInterest').textContent = 'Total interest (' + projectionYears + ' yrs): ' + fmt(totalLumpInterest);

      $('monthlyTenure').textContent = fmt(monthlyPayment);
      const projMonths = Math.min(tenureMonths, projectionYears * 12);
      $('tenureTotal').textContent = 'Projected total (' + projectionYears + ' yrs): ' + fmt(monthlyPayment * projMonths);

      $('locInitial').textContent = fmt(netAvailable);
      $('locGrown').textContent = 'After 10 yrs unused: ' + fmt(locAfter10);

      // --- Amortization table (lump sum scenario) ---
      const tbody = $('amortBody');
      tbody.innerHTML = '';
      const annualRate = interestRate / 100;

      // Initial loan balance = lump sum drawn + financed costs (MIP, closing, existing mortgage payoff)
      let loanBalance = lumpSumNet + totalDeductions;
      let currentHomeValue = homeValue;
      const tableData = [];

      for (let yr = 0; yr <= projectionYears; yr++) {
        const equity = currentHomeValue - loanBalance;
        const equityPctVal = currentHomeValue > 0 ? (equity / currentHomeValue) * 100 : 0;
        const yearInterest = yr === 0 ? 0 : loanBalance * annualRate;
        const yearMIP = yr === 0 ? 0 : loanBalance * ANNUAL_MIP_RATE;

        tableData.push({
          year: yr,
          age: clampedAge + yr,
          homeValue: currentHomeValue,
          loanBalance: loanBalance,
          interest: yearInterest,
          mip: yearMIP,
          equity: equity,
          equityPct: equityPctVal
        });

        const tr = document.createElement('tr');
        const eqClass = equity >= 0 ? 'equity-positive' : 'equity-negative';
        tr.innerHTML =
          '<td>' + yr + '</td>' +
          '<td>' + (clampedAge + yr) + '</td>' +
          '<td>' + fmt(currentHomeValue) + '</td>' +
          '<td>' + fmt(loanBalance) + '</td>' +
          '<td>' + (yr === 0 ? '—' : fmt(yearInterest)) + '</td>' +
          '<td>' + (yr === 0 ? '—' : fmt(yearMIP)) + '</td>' +
          '<td class="' + eqClass + '">' + fmt(equity) + '</td>' +
          '<td class="' + eqClass + '">' + pct(equityPctVal) + '</td>';
        tbody.appendChild(tr);

        // Advance to next year
        if (yr < projectionYears) {
          loanBalance = loanBalance * (1 + annualRate + ANNUAL_MIP_RATE);
          currentHomeValue = currentHomeValue * (1 + appreciationRate / 100);
        }
      }

      drawChart(tableData);
    }

    function drawChart(data) {
      const canvas = $('equityChart');
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();

      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);

      const W = rect.width;
      const H = rect.height;
      const pad = { top: 30, right: 20, bottom: 40, left: 70 };
      const plotW = W - pad.left - pad.right;
      const plotH = H - pad.top - pad.bottom;

      ctx.clearRect(0, 0, W, H);

      if (data.length < 2) return;

      // Find value range
      let maxVal = 0;
      let minVal = 0;
      data.forEach(function(d) {
        maxVal = Math.max(maxVal, d.homeValue, d.loanBalance);
        minVal = Math.min(minVal, d.equity);
      });
      const range = maxVal - minVal;
      const yMax = maxVal + range * 0.1;
      const yMin = Math.min(0, minVal - range * 0.1);
      const yRange = yMax - yMin || 1;

      function toX(i) { return pad.left + (i / (data.length - 1)) * plotW; }
      function toY(v) { return pad.top + (1 - (v - yMin) / yRange) * plotH; }

      // Grid lines and Y-axis labels
      ctx.strokeStyle = 'rgba(128,128,128,0.15)';
      ctx.lineWidth = 1;
      var gridLines = 5;
      for (var i = 0; i <= gridLines; i++) {
        var v = yMin + (yRange * i) / gridLines;
        var y = toY(v);
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(W - pad.right, y);
        ctx.stroke();

        ctx.fillStyle = 'rgba(128,128,128,0.6)';
        ctx.font = '11px system-ui';
        ctx.textAlign = 'right';
        var label = Math.abs(v) >= 1000 ? '$' + (v / 1000).toFixed(0) + 'k' : '$' + v.toFixed(0);
        ctx.fillText(label, pad.left - 8, y + 4);
      }

      // X-axis labels
      ctx.textAlign = 'center';
      var step = Math.max(1, Math.floor(data.length / 8));
      for (var i = 0; i < data.length; i += step) {
        ctx.fillStyle = 'rgba(128,128,128,0.6)';
        ctx.fillText('Yr ' + data[i].year, toX(i), H - pad.bottom + 20);
      }
      if ((data.length - 1) % step !== 0) {
        ctx.fillText('Yr ' + data[data.length - 1].year, toX(data.length - 1), H - pad.bottom + 20);
      }

      // Zero line
      if (yMin < 0) {
        ctx.strokeStyle = 'rgba(128,128,128,0.4)';
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 4]);
        ctx.beginPath();
        ctx.moveTo(pad.left, toY(0));
        ctx.lineTo(W - pad.right, toY(0));
        ctx.stroke();
        ctx.setLineDash([]);
      }

      // Draw data lines
      function drawLine(key, color, width) {
        ctx.strokeStyle = color;
        ctx.lineWidth = width;
        ctx.beginPath();
        data.forEach(function(d, i) {
          var x = toX(i);
          var y = toY(d[key]);
          if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        });
        ctx.stroke();
      }

      drawLine('homeValue', '#D4A017', 2.5);
      drawLine('loanBalance', '#4A90E2', 2.5);
      drawLine('equity', '#50E3C2', 2.5);

      // Fill equity area with transparency
      ctx.globalAlpha = 0.08;
      ctx.fillStyle = '#50E3C2';
      ctx.beginPath();
      ctx.moveTo(toX(0), toY(0));
      data.forEach(function(d, i) { ctx.lineTo(toX(i), toY(d.equity)); });
      ctx.lineTo(toX(data.length - 1), toY(0));
      ctx.closePath();
      ctx.fill();
      ctx.globalAlpha = 1;
    }

    // Wire up all inputs
    document.querySelectorAll('input').forEach(function(input) {
      input.addEventListener('input', calculate);
    });

    calculate();
    window.addEventListener('resize', calculate);
  </script>
</SiteLayout>
