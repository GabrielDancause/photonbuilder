---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Emergency Fund Calculator",
  "url": "https://firemaths.info/emergency-fund",
  "description": "Calculate your ideal emergency fund based on your monthly expenses, job stability, and dependents.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Emergency Fund Calculator | firemaths.info"
  description="Calculate your ideal emergency fund based on your monthly expenses, job stability, and dependents. Plan for 3, 6, or 12 months of runway."
  canonical="https://firemaths.info/emergency-fund" schema={schema}
>


<div class="max-w-4xl mx-auto px-5 py-12 text-white">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Your Details</h2>
                </div>

                <div class="inputs">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="monthly-expenses">Monthly Living Expenses</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="monthly-expenses" value="3000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="job-stability">Job Stability</label>
                        <select id="job-stability" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                            <option value="high">High (Secure industry, tenured role)</option>
                            <option value="medium" selected>Medium (Standard corporate role)</option>
                            <option value="low">Low (Freelance, volatile industry, startup)</option>
                        </select>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="dependents">Number of Dependents</label>
                        <select id="dependents" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                            <option value="0">0 (Single, no dependents)</option>
                            <option value="1" selected>1+ (Children, spouse, or other dependents)</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">Your Targets</h2>
                </div>

                <div class="result-recommended">
                    <span class="text-[var(--text-secondary)] text-sm font-medium">Recommended Target (<span id="rec-months">6</span> Months)</span>
                    <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                        <span id="rec-amount">$0</span>
                        <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('rec-amount', this)">Copy</button>
                    </div>
                    <div class="recommendation-note" id="rec-note">Based on medium job stability and having dependents.</div>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)] flex flex-col h-full">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">3 Months (Minimum)</span>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                            <span id="target-3">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('target-3', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">6 Months (Standard)</span>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                            <span id="target-6">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('target-6', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-[var(--text-secondary)] text-sm font-medium">12 Months (Conservative)</span>
                        <div class="font-mono text-lg font-medium flex items-center gap-2 text-white">
                            <span id="target-12">$0</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] cursor-pointer py-1 px-2 rounded text-xs font-sans transition-colors hover:border-[var(--accent-color)] hover:text-white" onclick="copyValue('target-12', this)">Copy</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-12 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Why Do You Need an Emergency Fund?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">An emergency fund is a stash of money set aside to cover the financial surprises life throws your way. These unexpected events can be stressful and costly. Examples include:</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li>Job loss or sudden reduction in income</li>
                <li>Medical or dental emergencies</li>
                <li>Unexpected home repairs (e.g., a broken AC or leaky roof)</li>
                <li>Major car repairs</li>
            </ul>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Without an emergency fund, a financial shock can push you into high-interest debt, such as credit card balances or personal loans, which can set back your long-term financial goals like achieving FIRE (Financial Independence, Retire Early).</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">How Much Should You Save?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The standard rule of thumb is to save enough to cover <strong>3 to 6 months of essential living expenses</strong>. However, the exact amount depends on your personal risk profile:</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>3 Months:</strong> Best for single individuals with highly stable jobs (e.g., tenured teachers, healthcare workers) and low living expenses.</li>
                <li><strong>6 Months:</strong> The sweet spot for most people. Recommended for those with a typical corporate job, single-income families, or individuals with dependents.</li>
                <li><strong>12 Months:</strong> Ideal for freelancers, contractors, those working in volatile industries (like early-stage startups), or those nearing retirement who want extra peace of mind.</li>
            </ul>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4">Where Should You Keep Your Emergency Fund?</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Your emergency fund must be <strong>liquid</strong> and <strong>safe</strong>. It should not be invested in the stock market or locked away in retirement accounts. The best places to keep your emergency fund include:</p>
            <ul class="list-disc pl-5 mb-6 text-[var(--text-secondary)] space-y-2">
                <li><strong>High-Yield Savings Accounts (HYSA):</strong> These accounts offer significantly higher interest rates than traditional savings accounts while keeping your money easily accessible and FDIC insured.</li>
                <li><strong>Money Market Accounts:</strong> Similar to HYSAs, these accounts often provide higher interest rates and may come with debit cards or check-writing privileges.</li>
                <li><strong>No-Penalty Certificates of Deposit (CDs):</strong> These allow you to lock in a guaranteed interest rate without paying a fee if you need to withdraw your money early.</li>
            </ul>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    const updateCalculator = () => {
        const expenses = parseFloat(document.getElementById('monthly-expenses').value) || 0;
        const jobStability = document.getElementById('job-stability').value;
        const dependents = document.getElementById('dependents').value;

        // Calculate standard targets
        const target3 = expenses * 3;
        const target6 = expenses * 6;
        const target12 = expenses * 12;

        document.getElementById('target-3').innerText = formatCurrency(target3);
        document.getElementById('target-6').innerText = formatCurrency(target6);
        document.getElementById('target-12').innerText = formatCurrency(target12);

        // Calculate recommended months
        let recMonths = 3; // Base
        let noteParts = [];

        if (jobStability === 'high') {
            noteParts.push("high job stability");
        } else if (jobStability === 'medium') {
            recMonths += 3;
            noteParts.push("medium job stability");
        } else if (jobStability === 'low') {
            recMonths += 6;
            noteParts.push("low job stability (higher risk)");
        }

        if (dependents === '1') {
            recMonths += 3;
            noteParts.push("having dependents");
        } else {
            noteParts.push("no dependents");
        }

        // Cap at 12 months
        recMonths = Math.min(12, recMonths);

        // Ensure at least 6 months if low stability
        if (jobStability === 'low' && recMonths < 6) {
            recMonths = 6;
        }

        const recAmount = expenses * recMonths;

        document.getElementById('rec-months').innerText = recMonths;
        document.getElementById('rec-amount').innerText = formatCurrency(recAmount);
        document.getElementById('rec-note').innerText = `Based on ${noteParts.join(' and ')}.`;
    };

    // Attach event listeners
    document.getElementById('monthly-expenses').addEventListener('input', updateCalculator);
    document.getElementById('job-stability').addEventListener('change', updateCalculator);
    document.getElementById('dependents').addEventListener('change', updateCalculator);

    // Initial calculation
    updateCalculator();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-budgeting-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Budgeting for Beginners: Build Your Financial Foundation</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
