---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Stock Return Calculator",
  "url": "https://firemaths.info/stock-return",
  "description": "Calculate total stock return, including capital gains and dividends, to determine ROI and CAGR.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Stock Return Calculator | firemaths.info"
  description="Calculate your total stock return including dividends. Find out your total return percentage and annualized CAGR based on buy/sell price and holding period."
  canonical="https://firemaths.info/stock-return" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8 mb-12">
            <!-- Inputs Column -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Investment Details</h2>
                </div>

                <div class="input-grid">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="buy-price">Buy Price (Per Share)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="buy-price" value="150.00" min="0.01" step="0.01">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="sell-price">Sell / Current Price</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="sell-price" value="210.00" min="0" step="0.01">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="shares">Number of Shares</label>
                        <div class="relative flex items-center">
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="shares" value="100" min="0.0001" step="1">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="dividends">Total Dividends Received</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="dividends" value="500.00" min="0" step="0.01">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="years">Holding Period</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">Yrs</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="years" value="3" min="0.01" step="0.1">
                        </div>
                    </div>
                </div>

                <p style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 1.5rem; line-height: 1.4;">
                    <strong>Tip:</strong> If you are still holding the stock, enter the current market price in the "Sell / Current Price" field to see your unrealized return.
                </p>
            </div>

            <!-- Summary Column -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-6 shadow-sm self-start" style="align-self: start;">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Return Summary</h2>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold">Initial Investment</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="res-invested">$0</span>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold">Final Value</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="res-final">$0</span>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Profit / Loss</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="res-profit">$0</span>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final" style="margin-top: 1rem;">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold" style="color: var(--text-primary);">Total Return (ROI)</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="res-roi">0.00%</span>
                        <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-roi', this)">Copy</button>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold" style="color: var(--text-primary);">Annualized (CAGR)</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="res-cagr">0.00%</span>
                        <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('res-cagr', this)">Copy</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding Stock Returns</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">A stock's total return encompasses both capital appreciation (the increase in the stock's price) and income generated from dividends. When evaluating an investment, many beginners only look at the price difference between buying and selling, ignoring the significant impact dividends can have over long periods.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Our Stock Return Calculator factors in all these elements to give you a true picture of your investment's performance, expressing the result as both a flat percentage (ROI) and an annualized rate (CAGR).</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Total Return vs. Price Return</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Price Return</strong> is simply the change in the stock's price over time. If you buy a stock at $100 and it grows to $110, the price return is 10%.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Total Return</strong> includes both the price change and any dividends received. If that same stock also paid $5 in dividends while you held it, your total profit is $15, making your total return 15%. Over decades, reinvested dividends often account for a massive portion of the stock market's overall historical return.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">How to Use the Stock Return Calculator</h2>
            <ol class="text-[var(--text-secondary)] mb-6 pl-6 list-decimal space-y-2">
                <li><strong>Buy Price:</strong> Enter the price you originally paid per share.</li>
                <li><strong>Sell / Current Price:</strong> Enter the price you sold it for, or the current market price if you still own the shares.</li>
                <li><strong>Number of Shares:</strong> The total amount of shares you hold or traded.</li>
                <li><strong>Total Dividends Received:</strong> The total absolute dollar amount of dividends you received during your holding period.</li>
                <li><strong>Holding Period:</strong> The amount of time you owned the stock, measured in years (e.g., use 1.5 for 18 months).</li>
            </ol>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Why CAGR is Important</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The Compound Annual Growth Rate (CAGR) tells you what the stock's return would be if it had grown at a steady, consistent rate every single year. A 50% total return sounds great, but if it took 15 years to achieve, the CAGR is only 2.7%, meaning your money might have grown faster in a simple high-yield savings account or index fund.</p>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(value);
    };

    // Format percentage
    const formatPercent = (value) => {
        if (!isFinite(value)) return 'N/A';
        return new Intl.NumberFormat('en-US', {
            style: 'percent',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(value / 100);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // Set color class based on value
    const setColorClass = (element, value) => {
        element.classList.remove('val-positive', 'val-negative');
        if (value > 0) element.classList.add('val-positive');
        else if (value < 0) element.classList.add('val-negative');
    };

    // Calculation logic
    const calculateReturns = () => {
        const buyPrice = parseFloat(document.getElementById('buy-price').value) || 0;
        const sellPrice = parseFloat(document.getElementById('sell-price').value) || 0;
        const shares = parseFloat(document.getElementById('shares').value) || 0;
        const dividends = parseFloat(document.getElementById('dividends').value) || 0;
        const years = parseFloat(document.getElementById('years').value) || 0;

        // Core calculations
        const initialInvestment = buyPrice * shares;
        const finalStockValue = sellPrice * shares;
        const totalFinalValue = finalStockValue + dividends;

        const totalProfit = totalFinalValue - initialInvestment;

        // ROI
        let roi = 0;
        if (initialInvestment > 0) {
            roi = (totalProfit / initialInvestment) * 100;
        }

        // CAGR
        let cagr = 0;
        if (initialInvestment > 0 && totalFinalValue > 0 && years > 0) {
            cagr = (Math.pow(totalFinalValue / initialInvestment, 1 / years) - 1) * 100;
        } else if (initialInvestment > 0 && totalFinalValue === 0 && years > 0) {
            cagr = -100;
        }

        // Update UI Summary
        document.getElementById('res-invested').textContent = formatCurrency(initialInvestment);
        document.getElementById('res-final').textContent = formatCurrency(totalFinalValue);

        const elProfit = document.getElementById('res-profit');
        elProfit.textContent = formatCurrency(totalProfit);
        setColorClass(elProfit, totalProfit);

        const elRoi = document.getElementById('res-roi');
        elRoi.textContent = formatPercent(roi);
        setColorClass(elRoi, roi);

        const elCagr = document.getElementById('res-cagr');
        elCagr.textContent = formatPercent(cagr);
        setColorClass(elCagr, cagr);
    };

    // Attach event listeners to inputs
    const inputs = document.querySelectorAll('input[type="number"]');
    inputs.forEach(input => {
        input.addEventListener('input', calculateReturns);
    });

    // Initial calculation on load
    calculateReturns();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-investing-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Beginner's Guide to Investing Your Money</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
