---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best Credit Cards 2026",
  "description": "Compare the best credit cards of 2026 for cash back, travel, no annual fee, balance transfers, business, students, and building credit.",
  "author": {
    "@type": "Organization",
    "name": "firemaths.info"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the best credit card for beginners?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For beginners, a no-annual-fee student card or a secured card is best to build credit safely."
      }
    },
    {
      "@type": "Question",
      "name": "How many credit cards should I have?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no perfect number, but having 2-3 cards for different spending categories (e.g., one for groceries, one for travel) can maximize rewards while keeping your accounts manageable."
      }
    },
    {
      "@type": "Question",
      "name": "Do travel cards have high annual fees?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Premium travel cards have high fees but offer extensive perks. However, there are low-fee and no-fee options available."
      }
    },
    {
      "@type": "Question",
      "name": "What is a 0% APR balance transfer card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "These cards offer a promotional period where no interest is charged on transferred balances, making them excellent for paying off existing debt."
      }
    },
    {
      "@type": "Question",
      "name": "Does applying for a new credit card hurt my credit score?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, a hard inquiry will temporarily lower your score by a few points. However, the new credit limit can lower your utilization ratio, which improves your score in the long run."
      }
    }
  ]
};

export const meta = {
  title: "Best Credit Cards 2026",
  description: "Compare the best credit cards of 2026 for cash back, travel, no annual fee, balance transfers, business, students, and building credit.",
  category: "guide",
  published: "2026-03-25",
};
---

<SiteLayout
  site="firemaths"
  title="Best Credit Cards 2026 | firemaths.info"
  description="Compare the best credit cards of 2026 for cash back, travel, no annual fee, balance transfers, business, students, and building credit."
  canonical="https://firemaths.info/best-credit-cards"
  schema={[articleSchema, faqSchema]}
>
  <style>
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 24px;
    margin-bottom: 60px;
}

.card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.card-header h3 {
    font-size: 1.5rem;
    color: var(--accent-color);
    margin-bottom: 0.25rem;
}

.category-badge {
    display: inline-block;
    background-color: var(--bg-color);
    border: 1px solid var(--accent-color);
    color: var(--accent-color);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.5rem;
}

.features-list {
    flex-grow: 1;
}

.features-list ul {
    list-style: none;
    margin-top: 12px;
}

.features-list li {
    margin-bottom: 8px;
    font-size: 0.95rem;
    color: var(--text-primary);
    border-bottom: 1px dashed var(--border-color);
    padding-bottom: 4px;
}

.meta-info {
    margin-top: 1.5rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
    padding: 1.25rem 1.5rem;
}

.faq-question {
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-size: 1rem;
}

.faq-answer {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}
  </style>

  <div class="container">
    <header>
      <h1>Best Credit Cards 2026</h1>
      <p>Top picks by category: cash back, travel, no annual fee, and more.</p>
    </header>

    <main>
      <div class="grid">
        <!-- Cash Back: Citi Double Cash -->
        <div class="card">
          <div class="card-header">
            <div>
              <h3>Citi Double Cash</h3>
