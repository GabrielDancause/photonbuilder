          ]
        }
      },
      2025: {
        standardDeduction: { single: 15000, marriedJoint: 30000, headOfHousehold: 22500 },
        brackets: {
          single: [
            { rate: 0.10, upTo: 11925 },
            { rate: 0.12, upTo: 48475 },
            { rate: 0.22, upTo: 103350 },
            { rate: 0.24, upTo: 197300 },
            { rate: 0.32, upTo: 250525 },
            { rate: 0.35, upTo: 626350 },
            { rate: 0.37, upTo: Infinity }
          ],
          marriedJoint: [
            { rate: 0.10, upTo: 23850 },
            { rate: 0.12, upTo: 96950 },
            { rate: 0.22, upTo: 206700 },
            { rate: 0.24, upTo: 394600 },
            { rate: 0.32, upTo: 501050 },
            { rate: 0.35, upTo: 751600 },
            { rate: 0.37, upTo: Infinity }
          ],
          headOfHousehold: [
            { rate: 0.10, upTo: 17000 },
            { rate: 0.12, upTo: 64850 },
            { rate: 0.22, upTo: 103350 },
            { rate: 0.24, upTo: 197300 },
            { rate: 0.32, upTo: 250500 },
            { rate: 0.35, upTo: 626350 },
            { rate: 0.37, upTo: Infinity }
          ]
        }
      },
      2026: { // Estimates based on typical ~2.5% inflation bump
        standardDeduction: { single: 15400, marriedJoint: 30800, headOfHousehold: 23100 },
        brackets: {
          single: [
            { rate: 0.10, upTo: 12225 },
            { rate: 0.12, upTo: 49700 },
            { rate: 0.22, upTo: 105950 },
            { rate: 0.24, upTo: 202250 },
            { rate: 0.32, upTo: 256800 },
            { rate: 0.35, upTo: 642000 },
            { rate: 0.37, upTo: Infinity }
          ],
          marriedJoint: [
            { rate: 0.10, upTo: 24450 },
            { rate: 0.12, upTo: 99400 },
            { rate: 0.22, upTo: 211900 },
            { rate: 0.24, upTo: 404500 },
            { rate: 0.32, upTo: 513600 },
            { rate: 0.35, upTo: 770400 },
            { rate: 0.37, upTo: Infinity }
          ],
          headOfHousehold: [
            { rate: 0.10, upTo: 17425 },
            { rate: 0.12, upTo: 66475 },
            { rate: 0.22, upTo: 105950 },
            { rate: 0.24, upTo: 202250 },
            { rate: 0.32, upTo: 256750 },
            { rate: 0.35, upTo: 642000 },
            { rate: 0.37, upTo: Infinity }
          ]
        }
      }
    };

    const incomeInput = document.getElementById('grossIncome');
    const filingStatusSelect = document.getElementById('filingStatus');
    const taxYearSelect = document.getElementById('taxYear');
    const incomeError = document.getElementById('incomeError');

    const totalTaxDisplay = document.getElementById('totalTaxDisplay');
    const effectiveRateDisplay = document.getElementById('effectiveRateDisplay');
    const marginalRateDisplay = document.getElementById('marginalRateDisplay');
    const deductionDisplay = document.getElementById('deductionDisplay');

    function formatCurrency(num) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(num);
    }

    function calculateTaxes() {
      const grossIncome = parseFloat(incomeInput.value);

      if (isNaN(grossIncome) || grossIncome < 0) {
        incomeError.style.display = 'block';
        totalTaxDisplay.textContent = '$0';
        effectiveRateDisplay.textContent = '0%';
        marginalRateDisplay.textContent = '0%';
        deductionDisplay.textContent = '$0';
        return;
      }

      incomeError.style.display = 'none';

      const year = taxYearSelect.value;
      const status = filingStatusSelect.value;
      const data = taxData[year];

      const deduction = data.standardDeduction[status];
      deductionDisplay.textContent = formatCurrency(deduction);

      let taxableIncome = Math.max(0, grossIncome - deduction);
      let totalTax = 0;
      let marginalRate = 0;
      let previousUpTo = 0;

      const brackets = data.brackets[status];

      if (taxableIncome > 0) {
        for (let i = 0; i < brackets.length; i++) {
          const bracket = brackets[i];
          const taxableInThisBracket = Math.min(taxableIncome - previousUpTo, bracket.upTo - previousUpTo);

          if (taxableInThisBracket > 0) {
            totalTax += taxableInThisBracket * bracket.rate;
            marginalRate = bracket.rate;
          }

          previousUpTo = bracket.upTo;
          if (taxableIncome <= bracket.upTo) break;
        }
      }

      totalTaxDisplay.textContent = formatCurrency(totalTax);
      marginalRateDisplay.textContent = (marginalRate * 100).toFixed(1) + '%';

      const effectiveRate = grossIncome > 0 ? (totalTax / grossIncome) : 0;
      effectiveRateDisplay.textContent = (effectiveRate * 100).toFixed(1) + '%';
    }

    ['input', 'change'].forEach(evt => {
      incomeInput.addEventListener(evt, calculateTaxes);
    });
    filingStatusSelect.addEventListener('change', calculateTaxes);
    taxYearSelect.addEventListener('change', calculateTaxes);

    // Initial calculation
    calculateTaxes();

  </script>

