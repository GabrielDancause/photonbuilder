---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Auto Loan Calculator",
  "url": "https://firemaths.info/auto-loan-calculator",
  "description": "Calculate your monthly car payment, total interest, and total cost. Compare new vs used auto loan rates and view a full amortization schedule.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How is a monthly car payment calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A monthly car payment is calculated using the standard amortization formula: M = P[r(1+r)^n]/[(1+r)^n – 1], where P is the loan amount (vehicle price minus down payment and trade-in, plus sales tax), r is the monthly interest rate (annual rate divided by 12), and n is the total number of monthly payments. The loan amount includes sales tax on the net purchase price."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good interest rate for a car loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A good auto loan interest rate depends on your credit score, loan term, and whether the vehicle is new or used. As of 2024-2025, excellent credit (750+) typically qualifies for 4-6% on new cars and 5-7% on used cars. Good credit (700-749) usually gets 6-8% on new and 7-9% on used. Rates above 10% are generally considered high. Credit unions often offer lower rates than banks or dealership financing."
      }
    },
    {
      "@type": "Question",
      "name": "Should I choose a shorter or longer car loan term?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shorter loan terms (24-48 months) have higher monthly payments but save significantly on total interest and help you avoid being underwater on the loan. Longer terms (60-84 months) lower your monthly payment but cost more in total interest and increase the risk of owing more than the car is worth. Financial experts generally recommend keeping auto loans to 48-60 months maximum and ensuring your total monthly car expenses stay under 15% of your gross income."
      }
    },
    {
      "@type": "Question",
      "name": "How does a trade-in affect my car loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A trade-in reduces the amount you need to finance by subtracting the trade-in value from the vehicle price before calculating the loan amount. In most states, trading in a vehicle also reduces the sales tax you owe because tax is calculated on the difference between the new vehicle price and the trade-in value. For example, if you buy a $30,000 car and trade in a vehicle worth $8,000, you'd only pay sales tax on $22,000 in most states."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between new and used car loan rates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Used car loan rates are typically 1-3% higher than new car rates. This is because used vehicles depreciate faster, making them riskier collateral for lenders. New cars may also qualify for manufacturer promotional rates (sometimes as low as 0% APR). The age of the used vehicle also matters — cars older than 5-7 years often have even higher rates or shorter maximum loan terms."
      }
    },
    {
      "@type": "Question",
      "name": "How much car can I afford?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Financial experts recommend following the 20/4/10 rule: put at least 20% down, finance for no more than 4 years, and keep total monthly vehicle expenses (payment, insurance, fuel, maintenance) under 10% of your gross monthly income. A more relaxed guideline is keeping your car payment under 15% of your take-home pay. Use our affordability guide to see what monthly payment fits your income level."
      }
    },
    {
      "@type": "Question",
      "name": "Does sales tax get added to my car loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, in most cases sales tax is rolled into the auto loan. Sales tax is calculated on the net purchase price (vehicle price minus trade-in value in most states). The tax amount is added to the loan balance, meaning you pay interest on the tax as well. Some states have no sales tax on vehicles (Oregon, Montana, New Hampshire, Delaware, Alaska), while others range from 2% to over 10%."
      }
    },
    {
      "@type": "Question",
      "name": "What is negative equity or being 'underwater' on a car loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Negative equity (being 'underwater') means you owe more on your car loan than the vehicle is currently worth. This commonly happens with long loan terms (72-84 months), small or no down payments, and vehicles that depreciate quickly. New cars typically lose 20-30% of their value in the first year. Being underwater makes it difficult to sell or trade in the vehicle without paying out of pocket to cover the difference."
      }
    }
  ]
};

export const meta = {
  title: "Auto Loan Calculator | firemaths.info",
  description: "Calculate your monthly car payment, total interest, and total cost with our free auto loan calculator. Compare new vs used rates, view amortization schedule, and check affordability.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Auto Loan Calculator | firemaths.info"
  description="Calculate your monthly car payment, total interest, and total cost with our free auto loan calculator. Compare new vs used rates, view amortization schedule, and check affordability."
  canonical="https://firemaths.info/auto-loan-calculator" schema={schema}
>
  <style>
:root {
    --color-principal: #4A90E2;
    --color-interest: #E25C5C;
    --color-tax: #D4A017;
    --color-new: #50E3C2;
    --color-used: #9B59B6;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

select {
    font-family: var(--font-ui);
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23888888' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1em;
    padding-right: 2.5rem;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.chart-section h2 {
    text-align: center;
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
}

.chart-container {
    width: 100%;
    height: 400px;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

.section-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.section-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.toggle-group {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
}

.toggle-btn {
    flex: 1;
    padding: 0.6rem 1rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    transition: all 0.2s;
}

.toggle-btn:first-child { border-radius: 6px 0 0 6px; }
.toggle-btn:last-child { border-radius: 0 6px 6px 0; }

.toggle-btn.active {
    background: var(--accent-color);
    color: #0c0a00;
    border-color: var(--accent-color);
    font-weight: 600;
}

.amort-table-wrap {
    overflow-x: auto;
    max-height: 500px;
    overflow-y: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.amort-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    white-space: nowrap;
}

.amort-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
}

.amort-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    text-align: right;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--border-color);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.amort-table th:first-child {
    text-align: center;
}

.amort-table td {
    padding: 0.5rem 0.75rem;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-secondary);
}

.amort-table td:first-child {
    text-align: center;
    color: var(--text-primary);
}

.amort-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

.comparison-table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.comparison-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    text-align: right;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--border-color);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.comparison-table th:first-child {
    text-align: left;
}

.comparison-table td {
    padding: 0.75rem 1rem;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
    font-family: var(--font-mono);
    color: var(--text-secondary);
}

.comparison-table td:first-child {
    text-align: left;
    font-family: var(--font-ui);
    font-weight: 500;
    color: var(--text-primary);
}

.comparison-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

.comparison-table .highlight-row {
    background: rgba(212, 160, 23, 0.08);
}

.comparison-table .highlight-row td {
    color: var(--text-primary);
}

.affordability-table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.affordability-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.affordability-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    text-align: right;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--border-color);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.affordability-table th:first-child {
    text-align: left;
}

.affordability-table td {
    padding: 0.75rem 1rem;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
    font-family: var(--font-mono);
    color: var(--text-secondary);
}

.affordability-table td:first-child {
    text-align: left;
    font-family: var(--font-ui);
    font-weight: 500;
    color: var(--text-primary);
}

.affordability-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content h3 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul, .seo-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.25rem 0;
}

.faq-question {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-size: 1rem;
}

.faq-answer {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
}

.related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
    margin-bottom: 4rem;
}

.related-link {
    display: block;
    padding: 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    transition: border-color 0.2s;
}

.related-link:hover {
    border-color: var(--accent-color);
}

.related-link span {
    display: block;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Auto Loan Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:3rem;">Calculate your monthly car payment, total interest paid, and view a full amortization schedule for your auto loan.</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Loan Details</h2>
                </div>

                <div class="input-group">
                    <label for="vehicle-price">Vehicle Price</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="vehicle-price" value="35000" min="0" step="500">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="down-payment">Down Payment</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="down-payment" value="5000" min="0" step="500">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="trade-in">Trade-In Value</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="trade-in" value="0" min="0" step="500">
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="sales-tax">Sales Tax Rate</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="sales-tax" value="6" min="0" max="15" step="0.25">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="interest-rate">Interest Rate (APR)</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="interest-rate" value="6.5" min="0" max="30" step="0.25">
                        </div>
                    </div>
                </div>

                <div class="input-group">
                    <label for="loan-term">Loan Term</label>
                    <div class="input-wrapper">
                        <select id="loan-term">
                            <option value="24">24 months (2 years)</option>
                            <option value="36">36 months (3 years)</option>
                            <option value="48">48 months (4 years)</option>
                            <option value="60" selected>60 months (5 years)</option>
                            <option value="72">72 months (6 years)</option>
                            <option value="84">84 months (7 years)</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your Car Payment</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Monthly Payment</span>
                        <div class="result-value">
                            <span id="monthly-payment">$0</span>
                            <button class="copy-btn" onclick="copyValue('monthly-payment', this)">Copy</button>
                        </div>
                    </div>

                    <div style="padding-bottom: 1rem; border-bottom: 1px dashed var(--border-color); margin-bottom: 1rem;">
                        <div class="result-item">
                            <span class="result-label">Loan Amount</span>
                            <span class="result-value" id="res-loan-amt" style="font-size: 0.9375rem;">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Sales Tax</span>
                            <span class="result-value" id="res-sales-tax" style="font-size: 0.9375rem; color: var(--color-tax);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Amount Financed</span>
                            <span class="result-value" id="res-financed" style="font-size: 0.9375rem;">$0</span>
                        </div>
                    </div>

                    <div>
                        <div class="result-item">
                            <span class="result-label">Total Interest</span>
                            <span class="result-value" id="res-total-interest" style="font-size: 0.9375rem; color: var(--color-interest);">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Total Cost</span>
                            <span class="result-value" id="res-total-cost" style="font-size: 1.125rem; font-weight: 600;">$0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Payoff Date</span>
                            <span class="result-value" id="res-payoff" style="font-size: 0.9375rem; font-family: var(--font-ui);">—</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Amortization Chart -->
        <div class="chart-section">
            <h2>Loan Balance Over Time</h2>
            <div class="chart-container">
                <canvas id="balanceChart"></canvas>
            </div>
        </div>

        <!-- Amortization Schedule -->
        <div class="section-card">
            <h2>Amortization Schedule</h2>
            <div class="toggle-group">
                <button class="toggle-btn active" id="btn-monthly" onclick="setAmortView('monthly')">Monthly</button>
                <button class="toggle-btn" id="btn-yearly" onclick="setAmortView('yearly')">Yearly Summary</button>
            </div>
            <div class="amort-table-wrap">
                <table class="amort-table" id="amort-table">
                    <thead id="amort-thead"></thead>
                    <tbody id="amort-tbody"></tbody>
                </table>
            </div>
        </div>

        <!-- New vs Used Rate Comparison -->
        <div class="section-card">
            <h2>New vs Used Auto Loan Rate Comparison</h2>
