</div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

window.copyValue = async (id, btn) => {
    const text = document.getElementById(id).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => btn.innerText = orig, 2000);
    } catch(e) {}
};

let amortView = 'monthly';
let amortData = [];

function getInputs() {
    const vehiclePrice = parseFloat(document.getElementById('vehicle-price').value) || 0;
    const downPayment = parseFloat(document.getElementById('down-payment').value) || 0;
    const tradeIn = parseFloat(document.getElementById('trade-in').value) || 0;
    const salesTaxRate = parseFloat(document.getElementById('sales-tax').value) || 0;
    const interestRate = parseFloat(document.getElementById('interest-rate').value) || 0;
    const loanTerm = parseInt(document.getElementById('loan-term').value) || 60;

    const netPrice = Math.max(0, vehiclePrice - tradeIn);
    const salesTaxAmount = netPrice * salesTaxRate / 100;
    const amountFinanced = Math.max(0, netPrice + salesTaxAmount - downPayment);

    return { vehiclePrice, downPayment, tradeIn, salesTaxRate, salesTaxAmount, interestRate, loanTerm, netPrice, amountFinanced };
}

function calcPayment(principal, annualRate, termMonths) {
    if (principal <= 0) return 0;
    if (annualRate <= 0) return principal / termMonths;
    const r = annualRate / 100 / 12;
    const n = termMonths;
    return principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function buildAmortization(principal, annualRate, termMonths) {
    const r = annualRate / 100 / 12;
    const payment = calcPayment(principal, annualRate, termMonths);
    let balance = principal;
    const schedule = [];
    let totalInterest = 0;
    let totalPrincipal = 0;

    for (let month = 1; month <= termMonths && balance > 0.01; month++) {
        const interestPayment = balance * r;
        let principalPayment = payment - interestPayment;

        if (principalPayment > balance) principalPayment = balance;
        balance -= principalPayment;
        if (balance < 0) balance = 0;

        totalInterest += interestPayment;
        totalPrincipal += principalPayment;

        schedule.push({
            month,
            payment: interestPayment + principalPayment,
            principal: principalPayment,
            interest: interestPayment,
            balance,
            totalInterest,
            totalPrincipal
        });

        if (balance <= 0) break;
    }

    return schedule;
}

function calculate() {
    const inp = getInputs();
    const { vehiclePrice, downPayment, tradeIn, salesTaxAmount, interestRate, loanTerm, amountFinanced } = inp;

    const monthlyPayment = calcPayment(amountFinanced, interestRate, loanTerm);
    const totalPaid = monthlyPayment * loanTerm;
    const totalInterest = totalPaid - amountFinanced;
    const totalCost = vehiclePrice + salesTaxAmount + totalInterest;

    const now = new Date();
    const payoffDate = new Date(now.getFullYear(), now.getMonth() + loanTerm, 1);
    const formatDate = (d) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

    // Update results
    document.getElementById('monthly-payment').innerText = fmt(monthlyPayment);
    document.getElementById('res-loan-amt').innerText = fmt(amountFinanced);
    document.getElementById('res-sales-tax').innerText = fmt(salesTaxAmount);
    document.getElementById('res-total-interest').innerText = fmt(totalInterest);
    document.getElementById('res-total-cost').innerText = fmt(totalCost);
    document.getElementById('res-upfront').innerText = fmt(downPayment + tradeIn);
    document.getElementById('res-financed').innerText = fmt(amountFinanced);
    document.getElementById('res-payoff').innerText = formatDate(payoffDate);

    // Build amortization
    amortData = buildAmortization(amountFinanced, interestRate, loanTerm);
    renderAmortTable();
    drawPie(amountFinanced, totalInterest);
    renderTermComparison(inp);
    renderNewUsedComparison(inp);
}

function renderAmortTable() {
    const thead = document.getElementById('amort-thead');
    const tbody = document.getElementById('amort-tbody');

    if (amortView === 'monthly') {
        thead.innerHTML = '<tr><th>#</th><th>Payment</th><th>Principal</th><th>Interest</th><th>Balance</th></tr>';
        let html = '';
        for (const row of amortData) {
            html += `<tr><td>${row.month}</td><td>${fmt2(row.payment)}</td><td>${fmt2(row.principal)}</td><td>${fmt2(row.interest)}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    } else {
        thead.innerHTML = '<tr><th>Year</th><th>Total Paid</th><th>Principal</th><th>Interest</th><th>End Balance</th></tr>';
        const yearly = [];
        let yearPayment = 0, yearPrincipal = 0, yearInterest = 0, yearEnd = 0;
        for (const row of amortData) {
            yearPayment += row.payment;
            yearPrincipal += row.principal;
            yearInterest += row.interest;
            yearEnd = row.balance;
            if (row.month % 12 === 0 || row === amortData[amortData.length - 1]) {
                yearly.push({ year: Math.ceil(row.month / 12), payment: yearPayment, principal: yearPrincipal, interest: yearInterest, balance: yearEnd });
                yearPayment = 0; yearPrincipal = 0; yearInterest = 0;
            }
        }
        let html = '';
        for (const row of yearly) {
            html += `<tr><td>${row.year}</td><td>${fmt(row.payment)}</td><td>${fmt(row.principal)}</td><td>${fmt(row.interest)}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    }
}

window.setAmortView = (view) => {
    amortView = view;
    document.getElementById('btn-monthly').classList.toggle('active', view === 'monthly');
    document.getElementById('btn-yearly').classList.toggle('active', view === 'yearly');
    renderAmortTable();
};

function drawPie(principal, totalInterest) {
    const canvas = document.getElementById('pieChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const size = container.getBoundingClientRect().width;

    canvas.width = size * dpr;
    canvas.height = size * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, size, size);

    const slices = [
        { value: principal, hex: '#4A90E2', label: 'Principal' },
        { value: totalInterest, hex: '#E25C5C', label: 'Interest' },
    ];

    const total = slices.reduce((s, sl) => s + sl.value, 0);
    if (total <= 0) return;

    const cx = size / 2;
    const cy = size / 2;
    const outerR = (size / 2) - 10;
    const innerR = outerR * 0.55;

    let startAngle = -Math.PI / 2;
    for (const slice of slices) {
        const sliceAngle = (slice.value / total) * Math.PI * 2;
        ctx.beginPath();
        ctx.arc(cx, cy, outerR, startAngle, startAngle + sliceAngle);
        ctx.arc(cx, cy, innerR, startAngle + sliceAngle, startAngle, true);
        ctx.closePath();
        ctx.fillStyle = slice.hex;
        ctx.fill();
        startAngle += sliceAngle;
    }

    // Center text
    ctx.fillStyle = '#e0d8c8';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = `bold ${size * 0.09}px Inter, sans-serif`;
    ctx.fillText(fmt(total), cx, cy - 8);
    ctx.font = `${size * 0.045}px Inter, sans-serif`;
    ctx.fillStyle = '#888888';
    ctx.fillText('total paid', cx, cy + size * 0.055);

    // Legend
    const legendEl = document.getElementById('pieLegend');
    legendEl.innerHTML = slices.map(s =>
        `<div class="pie-legend-item">
            <span class="pie-legend-color" style="background:${s.hex}"></span>
            <span class="pie-legend-label">${s.label}</span>
            <span class="pie-legend-value">${fmt(s.value)} <span style="color:var(--text-secondary);font-size:0.75rem;font-weight:400;">(${(s.value/total*100).toFixed(1)}%)</span></span>
        </div>`
    ).join('');
}

function renderTermComparison(inp) {
    const terms = [36, 48, 60, 72];
    const selectedTerm = inp.loanTerm;
    const rows = [
        { label: 'Monthly Payment', key: 'monthly' },
        { label: 'Total Paid', key: 'totalPaid' },
        { label: 'Total Interest', key: 'totalInterest' },
        { label: 'Interest Savings vs 72mo', key: 'savings' },
    ];

    const data = {};
    for (const t of terms) {
        const monthly = calcPayment(inp.amountFinanced, inp.interestRate, t);
        const totalPaid = monthly * t;
        const totalInterest = totalPaid - inp.amountFinanced;
        data[t] = { monthly, totalPaid, totalInterest };
    }

    const interest72 = data[72].totalInterest;
    for (const t of terms) {
        data[t].savings = interest72 - data[t].totalInterest;
    }

    const tbody = document.getElementById('term-comparison-tbody');
    let html = '';
    for (const row of rows) {
        html += '<tr>';
        html += `<td>${row.label}</td>`;
        for (const t of terms) {
            const val = data[t][row.key];
            const highlight = t === selectedTerm ? ' class="highlight-row"' : '';
            if (row.key === 'savings' && t === 72) {
                html += `<td${highlight}>—</td>`;
            } else {
                html += `<td${highlight}>${fmt(val)}</td>`;
            }
        }
        html += '</tr>';
    }
    tbody.innerHTML = html;
}

function renderNewUsedComparison(inp) {
    const newRate = inp.interestRate;
    const usedRate = newRate + 1.5;
    const term = inp.loanTerm;

    const newMonthly = calcPayment(inp.amountFinanced, newRate, term);
    const usedMonthly = calcPayment(inp.amountFinanced, usedRate, term);
    const newTotal = newMonthly * term;
    const usedTotal = usedMonthly * term;
    const newInterest = newTotal - inp.amountFinanced;
    const usedInterest = usedTotal - inp.amountFinanced;

    const rows = [
        { label: 'Interest Rate', newVal: newRate.toFixed(1) + '%', usedVal: usedRate.toFixed(1) + '%', diff: '+' + (usedRate - newRate).toFixed(1) + '%' },
        { label: 'Monthly Payment', newVal: fmt(newMonthly), usedVal: fmt(usedMonthly), diff: '+' + fmt(usedMonthly - newMonthly) },
        { label: 'Total Interest', newVal: fmt(newInterest), usedVal: fmt(usedInterest), diff: '+' + fmt(usedInterest - newInterest) },
        { label: 'Total Cost', newVal: fmt(newTotal), usedVal: fmt(usedTotal), diff: '+' + fmt(usedTotal - newTotal) },
    ];

    const tbody = document.getElementById('new-used-tbody');
    let html = '';
    for (const row of rows) {
        html += `<tr><td>${row.label}</td><td>${row.newVal}</td><td>${row.usedVal}</td><td style="color:var(--color-interest);">${row.diff}</td></tr>`;
    }
    tbody.innerHTML = html;
}

// Attach listeners
const allInputs = ['vehicle-price', 'down-payment', 'trade-in', 'sales-tax', 'interest-rate', 'loan-term'];
allInputs.forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
});

window.addEventListener('resize', () => {
    const inp = getInputs();
    drawPie(inp.amountFinanced, calcPayment(inp.amountFinanced, inp.interestRate, inp.loanTerm) * inp.loanTerm - inp.amountFinanced);
});

setTimeout(calculate, 0);
  </script>
</SiteLayout>
