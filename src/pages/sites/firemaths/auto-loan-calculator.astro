  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

window.copyValue = async (id, btn) => {
    const text = document.getElementById(id).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => btn.innerText = orig, 2000);
    } catch(e) {}
};

let amortView = 'monthly';
let amortData = [];

function getInputs() {
    const vehiclePrice = parseFloat(document.getElementById('vehicle-price').value) || 0;
    const downPayment = parseFloat(document.getElementById('down-payment').value) || 0;
    const tradeIn = parseFloat(document.getElementById('trade-in').value) || 0;
    const salesTaxRate = parseFloat(document.getElementById('sales-tax').value) || 0;
    const interestRate = parseFloat(document.getElementById('interest-rate').value) || 0;
    const loanTerm = parseInt(document.getElementById('loan-term').value) || 60;

    const netPrice = Math.max(0, vehiclePrice - tradeIn);
    const salesTax = netPrice * salesTaxRate / 100;
    const loanAmount = Math.max(0, netPrice + salesTax - downPayment);

    return { vehiclePrice, downPayment, tradeIn, salesTaxRate, interestRate, loanTerm, netPrice, salesTax, loanAmount };
}

function calcPayment(loanAmount, annualRate, termMonths) {
    if (loanAmount <= 0) return 0;
    if (annualRate <= 0) return loanAmount / termMonths;
    const r = annualRate / 100 / 12;
    const n = termMonths;
    return loanAmount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function buildAmortization(loanAmount, annualRate, termMonths) {
    const r = annualRate / 100 / 12;
    const payment = calcPayment(loanAmount, annualRate, termMonths);
    let balance = loanAmount;
    const schedule = [];
    let totalInterest = 0;
    let totalPrincipal = 0;

    for (let month = 1; month <= termMonths && balance > 0.01; month++) {
        const interestPayment = balance * r;
        let principalPayment = payment - interestPayment;

        if (principalPayment > balance) principalPayment = balance;
        balance -= principalPayment;
        if (balance < 0) balance = 0;

        totalInterest += interestPayment;
        totalPrincipal += principalPayment;

        schedule.push({
            month,
            payment: interestPayment + principalPayment,
            principal: principalPayment,
            interest: interestPayment,
            balance,
            totalInterest,
            totalPrincipal
        });

        if (balance <= 0) break;
    }

    return schedule;
}

function calculate() {
    const inp = getInputs();
    const { vehiclePrice, downPayment, tradeIn, salesTaxRate, interestRate, loanTerm, netPrice, salesTax, loanAmount } = inp;

    const monthlyPayment = calcPayment(loanAmount, interestRate, loanTerm);
    const totalPaid = monthlyPayment * loanTerm;
    const totalInterest = totalPaid - loanAmount;
    const totalCost = vehiclePrice + salesTax + totalInterest;

    // Payoff date
    const now = new Date();
    const payoffDate = new Date(now.getFullYear(), now.getMonth() + loanTerm, 1);
    const formatDate = (d) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

    // Update results
    document.getElementById('monthly-payment').innerText = fmt(monthlyPayment);
    document.getElementById('res-loan-amt').innerText = fmt(netPrice - downPayment);
    document.getElementById('res-sales-tax').innerText = fmt(salesTax);
    document.getElementById('res-financed').innerText = fmt(loanAmount);
    document.getElementById('res-total-interest').innerText = fmt(totalInterest);
    document.getElementById('res-total-cost').innerText = fmt(totalCost);
    document.getElementById('res-payoff').innerText = formatDate(payoffDate);

    amortData = buildAmortization(loanAmount, interestRate, loanTerm);
    renderAmortTable();
    drawBalanceChart(amortData);
    renderRateComparison(inp);
    renderTermComparison(inp);
    renderAffordability(inp);
}

function renderAmortTable() {
    const thead = document.getElementById('amort-thead');
    const tbody = document.getElementById('amort-tbody');

    if (amortView === 'monthly') {
        thead.innerHTML = '<tr><th>#</th><th>Payment</th><th>Principal</th><th>Interest</th><th>Balance</th></tr>';
        let html = '';
        for (const row of amortData) {
            html += `<tr><td>${row.month}</td><td>${fmt2(row.payment)}</td><td>${fmt2(row.principal)}</td><td>${fmt2(row.interest)}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    } else {
        thead.innerHTML = '<tr><th>Year</th><th>Total Paid</th><th>Principal</th><th>Interest</th><th>End Balance</th></tr>';
        const yearly = [];
        let yearPayment = 0, yearPrincipal = 0, yearInterest = 0, yearEnd = 0;
        for (const row of amortData) {
            yearPayment += row.payment;
            yearPrincipal += row.principal;
            yearInterest += row.interest;
            yearEnd = row.balance;
            if (row.month % 12 === 0 || row === amortData[amortData.length - 1]) {
                yearly.push({ year: Math.ceil(row.month / 12), payment: yearPayment, principal: yearPrincipal, interest: yearInterest, balance: yearEnd });
                yearPayment = 0; yearPrincipal = 0; yearInterest = 0;
            }
        }
        let html = '';
        for (const row of yearly) {
            html += `<tr><td>${row.year}</td><td>${fmt(row.payment)}</td><td>${fmt(row.principal)}</td><td>${fmt(row.interest)}</td><td>${fmt(row.balance)}</td></tr>`;
        }
        tbody.innerHTML = html;
    }
}

window.setAmortView = (view) => {
    amortView = view;
    document.getElementById('btn-monthly').classList.toggle('active', view === 'monthly');
    document.getElementById('btn-yearly').classList.toggle('active', view === 'yearly');
    renderAmortTable();
};

function drawBalanceChart(schedule) {
    const canvas = document.getElementById('balanceChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const rect = container.getBoundingClientRect();
    const width = rect.width;
    const height = rect.height;

    canvas.width = width * dpr;
    canvas.height = height * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, width, height);

    if (schedule.length === 0) return;

    const padLeft = 70;
    const padRight = 20;
    const padTop = 20;
    const padBottom = 40;
    const chartW = width - padLeft - padRight;
    const chartH = height - padTop - padBottom;

    const maxBalance = schedule[0].balance + schedule[0].principal;
    const totalMonths = schedule.length;

    // Grid lines
    ctx.strokeStyle = 'rgba(128,128,128,0.15)';
    ctx.lineWidth = 1;
    const gridSteps = 5;
    ctx.font = '11px Inter, sans-serif';
    ctx.fillStyle = '#888888';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    for (let i = 0; i <= gridSteps; i++) {
        const y = padTop + (chartH * i / gridSteps);
        const val = maxBalance * (1 - i / gridSteps);
        ctx.beginPath();
        ctx.moveTo(padLeft, y);
        ctx.lineTo(padLeft + chartW, y);
        ctx.stroke();
        ctx.fillText('$' + Math.round(val / 1000) + 'k', padLeft - 8, y);
    }

    // X axis labels
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    const xLabelCount = Math.min(totalMonths, 6);
    for (let i = 0; i <= xLabelCount; i++) {
        const month = Math.round((totalMonths * i) / xLabelCount);
        const x = padLeft + (month / totalMonths) * chartW;
        ctx.fillText(month + 'mo', x, padTop + chartH + 10);
    }

    // Principal area (bottom)
    ctx.beginPath();
    ctx.moveTo(padLeft, padTop + chartH);
    for (let i = 0; i < schedule.length; i++) {
        const x = padLeft + ((i + 1) / totalMonths) * chartW;
        const principalPaid = schedule[i].totalPrincipal;
        const y = padTop + chartH - (principalPaid / maxBalance) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.lineTo(padLeft + chartW, padTop + chartH);
    ctx.closePath();
    ctx.fillStyle = 'rgba(74, 144, 226, 0.3)';
    ctx.fill();

    // Balance line
    ctx.beginPath();
    ctx.moveTo(padLeft, padTop);
    for (let i = 0; i < schedule.length; i++) {
        const x = padLeft + ((i + 1) / totalMonths) * chartW;
        const y = padTop + (1 - schedule[i].balance / maxBalance) * chartH;
        ctx.lineTo(x, y);
    }
    ctx.strokeStyle = '#E25C5C';
    ctx.lineWidth = 2.5;
    ctx.stroke();

    // Legend
    const legendY = padTop + 8;
    ctx.fillStyle = '#E25C5C';
    ctx.fillRect(padLeft + 10, legendY, 12, 3);
    ctx.fillStyle = '#888888';
    ctx.font = '11px Inter, sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'middle';
    ctx.fillText('Remaining Balance', padLeft + 28, legendY + 2);

    ctx.fillStyle = 'rgba(74, 144, 226, 0.5)';
    ctx.fillRect(padLeft + 160, legendY, 12, 10);
    ctx.fillStyle = '#888888';
    ctx.fillText('Principal Paid', padLeft + 178, legendY + 5);
}

function renderRateComparison(inp) {
    const creditTiers = [
        { name: 'Excellent (750+)', newRate: 4.5, usedRate: 5.5 },
        { name: 'Good (700-749)', newRate: 6.0, usedRate: 7.5 },
        { name: 'Fair (650-699)', newRate: 8.5, usedRate: 10.5 },
        { name: 'Poor (600-649)', newRate: 12.0, usedRate: 14.5 },
        { name: 'Bad (<600)', newRate: 16.0, usedRate: 19.0 },
    ];

    const tbody = document.getElementById('rate-comparison-tbody');
    let html = '';
    for (const tier of creditTiers) {
        const newPmt = calcPayment(inp.loanAmount, tier.newRate, inp.loanTerm);
        const usedPmt = calcPayment(inp.loanAmount, tier.usedRate, inp.loanTerm);
        const diff = usedPmt - newPmt;
        html += `<tr>
            <td>${tier.name}</td>
            <td>${tier.newRate.toFixed(1)}%</td>
            <td>${fmt(newPmt)}</td>
            <td>${tier.usedRate.toFixed(1)}%</td>
            <td>${fmt(usedPmt)}</td>
            <td style="color: var(--color-interest);">+${fmt(diff)}</td>
        </tr>`;
    }
    tbody.innerHTML = html;
}

function renderTermComparison(inp) {
    const terms = [36, 48, 60, 72, 84];
    const selectedTerm = inp.loanTerm;
    const rows = [
        { label: 'Monthly Payment', key: 'payment' },
        { label: 'Total Interest', key: 'totalInterest' },
        { label: 'Total Cost', key: 'totalCost' },
    ];

    const data = {};
    for (const t of terms) {
        const pmt = calcPayment(inp.loanAmount, inp.interestRate, t);
        const totalPaid = pmt * t;
        const totalInterest = totalPaid - inp.loanAmount;
        data[t] = { payment: pmt, totalInterest, totalCost: totalPaid };
    }

    const tbody = document.getElementById('term-comparison-tbody');
    let html = '';
    for (const row of rows) {
        html += '<tr>';
        html += `<td>${row.label}</td>`;
        for (const t of terms) {
            const highlight = t === selectedTerm ? ' class="highlight-row"' : '';
            html += `<td${highlight}>${fmt(data[t][row.key])}</td>`;
        }
        html += '</tr>';
    }
    tbody.innerHTML = html;
}

function renderAffordability(inp) {
    const incomes = [30000, 40000, 50000, 60000, 75000, 100000, 125000, 150000];
    const tbody = document.getElementById('affordability-tbody');
    let html = '';

    for (const income of incomes) {
        const monthlyGross = income / 12;
        const max10 = monthlyGross * 0.10;
        const max15 = monthlyGross * 0.15;

        // Reverse-calculate max car price from max payment
        const r = inp.interestRate / 100 / 12;
        let maxLoan10, maxLoan15;
        if (r > 0) {
            const n = inp.loanTerm;
            const factor = (Math.pow(1 + r, n) - 1) / (r * Math.pow(1 + r, n));
            maxLoan10 = max10 * factor;
            maxLoan15 = max15 * factor;
        } else {
            maxLoan10 = max10 * inp.loanTerm;
            maxLoan15 = max15 * inp.loanTerm;
        }

        // Rough car price estimate (add back down payment, remove tax effect)
        const taxMultiplier = 1 + (inp.salesTaxRate / 100);
        const maxPrice10 = (maxLoan10 / taxMultiplier) + inp.downPayment + inp.tradeIn;
        const maxPrice15 = (maxLoan15 / taxMultiplier) + inp.downPayment + inp.tradeIn;

        html += `<tr>
            <td>${fmt(income)}</td>
            <td>${fmt(monthlyGross)}</td>
            <td>${fmt(max10)}</td>
            <td>${fmt(max15)}</td>
            <td>${fmt(maxPrice10)}</td>
            <td>${fmt(maxPrice15)}</td>
        </tr>`;
    }
    tbody.innerHTML = html;
}

// Attach listeners
const allInputs = ['vehicle-price', 'down-payment', 'trade-in', 'sales-tax', 'interest-rate', 'loan-term'];
allInputs.forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
});

window.addEventListener('resize', () => {
    if (amortData.length > 0) drawBalanceChart(amortData);
});

setTimeout(calculate, 0);
  </script>
