            <div class="summary-card">
                <div class="summary-card-label">Monthly Savings</div>
                <div class="summary-card-value" id="summary-monthly">$0</div>
            </div>
            <div class="summary-card">
                <div class="summary-card-label">Total Interest Saved</div>
