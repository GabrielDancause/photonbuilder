<div class="container">
    <h1>Mortgage Refinance Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:3rem;">Compare your current mortgage to a refinanced loan and see if refinancing saves you money.</p>

    <main>
        <div class="calculator-grid">
            <!-- Current Mortgage -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Current Mortgage</h2>
                </div>

                <div class="input-group">
                    <label for="current-balance">Current Loan Balance</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="current-balance" value="280000" min="0" step="5000">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="current-rate">Current Rate</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="current-rate" value="6.5" min="0" max="20" step="0.125">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="current-remaining">Remaining Term</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">yrs</span>
                            <input type="number" id="current-remaining" value="27" min="1" max="40" step="1">
                        </div>
                    </div>
                </div>

                <div class="results" style="margin-top: 1rem;">
                    <div class="result-item result-final">
                        <span class="result-label" style="font-size: 1rem;">Current Monthly P&I</span>
                        <div class="result-value">
                            <span id="current-payment">$0</span>
                            <button class="copy-btn" onclick="copyValue('current-payment', this)">Copy</button>
                        </div>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Total Remaining Interest</span>
                        <span class="result-value" id="current-total-interest" style="font-size: 0.9375rem;">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Total Remaining Cost</span>
                        <span class="result-value" id="current-total-cost" style="font-size: 0.9375rem;">$0</span>
                    </div>
                </div>
            </div>

            <!-- New Mortgage -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Refinanced Mortgage</h2>
                </div>

                <div class="input-group">
                    <label for="new-rate">New Interest Rate</label>
                    <div class="input-wrapper has-suffix">
                        <span class="suffix">%</span>
                        <input type="number" id="new-rate" value="5.5" min="0" max="20" step="0.125">
                    </div>
                </div>

