</div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

window.copyValue = async (id, btn) => {
    const text = document.getElementById(id).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => btn.innerText = orig, 2000);
    } catch(e) {}
};

function calcPI(loanAmount, annualRate, termYears) {
    if (loanAmount <= 0) return 0;
    if (annualRate <= 0) return loanAmount / (termYears * 12);
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    return loanAmount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function buildSchedule(loanAmount, annualRate, termYears) {
    const r = annualRate / 100 / 12;
    const n = termYears * 12;
    const monthly = calcPI(loanAmount, annualRate, termYears);
    let balance = loanAmount;
    const schedule = [];
    let totalInterest = 0;

    for (let month = 1; month <= n && balance > 0.01; month++) {
        const interest = balance * r;
        let principal = monthly - interest;
        if (principal > balance) principal = balance;
        balance -= principal;
        if (balance < 0) balance = 0;
        totalInterest += interest;
        schedule.push({ month, payment: interest + principal, principal, interest, balance, totalInterest });
        if (balance <= 0) break;
    }
    return schedule;
}

function calculate() {
    // Inputs
    const currentBalance = parseFloat(document.getElementById('current-balance').value) || 0;
    const currentRate = parseFloat(document.getElementById('current-rate').value) || 0;
    const currentRemaining = parseInt(document.getElementById('current-remaining').value) || 1;
    const newRate = parseFloat(document.getElementById('new-rate').value) || 0;
    const newTerm = parseInt(document.getElementById('new-term').value) || 15;
    const closingCosts = parseFloat(document.getElementById('closing-costs').value) || 0;
    const points = parseFloat(document.getElementById('points').value) || 0;

    // Point cost
    const pointCost = currentBalance * (points / 100);
    const totalUpfrontCost = closingCosts + pointCost;

    // Current mortgage schedule
    const currentSchedule = buildSchedule(currentBalance, currentRate, currentRemaining);
    const currentMonthly = calcPI(currentBalance, currentRate, currentRemaining);
    const currentTotalInterest = currentSchedule.length > 0 ? currentSchedule[currentSchedule.length - 1].totalInterest : 0;
    const currentTotalCost = currentBalance + currentTotalInterest;

    // New mortgage schedule
    const newSchedule = buildSchedule(currentBalance, newRate, newTerm);
    const newMonthly = calcPI(currentBalance, newRate, newTerm);
    const newTotalInterest = newSchedule.length > 0 ? newSchedule[newSchedule.length - 1].totalInterest : 0;
    const newTotalCost = currentBalance + newTotalInterest + totalUpfrontCost;

    // Monthly savings (can be negative if new payment is higher)
    const monthlySavings = currentMonthly - newMonthly;

    // Total interest savings
    const interestSaved = currentTotalInterest - newTotalInterest;

    // Net savings after fees
    const netSavings = interestSaved - totalUpfrontCost;

    // Breakeven month
    let breakevenMonth = null;
    if (monthlySavings > 0) {
        breakevenMonth = Math.ceil(totalUpfrontCost / monthlySavings);
    }

    // Update current side
    document.getElementById('current-payment').textContent = fmt(currentMonthly);
    document.getElementById('current-total-interest').textContent = fmt(currentTotalInterest);
    document.getElementById('current-total-cost').textContent = fmt(currentTotalCost);

    // Update new side
    document.getElementById('new-payment').textContent = fmt(newMonthly);
    document.getElementById('new-total-interest').textContent = fmt(newTotalInterest);
    document.getElementById('new-total-cost').textContent = fmt(newTotalCost);

    // Summary cards
    const summaryMonthlyEl = document.getElementById('summary-monthly');
    summaryMonthlyEl.textContent = (monthlySavings >= 0 ? '' : '+') + fmt(Math.abs(monthlySavings));
    summaryMonthlyEl.className = 'summary-card-value ' + (monthlySavings >= 0 ? 'green' : 'red');
    if (monthlySavings < 0) summaryMonthlyEl.textContent = '+' + fmt(Math.abs(monthlySavings));
    else summaryMonthlyEl.textContent = fmt(monthlySavings);

    const summaryInterestEl = document.getElementById('summary-interest');
    summaryInterestEl.textContent = fmt(interestSaved);
    summaryInterestEl.className = 'summary-card-value ' + (interestSaved >= 0 ? 'green' : 'red');

    const summaryBreakevenEl = document.getElementById('summary-breakeven');
    if (breakevenMonth !== null && breakevenMonth > 0) {
        const yrs = Math.floor(breakevenMonth / 12);
        const mos = breakevenMonth % 12;
        summaryBreakevenEl.textContent = yrs > 0 ? yrs + 'y ' + mos + 'm' : mos + ' mo';
    } else if (monthlySavings <= 0) {
        summaryBreakevenEl.textContent = 'Never';
    } else {
        summaryBreakevenEl.textContent = '0 mo';
    }

    const summaryNetEl = document.getElementById('summary-net');
    summaryNetEl.textContent = fmt(netSavings);
    summaryNetEl.className = 'summary-card-value ' + (netSavings >= 0 ? 'green' : 'red');

    // Verdict
    const verdictIcon = document.getElementById('verdict-icon');
    const verdictTitle = document.getElementById('verdict-title');
    const verdictDetail = document.getElementById('verdict-detail');
    verdictTitle.className = 'verdict-title';

    if (currentBalance <= 0) {
        verdictIcon.textContent = '';
        verdictTitle.textContent = 'Enter your loan details';
        verdictTitle.classList.add('maybe');
        verdictDetail.textContent = 'Fill in your current mortgage and refinance terms to see if refinancing makes sense.';
    } else if (netSavings > 0 && breakevenMonth !== null && breakevenMonth <= 36) {
        verdictIcon.textContent = '';
        verdictTitle.textContent = 'Yes — Refinancing Saves You Money';
        verdictTitle.classList.add('yes');
        verdictDetail.textContent = 'You\'ll break even in just ' + breakevenMonth + ' months and save ' + fmt(netSavings) + ' over the life of the loan. With a breakeven under 3 years, this refinance is a strong financial move.';
    } else if (netSavings > 0 && breakevenMonth !== null && breakevenMonth <= 60) {
        verdictIcon.textContent = '';
        verdictTitle.textContent = 'Probably — If You\'ll Stay Long Enough';
        verdictTitle.classList.add('maybe');
        verdictDetail.textContent = 'You\'ll break even in ' + breakevenMonth + ' months and save ' + fmt(netSavings) + ' total. This makes sense if you plan to keep the home at least ' + Math.ceil(breakevenMonth / 12) + ' more years.';
    } else if (netSavings > 0) {
        verdictIcon.textContent = '';
        verdictTitle.textContent = 'Maybe — Long Breakeven Period';
        verdictTitle.classList.add('maybe');
        verdictDetail.textContent = 'While you\'d save ' + fmt(netSavings) + ' total, it takes ' + breakevenMonth + ' months to break even. Only refinance if you\'re confident you\'ll stay in the home that long.';
    } else {
        verdictIcon.textContent = '';
        verdictTitle.textContent = 'No — Refinancing Costs More';
        verdictTitle.classList.add('no');
        if (monthlySavings <= 0) {
            verdictDetail.textContent = 'Your new monthly payment would be higher, and the total cost increases by ' + fmt(Math.abs(netSavings)) + '. Refinancing doesn\'t make financial sense with these terms.';
        } else {
            verdictDetail.textContent = 'Although your monthly payment drops by ' + fmt(monthlySavings) + ', the closing costs and fees outweigh the interest savings by ' + fmt(Math.abs(netSavings)) + '. Consider negotiating lower closing costs or waiting for a better rate.';
        }
    }

    // Comparison table
    const currentTermMonths = currentRemaining * 12;
    const newTermMonths = newTerm * 12;
    const compRows = [
        ['Monthly Payment', fmt(currentMonthly), fmt(newMonthly), (monthlySavings >= 0 ? '-' : '+') + fmt(Math.abs(monthlySavings))],
        ['Interest Rate', currentRate.toFixed(3) + '%', newRate.toFixed(3) + '%', (currentRate - newRate >= 0 ? '-' : '+') + Math.abs(currentRate - newRate).toFixed(3) + '%'],
        ['Loan Term', currentRemaining + ' years', newTerm + ' years', (currentRemaining - newTerm) + ' years'],
        ['Total Interest', fmt(currentTotalInterest), fmt(newTotalInterest), fmt(interestSaved)],
        ['Upfront Costs', fmt(0), fmt(totalUpfrontCost), '+' + fmt(totalUpfrontCost)],
        ['Total Cost', fmt(currentTotalCost), fmt(newTotalCost), fmt(currentTotalCost - newTotalCost)],
    ];

    const compTbody = document.getElementById('comparison-tbody');
    compTbody.innerHTML = compRows.map((row, i) => {
        const cls = i === compRows.length - 1 ? ' class="highlight-row"' : '';
        return '<tr' + cls + '><td>' + row[0] + '</td><td>' + row[1] + '</td><td>' + row[2] + '</td><td>' + row[3] + '</td></tr>';
    }).join('');

    // Draw chart
    drawSavingsChart(currentMonthly, newMonthly, totalUpfrontCost, currentSchedule.length, newSchedule.length);
}

function drawSavingsChart(currentMonthly, newMonthly, upfrontCost, currentMonths, newMonths) {
    const canvas = document.getElementById('savingsChart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;

    const rect = canvas.parentElement.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    ctx.scale(dpr, dpr);

    const W = rect.width;
    const H = rect.height;
    const pad = { top: 30, right: 30, bottom: 50, left: 70 };
    const chartW = W - pad.left - pad.right;
    const chartH = H - pad.top - pad.bottom;

    ctx.clearRect(0, 0, W, H);

    const monthlySavings = currentMonthly - newMonthly;
    const maxMonths = Math.max(currentMonths, newMonths);

    // Build cumulative savings data (savings minus upfront cost)
    const data = [];
    for (let m = 0; m <= maxMonths; m++) {
        // Each month you save monthlySavings, but you paid upfrontCost at month 0
        const cumSavings = (m * monthlySavings) - upfrontCost;
        data.push(cumSavings);
    }

    const minVal = Math.min(...data, 0);
    const maxVal = Math.max(...data, 0);
    const range = maxVal - minVal || 1;

    const textColor = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#888';
    const borderColor = getComputedStyle(document.documentElement).getPropertyValue('--border-color').trim() || '#333';
    const accentColor = getComputedStyle(document.documentElement).getPropertyValue('--accent-color').trim() || '#D4A017';

    // Grid lines
    ctx.strokeStyle = borderColor;
    ctx.lineWidth = 0.5;
    const gridLines = 5;
    ctx.font = '11px system-ui, sans-serif';
    ctx.fillStyle = textColor;
    ctx.textAlign = 'right';

    for (let i = 0; i <= gridLines; i++) {
        const val = minVal + (range * i / gridLines);
        const y = pad.top + chartH - (chartH * (val - minVal) / range);
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(pad.left + chartW, y);
        ctx.stroke();
        ctx.fillText(fmt(val), pad.left - 8, y + 4);
    }

    // Zero line
    const zeroY = pad.top + chartH - (chartH * (0 - minVal) / range);
    ctx.strokeStyle = textColor;
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(pad.left, zeroY);
    ctx.lineTo(pad.left + chartW, zeroY);
    ctx.stroke();
    ctx.setLineDash([]);

    // X-axis labels
    ctx.textAlign = 'center';
    ctx.fillStyle = textColor;
    const xSteps = Math.min(maxMonths, 10);
    for (let i = 0; i <= xSteps; i++) {
        const m = Math.round((maxMonths / xSteps) * i);
        const x = pad.left + (chartW * m / maxMonths);
        ctx.fillText(m + ' mo', x, H - pad.bottom + 20);
    }

    // X-axis title
    ctx.fillText('Months After Refinance', pad.left + chartW / 2, H - 5);

    // Draw the savings line with gradient coloring
    if (data.length > 1) {
        // Fill area under/above zero
        ctx.beginPath();
        ctx.moveTo(pad.left, zeroY);
        for (let i = 0; i < data.length; i++) {
            const x = pad.left + (chartW * i / maxMonths);
            const y = pad.top + chartH - (chartH * (data[i] - minVal) / range);
            ctx.lineTo(x, y);
        }
        ctx.lineTo(pad.left + (chartW * (data.length - 1) / maxMonths), zeroY);
        ctx.closePath();

        // Gradient fill
        const grad = ctx.createLinearGradient(0, pad.top, 0, pad.top + chartH);
        grad.addColorStop(0, 'rgba(80, 227, 194, 0.15)');
        grad.addColorStop(0.5, 'rgba(80, 227, 194, 0.05)');
        grad.addColorStop(1, 'rgba(226, 92, 92, 0.15)');
        ctx.fillStyle = grad;
        ctx.fill();

        // Savings line
        ctx.beginPath();
        for (let i = 0; i < data.length; i++) {
            const x = pad.left + (chartW * i / maxMonths);
            const y = pad.top + chartH - (chartH * (data[i] - minVal) / range);
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = accentColor;
        ctx.lineWidth = 2.5;
        ctx.stroke();

        // Breakeven marker
        if (monthlySavings > 0) {
            const beMonth = Math.ceil(upfrontCost / monthlySavings);
            if (beMonth <= maxMonths && beMonth >= 0) {
                const bx = pad.left + (chartW * beMonth / maxMonths);
                const by = pad.top + chartH - (chartH * (data[beMonth] - minVal) / range);

                ctx.beginPath();
                ctx.arc(bx, by, 6, 0, Math.PI * 2);
                ctx.fillStyle = accentColor;
                ctx.fill();
                ctx.strokeStyle = 'rgba(0,0,0,0.3)';
                ctx.lineWidth = 1;
                ctx.stroke();

                ctx.fillStyle = textColor;
                ctx.font = 'bold 11px system-ui, sans-serif';
                ctx.textAlign = 'center';
                ctx.fillText('Breakeven', bx, by - 14);
                ctx.font = '11px system-ui, sans-serif';
                ctx.fillText('Month ' + beMonth, bx, by - 3 + 22);
            }
        }
    }
}

// Wire up inputs
const inputIds = ['current-balance', 'current-rate', 'current-remaining', 'new-rate', 'new-term', 'closing-costs', 'points'];
inputIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', calculate);
});

// Initial calc
calculate();

// Redraw chart on resize
let resizeTimer;
window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(calculate, 150);
});
  </script>

