---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Lease vs Buy Car Calculator",
  "url": "https://firemaths.info/car-lease-vs-buy",
  "description": "Compare the total cost of leasing versus buying a car over 3, 5, or 7 years. See breakeven analysis, equity position, cost per mile, and a clear verdict with savings amount.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is it cheaper to lease or buy a car?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on how long you plan to keep the vehicle. Leasing typically costs less per month but you never build equity. Buying costs more upfront and in monthly payments, but once the loan is paid off you own an asset. Over 5-7 years, buying is almost always cheaper because you avoid perpetual lease payments. However, if you prefer driving a new car every 2-3 years, leasing may suit your lifestyle despite the higher long-term cost."
      }
    },
    {
      "@type": "Question",
      "name": "What is a residual value in a car lease?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The residual value is the estimated worth of the vehicle at the end of the lease term. It is set by the leasing company at the start of the lease and determines how much depreciation you pay for. A higher residual value means lower monthly payments because you're financing a smaller portion of the car's depreciation. Residual values are typically expressed as a percentage of MSRP — for example, a 55% residual on a $40,000 car means the car is expected to be worth $22,000 at lease end."
      }
    },
    {
      "@type": "Question",
      "name": "What happens when a car lease ends?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "At the end of a car lease, you typically have three options: return the vehicle and walk away, purchase the vehicle at the predetermined residual value, or trade it in and start a new lease. If you return the car, you may owe fees for excess mileage (usually $0.15-$0.25 per mile over the limit) and any wear and tear beyond normal use. If the car is worth more than the residual value, buying it can be a good deal."
      }
    },
    {
      "@type": "Question",
      "name": "How does mileage affect lease vs buy decisions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Leases come with annual mileage limits, typically 10,000-15,000 miles per year. Exceeding the limit incurs per-mile charges of $0.15-$0.25. If you drive more than 15,000 miles annually, buying is usually the better financial choice because you avoid mileage penalties. High-mileage drivers who lease often pay significantly more than expected due to excess mileage fees at lease end."
      }
    },
    {
      "@type": "Question",
      "name": "Should I put a down payment on a lease?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Financial experts generally advise against large down payments on leases. Unlike buying, where a down payment builds equity, a lease down payment simply prepays depreciation. If the car is totaled or stolen early in the lease, you may lose that down payment entirely since gap insurance only covers the remaining lease balance, not your upfront cash. A small down payment or first month's payment is usually sufficient."
      }
    }
  ]
};

export const meta = {
  title: "Lease vs Buy Car Calculator | firemaths.info",
  description: "Compare the total cost of leasing versus buying a car over 3, 5, or 7 years. Breakeven analysis, equity tracking, cost per mile, and clear verdict with savings amount.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Lease vs Buy Car Calculator | firemaths.info"
  description="Compare the total cost of leasing versus buying a car over 3, 5, or 7 years. Breakeven analysis, equity tracking, cost per mile, and clear verdict with savings amount."
  canonical="https://firemaths.info/car-lease-vs-buy" schema={schema}
>
  <style>
:root {
    --color-lease: #E25C5C;
    --color-buy: #4A90E2;
    --color-savings: #50E3C2;
    --color-equity: #9B59B6;
    --color-depreciation: #D4A017;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

select {
    font-family: var(--font-ui);
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23888888' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1em;
    padding-right: 2.5rem;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.verdict-card {
    background-color: var(--card-bg);
    border: 2px solid var(--accent-color);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    margin-bottom: 2rem;
}

.verdict-title {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.verdict-winner {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-color);
    margin-bottom: 0.25rem;
}

.verdict-savings {
    font-size: 1.25rem;
    font-family: var(--font-mono);
    color: var(--color-savings);
    margin-bottom: 1rem;
}

.verdict-detail {
    font-size: 0.875rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
}

.cost-comparison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

@media (max-width: 600px) {
    .cost-comparison {
        grid-template-columns: 1fr;
    }
}

.cost-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.cost-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.cost-card-header h3 {
    font-size: 1.125rem;
}

.cost-card-header .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
}

.cost-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
}

.cost-item-label {
    color: var(--text-secondary);
}

.cost-item-value {
    font-family: var(--font-mono);
    font-weight: 500;
}

.cost-total {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border-color);
    font-size: 1rem;
}

.cost-total .cost-item-value {
    font-size: 1.25rem;
    font-weight: 700;
}

.section-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.section-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.chart-container {
    position: relative;
    width: 100%;
    height: 300px;
    margin-bottom: 1rem;
}

.chart-container canvas {
    width: 100%;
    height: 100%;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 2rem;
    font-size: 0.875rem;
}

.chart-legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.chart-legend-color {
    width: 14px;
    height: 3px;
    border-radius: 2px;
}

.comparison-table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}

.comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
}

.comparison-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 600;
    text-align: right;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--border-color);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.comparison-table th:first-child {
    text-align: left;
}

.comparison-table td {
    padding: 0.75rem 1rem;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
    font-family: var(--font-mono);
    color: var(--text-secondary);
}

.comparison-table td:first-child {
    text-align: left;
    font-family: var(--font-ui);
    font-weight: 500;
    color: var(--text-primary);
}

.comparison-table tbody tr:hover {
    background: rgba(212, 160, 23, 0.05);
}

.comparison-table .highlight-row {
    background: rgba(212, 160, 23, 0.08);
}

.comparison-table .highlight-row td {
    color: var(--text-primary);
}

.winner-cell {
    color: var(--color-savings) !important;
    font-weight: 600;
}

.toggle-group {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
}

.toggle-btn {
    flex: 1;
    padding: 0.6rem 1rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    transition: all 0.2s;
}

.toggle-btn:first-child { border-radius: 6px 0 0 6px; }
.toggle-btn:last-child { border-radius: 0 6px 6px 0; }

.toggle-btn.active {
    background: var(--accent-color);
    color: #0c0a00;
    border-color: var(--accent-color);
    font-weight: 600;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1.25rem 0;
}

.faq-question {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-size: 1rem;
}

.faq-answer {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
}

.related-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
    margin-bottom: 4rem;
}

.related-link {
    display: block;
    padding: 1.25rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    transition: border-color 0.2s;
}

.related-link:hover {
    border-color: var(--accent-color);
}

.related-link span {
    display: block;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-top: 0.25rem;
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Lease vs Buy Car Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:3rem;">Compare the total cost of leasing versus buying a car and find out which option saves you more money.</p>

    <main>
        <!-- Shared Inputs -->
        <div class="scenario-card" style="margin-bottom: 2rem;">
            <div class="scenario-header">
                <h2>Vehicle Details</h2>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="input-group">
                    <label for="vehicle-price">Vehicle Price (MSRP)</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="vehicle-price" value="40000" min="0" step="500">
                    </div>
                </div>
                <div class="input-group">
                    <label for="down-payment">Down Payment</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="down-payment" value="5000" min="0" step="500">
                    </div>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                <div class="input-group">
                    <label for="sales-tax">Sales Tax Rate</label>
                    <div class="input-wrapper has-suffix">
                        <span class="suffix">%</span>
                        <input type="number" id="sales-tax" value="6" min="0" max="15" step="0.25">
                    </div>
                </div>
                <div class="input-group">
                    <label for="expected-miles">Expected Miles/Year</label>
                    <div class="input-wrapper">
                        <input type="number" id="expected-miles" value="12000" min="0" step="1000">
                    </div>
                </div>
                <div class="input-group">
                    <label for="depreciation-rate">Annual Depreciation</label>
                    <div class="input-wrapper has-suffix">
                        <span class="suffix">%</span>
                        <input type="number" id="depreciation-rate" value="15" min="0" max="50" step="1">
                    </div>
                </div>
            </div>
        </div>

        <!-- Lease + Buy side by side -->
        <div class="calculator-grid">
            <!-- Lease Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2><span class="dot" style="display:inline-block;width:12px;height:12px;border-radius:50%;background:var(--color-lease);"></span> Lease Terms</h2>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="lease-monthly">Monthly Payment</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="lease-monthly" value="450" min="0" step="25">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="lease-term">Lease Term</label>
                        <div class="input-wrapper">
                            <select id="lease-term">
                                <option value="24">24 months</option>
                                <option value="36" selected>36 months</option>
                                <option value="39">39 months</option>
                                <option value="48">48 months</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="lease-residual">Residual Value</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="lease-residual" value="55" min="0" max="90" step="1">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="lease-miles-limit">Mileage Limit/Year</label>
                        <div class="input-wrapper">
                            <input type="number" id="lease-miles-limit" value="12000" min="0" step="1000">
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="lease-excess-mile">Excess Mile Fee</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="lease-excess-mile" value="0.20" min="0" max="1" step="0.05">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="lease-insurance-diff">Insurance Premium (mo)</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="lease-insurance-diff" value="180" min="0" step="10">
                        </div>
                    </div>
                </div>

                <div class="input-group">
                    <label for="lease-maintenance">Maintenance/Month</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="lease-maintenance" value="25" min="0" step="5">
                    </div>
                </div>
            </div>

            <!-- Buy Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2><span class="dot" style="display:inline-block;width:12px;height:12px;border-radius:50%;background:var(--color-buy);"></span> Buy / Finance Terms</h2>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="buy-rate">Interest Rate (APR)</label>
                        <div class="input-wrapper has-suffix">
                            <span class="suffix">%</span>
                            <input type="number" id="buy-rate" value="6.5" min="0" max="30" step="0.1">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="buy-term">Loan Term</label>
                        <div class="input-wrapper">
                            <select id="buy-term">
                                <option value="36">36 months</option>
                                <option value="48">48 months</option>
                                <option value="60" selected>60 months</option>
                                <option value="72">72 months</option>
                                <option value="84">84 months</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="input-group">
                        <label for="buy-insurance">Insurance Premium (mo)</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="buy-insurance" value="150" min="0" step="10">
                        </div>
                    </div>
                    <div class="input-group">
                        <label for="buy-maintenance">Maintenance/Month</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="buy-maintenance" value="50" min="0" step="5">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Verdict -->
        <div class="verdict-card" id="verdict-card">
            <div class="verdict-title">The Verdict</div>
            <div class="verdict-winner" id="verdict-winner">Calculating...</div>
            <div class="verdict-savings" id="verdict-savings"></div>
            <div class="verdict-detail" id="verdict-detail"></div>
        </div>

        <!-- Cost Summary Cards -->
        <div class="cost-comparison">
            <div class="cost-card">
                <div class="cost-card-header">
                    <span class="dot" style="background:var(--color-lease);"></span>
                    <h3>Lease Cost</h3>
                </div>
                <div class="cost-item">
                    <span class="cost-item-label">Down Payment</span>
                    <span class="cost-item-value" id="lease-cost-down">$0</span>
                </div>
                <div class="cost-item">
                    <span class="cost-item-label">Monthly Payments</span>
                    <span class="cost-item-value" id="lease-cost-payments">$0</span>
                </div>
                <div class="cost-item">
                    <span class="cost-item-label">Insurance</span>
                    <span class="cost-item-value" id="lease-cost-insurance">$0</span>
                </div>
                <div class="cost-item">
                    <span class="cost-item-label">Maintenance</span>
                    <span class="cost-item-value" id="lease-cost-maintenance">$0</span>
                </div>
                <div class="cost-item">
                    <span class="cost-item-label">Excess Mileage Fees</span>
                    <span class="cost-item-value" id="lease-cost-mileage">$0</span>
                </div>
                <div class="cost-item">
                    <span class="cost-item-label">Equity at End</span>
