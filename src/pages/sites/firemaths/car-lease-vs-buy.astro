  <script is:inline>
const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);
const fmt2 = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(v);

let cpmYears = 3;

function getInputs() {
    const vehiclePrice = parseFloat(document.getElementById('vehicle-price').value) || 0;
    const downPayment = parseFloat(document.getElementById('down-payment').value) || 0;
    const salesTaxRate = parseFloat(document.getElementById('sales-tax').value) || 0;
    const expectedMiles = parseFloat(document.getElementById('expected-miles').value) || 0;
    const depreciationRate = parseFloat(document.getElementById('depreciation-rate').value) || 0;

    const leaseMonthly = parseFloat(document.getElementById('lease-monthly').value) || 0;
    const leaseTerm = parseInt(document.getElementById('lease-term').value) || 36;
    const leaseResidual = parseFloat(document.getElementById('lease-residual').value) || 0;
    const leaseMilesLimit = parseFloat(document.getElementById('lease-miles-limit').value) || 0;
    const leaseExcessMileFee = parseFloat(document.getElementById('lease-excess-mile').value) || 0;
    const leaseInsurance = parseFloat(document.getElementById('lease-insurance-diff').value) || 0;
    const leaseMaintenance = parseFloat(document.getElementById('lease-maintenance').value) || 0;

    const buyRate = parseFloat(document.getElementById('buy-rate').value) || 0;
    const buyTerm = parseInt(document.getElementById('buy-term').value) || 60;
    const buyInsurance = parseFloat(document.getElementById('buy-insurance').value) || 0;
    const buyMaintenance = parseFloat(document.getElementById('buy-maintenance').value) || 0;

    return {
        vehiclePrice, downPayment, salesTaxRate, expectedMiles, depreciationRate,
        leaseMonthly, leaseTerm, leaseResidual, leaseMilesLimit, leaseExcessMileFee, leaseInsurance, leaseMaintenance,
        buyRate, buyTerm, buyInsurance, buyMaintenance
    };
}

function calcPayment(principal, annualRate, termMonths) {
    if (principal <= 0) return 0;
    if (annualRate <= 0) return principal / termMonths;
    const r = annualRate / 100 / 12;
    const n = termMonths;
    return principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
}

function getLoanBalance(principal, annualRate, termMonths, monthsPaid) {
    if (principal <= 0) return 0;
    if (monthsPaid >= termMonths) return 0;
    if (annualRate <= 0) return principal * (1 - monthsPaid / termMonths);
    const r = annualRate / 100 / 12;
    const balance = principal * (Math.pow(1 + r, monthsPaid) - Math.pow(1 + r, termMonths)) / (1 - Math.pow(1 + r, termMonths));
    return Math.max(0, -balance);
}

function getCarValue(price, depRate, years) {
    // First year ~20% depreciation, then depRate% per year
    if (years <= 0) return price;
    let value = price * 0.80; // year 1
    for (let y = 1; y < years; y++) {
        value *= (1 - depRate / 100);
    }
    return Math.max(0, value);
}

function calcLeaseForYears(inp, years) {
    const totalMonths = years * 12;
    const leaseTermMonths = inp.leaseTerm;
    const numLeases = Math.ceil(totalMonths / leaseTermMonths);
    const actualMonths = Math.min(totalMonths, numLeases * leaseTermMonths);

    let totalPayments = 0;
    let totalDown = 0;
    let totalInsurance = 0;
    let totalMaintenance = 0;
    let totalMileageFees = 0;

    for (let lease = 0; lease < numLeases; lease++) {
        const startMonth = lease * leaseTermMonths;
        const endMonth = Math.min(startMonth + leaseTermMonths, totalMonths);
        const months = endMonth - startMonth;

        totalDown += (lease === 0) ? inp.downPayment : 0;
        totalPayments += inp.leaseMonthly * months;
        totalInsurance += inp.leaseInsurance * months;
        totalMaintenance += inp.leaseMaintenance * months;

        // Excess mileage for this lease period
        const leaseYears = months / 12;
        const totalMilesDriven = inp.expectedMiles * leaseYears;
        const mileageAllowance = inp.leaseMilesLimit * leaseYears;
        const excessMiles = Math.max(0, totalMilesDriven - mileageAllowance);
        totalMileageFees += excessMiles * inp.leaseExcessMileFee;
    }

    return {
        downPayment: totalDown,
        payments: totalPayments,
        insurance: totalInsurance,
        maintenance: totalMaintenance,
        mileageFees: totalMileageFees,
        equity: 0, // no equity with lease
        total: totalDown + totalPayments + totalInsurance + totalMaintenance + totalMileageFees
    };
}

function calcBuyForYears(inp, years) {
    const totalMonths = years * 12;
    const salesTax = inp.vehiclePrice * inp.salesTaxRate / 100;
    const loanAmount = Math.max(0, inp.vehiclePrice + salesTax - inp.downPayment);
    const monthlyPayment = calcPayment(loanAmount, inp.buyRate, inp.buyTerm);
    const loanMonths = Math.min(totalMonths, inp.buyTerm);

    const totalLoanPayments = monthlyPayment * loanMonths;
    const totalInterest = totalLoanPayments - (loanAmount - getLoanBalance(loanAmount, inp.buyRate, inp.buyTerm, loanMonths));
    const totalInsurance = inp.buyInsurance * totalMonths;
    const totalMaintenance = inp.buyMaintenance * totalMonths;
    const carValue = getCarValue(inp.vehiclePrice, inp.depreciationRate, years);

    const totalSpent = inp.downPayment + totalLoanPayments + totalInsurance + totalMaintenance;
    const netCost = totalSpent - carValue;

    return {
        downPayment: inp.downPayment,
        payments: totalLoanPayments,
        salesTax: salesTax,
        interest: totalInterest,
        insurance: totalInsurance,
        maintenance: totalMaintenance,
        carValue: carValue,
        loanAmount: loanAmount,
        total: totalSpent,
        netCost: netCost
    };
}

function calculate() {
    const inp = getInputs();

    // Use the selected CPM view years for verdict (default 5)
    const verdictYears = 5;
    const lease5 = calcLeaseForYears(inp, verdictYears);
    const buy5 = calcBuyForYears(inp, verdictYears);

    // Verdict
    const leaseCost5 = lease5.total;
    const buyCost5 = buy5.netCost;
    const diff = Math.abs(leaseCost5 - buyCost5);
    const winner = buyCost5 < leaseCost5 ? 'Buying' : 'Leasing';
    const loser = buyCost5 < leaseCost5 ? 'leasing' : 'buying';

    document.getElementById('verdict-winner').innerText = winner + ' Wins Over 5 Years';
    document.getElementById('verdict-savings').innerText = 'You save ' + fmt(diff);
    document.getElementById('verdict-detail').innerText = winner + ' saves you ' + fmt(diff) + ' compared to ' + loser + ' over 5 years. ' +
        (winner === 'Buying' ? 'After paying off your loan, you own an asset worth ' + fmt(buy5.carValue) + ' while lease payments continue indefinitely.' :
        'Lower monthly costs and no depreciation risk make leasing the better financial choice for your situation.');

    // Cost summary cards (use 5-year view)
    document.getElementById('lease-cost-down').innerText = fmt(lease5.downPayment);
    document.getElementById('lease-cost-payments').innerText = fmt(lease5.payments);
    document.getElementById('lease-cost-insurance').innerText = fmt(lease5.insurance);
    document.getElementById('lease-cost-maintenance').innerText = fmt(lease5.maintenance);
    document.getElementById('lease-cost-mileage').innerText = fmt(lease5.mileageFees);
    document.getElementById('lease-cost-equity').innerText = '$0';
    document.getElementById('lease-cost-total').innerText = fmt(lease5.total);

    document.getElementById('buy-cost-down').innerText = fmt(buy5.downPayment);
    document.getElementById('buy-cost-payments').innerText = fmt(buy5.payments);
    document.getElementById('buy-cost-tax').innerText = fmt(buy5.salesTax);
    document.getElementById('buy-cost-interest').innerText = fmt(buy5.interest);
    document.getElementById('buy-cost-insurance').innerText = fmt(buy5.insurance);
    document.getElementById('buy-cost-maintenance').innerText = fmt(buy5.maintenance);
    document.getElementById('buy-cost-value').innerText = '-' + fmt(buy5.carValue);
    document.getElementById('buy-cost-total').innerText = fmt(buy5.netCost);

    // Year-by-year table
    renderYearlyTable(inp);

    // Charts
    drawCostChart(inp);
    drawEquityChart(inp);

    // Cost per mile
    renderCPM(inp);
}

function renderYearlyTable(inp) {
    const tbody = document.getElementById('yearly-tbody');
    let html = '';

    for (let y = 1; y <= 7; y++) {
        const lease = calcLeaseForYears(inp, y);
        const buy = calcBuyForYears(inp, y);
        const diff = lease.total - buy.netCost;
        const w = diff > 0 ? 'Buy' : diff < 0 ? 'Lease' : 'Tie';
        const cls = (y === 3 || y === 5 || y === 7) ? ' class="highlight-row"' : '';

        html += `<tr${cls}>`;
        html += `<td>Year ${y}</td>`;
        html += `<td>${fmt(lease.total)}</td>`;
        html += `<td>${fmt(buy.total)}</td>`;
        html += `<td style="color:var(--color-equity);">${fmt(buy.carValue)}</td>`;
        html += `<td>${fmt(buy.netCost)}</td>`;
        html += `<td style="color:${diff > 0 ? 'var(--color-savings)' : 'var(--color-lease)'};">${diff > 0 ? '+' : ''}${fmt(diff)}</td>`;
        html += `<td class="winner-cell">${w}</td>`;
        html += '</tr>';
    }
    tbody.innerHTML = html;
}

function drawCostChart(inp) {
    const canvas = document.getElementById('costChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const width = container.getBoundingClientRect().width;
    const height = 300;

    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = width + 'px';
    canvas.style.height = height + 'px';
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, width, height);

    const years = [0, 1, 2, 3, 4, 5, 6, 7];
    const leaseData = years.map(y => y === 0 ? 0 : calcLeaseForYears(inp, y).total);
    const buyData = years.map(y => y === 0 ? 0 : calcBuyForYears(inp, y).netCost);

    const allValues = [...leaseData, ...buyData];
    const maxVal = Math.max(...allValues) * 1.1;
    const minVal = Math.min(0, ...allValues);

    const padL = 70, padR = 20, padT = 20, padB = 40;
    const chartW = width - padL - padR;
    const chartH = height - padT - padB;

    const toX = (i) => padL + (i / 7) * chartW;
    const toY = (v) => padT + chartH - ((v - minVal) / (maxVal - minVal)) * chartH;

    // Grid lines
    ctx.strokeStyle = 'rgba(128,128,128,0.15)';
    ctx.lineWidth = 1;
    const gridSteps = 5;
    for (let i = 0; i <= gridSteps; i++) {
        const val = minVal + (maxVal - minVal) * i / gridSteps;
        const y = toY(val);
        ctx.beginPath();
        ctx.moveTo(padL, y);
        ctx.lineTo(width - padR, y);
        ctx.stroke();

        ctx.fillStyle = '#888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText('$' + Math.round(val / 1000) + 'k', padL - 8, y);
    }

    // X axis labels
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    for (const y of years) {
        ctx.fillStyle = '#888';
        ctx.font = '11px Inter, sans-serif';
        ctx.fillText('Yr ' + y, toX(y), height - padB + 10);
    }

    // Draw lines
    function drawLine(data, color) {
        ctx.strokeStyle = color;
        ctx.lineWidth = 2.5;
        ctx.lineJoin = 'round';
        ctx.beginPath();
        for (let i = 0; i < data.length; i++) {
            const x = toX(i);
            const y = toY(data[i]);
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        }
        ctx.stroke();

        // Dots
        for (let i = 0; i < data.length; i++) {
            ctx.beginPath();
            ctx.arc(toX(i), toY(data[i]), 3.5, 0, Math.PI * 2);
            ctx.fillStyle = color;
            ctx.fill();
        }
    }

    drawLine(leaseData, '#E25C5C');
    drawLine(buyData, '#4A90E2');
}

function drawEquityChart(inp) {
    const canvas = document.getElementById('equityChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.parentElement;
    const width = container.getBoundingClientRect().width;
    const height = 300;

    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = width + 'px';
    canvas.style.height = height + 'px';
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, width, height);

    const salesTax = inp.vehiclePrice * inp.salesTaxRate / 100;
    const loanAmount = Math.max(0, inp.vehiclePrice + salesTax - inp.downPayment);

    const years = [0, 1, 2, 3, 4, 5, 6, 7];
    const carValues = years.map(y => getCarValue(inp.vehiclePrice, inp.depreciationRate, y));
    const loanBalances = years.map(y => getLoanBalance(loanAmount, inp.buyRate, inp.buyTerm, y * 12));
    const equityData = years.map((y, i) => carValues[i] - loanBalances[i]);

    const allValues = [...carValues, ...loanBalances, ...equityData];
    const maxVal = Math.max(...allValues) * 1.1;
    const minVal = Math.min(0, ...allValues) * 1.1;

    const padL = 70, padR = 20, padT = 20, padB = 40;
    const chartW = width - padL - padR;
    const chartH = height - padT - padB;

    const toX = (i) => padL + (i / 7) * chartW;
    const toY = (v) => padT + chartH - ((v - minVal) / (maxVal - minVal)) * chartH;

    // Grid
    ctx.strokeStyle = 'rgba(128,128,128,0.15)';
    ctx.lineWidth = 1;
    const gridSteps = 5;
    for (let i = 0; i <= gridSteps; i++) {
        const val = minVal + (maxVal - minVal) * i / gridSteps;
        const y = toY(val);
        ctx.beginPath();
        ctx.moveTo(padL, y);
        ctx.lineTo(width - padR, y);
        ctx.stroke();

        ctx.fillStyle = '#888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText('$' + Math.round(val / 1000) + 'k', padL - 8, y);
    }

    // X axis
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    for (const y of years) {
        ctx.fillStyle = '#888';
        ctx.font = '11px Inter, sans-serif';
        ctx.fillText('Yr ' + y, toX(y), height - padB + 10);
    }

    function drawLine(data, color, dashed) {
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.lineJoin = 'round';
        if (dashed) ctx.setLineDash([6, 4]);
        else ctx.setLineDash([]);
        ctx.beginPath();
        for (let i = 0; i < data.length; i++) {
            const x = toX(i);
            const y = toY(data[i]);
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
        }
        ctx.stroke();
        ctx.setLineDash([]);

        for (let i = 0; i < data.length; i++) {
            ctx.beginPath();
            ctx.arc(toX(i), toY(data[i]), 3, 0, Math.PI * 2);
            ctx.fillStyle = color;
            ctx.fill();
        }
    }

    drawLine(carValues, '#D4A017', false);
    drawLine(loanBalances, 'rgba(226,92,92,0.5)', true);
    drawLine(equityData, '#9B59B6', false);
}

function renderCPM(inp) {
    const y = cpmYears;
    const lease = calcLeaseForYears(inp, y);
    const buy = calcBuyForYears(inp, y);
    const totalMiles = inp.expectedMiles * y;

    const leaseCPM = totalMiles > 0 ? lease.total / totalMiles : 0;
    const buyCPM = totalMiles > 0 ? buy.netCost / totalMiles : 0;

    const rows = [
        { label: 'Total Cost', l: fmt(lease.total), b: fmt(buy.netCost) },
        { label: 'Total Miles', l: totalMiles.toLocaleString(), b: totalMiles.toLocaleString() },
        { label: 'Cost Per Mile', l: '$' + leaseCPM.toFixed(2), b: '$' + buyCPM.toFixed(2) },
        { label: 'Monthly Cost', l: fmt(lease.total / (y * 12)), b: fmt(buy.netCost / (y * 12)) },
    ];

    const tbody = document.getElementById('cpm-tbody');
    let html = '';
    for (const row of rows) {
        html += `<tr><td>${row.label}</td>`;
        const lWin = parseFloat(row.l.replace(/[^0-9.-]/g, '')) <= parseFloat(row.b.replace(/[^0-9.-]/g, ''));
        html += `<td${lWin ? ' class="winner-cell"' : ''}>${row.l}</td>`;
        html += `<td${!lWin ? ' class="winner-cell"' : ''}>${row.b}</td>`;
        html += '</tr>';
    }
    tbody.innerHTML = html;
}

window.setCpmView = (y) => {
    cpmYears = y;
    [3, 5, 7].forEach(v => {
        document.getElementById('btn-cpm-' + v).classList.toggle('active', v === y);
    });
    renderCPM(getInputs());
};

// Attach listeners
const allInputs = [
    'vehicle-price', 'down-payment', 'sales-tax', 'expected-miles', 'depreciation-rate',
    'lease-monthly', 'lease-term', 'lease-residual', 'lease-miles-limit', 'lease-excess-mile', 'lease-insurance-diff', 'lease-maintenance',
    'buy-rate', 'buy-term', 'buy-insurance', 'buy-maintenance'
];
allInputs.forEach(id => {
    document.getElementById(id).addEventListener('input', calculate);
});

window.addEventListener('resize', calculate);

setTimeout(calculate, 0);
  </script>
