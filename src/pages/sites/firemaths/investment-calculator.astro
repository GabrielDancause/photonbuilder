  <script is:inline>
    const fmt = (v) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(v);

    window.copyValue = async (id, btn) => {
        const text = document.getElementById(id).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const orig = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => btn.innerText = orig, 2000);
        } catch (e) {}
    };

    function calcInvestment(initial, monthly, rate, years) {
        const mr = (rate / 100) / 12;
        const months = years * 12;
        let balance = initial;
        let contributions = initial;
        const yearlyData = [{ year: 0, contributions: initial, returns: 0, balance: initial }];

        for (let i = 1; i <= months; i++) {
            balance = balance * (1 + mr) + monthly;
            contributions += monthly;
            if (i % 12 === 0) {
                yearlyData.push({
                    year: i / 12,
                    contributions: contributions,
                    returns: balance - contributions,
                    balance: balance
                });
            }
        }

        return { balance, contributions, returns: balance - contributions, yearlyData };
    }

    function adjustForInflation(nominal, inflationRate, years) {
        return nominal / Math.pow(1 + inflationRate / 100, years);
    }

    // Chart
    let canvas = document.getElementById('growthChart');
    let ctx = canvas.getContext('2d');

    function drawChart(yearlyData) {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.parentElement.getBoundingClientRect();
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);

        const w = rect.width;
        const h = rect.height;
        ctx.clearRect(0, 0, w, h);

        const pad = { top: 20, right: 20, bottom: 40, left: 80 };
        const cw = w - pad.left - pad.right;
        const ch = h - pad.top - pad.bottom;

        const maxVal = Math.max(...yearlyData.map(d => d.balance));
        const totalYears = yearlyData[yearlyData.length - 1].year;

        // Grid
        ctx.strokeStyle = '#2a2010';
        ctx.lineWidth = 1;
        ctx.font = '12px Inter, sans-serif';
        ctx.fillStyle = '#888888';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        const yTicks = 5;
        for (let i = 0; i <= yTicks; i++) {
            const val = maxVal * (i / yTicks);
            const y = h - pad.bottom - (ch * (i / yTicks));
            ctx.beginPath();
            ctx.moveTo(pad.left, y);
            ctx.lineTo(w - pad.right, y);
            ctx.stroke();
            let label = val >= 1e6 ? '$' + (val / 1e6).toFixed(1) + 'M' : val >= 1000 ? '$' + (val / 1000).toFixed(0) + 'k' : '$' + val.toFixed(0);
            ctx.fillText(label, pad.left - 10, y);
        }

        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const xTicks = Math.min(totalYears, 10);
        for (let i = 0; i <= xTicks; i++) {
            const yr = Math.round((totalYears / xTicks) * i);
            const x = pad.left + (cw * (yr / totalYears));
            ctx.beginPath();
            ctx.moveTo(x, h - pad.bottom);
            ctx.lineTo(x, h - pad.bottom + 5);
            ctx.stroke();
            ctx.fillText('Yr ' + yr, x, h - pad.bottom + 10);
        }

        function drawArea(data, getVal, color) {
            ctx.beginPath();
            ctx.strokeStyle = color;
            ctx.lineWidth = 3;
            ctx.lineJoin = 'round';

            data.forEach((d, i) => {
                const x = pad.left + (cw * (d.year / totalYears));
                const y = h - pad.bottom - (ch * (getVal(d) / maxVal));
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.stroke();

            const last = data[data.length - 1];
            ctx.lineTo(pad.left + (cw * (last.year / totalYears)), h - pad.bottom);
            ctx.lineTo(pad.left, h - pad.bottom);
            ctx.closePath();

            const r = parseInt(color.slice(1, 3), 16);
            const g = parseInt(color.slice(3, 5), 16);
            const b = parseInt(color.slice(5, 7), 16);
            const grad = ctx.createLinearGradient(0, pad.top, 0, h - pad.bottom);
            grad.addColorStop(0, `rgba(${r},${g},${b},0.2)`);
            grad.addColorStop(1, `rgba(${r},${g},${b},0)`);
            ctx.fillStyle = grad;
            ctx.fill();
        }

        // Draw contributions first (behind), then total value
        drawArea(yearlyData, d => d.contributions, '#4A90E2');
        drawArea(yearlyData, d => d.balance, '#D4A017');
    }

    function buildTable(yearlyData) {
        const tbody = document.getElementById('breakdown-table');
        tbody.innerHTML = '';
        yearlyData.forEach(d => {
            if (d.year === 0) return;
            const tr = document.createElement('tr');
            tr.innerHTML = `<td>${d.year}</td><td>${fmt(d.contributions)}</td><td>${fmt(d.returns)}</td><td>${fmt(d.balance)}</td>`;
            tbody.appendChild(tr);
        });
    }

    function updateAll() {
        const initial = parseFloat(document.getElementById('initial-investment').value) || 0;
        const monthly = parseFloat(document.getElementById('monthly-contribution').value) || 0;
        const rate = parseFloat(document.getElementById('annual-return').value) || 0;
        const years = parseInt(document.getElementById('investment-years').value) || 1;
        const inflation = parseFloat(document.getElementById('inflation-rate').value) || 0;
        const tax = parseFloat(document.getElementById('tax-rate').value) || 0;

        const res = calcInvestment(initial, monthly, rate, years);

        // Main results
        document.getElementById('result-nominal').innerText = fmt(res.balance);
        document.getElementById('result-real').innerText = fmt(adjustForInflation(res.balance, inflation, years)) + ' inflation-adjusted';
        document.getElementById('result-contributions').innerText = fmt(res.contributions);
        document.getElementById('result-returns').innerText = fmt(res.returns);

        const afterTax = res.returns > 0 ? res.contributions + res.returns * (1 - tax / 100) : res.balance;
        document.getElementById('result-after-tax').innerText = fmt(afterTax) + ' after tax';

        // Effective annual return
        const effectiveRate = res.contributions > 0 ? (Math.pow(res.balance / res.contributions, 1 / years) - 1) * 100 : 0;
        const realEffective = effectiveRate - inflation;
        document.getElementById('result-effective').innerText = effectiveRate.toFixed(1) + '%';
        document.getElementById('result-effective-real').innerText = realEffective.toFixed(1) + '% real';

        // Chart
        drawChart(res.yearlyData);

        // Table
        buildTable(res.yearlyData);

        // Scenarios
        const scenarios = [
            { rate: 5, id: 'conservative' },
            { rate: 7, id: 'moderate' },
            { rate: 10, id: 'aggressive' }
        ];

        scenarios.forEach(s => {
            const r = calcInvestment(initial, monthly, s.rate, years);
            document.getElementById('scenario-' + s.id).innerText = fmt(r.balance);
            document.getElementById('scenario-' + s.id + '-real').innerText = fmt(adjustForInflation(r.balance, inflation, years));
        });
    }

    document.querySelectorAll('input[type="number"]').forEach(input => {
        input.addEventListener('input', updateAll);
    });

    window.addEventListener('resize', updateAll);
    setTimeout(updateAll, 0);
  </script>

