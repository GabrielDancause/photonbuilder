</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<script>
const STORAGE_KEY = 'firemaths_networth_history';

const benchmarks = [
    { range: 'Under 35', min: 0, max: 34, median: 39000, average: 183500 },
    { range: '35\u201344', min: 35, max: 44, median: 135600, average: 549600 },
    { range: '45\u201354', min: 45, max: 54, median: 247200, average: 975800 },
    { range: '55\u201364', min: 55, max: 64, median: 364500, average: 1566900 },
    { range: '65\u201374', min: 65, max: 74, median: 409900, average: 1794600 },
    { range: '75+', min: 75, max: 120, median: 335600, average: 1624100 },
];

function fmt(n) {
    if (Math.abs(n) >= 1e6) return (n < 0 ? '-' : '') + '$' + (Math.abs(n) / 1e6).toFixed(1) + 'M';
    if (Math.abs(n) >= 1e3) return (n < 0 ? '-$' : '$') + Math.abs(n).toLocaleString('en-US');
    return (n < 0 ? '-$' : '$') + Math.abs(n).toLocaleString('en-US');
}

function getVal(id) {
    return parseFloat(document.getElementById(id).value) || 0;
}

function calculate() {
    const assets = {
        cash: getVal('asset-cash'),
        investments: getVal('asset-investments'),
        retirement: getVal('asset-retirement'),
        realestate: getVal('asset-realestate'),
        vehicles: getVal('asset-vehicles'),
        other: getVal('asset-other'),
    };

    const liabilities = {
        mortgage: getVal('liability-mortgage'),
        carloan: getVal('liability-carloan'),
        student: getVal('liability-student'),
        creditcard: getVal('liability-creditcard'),
        other: getVal('liability-other'),
    };

    const totalAssets = Object.values(assets).reduce((a, b) => a + b, 0);
    const totalLiabilities = Object.values(liabilities).reduce((a, b) => a + b, 0);
    const netWorth = totalAssets - totalLiabilities;
    const ratio = totalAssets > 0 ? (totalLiabilities / totalAssets * 100) : 0;

    document.getElementById('total-assets').textContent = fmt(totalAssets);
    document.getElementById('total-liabilities').textContent = fmt(totalLiabilities);
    document.getElementById('result-assets').textContent = fmt(totalAssets);
    document.getElementById('result-liabilities').textContent = fmt(totalLiabilities);
    document.getElementById('result-ratio').textContent = ratio.toFixed(1) + '%';
    document.getElementById('result-net-copy').textContent = fmt(netWorth);

    const nwEl = document.getElementById('net-worth-value');
    nwEl.textContent = fmt(netWorth);
    nwEl.className = 'net-worth-value ' + (netWorth >= 0 ? 'net-worth-positive' : 'net-worth-negative');

    drawBarChart(totalAssets, totalLiabilities);
    drawDonutChart(assets);
    renderBenchmarks(netWorth);
}

// Bar Chart
function drawBarChart(totalAssets, totalLiabilities) {
    const canvas = document.getElementById('barChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, rect.width, rect.height);

    const max = Math.max(totalAssets, totalLiabilities, 1);
    const pad = { top: 40, right: 30, bottom: 50, left: 30 };
    const w = rect.width - pad.left - pad.right;
    const h = rect.height - pad.top - pad.bottom;
    const barW = Math.min(w * 0.3, 80);
    const gap = w * 0.2;

    const x1 = pad.left + (w / 2) - gap / 2 - barW;
    const x2 = pad.left + (w / 2) + gap / 2;

    const h1 = (totalAssets / max) * h;
    const h2 = (totalLiabilities / max) * h;

    // Asset bar
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--chart-color-a').trim();
    ctx.beginPath();
    const r = 6;
    ctx.moveTo(x1, pad.top + h - h1 + r);
    ctx.arcTo(x1, pad.top + h - h1, x1 + r, pad.top + h - h1, r);
    ctx.arcTo(x1 + barW, pad.top + h - h1, x1 + barW, pad.top + h - h1 + r, r);
    ctx.lineTo(x1 + barW, pad.top + h);
    ctx.lineTo(x1, pad.top + h);
    ctx.closePath();
    ctx.fill();

    // Liability bar
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--chart-color-b').trim();
    ctx.beginPath();
    ctx.moveTo(x2, pad.top + h - h2 + r);
    ctx.arcTo(x2, pad.top + h - h2, x2 + r, pad.top + h - h2, r);
    ctx.arcTo(x2 + barW, pad.top + h - h2, x2 + barW, pad.top + h - h2 + r, r);
    ctx.lineTo(x2 + barW, pad.top + h);
    ctx.lineTo(x2, pad.top + h);
    ctx.closePath();
    ctx.fill();

    // Labels
    const textColor = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim();
    ctx.fillStyle = textColor;
    ctx.font = '12px system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('Assets', x1 + barW / 2, pad.top + h + 20);
    ctx.fillText('Liabilities', x2 + barW / 2, pad.top + h + 20);

    // Values on top
    ctx.font = 'bold 13px system-ui, sans-serif';
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim();
    ctx.fillText(fmt(totalAssets), x1 + barW / 2, pad.top + h - h1 - 10);
    ctx.fillText(fmt(totalLiabilities), x2 + barW / 2, pad.top + h - h2 - 10);

    // Baseline
    ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--border-color').trim();
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(pad.left, pad.top + h);
    ctx.lineTo(pad.left + w, pad.top + h);
    ctx.stroke();
}

// Donut Chart
function drawDonutChart(assets) {
    const canvas = document.getElementById('donutChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, rect.width, rect.height);

    const labels = ['Cash & Savings', 'Investments', 'Retirement', 'Real Estate', 'Vehicles', 'Other'];
    const keys = ['cash', 'investments', 'retirement', 'realestate', 'vehicles', 'other'];
    const colors = ['#50E3C2', '#4A90E2', '#D4A017', '#9B59B6', '#E67E22', '#7F8C8D'];
    const values = keys.map(k => assets[k]);
    const total = values.reduce((a, b) => a + b, 0);

    // Legend
    const legendEl = document.getElementById('donut-legend');
    legendEl.innerHTML = '';
    keys.forEach((k, i) => {
        if (values[i] > 0) {
            const pct = ((values[i] / total) * 100).toFixed(1);
            const item = document.createElement('div');
            item.className = 'legend-item';
            item.innerHTML = `<span class="indicator" style="background:${colors[i]}"></span>${labels[i]} (${pct}%)`;
            legendEl.appendChild(item);
        }
    });

    if (total === 0) {
        ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim();
        ctx.font = '14px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('No assets to display', rect.width / 2, rect.height / 2);
        return;
    }

    const cx = rect.width / 2;
    const cy = rect.height / 2;
    const outerR = Math.min(cx, cy) - 20;
    const innerR = outerR * 0.6;

    let startAngle = -Math.PI / 2;
    values.forEach((val, i) => {
        if (val <= 0) return;
        const sliceAngle = (val / total) * Math.PI * 2;
        ctx.beginPath();
        ctx.arc(cx, cy, outerR, startAngle, startAngle + sliceAngle);
        ctx.arc(cx, cy, innerR, startAngle + sliceAngle, startAngle, true);
        ctx.closePath();
        ctx.fillStyle = colors[i];
        ctx.fill();
        startAngle += sliceAngle;
    });

    // Center text
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim();
    ctx.font = 'bold 16px system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(fmt(total), cx, cy - 8);
    ctx.font = '11px system-ui, sans-serif';
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim();
    ctx.fillText('Total Assets', cx, cy + 12);
}

// Benchmarks table
function renderBenchmarks(netWorth) {
    const age = getVal('user-age');
    const tbody = document.getElementById('benchmark-body');
    tbody.innerHTML = '';
    benchmarks.forEach(b => {
        const isCurrent = age >= b.min && age <= b.max;
        const tr = document.createElement('tr');
        if (isCurrent) tr.className = 'current-age-row';
        tr.innerHTML = `
            <td>${b.range}${isCurrent ? ' (you)' : ''}</td>
            <td>${fmt(b.median)}</td>
            <td>${fmt(b.average)}</td>
            <td class="your-col">${isCurrent ? fmt(netWorth) : '\u2014'}</td>
        `;
        tbody.appendChild(tr);
    });
}

// History
function getHistory() {
    try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
    } catch { return []; }
}

function saveHistory(history) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
}

function renderHistory() {
    const history = getHistory();
    const list = document.getElementById('history-list');
    const chartSection = document.getElementById('history-chart-section');

    if (history.length === 0) {
        list.innerHTML = '<div class="empty-history">No snapshots saved yet. Click "Save Current Snapshot" to start tracking.</div>';
        chartSection.style.display = 'none';
        return;
    }

    chartSection.style.display = 'block';
    list.innerHTML = '';
    history.slice().reverse().forEach((entry, idx) => {
        const realIdx = history.length - 1 - idx;
        const div = document.createElement('div');
        div.className = 'history-entry';
        const nwClass = entry.netWorth >= 0 ? 'net-worth-positive' : 'net-worth-negative';
        div.innerHTML = `
            <span class="history-date">${entry.date}</span>
            <span class="history-nw ${nwClass}">${fmt(entry.netWorth)}</span>
            <button class="history-delete" data-idx="${realIdx}" title="Delete">&times;</button>
        `;
        list.appendChild(div);
    });

    list.querySelectorAll('.history-delete').forEach(btn => {
        btn.addEventListener('click', () => {
            const idx = parseInt(btn.dataset.idx);
            const h = getHistory();
            h.splice(idx, 1);
            saveHistory(h);
            renderHistory();
        });
    });

    drawHistoryChart(history);
}

function drawHistoryChart(history) {
    const canvas = document.getElementById('historyChart');
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, rect.width, rect.height);

    if (history.length < 2) {
        ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim();
        ctx.font = '13px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('Save at least 2 snapshots to see your trend', rect.width / 2, rect.height / 2);
        return;
    }

    const pad = { top: 30, right: 30, bottom: 40, left: 70 };
    const w = rect.width - pad.left - pad.right;
    const h = rect.height - pad.top - pad.bottom;
    const values = history.map(e => e.netWorth);
    const minV = Math.min(...values);
    const maxV = Math.max(...values);
    const range = maxV - minV || 1;

    const textColor = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim();
    const borderColor = getComputedStyle(document.documentElement).getPropertyValue('--border-color').trim();
    const accentColor = getComputedStyle(document.documentElement).getPropertyValue('--accent-color').trim();

    // Grid lines
    ctx.strokeStyle = borderColor;
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 4; i++) {
        const y = pad.top + (h / 4) * i;
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(pad.left + w, y);
        ctx.stroke();
        const val = maxV - (range / 4) * i;
        ctx.fillStyle = textColor;
        ctx.font = '10px system-ui, sans-serif';
        ctx.textAlign = 'right';
        ctx.fillText(fmt(Math.round(val)), pad.left - 8, y + 4);
    }

    // Line
    ctx.beginPath();
    ctx.strokeStyle = accentColor;
    ctx.lineWidth = 2.5;
    ctx.lineJoin = 'round';
    history.forEach((entry, i) => {
        const x = pad.left + (i / (history.length - 1)) * w;
        const y = pad.top + h - ((entry.netWorth - minV) / range) * h;
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    });
    ctx.stroke();

    // Points & date labels
    history.forEach((entry, i) => {
        const x = pad.left + (i / (history.length - 1)) * w;
        const y = pad.top + h - ((entry.netWorth - minV) / range) * h;
        ctx.beginPath();
        ctx.arc(x, y, 4, 0, Math.PI * 2);
        ctx.fillStyle = accentColor;
        ctx.fill();

        if (history.length <= 12 || i % Math.ceil(history.length / 8) === 0 || i === history.length - 1) {
            ctx.fillStyle = textColor;
            ctx.font = '9px system-ui, sans-serif';
            ctx.textAlign = 'center';
            ctx.fillText(entry.date, x, pad.top + h + 18);
        }
    });
}

document.getElementById('save-snapshot').addEventListener('click', () => {
    const totalAssets = ['asset-cash', 'asset-investments', 'asset-retirement', 'asset-realestate', 'asset-vehicles', 'asset-other']
        .reduce((sum, id) => sum + getVal(id), 0);
    const totalLiabilities = ['liability-mortgage', 'liability-carloan', 'liability-student', 'liability-creditcard', 'liability-other']
        .reduce((sum, id) => sum + getVal(id), 0);
    const netWorth = totalAssets - totalLiabilities;
    const date = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

    const history = getHistory();
    history.push({ date, netWorth, assets: totalAssets, liabilities: totalLiabilities });
    saveHistory(history);
    renderHistory();
});

document.getElementById('clear-history').addEventListener('click', () => {
    if (confirm('Clear all saved net worth snapshots?')) {
        localStorage.removeItem(STORAGE_KEY);
        renderHistory();
    }
});

function copyValue(id, btn) {
    const text = document.getElementById(id).textContent;
    navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 1500);
    });
}

// FAQ toggles
document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
        btn.parentElement.classList.toggle('open');
    });
});

// Bind inputs
document.querySelectorAll('input[type="number"]').forEach(input => {
    input.addEventListener('input', calculate);
});

// Resize handling
let resizeTimer;
window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { calculate(); renderHistory(); }, 150);
});

// Init
calculate();
renderHistory();
</script>

