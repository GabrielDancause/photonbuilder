---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Net Worth Calculator",
  "url": "https://firemaths.info/net-worth-calculator",
  "description": "Calculate your net worth by adding up all your assets and subtracting your liabilities. Track your net worth over time and compare to age benchmarks.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is net worth and how do you calculate it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Net worth is the total value of everything you own (assets) minus everything you owe (liabilities). Assets include cash, savings, investments, retirement accounts, real estate, and vehicles. Liabilities include mortgages, car loans, student loans, credit card balances, and other debts. The formula is simple: Net Worth = Total Assets − Total Liabilities. A positive net worth means you own more than you owe."
      }
    },
    {
      "@type": "Question",
      "name": "What is the average net worth by age?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "According to the Federal Reserve's Survey of Consumer Finances, the average and median net worth by age in the U.S. are: Under 35: median $39,000, average $183,500. Ages 35–44: median $135,600, average $549,600. Ages 45–54: median $247,200, average $975,800. Ages 55–64: median $364,500, average $1,566,900. Ages 65–74: median $409,900, average $1,794,600. Age 75+: median $335,600, average $1,624,100. The average is significantly higher due to wealthy outliers, so median is a better benchmark for most people."
      }
    },
    {
      "@type": "Question",
      "name": "What should be included in assets when calculating net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Assets to include: liquid assets (checking, savings, money market accounts), investments (stocks, bonds, mutual funds, ETFs, cryptocurrency), retirement accounts (401k, IRA, Roth IRA, pension), real estate (home equity, rental properties), vehicles (cars, boats), and other valuables (jewelry, collectibles, business ownership). Use current market values rather than purchase prices. For your home, use the current estimated value, not the original purchase price."
      }
    },
    {
      "@type": "Question",
      "name": "What liabilities should I include in my net worth calculation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Include all outstanding debts: mortgage balance (remaining principal), home equity loans/HELOCs, auto loans, student loans, credit card balances, personal loans, medical debt, and any other money you owe. Use the current outstanding balance, not the original loan amount. Do not include monthly bills like utilities or subscriptions—only actual debts where you owe a principal balance."
      }
    },
    {
      "@type": "Question",
      "name": "Can your net worth be negative?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, your net worth can be negative. This means you owe more than you own. It's common for young adults, especially those with student loans, to have a negative net worth early in their careers. A negative net worth isn't necessarily alarming if you're actively paying down debt and building assets. The key is that your net worth should be trending upward over time as you save, invest, and reduce debt."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I calculate my net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most financial advisors recommend calculating your net worth at least once per quarter (every 3 months) or monthly if you're actively working toward a financial goal. This frequency lets you track progress without getting distracted by short-term market fluctuations. Our calculator saves your history in your browser so you can track trends over time. The key is consistency—pick a regular interval and stick to it."
      }
    },
    {
      "@type": "Question",
      "name": "How can I increase my net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There are two sides to growing net worth: increase assets and decrease liabilities. To increase assets: maximize retirement contributions, invest consistently, build emergency savings, and grow your income. To decrease liabilities: pay off high-interest debt first (avalanche method), make extra mortgage payments, refinance to lower rates, and avoid taking on new consumer debt. The most impactful strategy is usually to simultaneously invest for the long term while aggressively paying down high-interest debt."
      }
    },
    {
      "@type": "Question",
      "name": "Should I include my home in my net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, your home should be included in your net worth calculation, but correctly. List your home's current market value as an asset and your remaining mortgage balance as a liability. The difference is your home equity. Some financial planners distinguish between 'total net worth' (including home) and 'investable net worth' (excluding home equity) since you can't easily access home equity for living expenses. Our calculator includes real estate as a separate asset category so you can see both perspectives."
      }
    }
  ]
};

export const meta = {
  title: "Net Worth Calculator | firemaths.info",
  description: "Free net worth calculator — add up your assets, subtract your liabilities, and calculate your net worth. Compare to age benchmarks and track over time.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Net Worth Calculator | firemaths.info"
  description="Free net worth calculator — add up your assets, subtract your liabilities, and calculate your net worth. Compare to age benchmarks and track over time."
  canonical="https://firemaths.info/net-worth-calculator" schema={schema}
>
  <style>
:root {
    --chart-color-a: #50E3C2;
    --chart-color-b: #E85D75;
    --chart-color-c: #4A90E2;
    --chart-color-d: #D4A017;
    --chart-color-e: #9B59B6;
    --chart-color-f: #E67E22;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.card-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.section-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
}

.section-total .label {
    font-weight: 600;
    font-size: 1rem;
}

.section-total .value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
}

.assets-total .value { color: var(--chart-color-a); }
.liabilities-total .value { color: var(--chart-color-b); }

.results-card {
    margin-bottom: 3rem;
}

.net-worth-display {
    text-align: center;
    padding: 2rem 0;
}

.net-worth-label {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}

.net-worth-value {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 700;
}

.net-worth-positive { color: var(--chart-color-a); }
.net-worth-negative { color: var(--chart-color-b); }

.result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-top: 1px solid var(--border-color);
}

.result-row .label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-row .value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
    margin-left: 0.5rem;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (max-width: 768px) {
    .charts-grid {
        grid-template-columns: 1fr;
    }
}

.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.chart-header {
    margin-bottom: 1.5rem;
    text-align: center;
}

.chart-header h2 {
    font-size: 1.15rem;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
}

.chart-container {
    width: 100%;
    height: 300px;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

.benchmarks-section {
    margin-bottom: 3rem;
}

.benchmarks-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.benchmark-table {
    width: 100%;
    border-collapse: collapse;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
}

.benchmark-table th,
.benchmark-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.9rem;
}

.benchmark-table th {
    background-color: var(--bg-color);
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.benchmark-table td {
    font-family: var(--font-mono);
}

.benchmark-table tr:last-child td {
    border-bottom: none;
}

.benchmark-table tr.current-age-row {
    background-color: color-mix(in srgb, var(--accent-color) 10%, transparent);
}

.benchmark-table tr.current-age-row td {
    font-weight: 600;
}

.your-col {
    color: var(--accent-color);
    font-weight: 600;
}

.history-section {
    margin-bottom: 3rem;
}

.history-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.history-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
}

.btn {
    background-color: var(--accent-color);
    color: var(--bg-color);
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
}

.btn:hover { opacity: 0.85; }

.btn-outline {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
}

.btn-outline:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
    opacity: 1;
}

.history-chart-container {
    width: 100%;
    height: 250px;
    position: relative;
}

.history-list {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
}

.history-entry {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.875rem;
}

.history-entry:last-child {
    border-bottom: none;
}

.history-date {
    color: var(--text-secondary);
}

.history-nw {
    font-family: var(--font-mono);
    font-weight: 600;
}

.history-delete {
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 1rem;
    padding: 0.25rem;
    transition: color 0.2s;
}

.history-delete:hover {
    color: var(--chart-color-b);
}

.empty-history {
    text-align: center;
    padding: 2rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "\2212";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Net Worth Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Calculate your net worth — total assets minus total liabilities</p>

    <main>
        <div class="input-group" style="max-width:200px; margin-bottom:2rem;">
            <label for="user-age">Your Age</label>
            <div class="input-wrapper">
                <input type="number" id="user-age" value="30" min="18" max="100" step="1">
            </div>
        </div>

        <div class="calculator-grid">
            <!-- Assets -->
            <div class="card">
                <div class="card-header">
                    <h2>Assets</h2>
                </div>

                <div class="input-group">
                    <label for="asset-cash">Cash &amp; Savings</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="asset-cash" value="10000" min="0" step="500" data-asset>
                    </div>
                </div>

                <div class="input-group">
                    <label for="asset-investments">Investments (Stocks, Bonds, Crypto)</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="asset-investments" value="25000" min="0" step="500" data-asset>
                    </div>
                </div>

                <div class="input-group">
                    <label for="asset-retirement">Retirement Accounts (401k, IRA)</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="asset-retirement" value="40000" min="0" step="500" data-asset>
                    </div>
                </div>

                <div class="input-group">
                    <label for="asset-realestate">Real Estate (Market Value)</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="asset-realestate" value="0" min="0" step="1000" data-asset>
                    </div>
                </div>

                <div class="input-group">
                    <label for="asset-vehicles">Vehicles</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="asset-vehicles" value="15000" min="0" step="500" data-asset>
                    </div>
                </div>

                <div class="input-group">
                    <label for="asset-other">Other Assets</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="asset-other" value="0" min="0" step="500" data-asset>
                    </div>
                </div>

                <div class="section-total assets-total">
                    <span class="label">Total Assets</span>
                    <span class="value" id="total-assets">$0</span>
                </div>
            </div>

            <!-- Liabilities -->
            <div class="card">
                <div class="card-header">
                    <h2>Liabilities</h2>
                </div>

                <div class="input-group">
                    <label for="liability-mortgage">Mortgage Balance</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="liability-mortgage" value="0" min="0" step="1000" data-liability>
                    </div>
                </div>

                <div class="input-group">
                    <label for="liability-carloan">Car Loans</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="liability-carloan" value="8000" min="0" step="500" data-liability>
                    </div>
                </div>

                <div class="input-group">
                    <label for="liability-student">Student Loans</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="liability-student" value="20000" min="0" step="500" data-liability>
                    </div>
                </div>

                <div class="input-group">
                    <label for="liability-creditcard">Credit Card Balances</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="liability-creditcard" value="2000" min="0" step="100" data-liability>
                    </div>
                </div>

                <div class="input-group">
                    <label for="liability-other">Other Debt</label>
                    <div class="input-wrapper has-prefix">
                        <span class="prefix">$</span>
                        <input type="number" id="liability-other" value="0" min="0" step="500" data-liability>
                    </div>
                </div>

                <div class="section-total liabilities-total">
                    <span class="label">Total Liabilities</span>
                    <span class="value" id="total-liabilities">$0</span>
                </div>
            </div>
        </div>

        <!-- Net Worth Result -->
        <div class="card results-card">
            <div class="net-worth-display">
                <div class="net-worth-label">Your Net Worth</div>
                <div class="net-worth-value net-worth-positive" id="net-worth-value">$0</div>
            </div>
            <div class="result-row">
                <span class="label">Total Assets</span>
                <span class="value" id="result-assets" style="color: var(--chart-color-a);">$0</span>
            </div>
            <div class="result-row">
                <span class="label">Total Liabilities</span>
                <span class="value" id="result-liabilities" style="color: var(--chart-color-b);">$0</span>
            </div>
            <div class="result-row">
                <span class="label">Debt-to-Asset Ratio</span>
                <span class="value" id="result-ratio">0%</span>
            </div>
            <div class="result-row">
                <span class="label">Assets minus Liabilities</span>
                <div>
                    <span class="value" id="result-net-copy">$0</span>
                    <button class="copy-btn" onclick="copyValue('result-net-copy', this)">Copy</button>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="charts-grid">
            <div class="chart-section">
                <div class="chart-header">
                    <h2>Assets vs Liabilities</h2>
                </div>
                <div class="chart-container">
                    <canvas id="barChart"></canvas>
                </div>
            </div>

            <div class="chart-section">
                <div class="chart-header">
                    <h2>Asset Allocation</h2>
                    <div class="chart-legend" id="donut-legend"></div>
                </div>
                <div class="chart-container">
                    <canvas id="donutChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Benchmarks -->
        <div class="benchmarks-section">
            <h2>Net Worth by Age Benchmarks</h2>
            <table class="benchmark-table">
                <thead>
                    <tr>
                        <th>Age Range</th>
                        <th>Median Net Worth</th>
