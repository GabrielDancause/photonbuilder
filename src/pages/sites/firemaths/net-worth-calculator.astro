  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <script>
    const assetCats = ['cash', 'investments', 'realestate', 'vehicles', 'otherasset'];
    const liabilityCats = ['mortgage', 'auto', 'student', 'credit', 'otherdebt'];
    const assetColors = ['#D4A017', '#4A90E2', '#9B59B6', '#E67E22', '#2ECC71'];
    const liabilityColors = ['#E74C3C', '#E67E22', '#3498DB', '#9B59B6', '#95A5A6'];
    const assetLabels = ['Cash & Savings', 'Investments', 'Real Estate', 'Vehicles', 'Other Assets'];
    const liabilityLabels = ['Mortgage', 'Auto Loans', 'Student Loans', 'Credit Cards', 'Other Debt'];

    const STORAGE_KEY = 'firemaths_nw_snapshots';

    function fmt(n) {
      if (n < 0) return '-$' + Math.abs(n).toLocaleString('en-US', { maximumFractionDigits: 0 });
      return '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });
    }

    function getCatTotal(cat) {
      let total = 0;
      const rows = document.getElementById('rows-' + cat);
      if (!rows) return 0;
      rows.querySelectorAll('input[type="number"]').forEach(inp => {
        total += parseFloat(inp.value) || 0;
      });
      return total;
    }

    function calculate() {
      let totalAssets = 0;
      let totalLiabilities = 0;
      const assetTotals = [];
      const liabilityTotals = [];

      assetCats.forEach(cat => {
        const t = getCatTotal(cat);
        assetTotals.push(t);
        totalAssets += t;
        const el = document.getElementById('total-' + cat);
        if (el) el.textContent = fmt(t);
      });

      liabilityCats.forEach(cat => {
        const t = getCatTotal(cat);
        liabilityTotals.push(t);
        totalLiabilities += t;
        const el = document.getElementById('total-' + cat);
        if (el) el.textContent = fmt(t);
      });

      const netWorth = totalAssets - totalLiabilities;

      document.getElementById('result-assets').textContent = fmt(totalAssets);
      document.getElementById('result-liabilities').textContent = fmt(totalLiabilities);
      const nwEl = document.getElementById('result-networth');
      nwEl.textContent = fmt(netWorth);
      nwEl.style.color = netWorth >= 0 ? 'var(--accent-color)' : 'var(--color-negative)';

      drawPie('asset-pie', 'asset-legend', assetTotals, assetColors, assetLabels);
      drawPie('liability-pie', 'liability-legend', liabilityTotals, liabilityColors, liabilityLabels);
    }

    function drawPie(canvasId, legendId, data, colors, labels) {
      const canvas = document.getElementById(canvasId);
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);
      const w = rect.width;
      const h = rect.height;
      ctx.clearRect(0, 0, w, h);

      const total = data.reduce((s, v) => s + v, 0);
      const legendEl = document.getElementById(legendId);
      legendEl.innerHTML = '';

      if (total === 0) {
        ctx.fillStyle = '#333';
        ctx.beginPath();
        ctx.arc(w / 2, h / 2, Math.min(w, h) / 2 - 20, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#666';
        ctx.font = '14px system-ui';
        ctx.textAlign = 'center';
        ctx.fillText('No data entered', w / 2, h / 2);
        return;
      }

      const cx = w / 2;
      const cy = h / 2;
      const radius = Math.min(w, h) / 2 - 20;
      let startAngle = -Math.PI / 2;

      data.forEach((val, i) => {
        if (val <= 0) return;
        const slice = (val / total) * Math.PI * 2;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, radius, startAngle, startAngle + slice);
        ctx.closePath();
        ctx.fillStyle = colors[i];
        ctx.fill();

        // Label
        if (slice > 0.15) {
          const mid = startAngle + slice / 2;
          const lx = cx + Math.cos(mid) * radius * 0.6;
          const ly = cy + Math.sin(mid) * radius * 0.6;
          ctx.fillStyle = '#fff';
          ctx.font = 'bold 12px system-ui';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(Math.round(val / total * 100) + '%', lx, ly);
        }

        startAngle += slice;

        const item = document.createElement('div');
        item.className = 'legend-item';
        item.innerHTML = '<span class="legend-dot" style="background:' + colors[i] + '"></span>' +
          labels[i] + ': ' + fmt(val) + ' (' + Math.round(val / total * 100) + '%)';
        legendEl.appendChild(item);
      });
    }

    function addRow(target) {
      const container = document.getElementById('rows-' + target);
      const row = document.createElement('div');
      row.className = 'row-item';
      row.innerHTML = '<input type="text" value="" placeholder="Description">' +
        '<input type="number" value="" placeholder="0" data-cat="' + target + '">' +
        '<button class="btn-remove" title="Remove">&times;</button>';
      container.appendChild(row);
      row.querySelector('input[type="number"]').addEventListener('input', calculate);
      row.querySelector('.btn-remove').addEventListener('click', function() {
        row.remove();
        calculate();
      });
      row.querySelector('input[type="text"]').focus();
    }

    // Snapshot management
    function getSnapshots() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
      catch { return []; }
    }

    function saveSnapshot() {
      const snapshots = getSnapshots();
      let totalAssets = 0;
      let totalLiabilities = 0;
      assetCats.forEach(cat => { totalAssets += getCatTotal(cat); });
      liabilityCats.forEach(cat => { totalLiabilities += getCatTotal(cat); });
      const netWorth = totalAssets - totalLiabilities;

      snapshots.push({
        date: new Date().toISOString().split('T')[0],
        assets: totalAssets,
        liabilities: totalLiabilities,
        netWorth: netWorth
      });

      localStorage.setItem(STORAGE_KEY, JSON.stringify(snapshots));
      renderSnapshots();
      drawTrendChart();
    }

    function renderSnapshots() {
      const list = document.getElementById('snapshot-list');
      const snapshots = getSnapshots();
      list.innerHTML = '';
      if (snapshots.length === 0) return;

      snapshots.slice().reverse().forEach((snap, i) => {
        const item = document.createElement('div');
        item.className = 'snapshot-item';
        const color = snap.netWorth >= 0 ? 'var(--color-positive)' : 'var(--color-negative)';
        item.innerHTML = '<span class="snap-date">' + snap.date + '</span>' +
          '<span class="snap-value" style="color:' + color + '">' + fmt(snap.netWorth) + '</span>' +
          '<button class="btn-remove" data-idx="' + (snapshots.length - 1 - i) + '">&times;</button>';
        list.appendChild(item);
      });

      list.querySelectorAll('.btn-remove').forEach(btn => {
        btn.addEventListener('click', function() {
          const idx = parseInt(this.getAttribute('data-idx'));
          const snaps = getSnapshots();
          snaps.splice(idx, 1);
          localStorage.setItem(STORAGE_KEY, JSON.stringify(snaps));
          renderSnapshots();
          drawTrendChart();
        });
      });
    }

    function drawTrendChart() {
      const canvas = document.getElementById('trend-chart');
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);
      const w = rect.width;
      const h = rect.height;
      ctx.clearRect(0, 0, w, h);

      const snapshots = getSnapshots();
      if (snapshots.length < 2) {
        ctx.fillStyle = '#666';
        ctx.font = '14px system-ui';
        ctx.textAlign = 'center';
        ctx.fillText(snapshots.length === 0 ? 'Save at least 2 snapshots to see a trend chart' : 'Save one more snapshot to see a trend chart', w / 2, h / 2);
        return;
      }

      const pad = { top: 30, right: 20, bottom: 50, left: 80 };
      const cw = w - pad.left - pad.right;
      const ch = h - pad.top - pad.bottom;

      const values = snapshots.map(s => s.netWorth);
      let minV = Math.min(...values);
      let maxV = Math.max(...values);
      if (minV === maxV) { minV -= 1000; maxV += 1000; }
      const range = maxV - minV;
      minV -= range * 0.1;
      maxV += range * 0.1;

      // Grid lines
      ctx.strokeStyle = '#2a2010';
      ctx.lineWidth = 1;
      const gridLines = 5;
      for (let i = 0; i <= gridLines; i++) {
        const y = pad.top + (ch / gridLines) * i;
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(w - pad.right, y);
        ctx.stroke();

        const val = maxV - ((maxV - minV) / gridLines) * i;
        ctx.fillStyle = '#888';
        ctx.font = '11px monospace';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(fmt(Math.round(val)), pad.left - 8, y);
      }

      // Line
      ctx.beginPath();
      ctx.strokeStyle = '#D4A017';
      ctx.lineWidth = 2;
      snapshots.forEach((snap, i) => {
        const x = pad.left + (i / (snapshots.length - 1)) * cw;
        const y = pad.top + ch - ((snap.netWorth - minV) / (maxV - minV)) * ch;
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      });
      ctx.stroke();

      // Fill
      ctx.lineTo(pad.left + cw, pad.top + ch);
      ctx.lineTo(pad.left, pad.top + ch);
      ctx.closePath();
      ctx.fillStyle = 'rgba(212, 160, 23, 0.08)';
      ctx.fill();

      // Dots + labels
      snapshots.forEach((snap, i) => {
        const x = pad.left + (i / (snapshots.length - 1)) * cw;
        const y = pad.top + ch - ((snap.netWorth - minV) / (maxV - minV)) * ch;
        ctx.beginPath();
        ctx.arc(x, y, 4, 0, Math.PI * 2);
        ctx.fillStyle = '#D4A017';
        ctx.fill();

        // Date label
        if (snapshots.length <= 12 || i % Math.ceil(snapshots.length / 10) === 0) {
          ctx.fillStyle = '#888';
          ctx.font = '10px monospace';
          ctx.textAlign = 'center';
          ctx.fillText(snap.date.substring(5), x, h - pad.bottom + 16);
        }
      });
    }

    // Age comparison highlight
    function highlightAge() {
      const age = parseInt(document.getElementById('user-age').value);
      document.querySelectorAll('#comparison-table tbody tr').forEach(row => {
        row.classList.remove('your-row');
        if (age && age >= parseInt(row.dataset.min) && age <= parseInt(row.dataset.max)) {
          row.classList.add('your-row');
        }
      });
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', function() {
      // Listen on all number inputs
      document.querySelectorAll('input[type="number"][data-cat]').forEach(inp => {
        inp.addEventListener('input', calculate);
      });

      // Remove buttons
      document.querySelectorAll('.btn-remove').forEach(btn => {
        btn.addEventListener('click', function() {
          const row = this.closest('.row-item');
          if (row) { row.remove(); calculate(); }
        });
      });

      // Add buttons
      document.querySelectorAll('.btn-add').forEach(btn => {
        btn.addEventListener('click', function() {
          addRow(this.dataset.target);
        });
      });

      // Snapshot buttons
      document.getElementById('btn-snapshot').addEventListener('click', saveSnapshot);
      document.getElementById('btn-clear-history').addEventListener('click', function() {
        if (confirm('Clear all saved snapshots?')) {
          localStorage.removeItem(STORAGE_KEY);
          renderSnapshots();
          drawTrendChart();
        }
      });

      // Age input
      document.getElementById('user-age').addEventListener('input', highlightAge);

      // Initial render
      calculate();
      renderSnapshots();
      drawTrendChart();
    });

    // Redraw charts on resize
    let resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() { calculate(); drawTrendChart(); }, 200);
    });
  </script>
</SiteLayout>
