---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Net Worth Calculator",
  "url": "https://firemaths.info/net-worth-calculator",
  "description": "Calculate your personal net worth by tracking assets and liabilities. Pie chart breakdown, age comparison benchmarks, and trend tracking over time.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is net worth and how do I calculate it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Net worth is the total value of everything you own (assets) minus everything you owe (liabilities). To calculate it, add up all your assets — cash, savings, investments, real estate, vehicles, and other valuables — then subtract all debts including mortgages, auto loans, student loans, and credit card balances. The result is your net worth."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good net worth for my age?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Net worth varies significantly by age. The median net worth for Americans under 35 is about $39,000, ages 35-44 is around $135,600, ages 45-54 is about $247,200, ages 55-64 is roughly $364,500, and ages 65-74 is approximately $409,900. These figures come from the Federal Reserve's Survey of Consumer Finances. A common benchmark is to have a net worth equal to your age times your annual income divided by 10."
      }
    },
    {
      "@type": "Question",
      "name": "Can your net worth be negative?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, your net worth can be negative if your total liabilities exceed your total assets. This is common for young adults who have student loans or recent home buyers with large mortgages. A negative net worth isn't necessarily bad — it often reflects investments in education or property that will build wealth over time. The key is tracking it and ensuring it trends upward."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I calculate my net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most financial advisors recommend calculating your net worth quarterly or at least twice a year. Monthly tracking can be useful if you're aggressively paying off debt or saving. Avoid checking too frequently (weekly or daily) as short-term market fluctuations can cause unnecessary stress. Our calculator lets you save snapshots over time to track your progress."
      }
    },
    {
      "@type": "Question",
      "name": "Should I include my home in my net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, your home should be included in your net worth calculation. Include the current market value of your home as an asset and your remaining mortgage balance as a liability. The difference is your home equity. However, be conservative with your home value estimate — use recent comparable sales in your area rather than optimistic Zestimate-style valuations."
      }
    },
    {
      "@type": "Question",
      "name": "What is the fastest way to increase net worth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The fastest ways to increase net worth are: 1) Pay off high-interest debt first (credit cards, personal loans), 2) Increase your savings rate — aim for at least 20% of income, 3) Invest consistently in diversified index funds, 4) Increase your income through raises, side income, or career changes, 5) Avoid lifestyle inflation when your income grows. The combination of reducing liabilities and growing assets accelerates net worth growth exponentially over time."
      }
    }
  ]
};

export const meta = {
  title: "Net Worth Calculator — Track Your Personal Net Worth | firemaths.info",
  description: "Free net worth calculator to track assets, liabilities, and overall financial health. Pie chart breakdown, age-based benchmarks, and trend tracking over time.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Net Worth Calculator — Track Your Personal Net Worth | firemaths.info"
  description="Free net worth calculator to track assets, liabilities, and overall financial health. Pie chart breakdown, age-based benchmarks, and trend tracking over time."
  canonical="https://firemaths.info/net-worth-calculator" schema={schema}
>
  <style>
:root {
  --color-positive: #4ade80;
  --color-negative: #ef4444;
  --color-cash: #D4A017;
  --color-investments: #4A90E2;
  --color-realestate: #9B59B6;
  --color-vehicles: #E67E22;
  --color-other-asset: #2ECC71;
  --color-mortgage: #E74C3C;
  --color-auto: #E67E22;
  --color-student: #3498DB;
  --color-credit: #9B59B6;
  --color-other-debt: #95A5A6;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-family: var(--font-ui);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 { font-weight: 700; line-height: 1.2; color: var(--text-primary); }

.container { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }

header { text-align: center; margin-bottom: 3rem; }
header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; color: var(--accent-color); }
header p { color: var(--text-secondary); font-size: 1.1rem; }

.card {
  background-color: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 1.5rem;
  margin-bottom: 2rem;
}

.card h2 {
  font-size: 1.25rem;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border-color);
}

.category-section { margin-bottom: 1.5rem; }

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.75rem;
}

.category-header h3 {
  font-size: 1rem;
  color: var(--text-secondary);
}

.category-total {
  font-family: var(--font-mono);
  font-size: 0.875rem;
  color: var(--text-secondary);
}

.row-item {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: 0.75rem;
  align-items: center;
  margin-bottom: 0.5rem;
}

@media (max-width: 500px) {
  .row-item { grid-template-columns: 1fr auto; }
  .row-item input[type="text"] { grid-column: 1 / -1; }
}

input[type="text"], input[type="number"] {
  width: 100%;
  background-color: var(--bg-color);
  border: 1px solid var(--border-color);
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 0.9375rem;
  padding: 0.6rem 0.75rem;
  border-radius: 6px;
  transition: border-color 0.2s;
  -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
input:focus { outline: none; border-color: var(--accent-color); }

.btn-add {
  background: rgba(212, 160, 23, 0.1);
  border: 1px solid var(--accent-color);
  color: var(--accent-color);
  cursor: pointer;
  padding: 0.4rem 0.75rem;
  border-radius: 6px;
  font-size: 0.8125rem;
  font-family: var(--font-ui);
  font-weight: 500;
  transition: all 0.2s;
}

.btn-add:hover { background: rgba(212, 160, 23, 0.2); }

.btn-remove {
  background: none;
  border: none;
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 1.25rem;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  transition: color 0.2s;
  line-height: 1;
}

.btn-remove:hover { color: var(--color-negative); }

/* Results */
.results-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1rem;
  margin-bottom: 2rem;
}

@media (max-width: 600px) {
  .results-grid { grid-template-columns: 1fr; }
}

.result-box {
  background-color: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 1.25rem;
  text-align: center;
}

.result-box.highlight { border-color: var(--accent-color); }

.result-box .result-label {
  color: var(--text-secondary);
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.25rem;
}

.result-box .result-value {
  font-family: var(--font-mono);
  font-size: 1.5rem;
  font-weight: 700;
}

.result-box.highlight .result-value { color: var(--accent-color); font-size: 1.75rem; }

/* Charts */
.charts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-bottom: 2rem;
}

@media (max-width: 700px) {
  .charts-grid { grid-template-columns: 1fr; }
}

.chart-card {
  background-color: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 1.5rem;
}

.chart-card h3 { font-size: 1.1rem; margin-bottom: 1rem; }

.chart-container { width: 100%; height: 300px; position: relative; }
canvas { width: 100%; height: 100%; }

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 1rem;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8125rem;
  color: var(--text-secondary);
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* Snapshot tracking */
.snapshot-controls {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 1rem;
  flex-wrap: wrap;
}

.btn-primary {
  background: rgba(212, 160, 23, 0.15);
  border: 1px solid var(--accent-color);
  color: var(--accent-color);
  cursor: pointer;
  padding: 0.5rem 1rem;
  border-radius: 6px;
  font-size: 0.875rem;
  font-family: var(--font-ui);
  font-weight: 600;
  transition: all 0.2s;
}

.btn-primary:hover { background: rgba(212, 160, 23, 0.25); }

.btn-secondary {
  background: none;
  border: 1px solid var(--border-color);
  color: var(--text-secondary);
  cursor: pointer;
  padding: 0.5rem 1rem;
  border-radius: 6px;
  font-size: 0.875rem;
  font-family: var(--font-ui);
  transition: all 0.2s;
}

.btn-secondary:hover { border-color: var(--text-secondary); color: var(--text-primary); }

.trend-container { width: 100%; height: 300px; position: relative; }

.snapshot-list {
  margin-top: 1rem;
  max-height: 200px;
  overflow-y: auto;
}

.snapshot-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--border-color);
  font-size: 0.875rem;
}

.snapshot-item .snap-date { color: var(--text-secondary); font-family: var(--font-mono); }
.snapshot-item .snap-value { font-family: var(--font-mono); font-weight: 600; }

/* Comparison table */
.table-container { overflow-x: auto; }

table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-mono);
  font-size: 0.875rem;
}

thead th {
  text-align: left;
  padding: 0.75rem 0.5rem;
  border-bottom: 2px solid var(--border-color);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-secondary);
  white-space: nowrap;
}

tbody td {
  padding: 0.6rem 0.5rem;
  border-bottom: 1px solid var(--border-color);
  white-space: nowrap;
}

tbody tr:hover { background-color: var(--bg-color); }

td.num { text-align: right; }

.your-row { background-color: rgba(212, 160, 23, 0.08); }
.your-row td { font-weight: 600; color: var(--accent-color); }

/* Tips */
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
}

.tip-card {
  background-color: var(--bg-color);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 1.25rem;
}

.tip-card h4 {
  font-size: 0.9375rem;
  margin-bottom: 0.5rem;
  color: var(--accent-color);
}

.tip-card p { font-size: 0.875rem; color: var(--text-secondary); }

/* FAQ */
.faq-item {
  background-color: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 1.5rem;
  margin-bottom: 1rem;
}

.faq-item h3 { font-size: 1rem; color: var(--accent-color); margin-bottom: 0.5rem; }
.faq-item p { color: var(--text-secondary); font-size: 0.9375rem; }

/* SEO content */
.seo-content { margin-bottom: 4rem; }
.seo-content h2 { font-size: 1.75rem; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--accent-color); }
.seo-content h3 { font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.75rem; }
.seo-content p { margin-bottom: 1rem; color: var(--text-secondary); }
.seo-content ul, .seo-content ol { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
.seo-content li { margin-bottom: 0.5rem; }

.related-links {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-top: 2rem;
}

@media (max-width: 600px) { .related-links { grid-template-columns: 1fr; } }

.related-links a {
  display: block;
  background-color: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 1rem;
  text-decoration: none;
  transition: all 0.2s;
}

.related-links a:hover { border-color: var(--accent-color); transform: translateY(-2px); }
.related-links a h4 { font-size: 0.9375rem; color: var(--text-primary); margin-bottom: 0.25rem; }
.related-links a p { font-size: 0.8125rem; color: var(--text-secondary); }
  </style>

  <div class="container">
    <header>
      <h1>Net Worth Calculator</h1>
      <p>Track your total assets, liabilities, and personal net worth over time</p>
    </header>

    <!-- Assets Section -->
    <div class="card" id="assets-card">
      <h2>Assets — What You Own</h2>

      <div class="category-section" data-category="cash">
        <div class="category-header">
          <h3>Cash & Savings</h3>
          <span class="category-total" id="total-cash">$0</span>
        </div>
        <div class="rows" id="rows-cash">
          <div class="row-item">
            <input type="text" value="Checking Account" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="cash">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
          <div class="row-item">
            <input type="text" value="Savings Account" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="cash">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="cash" data-type="asset">+ Add Row</button>
      </div>

      <div class="category-section" data-category="investments">
        <div class="category-header">
          <h3>Investments</h3>
          <span class="category-total" id="total-investments">$0</span>
        </div>
        <div class="rows" id="rows-investments">
          <div class="row-item">
            <input type="text" value="401(k)" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="investments">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
          <div class="row-item">
            <input type="text" value="IRA / Roth IRA" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="investments">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
          <div class="row-item">
            <input type="text" value="Brokerage Account" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="investments">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="investments" data-type="asset">+ Add Row</button>
      </div>

      <div class="category-section" data-category="realestate">
        <div class="category-header">
          <h3>Real Estate</h3>
          <span class="category-total" id="total-realestate">$0</span>
        </div>
        <div class="rows" id="rows-realestate">
          <div class="row-item">
            <input type="text" value="Primary Residence" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="realestate">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="realestate" data-type="asset">+ Add Row</button>
      </div>

      <div class="category-section" data-category="vehicles">
        <div class="category-header">
          <h3>Vehicles</h3>
          <span class="category-total" id="total-vehicles">$0</span>
        </div>
        <div class="rows" id="rows-vehicles">
          <div class="row-item">
            <input type="text" value="Car" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="vehicles">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="vehicles" data-type="asset">+ Add Row</button>
      </div>

      <div class="category-section" data-category="otherasset">
        <div class="category-header">
          <h3>Other Assets</h3>
          <span class="category-total" id="total-otherasset">$0</span>
        </div>
        <div class="rows" id="rows-otherasset">
          <div class="row-item">
            <input type="text" value="Other" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="otherasset">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="otherasset" data-type="asset">+ Add Row</button>
      </div>
    </div>

    <!-- Liabilities Section -->
    <div class="card" id="liabilities-card">
      <h2>Liabilities — What You Owe</h2>

      <div class="category-section" data-category="mortgage">
        <div class="category-header">
          <h3>Mortgage</h3>
          <span class="category-total" id="total-mortgage">$0</span>
        </div>
        <div class="rows" id="rows-mortgage">
          <div class="row-item">
            <input type="text" value="Home Mortgage" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="mortgage">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="mortgage" data-type="liability">+ Add Row</button>
      </div>

      <div class="category-section" data-category="auto">
        <div class="category-header">
          <h3>Auto Loans</h3>
          <span class="category-total" id="total-auto">$0</span>
        </div>
        <div class="rows" id="rows-auto">
          <div class="row-item">
            <input type="text" value="Auto Loan" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="auto">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="auto" data-type="liability">+ Add Row</button>
      </div>

      <div class="category-section" data-category="student">
        <div class="category-header">
          <h3>Student Loans</h3>
          <span class="category-total" id="total-student">$0</span>
        </div>
        <div class="rows" id="rows-student">
          <div class="row-item">
            <input type="text" value="Student Loan" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="student">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="student" data-type="liability">+ Add Row</button>
      </div>

      <div class="category-section" data-category="credit">
        <div class="category-header">
          <h3>Credit Cards</h3>
          <span class="category-total" id="total-credit">$0</span>
        </div>
        <div class="rows" id="rows-credit">
          <div class="row-item">
            <input type="text" value="Credit Card" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="credit">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="credit" data-type="liability">+ Add Row</button>
      </div>

      <div class="category-section" data-category="otherdebt">
        <div class="category-header">
          <h3>Other Debt</h3>
          <span class="category-total" id="total-otherdebt">$0</span>
        </div>
        <div class="rows" id="rows-otherdebt">
          <div class="row-item">
            <input type="text" value="Other Debt" placeholder="Description">
            <input type="number" value="" placeholder="0" data-cat="otherdebt">
            <button class="btn-remove" title="Remove">&times;</button>
          </div>
        </div>
        <button class="btn-add" data-target="otherdebt" data-type="liability">+ Add Row</button>
      </div>
    </div>

    <!-- Results -->
    <div class="results-grid">
      <div class="result-box">
        <div class="result-label">Total Assets</div>
        <div class="result-value" id="result-assets" style="color: var(--color-positive)">$0</div>
      </div>
      <div class="result-box">
        <div class="result-label">Total Liabilities</div>
        <div class="result-value" id="result-liabilities" style="color: var(--color-negative)">$0</div>
      </div>
      <div class="result-box highlight">
        <div class="result-label">Net Worth</div>
        <div class="result-value" id="result-networth">$0</div>
      </div>
    </div>

    <!-- Pie Charts -->
    <div class="charts-grid">
      <div class="chart-card">
        <h3>Asset Breakdown</h3>
        <div class="chart-container"><canvas id="asset-pie"></canvas></div>
        <div class="chart-legend" id="asset-legend"></div>
      </div>
      <div class="chart-card">
        <h3>Liability Breakdown</h3>
        <div class="chart-container"><canvas id="liability-pie"></canvas></div>
        <div class="chart-legend" id="liability-legend"></div>
      </div>
    </div>

    <!-- Net Worth Trend -->
    <div class="card">
      <h2>Track Over Time</h2>
      <div class="snapshot-controls">
        <button class="btn-primary" id="btn-snapshot">Save Snapshot</button>
        <button class="btn-secondary" id="btn-clear-history">Clear History</button>
      </div>
      <div class="trend-container"><canvas id="trend-chart"></canvas></div>
      <div class="snapshot-list" id="snapshot-list"></div>
    </div>

    <!-- Age Comparison Table -->
    <div class="card">
      <h2>Net Worth by Age — How Do You Compare?</h2>
      <p style="color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 1rem;">Based on the Federal Reserve Survey of Consumer Finances. Enter your age to highlight your bracket.</p>
      <div style="margin-bottom: 1rem;">
        <label style="font-size: 0.875rem; color: var(--text-secondary); margin-right: 0.5rem;">Your Age:</label>
        <input type="number" id="user-age" placeholder="30" style="width: 80px; display: inline-block;">
      </div>
      <div class="table-container">
        <table id="comparison-table">
          <thead>
            <tr>
