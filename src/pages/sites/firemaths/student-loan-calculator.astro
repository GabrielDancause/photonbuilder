---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Student Loan Repayment Calculator",
  "url": "https://firemaths.info/student-loan-calculator.html",
  "description": "Compare student loan repayment plans including Standard, IBR, SAVE, and PSLF. Calculate your payoff timeline, total interest, and potential forgiveness.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Student Loan Repayment Calculator: Standard, IBR & PSLF Compared | FireMaths"
  description="Think paying minimums is safe? See the exact month your student loans could be forgiven—or the hidden cost of waiting. Find out how fast you can really pay them off."
  canonical="https://firemaths.info/student-loan-calculator.html" schema={schema}
>
  <!-- Sticky Nav -->
    

    <div class="max-w-4xl mx-auto px-6 py-12">
        

        <main class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
            <!-- Left Column: Inputs -->
            <aside>
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-6 shadow-sm" style="position: sticky; top: 80px;">
                    <h2 class="card-title">Loan Details</h2>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="balance">Total Loan Balance</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="balance" value="37500" min="0" step="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="rate">Average Interest Rate</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">%</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="rate" value="5.8" min="0" step="0.1">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="income">Adjusted Gross Income (AGI)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="income" value="65000" min="0" step="1000">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="family-size">Family Size</label>
                        <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="family-size" value="1" min="1" step="1">
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="extra-pay">Extra Monthly Payment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="extra-pay" value="0" min="0" step="50">
                        </div>
                    </div>

                    <div class="mb-5" style="margin-top: 2rem;">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                            <input type="checkbox" id="pslf-eligible" style="width: 16px; height: 16px; accent-color: var(--accent-color);">
                            <span style="font-size: 0.95rem; color: #fff;">I work in public service (PSLF eligible)</span>
                        </label>
                    </div>
                </div>
            </aside>

            <!-- Right Column: Results & Chart -->
            <section>
                <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-6 shadow-sm">
                    <h2 class="card-title">Repayment Plan Comparison</h2>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6" id="results-container">
                        <!-- JS injected results -->
                    </div>

                    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                        <h3 style="margin-top:0; margin-bottom: 0.5rem; font-size: 1.1rem; color: #fff;">Loan Balance Over Time</h3>
                        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1rem;">Comparing balances across different repayment strategies.</p>
                        <div class="h-[300px] mt-4">
                            <canvas id="balanceChart"></canvas>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <!-- SEO Content & FAQ -->
        <article class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding Your Student Loan Repayment Options</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Choosing the right repayment strategy is critical. A standard plan might minimize total interest, while an income-driven plan could provide crucial monthly cash flow relief or a path to massive forgiveness.</p>

            <h3 class="text-xl font-bold text-white mt-6 mb-3">The Standard 10-Year Plan</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">This is the default plan for federal student loans. Your payments are fixed over 120 months. It usually results in the lowest total interest paid, provided you don't make extra payments. If you want to know <strong>how fast you can pay off student loans</strong>, this plan is the baseline, but adding an extra monthly payment can aggressively shorten this timeline.</p>

            <h3 class="text-xl font-bold text-white mt-6 mb-3">Income-Driven Repayment (SAVE, IBR, PAYE)</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">If your student loan balance is high relative to your income, an Income-Driven Repayment (IDR) plan like SAVE (Saving on a Valuable Education) or IBR (Income-Based Repayment) caps your monthly payment at a percentage of your discretionary income. For 2026 projections, SAVE often provides the lowest monthly payment. Balances remaining after 20 or 25 years of qualifying payments are forgiven (though the forgiven amount may be treated as taxable income).</p>

            <h3 class="text-xl font-bold text-white mt-6 mb-3">Public Service Loan Forgiveness (PSLF)</h3>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">If you work full-time for a qualifying government or non-profit employer, PSLF can forgive your remaining balance tax-free after just 120 qualifying payments (10 years). To maximize PSLF, you must use an IDR plan to keep your monthly payments low, ensuring there is a substantial balance left to be forgiven at the 10-year mark.</p>
        </article>

        <section class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Frequently Asked Questions</h2>

            <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                <h3 class="font-bold text-lg text-white mb-3">What is the best student loan repayment calculator?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">The best student loan repayment calculator lets you compare multiple strategies side-by-side. You should be able to see the standard 10-year plan, income-driven repayment (IDR) plans like SAVE or IBR, and see the impact of Public Service Loan Forgiveness (PSLF) based on your specific income and loan balance.</p>
            </div>

            <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                <h3 class="font-bold text-lg text-white mb-3">How fast can I pay off student loans?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">How fast you can pay off student loans depends on your interest rate, balance, and how much extra you pay each month. On a standard plan, it takes 10 years. By making extra payments, you can reduce this timeline to 5 years or less. Using a student loan payoff calculator helps you visualize the exact timeline based on your budget.</p>
            </div>

            <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                <h3 class="font-bold text-lg text-white mb-3">Should I use an income-based repayment (IBR) plan?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">An income-based repayment plan is excellent if your debt is high compared to your income. It caps your monthly payment at a percentage of your discretionary income (often 10%). However, it extends your payoff timeline to 20 or 25 years, meaning you might pay more in total interest unless you qualify for PSLF or IDR forgiveness.</p>
            </div>

            <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                <h3 class="font-bold text-lg text-white mb-3">How does Public Service Loan Forgiveness (PSLF) work?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">PSLF forgives your remaining federal student loan balance after you make 120 qualifying monthly payments while working full-time for an eligible non-profit or government employer. You must be on an income-driven repayment plan to benefit, otherwise, a standard 10-year plan pays off the loan before forgiveness kicks in.</p>
            </div>

            <div class="mb-6 pb-6 border-b border-[var(--border-color)] last:border-0 last:pb-0">
                <h3 class="font-bold text-lg text-white mb-3">What is a student loan payoff calculator?</h3>
                <p class="text-[var(--text-secondary)] leading-relaxed">A student loan payoff calculator is a financial tool that projects the future trajectory of your debt. It shows your monthly payments, total interest paid, total amount paid over the life of the loan, and the exact date you will be debt-free under various repayment strategies.</p>
            </div>
        </section>
    </div>
  <script is:inline>
// Constants & Utilities
        const COLORS = {
            standard: '#4A90E2',
            graduated: '#9B51E0',
            save: '#34d399',
            ibr: '#f97316'
        };

        const formatCurr = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
        const formatMonths = (m) => {
            const y = Math.floor(m/12);
            const mos = m%12;
            return y > 0 ? `${y}y ${mos}m` : `${mos}m`;
        };

        // DOM Elements
        const inputs = {
            balance: document.getElementById('balance'),
            rate: document.getElementById('rate'),
            income: document.getElementById('income'),
            familySize: document.getElementById('family-size'),
            extraPay: document.getElementById('extra-pay'),
            pslf: document.getElementById('pslf-eligible')
        };
        const resultsContainer = document.getElementById('results-container');
        const canvas = document.getElementById('balanceChart');
        const ctx = canvas.getContext('2d');

        // Poverty Guidelines (2024/2026 approx)
        // 48 Contiguous states
        const getPovertyLine = (familySize) => 15060 + (5380 * (familySize - 1));

        // Core Calculation Engines
        const calculateStandard = (balance, rate, extra) => {
            const r = (rate / 100) / 12;
            const n = 120;
            // Base required payment for 10 years
            let pmt = r === 0 ? balance / n : balance * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);

            let currentBalance = balance;
            let totalPaid = 0;
            let totalInterest = 0;
            let months = 0;
            let history = [balance];

            const actualPmt = pmt + extra;

            while (currentBalance > 0.01 && months < 360) {
                months++;
                let interest = currentBalance * r;
                totalInterest += interest;

                let payment = Math.min(actualPmt, currentBalance + interest);
                let principal = payment - interest;

                currentBalance -= principal;
                totalPaid += payment;
                history.push(currentBalance);
            }

            return {
                id: 'standard',
                name: 'Standard 10-Year',
                color: COLORS.standard,
                monthlyPayment: pmt + extra,
                totalPaid,
                forgiven: 0,
                months,
                history,
                isRecommended: false
            };
        };

        const calculateGraduated = (balance, rate, extra) => {
            // Rough approximation: starts lower, increases every 2 years
            // Total term 10 years (120 months)
            const r = (rate / 100) / 12;
            const standardPmt = r === 0 ? balance / 120 : balance * (r * Math.pow(1 + r, 120)) / (Math.pow(1 + r, 120) - 1);

            // Assume starts at interest only or half standard
            let basePmt = Math.max(balance * r, standardPmt * 0.5);

            let currentBalance = balance;
            let totalPaid = 0;
            let months = 0;
            let history = [balance];

            while (currentBalance > 0.01 && months < 360) {
                months++;

                // Increase base payment by 20% every 24 months
                if (months > 1 && months % 24 === 1 && months <= 120) {
                    basePmt *= 1.2;
                }

                let actualPmt = basePmt + extra;
                let interest = currentBalance * r;

                let payment = Math.min(actualPmt, currentBalance + interest);
                let principal = payment - interest;

                currentBalance -= principal;
                totalPaid += payment;
                history.push(currentBalance);
            }

            return {
                id: 'graduated',
                name: 'Graduated',
                color: COLORS.graduated,
                monthlyPayment: (Math.max(balance * r, standardPmt * 0.5)) + extra, // initial
                totalPaid,
                forgiven: 0,
                months,
                history,
                isRecommended: false
            };
        };

        const calculateSAVE = (balance, rate, income, familySize, extra, isPSLF) => {
            const r = (rate / 100) / 12;
            const povertyLine = getPovertyLine(familySize);
            // SAVE protects 225% of poverty line
            const discretionary = Math.max(0, income - (povertyLine * 2.25));
            // SAVE is 5% to 10% depending on undergrad/grad split. Assume 10% for worst-case/blended.
            const monthlyIDR = discretionary * 0.10 / 12;

            const maxMonths = isPSLF ? 120 : 240; // Assume undergrad (20 yrs), otherwise 25

            let currentBalance = balance;
            let totalPaid = 0;
            let months = 0;
            let history = [balance];

            while (currentBalance > 0.01 && months < maxMonths) {
                months++;
                let interest = currentBalance * r;

                let requiredPmt = monthlyIDR;
                let actualPmt = requiredPmt + extra;

                // SAVE interest subsidy: if requiredPmt < interest, unpaid interest is subsidized/waived
                let appliedInterest = Math.min(interest, requiredPmt);

                let payment = Math.min(actualPmt, currentBalance + appliedInterest);
                let principal = payment - appliedInterest;

                // Extra payment goes directly to principal
                if (extra > 0 && payment === actualPmt) {
                    principal = (requiredPmt - appliedInterest) + extra;
                }

                currentBalance -= principal;
                totalPaid += payment;
                history.push(currentBalance);
            }

            let forgiven = currentBalance > 0 ? currentBalance : 0;

            return {
                id: 'save',
                name: isPSLF ? 'SAVE + PSLF' : 'SAVE Plan',
                color: COLORS.save,
                monthlyPayment: monthlyIDR + extra,
                totalPaid,
                forgiven,
                months,
                history,
                isRecommended: false
            };
        };

        const calculateIBR = (balance, rate, income, familySize, extra, isPSLF) => {
            const r = (rate / 100) / 12;
            const povertyLine = getPovertyLine(familySize);
            // IBR protects 150% of poverty line
            const discretionary = Math.max(0, income - (povertyLine * 1.5));
            // IBR is 10% for new borrowers (15% for old, assume 10%)
            const monthlyIDR = discretionary * 0.10 / 12;

            // Cap at standard 10yr payment
            const standardPmt = balance * (r * Math.pow(1 + r, 120)) / (Math.pow(1 + r, 120) - 1);
            const cappedIDR = Math.min(monthlyIDR, standardPmt);

            const maxMonths = isPSLF ? 120 : 240;

            let currentBalance = balance;
            let totalPaid = 0;
            let months = 0;
            let history = [balance];

            while (currentBalance > 0.01 && months < maxMonths) {
                months++;
                let interest = currentBalance * r;

                let requiredPmt = cappedIDR;
                let actualPmt = requiredPmt + extra;

                // No interest subsidy in normal IBR after first 3 years, keep simple: unpaid interest capitalizes or grows

                let payment = Math.min(actualPmt, currentBalance + interest);
                let principal = payment - interest;

                currentBalance -= principal;
                totalPaid += payment;
                history.push(currentBalance);
            }

            let forgiven = currentBalance > 0 ? currentBalance : 0;

            return {
                id: 'ibr',
                name: isPSLF ? 'IBR + PSLF' : 'IBR Plan',
                color: COLORS.ibr,
                monthlyPayment: cappedIDR + extra,
                totalPaid,
                forgiven,
                months,
                history,
                isRecommended: false
            };
        };


        const updateApp = () => {
            const b = parseFloat(inputs.balance.value) || 0;
            const r = parseFloat(inputs.rate.value) || 0;
            const i = parseFloat(inputs.income.value) || 0;
            const f = parseInt(inputs.familySize.value) || 1;
            const e = parseFloat(inputs.extraPay.value) || 0;
            const pslf = inputs.pslf.checked;

            if(b === 0) return;

            const plans = [
                calculateStandard(b, r, e),
                calculateGraduated(b, r, e),
                calculateSAVE(b, r, i, f, e, pslf),
                calculateIBR(b, r, i, f, e, pslf)
            ];

            // Find recommended (lowest total paid out of pocket)
            let minPaid = Infinity;
            let recIndex = 0;
            plans.forEach((p, idx) => {
                if (p.totalPaid < minPaid) {
                    minPaid = p.totalPaid;
                    recIndex = idx;
                }
            });
            plans[recIndex].isRecommended = true;

            renderResults(plans);
            drawChart(plans);
        };

        const renderResults = (plans) => {
            resultsContainer.innerHTML = plans.map(p => `
                <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-xl p-5 relative transition-all duration-200 ${p.isRecommended ? 'recommended' : ''}">
                    ${p.isRecommended ? '<div class="absolute -top-3 right-4 bg-[var(--accent-color)] text-[var(--bg-color)] text-xs font-bold px-2 py-1 rounded shadow-sm">Best Value</div>' : ''}
                    <div class="text-xl font-bold text-white mb-4 flex items-center gap-2">
                        <span class="w-3 h-3 rounded-full" style="background-color: ${p.color}"></span>
                        ${p.name}
                    </div>

                    <div class="flex justify-between items-center py-2 border-b border-dashed border-[var(--border-color)] last:border-0">
                        <span class="text-[var(--text-secondary)] text-sm">Monthly Payment</span>
                        <span class="font-mono text-white font-medium  ${p.id === 'graduated' ? '' : 'highlight'}">
                            ${formatCurr(p.monthlyPayment)}${p.id === 'graduated' ? '<span style="font-size:0.7em;color:var(--text-secondary);font-weight:400;margin-left:4px;">(Initial)</span>' : ''}
                        </span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-dashed border-[var(--border-color)] last:border-0">
                        <span class="text-[var(--text-secondary)] text-sm">Total Paid Over Time</span>
                        <span class="font-mono text-white font-medium ">${formatCurr(p.totalPaid)}</span>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-dashed border-[var(--border-color)] last:border-0">
                        <span class="text-[var(--text-secondary)] text-sm">Time to Payoff/Forgiveness</span>
                        <span class="font-mono text-white font-medium ">${formatMonths(p.months)}</span>
                    </div>
                    ${p.forgiven > 0 ? `
                    <div class="flex justify-between items-center py-2 border-b border-dashed border-[var(--border-color)] last:border-0">
                        <span class="text-[var(--text-secondary)] text-sm">Amount Forgiven</span>
                        <span class="font-mono text-green-400 font-bold text-lg">${formatCurr(p.forgiven)}</span>
                    </div>
                    ` : ''}
                </div>
            `).join('');
        };

        const drawChart = (plans) => {
            const dpr = window.devicePixelRatio || 1;
            const rect = canvas.parentElement.getBoundingClientRect();

            canvas.width = rect.width * dpr;
            canvas.height = rect.height * dpr;

            ctx.setTransform(1, 0, 0, 1, 0, 0);
            ctx.scale(dpr, dpr);

            const w = rect.width;
            const h = rect.height;
            const pad = { t: 20, r: 20, b: 30, l: 60 };
            const cw = w - pad.l - pad.r;
            const ch = h - pad.t - pad.b;

            ctx.clearRect(0, 0, w, h);

            // Find max bounds
            let maxM = 0;
            let maxB = 0;
            plans.forEach(p => {
                if (p.history.length > maxM) maxM = p.history.length;
                p.history.forEach(v => { if (v > maxB) maxB = v; });
            });
            maxM = Math.max(maxM, 12); // At least 1 year
            maxB = maxB * 1.1; // 10% headroom

            // Grid & Axes
            ctx.strokeStyle = '#152040';
            ctx.fillStyle = '#8b9bb4';
            ctx.font = '11px "JetBrains Mono", monospace';
            ctx.lineWidth = 1;

            // Y Axis
            ctx.textAlign = 'right';
            ctx.textBaseline = 'middle';
            for(let i=0; i<=5; i++) {
                let y = h - pad.b - (ch * (i/5));
                let val = maxB * (i/5);

                ctx.beginPath();
                ctx.moveTo(pad.l, y);
                ctx.lineTo(w - pad.r, y);
                ctx.stroke();

                let txt = val >= 1000 ? `$${(val/1000).toFixed(0)}k` : `$${val.toFixed(0)}`;
                ctx.fillText(txt, pad.l - 10, y);
            }

            // X Axis
            ctx.textAlign = 'center';
            ctx.textBaseline = 'top';
            let years = Math.ceil(maxM / 12);
            let xTicks = years > 10 ? 10 : years;
            for(let i=0; i<=xTicks; i++) {
                let yr = Math.round((years / xTicks) * i);
                let x = pad.l + (cw * ((yr * 12) / maxM));

                if (x <= w - pad.r) {
                    ctx.fillText(`${yr}y`, x, h - pad.b + 10);
                }
            }

            // Draw Lines
            plans.forEach(p => {
                ctx.beginPath();
                ctx.strokeStyle = p.color;
                ctx.lineWidth = p.isRecommended ? 4 : 2;
                ctx.lineJoin = 'round';

                p.history.forEach((val, idx) => {
                    let x = pad.l + (cw * (idx / maxM));
                    let y = h - pad.b - (ch * (val / maxB));
                    if (idx === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                });
                ctx.stroke();

                // Draw drop line if forgiven
                if (p.forgiven > 0 && p.history.length > 0) {
                    let lastX = pad.l + (cw * ((p.history.length - 1) / maxM));
                    let lastY = h - pad.b - (ch * (p.history[p.history.length-1] / maxB));
                    let endY = h - pad.b; // 0 balance

                    ctx.beginPath();
                    ctx.strokeStyle = p.color;
                    ctx.setLineDash([5, 5]);
                    ctx.moveTo(lastX, lastY);
                    ctx.lineTo(lastX, endY);
                    ctx.stroke();
                    ctx.setLineDash([]); // reset
                }
            });
        };

        // Event Listeners
        Object.values(inputs).forEach(input => {
            input.addEventListener('input', updateApp);
            if(input.type === 'checkbox') input.addEventListener('change', updateApp);
        });
        window.addEventListener('resize', () => {
            // Need a tiny delay for resize to settle
            setTimeout(updateApp, 50);
        });

        // Init
        updateApp();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
