        <div class="text-2xl font-bold text-[var(--accent-color)] font-mono mb-1" id="stat-total-accounts">0</div>
        <div class="text-xs text-[var(--text-secondary)] uppercase tracking-wide">Banks Compared</div>
      </div>
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-[var(--accent-color)] font-mono mb-1" id="stat-no-fee">0%</div>
        <div class="text-xs text-[var(--text-secondary)] uppercase tracking-wide">Charge No Fees</div>
      </div>
    </div>

    <div class="bg-[var(--accent-color)] bg-opacity-5 border border-[var(--accent-color)] border-opacity-20 rounded-xl p-6 mb-12">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">🔍 Key Findings</h2>
      <ul class="space-y-3" id="findings-list">
        <!-- Injected via JS -->
      </ul>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
