        <!-- Injected via JS -->
      </div>
    </div>

    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Complete Rate Comparison</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6 bg-[var(--card-bg)] p-4 rounded-xl border border-[var(--border-color)]">
      <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="filter-type">
        <option value="all">All Bank Types</option>
        <option value="online">Online Banks</option>
        <option value="traditional">Traditional Banks</option>
        <option value="credit-union">Credit Unions</option>
        <option value="neobank">Neobanks</option>
      </select>
      <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="filter-fee">
        <option value="all">Any Fee Structure</option>
        <option value="no-fee">No Monthly Fee Only</option>
      </select>
      <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="filter-apy">
        <option value="all">Any APY Range</option>
        <option value="high">5.00% and above</option>
        <option value="med">4.00% - 4.99%</option>
        <option value="low">Below 4.00%</option>
      </select>
      <select class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors appearance-none pr-10" id="filter-min">
        <option value="all">Any Minimum Deposit</option>
        <option value="zero">$0 Minimum Only</option>
        <option value="under500">Under $500</option>
      </select>
    </div>

    <div class="overflow-x-auto bg-[var(--card-bg)] rounded-xl border border-[var(--border-color)] shadow-sm">
      <table class="w-full text-left border-collapse whitespace-nowrap">
        <th class="p-4 font-mediumead  bg-[var(--bg-color)] border-b border-[var(--border-color)] text-[var(--text-secondary)] text-sm uppercase tracking-wide"">
