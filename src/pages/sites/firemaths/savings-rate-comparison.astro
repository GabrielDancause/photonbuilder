  <script is:inline>
const rawData = document.getElementById('savings-data').textContent.trim();
let studyData;
try {
  studyData = JSON.parse(rawData);
} catch (e) {
  console.error("Failed to parse data", e);
  studyData = { accounts: [], crawlDate: new Date().toISOString() };
}

let accounts = studyData.accounts;
let currentSort = { col: 'apyPct', asc: false };

// Format helpers
const fmtMoney = (val) => val === null ? '-' : new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
const fmtPct = (val) => val === null ? '-' : Number(val).toFixed(2) + '%';
const fmtType = (type) => {
  const map = { 'online': 'Online', 'traditional': 'Traditional', 'credit-union': 'Credit Union', 'neobank': 'Neobank' };
  return map[type] || type;
};
const getTypeBadgeClass = (type) => {
  const map = { 'online': 'badge-online', 'traditional': 'badge-traditional', 'credit-union': 'badge-cu', 'neobank': 'badge-neobank' };
  return map[type] || 'badge-online';
};

function init() {
  document.getElementById('page-title').textContent = `High-Yield Savings Account Rates 2025 — ${accounts.length} Banks Compared`;
  document.getElementById('crawl-date').textContent = new Date(studyData.crawlDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

  updateStats();
  renderChart();
  renderDistribution();
  generateFindings();

  // Event listeners
  document.querySelectorAll('th[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort;
      if (currentSort.col === col) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.col = col;
        currentSort.asc = (col === 'bankName' || col === 'bankType');
      }
      document.querySelectorAll('th').forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
      th.classList.add(currentSort.asc ? 'sort-asc' : 'sort-desc');
      renderTable();
    });
  });

  document.getElementById('filter-type').addEventListener('change', renderTable);
  document.getElementById('filter-fee').addEventListener('change', renderTable);
  document.getElementById('filter-apy').addEventListener('change', renderTable);
  document.getElementById('filter-min').addEventListener('change', renderTable);

  renderTable();
}

function updateStats() {
  if (accounts.length === 0) return;
  const apys = accounts.map(a => a.apyPct).filter(a => a > 0);
  const maxApy = Math.max(...apys);
  const avgApy = apys.reduce((sum, a) => sum + a, 0) / apys.length;
  const noFee = accounts.filter(a => a.monthlyFee === 0).length;

  document.getElementById('stat-max-apy').textContent = fmtPct(maxApy);
  document.getElementById('stat-avg-apy').textContent = fmtPct(avgApy);
  document.getElementById('stat-total-accounts').textContent = accounts.length;
  document.getElementById('stat-no-fee').textContent = Math.round((noFee / accounts.length) * 100) + '%';
}

function renderDistribution() {
  const container = document.getElementById('distribution-chart');
  if (accounts.length === 0) return;

  const groups = {
    'online': { label: 'Online Banks', sum: 0, count: 0 },
    'neobank': { label: 'Neobanks', sum: 0, count: 0 },
    'credit-union': { label: 'Credit Unions', sum: 0, count: 0 },
    'traditional': { label: 'Traditional Banks', sum: 0, count: 0 }
  };

  accounts.forEach(a => {
    if (groups[a.bankType] && a.apyPct > 0) {
      groups[a.bankType].sum += a.apyPct;
      groups[a.bankType].count++;
    }
  });

  const avgs = Object.values(groups)
    .filter(g => g.count > 0)
    .map(g => ({ label: g.label, avg: g.sum / g.count }))
    .sort((a, b) => b.avg - a.avg);

  if (avgs.length === 0) return;
  const maxAvg = avgs[0].avg;

  container.innerHTML = avgs.map(g => {
    const pct = (g.avg / maxAvg) * 100;
    return `
      <div class="flex items-center gap-4 mb-3">
        <div class="w-32 text-sm text-[var(--text-secondary)] truncate text-right">${g.label}</div>
        <div class="flex-1 bg-[var(--bg-color)] h-6 rounded overflow-hidden flex">
          <div class="h-full bg-[var(--accent-color)]" style="width: ${pct}%; background-color: var(--success)"></div>
          <div class="ml-2 text-xs font-mono text-white flex items-center">${fmtPct(g.avg)}</div>
        </div>
      </div>
    `;
  }).join('');
}

function renderChart() {
  const container = document.getElementById('chart-bars');
  if (accounts.length === 0) return;
  const top15 = [...accounts].sort((a, b) => b.apyPct - a.apyPct).slice(0, 15);
  const maxChartApy = top15[0].apyPct;

  container.innerHTML = top15.map(acc => {
    const pct = (acc.apyPct / maxChartApy) * 100;
    return `
      <div class="flex items-center gap-4 mb-3">
        <div class="w-32 text-sm text-[var(--text-secondary)] truncate text-right" title="${acc.bankName}">${acc.bankName}</div>
        <div class="flex-1 bg-[var(--bg-color)] h-6 rounded overflow-hidden flex">
          <div class="h-full bg-[var(--accent-color)]" style="width: ${pct}%"></div>
          <div class="ml-2 text-xs font-mono text-white flex items-center">${fmtPct(acc.apyPct)}</div>
        </div>
      </div>
    `;
  }).join('');
}

function generateFindings() {
  const list = document.getElementById('findings-list');
  if (accounts.length === 0) return;
  const apys = accounts.map(a => a.apyPct).filter(a => a > 0);
  const avgApy = apys.reduce((sum, a) => sum + a, 0) / apys.length;
  const onlineAvg = accounts.filter(a => a.bankType === 'online' || a.bankType === 'neobank').map(a => a.apyPct).reduce((sum, a, i, arr) => sum + a / arr.length, 0);
  const tradAvg = accounts.filter(a => a.bankType === 'traditional').map(a => a.apyPct).reduce((sum, a, i, arr) => sum + a / arr.length, 0) || 0.01;
  const zeroMin = accounts.filter(a => a.minDeposit === 0).length;
  const zeroFee = accounts.filter(a => a.monthlyFee === 0).length;

  let findings = [
    `The average high-yield rate across all surveyed institutions is <strong>${fmtPct(avgApy)}</strong>.`,
    `<strong>${Math.round((zeroFee / accounts.length) * 100)}%</strong> of the surveyed top-yielding accounts charge no monthly maintenance fees.`,
    `<strong>${Math.round((zeroMin / accounts.length) * 100)}%</strong> of accounts require a $0 minimum deposit to open.`,
  ];

  if (tradAvg > 0 && onlineAvg > 0) {
    const diff = (onlineAvg / tradAvg).toFixed(0);
    findings.push(`Online banks and neobanks offer rates approximately <strong>${diff}x higher</strong> than traditional brick-and-mortar banks.`);
  }

  list.innerHTML = findings.map(f => `<li>${f}</li>`).join('');
}

function renderTable() {
  const tbody = document.getElementById('table-body');

  // Filters
  const fType = document.getElementById('filter-type').value;
  const fFee = document.getElementById('filter-fee').value;
  const fApy = document.getElementById('filter-apy').value;
  const fMin = document.getElementById('filter-min').value;

  let filtered = accounts.filter(a => {
    if (fType !== 'all' && a.bankType !== fType) return false;
    if (fFee === 'no-fee' && a.monthlyFee > 0) return false;
    if (fApy === 'high' && a.apyPct < 5.0) return false;
    if (fApy === 'med' && (a.apyPct < 4.0 || a.apyPct >= 5.0)) return false;
    if (fApy === 'low' && a.apyPct >= 4.0) return false;
    if (fMin === 'zero' && a.minDeposit > 0) return false;
    if (fMin === 'under500' && a.minDeposit >= 500) return false;
    return true;
  });

  // Sort
  filtered.sort((a, b) => {
    let valA = a[currentSort.col];
    let valB = b[currentSort.col];

    if (typeof valA === 'string') valA = valA.toLowerCase();
    if (typeof valB === 'string') valB = valB.toLowerCase();

    if (valA < valB) return currentSort.asc ? -1 : 1;
    if (valA > valB) return currentSort.asc ? 1 : -1;
    return 0;
  });

  if (filtered.length === 0) {
    tbody.innerHTML = `<tr class="hover:bg-[var(--bg-color)] transition-colors"><td class="p-4" colspan="5" style="text-align:center;color:var(--text-muted)">No accounts match your filters.</td></tr>`;
    return;
  }

  tbody.innerHTML = filtered.map(acc => `
    <tr class="hover:bg-[var(--bg-color)] transition-colors">
      <td class="p-4">
        <strong>${acc.bankName}</strong>
      </td>
      <td class="p-4 font-mono font-bold text-[var(--accent-color)]  col-apy"">${fmtPct(acc.apyPct)}</td>
      <td class="p-4 font-mono text-[var(--text-secondary)]  col-money"">${fmtMoney(acc.minDeposit)}</td>
      <td class="p-4 font-mono text-[var(--text-secondary)]  col-money"">${acc.monthlyFee === 0 ? '$0' : fmtMoney(acc.monthlyFee)}</td>
      <td class="p-4"><span class="px-2 py-1 rounded text-xs font-bold bg-opacity-20 inline-block ${getTypeBadgeClass(acc.bankType)}">${fmtType(acc.bankType)}</span></td>
    </tr>
  `).join('');
}

init();
  </script>

