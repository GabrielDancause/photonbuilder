---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "High-Yield Savings Account Rates 2025 \u2014 Every Major Bank Compared",
    "description": "A comprehensive, interactive comparison of savings account interest rates (APY) across major US banks, credit unions, and neobanks.",
    "author": {
      "@type": "Organization",
      "name": "firemaths.info",
      "url": "https://firemaths.info"
    },
    "publisher": {
      "@type": "Organization",
      "name": "firemaths.info"
    },
    "datePublished": "2025-03-08"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Savings Rate Comparison Tool",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "All",
    "description": "Interactive tool to filter and sort current high-yield savings account rates, minimum deposits, and fees."
  }
];
---

<SiteLayout
  site="firemaths"
  title="High-Yield Savings Account Rates 2025 | firemaths.info"
  description=""
  canonical="https://firemaths.info/savings-rate-comparison" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    <div class="inline-block bg-[var(--accent-color)] text-[var(--bg-color)] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">Original Research</div>
    <h1 id="page-title">High-Yield Savings Account Rates 2025</h1>
    <div class="text-xl text-[var(--text-secondary)] mb-8 text-center" id="page-subtitle">Comparing accounts to find the best places for your cash.</div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-[var(--accent-color)] font-mono mb-1" id="stat-max-apy">0%</div>
        <div class="text-xs text-[var(--text-secondary)] uppercase tracking-wide">Highest APY</div>
      </div>
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-[var(--accent-color)] font-mono mb-1" id="stat-avg-apy">0%</div>
        <div class="text-xs text-[var(--text-secondary)] uppercase tracking-wide">Average APY</div>
