---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Retirement Savings Calculator",
  "url": "https://firemaths.info/retirement-savings-calculator",
  "description": "Calculate how much you need to retire. Model savings growth, drawdown phase, and compare optimistic, moderate, and conservative scenarios.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much money do I need to retire?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A common rule of thumb is the 4% rule: you need 25 times your desired annual retirement spending saved. For example, if you want $60,000 per year in retirement, you need approximately $1.5 million. However, the exact amount depends on your expected retirement age, lifestyle, healthcare costs, Social Security benefits, and investment returns."
      }
    },
    {
      "@type": "Question",
      "name": "What is the 4% rule for retirement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 4% rule states that you can withdraw 4% of your retirement portfolio in the first year, then adjust for inflation each subsequent year, and your savings should last at least 30 years. It was derived from the Trinity Study. So if you have $1 million saved, you could withdraw $40,000 in year one. While widely used as a guideline, some financial planners suggest a more conservative 3-3.5% rate given current market conditions."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I save for retirement each month?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Financial advisors commonly recommend saving 15-20% of your gross income for retirement, including any employer match. If you start in your 20s, 15% is often sufficient. Starting later requires higher percentages: in your 30s aim for 20-25%, and in your 40s you may need 30% or more. Use our calculator to find the exact monthly contribution needed based on your specific situation."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good rate of return for retirement planning?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Historically, a diversified stock portfolio has returned about 7-10% annually before inflation (roughly 5-7% after inflation). For conservative planning, many advisors use 6% nominal return. A balanced stock/bond portfolio might return 5-7%. Our calculator lets you compare optimistic (8%), moderate (6%), and conservative (4%) scenarios so you can plan for multiple outcomes."
      }
    },
    {
      "@type": "Question",
      "name": "Should I factor inflation into my retirement calculations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, inflation is critical to retirement planning. At 3% annual inflation, $1 today will only be worth about $0.41 in 30 years. This means if you need $60,000/year in today's dollars, you'll actually need roughly $146,000/year in 30 years. Our calculator adjusts for inflation so your projections reflect real purchasing power, giving you a more accurate picture of your retirement readiness."
      }
    },
    {
      "@type": "Question",
      "name": "How does Social Security affect my retirement savings goal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Social Security can cover a portion of your retirement income, reducing how much you need from personal savings. The average Social Security benefit in 2024 is about $1,907/month ($22,884/year). Higher earners may receive up to $4,873/month at full retirement age. However, financial planners recommend not relying too heavily on Social Security alone, as benefits may be adjusted in the future and typically replace only 30-40% of pre-retirement income."
      }
    },
    {
      "@type": "Question",
      "name": "What are catch-up contributions and who qualifies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Catch-up contributions are additional amounts that workers aged 50 and older can contribute to retirement accounts beyond the standard limits. For 2024, the catch-up contribution limit is $7,500 for 401(k) plans (on top of the $23,000 base limit) and $1,000 for IRAs (on top of the $7,000 base limit). Starting in 2025, workers aged 60-63 can make even larger catch-up contributions of $10,000 to 401(k) plans under SECURE 2.0."
      }
    },
    {
      "@type": "Question",
      "name": "How do I know if I'm on track for retirement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common retirement savings benchmarks by age: by 30 have 1x your salary saved, by 40 have 3x, by 50 have 6x, by 60 have 8x, and by 67 have 10x your salary saved. These are guidelines from Fidelity Investments. Use our calculator to get a personalized projection based on your actual savings, contributions, and expected returns. The calculator will show whether you have a surplus or gap relative to your retirement income goal."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between nominal and real returns in retirement planning?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nominal returns are your investment gains before accounting for inflation (e.g., 8% market return). Real returns subtract inflation to show your actual purchasing power growth (e.g., 8% nominal minus 3% inflation = roughly 5% real return). For retirement planning, using real returns gives you a more accurate picture since your future expenses will also increase with inflation. Our calculator handles this by letting you set both the expected return rate and inflation rate separately."
      }
    }
  ]
};

export const meta = {
  title: "Retirement Savings Calculator | firemaths.info",
  description: "Free retirement calculator — find out how much you need to retire, project savings growth and drawdown, and compare optimistic and conservative scenarios.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="firemaths"
  title="Retirement Savings Calculator | firemaths.info"
  description="Free retirement calculator — find out how much you need to retire, project savings growth and drawdown, and compare optimistic, moderate, and conservative scenarios."
  canonical="https://firemaths.info/retirement-savings-calculator" schema={schema}
>
  <style>
:root {
    --chart-color-a: #D4A017;
    --chart-color-b: #4A90E2;
    --chart-color-c: #50E3C2;
    --chart-color-d: #E85D75;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: var(--font-ui);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4 {
    font-weight: 700;
    line-height: 1.2;
    color: var(--text-primary);
}

.container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

header {
    text-align: center;
    margin-bottom: 3rem;
}

header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--accent-color);
}

header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
}

.calculator-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (min-width: 768px) {
    .calculator-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.scenario-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.scenario-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

.scenario-header h2 {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.input-group {
    margin-bottom: 1.25rem;
}

.input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.prefix, .suffix {
    position: absolute;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 1rem;
    pointer-events: none;
}

.prefix { left: 1rem; }
.suffix { right: 1rem; }

input[type="number"], select {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
}

input[type="number"]::-webkit-outer-spin-button,
input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type="number"]:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
}

.has-prefix input { padding-left: 2rem; }
.has-suffix input { padding-right: 2.5rem; }

.results {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
}

.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.result-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.result-value {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.result-final .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent-color);
}

.copy-btn {
    background: none;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-ui);
    transition: all 0.2s;
}

.copy-btn:hover {
    border-color: var(--accent-color);
    color: var(--text-primary);
}

.chart-section {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.chart-header {
    margin-bottom: 1.5rem;
    text-align: center;
}

.chart-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.indicator {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
}

.indicator-a { background-color: var(--chart-color-a); }
.indicator-b { background-color: var(--chart-color-b); }
.indicator-c { background-color: var(--chart-color-c); }
.indicator-d { background-color: var(--chart-color-d); }

.chart-container {
    width: 100%;
    height: 400px;
    position: relative;
}

canvas {
    width: 100%;
    height: 100%;
}

.scenario-comparison {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .scenario-comparison {
        grid-template-columns: 1fr;
    }
}

.scenario-box {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
}

.scenario-box h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
}

.scenario-box .rate {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
}

.scenario-box .amount {
    font-family: var(--font-mono);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.scenario-box .detail {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}

.scenario-optimistic { border-top: 3px solid #50E3C2; }
.scenario-moderate { border-top: 3px solid #4A90E2; }
.scenario-conservative { border-top: 3px solid #D4A017; }

.scenario-optimistic .amount { color: #50E3C2; }
.scenario-moderate .amount { color: #4A90E2; }
.scenario-conservative .amount { color: #D4A017; }

.ss-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
}

.ss-card h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-color);
}

.ss-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

@media (max-width: 640px) {
    .ss-grid {
        grid-template-columns: 1fr;
    }
}

.ss-result {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.ss-result .result-value {
    font-size: 1rem;
}

.status-surplus { color: #50E3C2; }
.status-gap { color: #E85D75; }

.tips-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
}

@media (max-width: 640px) {
    .tips-grid {
        grid-template-columns: 1fr;
    }
}

.tip-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
}

.tip-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.tip-card ul {
    list-style: none;
    padding: 0;
}

.tip-card li {
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
    position: relative;
    font-size: 0.9rem;
}

.tip-card li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--accent-color);
    font-weight: bold;
}

.seo-content {
    margin-bottom: 4rem;
}

.seo-content h2 {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
}

.seo-content p {
    margin-bottom: 1rem;
    color: var(--text-secondary);
}

.seo-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
}

.seo-content li {
    margin-bottom: 0.5rem;
}

.faq-section {
    margin-bottom: 4rem;
}

.faq-section h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
}

.faq-item {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 0.75rem;
    overflow: hidden;
}

.faq-question {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.2s;
}

.faq-question:hover {
    color: var(--accent-color);
}

.faq-question::after {
    content: "+";
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text-secondary);
    transition: transform 0.2s;
    flex-shrink: 0;
    margin-left: 1rem;
}

.faq-item.open .faq-question::after {
    content: "−";
}

.faq-answer {
    display: none;
    padding: 0 1.5rem 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
}

.faq-item.open .faq-answer {
    display: block;
}

.related-links {
    margin-bottom: 3rem;
}

.related-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
}

.related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

@media (max-width: 640px) {
    .related-grid {
        grid-template-columns: 1fr;
    }
}

.related-grid a {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, color 0.2s;
}

.related-grid a:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
}

footer {
    text-align: center;
    padding: 2rem 0;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.875rem;
}

footer a {
    color: var(--accent-color);
    text-decoration: none;
    transition: color 0.2s;
}

footer a:hover {
    color: var(--text-primary);
    text-decoration: underline;
}
  </style>

<div class="container">
    <h1>Retirement Savings Calculator</h1>
    <p style="text-align:center; color:var(--text-secondary); font-size:1.1rem; margin-bottom:2rem;">Find out how much you need to retire and whether you're on track</p>

    <main>
        <div class="calculator-grid">
            <!-- Inputs -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your Details</h2>
                </div>

                <div class="inputs">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="input-group">
                            <label for="current-age">Current Age</label>
                            <div class="input-wrapper">
                                <input type="number" id="current-age" value="30" min="18" max="80" step="1">
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="retire-age">Retirement Age</label>
                            <div class="input-wrapper">
                                <input type="number" id="retire-age" value="65" min="30" max="90" step="1">
                            </div>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="current-savings">Current Retirement Savings</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="current-savings" value="50000" min="0" step="1000">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="monthly-contribution">Monthly Contribution</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="monthly-contribution" value="500" min="0" step="50">
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="input-group">
                            <label for="annual-return">Expected Return</label>
                            <div class="input-wrapper has-suffix">
                                <span class="suffix">%</span>
                                <input type="number" id="annual-return" value="7" min="0" max="15" step="0.5">
                            </div>
                        </div>
                        <div class="input-group">
                            <label for="inflation-rate">Inflation Rate</label>
                            <div class="input-wrapper has-suffix">
                                <span class="suffix">%</span>
                                <input type="number" id="inflation-rate" value="3" min="0" max="10" step="0.5">
                            </div>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="retirement-income">Desired Monthly Retirement Income (today's $)</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="retirement-income" value="5000" min="0" step="500">
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="annual-income">Current Annual Income (for SS estimate)</label>
                        <div class="input-wrapper has-prefix">
                            <span class="prefix">$</span>
                            <input type="number" id="annual-income" value="80000" min="0" step="5000">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="scenario-card">
                <div class="scenario-header">
                    <h2>Your Projections</h2>
                </div>

                <div class="results" style="margin-top: 0; border-top: none; padding-top: 0;">
                    <div class="result-item result-final" style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                        <span class="result-label" style="font-size: 1rem;">Projected Savings at Retirement</span>
                        <div class="result-value">
                            <span id="projected-savings">$0</span>
                            <button class="copy-btn" onclick="copyValue('projected-savings', this)">Copy</button>
                        </div>
                    </div>

                    <div class="result-item">
                        <span class="result-label">Total Needed (4% Rule)</span>
                        <span class="result-value" id="total-needed" style="color: var(--chart-color-b);">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Gap / Surplus</span>
                        <span class="result-value" id="gap-surplus">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Years Money Will Last</span>
                        <span class="result-value" id="years-last" style="color: var(--chart-color-a);">0</span>
                    </div>

                    <div style="flex-grow: 1;"></div>

                    <div class="result-item" style="padding-top: 1rem; border-top: 1px dashed var(--border-color);">
                        <span class="result-label">Total Contributions</span>
                        <span class="result-value" id="total-contributions" style="font-size: 1rem;">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Total Interest Earned</span>
                        <span class="result-value" id="total-interest" style="font-size: 1rem; color: var(--chart-color-a);">$0</span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">Real Return (after inflation)</span>
                        <span class="result-value" id="real-return" style="font-size: 0.9rem; font-family: var(--font-ui); color: var(--text-secondary);">0%</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart -->
        <div class="chart-section">
            <div class="chart-header">
                <h2>Savings Growth &amp; Drawdown Projection</h2>
                <div class="chart-legend">
                    <div class="legend-item"><span class="indicator indicator-a"></span> Savings Balance</div>
                    <div class="legend-item"><span class="indicator indicator-d"></span> Drawdown Phase</div>
                </div>
            </div>
            <div class="chart-container">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

        <!-- Scenario Comparison -->
        <h2 style="font-size: 1.75rem; margin-bottom: 1.5rem; color: var(--accent-color);">Scenario Comparison</h2>
        <div class="scenario-comparison">
            <div class="scenario-box scenario-optimistic">
                <h3>Optimistic</h3>
                <p class="rate">8% annual return</p>
                <p class="amount" id="sc-optimistic-bal">$0</p>
                <p class="detail" id="sc-optimistic-years">Money lasts: —</p>
                <p class="detail" id="sc-optimistic-gap">Gap/Surplus: —</p>
            </div>
            <div class="scenario-box scenario-moderate">
                <h3>Moderate</h3>
