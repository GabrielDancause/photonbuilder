  <script is:inline>
const formatCurrency = (value) => {
    return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
    }).format(value);
};

window.copyValue = async (elementId, btn) => {
    const text = document.getElementById(elementId).innerText;
    try {
        await navigator.clipboard.writeText(text);
        const orig = btn.innerText;
        btn.innerText = 'Copied!';
        setTimeout(() => { btn.innerText = orig; }, 2000);
    } catch (err) {
        console.error('Failed to copy: ', err);
    }
};

window.toggleFaq = (btn) => {
    const item = btn.parentElement;
    item.classList.toggle('open');
};

// Core projection engine
function projectSavings(currentAge, retireAge, currentSavings, monthlyContrib, annualReturnPct, inflationPct) {
    const years = Math.max(0, retireAge - currentAge);
    const realReturn = ((1 + annualReturnPct / 100) / (1 + inflationPct / 100)) - 1;
    const monthlyReturn = realReturn / 12;

    let balance = currentSavings;
    let totalContributed = currentSavings;
    const history = [{ age: currentAge, balance: balance }];

    for (let y = 1; y <= years; y++) {
        for (let m = 0; m < 12; m++) {
            balance = balance * (1 + monthlyReturn) + monthlyContrib;
        }
        totalContributed += monthlyContrib * 12;
        history.push({ age: currentAge + y, balance: balance });
    }

    return { balance, totalContributed, interest: balance - totalContributed, history, years, realReturn };
}

// Calculate years money lasts in drawdown
function calcYearsLast(balance, annualWithdrawal, realReturnPct) {
    if (annualWithdrawal <= 0) return Infinity;
    if (balance <= 0) return 0;

    const monthlyWithdraw = annualWithdrawal / 12;
    const monthlyReturn = realReturnPct / 12;
    let b = balance;
    let months = 0;
    const maxMonths = 100 * 12; // cap at 100 years

    while (b > 0 && months < maxMonths) {
        b = b * (1 + monthlyReturn) - monthlyWithdraw;
        months++;
    }

    return months / 12;
}

// Drawdown trajectory for chart
function calcDrawdown(startBalance, annualWithdrawal, realReturnPct, retireAge, maxAge) {
    const monthlyWithdraw = annualWithdrawal / 12;
    const monthlyReturn = realReturnPct / 12;
    let b = startBalance;
    const points = [{ age: retireAge, balance: b }];

    for (let age = retireAge + 1; age <= maxAge; age++) {
        for (let m = 0; m < 12; m++) {
            b = b * (1 + monthlyReturn) - monthlyWithdraw;
        }
        if (b < 0) b = 0;
        points.push({ age, balance: b });
        if (b <= 0) break;
    }
    return points;
}

// Social Security rough estimate
function estimateSS(annualIncome) {
    // Very rough progressive replacement
    // 2024 bend points simplified
    const monthlyIncome = annualIncome / 12;
    let pia = 0;

    if (monthlyIncome <= 1174) {
        pia = monthlyIncome * 0.9;
    } else if (monthlyIncome <= 7078) {
        pia = 1174 * 0.9 + (monthlyIncome - 1174) * 0.32;
    } else {
        pia = 1174 * 0.9 + (7078 - 1174) * 0.32 + (monthlyIncome - 7078) * 0.15;
    }

    // Cap roughly
    pia = Math.min(pia, 4873);
    return Math.round(pia);
}

// Run a scenario at a given return rate
function runScenario(returnRate) {
    const currentAge = parseInt(document.getElementById('current-age').value) || 30;
    const retireAge = parseInt(document.getElementById('retire-age').value) || 65;
    const currentSavings = parseFloat(document.getElementById('current-savings').value) || 0;
    const monthlyContrib = parseFloat(document.getElementById('monthly-contribution').value) || 0;
    const inflationRate = parseFloat(document.getElementById('inflation-rate').value) || 3;
    const desiredMonthly = parseFloat(document.getElementById('retirement-income').value) || 5000;

    const proj = projectSavings(currentAge, retireAge, currentSavings, monthlyContrib, returnRate, inflationRate);
    const annualNeed = desiredMonthly * 12;
    const totalNeeded = annualNeed * 25; // 4% rule
    const gap = proj.balance - totalNeeded;
    const realReturn = ((1 + returnRate / 100) / (1 + inflationRate / 100)) - 1;
    const yearsLast = calcYearsLast(proj.balance, annualNeed, realReturn);

    return { balance: proj.balance, totalNeeded, gap, yearsLast, proj };
}

function updateAll() {
    const currentAge = parseInt(document.getElementById('current-age').value) || 30;
    const retireAge = parseInt(document.getElementById('retire-age').value) || 65;
    const currentSavings = parseFloat(document.getElementById('current-savings').value) || 0;
    const monthlyContrib = parseFloat(document.getElementById('monthly-contribution').value) || 0;
    const annualReturn = parseFloat(document.getElementById('annual-return').value) || 7;
    const inflationRate = parseFloat(document.getElementById('inflation-rate').value) || 3;
    const desiredMonthly = parseFloat(document.getElementById('retirement-income').value) || 5000;
    const annualIncome = parseFloat(document.getElementById('annual-income').value) || 80000;

    // Main projection
    const proj = projectSavings(currentAge, retireAge, currentSavings, monthlyContrib, annualReturn, inflationRate);
    const annualNeed = desiredMonthly * 12;
    const totalNeeded = annualNeed * 25;
    const gap = proj.balance - totalNeeded;
    const realReturn = proj.realReturn;
    const yearsLast = calcYearsLast(proj.balance, annualNeed, realReturn);

    // Update main results
    document.getElementById('projected-savings').innerText = formatCurrency(proj.balance);
    document.getElementById('total-needed').innerText = formatCurrency(totalNeeded);

    const gapEl = document.getElementById('gap-surplus');
    if (gap >= 0) {
        gapEl.innerText = '+' + formatCurrency(gap);
        gapEl.className = 'result-value status-surplus';
    } else {
        gapEl.innerText = '-' + formatCurrency(Math.abs(gap));
        gapEl.className = 'result-value status-gap';
    }

    const yearsText = yearsLast >= 99 ? '99+ years' : yearsLast.toFixed(1) + ' years';
    document.getElementById('years-last').innerText = yearsText;

    document.getElementById('total-contributions').innerText = formatCurrency(proj.totalContributed);
    document.getElementById('total-interest').innerText = formatCurrency(proj.interest);
    document.getElementById('real-return').innerText = (realReturn * 100).toFixed(2) + '% per year';

    // Scenario comparison
    ['optimistic', 'moderate', 'conservative'].forEach((name, i) => {
        const rate = [8, 6, 4][i];
        const sc = runScenario(rate);
        document.getElementById('sc-' + name + '-bal').innerText = formatCurrency(sc.balance);
        const yrs = sc.yearsLast >= 99 ? '99+ years' : sc.yearsLast.toFixed(1) + ' years';
        document.getElementById('sc-' + name + '-years').innerText = 'Money lasts: ' + yrs;
        const gapText = sc.gap >= 0 ? 'Surplus: ' + formatCurrency(sc.gap) : 'Gap: -' + formatCurrency(Math.abs(sc.gap));
        document.getElementById('sc-' + name + '-gap').innerText = gapText;
    });

    // Social Security
    const ssMonthly = estimateSS(annualIncome);
    const ssAnnual = ssMonthly * 12;
    const ssReplacement = annualIncome > 0 ? ((ssAnnual / annualIncome) * 100).toFixed(0) : 0;
    const incomeGapAfterSS = Math.max(0, annualNeed - ssAnnual);
    const savingsNeededAfterSS = incomeGapAfterSS * 25;

    document.getElementById('ss-monthly').innerText = formatCurrency(ssMonthly);
    document.getElementById('ss-annual').innerText = formatCurrency(ssAnnual);
    document.getElementById('ss-replaced').innerText = ssReplacement + '%';
    document.getElementById('ss-needed').innerText = formatCurrency(savingsNeededAfterSS);

    // Draw chart
    drawChart(proj, annualNeed, realReturn, retireAge);
}

// Chart
let chartCanvas = document.getElementById('growthChart');
let ctx = chartCanvas.getContext('2d');

function drawChart(proj, annualWithdrawal, realReturn, retireAge) {
    const history = proj.history;
    if (history.length <= 1) {
        ctx.clearRect(0, 0, chartCanvas.width, chartCanvas.height);
        return;
    }

    // Drawdown phase
    const drawdownData = calcDrawdown(proj.balance, annualWithdrawal, realReturn, retireAge, retireAge + 40);

    // Combine: growth phase ages, then drawdown ages (skip first to avoid duplicate)
    const allPoints = [...history, ...drawdownData.slice(1)];
    const minAge = allPoints[0].age;
    const maxAge = allPoints[allPoints.length - 1].age;
    const maxBalance = Math.max(...allPoints.map(p => p.balance));

    const dpr = window.devicePixelRatio || 1;
    const rect = chartCanvas.parentElement.getBoundingClientRect();
    chartCanvas.width = rect.width * dpr;
    chartCanvas.height = rect.height * dpr;
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);

    const width = rect.width;
    const height = rect.height;
    ctx.clearRect(0, 0, width, height);

    const padding = { top: 20, right: 20, bottom: 40, left: 80 };
    const cw = width - padding.left - padding.right;
    const ch = height - padding.top - padding.bottom;

    const ageSpan = maxAge - minAge || 1;
    const xOf = (age) => padding.left + cw * ((age - minAge) / ageSpan);
    const yOf = (val) => height - padding.bottom - ch * (val / (maxBalance || 1));

    // Grid
    ctx.strokeStyle = '#2a2010';
    ctx.lineWidth = 1;
    ctx.font = '12px Inter, sans-serif';
    ctx.fillStyle = '#888888';

    // Y-axis
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    const yTicks = 5;
    for (let i = 0; i <= yTicks; i++) {
        const val = maxBalance * (i / yTicks);
        const y = yOf(val);
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(width - padding.right, y);
        ctx.stroke();
        const label = val >= 1e6 ? '$' + (val / 1e6).toFixed(1) + 'M' :
                      val >= 1e3 ? '$' + (val / 1e3).toFixed(0) + 'k' : '$' + val.toFixed(0);
        ctx.fillText(label, padding.left - 10, y);
    }

    // X-axis
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    const xTicks = Math.min(ageSpan, 10);
    for (let i = 0; i <= xTicks; i++) {
        const age = Math.round(minAge + ageSpan * (i / xTicks));
        const x = xOf(age);
        ctx.beginPath();
        ctx.moveTo(x, height - padding.bottom);
        ctx.lineTo(x, height - padding.bottom + 5);
        ctx.stroke();
        ctx.fillText('Age ' + age, x, height - padding.bottom + 10);
    }

    // Retirement line
    if (retireAge > minAge && retireAge < maxAge) {
        ctx.strokeStyle = '#555';
        ctx.setLineDash([4, 4]);
        ctx.beginPath();
        ctx.moveTo(xOf(retireAge), padding.top);
        ctx.lineTo(xOf(retireAge), height - padding.bottom);
        ctx.stroke();
        ctx.setLineDash([]);

        ctx.fillStyle = '#888';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        ctx.fillText('Retire', xOf(retireAge), padding.top - 2);
    }

    // Growth phase area
    ctx.beginPath();
    ctx.moveTo(xOf(history[0].age), yOf(history[0].balance));
    for (let i = 1; i < history.length; i++) {
        ctx.lineTo(xOf(history[i].age), yOf(history[i].balance));
    }
    ctx.lineTo(xOf(history[history.length - 1].age), yOf(0));
    ctx.lineTo(xOf(history[0].age), yOf(0));
    ctx.closePath();
    ctx.fillStyle = 'rgba(212, 160, 23, 0.25)';
    ctx.fill();

    // Growth line
    ctx.beginPath();
    ctx.strokeStyle = '#D4A017';
    ctx.lineWidth = 2.5;
    ctx.lineJoin = 'round';
    history.forEach((p, i) => {
        const x = xOf(p.age), y = yOf(p.balance);
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.stroke();

    // Drawdown phase area
    if (drawdownData.length > 1) {
        ctx.beginPath();
        ctx.moveTo(xOf(drawdownData[0].age), yOf(drawdownData[0].balance));
        for (let i = 1; i < drawdownData.length; i++) {
            ctx.lineTo(xOf(drawdownData[i].age), yOf(drawdownData[i].balance));
        }
        ctx.lineTo(xOf(drawdownData[drawdownData.length - 1].age), yOf(0));
        ctx.lineTo(xOf(drawdownData[0].age), yOf(0));
        ctx.closePath();
        ctx.fillStyle = 'rgba(232, 93, 117, 0.2)';
        ctx.fill();

        // Drawdown line
        ctx.beginPath();
        ctx.strokeStyle = '#E85D75';
        ctx.lineWidth = 2.5;
        drawdownData.forEach((p, i) => {
            const x = xOf(p.age), y = yOf(p.balance);
            i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
        ctx.stroke();
    }
}

// Event listeners
document.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', updateAll);
});

window.addEventListener('resize', updateAll);

setTimeout(updateAll, 0);
  </script>

