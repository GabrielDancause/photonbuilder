---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Lease vs Buy Car Calculator",
  "url": "https://firemaths.info/car-lease-vs-buy-calculator.html",
  "description": "Interactive calculator to compare the true cost of leasing versus buying a car over 3, 5, and 7 years, factoring in depreciation, interest, maintenance, and insurance.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Lease vs Buy Car Calculator: Which Is Actually Cheaper?"
  description="One option drains your net worth 3x faster—and it's not the one you think. Over 5 years, the true cost difference will shock you. See the math."
  canonical="https://firemaths.info/car-lease-vs-buy-calculator.html" schema={schema}
>


<!-- STICKY NAV -->
    

    <div class="max-w-4xl mx-auto px-5 py-12 text-white">
        

        <main>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 items-start">
                <!-- Vehicle & Buy Inputs -->
                <div class="input-card">
                    <h2>Purchase & Loan Details</h2>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="car-price">Vehicle Price (MSRP/Negotiated)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="car-price" value="35000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="down-payment">Down Payment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="down-payment" value="3000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="loan-rate">Loan Interest Rate (APR)</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">%</span>
                            <input type="number" id="loan-rate" value="6.5" min="0" step="0.1" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="loan-term">Loan Term (Months)</label>
                        <select id="loan-term" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                            <option value="36">36 Months</option>
                            <option value="48">48 Months</option>
                            <option value="60" selected>60 Months</option>
                            <option value="72">72 Months</option>
                            <option value="84">84 Months</option>
                        </select>
                    </div>
                </div>

                <!-- Lease & Operating Inputs -->
                <div class="input-card">
                    <h2>Lease & Operating Details</h2>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="lease-payment">Monthly Lease Payment</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="lease-payment" value="450" min="0" step="10" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="lease-down">Lease Due at Signing</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="lease-down" value="3000" min="0" step="100" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="miles-year">Miles Per Year</label>
                        <select id="miles-year" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-sans cursor-pointer appearance-none pr-10 text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-sans bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none cursor-pointer appearance-none w-full border text-base transition-colors">
                            <option value="10000">10,000 miles</option>
                            <option value="12000" selected>12,000 miles</option>
                            <option value="15000">15,000 miles</option>
                        </select>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="insurance-diff">Extra Monthly Insurance (Lease vs Buy)</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono text-base pointer-events-none">$</span>
                            <input type="number" id="insurance-diff" value="25" min="0" step="5" title="Leasing often requires higher coverage limits" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg py-3 text-white font-mono text-base focus:border-[var(--accent-color)] focus:outline-none transition-colors px-4 font-mono bg-[var(--bg-color)] py-3 border-[var(--border-color)] px-4 text-white rounded-lg focus:border-[var(--accent-color)] focus:outline-none w-full border text-base transition-colors">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results Section -->
            <div class="flex flex-col gap-6">
                <h2>Total Cost Comparison</h2>

                <div class="timeframe-selector">
                    <button class="flex-1 py-2 text-sm font-semibold text-white bg-[var(--accent-color)] border border-[var(--accent-color)] rounded transition-colors" data-years="3">3 Years</button>
                    <button class="flex-1 py-2 text-sm font-semibold text-[var(--text-secondary)] bg-[var(--bg-color)] border border-[var(--border-color)] rounded hover:bg-[var(--card-bg)] transition-colors" data-years="5">5 Years</button>
                    <button class="flex-1 py-2 text-sm font-semibold text-[var(--text-secondary)] bg-[var(--bg-color)] border border-[var(--border-color)] rounded hover:bg-[var(--card-bg)] transition-colors" data-years="7">7 Years</button>
                </div>

                <div class="winner-banner" id="winner-banner">
                    <h3 id="winner-title">Buying Wins</h3>
                    <p id="winner-text">Saves $0 over 5 years</p>
                </div>

                <div class="comparison-grid">
                    <div class="result-col">
                        <h3>If You Buy</h3>
                        <div class="result-row">
                            <span>Down Payment</span>
                            <span id="buy-down-res">$0</span>
                        </div>
                        <div class="result-row">
                            <span>Total Loan Payments</span>
                            <span id="buy-payments-res">$0</span>
                        </div>
                        <div class="result-row">
                            <span>Estimated Maintenance</span>
                            <span id="buy-maint-res">$0</span>
                        </div>
                        <div class="result-row">
                            <span>Vehicle Equity (Asset Value)</span>
                            <span id="buy-equity-res">+$0</span>
                        </div>
                        <div class="result-row total">
                            <span>True Net Cost</span>
                            <span id="buy-total-res">$0</span>
                        </div>
                    </div>

                    <div class="result-col">
                        <h3>If You Lease</h3>
                        <div class="result-row">
                            <span>Due at Signing(s)</span>
                            <span id="lease-down-res">$0</span>
                        </div>
                        <div class="result-row">
                            <span>Total Lease Payments</span>
                            <span id="lease-payments-res">$0</span>
                        </div>
                        <div class="result-row">
                            <span>Extra Insurance Costs</span>
                            <span id="lease-ins-res">$0</span>
                        </div>
                        <div class="result-row">
                            <span>Disposition Fees</span>
                            <span id="lease-disp-res">$0</span>
                        </div>
                        <div class="result-row total">
                            <span>True Net Cost</span>
                            <span id="lease-total-res">$0</span>
                        </div>
                    </div>
                </div>

                <div class="w-full h-[400px] relative">
                    <canvas id="costChart"></canvas>
                </div>
            </div>

            <!-- SEO Content & FAQ -->
            <div class="content-section">
                <h2>Is it cheaper to lease or buy?</h2>
                <p>The eternal question in personal finance: <strong>is it cheaper to lease or buy a car?</strong> The answer depends heavily on your timeframe. In the short term (2-3 years), a car lease calculator will often show leasing as the cheaper option due to lower monthly payments. However, over 5 to 7 years, buying almost universally wins out because you eventually stop making payments and own an asset with residual value.</p>

                <h3>When leasing makes sense vs buying</h3>
                <p>Despite the long-term math usually favoring purchasing, leasing can make sense in specific scenarios:</p>
                <ul>
                    <li><strong>Business Owners:</strong> If you use the car for business, lease payments can often be deducted as a business expense.</li>
                    <li><strong>The "New Car" Preference:</strong> If you are absolutely committed to driving a brand new car every 3 years for safety, reliability, or status, leasing is generally a more efficient way to do so than constantly trading in purchased vehicles.</li>
                    <li><strong>Cash Flow Investing:</strong> If you take the monthly savings from a lease payment (compared to a higher loan payment) and invest it into assets yielding high returns, you might outpace the financial penalty of leasing. (Though few people actually do this disciplined investing).</li>
                </ul>
            </div>

            <div class="content-section">
                <h2>Frequently Asked Questions</h2>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">Is it cheaper to lease or buy a car?</div>
                    <div class="faq-answer">Over a short period (3 years), leasing often looks cheaper due to lower monthly payments. However, over 5 to 7 years, buying is almost always cheaper because you eventually own an asset with residual value and eliminate monthly payments.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">What is a car lease calculator?</div>
                    <div class="faq-answer">A car lease calculator estimates your monthly lease payment and total out-of-pocket costs by factoring in the vehicle price, money factor (interest rate), lease term, residual value, down payment, and taxes.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">How does a lease vs buy car calculator work?</div>
                    <div class="faq-answer">It compares the total cost of ownership for both options. For buying, it calculates loan payments, depreciation, and equity. For leasing, it calculates total lease payments and fees. It then compares the net cost after 3, 5, or 7 years.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">Should I lease a car to get a lower monthly payment?</div>
                    <div class="faq-answer">While leasing provides a lower monthly payment, you are continuously paying for the steepest part of a car's depreciation without building any equity. It makes sense for cash flow, but not for long-term wealth building.</div>
                </div>

                <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 shadow-sm">
                    <div class="faq-question">When does leasing a car make financial sense?</div>
                    <div class="faq-answer">Leasing makes sense if you can deduct the lease as a business expense, if you strictly want a new car every 3 years and are willing to pay a premium for it, or if you invest the monthly payment savings into high-yield assets.</div>
                </div>
            </div>
        </main>

        
    </div>
  <script is:inline>
// Formatting helper
        const formatCurrency = (val) => {
            return new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            }).format(Math.round(val));
        };

        // State
        let currentYears = 3;

        // Depreciation Curve (rough estimate based on industry averages)
        // Year 1: -20%, Year 2: -15%, Year 3: -10%, Year 4: -10%, Year 5: -10%, Year 6: -5%, Year 7: -5%
        const getDepreciationRetained = (years) => {
            const curve = {
                0: 1.0,
                1: 0.80,
                2: 0.65,
                3: 0.55,
                4: 0.45,
                5: 0.35,
                6: 0.30,
                7: 0.25
            };
            return curve[years] || 0.20;
        };

        // Estimated maintenance costs per year
        const getMaintenanceCost = (years) => {
            const annualCost = [0, 100, 200, 400, 600, 800, 1000, 1200];
            let total = 0;
            for(let i=1; i<=years; i++) {
                total += annualCost[i] || 1500;
            }
            return total;
        };

        const calculate = () => {
            // Inputs
            const price = parseFloat(document.getElementById('car-price').value) || 0;
            const downPmt = parseFloat(document.getElementById('down-payment').value) || 0;
            const loanRate = parseFloat(document.getElementById('loan-rate').value) || 0;
            const loanTerm = parseInt(document.getElementById('loan-term').value) || 60;

            const leasePmt = parseFloat(document.getElementById('lease-payment').value) || 0;
            const leaseDown = parseFloat(document.getElementById('lease-down').value) || 0;
            const insDiff = parseFloat(document.getElementById('insurance-diff').value) || 0;

            const months = currentYears * 12;

            // --- BUY CALCULATIONS ---
            const loanAmount = price - downPmt;
            let buyMonthly = 0;

            if (loanAmount > 0 && loanRate > 0) {
                const r = (loanRate / 100) / 12;
                buyMonthly = loanAmount * (r * Math.pow(1 + r, loanTerm)) / (Math.pow(1 + r, loanTerm) - 1);
            } else if (loanAmount > 0) {
                buyMonthly = loanAmount / loanTerm;
            }

            const monthsPaid = Math.min(months, loanTerm);
            const totalBuyPayments = buyMonthly * monthsPaid;

            // Calculate remaining loan balance if sold before loan ends
            let remainingLoan = 0;
            if (months < loanTerm && loanRate > 0) {
                const r = (loanRate / 100) / 12;
                remainingLoan = loanAmount * (Math.pow(1 + r, loanTerm) - Math.pow(1 + r, months)) / (Math.pow(1 + r, loanTerm) - 1);
            } else if (months < loanTerm) {
                remainingLoan = loanAmount - (buyMonthly * months);
            }

            const carValue = price * getDepreciationRetained(currentYears);
            const equity = carValue - remainingLoan;
            const maintenance = getMaintenanceCost(currentYears);

            const buyNetCost = downPmt + totalBuyPayments + maintenance - equity;

            // --- LEASE CALCULATIONS ---
            // Assume 36 month lease terms back-to-back
            const numLeases = Math.ceil(currentYears / 3);
            const totalLeaseDown = leaseDown * numLeases;
            const totalLeasePayments = leasePmt * months;
            const totalInsDiff = insDiff * months;

            // Disposition fee assume $395 per lease end
            let dispFees = 0;
            if (currentYears >= 3) dispFees += 395;
            if (currentYears >= 6) dispFees += 395;

            const leaseNetCost = totalLeaseDown + totalLeasePayments + totalInsDiff + dispFees;

            // --- UPDATE DOM ---
            document.getElementById('buy-down-res').innerText = formatCurrency(downPmt);
            document.getElementById('buy-payments-res').innerText = formatCurrency(totalBuyPayments);
            document.getElementById('buy-maint-res').innerText = formatCurrency(maintenance);

            const equityEl = document.getElementById('buy-equity-res');
            equityEl.innerText = (equity >= 0 ? '+' : '') + formatCurrency(equity);
            equityEl.style.color = equity >= 0 ? 'var(--success-color)' : 'var(--danger-color)';

            document.getElementById('buy-total-res').innerText = formatCurrency(buyNetCost);

            document.getElementById('lease-down-res').innerText = formatCurrency(totalLeaseDown);
            document.getElementById('lease-payments-res').innerText = formatCurrency(totalLeasePayments);
            document.getElementById('lease-ins-res').innerText = formatCurrency(totalInsDiff);
            document.getElementById('lease-disp-res').innerText = formatCurrency(dispFees);
            document.getElementById('lease-total-res').innerText = formatCurrency(leaseNetCost);

            // Winner
            const banner = document.getElementById('winner-banner');
            const title = document.getElementById('winner-title');
            const text = document.getElementById('winner-text');

            if (buyNetCost < leaseNetCost) {
                const diff = leaseNetCost - buyNetCost;
                banner.style.backgroundColor = 'rgba(74, 255, 138, 0.1)';
                banner.style.borderColor = 'var(--success-color)';
                title.style.color = 'var(--success-color)';
                title.innerText = 'Buying Wins';
                text.innerText = `Saves ${formatCurrency(diff)} over ${currentYears} years`;
            } else {
                const diff = buyNetCost - leaseNetCost;
                banner.style.backgroundColor = 'rgba(212, 160, 23, 0.1)';
                banner.style.borderColor = 'var(--accent-color)';
                title.style.color = 'var(--accent-color)';
                title.innerText = 'Leasing Wins';
                text.innerText = `Saves ${formatCurrency(diff)} over ${currentYears} years`;
            }

            drawChart(buyNetCost, leaseNetCost);
        };

        let chartCanvas = document.getElementById('costChart');
        let ctx = chartCanvas.getContext('2d');

        const drawChart = (buyCost, leaseCost) => {
            const dpr = window.devicePixelRatio || 1;
            const rect = chartCanvas.parentElement.getBoundingClientRect();

            chartCanvas.width = rect.width * dpr;
            chartCanvas.height = rect.height * dpr;

            ctx.setTransform(1, 0, 0, 1, 0, 0);
            ctx.scale(dpr, dpr);

            const width = rect.width;
            const height = rect.height;

            ctx.clearRect(0, 0, width, height);

            const padding = { top: 40, right: 20, bottom: 40, left: 20 };
            const chartWidth = width - padding.left - padding.right;
            const chartHeight = height - padding.top - padding.bottom;

            const maxCost = Math.max(buyCost, leaseCost) * 1.1; // 10% headroom

            const barWidth = Math.min(100, chartWidth / 4);
            const spacing = chartWidth / 4;

            const buyX = padding.left + spacing - (barWidth/2);
            const leaseX = padding.left + (spacing * 3) - (barWidth/2);

            const buyH = (buyCost / maxCost) * chartHeight;
            const leaseH = (leaseCost / maxCost) * chartHeight;

            // Draw axes
            ctx.strokeStyle = '#152040';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(padding.left, height - padding.bottom);
            ctx.lineTo(width - padding.right, height - padding.bottom);
            ctx.stroke();

            // Draw Buy Bar
            ctx.fillStyle = '#4aff8a';
            ctx.fillRect(buyX, height - padding.bottom - buyH, barWidth, buyH);

            // Draw Lease Bar
            ctx.fillStyle = '#D4A017';
            ctx.fillRect(leaseX, height - padding.bottom - leaseH, barWidth, leaseH);

            // Labels
            ctx.fillStyle = '#e0d8c8';
            ctx.font = '600 14px Inter, sans-serif';
            ctx.textAlign = 'center';

            // X-axis labels
            ctx.fillText('Buying', buyX + (barWidth/2), height - padding.bottom + 25);
            ctx.fillText('Leasing', leaseX + (barWidth/2), height - padding.bottom + 25);

            // Values on top
            ctx.font = '500 13px JetBrains Mono, monospace';
            ctx.fillText(formatCurrency(buyCost), buyX + (barWidth/2), height - padding.bottom - buyH - 10);
            ctx.fillText(formatCurrency(leaseCost), leaseX + (barWidth/2), height - padding.bottom - leaseH - 10);
        };

        // Event Listeners
        document.querySelectorAll('input, select').forEach(el => {
            el.addEventListener('input', calculate);
        });

        document.querySelectorAll('.timeframe-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.timeframe-btn').forEach(b => b.classList.remove('active'));
                e.target.classList.add('active');
                currentYears = parseInt(e.target.dataset.years);
                calculate();
            });
        });

        window.addEventListener('resize', calculate);

        // Initial run
        setTimeout(calculate, 100);
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-real-estate-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Real Estate Investing: Complete Beginner's Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
