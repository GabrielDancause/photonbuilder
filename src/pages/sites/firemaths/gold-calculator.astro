---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Scrap Gold Value Calculator | Calculate by Karat & Weight",
  description: "Find out how much your gold is actually worth right now. Calculate the exact scrap value of your gold jewelry based on karat, weight, and current market price.",
  category: "tool",
  published: "2024-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How is the scrap value of gold calculated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The scrap value is calculated by multiplying the weight of the item by the gold purity percentage (karat / 24) and then by the current market price of gold per unit of weight."
          }
        },
        {
          "@type": "Question",
          "name": "What does karat mean in gold?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Karat is a measure of gold purity out of 24 parts. For example, 24k is 100% pure gold, 18k is 75% pure (18/24), and 14k is 58.3% pure (14/24)."
          }
        },
        {
          "@type": "Question",
          "name": "Why is the scrap value lower than the retail price?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The retail price includes markup for design, labor, marketing, and the jeweler's profit. Scrap value only accounts for the raw material cost of the pure gold content."
          }
        },
        {
          "@type": "Question",
          "name": "How many grams are in a Troy Ounce?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There are exactly 31.1034768 grams in one Troy Ounce. Precious metals are weighed in Troy Ounces, not standard (Avoirdupois) ounces which equal 28.35 grams."
          }
        },
        {
          "@type": "Question",
          "name": "What is pennyweight (dwt)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pennyweight (abbreviated dwt) is a traditional unit of mass for precious metals. One pennyweight is equal to 1.555 grams or 1/20th of a Troy Ounce."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": "Gold Value Calculator: Determine Your Jewelry's Scrap Value",
      "description": "Calculate the true melt value of your scrap gold, jewelry, or coins based on current spot prices, weight, and karat purity.",
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      }
    }
  ]
};
---

<SiteLayout
  site="firemaths"
  title="Scrap Gold Value Calculator | Real-Time Melt Value"
  description="Find out how much your gold is actually worth right now. Calculate the exact scrap value of your gold jewelry based on karat, weight, and current market price."
  canonical="https://firemaths.info/gold-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Gold Value Calculator</h1>
      <p class="subtitle">Calculate the true scrap melt value of your gold jewelry and coins.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-group">
          <label for="gold-price">Current Gold Spot Price ($/Troy Oz)</label>
          <input type="number" id="gold-price" placeholder="e.g. 2350.50" value="2350" step="0.01" min="0">
        </div>

        <div class="input-group">
          <label for="purity">Gold Purity (Karat)</label>
          <select id="purity">
            <option value="24">24k (99.9% Pure)</option>
            <option value="22">22k (91.6% Pure)</option>
            <option value="21">21k (87.5% Pure)</option>
            <option value="18">18k (75.0% Pure)</option>
            <option value="14" selected>14k (58.3% Pure)</option>
            <option value="10">10k (41.7% Pure)</option>
            <option value="9">9k (37.5% Pure)</option>
          </select>
        </div>

        <div class="input-group">
          <label for="weight">Weight</label>
          <div style="display: flex; gap: 0.5rem;">
            <input type="number" id="weight" placeholder="e.g. 10" value="10" step="0.01" min="0" style="flex: 2;">
            <select id="weight-unit" style="flex: 1;">
              <option value="grams" selected>Grams (g)</option>
              <option value="oz">Troy Oz</option>
              <option value="dwt">Pennyweight (dwt)</option>
            </select>
          </div>
        </div>
      </div>

      <div class="result-card">
        <div class="result-label">Estimated Scrap Value</div>
        <div class="result-value" id="res-value">$0.00</div>
        <div style="color: var(--text-secondary); margin-top: 1rem; font-size: 0.9rem;">
          Pure Gold Content: <span id="res-pure-weight" style="font-family: var(--font-mono); font-weight: 600;">0</span> Troy Oz
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>How is Scrap Gold Value Calculated?</h2>
      <p>Whether you're looking to sell old jewelry, evaluate an inheritance, or invest in precious metals, understanding how to calculate the true value of gold is an essential skill. Our Gold Value Calculator helps you determine the "melt value" or "scrap value" of your items. But what exactly does this mean, and how does the underlying math work?</p>

      <h3>The Fundamentals of Gold Pricing</h3>
      <p>The value of your gold depends entirely on three crucial factors: the current market price of gold (often called the "spot price"), the purity of your item (measured in karats), and the actual physical weight of the item.</p>

      <h4>1. The Spot Price of Gold</h4>
      <p>The spot price of gold is the current market price at which one Troy Ounce of pure (24k) gold can be bought or sold for immediate delivery. This price fluctuates continuously during market hours based on global supply and demand, geopolitical events, inflation rates, and currency values. Our calculator defaults to a recent baseline price, but you can manually enter today's exact spot price for perfect accuracy.</p>

      <h4>2. Understanding Purity (Karats)</h4>
      <p>Pure gold is generally too soft to be used for everyday jewelry like rings or bracelets. Therefore, jewelers alloy (mix) pure gold with harder metals such as copper, silver, nickel, or zinc to increase its durability. The "karat" (k) system measures the ratio of pure gold to other metals out of 24 parts.</p>
      <ul>
        <li><strong>24k Gold:</strong> 24 out of 24 parts are gold (99.9% pure).</li>
        <li><strong>18k Gold:</strong> 18 out of 24 parts are gold (75.0% pure).</li>
        <li><strong>14k Gold:</strong> 14 out of 24 parts are gold (58.3% pure).</li>
        <li><strong>10k Gold:</strong> 10 out of 24 parts are gold (41.7% pure).</li>
      </ul>
      <p>To find the decimal purity, simply divide the karat number by 24. For instance, 14 / 24 = 0.5833 (or 58.33%).</p>

      <h4>3. Weighing Precious Metals</h4>
      <p>When weighing gold, the industry relies on Troy Ounces, not the standard Avoirdupois ounces you use to weigh food in your kitchen. This is a critical distinction that often causes confusion.</p>
      <ul>
        <li>1 Troy Ounce = 31.1034768 grams</li>
        <li>1 Standard (Avoirdupois) Ounce = 28.3495 grams</li>
      </ul>
      <p>Jewelers also frequently use a measurement called "pennyweight" (abbreviated as dwt). One Troy Ounce equals precisely 20 pennyweights, meaning one pennyweight is roughly 1.555 grams.</p>

      <h3>The Calculation Formula</h3>
      <p>To calculate the melt value of your gold, you must convert the total weight into Troy Ounces, determine the actual amount of pure gold inside the alloy, and multiply that by the current spot price.</p>
      <div class="formula-box">
        Scrap Value = (Weight in Troy Oz) &times; (Karat / 24) &times; (Spot Price)
      </div>
      <p>Let's look at an example. Imagine you have a 14k gold chain that weighs 20 grams, and the current gold spot price is $2,000 per Troy Ounce.</p>
      <ol>
        <li>Convert 20 grams to Troy Ounces: 20 / 31.103 = 0.643 Troy Oz.</li>
        <li>Calculate purity: 14k / 24 = 0.5833 (58.33% pure gold).</li>
        <li>Find the pure gold weight: 0.643 Troy Oz &times; 0.5833 = 0.375 Troy Oz of pure gold.</li>
        <li>Calculate final value: 0.375 Troy Oz &times; $2,000 = $750.</li>
      </ol>
      <p>Your 14k chain has a raw melt value of $750.</p>

      <h3>Why Do Buyers Offer Less Than Melt Value?</h3>
      <p>If your calculator says your gold is worth $750, a pawn shop, jewelry store, or "cash for gold" business will likely offer you less—sometimes significantly less (e.g., 60% to 80% of the melt value). Why?</p>
      <p>The calculated value is the strict, raw material cost. However, the buyer must account for the cost of refining (melting the item down and separating the pure gold from the alloyed metals), business overhead, and their own profit margin. Therefore, the melt value serves as the maximum theoretical baseline, ensuring you are well-informed before negotiating a sale.</p>
      <p>If you're dealing with multiple distinct weights or evaluating statistical averages of coin sets, you can easily crunch those numbers over at our Mean Calculator.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How is the scrap value of gold calculated?</summary>
        <p>The scrap value is calculated by determining the item's weight in Troy Ounces, multiplying it by the purity percentage (Karat / 24) to find the exact weight of pure gold, and finally multiplying that by the current spot market price of gold.</p>
      </details>
      <details>
        <summary>What does karat mean in gold?</summary>
        <p>Karat is a measure of gold purity based on 24 parts. 24 karat (24k) is pure gold. An 18k item consists of 18 parts gold and 6 parts alloy metals (75% pure). A 14k item is 14 parts gold and 10 parts alloy (58.3% pure).</p>
      </details>
      <details>
        <summary>Why is the scrap value lower than the retail price?</summary>
        <p>When you buy jewelry at retail, you pay for the raw gold, plus the jeweler's labor, design costs, marketing, store overhead, and profit margin. Scrap value completely ignores these factors and only values the raw, pure gold material left over if the item were melted down.</p>
      </details>
      <details>
        <summary>How many grams are in a Troy Ounce?</summary>
        <p>There are exactly 31.1034768 grams in one Troy Ounce. This is heavier than a standard (Avoirdupois) ounce used for food and mail, which is roughly 28.35 grams.</p>
      </details>
      <details>
        <summary>What is pennyweight (dwt)?</summary>
        <p>Pennyweight (abbreviated dwt) is an old jewelry industry standard for measuring precious metals. There are 20 pennyweights in a single Troy Ounce, which means one pennyweight is equal to about 1.555 grams.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const elPrice = document.getElementById('gold-price');
      const elPurity = document.getElementById('purity');
      const elWeight = document.getElementById('weight');
      const elUnit = document.getElementById('weight-unit');
      const resValue = document.getElementById('res-value');
      const resPureWeight = document.getElementById('res-pure-weight');

      const GRAMS_IN_TROY_OZ = 31.1034768;

      function formatCurrency(num) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(num);
      }

      function formatNumber(num) {
        return new Intl.NumberFormat('en-US', { maximumFractionDigits: 4 }).format(num);
      }

      function calculate() {
        const spotPrice = parseFloat(elPrice.value);
        const karat = parseFloat(elPurity.value);
        const weight = parseFloat(elWeight.value);
        const unit = elUnit.value;

        if (isNaN(spotPrice) || isNaN(karat) || isNaN(weight)) {
          resValue.textContent = '$0.00';
          resPureWeight.textContent = '0';
          return;
        }

        // Convert weight to Troy Ounces
        let weightTroyOz = 0;
        if (unit === 'grams') {
          weightTroyOz = weight / GRAMS_IN_TROY_OZ;
        } else if (unit === 'oz') {
          weightTroyOz = weight;
        } else if (unit === 'dwt') {
          // 20 dwt = 1 troy oz
          weightTroyOz = weight / 20;
        }

        // Calculate Purity Percentage
        const purityPercent = karat / 24;

        // Calculate Pure Gold Weight in Troy Oz
        const pureGoldWeight = weightTroyOz * purityPercent;

        // Calculate Total Value
        const totalValue = pureGoldWeight * spotPrice;

        resValue.textContent = formatCurrency(totalValue);
        resPureWeight.textContent = formatNumber(pureGoldWeight);
      }

      elPrice.addEventListener('input', calculate);
      elPurity.addEventListener('change', calculate);
      elWeight.addEventListener('input', calculate);
      elUnit.addEventListener('change', calculate);

      // Initial calculation
      calculate();
    });
  </script>

