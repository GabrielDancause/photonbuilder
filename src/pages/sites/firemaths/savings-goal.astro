---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Savings Goal Calculator",
  "url": "https://firemaths.info/savings-goal",
  "description": "Calculate how long it will take to reach your savings goal with monthly contributions, considering interest and inflation.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="Savings Goal Calculator | firemaths.info"
  description="Calculate how long it will take to reach your savings goal with monthly contributions, considering interest and inflation. Visualize your progress."
  canonical="https://firemaths.info/savings-goal" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            <!-- Inputs -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Your Goal Inputs</h2>
                </div>

                <div class="space-y-4">
                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="goal-target">Savings Goal Target</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="goal-target" value="100000" min="1" step="1000">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="initial-saved">Currently Saved</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="initial-saved" value="10000" min="0" step="500">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="monthly-contribution">Monthly Contribution</label>
                        <div class="relative flex items-center">
                            <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors pl-8" id="monthly-contribution" value="1000" min="0" step="50">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="annual-return">Expected Annual Return</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">%</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="annual-return" value="7" min="0" step="0.1" max="100">
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide" for="annual-inflation">Annual Inflation Rate (Adjusts Goal)</label>
                        <div class="relative flex items-center">
                            <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">%</span>
                            <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" id="annual-inflation" value="2" min="0" step="0.1" max="100">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Your Progress Plan</h2>
                </div>

                <div class="mt-8 pt-6 border-t border-[var(--border-color)]">
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Time to Reach Goal</span>
                        <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                            <span id="time-to-goal">0 Years, 0 Months</span>
                            <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('time-to-goal', this)">Copy</button>
                        </div>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Final Adjusted Goal Target</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="final-goal-target">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Contributions</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="total-contributions">$0</span>
                    </div>
                    <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                        <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Interest Earned</span>
                        <span class="font-mono text-lg font-medium text-white flex items-center gap-2" id="total-interest">$0</span>
                    </div>
                    <div id="error-msg" class="error-message">Goal is unreachable. Please increase contributions or return rate.</div>
                </div>
            </div>
        </div>

        <div class="chart-section">
            <div class="chart-header">
                <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Savings Progress vs Target Goal</h2>
                <div style="display: flex; justify-content: center; gap: 1rem; margin-top: 0.5rem; font-size: 0.875rem; color: var(--text-secondary);">
                    <div><span class="w-3 h-3 rounded-full bg-[var(--chart-color-a,var(--accent-color))] inline-block mr-2"></span> Savings Balance</div>
                    <div><span class="w-3 h-3 rounded-full bg-[#4A90E2] inline-block mr-2"></span> Adjusted Goal</div>
                </div>
            </div>
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
                <canvas id="progressChart"></canvas>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">How to Reach Your Savings Goal</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Setting a savings goal is the first step towards achieving financial milestones, whether it's a down payment for a house, starting a business, or reaching financial independence. Using a savings goal calculator helps you determine exactly how long it will take to reach your target based on your current savings and monthly contributions.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">The time required to hit your target depends heavily on the consistency of your contributions and the power of compound interest. A higher expected annual return can drastically reduce the number of years needed to reach your goal.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">The Impact of Inflation on Your Savings</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">When planning for long-term goals, it's crucial to factor in inflation. A $100,000 goal today won't have the same purchasing power 10 years from now. Our calculator automatically adjusts your target goal upward based on the annual inflation rate you provide. This ensures that when you finally reach your financial milestone, you actually have the purchasing power you initially planned for.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Strategies to Hit Your Goal Faster</h2>
            <ul class="text-[var(--text-secondary)] mb-6 pl-6 list-disc space-y-2">
                <li><strong>Increase Monthly Contributions:</strong> Even small increases in your monthly savings rate can shave off months or even years from your timeline.</li>
                <li><strong>Optimize Your Return Rate:</strong> Ensure your money is working for you. Cash sitting in a low-yield checking account won't grow efficiently. Consider investing in diversified index funds for long-term goals, or high-yield savings accounts for short-term goals.</li>
                <li><strong>Minimize Expenses:</strong> Reducing your monthly living expenses frees up more capital that can be directly routed to your savings plan.</li>
                <li><strong>Lump Sum Additions:</strong> Whenever you receive a bonus, tax refund, or sudden windfall, depositing it directly into your savings accelerates your compounding growth.</li>
            </ul>
        </div>
    </main>

    
</div>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // Calculation logic
    const calculateSavingsProgress = (goal, initial, monthly, annualReturn, annualInflation) => {
        const monthlyReturn = (annualReturn / 100) / 12;
        const monthlyInflation = (annualInflation / 100) / 12;

        let balance = initial;
        let currentGoal = goal;
        let totalContributions = initial;

        let months = 0;
        const maxMonths = 1200; // 100 years safeguard

        const balanceHistory = [balance];
        const goalHistory = [currentGoal];

        // If starting balance already meets the goal
        if (balance >= currentGoal) {
            return {
                months: 0,
                finalBalance: balance,
                finalGoal: currentGoal,
                totalContributions: totalContributions,
                totalInterest: 0,
                balanceHistory: balanceHistory,
                goalHistory: goalHistory,
                unreachable: false
            };
        }

        while (balance < currentGoal && months < maxMonths) {
            balance = balance * (1 + monthlyReturn) + monthly;
            currentGoal = currentGoal * (1 + monthlyInflation);
            totalContributions += monthly;
            months++;

            if (months % 12 === 0 || balance >= currentGoal) {
                balanceHistory.push(balance);
                goalHistory.push(currentGoal);
            }
        }

        return {
            months: months,
            finalBalance: balance,
            finalGoal: currentGoal,
            totalContributions: totalContributions,
            totalInterest: balance - totalContributions,
            balanceHistory: balanceHistory,
            goalHistory: goalHistory,
            unreachable: months >= maxMonths
        };
    };

    // Charting logic using vanilla canvas
    let chartCanvas = document.getElementById('progressChart');
    let ctx = chartCanvas.getContext('2d');

    const drawChart = (balanceData, goalData, totalMonths) => {
        const dpr = window.devicePixelRatio || 1;
        const rect = chartCanvas.parentElement.getBoundingClientRect();

        chartCanvas.width = rect.width * dpr;
        chartCanvas.height = rect.height * dpr;

        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);

        const width = rect.width;
        const height = rect.height;

        ctx.clearRect(0, 0, width, height);

        const padding = { top: 20, right: 20, bottom: 40, left: 80 };
        const chartWidth = width - padding.left - padding.right;
        const chartHeight = height - padding.top - padding.bottom;

        const maxPoints = Math.max(balanceData.length, goalData.length);
        const maxVal = Math.max(...balanceData, ...goalData);

        if (maxVal === 0 || maxPoints <= 1) return;

        // Draw grid and axes
        ctx.strokeStyle = '#2a2010';
        ctx.lineWidth = 1;
        ctx.font = '12px Inter, sans-serif';
        ctx.fillStyle = '#888888';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';

        // Y-axis
        const yTicks = 5;
        for (let i = 0; i <= yTicks; i++) {
            const val = maxVal * (i / yTicks);
            const y = height - padding.bottom - (chartHeight * (i / yTicks));

            ctx.beginPath();
            ctx.moveTo(padding.left, y);
            ctx.lineTo(width - padding.right, y);
            ctx.stroke();

            let label = val >= 1000000 ? '$' + (val / 1000000).toFixed(1) + 'M' :
                        val >= 1000 ? '$' + (val / 1000).toFixed(0) + 'k' : '$' + val.toFixed(0);
            ctx.fillText(label, padding.left - 10, y);
        }

        // X-axis (Years)
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        const totalYears = Math.ceil(totalMonths / 12);
        const xTicks = Math.min(totalYears, 10);

        for (let i = 0; i <= xTicks; i++) {
            let yearVal = 0;
            if (xTicks > 0) {
                yearVal = (totalYears / xTicks) * i;
            }

            // Map the year exactly to the width of the chart
            const progress = totalYears > 0 ? (yearVal / totalYears) : 0;
            const x = padding.left + (chartWidth * progress);

            ctx.beginPath();
            ctx.moveTo(x, height - padding.bottom);
            ctx.lineTo(x, height - padding.bottom + 5);
            ctx.stroke();

            ctx.fillText('Yr ' + Math.round(yearVal), x, height - padding.bottom + 10);
        }

        const drawLine = (data, color, fillArea = true, isDashed = false) => {
            if (data.length === 0) return;

            ctx.beginPath();
            ctx.strokeStyle = color;
            ctx.lineWidth = 3;
            ctx.lineJoin = 'round';
            if (isDashed) {
                ctx.setLineDash([5, 5]);
            } else {
                ctx.setLineDash([]);
            }

            data.forEach((val, i) => {
                const progress = (data.length > 1) ? (i / (data.length - 1)) : 0;
                const x = padding.left + (chartWidth * progress);
                const y = height - padding.bottom - (chartHeight * (val / maxVal));

                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.stroke();
            ctx.setLineDash([]); // Reset dash

            if (fillArea && data.length > 1) {
                ctx.lineTo(padding.left + chartWidth, height - padding.bottom);
                ctx.lineTo(padding.left, height - padding.bottom);
                ctx.closePath();

                const gradient = ctx.createLinearGradient(0, padding.top, 0, height - padding.bottom);
                const r = parseInt(color.slice(1,3), 16);
                const g = parseInt(color.slice(3,5), 16);
                const b = parseInt(color.slice(5,7), 16);

                gradient.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0.2)`);
                gradient.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);

                ctx.fillStyle = gradient;
                ctx.fill();
            }
        };

        // Draw goal line (red/dashed)
        drawLine(goalData, '#E24A4A', false, true);
        // Draw balance line (gold/solid)
        drawLine(balanceData, '#D4A017', true, false);
    };

    const updateCalculator = () => {
        const goal = parseFloat(document.getElementById('goal-target').value) || 0;
        const initial = parseFloat(document.getElementById('initial-saved').value) || 0;
        const monthly = parseFloat(document.getElementById('monthly-contribution').value) || 0;
        const annualReturn = parseFloat(document.getElementById('annual-return').value) || 0;
        const annualInflation = parseFloat(document.getElementById('annual-inflation').value) || 0;

        const res = calculateSavingsProgress(goal, initial, monthly, annualReturn, annualInflation);

        const errorMsg = document.getElementById('error-msg');
        if (res.unreachable) {
            errorMsg.style.display = 'block';
            document.getElementById('time-to-goal').innerText = '> 100 Years';
        } else {
            errorMsg.style.display = 'none';
            const years = Math.floor(res.months / 12);
            const months = res.months % 12;
            let timeString = '';
            if (years > 0) timeString += `${years} Yrs`;
            if (months > 0 || years === 0) {
                if (timeString) timeString += ', ';
                timeString += `${months} Mos`;
            }
            // Fix "1 Yrs, 1 Mos" -> "1 Yr, 1 Mo" etc
            timeString = timeString.replace('1 Yrs', '1 Yr').replace('1 Mos', '1 Mo');
            document.getElementById('time-to-goal').innerText = timeString;
        }

        document.getElementById('final-goal-target').innerText = formatCurrency(res.finalGoal);
        document.getElementById('total-contributions').innerText = formatCurrency(res.totalContributions);
        document.getElementById('total-interest').innerText = formatCurrency(res.totalInterest);

        drawChart(res.balanceHistory, res.goalHistory, res.months);
    };

    // Attach event listeners
    const inputs = document.querySelectorAll('input[type="number"]');
    inputs.forEach(input => {
        input.addEventListener('input', updateCalculator);
    });

    // Handle window resize for canvas
    window.addEventListener('resize', () => {
        updateCalculator();
    });

    // Initial calculation
    setTimeout(() => {
        updateCalculator();
    }, 0);
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-budgeting-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Budgeting for Beginners: Build Your Financial Foundation</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
