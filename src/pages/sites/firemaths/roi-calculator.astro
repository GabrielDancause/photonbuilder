---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ROI & CAGR Calculator",
  "url": "https://firemaths.info/roi-calculator",
  "description": "Calculate Return on Investment (ROI) and Compound Annual Growth Rate (CAGR) for multiple investments.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<SiteLayout
  site="firemaths"
  title="ROI & CAGR Calculator | firemaths.info"
  description="Calculate Return on Investment (ROI) and Compound Annual Growth Rate (CAGR) for multiple investments. Track total return and annualized performance."
  canonical="https://firemaths.info/roi-calculator" schema={schema}
>
  <div class="max-w-4xl mx-auto px-6 py-12">
    

    <main>
        <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8 mb-12">
            <!-- Investments Column -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-6 shadow-sm">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Investments Portfolio</h2>
                </div>

                <div class="space-y-6 mt-6" id="investments-container">
                    <!-- Dynamic Investment Items will be inserted here -->
                </div>

                <div style="margin-top: 1.5rem;">
                    <button class="w-full bg-[var(--accent-color)] text-[var(--bg-color)] font-bold py-3 px-4 rounded-lg hover:opacity-90 transition-opacity" id="btn-add-investment">+ Add Another Investment</button>
                </div>
            </div>

            <!-- Summary Column -->
            <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-6 shadow-sm self-start" style="align-self: start;">
                <div class="flex justify-between items-center mb-6 pb-4 border-b border-[var(--border-color)]">
                    <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Total Portfolio Summary</h2>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Invested</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="total-invested">$0</span>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold">Total Final Value</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="total-final">$0</span>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold">Net Profit / Loss</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="total-profit">$0</span>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final" style="margin-top: 1rem;">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold" style="color: var(--text-primary);">Overall ROI</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="overall-roi">0.00%</span>
                        <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('overall-roi', this)">Copy</button>
                    </div>
                </div>

                <div class="flex justify-between items-center mb-4 pb-4 border-b border-[var(--border-color)] last:border-0 last:mb-0 last:pb-0 result-final">
                    <span class="text-[var(--text-secondary)] text-sm font-semibold" style="color: var(--text-primary);">Portfolio CAGR*</span>
                    <div class="font-mono text-lg font-medium text-white flex items-center gap-2">
                        <span id="overall-cagr">0.00%</span>
                        <button class="bg-transparent border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] px-2 py-1 rounded text-xs transition-colors cursor-pointer" onclick="copyValue('overall-cagr', this)">Copy</button>
                    </div>
                </div>
                <p style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.5rem; text-align: right;">
                    *Calculated using total return and capital-weighted average duration.
                </p>
            </div>
        </div>

        <div class="mt-16 mb-16">
            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Understanding ROI and CAGR</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Return on Investment (ROI)</strong> is a straightforward metric used to evaluate the efficiency or profitability of an investment. It measures the total return relative to the investment's cost. However, ROI doesn't account for the time you held the investment.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed"><strong>Compound Annual Growth Rate (CAGR)</strong> solves this by showing the mean annual growth rate of an investment over a specified period of time longer than one year. It assumes that any growth is compounded over that time. CAGR is one of the most accurate ways to calculate and determine returns for anything that can rise or fall in value over time.</p>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">How to Use This Calculator</h2>
            <ol class="text-[var(--text-secondary)] mb-6 pl-6 list-decimal space-y-2">
                <li><strong>Enter Initial Investment:</strong> The total amount of money you originally invested.</li>
                <li><strong>Enter Final Value:</strong> The current value of your investment, or the amount you received when you sold it.</li>
                <li><strong>Enter Years Held:</strong> The exact duration you held the investment. For partial years, use decimals (e.g., 2.5 for two and a half years).</li>
                <li><strong>Add Multiple Assets:</strong> Click "+ Add Another Investment" to build a portfolio. The calculator will automatically determine your total overall return and a weighted portfolio CAGR.</li>
            </ol>

            <h2 class="text-2xl font-bold text-[var(--accent-color)] mt-10 mb-4 border-b border-[var(--border-color)] pb-2 flex items-center gap-2">Why Both Metrics Matter</h2>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">If an investment grew from $10,000 to $15,000, your ROI is 50%. If it took you 1 year to make that return, your CAGR is also 50%. But if it took you 10 years to make that same return, your annualized CAGR is only 4.14%.</p>
            <p class="text-[var(--text-secondary)] mb-4 leading-relaxed">Using both metrics gives you a complete picture: ROI tells you how much absolute money you made relative to your starting capital, while CAGR tells you how efficiently your money grew over time, allowing you to fairly compare it against benchmarks like the stock market or savings accounts.</p>
        </div>
    </main>

    
</div>

<template id="investment-template">
    <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-xl p-5">
        <div class="flex justify-between items-center gap-4 mb-4">
            <input type="text" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" class="investment-name" value="Investment 1" placeholder="Investment Name">
            <button class="text-red-400 hover:text-red-300 text-sm font-semibold transition-colors bg-transparent border-0 cursor-pointer" title="Remove Investment">✕ Remove</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide">Initial Investment</label>
                <div class="relative flex items-center">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" class="input-initial pl-8 pl-8" value="10000" min="0" step="100">
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide">Final Value</label>
                <div class="relative flex items-center">
                    <span class="absolute left-4 text-[var(--text-secondary)] font-mono pointer-events-none">$</span>
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" class="input-final pl-8 pl-8" value="15000" min="0" step="100">
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2 uppercase tracking-wide">Years Held</label>
                <div class="relative flex items-center">
                    <span class="absolute right-4 text-[var(--text-secondary)] font-mono pointer-events-none">Yrs</span>
                    <input type="number" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] text-white font-mono text-base p-3 rounded-lg focus:outline-none focus:border-[var(--accent-color)] transition-colors" class="input-years" value="5" min="0.1" step="0.1">
                </div>
            </div>
        </div>

        <div class="grid grid-cols-3 gap-4 mt-6 p-4 bg-[var(--card-bg)] border-t border-[var(--border-color)] rounded-b-xl -mx-5 -mb-5">
            <div class="flex flex-col text-center">
                <span class="text-xs text-[var(--text-secondary)] uppercase tracking-wide mb-1">ROI:</span>
                <span class="font-mono font-bold text-[var(--accent-color)] text-lg">0.00%</span>
            </div>
            <div class="flex flex-col text-center">
                <span class="text-xs text-[var(--text-secondary)] uppercase tracking-wide mb-1">CAGR:</span>
                <span class="font-mono font-bold text-blue-400 text-lg">0.00%</span>
            </div>
            <div class="flex flex-col text-center">
                <span class="text-xs text-[var(--text-secondary)] uppercase tracking-wide mb-1">Profit:</span>
                <span class="font-mono font-bold text-white">$0</span>
            </div>
        </div>
    </div>
</template>
  <script is:inline>
// Format currency
    const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        }).format(value);
    };

    // Format percentage
    const formatPercent = (value) => {
        if (!isFinite(value)) return 'N/A';
        const formatted = new Intl.NumberFormat('en-US', {
            style: 'percent',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(value / 100);
        return formatted;
    };

    // Copy to clipboard
    window.copyValue = async (elementId, btn) => {
        const text = document.getElementById(elementId).innerText;
        try {
            await navigator.clipboard.writeText(text);
            const originalText = btn.innerText;
            btn.innerText = 'Copied!';
            setTimeout(() => {
                btn.innerText = originalText;
            }, 2000);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    };

    // DOM Elements
    const container = document.getElementById('investments-container');
    const template = document.getElementById('investment-template');
    const btnAdd = document.getElementById('btn-add-investment');

    let investmentCount = 0;

    // Set color class based on value
    const setColorClass = (element, value) => {
        element.classList.remove('val-positive', 'val-negative');
        if (value > 0) element.classList.add('val-positive');
        else if (value < 0) element.classList.add('val-negative');
    };

    // Calculation logic
    const calculateMetrics = () => {
        const items = document.querySelectorAll('.investment-item');

        let totalInvested = 0;
        let totalFinal = 0;
        let sumDurationWeight = 0; // for weighted CAGR

        items.forEach(item => {
            const initial = parseFloat(item.querySelector('.input-initial').value) || 0;
            const final = parseFloat(item.querySelector('.input-final').value) || 0;
            const years = parseFloat(item.querySelector('.input-years').value) || 0;

            // Individual calculation
            const profit = final - initial;
            const roi = initial > 0 ? (profit / initial) * 100 : 0;

            let cagr = 0;
            if (initial > 0 && final > 0 && years > 0) {
                cagr = (Math.pow(final / initial, 1 / years) - 1) * 100;
            } else if (initial > 0 && final === 0 && years > 0) {
                cagr = -100; // total loss
            }

            // Update item UI
            const elRoi = item.querySelector('.item-roi');
            const elCagr = item.querySelector('.item-cagr');
            const elProfit = item.querySelector('.item-profit');

            elRoi.textContent = formatPercent(roi);
            elCagr.textContent = formatPercent(cagr);
            elProfit.textContent = formatCurrency(profit);

            setColorClass(elRoi, roi);
            setColorClass(elCagr, cagr);
            setColorClass(elProfit, profit);

            // Accumulate for totals
            totalInvested += initial;
            totalFinal += final;
            sumDurationWeight += (initial * years);
        });

        // Summary calculation
        const totalProfit = totalFinal - totalInvested;
        const overallRoi = totalInvested > 0 ? (totalProfit / totalInvested) * 100 : 0;

        // Weighted portfolio CAGR
        let overallCagr = 0;
        if (totalInvested > 0 && totalFinal > 0) {
            const avgYears = sumDurationWeight / totalInvested;
            if (avgYears > 0) {
                overallCagr = (Math.pow(totalFinal / totalInvested, 1 / avgYears) - 1) * 100;
            }
        } else if (totalInvested > 0 && totalFinal === 0) {
            overallCagr = -100;
        }

        // Update Summary UI
        document.getElementById('total-invested').textContent = formatCurrency(totalInvested);
        document.getElementById('total-final').textContent = formatCurrency(totalFinal);

        const elTotalProfit = document.getElementById('total-profit');
        elTotalProfit.textContent = formatCurrency(totalProfit);
        setColorClass(elTotalProfit, totalProfit);

        const elOverallRoi = document.getElementById('overall-roi');
        elOverallRoi.textContent = formatPercent(overallRoi);
        setColorClass(elOverallRoi, overallRoi);

        const elOverallCagr = document.getElementById('overall-cagr');
        elOverallCagr.textContent = formatPercent(overallCagr);
        setColorClass(elOverallCagr, overallCagr);
    };

    // Add new investment item
    const addInvestment = () => {
        investmentCount++;
        const clone = template.content.cloneNode(true);
        const item = clone.querySelector('.investment-item');

        // Update default values slightly to make them look distinct if desired
        const nameInput = clone.querySelector('.investment-name');
        nameInput.value = `Investment ${investmentCount}`;

        // Attach event listeners
        const inputs = clone.querySelectorAll('input');
        inputs.forEach(input => {
            input.addEventListener('input', calculateMetrics);
        });

        const btnRemove = clone.querySelector('.btn-remove');
        btnRemove.addEventListener('click', () => {
            item.remove();
            calculateMetrics();

            // Ensure at least one item remains
            if (document.querySelectorAll('.investment-item').length === 0) {
                addInvestment();
            }
        });

        container.appendChild(clone);
        calculateMetrics();
    };

    btnAdd.addEventListener('click', addInvestment);

    // Initial setup
    addInvestment();

    // Add a second one by default to show multiple capability
    const secondItem = addInvestment();
    const items = document.querySelectorAll('.investment-item');
    if(items.length >= 2) {
        items[1].querySelector('.investment-name').value = "Investment 2";
        items[1].querySelector('.input-initial').value = "5000";
        items[1].querySelector('.input-final').value = "8000";
        items[1].querySelector('.input-years').value = "3";
    }
    calculateMetrics();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-investing-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Beginner's Guide to Investing Your Money</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
