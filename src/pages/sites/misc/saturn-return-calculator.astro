    .input-group { margin-bottom: 1.5rem; }
    .input-group label { display: block; font-weight: 600; margin-bottom: 0.5rem; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; box-sizing: border-box; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    .error-msg { color: #ef4444; font-size: 0.875rem; margin-top: 0.5rem; display: none; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; display: none; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); margin: 0.5rem 0; }
    .result-label { font-size: 1rem; font-weight: 600; color: var(--text-secondary); }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 600px) { .grid-2 { grid-template-columns: 1fr; } }
    .explainer { line-height: 1.7; margin-top: 3rem; }
    .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; }
    .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 1rem; }
    .explainer p { margin-bottom: 1rem; }
    .faq-section { margin-top: 3rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .faq-section details p { margin-top: 1rem; margin-bottom: 0; line-height: 1.6; }
    .cross-link { display: inline-block; margin-top: 2rem; padding: 1rem; background: var(--card-bg); border-left: 4px solid var(--accent-color); text-decoration: none; color: var(--text-primary); font-weight: 600; border-radius: 4px; }
    .cross-link:hover { background: color-mix(in srgb, var(--card-bg) 90%, var(--accent-color)); }

  </style>
</SiteLayout>
