---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Flotilla Tracker & Logistics Calculator",
  description: "Plan your naval flotilla or convoy operations. Calculate fleet transit times, overall marine fuel consumption, and provision requirements.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a flotilla?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A flotilla is a formation of small ships that may be part of a larger fleet. It is usually composed of a homogeneous group of the same class of warship, such as frigates, destroyers, submarines, or minesweepers."
          }
        },
        {
          "@type": "Question",
          "name": "How is a flotilla different from a convoy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A flotilla is typically a naval organizational unit consisting of warships of the same class. A convoy, on the other under, is a group of vehicles or ships (often merchant ships) traveling together for mutual support and protection, frequently escorted by naval vessels."
          }
        },
        {
          "@type": "Question",
          "name": "What factors into marine fuel management (MFM)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Effective MFM relies on understanding projections of fuel usage, monitoring actual consumption rates under various conditions (like traveling vs. idling), inventory control, and engine throttle management."
          }
        },
        {
          "@type": "Question",
          "name": "Why is it important to track fuel consumption in a flotilla?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Tracking fuel consumption helps maintain operational efficiency, lowers operational costs, ensures that the fleet has enough fuel to complete its transit without stranding vessels, and allows for the evaluation of fuel conservation strategies."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate the transit time for a convoy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Transit time is generally calculated by dividing the total voyage distance by the fleet's cruising speed. Because a convoy must stay together, the cruising speed is dictated by the slowest vessel in the group."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Siliconbased.dev"
      },
      "datePublished": meta.published
    }
  ]
};
---

<SiteLayout site="misc" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/misc/flotilla-tracker" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Flotilla Tracker & Logistics Calculator</h1>
      <p class="subtitle">Estimate fleet transit times, fuel consumption, and provision logistics.</p>
    </div>

    <div class="calculator-container">
      <div class="stats-grid" style="margin-top: 0;">
        <div class="input-group">
          <label for="distance">Voyage Distance (Nautical Miles)</label>
          <input type="number" id="distance" min="1" value="2500">
        </div>
        <div class="input-group">
          <label for="speed">Fleet Speed (Knots)</label>
          <input type="number" id="speed" min="1" value="15">
        </div>
      </div>

      <div class="stats-grid" style="margin-top: 0;">
        <div class="input-group">
          <label for="vessels">Number of Vessels</label>
          <input type="number" id="vessels" min="1" value="5">
        </div>
        <div class="input-group">
          <label for="burnRate">Avg Fuel Burn / Vessel (Gal/hr)</label>
          <input type="number" id="burnRate" min="1" value="300">
        </div>
      </div>

      <div class="input-group">
        <label for="crew">Total Fleet Crew</label>
        <input type="number" id="crew" min="1" value="1200">
      </div>

      <div id="calc-error" class="error-message" style="display: none; color: #ef4444; font-size: 0.85rem; margin-bottom: 1rem; text-align: center;">Please ensure all inputs are valid positive numbers.</div>

      <div class="result-card">
        <div class="calc-result-label">Total Fleet Fuel Consumption (Gallons)</div>
        <div class="calc-result-value" id="fuelResult">0</div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="calc-result-label">Transit Time (Days)</div>
          <div class="result-value" style="font-size: 1.5rem;" id="timeResult">0.0</div>
        </div>
        <div class="stat-card">
          <div class="calc-result-label">Provisions Required (Lbs)</div>
          <div class="result-value" style="font-size: 1.5rem;" id="provisionsResult">0</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Flotilla Composition and Convoy Logistics</h2>

      <p>Organizing a multi-vessel transit, whether it is a naval flotilla or a merchant convoy, involves complex logistical planning. The Flotilla Tracker is designed to provide rapid estimations for fleet managers and naval enthusiasts by calculating transit times, fleet-wide fuel consumption, and daily provision requirements based on fundamental logistical parameters.</p>

      <h3>What is a Flotilla?</h3>
      <p>A flotilla (from Spanish, meaning a small fleet of ships) is a formation of small ships that may operate independently or as part of a larger fleet. Traditionally, a flotilla is composed of a homogeneous group of the same class of warship. Examples include formations of frigates, destroyers, torpedo boats, submarines, gunboats, or minesweepers. In contrast, groups of larger warships (capital ships like battleships or aircraft carriers) are usually organized into squadrons or task forces.</p>

      <p>In modern navies, the definition has evolved. Flotillas have tended to become administrative units containing several squadrons. As warships have grown larger over time, the term "squadron" has gradually replaced "flotilla" for formations of destroyers and frigates in many naval organizations. A naval flotilla has no direct equivalent on land, but tactically, it is roughly the equivalent of a military brigade or regiment.</p>

      <h3>The Role of Convoys</h3>
      <p>While a flotilla is a specific naval organization, a convoy is a group of ships traveling together for mutual support and protection. The use of organized naval convoys dates back centuries. By the late 18th century, during the French Revolutionary Wars, effective naval convoy tactics had been developed to ward off pirates and privateers. A key defensive strategy of a convoy is that multiple ships sailing together present a much smaller target than ships sailing independently; a convoy is essentially as hard to find on the open ocean as a single ship, but it benefits from the collective defense of naval escorts.</p>

      <h3>Marine Fuel Management (MFM)</h3>
      <p>Marine fuel management is a multi-level approach to measuring, monitoring, and reporting fuel usage on a boat or ship. The goals are to reduce fuel usage, increase operational efficiency, and lower overall operational costs. MFM has grown significantly in importance due to rising fuel costs and increasing environmental oversight regarding pollution generated by the global shipping fleet.</p>

      <p>Effective MFM relies on a clear understanding of several variables: projections of fuel usage, records of actual consumption, and the conditions under which the fuel was used. Historically, manual methods of measuring fuel usage (such as fuel tank dipping) lacked the detail necessary to differentiate fuel consumption under varying operating conditions, such as cruising at sea versus idling in port.</p>

      <p>Today, optimal MFM systems employ instantaneous fuel burn monitoring from the wheelhouse, utilizing flow meters and sensors in the fuel tanks. This operational performance data allows the captain and fleet manager to make proactive decisions regarding engine throttle management and inventory control, ensuring that the fleet does not run out of fuel during long transits.</p>

      <h3>Logistics and Provisioning</h3>
      <p>Logistics is the part of supply chain management that deals with the efficient forward and reverse flow of goods, services, and related information. The term itself has military origins, deriving from the French "logistique," popularized by Swiss military officer Antoine-Henri Jomini in the 1830s.</p>

      <p>In the context of a flotilla or convoy, military and civil logistics are concerned with maintaining supply lines. This involves ensuring the fleet is stocked with sufficient food, potable water, medical supplies, and spare parts for the duration of the voyage. Provisioning is generally calculated on a per-person, per-day basis. Fleet managers must know the total crew complement across all vessels and the expected transit time to ensure sufficient stores are loaded before departure.</p>

      <h3>Methodology Behind the Calculator</h3>
      <p>The Flotilla Tracker simplifies these complex logistics into a straightforward estimation tool:</p>

      <ol>
        <li><strong>Transit Time:</strong> The total transit time is calculated by dividing the voyage distance by the fleet speed. Importantly, a fleet must travel at the speed of its slowest vessel to maintain cohesion. Therefore, the "Fleet Speed" input should represent the sustainable cruising speed of the slowest ship in the flotilla.</li>
        <li><strong>Fuel Consumption:</strong> The total fuel consumption is the product of the transit time (in hours), the number of vessels in the fleet, and the average fuel burn rate per vessel. While real flotillas may mix ship classes with different burn rates, this tool uses an average baseline for rapid estimation.</li>
        <li><strong>Provision Requirements:</strong> The total provisions required are determined by multiplying the total crew size by the transit time (converted into days), and then multiplying that figure by a standard weight of provisions required per person per day (often estimated at around 5 to 7 pounds, including food and basic daily consumables).</li>
      </ol>

      <p>For individuals tracking fast-moving airborne logistics, consider checking out our <a href="/taylor-swift-flight-tracker">Taylor Swift Flight Tracker</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is a flotilla?</summary>
        <p>A flotilla is a formation of small ships that may be part of a larger fleet. It is usually composed of a homogeneous group of the same class of warship, such as frigates, destroyers, submarines, or minesweepers.</p>
      </details>
      <details>
        <summary>How is a flotilla different from a convoy?</summary>
        <p>A flotilla is typically a naval organizational unit consisting of warships of the same class. A convoy, on the other under, is a group of vehicles or ships (often merchant ships) traveling together for mutual support and protection, frequently escorted by naval vessels.</p>
      </details>
      <details>
        <summary>What factors into marine fuel management (MFM)?</summary>
        <p>Effective MFM relies on understanding projections of fuel usage, monitoring actual consumption rates under various conditions (like traveling vs. idling), inventory control, and engine throttle management.</p>
      </details>
      <details>
        <summary>Why is it important to track fuel consumption in a flotilla?</summary>
        <p>Tracking fuel consumption helps maintain operational efficiency, lowers operational costs, ensures that the fleet has enough fuel to complete its transit without stranding vessels, and allows for the evaluation of fuel conservation strategies.</p>
      </details>
      <details>
        <summary>How do you calculate the transit time for a convoy?</summary>
        <p>Transit time is generally calculated by dividing the total voyage distance by the fleet's cruising speed. Because a convoy must stay together, the cruising speed is dictated by the slowest vessel in the group.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    const distanceInput = document.getElementById('distance');
    const speedInput = document.getElementById('speed');
    const vesselsInput = document.getElementById('vessels');
    const burnRateInput = document.getElementById('burnRate');
    const crewInput = document.getElementById('crew');

    const calcError = document.getElementById('calc-error');

    const timeResult = document.getElementById('timeResult');
    const fuelResult = document.getElementById('fuelResult');
    const provisionsResult = document.getElementById('provisionsResult');

    const PROVISIONS_LBS_PER_PERSON_PER_DAY = 6;

    function calculate() {
      const distance = parseFloat(distanceInput.value);
      const speed = parseFloat(speedInput.value);
      const vessels = parseFloat(vesselsInput.value);
      const burnRate = parseFloat(burnRateInput.value);
      const crew = parseFloat(crewInput.value);

      if ([distance, speed, vessels, burnRate, crew].some(val => isNaN(val) || val <= 0)) {
        calcError.style.display = 'block';
        timeResult.textContent = '0.0';
        fuelResult.textContent = '0';
        provisionsResult.textContent = '0';
        return;
      }

      calcError.style.display = 'none';

      const transitHours = distance / speed;
      const transitDays = transitHours / 24;

      const fleetFuelBurned = transitHours * vessels * burnRate;
      const provisionsRequired = crew * transitDays * PROVISIONS_LBS_PER_PERSON_PER_DAY;

      const numberFormatter = new Intl.NumberFormat('en-US', { maximumFractionDigits: 1 });
      const integerFormatter = new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 });

      timeResult.textContent = numberFormatter.format(transitDays);
      fuelResult.textContent = integerFormatter.format(fleetFuelBurned);
      provisionsResult.textContent = integerFormatter.format(provisionsRequired);
    }

    [distanceInput, speedInput, vesselsInput, burnRateInput, crewInput].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Initial calculation
    calculate();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .error-message { color: #ef4444; font-size: 0.85rem; margin-top: 0.25rem; }
  </style>
</SiteLayout>