const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a golf handicap differential?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A handicap differential is a numerical value that evaluates a golfer's score relative to the difficulty of the course played. It takes into account both the Course Rating and Slope Rating, ensuring that a score of 85 on a very difficult course might result in a better (lower) differential than a score of 82 on an easy course."
        }
      },
      {
        "@type": "Question",
        "name": "How does the Strokes Gained methodology work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Strokes Gained measures a player's performance against the field average for every single shot. It assigns a baseline value to every situation on the course (e.g., 150 yards from the fairway) and compares the player's actual result to that baseline, determining if they gained or lost strokes relative to their competitors."
        }
      },
      {
        "@type": "Question",
        "name": "Why is Slope Rating important in a tracker?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Slope Rating indicates the relative difficulty of a golf course for a bogey golfer compared to a scratch golfer. A course with a higher Slope Rating is disproportionately more difficult for a higher-handicap player. Including Slope Rating in the differential formula ensures fair handicapping across different skill levels."
        }
      },
      {
        "@type": "Question",
        "name": "How can amateurs track stats like professionals?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Amateurs can track fairways hit, greens in regulation, putts per round, and proximity to the hole using various smartphone applications. While not as precise as tour-level laser systems, tracking these core metrics consistently provides actionable data to identify strengths and weaknesses."
        }
      },
      {
        "@type": "Question",
        "name": "What is the standard Course Rating?",
