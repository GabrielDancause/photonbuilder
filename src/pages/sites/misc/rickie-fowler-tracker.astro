    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Rickie Fowler Tracker & Golf Score Calculator",
    "description": "Want to track golf stats like a pro? Discover the exact formulas used to calculate strokes gained and see how your numbers compare.",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SiliconBased",
      "logo": {
        "@type": "ImageObject",
        "url": "https://photonbuilder.com/misc/logo.png"
      }
