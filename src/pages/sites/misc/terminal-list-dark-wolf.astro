        {
          "@type": "Question",
          "name": "Who are the main actors in Dark Wolf?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Taylor Kitsch reprises his role as Ben Edwards, and Chris Pratt returns as James Reece. Tom Hopper also stars in the series."
          }
        },
        {
          "@type": "Question",
          "name": "When did The Terminal List: Dark Wolf premiere?",
          "acceptedAnswer": {
