  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Is Dark Wolf a prequel or a sequel?",
          "acceptedAnswer": {
