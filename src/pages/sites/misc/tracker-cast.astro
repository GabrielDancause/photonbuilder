    "datePublished": meta.published,
    "author": {
      "@type": "Organization",
      "name": "Siliconbased"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Who plays Colter Shaw in Tracker?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Justin Hartley plays the lead role of Colter Shaw, a skilled survivalist and 'rewardist' who travels the country helping law enforcement and private citizens solve mysteries and find missing persons."
        }
      },
      {
        "@type": "Question",
        "name": "Is Robin Weigert leaving Tracker?",
        "acceptedAnswer": {
