---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Pythagorean Theorem Calculator",
  description: "Calculate the missing side of any right triangle instantly. See the exact math behind a² + b² = c².",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.published,
    "author": {
      "@type": "Organization",
      "name": "photonbuilder.com/misc"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Pythagorean theorem?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Pythagorean theorem is a fundamental relation in Euclidean geometry among the three sides of a right triangle. It states that the area of the square whose side is the hypotenuse is equal to the sum of the areas of the squares on the other two sides: a² + b² = c²."
        }
      },
      {
        "@type": "Question",
        "name": "How do I calculate the hypotenuse?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To find the hypotenuse (c), square the lengths of the two legs (a and b), add them together, and then take the square root of that sum: c = √(a² + b²)."
        }
      },
      {
        "@type": "Question",
        "name": "Can the Pythagorean theorem be used on any triangle?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The standard Pythagorean theorem only applies to right-angled triangles (triangles where one angle is exactly 90 degrees). For other triangles, you must use the Law of Cosines."
        }
      },
      {
        "@type": "Question",
        "name": "What are Pythagorean triples?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Pythagorean triple consists of three positive integers a, b, and c, such that a² + b² = c². The most famous example is 3, 4, and 5 (3² + 4² = 9 + 16 = 25 = 5²)."
        }
      },
      {
        "@type": "Question",
        "name": "Who invented the Pythagorean theorem?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While named after the ancient Greek mathematician Pythagoras (c. 570–495 BC), there is evidence that the principle was known to Babylonian and Chinese mathematicians centuries earlier."
        }
      }
    ]
  }
];
---

<SiteLayout site="misc" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/misc/pythagorean-theorem-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Pythagorean Theorem Calculator</h1>
      <p class="subtitle">Find the missing side of a right triangle using <em>a² + b² = c²</em></p>
    </div>

    <div class="calculator-container">
      <div class="calculator-layout">

        <!-- Controls -->
        <div class="controls-panel">
          <div class="input-group">
            <label for="solve-for">Solve For</label>
            <select id="solve-for">
              <option value="c">Hypotenuse (c)</option>
              <option value="a">Leg (a)</option>
              <option value="b">Leg (b)</option>
            </select>
          </div>

          <div class="input-group" id="group-a">
            <label for="side-a">Side <em>a</em> (Leg)</label>
            <input type="number" id="side-a" min="0" step="any" placeholder="Enter length of side a">
          </div>

          <div class="input-group" id="group-b">
            <label for="side-b">Side <em>b</em> (Leg)</label>
            <input type="number" id="side-b" min="0" step="any" placeholder="Enter length of side b">
          </div>

          <div class="input-group" id="group-c" style="display: none;">
            <label for="side-c">Side <em>c</em> (Hypotenuse)</label>
            <input type="number" id="side-c" min="0" step="any" placeholder="Enter length of side c">
          </div>

          <div id="error-message" class="error-message" style="display: none;"></div>
        </div>

        <!-- Visualization / Result -->
        <div class="result-panel">
          <div class="triangle-container">
            <svg viewBox="-10 -10 120 120" class="triangle-svg">
              <!-- Right angle square -->
              <rect x="0" y="80" width="10" height="10" fill="none" stroke="var(--text-secondary)" stroke-width="1.5" />
              <!-- Triangle -->
              <polygon points="0,0 0,90 90,90" fill="color-mix(in srgb, var(--accent-color) 10%, transparent)" stroke="var(--accent-color)" stroke-width="3" stroke-linejoin="round" />
              <!-- Labels -->
              <text x="-15" y="45" fill="var(--text-primary)" font-style="italic" font-weight="bold" id="label-a">a</text>
              <text x="45" y="110" fill="var(--text-primary)" font-style="italic" font-weight="bold" id="label-b">b</text>
              <text x="50" y="40" fill="var(--accent-color)" font-style="italic" font-weight="bold" font-size="1.2em" id="label-c">c</text>
            </svg>
          </div>

          <div class="result-card">
            <h3>Result</h3>
            <div class="result-value" id="calc-result">---</div>
            <div class="formula-box" id="step-by-step">
              a² + b² = c²
            </div>
          </div>
        </div>

      </div>
    </div>

    <div class="explainer">
      <h2>How the Pythagorean Theorem Works</h2>
      <p>
        The Pythagorean theorem is one of the most fundamental principles in geometry. It states that in any right-angled triangle, the area of the square whose side is the hypotenuse (the side opposite the right angle) is equal to the sum of the areas of the squares on the other two sides.
      </p>

      <h3>The Formula</h3>
      <p>The mathematical equation used to express this relationship is:</p>
      <div style="background: var(--card-bg); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); margin: 1rem 0; text-align: center; font-size: 1.5rem; font-weight: bold;">
        a² + b² = c²
      </div>
      <p>Where the variables represent:</p>
      <ul>
        <li><strong>a</strong> and <strong>b</strong>: The lengths of the triangle's two legs (the sides that meet at the 90-degree right angle).</li>
        <li><strong>c</strong>: The length of the hypotenuse (the longest side of the right triangle, strictly opposite the right angle).</li>
      </ul>

      <h3>Solving for the Hypotenuse (c)</h3>
      <p>
        If you know the lengths of the two shorter legs, you can easily find the hypotenuse. You simply square both leg lengths, add them together, and calculate the square root of the result.
      </p>
      <div style="background: var(--bg-color); padding: 1rem; border-left: 4px solid var(--accent-color); margin: 1rem 0; font-family: monospace;">
        c = √(a² + b²)
      </div>
      <p>
        <strong>Example:</strong> If leg <em>a</em> is 3 and leg <em>b</em> is 4:
        <br>c = √(3² + 4²)
        <br>c = √(9 + 16)
        <br>c = √25
        <br>c = 5
      </p>

      <h3>Solving for a Leg (a or b)</h3>
      <p>
        If you know the length of the hypotenuse and one leg, you can find the missing leg by rearranging the formula. Subtract the square of the known leg from the square of the hypotenuse, and then find the square root.
      </p>
      <div style="background: var(--bg-color); padding: 1rem; border-left: 4px solid var(--accent-color); margin: 1rem 0; font-family: monospace;">
        a = √(c² - b²) &nbsp;&nbsp;&nbsp; OR &nbsp;&nbsp;&nbsp; b = √(c² - a²)
      </div>
      <p>
        <strong>Example:</strong> If hypotenuse <em>c</em> is 13 and leg <em>a</em> is 5:
        <br>b = √(13² - 5²)
        <br>b = √(169 - 25)
        <br>b = √144
        <br>b = 12
      </p>

      <h3>Practical Applications</h3>
      <p>
        While it might seem like a purely theoretical mathematical concept, the Pythagorean theorem has countless real-world applications. It is used daily by:
      </p>
      <ul>
        <li><strong>Architects and Carpenters:</strong> To ensure walls and corners form perfect 90-degree angles (often using the "3-4-5 rule").</li>
        <li><strong>Navigators:</strong> To find the shortest straight-line distance between two points on a map.</li>
        <li><strong>Programmers:</strong> In game development and computer graphics, calculating distances between 2D or 3D coordinate points relies heavily on Pythagorean math.</li>
      </ul>

      <p>If you're interested in calculations relevant to physical health and chemistry rather than geometry, check out our <a href="/bac-calculator">Blood Alcohol Content Calculator</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map((faq: any) => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    function calculatePythagoras() {
      const solveFor = document.getElementById('solve-for').value;
      const inputA = document.getElementById('side-a');
      const inputB = document.getElementById('side-b');
      const inputC = document.getElementById('side-c');

      const errorEl = document.getElementById('error-message');
      const resultEl = document.getElementById('calc-result');
      const stepsEl = document.getElementById('step-by-step');

      const labelA = document.getElementById('label-a');
      const labelB = document.getElementById('label-b');
      const labelC = document.getElementById('label-c');

      // Reset UI states
      errorEl.style.display = 'none';
      labelA.style.fill = 'var(--text-primary)';
      labelB.style.fill = 'var(--text-primary)';
      labelC.style.fill = 'var(--text-primary)';

      // Highlight the side being solved for
      if (solveFor === 'c') labelC.style.fill = 'var(--accent-color)';
      if (solveFor === 'a') labelA.style.fill = 'var(--accent-color)';
      if (solveFor === 'b') labelB.style.fill = 'var(--accent-color)';

      // Parse values
      const a = parseFloat(inputA.value);
      const b = parseFloat(inputB.value);
      const c = parseFloat(inputC.value);

      // Helper to format large numbers nicely
      const fmt = (num) => Number.isInteger(num) ? num : parseFloat(num.toFixed(5));

      if (solveFor === 'c') {
        if (isNaN(a) || isNaN(b)) {
          resultEl.textContent = "---";
          stepsEl.innerHTML = "c = &radic;(a&sup2; + b&sup2;)";
          return;
        }
        if (a <= 0 || b <= 0) {
          showError("Side lengths must be greater than zero.");
          return;
        }

        const cSquared = (a * a) + (b * b);
        const calcC = Math.sqrt(cSquared);

        resultEl.textContent = `c = ${fmt(calcC)}`;
        stepsEl.innerHTML = `
          c = &radic;(${fmt(a)}&sup2; + ${fmt(b)}&sup2;)<br>
          c = &radic;(${fmt(a*a)} + ${fmt(b*b)})<br>
          c = &radic;${fmt(cSquared)}
        `;

        labelA.textContent = fmt(a);
        labelB.textContent = fmt(b);
        labelC.textContent = 'c';

      } else if (solveFor === 'a') {
        if (isNaN(b) || isNaN(c)) {
          resultEl.textContent = "---";
          stepsEl.innerHTML = "a = &radic;(c&sup2; - b&sup2;)";
          return;
        }
        if (b <= 0 || c <= 0) {
          showError("Side lengths must be greater than zero.");
          return;
        }
        if (b >= c) {
          showError("Hypotenuse (c) must be strictly strictly greater than leg (b).");
          return;
        }

        const aSquared = (c * c) - (b * b);
        const calcA = Math.sqrt(aSquared);

        resultEl.textContent = `a = ${fmt(calcA)}`;
        stepsEl.innerHTML = `
          a = &radic;(${fmt(c)}&sup2; - ${fmt(b)}&sup2;)<br>
          a = &radic;(${fmt(c*c)} - ${fmt(b*b)})<br>
          a = &radic;${fmt(aSquared)}
        `;

        labelA.textContent = 'a';
        labelB.textContent = fmt(b);
        labelC.textContent = fmt(c);

      } else if (solveFor === 'b') {
        if (isNaN(a) || isNaN(c)) {
          resultEl.textContent = "---";
          stepsEl.innerHTML = "b = &radic;(c&sup2; - a&sup2;)";
          return;
        }
        if (a <= 0 || c <= 0) {
          showError("Side lengths must be greater than zero.");
          return;
        }
        if (a >= c) {
          showError("Hypotenuse (c) must be strictly greater than leg (a).");
          return;
        }

        const bSquared = (c * c) - (a * a);
        const calcB = Math.sqrt(bSquared);

        resultEl.textContent = `b = ${fmt(calcB)}`;
        stepsEl.innerHTML = `
          b = &radic;(${fmt(c)}&sup2; - ${fmt(a)}&sup2;)<br>
          b = &radic;(${fmt(c*c)} - ${fmt(a*a)})<br>
          b = &radic;${fmt(bSquared)}
        `;

        labelA.textContent = fmt(a);
        labelB.textContent = 'b';
        labelC.textContent = fmt(c);
      }
    }

    function showError(msg) {
      const errorEl = document.getElementById('error-message');
      const resultEl = document.getElementById('calc-result');
      const stepsEl = document.getElementById('step-by-step');

      errorEl.textContent = msg;
      errorEl.style.display = 'block';
      resultEl.textContent = '---';
      stepsEl.innerHTML = 'Invalid Triangle';
    }

    function handleSolveForChange() {
      const mode = document.getElementById('solve-for').value;
      const groupA = document.getElementById('group-a');
      const groupB = document.getElementById('group-b');
      const groupC = document.getElementById('group-c');

      // Clear inputs
      document.getElementById('side-a').value = '';
      document.getElementById('side-b').value = '';
      document.getElementById('side-c').value = '';

      // Reset labels
      document.getElementById('label-a').textContent = 'a';
      document.getElementById('label-b').textContent = 'b';
      document.getElementById('label-c').textContent = 'c';

      if (mode === 'c') {
        groupA.style.display = 'flex';
        groupB.style.display = 'flex';
        groupC.style.display = 'none';
      } else if (mode === 'a') {
        groupA.style.display = 'none';
        groupB.style.display = 'flex';
        groupC.style.display = 'flex';
      } else if (mode === 'b') {
        groupA.style.display = 'flex';
        groupB.style.display = 'none';
        groupC.style.display = 'flex';
      }

      calculatePythagoras();
    }

    // Attach event listeners
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('solve-for').addEventListener('change', handleSolveForChange);

      const inputs = ['side-a', 'side-b', 'side-c'];
      inputs.forEach(id => {
        document.getElementById(id).addEventListener('input', calculatePythagoras);
      });

      // Initial state
      handleSolveForChange();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .calculator-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
    @media (max-width: 768px) {
      .calculator-layout { grid-template-columns: 1fr; gap: 2rem; }
    }

    .controls-panel { display: flex; flex-direction: column; gap: 1.5rem; }

    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group label { font-weight: 600; font-size: 0.95rem; }
    .input-group em { color: var(--accent-color); font-weight: bold; font-style: italic; }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .error-message { background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 1rem; border-radius: 8px; border: 1px solid #ef4444; font-weight: 500; font-size: 0.9rem; }

    .result-panel { display: flex; flex-direction: column; gap: 1.5rem; }

    .triangle-container { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; display: flex; justify-content: center; align-items: center; min-height: 200px; }
    .triangle-svg { width: 100%; max-width: 250px; height: auto; overflow: visible; }

    .result-card { background: color-mix(in srgb, var(--accent-color) 5%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; text-align: center; }
    .result-card h3 { margin: 0 0 0.5rem 0; color: var(--text-secondary); font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); margin-bottom: 1rem; line-height: 1.2; }

    .formula-box { background: var(--card-bg); border: 1px dashed var(--border-color); padding: 1rem; border-radius: 6px; font-family: monospace; font-size: 1.1rem; line-height: 1.5; color: var(--text-secondary); text-align: left; overflow-x: auto; }

    .explainer { margin: 3rem 0; line-height: 1.7; }
    .explainer h2, .explainer h3 { margin-top: 2rem; margin-bottom: 1rem; }
    .explainer ul { margin-left: 1.5rem; margin-bottom: 1.5rem; }
    .explainer li { margin-bottom: 0.5rem; }

    .faq-section { margin-top: 3rem; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; list-style-position: inside; }
    .faq-section details[open] summary { margin-bottom: 1rem; color: var(--accent-color); }
    .faq-section p { margin: 0; line-height: 1.6; color: var(--text-secondary); }
  </style>
</SiteLayout>
