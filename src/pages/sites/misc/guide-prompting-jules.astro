---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "How to Prompt Google Jules for Research \u2014 24 Lessons from 500+ Sessions",
      "description": "Complete guide to prompting Google Jules for web scraping, original research, and automated content factories across multiple domains.",
      "author": {
        "@type": "Organization",
        "name": "photonbuilder.com/misc"
      },
      "publisher": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      },
      "datePublished": "2026-03-08",
      "dateModified": "2026-03-11"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can Google Jules make HTTP requests and scrape websites?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Jules runs in a GitHub Codespace with full internet access. It can make HTTPS GET/HEAD requests, parse HTML, follow redirects, and save results to JSON \u2014 but it cannot render JavaScript or bypass anti-scraping measures."
          }
        },
        {
          "@type": "Question",
          "name": "How many Jules sessions can you run per day?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Google Jules allows 300 sessions per day per account with up to 60 concurrent sessions. Each session takes roughly 20-45 minutes to complete."
          }
        },
        {
          "@type": "Question",
          "name": "How do you prevent Jules from generating fake data?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Include explicit anti-hallucination phrases like 'null over fake data, always' and define validation ranges for every numeric field. Jules follows these constraints when clearly stated."
          }
        },
        {
          "@type": "Question",
          "name": "What is the best way to automate Jules at scale?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use a dispatch cron to send sessions via the Jules API, a review cron to merge PRs, and a post-merge validation script to catch missing elements like GA tags, nav bars, and sitemaps."
          }
        },
        {
          "@type": "Question",
          "name": "How do you fix zero-click searches from Jules-generated content?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Rewrite meta descriptions to create curiosity gaps \u2014 tease the data without revealing the key stat. Instead of stating the answer, make users click to find it."
          }
        }
      ]
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <div class="hero-tag">Lessons Learned — Updated March 11, 2026</div>
  <h1>How to Prompt Google Jules for Original Research</h1>
  <p class="subtitle">500+ sessions, 9 domains, 400+ pages shipped. Every lesson from building a fully automated content factory — including the SEO disaster we almost missed.</p>
  <div class="date">Updated March 11, 2026 · Based on real production experience</div>
</div>

<div class="main">

  <div class="stat-row">
    <div class="stat-box"><div class="n">500+</div><div class="l">Sessions Run</div></div>
    <div class="stat-box"><div class="n">400+</div><div class="l">Pages Shipped</div></div>
    <div class="stat-box"><div class="n">9</div><div class="l">Domains</div></div>
    <div class="stat-box"><div class="n">300</div><div class="l">Daily Limit</div></div>
  </div>

  <div class="card">
    <h2>Table of Contents</h2>
    <div class="toc">
      <div class="toc-section">Foundation (Lessons 1–14)</div>
       — 43 pages (tools, studies, guides)</li>
      <li><a href="https://aliimperiale.com" style="color:#818cf8">aliimperiale.com</a> — 377 pages (tools, guides, studies, lists, blog)</li>
      <li><a href="https://photonbuilder.com/misc" style="color:#818cf8">photonbuilder.com/misc</a> — dev tools & research</li>
      <li><a href="https://photonbuilder.com" style="color:#818cf8">photonbuilder.com</a> — website builder engine</li>
      <li><a href="https://firemaths.info" style="color:#818cf8">firemaths.info</a> — finance calculators</li>
      <li><a href="https://migratingmammals.com" style="color:#818cf8">migratingmammals.com</a> — travel/nomad</li>
      <li><a href="https://ijustwantto.live" style="color:#818cf8">ijustwantto.live</a> — practical life tools</li>
      <li><a href="https://28grams.vip" style="color:#818cf8">28grams.vip</a> — food/cooking</li>
      <li><a href="https://leeroyjenkins.quest" style="color:#818cf8">leeroyjenkins.quest</a> — gaming</li>
    </ul>
    <h3>Key metrics</h3>
    <div class="stat-row">
      <div class="stat-box"><div class="n">500+</div><div class="l">Jules Sessions</div></div>
      <div class="stat-box"><div class="n">400+</div><div class="l">Pages Live</div></div>
      <div class="stat-box"><div class="n">0</div><div class="l">Fake Data Merged</div></div>
      <div class="stat-box"><div class="n">24</div><div class="l">Lessons Learned</div></div>
    </div>
    <p style="color:#555;font-size:0.82rem">Last updated: March 11, 2026. This guide is a living document — we update it every time we learn something new.</p>
  </div>

</div>
</div>`

export const meta = {
  title: "How to Prompt Google Jules for Research",
  description: "We ran 500+ Google Jules sessions across 9 domains and built a fully automated content factory.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="misc"
  title="How to Prompt Google Jules for Research"
  description="We ran 500+ Google Jules sessions across 9 domains and built a fully automated content factory."
  canonical="https://photonbuilder.com/misc/guide-prompting-jules"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <style is:inline>

code{font-family:'JetBrains Mono',monospace;font-size:0.82rem;background:#13151d;padding:2px 6px;border-radius:4px;color:#818cf8}
pre{font-family:'JetBrains Mono',monospace;font-size:0.8rem;background:#0d0e16;border:1px solid #1e2030;border-radius:10px;padding:20px;overflow-x:auto;margin:16px 0;color:#ccc;line-height:1.6}
.hero{text-align:center;padding:56px 24px 40px;background:linear-gradient(180deg,#0f1729 0%,#0a0b10 100%)}
.hero-tag{font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:#818cf8;margin-bottom:12px}
.hero h1{font-size:2rem;font-weight:900;color:#fff;margin-bottom:12px;letter-spacing:-0.5px;max-width:700px;margin-left:auto;margin-right:auto}
.hero .subtitle{color:#666;font-size:0.95rem;max-width:560px;margin:0 auto 16px}
.hero .date{font-size:0.78rem;color:#444}
.main{max-width:780px;margin:0 auto;padding:32px 20px 60px}
.card{background:#111318;border:1px solid #1e2030;border-radius:14px;padding:28px 24px;margin-bottom:20px}
.card h2{font-size:1.25rem;font-weight:800;color:#fff;margin-bottom:14px}
.card h3{font-size:1.05rem;font-weight:700;color:#ccc;margin:20px 0 10px}
.card p{font-size:0.9rem;color:#999;line-height:1.8;margin-bottom:12px}
.card ul,.card ol{font-size:0.9rem;color:#999;padding-left:24px;margin-bottom:12px}
.card li{margin-bottom:6px;line-height:1.7}
.card strong{color:#ccc}
.lesson{background:#0f1120;border:1px solid #1a2040;border-radius:10px;padding:20px;margin:16px 0}
.lesson .lesson-num{font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#818cf8;margin-bottom:6px}
.lesson .lesson-title{font-size:1rem;font-weight:700;color:#fff;margin-bottom:8px}
.lesson p{font-size:0.85rem;color:#999;margin-bottom:8px}
.before-after{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:16px 0}
.ba-col{border-radius:10px;padding:16px;font-size:0.82rem}
.ba-bad{background:#1a0a0a;border:1px solid #2e1515;color:#f87171}
.ba-good{background:#0a1a10;border:1px solid #152e15;color:#34d399}
.ba-label{font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;opacity:0.7}
.stat-row{display:flex;gap:16px;flex-wrap:wrap;margin:16px 0}
.stat-box{background:#0a0b10;border:1px solid #1e2030;border-radius:10px;padding:14px 20px;text-align:center;flex:1;min-width:100px}
.stat-box .n{font-size:1.5rem;font-weight:900;color:#818cf8}.stat-box .l{font-size:0.68rem;color:#666;text-transform:uppercase;margin-top:2px}
.toc{background:#0a0b10;border:1px solid #1e2030;border-radius:10px;padding:20px;margin:16px 0}
.toc a{color:#818cf8;text-decoration:none;font-size:0.85rem;display:block;padding:3px 0}
.toc a:hover{text-decoration:underline}
.toc .toc-section{font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#555;margin:14px 0 6px;padding-top:8px;border-top:1px solid #1e2030}
.toc .toc-section:first-child{border-top:none;margin-top:0;padding-top:0}
.new-tag{display:inline-block;background:#818cf8;color:#0a0b10;font-size:0.55rem;font-weight:800;padding:2px 6px;border-radius:4px;margin-left:6px;vertical-align:middle;letter-spacing:0.5px}
.footer{text-align:center;padding:40px 24px;font-size:0.78rem;color:#555;border-top:1px solid #151520;margin-top:40px}
.footer a{color:#818cf8;text-decoration:none}
@media(max-width:600px){
  .hero h1{font-size:1.5rem}
  .main{padding:20px 14px}
  .before-after{grid-template-columns:1fr}
  .stat-row{gap:8px}
  .stat-box{min-width:80px;padding:10px 12px}
  .stat-box .n{font-size:1.2rem}
}

</style>
</SiteLayout>
