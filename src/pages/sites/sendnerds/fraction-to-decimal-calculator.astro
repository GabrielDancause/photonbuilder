  <script is:inline>
    // Client-side calculator logic
    document.addEventListener('DOMContentLoaded', () => {
      const numInput = document.getElementById('numerator');
      const denInput = document.getElementById('denominator');
      const decimalResult = document.getElementById('decimal-result');
      const errorMsg = document.getElementById('error-msg');
      const percResult = document.getElementById('percentage-result');
      const typeResult = document.getElementById('type-result');
      const repResult = document.getElementById('repeating-result');
      const visualFill = document.getElementById('visual-fill');
      const visualLabel = document.getElementById('visual-current-fraction');
      const divTable = document.getElementById('division-table');

      function calculate() {
        const nStr = numInput.value.trim();
        const dStr = denInput.value.trim();

        if (!nStr || !dStr) {
          showError('Please enter both numerator and denominator.');
          return;
        }

        const n = parseInt(nStr, 10);
        const d = parseInt(dStr, 10);

        if (isNaN(n) || isNaN(d)) {
          showError('Please enter valid integers.');
          return;
        }

        if (d === 0) {
          showError('Denominator cannot be zero.');
          return;
        }

        errorMsg.style.display = 'none';

        // Handle negative signs
        const isNegative = (n < 0 && d > 0) || (n > 0 && d < 0);
        const absN = Math.abs(n);
        const absD = Math.abs(d);

        // Core calculation
        const result = absN / absD;
        const finalResultStr = isNegative ? '-' + result.toString() : result.toString();

        // Long Division to find repeating sequence
        let remainders = {};
        let resultStr = "";
        let remainder = absN % absD;

        let integerPart = Math.floor(absN / absD);
        resultStr += integerPart.toString();

        let repeatingIndex = -1;
        let decimalPart = "";

        // Collect steps for visualization
        let steps = [];
        steps.push({ step: 'Initial', val: absN, rem: remainder, div: integerPart, sub: integerPart * absD });

        if (remainder === 0) {
          // Terminating
          decimalResult.textContent = finalResultStr;
          typeResult.textContent = 'Terminating';
          repResult.textContent = 'None';
        } else {
          resultStr += ".";

          while (remainder !== 0) {
            if (remainders.hasOwnProperty(remainder)) {
              repeatingIndex = remainders[remainder];
              break;
            }

            remainders[remainder] = decimalPart.length;
            remainder *= 10;

            let quotientDigit = Math.floor(remainder / absD);
            let subVal = quotientDigit * absD;

            steps.push({ step: 'Dec', val: remainder, rem: remainder - subVal, div: quotientDigit, sub: subVal });

            decimalPart += quotientDigit.toString();
            remainder = remainder % absD;

            // Limit to 20 decimals to prevent infinite browser hang on huge numbers
            if (decimalPart.length > 20) {
              break;
            }
          }

          if (repeatingIndex !== -1) {
            // Repeating
            const nonRepeatingPart = decimalPart.substring(0, repeatingIndex);
            const repeatingPart = decimalPart.substring(repeatingIndex);

            let htmlStr = (isNegative ? "-" : "") + integerPart.toString() + "." + nonRepeatingPart + "<span style='text-decoration: overline'>" + repeatingPart + "</span>";
            decimalResult.innerHTML = htmlStr;
            typeResult.textContent = 'Repeating';
            repResult.textContent = repeatingPart;
          } else {
            // Terminating or truncated
            decimalResult.textContent = finalResultStr;
            typeResult.textContent = decimalPart.length > 20 ? 'Truncated' : 'Terminating';
            repResult.textContent = 'None';
          }
        }

        // Percentage
        const perc = (result * 100).toFixed(4).replace(/\.?0+$/, '');
        percResult.textContent = (isNegative ? '-' : '') + perc + '%';

        // Visualization
        let percentageNum = result * 100;
        if (percentageNum > 100) percentageNum = 100;
        if (percentageNum < 0) percentageNum = 0;
        visualFill.style.width = percentageNum + '%';
        visualLabel.textContent = n + '/' + d;

        // Render Long Division Steps
        renderDivisionTable(absN, absD, integerPart, decimalPart, steps);
      }

      function renderDivisionTable(n, d, intPart, decPart, steps) {
        divTable.innerHTML = '';

        let fullAnswer = intPart.toString();
        if (decPart.length > 0) fullAnswer += "." + decPart;

        // Header
        const header = document.createElement('div');
        header.className = 'division-header';

        const divisorSpan = document.createElement('span');
        divisorSpan.className = 'division-divisor';
        divisorSpan.textContent = d;

        const answerSpan = document.createElement('span');
        answerSpan.textContent = fullAnswer;

        header.appendChild(divisorSpan);
        header.appendChild(answerSpan);
        divTable.appendChild(header);

        // Initial Dividend
        const initDiv = document.createElement('div');
        initDiv.className = 'division-row';
        initDiv.textContent = n;
        divTable.appendChild(initDiv);

        let indent = 0;

        steps.forEach((step, idx) => {
          if (step.sub > 0 || idx > 0) {
            const subRow = document.createElement('div');
            subRow.className = 'division-row subtraction-line text-red';
            subRow.innerHTML = '-' + step.sub;
            // Simplified spacing for illustration
            divTable.appendChild(subRow);

            const remRow = document.createElement('div');
            remRow.className = 'division-row text-green';
            remRow.textContent = step.rem;
            divTable.appendChild(remRow);

            if (step.rem === 0) {
              const doneRow = document.createElement('div');
              doneRow.className = 'division-row';
              doneRow.textContent = '0 (Done)';
              divTable.appendChild(doneRow);
            }
          }
        });
      }

      function showError(msg) {
        errorMsg.textContent = msg;
        errorMsg.style.display = 'block';
        decimalResult.textContent = '--';
        percResult.textContent = '--';
        typeResult.textContent = '--';
        repResult.textContent = '--';
        visualFill.style.width = '0%';
        divTable.innerHTML = 'Enter valid numbers to see steps.';
      }

      numInput.addEventListener('input', calculate);
      denInput.addEventListener('input', calculate);

      // Initial calculate
      calculate();
    });

