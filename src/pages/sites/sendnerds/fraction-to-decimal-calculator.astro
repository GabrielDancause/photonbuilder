            <div class="decimal-result" id="decimal-result">0.375</div>
            <div class="error-msg" id="error-msg" style="display: none;"></div>
          </div>
        </div>

        <div class="results-grid">
          <div class="result-card">
            <h3>Percentage</h3>
            <div class="result-value" id="percentage-result">37.5%</div>
            <p class="result-desc">The fraction expressed as a percent.</p>
          </div>
          <div class="result-card">
            <h3>Decimal Type</h3>
            <div class="result-value" id="type-result">Terminating</div>
