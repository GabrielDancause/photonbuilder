---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Law of Cosines Calculator | Sendnerds',
  description: 'Solve triangles instantly with our Law of Cosines Calculator. Find missing sides and angles, explore step-by-step solutions, and learn exactly when to use it.',
  category: 'tool',
  keywords: ['law of cosines calculator', 'sas triangle calculator', 'sss triangle calculator', 'find missing side of triangle', 'find missing angle of triangle', 'law of cosines formula']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Law of Cosines Calculator | Sendnerds",
    "description": "Solve triangles instantly with our Law of Cosines Calculator. Find missing sides and angles, explore step-by-step solutions, and learn exactly when to use it.",
    "author": {
      "@type": "Organization",
      "name": "sendnerds.photonbuilder.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "sendnerds.photonbuilder.com"
    },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Law of Cosines used for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Law of Cosines is used to find unknown sides or angles in a triangle, especially when you know three sides (SSS) or two sides and the included angle (SAS). It's a generalization of the Pythagorean theorem for non-right triangles."
        }
      },
      {
        "@type": "Question",
        "name": "What is the formula for the Law of Cosines?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The formula is c\u00b2 = a\u00b2 + b\u00b2 - 2ab * cos(C), where a, b, and c are sides of the triangle, and C is the angle opposite side c. It can also be rearranged to solve for an angle: cos(C) = (a\u00b2 + b\u00b2 - c\u00b2) / (2ab)."
        }
      },
      {
        "@type": "Question",
        "name": "When should I use the Law of Cosines instead of the Law of Sines?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Use the Law of Cosines when you have SSS (Side-Side-Side) or SAS (Side-Angle-Side). Use the Law of Sines when you have a known side and its opposite known angle, like AAS, ASA, or SSA."
        }
      },
      {
        "@type": "Question",
        "name": "Can the Law of Cosines solve for right triangles?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! If angle C is 90 degrees, cos(90\u00b0) = 0, so the term '- 2ab * cos(C)' becomes zero. The formula then simplifies exactly to the Pythagorean theorem: c\u00b2 = a\u00b2 + b\u00b2."
        }
      },
      {
        "@type": "Question",
        "name": "Can a triangle be solved if only the three angles are known?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Knowing only three angles (AAA) gives the shape of the triangle but not its size. There are infinitely many similar triangles with the same angles, so you need at least one side length to find exact dimensions."
        }
      }
    ]
  }
]);
---
<SiteLayout site="sendnerds" title={meta.title} description={meta.description}>
