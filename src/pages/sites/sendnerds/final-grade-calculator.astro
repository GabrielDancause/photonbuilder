---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Final Grade Calculator | What Do I Need on My Final?",
  description: "Calculate exactly what grade you need on your final exam. Enter your current grade, desired grade, and exam weight — get your answer instantly.",
  category: "tool",
  published: "2026-03-26"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Final Grade Calculator",
    "description": "Calculate what grade you need on your final exam to achieve your desired course grade",
    "url": "https://sendnerds.photonbuilder.com/final-grade-calculator",
    "publisher": {
      "@type": "Organization",
      "name": "Send Nerds"
    },
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "Web Browser",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I calculate what grade I need on my final exam?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Use the formula: Grade Needed = (Desired Grade - Current Grade × (1 - Final Weight)) / Final Weight. For example, if you have an 80% average, want a 90% final grade, and the final is worth 30%, you'd need: (90 - 80 × 0.7) / 0.3 = 96.67%"
        }
      },
      {
        "@type": "Question", 
        "name": "What if I need more than 100% on my final?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If the calculator shows you need more than 100%, it means your desired final grade is mathematically impossible given your current grade and the final exam weight. You may need to adjust your target grade or check if there are extra credit opportunities."
        }
      },
      {
        "@type": "Question",
        "name": "How are weighted grades calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Weighted grades multiply each component by its percentage weight, then sum them up. For example: Final Grade = (Current Grade × (100% - Final Weight)) + (Final Exam Grade × Final Weight)"
        }
      },
      {
        "@type": "Question",
        "name": "What's a typical final exam weight?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Final exam weights vary by course and instructor. Common weights are 20-40% for most courses, with some courses having finals worth up to 50% or more. Check your syllabus for the exact weight."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use this calculator for different grading scales?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, this calculator works with any percentage-based grading system. Just enter your grades as percentages (0-100). For other scales, convert to percentages first."
        }
      }
    ]
  }
];
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description} canonical="https://sendnerds.photonbuilder.com/final-grade-calculator" schema={schema}>
  <!-- Hero Section -->
  <div class="bg-[var(--bg-color)] py-12">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-[var(--text-primary)] mb-4">
          Final Grade Calculator
        </h1>
        <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
          Calculate exactly what grade you need on your final exam to achieve your target course grade
        </p>
      </div>
    </div>
  </div>

  <!-- Calculator Tool -->
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
      <!-- Main Calculator Card -->
      <div class="bg-[var(--card-bg)] rounded-xl border border-[var(--border-color)] p-6 md:p-8 mb-8">
        <!-- Mode Toggle -->
        <div class="flex justify-center mb-6">
          <div class="bg-[var(--bg-color)] rounded-lg p-1 border border-[var(--border-color)]">
            <button id="normalModeBtn" class="px-4 py-2 rounded-md bg-[var(--accent-color)] text-white font-medium transition-colors">
              What do I need?
            </button>
            <button id="reverseModeBtn" class="px-4 py-2 rounded-md text-[var(--text-secondary)] font-medium hover:text-[var(--text-primary)] transition-colors">
              What will I get?
            </button>
          </div>
        </div>

        <!-- Calculator Form -->
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Input Section -->
          <div class="space-y-6">
            <!-- Current Grade -->
            <div>
              <label for="currentGrade" class="block text-[var(--text-primary)] font-medium mb-2">
                Current Grade (%)
              </label>
              <input
                type="number"
                id="currentGrade"
                min="0"
                max="100"
                step="0.1"
                placeholder="85"
                class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-[var(--bg-color)] text-[var(--text-primary)] focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              />
            </div>

            <!-- Desired Grade (Normal Mode) / Final Exam Score (Reverse Mode) -->
            <div id="desiredGradeContainer">
              <label for="desiredGrade" class="block text-[var(--text-primary)] font-medium mb-2">
                Desired Final Grade (%)
              </label>
              <input
                type="number"
                id="desiredGrade"
                min="0"
                max="100"
                step="0.1"
                placeholder="90"
                class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-[var(--bg-color)] text-[var(--text-primary)] focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              />
            </div>

            <div id="finalScoreContainer" class="hidden">
              <label for="finalScore" class="block text-[var(--text-primary)] font-medium mb-2">
                Final Exam Score (%)
              </label>
              <input
                type="number"
                id="finalScore"
                min="0"
                max="100"
                step="0.1"
                placeholder="85"
                class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-[var(--bg-color)] text-[var(--text-primary)] focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              />
            </div>

            <!-- Final Exam Weight -->
            <div>
              <label for="finalWeight" class="block text-[var(--text-primary)] font-medium mb-2">
                Final Exam Weight (%)
              </label>
              <input
                type="number"
                id="finalWeight"
                min="1"
                max="100"
                step="0.1"
                placeholder="30"
                class="w-full px-4 py-3 rounded-lg border border-[var(--border-color)] bg-[var(--bg-color)] text-[var(--text-primary)] focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              />
            </div>
          </div>

          <!-- Results Section -->
          <div class="space-y-6">
            <!-- Result Display -->
            <div id="resultCard" class="bg-[var(--bg-color)] rounded-lg p-6 border border-[var(--border-color)] text-center hidden">
              <div id="resultText" class="text-2xl md:text-3xl font-bold mb-2"></div>
              <div id="resultDescription" class="text-[var(--text-secondary)] mb-4"></div>
              <div id="verdictBadge" class="inline-block px-3 py-1 rounded-full text-sm font-medium"></div>
            </div>

            <!-- Letter Grade Reference -->
            <div class="bg-[var(--bg-color)] rounded-lg p-6 border border-[var(--border-color)]">
              <h3 class="font-bold text-[var(--text-primary)] mb-3">Letter Grade Scale</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-[var(--text-primary)] font-medium">A</span>
                  <span class="text-[var(--text-secondary)]">90-100%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-primary)] font-medium">B</span>
                  <span class="text-[var(--text-secondary)]">80-89%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-primary)] font-medium">C</span>
                  <span class="text-[var(--text-secondary)]">70-79%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-primary)] font-medium">D</span>
                  <span class="text-[var(--text-secondary)]">60-69%</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-[var(--text-primary)] font-medium">F</span>
                  <span class="text-[var(--text-secondary)]">Below 60%</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Sections -->
      
      <!-- How Final Grades Are Calculated -->
      <div class="bg-[var(--card-bg)] rounded-xl border border-[var(--border-color)] p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-6">
          How Final Grades Are Calculated
        </h2>
        <div class="prose max-w-none text-[var(--text-secondary)]">
          <p class="mb-4">
            Final course grades use weighted averages, where different components (homework, tests, final exam) 
            contribute different percentages to your overall grade. Understanding this system is crucial for 
            planning your exam preparation strategy.
          </p>
          
          <h3 class="text-xl font-semibold text-[var(--text-primary)] mb-3">Example Calculation</h3>
          <p class="mb-4">
            Let's say you have an 82% average so far, and the final exam is worth 25% of your total grade. 
            If you want to finish with a 90% (A-) in the class, you'd need:
          </p>
          
          <div class="bg-[var(--bg-color)] rounded-lg p-4 mb-4">
            <p class="font-mono text-sm">
              Grade Needed = (90 - 82 × 0.75) / 0.25 = (90 - 61.5) / 0.25 = <strong>114%</strong>
            </p>
          </div>
          
          <p>
            This means you'd need 114% on the final—which is impossible! In this case, you might need to 
            adjust your target grade or look for extra credit opportunities.
          </p>
        </div>
      </div>

      <!-- What Grade Do I Need on My Final -->
      <div class="bg-[var(--card-bg)] rounded-xl border border-[var(--border-color)] p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-6">
          What Grade Do I Need on My Final?
        </h2>
        <div class="prose max-w-none text-[var(--text-secondary)]">
          <p class="mb-4">
            The formula to calculate your required final exam grade is straightforward once you understand 
            weighted averages:
          </p>
          
          <div class="bg-[var(--bg-color)] rounded-lg p-4 mb-6">
            <p class="font-mono text-sm mb-2">
              <strong>Required Final Grade = (Target Grade - Current Grade × (1 - Final Weight)) / Final Weight</strong>
            </p>
          </div>
          
          <h3 class="text-xl font-semibold text-[var(--text-primary)] mb-3">Step-by-Step Process</h3>
          
          <ol class="list-decimal list-inside space-y-3 mb-6">
            <li><strong>Find your current grade:</strong> Calculate your average across all completed assignments, tests, and projects.</li>
            <li><strong>Determine the final exam weight:</strong> Check your syllabus for what percentage the final counts toward your total grade.</li>
            <li><strong>Set your target grade:</strong> Decide what final grade you want to achieve in the class.</li>
            <li><strong>Apply the formula:</strong> Use the calculation above to find your required final exam score.</li>
          </ol>
          
          <div class="bg-blue-50 border-l-4 border-blue-400 p-4 rounded-r-lg">
            <p class="text-blue-800">
              <strong>Pro Tip:</strong> If the calculator shows you need more than 100%, don't panic! 
              Consider adjusting your target grade, seeking extra credit, or discussing options with your instructor.
            </p>
          </div>
        </div>
      </div>

      <!-- Tips for Final Exam Preparation -->
      <div class="bg-[var(--card-bg)] rounded-xl border border-[var(--border-color)] p-6 md:p-8 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-6">
          Tips for Final Exam Preparation
        </h2>
        <div class="prose max-w-none text-[var(--text-secondary)]">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h3 class="text-xl font-semibold text-[var(--text-primary)] mb-3">Study Strategies</h3>
              <ul class="space-y-2">
                <li class="flex items-start">
                  <span class="bg-green-100 text-green-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">✓</span>
                  Create a study schedule working backwards from your exam date
                </li>
                <li class="flex items-start">
                  <span class="bg-green-100 text-green-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">✓</span>
                  Focus on topics that will have the biggest impact on your grade
                </li>
                <li class="flex items-start">
                  <span class="bg-green-100 text-green-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">✓</span>
                  Use active recall and practice testing instead of just re-reading
                </li>
                <li class="flex items-start">
                  <span class="bg-green-100 text-green-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">✓</span>
                  Form study groups to discuss complex concepts
                </li>
              </ul>
            </div>
            
            <div>
              <h3 class="text-xl font-semibold text-[var(--text-primary)] mb-3">Exam Day Tips</h3>
              <ul class="space-y-2">
                <li class="flex items-start">
                  <span class="bg-blue-100 text-blue-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">!</span>
                  Get plenty of sleep the night before—cramming won't help
                </li>
                <li class="flex items-start">
                  <span class="bg-blue-100 text-blue-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">!</span>
                  Read all instructions carefully before starting
                </li>
                <li class="flex items-start">
                  <span class="bg-blue-100 text-blue-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">!</span>
                  Budget your time—don't spend too long on any one question
                </li>
                <li class="flex items-start">
                  <span class="bg-blue-100 text-blue-800 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold mr-3 mt-0.5 flex-shrink-0">!</span>
                  Review your answers if time permits
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="bg-[var(--card-bg)] rounded-xl border border-[var(--border-color)] p-6 md:p-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-6">
          Frequently Asked Questions
        </h2>
        <div class="space-y-4">
          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)] hover:border-blue-300 transition-colors">
              <span class="font-medium text-[var(--text-primary)]">How do I calculate what grade I need on my final exam?</span>
              <span class="text-[var(--text-secondary)] group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="mt-4 p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)]">
              <p class="text-[var(--text-secondary)]">
                Use the formula: Grade Needed = (Desired Grade - Current Grade × (1 - Final Weight)) / Final Weight. 
                For example, if you have an 80% average, want a 90% final grade, and the final is worth 30%, 
                you'd need: (90 - 80 × 0.7) / 0.3 = 96.67%
              </p>
            </div>
          </details>

          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)] hover:border-blue-300 transition-colors">
              <span class="font-medium text-[var(--text-primary)]">What if I need more than 100% on my final?</span>
              <span class="text-[var(--text-secondary)] group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="mt-4 p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)]">
              <p class="text-[var(--text-secondary)]">
                If the calculator shows you need more than 100%, it means your desired final grade is mathematically 
                impossible given your current grade and the final exam weight. You may need to adjust your target 
                grade or check if there are extra credit opportunities.
              </p>
            </div>
          </details>

          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)] hover:border-blue-300 transition-colors">
              <span class="font-medium text-[var(--text-primary)]">How are weighted grades calculated?</span>
              <span class="text-[var(--text-secondary)] group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="mt-4 p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)]">
              <p class="text-[var(--text-secondary)]">
                Weighted grades multiply each component by its percentage weight, then sum them up. 
                For example: Final Grade = (Current Grade × (100% - Final Weight)) + (Final Exam Grade × Final Weight)
              </p>
            </div>
          </details>

          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)] hover:border-blue-300 transition-colors">
              <span class="font-medium text-[var(--text-primary)]">What's a typical final exam weight?</span>
              <span class="text-[var(--text-secondary)] group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="mt-4 p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)]">
              <p class="text-[var(--text-secondary)]">
                Final exam weights vary by course and instructor. Common weights are 20-40% for most courses, 
                with some courses having finals worth up to 50% or more. Check your syllabus for the exact weight.
              </p>
            </div>
          </details>

          <details class="group">
            <summary class="flex justify-between items-center cursor-pointer p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)] hover:border-blue-300 transition-colors">
              <span class="font-medium text-[var(--text-primary)]">Can I use this calculator for different grading scales?</span>
              <span class="text-[var(--text-secondary)] group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="mt-4 p-4 bg-[var(--bg-color)] rounded-lg border border-[var(--border-color)]">
              <p class="text-[var(--text-secondary)]">
                Yes, this calculator works with any percentage-based grading system. Just enter your grades as 
                percentages (0-100). For other scales, convert to percentages first.
              </p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Get DOM elements
    const normalModeBtn = document.getElementById('normalModeBtn');
    const reverseModeBtn = document.getElementById('reverseModeBtn');
    const currentGradeInput = document.getElementById('currentGrade');
    const desiredGradeInput = document.getElementById('desiredGrade');
    const finalScoreInput = document.getElementById('finalScore');
    const finalWeightInput = document.getElementById('finalWeight');
    const desiredGradeContainer = document.getElementById('desiredGradeContainer');
    const finalScoreContainer = document.getElementById('finalScoreContainer');
    const resultCard = document.getElementById('resultCard');
    const resultText = document.getElementById('resultText');
    const resultDescription = document.getElementById('resultDescription');
    const verdictBadge = document.getElementById('verdictBadge');

    let isReverseMode = false;

    // Mode toggle functionality
    function toggleMode() {
      isReverseMode = !isReverseMode;
      
      if (isReverseMode) {
        // Switch to reverse mode
        normalModeBtn.classList.remove('bg-[var(--accent-color)]', 'text-white');
        normalModeBtn.classList.add('text-[var(--text-secondary)]');
        reverseModeBtn.classList.add('bg-[var(--accent-color)]', 'text-white');
        reverseModeBtn.classList.remove('text-[var(--text-secondary)]');
        
        desiredGradeContainer.classList.add('hidden');
        finalScoreContainer.classList.remove('hidden');
      } else {
        // Switch to normal mode
        reverseModeBtn.classList.remove('bg-[var(--accent-color)]', 'text-white');
        reverseModeBtn.classList.add('text-[var(--text-secondary)]');
        normalModeBtn.classList.add('bg-[var(--accent-color)]', 'text-white');
        normalModeBtn.classList.remove('text-[var(--text-secondary)]');
        
        finalScoreContainer.classList.add('hidden');
        desiredGradeContainer.classList.remove('hidden');
      }
      
      calculate();
    }

    normalModeBtn.addEventListener('click', () => {
      if (isReverseMode) toggleMode();
    });

    reverseModeBtn.addEventListener('click', () => {
      if (!isReverseMode) toggleMode();
    });

    // Calculation function
    function calculate() {
      const currentGrade = parseFloat(currentGradeInput.value);
      const finalWeight = parseFloat(finalWeightInput.value);
      
      if (isNaN(currentGrade) || isNaN(finalWeight)) {
        resultCard.classList.add('hidden');
        return;
      }

      let result, description, verdictClass, verdictText;

      if (isReverseMode) {
        // Reverse mode: calculate final grade
        const finalScore = parseFloat(finalScoreInput.value);
        
        if (isNaN(finalScore)) {
          resultCard.classList.add('hidden');
          return;
        }
        
        const finalGrade = currentGrade * (1 - finalWeight / 100) + finalScore * (finalWeight / 100);
        
        result = finalGrade.toFixed(1) + '%';
        description = `With a ${finalScore}% on your final, your course grade will be ${finalGrade.toFixed(1)}%`;
        
        // Determine letter grade and color
        if (finalGrade >= 90) {
          verdictClass = 'bg-green-100 text-green-800';
          verdictText = 'A Grade';
        } else if (finalGrade >= 80) {
          verdictClass = 'bg-blue-100 text-blue-800';
          verdictText = 'B Grade';
        } else if (finalGrade >= 70) {
          verdictClass = 'bg-yellow-100 text-yellow-800';
          verdictText = 'C Grade';
        } else if (finalGrade >= 60) {
          verdictClass = 'bg-orange-100 text-orange-800';
          verdictText = 'D Grade';
        } else {
          verdictClass = 'bg-red-100 text-red-800';
          verdictText = 'F Grade';
        }
      } else {
        // Normal mode: calculate required final grade
        const desiredGrade = parseFloat(desiredGradeInput.value);
        
        if (isNaN(desiredGrade)) {
          resultCard.classList.add('hidden');
          return;
        }
        
        const gradeNeeded = (desiredGrade - currentGrade * (1 - finalWeight / 100)) / (finalWeight / 100);
        
        result = gradeNeeded.toFixed(1) + '%';
        description = `You need a ${gradeNeeded.toFixed(1)}% on your final to get a ${desiredGrade}% in the class`;
        
        // Determine difficulty and color
        if (gradeNeeded > 100) {
          verdictClass = 'bg-red-100 text-red-800';
          verdictText = 'Impossible';
        } else if (gradeNeeded > 90) {
          verdictClass = 'bg-orange-100 text-orange-800';
          verdictText = 'Very Tough';
        } else if (gradeNeeded > 70) {
          verdictClass = 'bg-yellow-100 text-yellow-800';
          verdictText = 'Doable';
        } else {
          verdictClass = 'bg-green-100 text-green-800';
          verdictText = 'Easy';
        }
      }

      // Update result display
      resultText.textContent = result;
      resultDescription.textContent = description;
      verdictBadge.className = `inline-block px-3 py-1 rounded-full text-sm font-medium ${verdictClass}`;
      verdictBadge.textContent = verdictText;
      
      resultCard.classList.remove('hidden');
    }

    // Add event listeners for real-time calculation
    currentGradeInput.addEventListener('input', calculate);
    desiredGradeInput.addEventListener('input', calculate);
    finalScoreInput.addEventListener('input', calculate);
    finalWeightInput.addEventListener('input', calculate);

    // Initial calculation on page load
    calculate();
  </script>
</SiteLayout>