          {id:'c25',front:'Missouri',back:'Jefferson City',box:0,next:0},{id:'c26',front:'Montana',back:'Helena',box:0,next:0},
          {id:'c27',front:'Nebraska',back:'Lincoln',box:0,next:0},{id:'c28',front:'Nevada',back:'Carson City',box:0,next:0},
          {id:'c29',front:'New Hampshire',back:'Concord',box:0,next:0},{id:'c30',front:'New Jersey',back:'Trenton',box:0,next:0},
          {id:'c31',front:'New Mexico',back:'Santa Fe',box:0,next:0},{id:'c32',front:'New York',back:'Albany',box:0,next:0},
          {id:'c33',front:'North Carolina',back:'Raleigh',box:0,next:0},{id:'c34',front:'North Dakota',back:'Bismarck',box:0,next:0},
          {id:'c35',front:'Ohio',back:'Columbus',box:0,next:0},{id:'c36',front:'Oklahoma',back:'Oklahoma City',box:0,next:0},
          {id:'c37',front:'Oregon',back:'Salem',box:0,next:0},{id:'c38',front:'Pennsylvania',back:'Harrisburg',box:0,next:0},
          {id:'c39',front:'Rhode Island',back:'Providence',box:0,next:0},{id:'c40',front:'South Carolina',back:'Columbia',box:0,next:0},
          {id:'c41',front:'South Dakota',back:'Pierre',box:0,next:0},{id:'c42',front:'Tennessee',back:'Nashville',box:0,next:0},
          {id:'c43',front:'Texas',back:'Austin',box:0,next:0},{id:'c44',front:'Utah',back:'Salt Lake City',box:0,next:0},
          {id:'c45',front:'Vermont',back:'Montpelier',box:0,next:0},{id:'c46',front:'Virginia',back:'Richmond',box:0,next:0},
          {id:'c47',front:'Washington',back:'Olympia',box:0,next:0},{id:'c48',front:'West Virginia',back:'Charleston',box:0,next:0},
          {id:'c49',front:'Wisconsin',back:'Madison',box:0,next:0},{id:'c50',front:'Wyoming',back:'Cheyenne',box:0,next:0}
        ]
      };

      // ---- State ----
      let decks = [];
      let stats = { totalStudied: 0, totalCorrect: 0, totalWrong: 0, bestStreak: 0, sessions: 0 };
      let currentDeckId = null;
      let editingCards = [];
      let studyDeckId = null;
      let studyMode = 'flip';
      let studyQueue = [];
      let studyIndex = 0;
      let sessionCorrect = 0;
      let sessionWrong = 0;
      let sessionStreak = 0;
      let sessionBestStreak = 0;
      let flipped = false;

      // ---- Persistence ----
      function loadData() {
        try {
          const d = JSON.parse(localStorage.getItem(DECKS_KEY));
          if (d && Array.isArray(d) && d.length > 0) { decks = d; }
          else { decks = [JSON.parse(JSON.stringify(defaultSpanish)), JSON.parse(JSON.stringify(defaultCapitals))]; saveDecks(); }
        } catch { decks = [JSON.parse(JSON.stringify(defaultSpanish)), JSON.parse(JSON.stringify(defaultCapitals))]; saveDecks(); }
        try {
          const s = JSON.parse(localStorage.getItem(STATS_KEY));
          if (s) stats = s;
        } catch {}
      }
      function saveDecks() { localStorage.setItem(DECKS_KEY, JSON.stringify(decks)); }
      function saveStats() { localStorage.setItem(STATS_KEY, JSON.stringify(stats)); }

      // ---- Utility ----
      function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2, 8); }
      function shuffle(arr) { const a = [...arr]; for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; } return a; }

      // ---- Navigation ----
      const views = { decks: document.getElementById('view-decks'), study: document.getElementById('view-study'), stats: document.getElementById('view-stats'), editor: document.getElementById('view-editor') };
      document.querySelectorAll('.nav-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          showView(btn.dataset.view);
        });
      });
      function showView(name) {
        Object.values(views).forEach(v => v.style.display = 'none');
        views[name].style.display = 'block';
        if (name === 'decks') renderDecks();
        if (name === 'study') renderStudySetup();
        if (name === 'stats') renderStats();
      }

      // ---- Deck Grid ----
      function renderDecks() {
        const grid = document.getElementById('deck-grid');
        if (decks.length === 0) {
          grid.innerHTML = '<p class="empty-msg">No decks yet. Create one or import a JSON file.</p>';
          return;
        }
        grid.innerHTML = decks.map(d => {
          const due = d.cards.filter(c => (c.next || 0) <= Date.now()).length;
          return '<div class="deck-card" data-id="' + d.id + '">' +
            '<h3>' + esc(d.name) + '</h3>' +
            '<span class="deck-subject">' + esc(d.subject || 'General') + '</span>' +
            '<div class="deck-meta">' + d.cards.length + ' cards &middot; ' + due + ' due</div>' +
            '</div>';
        }).join('');
        grid.querySelectorAll('.deck-card').forEach(el => {
          el.addEventListener('click', () => openEditor(el.dataset.id));
        });
      }

      function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

      // ---- Deck Editor ----
      function openEditor(deckId) {
        currentDeckId = deckId;
        const deck = decks.find(d => d.id === deckId);
        if (!deck) return;
        editingCards = JSON.parse(JSON.stringify(deck.cards));
        document.getElementById('deck-name-input').value = deck.name;
        document.getElementById('deck-subject-input').value = deck.subject || '';
        document.getElementById('editor-title').textContent = 'Edit: ' + deck.name;
        renderCardList();
        Object.values(views).forEach(v => v.style.display = 'none');
        views.editor.style.display = 'block';
      }

      function renderCardList() {
        document.getElementById('card-count').textContent = editingCards.length;
        const list = document.getElementById('card-list');
        if (editingCards.length === 0) {
          list.innerHTML = '<p class="empty-msg">No cards. Click "+ Add Card" to create one.</p>';
          return;
        }
        list.innerHTML = editingCards.map((c, i) =>
          '<div class="card-row">' +
            '<div class="card-fields">' +
              '<input type="text" class="card-input" data-i="' + i + '" data-side="front" value="' + esc(c.front) + '" placeholder="Front">' +
              '<input type="text" class="card-input" data-i="' + i + '" data-side="back" value="' + esc(c.back) + '" placeholder="Back">' +
            '</div>' +
            '<button class="remove-card-btn" data-i="' + i + '">&times;</button>' +
          '</div>'
        ).join('');
        list.querySelectorAll('.card-input').forEach(input => {
          input.addEventListener('input', () => {
            const idx = parseInt(input.dataset.i);
            editingCards[idx][input.dataset.side] = input.value;
          });
        });
        list.querySelectorAll('.remove-card-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            editingCards.splice(parseInt(btn.dataset.i), 1);
            renderCardList();
          });
        });
      }

      document.getElementById('add-card-btn').addEventListener('click', () => {
        editingCards.push({ id: uid(), front: '', back: '', box: 0, next: 0 });
        renderCardList();
        const list = document.getElementById('card-list');
        list.scrollTop = list.scrollHeight;
        const inputs = list.querySelectorAll('.card-input[data-side="front"]');
        if (inputs.length) inputs[inputs.length - 1].focus();
      });

      document.getElementById('save-deck-btn').addEventListener('click', () => {
        const name = document.getElementById('deck-name-input').value.trim();
        if (!name) { alert('Please enter a deck name.'); return; }
        const valid = editingCards.filter(c => c.front.trim() && c.back.trim());
        if (valid.length === 0) { alert('Add at least one card with both front and back.'); return; }
        const deck = decks.find(d => d.id === currentDeckId);
        if (deck) {
          deck.name = name;
          deck.subject = document.getElementById('deck-subject-input').value.trim();
          deck.cards = valid;
          saveDecks();
          showView('decks');
          document.querySelector('.nav-btn[data-view="decks"]').classList.add('active');
        }
      });

      document.getElementById('delete-deck-btn').addEventListener('click', () => {
        if (!confirm('Delete this deck? This cannot be undone.')) return;
        decks = decks.filter(d => d.id !== currentDeckId);
        saveDecks();
        showView('decks');
        document.querySelector('.nav-btn[data-view="decks"]').classList.add('active');
      });

      document.getElementById('editor-back').addEventListener('click', () => {
        showView('decks');
        document.querySelector('.nav-btn[data-view="decks"]').classList.add('active');
      });

      // ---- New Deck ----
      document.getElementById('new-deck-btn').addEventListener('click', () => {
        const newDeck = { id: uid(), name: 'New Deck', subject: '', cards: [] };
        decks.push(newDeck);
        saveDecks();
        openEditor(newDeck.id);
      });

      // ---- Import / Export ----
      document.getElementById('import-btn').addEventListener('click', () => {
        document.getElementById('import-input').click();
      });
      document.getElementById('import-input').addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
          try {
            const data = JSON.parse(ev.target.result);
            if (data.name && Array.isArray(data.cards)) {
              data.id = uid();
              data.cards = data.cards.map(c => ({ id: c.id || uid(), front: c.front || '', back: c.back || '', box: c.box || 0, next: c.next || 0 }));
              decks.push(data);
              saveDecks();
              renderDecks();
              alert('Deck "' + data.name + '" imported with ' + data.cards.length + ' cards.');
            } else { alert('Invalid file format.'); }
          } catch { alert('Could not parse JSON file.'); }
        };
        reader.readAsText(file);
        e.target.value = '';
      });

      document.getElementById('export-deck-btn').addEventListener('click', () => {
        const deck = decks.find(d => d.id === currentDeckId);
        if (!deck) return;
        const blob = new Blob([JSON.stringify(deck, null, 2)], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = deck.name.replace(/[^a-z0-9]/gi, '-').toLowerCase() + '.json';
        a.click();
        URL.revokeObjectURL(a.href);
      });

      // ---- Study Setup ----
      function renderStudySetup() {
        document.getElementById('study-setup').style.display = 'block';
        document.getElementById('study-session').style.display = 'none';
        document.getElementById('study-results').style.display = 'none';
        const list = document.getElementById('study-deck-list');
        const modeSelect = document.getElementById('mode-select');
        modeSelect.style.display = 'none';
        if (decks.length === 0) {
          list.innerHTML = '<p class="empty-msg">No decks available. Create or import a deck first.</p>';
          return;
        }
        list.innerHTML = decks.map(d => {
          const due = d.cards.filter(c => (c.next || 0) <= Date.now()).length;
          return '<button class="study-deck-btn' + (studyDeckId === d.id ? ' active' : '') + '" data-id="' + d.id + '">' +
            '<strong>' + esc(d.name) + '</strong> <span>' + due + ' due / ' + d.cards.length + ' total</span></button>';
        }).join('');
        list.querySelectorAll('.study-deck-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            list.querySelectorAll('.study-deck-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            studyDeckId = btn.dataset.id;
            modeSelect.style.display = 'block';
          });
        });
      }

      document.querySelectorAll('.mode-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          studyMode = btn.dataset.mode;
        });
      });

      // ---- Spaced Repetition (Leitner-style) ----
      // box 0: every session, box 1: after 1 session, box 2: after 3, box 3: after 7, box 4: after 14
      const intervals = [0, 60000, 180000, 420000, 840000]; // in ms (minutes-scale for demo)

      function buildStudyQueue(deck) {
        const now = Date.now();
        const due = deck.cards.filter(c => (c.next || 0) <= now);
        const notDue = deck.cards.filter(c => (c.next || 0) > now);
        // Prioritize due cards, shuffle them, and add some not-due if less than 10
        let queue = shuffle(due);
        if (queue.length < 10 && notDue.length > 0) {
          queue = queue.concat(shuffle(notDue).slice(0, 10 - queue.length));
        }
        return queue.slice(0, Math.max(10, queue.length));
      }

      function markCard(card, correct) {
        if (correct) {
          card.box = Math.min((card.box || 0) + 1, intervals.length - 1);
        } else {
          card.box = 0;
        }
        card.next = Date.now() + (intervals[card.box] || 0);
        // Persist to deck
        const deck = decks.find(d => d.id === studyDeckId);
        if (deck) {
          const c = deck.cards.find(x => x.id === card.id);
          if (c) { c.box = card.box; c.next = card.next; }
          saveDecks();
        }
      }

      // ---- Start Study ----
      document.getElementById('start-study-btn').addEventListener('click', () => {
        const deck = decks.find(d => d.id === studyDeckId);
        if (!deck || deck.cards.length === 0) { alert('This deck has no cards.'); return; }
        studyQueue = buildStudyQueue(deck);
        if (studyQueue.length === 0) { alert('No cards due for review. Try again later or add new cards.'); return; }
        studyIndex = 0;
        sessionCorrect = 0;
        sessionWrong = 0;
        sessionStreak = 0;
        sessionBestStreak = 0;
        flipped = false;
        document.getElementById('study-setup').style.display = 'none';
        document.getElementById('study-session').style.display = 'block';
        document.getElementById('study-results').style.display = 'none';
        showStudyCard();
      });

      function showStudyCard() {
        if (studyIndex >= studyQueue.length) { endStudySession(); return; }
        const card = studyQueue[studyIndex];
        document.getElementById('study-progress-text').textContent = (studyIndex + 1) + ' / ' + studyQueue.length;
        document.getElementById('progress-fill').style.width = ((studyIndex + 1) / studyQueue.length * 100) + '%';
        document.getElementById('study-correct').textContent = sessionCorrect;
        document.getElementById('study-wrong').textContent = sessionWrong;
        document.getElementById('study-streak').textContent = sessionStreak;

        document.getElementById('flip-area').style.display = 'none';
        document.getElementById('mc-area').style.display = 'none';
        document.getElementById('type-area').style.display = 'none';

        if (studyMode === 'flip') showFlipCard(card);
        else if (studyMode === 'mc') showMCCard(card);
        else showTypeCard(card);
      }

      // ---- Flip Mode ----
      function showFlipCard(card) {
        document.getElementById('flip-area').style.display = 'block';
        document.getElementById('flashcard-front').textContent = card.front;
        document.getElementById('flashcard-back').textContent = card.back;
        document.getElementById('flashcard-inner').classList.remove('flipped');
        document.getElementById('flip-hint').style.display = 'block';
        document.getElementById('flip-buttons').style.display = 'none';
        flipped = false;
      }

      document.getElementById('flashcard').addEventListener('click', () => {
        if (studyMode !== 'flip') return;
        const inner = document.getElementById('flashcard-inner');
        if (!flipped) {
          inner.classList.add('flipped');
          flipped = true;
          document.getElementById('flip-hint').style.display = 'none';
          document.getElementById('flip-buttons').style.display = 'flex';
        } else {
          inner.classList.remove('flipped');
          flipped = false;
          document.getElementById('flip-hint').style.display = 'block';
          document.getElementById('flip-buttons').style.display = 'none';
        }
      });

      document.getElementById('flip-right').addEventListener('click', (e) => {
        e.stopPropagation();
        recordAnswer(true);
      });
      document.getElementById('flip-wrong').addEventListener('click', (e) => {
        e.stopPropagation();
        recordAnswer(false);
      });

      // ---- Multiple Choice Mode ----
      function showMCCard(card) {
        document.getElementById('mc-area').style.display = 'block';
        document.getElementById('mc-question').textContent = card.front;
        document.getElementById('mc-next').style.display = 'none';
        const deck = decks.find(d => d.id === studyDeckId);
        const others = deck.cards.filter(c => c.id !== card.id).map(c => c.back);
        const wrong = shuffle(others).slice(0, 3);
        const options = shuffle([card.back, ...wrong]);
        const optionsEl = document.getElementById('mc-options');
        optionsEl.innerHTML = options.map(o =>
          '<button class="mc-option">' + esc(o) + '</button>'
        ).join('');
        optionsEl.querySelectorAll('.mc-option').forEach(btn => {
          btn.addEventListener('click', () => {
            const correct = btn.textContent === card.back;
            optionsEl.querySelectorAll('.mc-option').forEach(b => {
              b.disabled = true;
              if (b.textContent === card.back) b.classList.add('correct');
              else if (b === btn && !correct) b.classList.add('incorrect');
            });
            document.getElementById('mc-next').style.display = 'block';
            recordAnswer(correct, true);
          });
        });
      }

      document.getElementById('mc-next').addEventListener('click', () => {
        studyIndex++;
        showStudyCard();
      });

      // ---- Type Answer Mode ----
      function showTypeCard(card) {
        document.getElementById('type-area').style.display = 'block';
        document.getElementById('type-question').textContent = card.front;
        document.getElementById('type-input').value = '';
        document.getElementById('type-input').disabled = false;
        document.getElementById('type-feedback').style.display = 'none';
        document.getElementById('type-next').style.display = 'none';
        document.getElementById('type-submit').style.display = 'inline-block';
        document.getElementById('type-input').focus();
      }

      document.getElementById('type-submit').addEventListener('click', () => {
        const card = studyQueue[studyIndex];
        const input = document.getElementById('type-input').value.trim();
        if (!input) return;
        const correct = input.toLowerCase() === card.back.toLowerCase();
        const fb = document.getElementById('type-feedback');
        fb.style.display = 'block';
        fb.className = 'type-feedback ' + (correct ? 'fb-correct' : 'fb-incorrect');
        fb.textContent = correct ? 'Correct!' : 'Incorrect. Answer: ' + card.back;
        document.getElementById('type-input').disabled = true;
        document.getElementById('type-submit').style.display = 'none';
        document.getElementById('type-next').style.display = 'inline-block';
        recordAnswer(correct, true);
      });

      document.getElementById('type-input').addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          if (!document.getElementById('type-input').disabled) {
            document.getElementById('type-submit').click();
          } else {
            document.getElementById('type-next').click();
          }
        }
      });

      document.getElementById('type-next').addEventListener('click', () => {
        studyIndex++;
        showStudyCard();
      });

      // ---- Record Answer ----
      function recordAnswer(correct, deferAdvance) {
        const card = studyQueue[studyIndex];
        markCard(card, correct);
        if (correct) {
          sessionCorrect++;
          sessionStreak++;
          if (sessionStreak > sessionBestStreak) sessionBestStreak = sessionStreak;
          stats.totalCorrect++;
        } else {
          sessionWrong++;
          sessionStreak = 0;
          stats.totalWrong++;
        }
        stats.totalStudied++;
        if (sessionBestStreak > stats.bestStreak) stats.bestStreak = sessionBestStreak;
        saveStats();
        document.getElementById('study-correct').textContent = sessionCorrect;
        document.getElementById('study-wrong').textContent = sessionWrong;
        document.getElementById('study-streak').textContent = sessionStreak;
        if (!deferAdvance) {
          studyIndex++;
          showStudyCard();
        }
      }

      // ---- End Session ----
      function endStudySession() {
        stats.sessions++;
        saveStats();
        const total = sessionCorrect + sessionWrong;
        const accuracy = total > 0 ? Math.round((sessionCorrect / total) * 100) : 0;
        document.getElementById('sr-accuracy').textContent = accuracy + '%';
        document.getElementById('sr-studied').textContent = total;
        document.getElementById('sr-correct').textContent = sessionCorrect;
        document.getElementById('sr-best-streak').textContent = sessionBestStreak;
        document.getElementById('study-session').style.display = 'none';
        document.getElementById('study-results').style.display = 'block';
      }

      document.getElementById('study-again-btn').addEventListener('click', () => {
        document.getElementById('study-results').style.display = 'none';
        renderStudySetup();
      });
      document.getElementById('back-to-decks-btn').addEventListener('click', () => {
        showView('decks');
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        document.querySelector('.nav-btn[data-view="decks"]').classList.add('active');
      });

      // ---- Stats View ----
      function renderStats() {
        const totalCards = decks.reduce((sum, d) => sum + d.cards.length, 0);
        const total = stats.totalCorrect + stats.totalWrong;
        const accuracy = total > 0 ? Math.round((stats.totalCorrect / total) * 100) : 0;
        document.getElementById('stat-total-studied').textContent = stats.totalStudied;
        document.getElementById('stat-accuracy').textContent = accuracy + '%';
        document.getElementById('stat-streak').textContent = stats.bestStreak;
        document.getElementById('stat-sessions').textContent = stats.sessions;
        document.getElementById('stat-decks').textContent = decks.length;
        document.getElementById('stat-cards').textContent = totalCards;
      }

      document.getElementById('reset-stats-btn').addEventListener('click', () => {
        if (!confirm('Reset all study stats? Deck data will be preserved.')) return;
        stats = { totalStudied: 0, totalCorrect: 0, totalWrong: 0, bestStreak: 0, sessions: 0 };
        decks.forEach(d => d.cards.forEach(c => { c.box = 0; c.next = 0; }));
        saveStats();
        saveDecks();
        renderStats();
      });

      // ---- Init ----
      loadData();
      renderDecks();
    });
  </script>

