          {id:'s21',front:'Money',back:'Dinero',box:0,next:0},{id:'s22',front:'School',back:'Escuela',box:0,next:0},
          {id:'s23',front:'Work',back:'Trabajo',box:0,next:0},{id:'s24',front:'Family',back:'Familia',box:0,next:0},
          {id:'s25',front:'Man',back:'Hombre',box:0,next:0},{id:'s26',front:'Woman',back:'Mujer',box:0,next:0},
          {id:'s27',front:'Child',back:'Niño',box:0,next:0},{id:'s28',front:'Big',back:'Grande',box:0,next:0},
