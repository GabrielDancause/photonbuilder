---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Flashcard Study Tool",
  description: "Create and study flashcard decks with spaced repetition. Flip cards, multiple choice, type-answer modes, accuracy stats, and streak tracking.",
  category: "tool",
  published: "2026-03-21",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Flashcard Study Tool",
    "description": meta.description,
    "url": "https://sendnerds.photonbuilder.com/flashcard-maker",
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is spaced repetition and how does it work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Spaced repetition is a learning technique that shows you cards at increasing intervals based on how well you know them. Cards you get wrong appear more frequently so you practice weak spots, while cards you know well appear less often. This method is backed by decades of cognitive science research and can improve long-term retention by 200-400% compared to traditional studying."
        }
      },
      {
        "@type": "Question",
        "name": "How do I create effective flashcards?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Keep each card focused on one concept — avoid cramming multiple facts onto a single card. Use clear, concise language on the front (question side) and a brief, specific answer on the back. For vocabulary, include example sentences. For concepts, use your own words rather than copying definitions verbatim. Adding context and making personal connections to the material significantly improves recall."
        }
      },
      {
        "@type": "Question",
        "name": "Can I import or export my flashcard decks?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You can export any deck as a JSON file to back up your work or share it with others. To import, click the Import button and select a previously exported JSON file. The tool validates the file format and merges the deck into your collection. All card progress data (repetition intervals, accuracy) is preserved during export and import."
        }
      },
      {
        "@type": "Question",
        "name": "What study modes are available?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Three study modes are available: Flip Card mode shows you the front of a card and you mentally recall the answer before flipping to check. Multiple Choice mode presents four options and you select the correct answer. Type Answer mode requires you to type the answer, which provides the strongest memory reinforcement. Each mode tracks your accuracy and streak separately."
        }
      },
      {
        "@type": "Question",
        "name": "Is my data saved between sessions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All your decks, cards, and study progress are stored in your browser's localStorage. Your data persists between sessions on the same browser and device. No account or internet connection is needed. For permanent backup, use the export feature to save your decks as JSON files that you can re-import at any time on any device."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="sendnerds"
  title={meta.title}
  description={meta.description}
  canonical="https://sendnerds.photonbuilder.com/flashcard-maker"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      🧠 <strong style="color:#3B82F6;">Spaced repetition boosts retention by 200%.</strong> With med school GPA requirements at 3.73 and DOJ scrutiny on admissions, every point matters. Study smarter, not harder. <a href="https://gab.ae/news/trump-medical-school-admissions-investigation-2026" style="color:#3B82F6;">Why grades matter more now →</a>
    </div>
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      🧠 <strong style="color:#3B82F6;">Spaced repetition improves retention by 200% vs re-reading.</strong> With med school admission under federal scrutiny, every exam score matters. This tool uses proven memory science — flip, type, or quiz mode. <a href="https://gab.ae/news/trump-medical-school-admissions-investigation-2026" style="color:#3B82F6;">Why academic performance counts →</a>
    </div>
    <div class="hero">
      <h1>Flashcard Study Tool</h1>
      <p class="subtitle">Create custom flashcard decks, study with spaced repetition, and track your progress. Choose flip, multiple choice, or type-answer mode.</p>
    </div>

    <div class="app-container" id="app">
      <!-- Top Nav -->
      <div class="top-nav">
        <button class="nav-btn active" data-view="decks">My Decks</button>
        <button class="nav-btn" data-view="study">Study</button>
        <button class="nav-btn" data-view="stats">Stats</button>
      </div>

      <!-- Decks View -->
      <div class="view" id="view-decks">
        <div class="deck-actions">
          <button class="action-btn primary-btn" id="new-deck-btn">+ New Deck</button>
          <button class="action-btn" id="import-btn">Import JSON</button>
          <input type="file" id="import-input" accept=".json" style="display:none">
        </div>
        <div class="deck-grid" id="deck-grid"></div>
      </div>

      <!-- Deck Editor (hidden) -->
      <div class="view" id="view-editor" style="display:none">
        <div class="editor-header">
          <button class="back-btn" id="editor-back">&larr; Back</button>
          <h2 id="editor-title">Edit Deck</h2>
        </div>
        <div class="editor-form">
          <div class="form-row">
            <label>Deck Name</label>
            <input type="text" id="deck-name-input" placeholder="e.g. Spanish Vocabulary">
          </div>
          <div class="form-row">
            <label>Subject</label>
            <input type="text" id="deck-subject-input" placeholder="e.g. Languages">
          </div>
        </div>
        <div class="cards-header">
          <h3>Cards (<span id="card-count">0</span>)</h3>
          <button class="action-btn primary-btn" id="add-card-btn">+ Add Card</button>
        </div>
        <div class="card-list" id="card-list"></div>
        <div class="editor-footer">
          <button class="action-btn primary-btn" id="save-deck-btn">Save Deck</button>
          <button class="action-btn" id="export-deck-btn">Export JSON</button>
          <button class="action-btn danger-btn" id="delete-deck-btn">Delete Deck</button>
        </div>
      </div>

      <!-- Study View (hidden) -->
      <div class="view" id="view-study" style="display:none">
        <div class="study-setup" id="study-setup">
          <h2>Choose a Deck to Study</h2>
          <div class="study-deck-list" id="study-deck-list"></div>
          <div class="mode-select" id="mode-select" style="display:none">
            <h3>Study Mode</h3>
            <div class="btn-group">
              <button class="mode-btn active" data-mode="flip">Flip Card</button>
              <button class="mode-btn" data-mode="mc">Multiple Choice</button>
              <button class="mode-btn" data-mode="type">Type Answer</button>
            </div>
            <button class="action-btn primary-btn start-study-btn" id="start-study-btn">Start Studying</button>
          </div>
        </div>

        <div class="study-session" id="study-session" style="display:none">
          <div class="study-progress">
            <span id="study-progress-text">1 / 10</span>
            <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
          </div>
          <div class="study-stats-bar">
            <span>Correct: <strong id="study-correct">0</strong></span>
            <span>Wrong: <strong id="study-wrong">0</strong></span>
            <span>Streak: <strong id="study-streak">0</strong></span>
          </div>

          <!-- Flip mode -->
          <div class="study-card-area" id="flip-area" style="display:none">
            <div class="flashcard" id="flashcard">
              <div class="flashcard-inner" id="flashcard-inner">
                <div class="flashcard-front" id="flashcard-front"></div>
                <div class="flashcard-back" id="flashcard-back"></div>
              </div>
            </div>
            <p class="flip-hint" id="flip-hint">Click the card to flip</p>
            <div class="flip-buttons" id="flip-buttons" style="display:none">
              <button class="action-btn danger-btn" id="flip-wrong">Got it Wrong</button>
              <button class="action-btn success-btn" id="flip-right">Got it Right</button>
            </div>
          </div>

          <!-- MC mode -->
          <div class="study-card-area" id="mc-area" style="display:none">
            <div class="mc-question" id="mc-question"></div>
            <div class="mc-options" id="mc-options"></div>
            <button class="action-btn primary-btn mc-next" id="mc-next" style="display:none">Next</button>
          </div>

          <!-- Type mode -->
          <div class="study-card-area" id="type-area" style="display:none">
            <div class="type-question" id="type-question"></div>
            <input type="text" id="type-input" class="type-input" placeholder="Type your answer..." autocomplete="off">
            <button class="action-btn primary-btn" id="type-submit">Check</button>
            <div class="type-feedback" id="type-feedback" style="display:none"></div>
            <button class="action-btn primary-btn type-next" id="type-next" style="display:none">Next</button>
          </div>
        </div>

        <!-- Study Results -->
        <div class="study-results" id="study-results" style="display:none">
          <h2>Session Complete</h2>
          <div class="results-grid">
            <div class="result-card primary-card">
              <span class="rc-value" id="sr-accuracy">0%</span>
              <span class="rc-label">Accuracy</span>
            </div>
            <div class="result-card">
              <span class="rc-value" id="sr-studied">0</span>
              <span class="rc-label">Cards Studied</span>
            </div>
            <div class="result-card">
              <span class="rc-value" id="sr-correct">0</span>
              <span class="rc-label">Correct</span>
            </div>
            <div class="result-card">
              <span class="rc-value" id="sr-best-streak">0</span>
              <span class="rc-label">Best Streak</span>
            </div>
          </div>
          <div class="results-actions">
            <button class="action-btn primary-btn" id="study-again-btn">Study Again</button>
            <button class="action-btn" id="back-to-decks-btn">Back to Decks</button>
          </div>
        </div>
      </div>

      <!-- Stats View (hidden) -->
      <div class="view" id="view-stats" style="display:none">
        <h2>Your Study Stats</h2>
        <div class="results-grid" id="global-stats">
          <div class="result-card primary-card">
            <span class="rc-value" id="stat-total-studied">0</span>
            <span class="rc-label">Total Cards Studied</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="stat-accuracy">0%</span>
            <span class="rc-label">Overall Accuracy</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="stat-streak">0</span>
            <span class="rc-label">Best Streak</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="stat-sessions">0</span>
            <span class="rc-label">Sessions</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="stat-decks">0</span>
            <span class="rc-label">Decks</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="stat-cards">0</span>
            <span class="rc-label">Total Cards</span>
          </div>
        </div>
        <div class="stats-reset">
          <button class="action-btn danger-btn" id="reset-stats-btn">Reset All Stats</button>
        </div>
      </div>
    </div>

    <!-- Explainer -->
    <div class="explainer">
      <h2>The Science Behind Flashcard Study</h2>
      <p>Flashcards are one of the most effective study tools available, backed by decades of cognitive science research. When combined with spaced repetition — a technique that times your reviews based on how well you know each card — flashcards can dramatically improve long-term retention of any subject matter.</p>

      <h3>Why Flashcards Work</h3>
      <p>Flashcards leverage active recall, which forces your brain to retrieve information rather than passively re-read it. Studies show that active recall strengthens neural pathways far more effectively than highlighting or re-reading notes. Each time you successfully recall a fact, the memory trace becomes stronger and more durable.</p>

      <h3>Spaced Repetition Explained</h3>
      <p>The spacing effect, first documented by Hermann Ebbinghaus in 1885, shows that we retain information better when study sessions are spaced out over time. Our tool implements this by tracking how well you know each card. Cards you struggle with appear more frequently, while cards you have mastered are shown at increasing intervals. This optimizes your study time by focusing effort where it is needed most.</p>

      <h3>Choosing the Right Study Mode</h3>
      <p>Flip card mode is ideal for initial learning and quick review — you see the question, mentally recall the answer, then flip to check. Multiple choice mode adds contextual learning by presenting related options, helping you distinguish between similar concepts. Type answer mode provides the deepest encoding by requiring you to produce the answer from memory, which research shows creates the strongest long-term retention.</p>

      <h3>Tips for Effective Flashcard Study</h3>
      <p>Keep cards atomic — one fact per card. Write questions that require recall, not recognition. Study in short daily sessions rather than long cramming periods. Use the spaced repetition scheduling to let the algorithm optimize your review timing. Mix subjects within a study session to improve contextual learning and prevent interference effects.</p>

      <h3>Related Tools</h3>
      <p>Preparing for a timed exam? Sharpen your speed with our <a href="/typing-speed-test">Typing Speed Test</a>. Need to calculate your course grades? Try our <a href="/grade-calculator">Grade Calculator</a> for weighted averages and GPA conversion.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map(faq => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

