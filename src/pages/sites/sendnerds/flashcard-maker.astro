          {id:'s49',front:'Why?',back:'¿Por qué?',box:0,next:0},{id:'s50',front:'What?',back:'¿Qué?',box:0,next:0}
        ]
      };

      const defaultCapitals = {
        id: 'us-capitals',
        name: 'US State Capitals',
        subject: 'Geography',
        cards: [
          {id:'c1',front:'Alabama',back:'Montgomery',box:0,next:0},{id:'c2',front:'Alaska',back:'Juneau',box:0,next:0},
