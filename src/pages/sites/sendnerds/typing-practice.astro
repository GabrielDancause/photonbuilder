---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Typing Practice",
  description: "Practice typing with structured lessons for home row, top row, bottom row, numbers, common words, sentences, and code snippets. Track accuracy, WPM, personal records, and daily practice streaks with a visual keyboard guide.",
  category: "tool",
  published: "2026-03-21",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Typing Practice",
    "description": meta.description,
    "url": "https://sendnerds.photonbuilder.com/typing-practice",
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long should I practice typing each day?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Consistent daily practice of 15 to 20 minutes is more effective than occasional long sessions. Short, focused sessions build muscle memory faster because your brain consolidates motor skills during breaks. Start with 10 minutes if you are a beginner and increase gradually. Most typists see measurable improvement within two weeks of daily practice."
        }
      },
      {
        "@type": "Question",
        "name": "What is the home row and why is it important?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The home row consists of the keys A, S, D, F for the left hand and J, K, L, semicolon for the right hand. It is the resting position for touch typing. Every other key is reached by moving a finger from its home row position and returning it afterward. Mastering the home row first builds the foundation for accurate touch typing because it trains your fingers to always return to a known starting position."
        }
      },
      {
        "@type": "Question",
        "name": "Should I focus on accuracy or speed when practicing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Always prioritize accuracy over speed. Typing fast with many errors actually slows you down because corrections take extra keystrokes. Aim for 97 percent accuracy or higher before trying to increase speed. Once accuracy is consistent, speed naturally improves as your muscle memory strengthens. Practicing slowly and correctly trains your fingers to hit the right keys automatically."
        }
      },
      {
        "@type": "Question",
        "name": "Which fingers should press which keys?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Each finger is responsible for a vertical column of keys. The left pinky covers Q, A, Z and modifier keys. The left ring finger covers W, S, X. The left middle finger covers E, D, C. The left index finger covers R, F, V and T, G, B. The right index finger covers Y, H, N and U, J, M. The right middle finger covers I, K, comma. The right ring finger covers O, L, period. The right pinky covers P, semicolon, slash, and modifier keys. Both thumbs share the space bar."
        }
      },
      {
        "@type": "Question",
        "name": "How do I maintain a daily practice streak?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Set a specific time each day for practice, such as first thing in the morning or during a lunch break. Even completing one short lesson counts toward your streak. Our tool tracks your streak automatically using your browser storage, so just open the page and complete at least one lesson each day. Streaks build consistency, which is the most important factor in improving typing speed."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="sendnerds"
  title={meta.title}
  description={meta.description}
  canonical="https://sendnerds.photonbuilder.com/typing-practice"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Typing Practice</h1>
      <p class="subtitle">Structured lessons to build speed and accuracy. Master each key group, track your progress, and build a daily streak.</p>
    </div>

    <!-- Streak & Stats Bar -->
    <div class="streak-bar">
      <div class="streak-item">
        <span class="streak-icon">&#9889;</span>
        <span class="streak-value" id="streak-count">0</span>
        <span class="streak-label">Day Streak</span>
      </div>
      <div class="streak-item">
        <span class="streak-value" id="lessons-completed">0</span>
        <span class="streak-label">Lessons Done</span>
      </div>
      <div class="streak-item">
        <span class="streak-value" id="avg-accuracy">—</span>
        <span class="streak-label">Avg Accuracy</span>
      </div>
    </div>

    <div class="practice-container">
      <!-- Lesson Selector -->
      <div class="lesson-selector">
        <label>Lesson</label>
        <div class="btn-group" id="lesson-btns">
          <button data-lesson="home-row" class="active">Home Row</button>
          <button data-lesson="top-row">Top Row</button>
          <button data-lesson="bottom-row">Bottom Row</button>
          <button data-lesson="numbers">Numbers</button>
          <button data-lesson="common-words">Common Words</button>
          <button data-lesson="sentences">Sentences</button>
          <button data-lesson="code">Code Snippets</button>
        </div>
      </div>

      <!-- Live Stats -->
      <div class="live-stats" id="live-stats">
        <div class="stat-item">
          <span class="stat-value" id="live-wpm">0</span>
          <span class="stat-label">WPM</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="live-accuracy">100</span>
          <span class="stat-label">Accuracy %</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="live-progress">0</span>
          <span class="stat-label">Progress %</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="live-errors">0</span>
          <span class="stat-label">Errors</span>
        </div>
      </div>

      <!-- Progress Bar -->
      <div class="progress-track">
        <div class="progress-fill" id="progress-fill"></div>
      </div>

      <!-- Text Display -->
      <div class="text-display" id="text-display"></div>

      <!-- Input -->
      <input type="text" id="typing-input" class="typing-input" placeholder="Start typing here..." autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">

      <!-- Controls -->
      <div class="controls">
        <button id="restart-btn" class="action-btn">Restart Lesson</button>
        <button id="next-btn" class="action-btn">Next Lesson</button>
      </div>

      <!-- Visual Keyboard -->
      <div class="keyboard-wrap">
        <div class="keyboard" id="keyboard">
          <div class="kb-row">
            <div class="key pinky-l" data-key="`">`</div>
            <div class="key pinky-l" data-key="1">1</div>
            <div class="key ring-l" data-key="2">2</div>
            <div class="key middle-l" data-key="3">3</div>
            <div class="key index-l" data-key="4">4</div>
            <div class="key index-l" data-key="5">5</div>
            <div class="key index-r" data-key="6">6</div>
            <div class="key index-r" data-key="7">7</div>
            <div class="key middle-r" data-key="8">8</div>
            <div class="key ring-r" data-key="9">9</div>
            <div class="key pinky-r" data-key="0">0</div>
            <div class="key pinky-r" data-key="-">-</div>
            <div class="key pinky-r" data-key="=">=</div>
          </div>
          <div class="kb-row">
            <div class="key pinky-l" data-key="q">Q</div>
            <div class="key ring-l" data-key="w">W</div>
            <div class="key middle-l" data-key="e">E</div>
            <div class="key index-l" data-key="r">R</div>
            <div class="key index-l" data-key="t">T</div>
            <div class="key index-r" data-key="y">Y</div>
            <div class="key index-r" data-key="u">U</div>
            <div class="key middle-r" data-key="i">I</div>
            <div class="key ring-r" data-key="o">O</div>
            <div class="key pinky-r" data-key="p">P</div>
            <div class="key pinky-r" data-key="[">[</div>
            <div class="key pinky-r" data-key="]">]</div>
            <div class="key pinky-r" data-key="\">\</div>
          </div>
          <div class="kb-row">
            <div class="key pinky-l home" data-key="a">A</div>
            <div class="key ring-l home" data-key="s">S</div>
            <div class="key middle-l home" data-key="d">D</div>
            <div class="key index-l home" data-key="f">F</div>
            <div class="key index-l" data-key="g">G</div>
            <div class="key index-r" data-key="h">H</div>
            <div class="key index-r home" data-key="j">J</div>
            <div class="key middle-r home" data-key="k">K</div>
            <div class="key ring-r home" data-key="l">L</div>
            <div class="key pinky-r home" data-key=";">;</div>
            <div class="key pinky-r" data-key="'">'</div>
          </div>
          <div class="kb-row">
            <div class="key pinky-l" data-key="z">Z</div>
            <div class="key ring-l" data-key="x">X</div>
            <div class="key middle-l" data-key="c">C</div>
            <div class="key index-l" data-key="v">V</div>
            <div class="key index-l" data-key="b">B</div>
            <div class="key index-r" data-key="n">N</div>
            <div class="key index-r" data-key="m">M</div>
            <div class="key middle-r" data-key=",">,</div>
            <div class="key ring-r" data-key=".">.</div>
            <div class="key pinky-r" data-key="/">/</div>
          </div>
          <div class="kb-row">
            <div class="key space thumb" data-key=" ">Space</div>
          </div>
        </div>
        <div class="finger-legend">
          <span class="legend-dot pinky-l"></span> Pinky
          <span class="legend-dot ring-l"></span> Ring
          <span class="legend-dot middle-l"></span> Middle
          <span class="legend-dot index-l"></span> Index L
          <span class="legend-dot index-r"></span> Index R
          <span class="legend-dot middle-r"></span> Middle R
          <span class="legend-dot ring-r"></span> Ring R
          <span class="legend-dot pinky-r"></span> Pinky R
        </div>
      </div>

      <!-- Results Panel (hidden until lesson complete) -->
      <div class="results-panel" id="results-panel" style="display:none">
        <h2>Lesson Complete</h2>
        <div class="results-grid">
          <div class="result-card primary-card">
            <span class="rc-value" id="res-wpm">0</span>
            <span class="rc-label">WPM (Net)</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-accuracy">0%</span>
            <span class="rc-label">Accuracy</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-errors">0</span>
            <span class="rc-label">Errors</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-time">0s</span>
            <span class="rc-label">Time</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-pb">—</span>
            <span class="rc-label">Personal Best</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-streak">0</span>
            <span class="rc-label">Day Streak</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Explainer -->
    <div class="explainer">
      <h2>How Typing Practice Works</h2>
      <p>Typing practice is different from a typing test. While a speed test measures your current ability, structured practice is designed to systematically improve it. Each lesson targets a specific group of keys so your fingers build muscle memory for every region of the keyboard before combining them into full words and sentences.</p>

      <h3>Start With the Home Row</h3>
      <p>The home row keys — A, S, D, F, J, K, L, and semicolon — are where your fingers rest between keystrokes. Every touch-typing technique begins here. Practice these keys until you can type them without looking at the keyboard. The visual keyboard below the input highlights which finger should press each key, helping you develop correct habits from the start.</p>

      <h3>Layer in Top and Bottom Rows</h3>
      <p>Once the home row feels automatic, add the top row (Q through P) and bottom row (Z through slash). Each new row is a small extension from the home position. Your fingers learn to reach up or down and return to home position. Drilling these rows separately before mixing them builds cleaner motor patterns than jumping straight to full text.</p>

      <h3>Numbers and Special Characters</h3>
      <p>The number row is the weakest zone for most typists because it requires the longest finger reach. Dedicated number drills fix this gap. For programmers, comfort with brackets, semicolons, and operators is essential — the code snippets lesson targets these characters specifically.</p>

      <h3>Building Speed With Words and Sentences</h3>
      <p>After individual key groups are comfortable, common words and full sentences develop speed and flow. Common English words make up the majority of everyday typing, so drilling them creates the largest real-world speed gain. Sentence practice adds capitalization, punctuation, and natural rhythm.</p>

      <h3>Track Your Progress</h3>
      <p>Personal records are saved per lesson so you can see improvement over time. The daily streak counter encourages consistency — the single most important factor in building typing speed. Even one completed lesson per day keeps your streak alive.</p>

      <h3>Related Tools</h3>
      <p>Ready to benchmark your progress? Try our <a href="/sendnerds/typing-speed-test">Typing Speed Test</a> to measure your WPM. Working on school assignments? Our <a href="/sendnerds/citation-generator">Citation Generator</a> formats your sources automatically.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map(faq => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // ---- Lesson Text Banks ----
      const lessons = {
        'home-row': [
          "asdf jkl; asdf jkl; fjdk sl;a fjdk sl;a dksl afj; dksl afj;",
          "fall lads fads jaks salad flask half dask fall flask salad lads",
          "ask all fall sad lad flask dad add fad hall lasslass flask ask",
          "alas fall dad flask add lad sad lass ask hall all fad salad dad"
        ],
        'top-row': [
          "we were pier rope wire quite type your tower power equity writer",
          "report tower quote worry query optic trip equip pewter require rip",
          "require quote upper type power tower worry trip report equity rip",
          "quiet pew rut yet rip tip wet wit ire ore yew rue out pie tie"
        ],
        'bottom-row': [
          "vim ban comb van zinc bomb next cab zing vim cabin box vex nab",
          "mix van box comb zinc cabin vim next zing ban cab vex nab bomb",
          "zinc mix box van nab comb next zing vim cabin ban cab bomb vex",
          "van comb cabin zinc vim box next zing mix ban cab nab vex bomb"
        ],
        'numbers': [
          "192 384 576 768 1024 2048 4096 8192 100 200 300 400 500 600 700 800 900",
          "12 + 7 = 19 and 45 - 18 = 27 then 8 * 6 = 48 next 144 / 12 = 12",
          "phone: 555-0123 zip: 90210 pin: 1234 year: 2026 score: 98.6 port: 8080",
          "3.14 2.71 1.61 9.81 6.02 1.38 2.99 0.69 42 256 1024 65536 128 512"
        ],
        'common-words': [
          "the be to of and a in that have i it for not on with he as you do at this but his by from they we say her she or an will my one all would there their what so up out if about who get which go me when make can like time no just him know take people into year your good some could them see other than then now look only come its over think also back after use two how our work first well way even new want because any these give day most us",
          "about after again air all along also another any around as at away back be because been before began below between both but came can come could day did different do does each end even every few find first for from get give go going good great had has have help here him his home house how if in into is just know large last left let life like line little long look made make man many may me more most much must name never new next no not now number of off old on one only or other our out over own part people place point"
        ],
        'sentences': [
          "The quick brown fox jumps over the lazy dog. Pack my box with five dozen liquor jugs. How vexingly quick daft zebras jump.",
          "She sells seashells by the seashore. The shells she sells are seashells for sure. Peter Piper picked a peck of pickled peppers.",
          "A journey of a thousand miles begins with a single step. Actions speak louder than words. Practice makes progress, not perfection.",
          "The five boxing wizards jump quickly. Sphinx of black quartz, judge my vow. Two driven jocks help fax my big quiz."
        ],
        'code': [
          "function fibonacci(n) { if (n <= 1) return n; return fibonacci(n - 1) + fibonacci(n - 2); }",
          "const fetchData = async (url) => { const res = await fetch(url); return res.json(); };",
          "for (let i = 0; i < arr.length; i++) { if (arr[i] === target) return i; } return -1;",
          "class Node { constructor(val) { this.val = val; this.next = null; } }",
          "const map = new Map(); arr.forEach(x => map.set(x, (map.get(x) || 0) + 1));",
          "if (left <= right) { const mid = Math.floor((left + right) / 2); }"
        ]
      };

      // ---- Finger map for keyboard highlighting ----
      const fingerMap = {
        '`':'pinky-l','1':'pinky-l','2':'ring-l','3':'middle-l','4':'index-l','5':'index-l',
        '6':'index-r','7':'index-r','8':'middle-r','9':'ring-r','0':'pinky-r','-':'pinky-r','=':'pinky-r',
        'q':'pinky-l','w':'ring-l','e':'middle-l','r':'index-l','t':'index-l',
        'y':'index-r','u':'index-r','i':'middle-r','o':'ring-r','p':'pinky-r','[':'pinky-r',']':'pinky-r','\\':'pinky-r',
        'a':'pinky-l','s':'ring-l','d':'middle-l','f':'index-l','g':'index-l',
        'h':'index-r','j':'index-r','k':'middle-r','l':'ring-r',';':'pinky-r','\'':'pinky-r',
        'z':'pinky-l','x':'ring-l','c':'middle-l','v':'index-l','b':'index-l',
        'n':'index-r','m':'index-r',',':'middle-r','.':'ring-r','/':'pinky-r',
        ' ':'thumb'
      };

      // ---- State ----
      let currentLesson = 'home-row';
      let lessonText = '';
      let charIndex = 0;
      let errors = 0;
      let totalCharsTyped = 0;
      let correctChars = 0;
      let started = false;
      let finished = false;
      let startTime = 0;

      // ---- DOM ----
      const textDisplay = document.getElementById('text-display');
      const typingInput = document.getElementById('typing-input');
      const liveWpm = document.getElementById('live-wpm');
      const liveAccuracy = document.getElementById('live-accuracy');
      const liveProgress = document.getElementById('live-progress');
      const liveErrors = document.getElementById('live-errors');
      const progressFill = document.getElementById('progress-fill');
      const resultsPanel = document.getElementById('results-panel');
      const restartBtn = document.getElementById('restart-btn');
      const nextBtn = document.getElementById('next-btn');
      const keyboard = document.getElementById('keyboard');
      const streakCountEl = document.getElementById('streak-count');
      const lessonsCompletedEl = document.getElementById('lessons-completed');
      const avgAccuracyEl = document.getElementById('avg-accuracy');

      // ---- Streak & Stats (localStorage) ----
      function getStreakData() {
        try {
          return JSON.parse(localStorage.getItem('tp-streak') || '{}');
        } catch { return {}; }
      }

      function updateStreak() {
        const data = getStreakData();
        const today = new Date().toISOString().slice(0, 10);
        const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);

        if (!data.lastDate) {
          data.streak = 1;
          data.lastDate = today;
        } else if (data.lastDate === today) {
          // already practiced today
        } else if (data.lastDate === yesterday) {
          data.streak = (data.streak || 0) + 1;
          data.lastDate = today;
        } else {
          data.streak = 1;
          data.lastDate = today;
        }
        data.totalLessons = (data.totalLessons || 0) + 1;
        localStorage.setItem('tp-streak', JSON.stringify(data));
        displayStreakStats();
      }

      function displayStreakStats() {
        const data = getStreakData();
        const today = new Date().toISOString().slice(0, 10);
        const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
        let streak = data.streak || 0;
        if (data.lastDate && data.lastDate !== today && data.lastDate !== yesterday) {
          streak = 0;
        }
        streakCountEl.textContent = streak;
        lessonsCompletedEl.textContent = data.totalLessons || 0;

        // Average accuracy from recent records
        let accSum = 0, accCount = 0;
        const lessonKeys = ['home-row','top-row','bottom-row','numbers','common-words','sentences','code'];
        lessonKeys.forEach(k => {
          const rec = localStorage.getItem('tp-pb-' + k);
          if (rec) {
            try {
              const r = JSON.parse(rec);
              if (r.accuracy) { accSum += r.accuracy; accCount++; }
            } catch {}
          }
        });
        avgAccuracyEl.textContent = accCount > 0 ? Math.round(accSum / accCount) + '%' : '—';
      }

      // ---- Lesson Buttons ----
      document.querySelectorAll('#lesson-btns button').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#lesson-btns button').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentLesson = btn.dataset.lesson;
          resetLesson();
        });
      });

      // ---- Text Generation ----
      function generateLessonText() {
        const bank = lessons[currentLesson];
        const chosen = bank[Math.floor(Math.random() * bank.length)];
        if (currentLesson === 'home-row' || currentLesson === 'top-row' || currentLesson === 'bottom-row') {
          // Shuffle words for variety
          const words = chosen.split(/\s+/);
          for (let i = words.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [words[i], words[j]] = [words[j], words[i]];
          }
          // Repeat to get ~60 words
          const result = [];
          while (result.length < 60) result.push(...words);
          return result.slice(0, 60).join(' ');
        }
        if (currentLesson === 'common-words') {
          const words = chosen.split(/\s+/);
          for (let i = words.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [words[i], words[j]] = [words[j], words[i]];
          }
          return words.slice(0, 80).join(' ');
        }
        // For sentences, code, numbers — concatenate a couple
        const shuffled = [...bank].sort(() => Math.random() - 0.5);
        return shuffled.slice(0, 2).join(' ');
      }

      function renderText() {
        textDisplay.innerHTML = '';
        for (let i = 0; i < lessonText.length; i++) {
          const span = document.createElement('span');
          span.textContent = lessonText[i];
          span.className = 'char';
          if (i === 0) span.classList.add('current');
          textDisplay.appendChild(span);
        }
        highlightKey(lessonText[0]);
      }

      // ---- Keyboard Highlighting ----
      function highlightKey(char) {
        keyboard.querySelectorAll('.key').forEach(k => k.classList.remove('active-key'));
        if (!char) return;
        const lower = char.toLowerCase();
        const keyEl = keyboard.querySelector('[data-key="' + CSS.escape(lower) + '"]');
        if (keyEl) keyEl.classList.add('active-key');
      }

      // ---- Reset ----
      function resetLesson() {
        started = false;
        finished = false;
        charIndex = 0;
        errors = 0;
        totalCharsTyped = 0;
        correctChars = 0;
        startTime = 0;
        lessonText = generateLessonText();
        renderText();
        typingInput.value = '';
        typingInput.disabled = false;
        liveWpm.textContent = '0';
        liveAccuracy.textContent = '100';
        liveProgress.textContent = '0';
        liveErrors.textContent = '0';
        progressFill.style.width = '0%';
        resultsPanel.style.display = 'none';
        typingInput.focus();
      }

      // ---- Live WPM updater ----
      let wpmInterval = null;
      function startWpmUpdater() {
        wpmInterval = setInterval(() => {
          if (!started || finished) return;
          const elapsed = (Date.now() - startTime) / 1000;
          const minutes = elapsed / 60;
          if (minutes > 0) {
            liveWpm.textContent = Math.round((correctChars / 5) / minutes);
          }
        }, 500);
      }

      // ---- Typing Handler ----
      typingInput.addEventListener('input', () => {
        if (finished) return;
        if (!started) {
          started = true;
          startTime = Date.now();
          startWpmUpdater();
        }

        const inputVal = typingInput.value;
        const chars = textDisplay.querySelectorAll('.char');
        const typed = inputVal[inputVal.length - 1];

        if (charIndex < lessonText.length && typed !== undefined) {
          totalCharsTyped++;
          if (typed === lessonText[charIndex]) {
            chars[charIndex].classList.add('correct');
            chars[charIndex].classList.remove('current');
            correctChars++;
            charIndex++;
          } else {
            chars[charIndex].classList.add('incorrect');
            chars[charIndex].classList.remove('current');
            errors++;
            charIndex++;
          }

          // Mark next char as current
          if (charIndex < lessonText.length) {
            chars[charIndex].classList.add('current');
            highlightKey(lessonText[charIndex]);
            // Auto-scroll
            const currentChar = chars[charIndex];
            const displayRect = textDisplay.getBoundingClientRect();
            const charRect = currentChar.getBoundingClientRect();
            if (charRect.top > displayRect.top + displayRect.height - 40) {
              textDisplay.scrollTop += charRect.height * 2;
            }
          }

          // Update live stats
          if (totalCharsTyped > 0) {
            liveAccuracy.textContent = Math.round((correctChars / totalCharsTyped) * 100);
          }
          liveErrors.textContent = errors;
          const pct = Math.round((charIndex / lessonText.length) * 100);
          liveProgress.textContent = pct;
          progressFill.style.width = pct + '%';

          typingInput.value = '';

          if (charIndex >= lessonText.length) {
            endLesson();
          }
        }
      });

      typingInput.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace') e.preventDefault();
        if (e.key === 'Tab') {
          e.preventDefault();
          resetLesson();
        }
      });

      // ---- End Lesson ----
      function endLesson() {
        clearInterval(wpmInterval);
        finished = true;
        typingInput.disabled = true;
        highlightKey(null);

        const elapsed = (Date.now() - startTime) / 1000;
        const minutes = elapsed / 60;
        const netWpm = minutes > 0 ? Math.max(0, Math.round((correctChars / 5) / minutes)) : 0;
        const accuracy = totalCharsTyped > 0 ? Math.round((correctChars / totalCharsTyped) * 100) : 0;

        document.getElementById('res-wpm').textContent = netWpm;
        document.getElementById('res-accuracy').textContent = accuracy + '%';
        document.getElementById('res-errors').textContent = errors;
        document.getElementById('res-time').textContent = Math.round(elapsed) + 's';

        // Personal best
        const pbKey = 'tp-pb-' + currentLesson;
        let current;
        try { current = JSON.parse(localStorage.getItem(pbKey) || '{}'); } catch { current = {}; }
        let pbText = (current.wpm || 0) + ' WPM';
        if (netWpm > (current.wpm || 0)) {
          localStorage.setItem(pbKey, JSON.stringify({ wpm: netWpm, accuracy: accuracy }));
          pbText = netWpm + ' WPM (New!)';
        }
        document.getElementById('res-pb').textContent = pbText;

        // Update streak
        updateStreak();
        document.getElementById('res-streak').textContent = getStreakData().streak || 0;

        resultsPanel.style.display = 'block';
        resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // ---- Controls ----
      restartBtn.addEventListener('click', resetLesson);
      nextBtn.addEventListener('click', () => {
        const btns = Array.from(document.querySelectorAll('#lesson-btns button'));
        const idx = btns.findIndex(b => b.classList.contains('active'));
        const nextIdx = (idx + 1) % btns.length;
        btns.forEach(b => b.classList.remove('active'));
        btns[nextIdx].classList.add('active');
        currentLesson = btns[nextIdx].dataset.lesson;
        resetLesson();
      });

      textDisplay.addEventListener('click', () => {
        if (!finished) typingInput.focus();
      });

      // ---- Init ----
      displayStreakStats();
      resetLesson();
    });
  </script>

