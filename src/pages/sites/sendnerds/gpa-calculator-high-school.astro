      line-height: 1.6;
      margin: 0;
    }
  </style>

  <script is:inline>
    (function() {
      // DOM Elements
      const classesList = document.getElementById('classes-list');
      const btnAddClass = document.getElementById('btn-add-class');
      const btnClear = document.getElementById('btn-clear');

      // Prior Inputs
      const inputPriorUnweighted = document.getElementById('prior-unweighted');
      const inputPriorWeighted = document.getElementById('prior-weighted');
      const inputPriorCredits = document.getElementById('prior-credits');

      // Results
      const resSemesterUnweighted = document.getElementById('res-semester-unweighted');
      const resSemesterWeighted = document.getElementById('res-semester-weighted');
      const resCumUnweighted = document.getElementById('res-cumulative-unweighted');
      const resCumWeighted = document.getElementById('res-cumulative-weighted');
      const resTotalCredits = document.getElementById('res-total-credits');

      // Chart
      const gpaFill = document.getElementById('gpa-fill');
      const gpaMarker = document.getElementById('gpa-marker');

      // What-If
      const wiName = document.getElementById('what-if-name');
      const wiGrade = document.getElementById('what-if-grade');
      const wiWeight = document.getElementById('what-if-weight');
      const wiDispName = document.getElementById('wi-display-name');
      const wiDispGrade = document.getElementById('wi-display-grade');
      const wiDispRes = document.getElementById('wi-display-result');

      let rowCount = 0;

      // Initialize default rows
      function init() {
        const savedData = localStorage.getItem('hsGpaDataV2');
        if (savedData) {
          try {
            const data = JSON.parse(savedData);
            if (data.prior) {
              inputPriorUnweighted.value = data.prior.unweighted || '';
              inputPriorWeighted.value = data.prior.weighted || '';
              inputPriorCredits.value = data.prior.credits || '';
            }
            if (data.classes && data.classes.length > 0) {
              data.classes.forEach(c => addClassRow(c.name, c.grade, c.credits, c.weight));
            } else {
              addDefaultRows();
            }
          } catch(e) {
            addDefaultRows();
          }
        } else {
          addDefaultRows();
        }

        setupEventListeners();
        calculateGPA();
      }

      function addDefaultRows() {
        addClassRow('English 9', '4.0', '1', '0');
        addClassRow('Algebra 1', '3.3', '1', '0');
        addClassRow('Biology', '3.7', '1', '0.5');
        addClassRow('World History', '3.0', '1', '0');
      }

      function setupEventListeners() {
        btnAddClass.addEventListener('click', () => {
          addClassRow();
          calculateGPA();
        });

        btnClear.addEventListener('click', () => {
          if(confirm('Are you sure you want to clear all classes and prior GPA data?')) {
            classesList.innerHTML = '';
            inputPriorUnweighted.value = '';
            inputPriorWeighted.value = '';
            inputPriorCredits.value = '';
            addDefaultRows();
            calculateGPA();
            localStorage.removeItem('hsGpaDataV2');
          }
        });

        classesList.addEventListener('input', calculateGPA);

        inputPriorUnweighted.addEventListener('input', calculateGPA);
        inputPriorWeighted.addEventListener('input', calculateGPA);
        inputPriorCredits.addEventListener('input', calculateGPA);

        wiName.addEventListener('input', updateWhatIf);
        wiGrade.addEventListener('change', updateWhatIf);
        wiWeight.addEventListener('change', updateWhatIf);
      }

      function addClassRow(name = '', grade = '4.0', credits = '1', weight = '0') {
        rowCount++;

        const row = document.createElement('div');
        row.className = 'class-row';
        row.innerHTML = `
          <div class="form-group">
            <label>Class Name</label>
            <input type="text" class="c-name" placeholder="e.g., Biology" value="${name}">
          </div>
          <div class="form-group">
            <label>Grade</label>
            <select class="c-grade">
              <option value="4.0" ${grade === '4.0' ? 'selected' : ''}>A+ / A (4.0)</option>
              <option value="3.7" ${grade === '3.7' ? 'selected' : ''}>A- (3.7)</option>
              <option value="3.3" ${grade === '3.3' ? 'selected' : ''}>B+ (3.3)</option>
              <option value="3.0" ${grade === '3.0' ? 'selected' : ''}>B (3.0)</option>
              <option value="2.7" ${grade === '2.7' ? 'selected' : ''}>B- (2.7)</option>
              <option value="2.3" ${grade === '2.3' ? 'selected' : ''}>C+ (2.3)</option>
              <option value="2.0" ${grade === '2.0' ? 'selected' : ''}>C (2.0)</option>
              <option value="1.7" ${grade === '1.7' ? 'selected' : ''}>C- (1.7)</option>
              <option value="1.3" ${grade === '1.3' ? 'selected' : ''}>D+ (1.3)</option>
              <option value="1.0" ${grade === '1.0' ? 'selected' : ''}>D (1.0)</option>
              <option value="0.0" ${grade === '0.0' ? 'selected' : ''}>F (0.0)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Credits</label>
            <input type="number" class="c-credits" min="0" step="0.5" value="${credits}">
          </div>
          <div class="form-group">
            <label>Class Type</label>
            <select class="c-weight">
              <option value="0" ${weight === '0' ? 'selected' : ''}>Regular</option>
              <option value="0.5" ${weight === '0.5' ? 'selected' : ''}>Honors (+0.5)</option>
              <option value="1.0" ${weight === '1.0' ? 'selected' : ''}>AP/IB/Dual (+1.0)</option>
            </select>
          </div>
          <button class="btn-remove" aria-label="Remove class" onclick="this.parentElement.remove(); document.getElementById('classes-list').dispatchEvent(new Event('input', {bubbles: true}));">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        `;
        classesList.appendChild(row);
      }

      function calculateGPA() {
        let semCredits = 0;
        let semPtsUnweighted = 0;
        let semPtsWeighted = 0;

        const classes = [];

        const rows = document.querySelectorAll('.class-row');
        rows.forEach(row => {
          const name = row.querySelector('.c-name').value;
          const grade = parseFloat(row.querySelector('.c-grade').value);
          const credits = parseFloat(row.querySelector('.c-credits').value) || 0;
          const weight = parseFloat(row.querySelector('.c-weight').value) || 0;

          classes.push({ name, grade: grade.toString(), credits: credits.toString(), weight: weight.toString() });

          if (credits > 0 && !isNaN(grade)) {
            semCredits += credits;
            semPtsUnweighted += (grade * credits);
            // If F, no weight boost usually applies
            const finalWeight = grade > 0 ? weight : 0;
            semPtsWeighted += ((grade + finalWeight) * credits);
          }
        });

        const semesterUnweighted = semCredits > 0 ? (semPtsUnweighted / semCredits) : 0;
        const semesterWeighted = semCredits > 0 ? (semPtsWeighted / semCredits) : 0;

        const priorUnweighted = parseFloat(inputPriorUnweighted.value) || 0;
        const priorWeighted = parseFloat(inputPriorWeighted.value) || 0;
        const priorCredits = parseFloat(inputPriorCredits.value) || 0;

        let totalCredits = priorCredits + semCredits;
        let totalPtsUnweighted = (priorUnweighted * priorCredits) + semPtsUnweighted;
        let totalPtsWeighted = (priorWeighted * priorCredits) + semPtsWeighted;

        const cumUnweighted = totalCredits > 0 ? (totalPtsUnweighted / totalCredits) : 0;
        const cumWeighted = totalCredits > 0 ? (totalPtsWeighted / totalCredits) : 0;

        resSemesterUnweighted.textContent = semesterUnweighted.toFixed(2);
        resSemesterWeighted.textContent = semesterWeighted.toFixed(2);
        resCumUnweighted.textContent = cumUnweighted.toFixed(2);
        resCumWeighted.textContent = cumWeighted.toFixed(2);
        resTotalCredits.textContent = totalCredits.toString();

        updateChart(cumWeighted);
        updateWhatIf();
        saveData(priorUnweighted, priorWeighted, priorCredits, classes);
      }

      function updateChart(gpa) {
        const maxGPA = 5.0;
        let percentage = (gpa / maxGPA) * 100;
        if (percentage > 100) percentage = 100;
        if (percentage < 0) percentage = 0;

        gpaFill.style.width = `${percentage}%`;
        gpaMarker.style.left = `${percentage}%`;
      }

      function updateWhatIf() {
        const name = wiName.value || 'Class';
        const gradeText = wiGrade.options[wiGrade.selectedIndex].text.split(' ')[0];
        const gradeVal = parseFloat(wiGrade.value);
        const weightVal = parseFloat(wiWeight.value);

        wiDispName.textContent = name;
        wiDispGrade.textContent = gradeText;

        // Cumulative what-if logic
        const priorUnweighted = parseFloat(inputPriorUnweighted.value) || 0;
        const priorWeighted = parseFloat(inputPriorWeighted.value) || 0;
        const priorCredits = parseFloat(inputPriorCredits.value) || 0;

        let semCredits = 0;
        let semPtsWeighted = 0;

        const rows = document.querySelectorAll('.class-row');
        rows.forEach(row => {
          const g = parseFloat(row.querySelector('.c-grade').value);
          const c = parseFloat(row.querySelector('.c-credits').value) || 0;
          const w = parseFloat(row.querySelector('.c-weight').value) || 0;
          if (c > 0 && !isNaN(g)) {
            semCredits += c;
            semPtsWeighted += ((g + (g > 0 ? w : 0)) * c);
          }
        });

        // Add what-if class (assume 1 credit)
        const whatIfCredit = 1;
        const whatIfWeight = gradeVal > 0 ? weightVal : 0;

        semCredits += whatIfCredit;
        semPtsWeighted += ((gradeVal + whatIfWeight) * whatIfCredit);

        let totalCredits = priorCredits + semCredits;
        let totalPtsWeighted = (priorWeighted * priorCredits) + semPtsWeighted;

        const newWeightedGPA = totalCredits > 0 ? (totalPtsWeighted / totalCredits) : 0;
        wiDispRes.textContent = newWeightedGPA.toFixed(2);
      }

      function saveData(pu, pw, pc, classes) {
        const data = {
          prior: {
            unweighted: pu,
            weighted: pw,
            credits: pc
          },
          classes: classes
        };
        localStorage.setItem('hsGpaDataV2', JSON.stringify(data));
      }

      document.addEventListener('DOMContentLoaded', init);
    })();
