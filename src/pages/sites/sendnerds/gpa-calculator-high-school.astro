      border-color: var(--accent-color);
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
      background: var(--card-bg);
    }

    .related-card h4 {
      color: var(--accent-color);
      font-size: 1.25rem;
      margin-bottom: 0.75rem;
      font-weight: 700;
