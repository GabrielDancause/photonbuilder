---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Citation Generator — APA, MLA, Chicago & Harvard",
  description: "Generate perfectly formatted citations in APA 7th, MLA 9th, Chicago, and Harvard styles. Cite websites, books, journals, and more — then export your full bibliography instantly.",
  category: "tool",
  published: "2026-03-21",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between APA and MLA citation format?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "APA (American Psychological Association) style is used primarily in the social sciences, education, and psychology. It emphasizes the date of publication by placing it immediately after the author's name. MLA (Modern Language Association) style is used in the humanities, especially English and literature. It emphasizes the author's name and page numbers rather than the publication date. The two formats also differ in how they handle titles, publisher information, and in-text citations."
        }
      },
      {
        "@type": "Question",
        "name": "How do I cite a website with no author listed?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "When no individual author is listed, use the organization or website name as the author. If neither is available, begin the citation with the title of the page or article. In APA format, the title moves to the author position. In MLA format, you start with the title in quotation marks. In Chicago style, you can also lead with the title. This approach applies across all major citation formats and ensures your citation is still traceable to the original source."
        }
      },
      {
        "@type": "Question",
        "name": "When should I use Chicago style citations?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Chicago style (also known as Turabian for students) is commonly required in history, some social sciences, and publishing. It offers two systems: notes-bibliography (used in humanities, using footnotes or endnotes) and author-date (used in sciences, similar to APA). If your professor or publisher specifies Chicago style, use the notes-bibliography system unless told otherwise. Our generator produces the bibliography entry for the notes-bibliography system."
        }
      },
      {
        "@type": "Question",
        "name": "What is Harvard referencing style and who uses it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Harvard referencing is an author-date citation system widely used in universities across the UK, Australia, and parts of Europe. Unlike APA or MLA, Harvard is not governed by a single official manual — institutions often have their own variations. The core format places the author's surname and year in parentheses for in-text citations, with a full reference list at the end. It is common in business, social sciences, and natural sciences programs outside North America."
        }
      },
      {
        "@type": "Question",
        "name": "How do I cite a journal article with multiple authors?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The rules vary by format. In APA 7th edition, list up to 20 authors separated by commas with an ampersand before the last name; for 21 or more, list the first 19, add an ellipsis, and then the final author. In MLA 9th edition, list the first author in last-name-first order, then use 'et al.' for three or more authors. In Chicago, list up to 10 authors; for 11 or more, list the first seven followed by 'et al.' Our generator handles these rules automatically based on how many authors you enter."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use a citation generator for my academic papers?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, citation generators are widely accepted tools for academic writing. They help ensure formatting consistency and save significant time. However, you should always double-check the generated citations against your institution's specific style guide, as minor variations exist between publishers and universities. A citation generator handles the mechanical formatting, but you are responsible for ensuring the accuracy of the source information you input — such as author names, titles, and publication dates."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between a citation, a reference, and a bibliography?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A citation (or in-text citation) is a brief note within the body of your paper that points to a source — for example, (Smith, 2024). A reference is the full, detailed entry in your reference list at the end of the paper that gives readers enough information to locate the source. A bibliography is similar to a reference list, but it may also include works you consulted but did not directly cite. APA and MLA use 'References' and 'Works Cited' respectively, while Chicago often uses 'Bibliography.'"
        }
      },
      {
        "@type": "Question",
        "name": "How do I cite a YouTube video or podcast episode?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For YouTube videos in APA format, list the uploader as the author, the upload date, the video title in italics, '[Video]' in brackets, 'YouTube' as the site name, and the URL. In MLA, list the author or uploader, the title in quotation marks, 'YouTube' in italics, the upload date, and the URL. For podcasts, treat the host as the author, include the episode title and podcast name, the episode number if available, the publisher or network, and the URL. Our generator provides fields for all of these details."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="sendnerds"
  title={meta.title}
  description={meta.description}
  canonical="https://sendnerds.photonbuilder.com/citation-generator"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      📚 <strong style="color:#3B82F6;">Academic integrity matters more than ever.</strong> With the DOJ investigating admissions processes, universities are cracking down on plagiarism. Proper citations aren't optional — they protect your academic career. <a href="https://gab.ae/news/trump-medical-school-admissions-investigation-2026" style="color:#3B82F6;">Why standards are tightening →</a>
    </div>
    <div class="hero">
      <h1>Citation Generator</h1>
      <p class="subtitle">Generate accurate citations in APA, MLA, Chicago, and Harvard — then build your full bibliography.</p>
    </div>

    <div class="calculator-container">
      <div class="tool-grid">
        <!-- Input Panel -->
        <div class="input-section">
          <h3 class="section-heading">Source Details</h3>

          <div class="input-group">
            <label for="source-type">Source Type</label>
            <select id="source-type">
              <option value="website">Website</option>
              <option value="book">Book</option>
              <option value="journal">Journal Article</option>
              <option value="newspaper">Newspaper Article</option>
              <option value="video">Video</option>
              <option value="podcast">Podcast</option>
            </select>
          </div>

          <div id="url-autofill" class="autofill-row">
            <div class="input-group" style="flex:1">
              <label for="source-url">URL (paste to auto-fill)</label>
              <input type="url" id="source-url" placeholder="https://example.com/article">
            </div>
            <button id="autofill-btn" class="action-btn small-btn" title="Fetch metadata from URL">Auto-fill</button>
          </div>
          <div id="autofill-status" class="status-msg"></div>

          <div id="dynamic-fields">
            <!-- Fields injected by JS based on source type -->
          </div>

          <button id="generate-btn" class="primary-btn">Generate Citations</button>
          <div id="generate-error" class="error-msg"></div>
        </div>

        <!-- Output Panel -->
        <div class="output-section">
          <div class="results-sticky">
            <h3>Formatted Citations</h3>
            <div class="format-tabs" id="format-tabs">
              <button class="tab-btn active" data-format="apa">APA 7th</button>
              <button class="tab-btn" data-format="mla">MLA 9th</button>
              <button class="tab-btn" data-format="chicago">Chicago</button>
              <button class="tab-btn" data-format="harvard">Harvard</button>
            </div>
            <div id="citation-output" class="citation-output">
              <p class="placeholder-text">Fill in the source details and click <strong>Generate Citations</strong> to see your formatted references here.</p>
            </div>
            <div id="citation-actions" class="citation-actions" style="display:none">
              <button id="copy-btn" class="action-btn">Copy Citation</button>
              <button id="save-btn" class="action-btn secondary">Save to List</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Saved Citations List -->
    <div class="list-container" id="list-container" style="display:none">
      <div class="list-header">
        <h3>Your Bibliography</h3>
        <div class="list-controls">
          <select id="export-format">
            <option value="apa">APA 7th</option>
            <option value="mla">MLA 9th</option>
            <option value="chicago">Chicago</option>
            <option value="harvard">Harvard</option>
          </select>
          <button id="copy-all-btn" class="action-btn small-btn">Copy All</button>
          <button id="clear-all-btn" class="action-btn small-btn danger">Clear All</button>
        </div>
      </div>
      <div id="saved-list">
        <!-- Saved citations rendered here -->
      </div>
    </div>

    <!-- Formatting Rules Reference -->
    <div class="explainer">
      <h2>Citation Formatting Rules: A Complete Reference</h2>
      <p>Correctly formatting academic citations is one of the most tedious yet critically important requirements in scholarly writing. A single misplaced period, an incorrectly italicized title, or a missing piece of publication data can cost you points on an assignment, delay a journal submission, or undermine the credibility of an otherwise excellent paper. This comprehensive reference covers the four most widely used citation styles in academic institutions worldwide, giving you a practical understanding of when to use each one and how the rules differ across formats.</p>

      <h3>APA 7th Edition (American Psychological Association)</h3>
      <p>APA style is the dominant citation format in the social sciences, psychology, education, nursing, and business. The 7th edition, published in 2019, introduced several significant changes from the 6th edition, including simplified rules for DOIs and URLs, inclusion of up to 20 authors in a reference, and the removal of location information for publishers. The core structure of an APA reference follows this pattern: <code>Author, A. A. (Year). Title of work. Publisher. URL</code></p>
      <p>Key rules for APA 7th edition include: only capitalize the first word and proper nouns in article and book titles (known as sentence case), italicize titles of standalone works such as books and journals, use an ampersand (&amp;) before the last author in multi-author works, and always include DOIs as clickable hyperlinks when available. In-text citations use the author-date format, such as (Smith, 2024), and page numbers are included only for direct quotations.</p>

      <h3>MLA 9th Edition (Modern Language Association)</h3>
      <p>MLA style is the standard citation format for the humanities, including English literature, comparative literature, foreign languages, and cultural studies. The 9th edition emphasizes a core elements approach, using a universal template of nine elements (author, title, container, contributors, version, number, publisher, date, location) that applies to any source type. The core structure follows: <code>Author. "Title of Source." Container, Other contributors, Version, Number, Publisher, Date, Location.</code></p>
      <p>Key rules for MLA 9th edition include: use title case for all titles (capitalize major words), place article and chapter titles in quotation marks while italicizing the names of larger works, use "et al." when there are three or more authors, omit URLs unless required by your instructor or needed for reader access, and include page numbers in all in-text citations when available. MLA labels its reference list "Works Cited" and arranges entries alphabetically by the author's last name.</p>

      <h3>Chicago / Turabian Style</h3>
      <p>The Chicago Manual of Style, now in its 17th edition, is used primarily in history, fine arts, and some social sciences. Turabian style is its student-friendly adaptation. Chicago offers two distinct citation systems: the notes-bibliography system (favored in the humanities) uses footnotes or endnotes with a bibliography, while the author-date system (used in sciences) resembles APA formatting. Our generator produces bibliography entries for the notes-bibliography system.</p>
      <p>Key rules for Chicago notes-bibliography include: use title case for all titles, italicize book and journal titles, place article titles in quotation marks, list up to 10 authors with the first author inverted (Last, First) and subsequent authors in normal order, and separate major elements with periods. In footnotes, the first reference to a source uses the full citation, while subsequent references use a shortened form with just the author's last name, a short title, and the page number.</p>

      <h3>Harvard Referencing Style</h3>
      <p>Harvard style is used extensively in universities across the United Kingdom, Australia, and parts of continental Europe. Unlike APA, MLA, and Chicago, Harvard referencing is not controlled by a single official style manual — instead, individual institutions publish their own Harvard guides, leading to minor variations in formatting. The general structure follows: <code>Author surname, Initial. (Year) Title. Publisher/Source. Available at: URL (Accessed: date).</code></p>
      <p>Common Harvard rules include: use title case for book titles and sentence case for article titles (though this varies by institution), italicize book and journal titles, use "and" (not "&amp;") before the last author, include "Available at:" before URLs and an "Accessed:" date for online sources, and arrange the reference list alphabetically. In-text citations use the author-date format in parentheses, such as (Smith, 2024), identical in concept to APA but with minor formatting differences.</p>

      <h3>Explore More Academic Tools</h3>
      <p>Need to check your academic standing? Try our <a href="/college-gpa-calculator">College GPA Calculator</a> to project your semester and cumulative GPA with precision. If you are working on final grades, our <a href="/final-grade-calculator">Final Grade Calculator</a> can tell you exactly what score you need on your final exam. For comprehensive grade tracking across multiple assignments, use our <a href="/grade-calculator">Grade Calculator</a> to stay on top of your coursework.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map(faq => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const sourceType = document.getElementById('source-type');
      const dynamicFields = document.getElementById('dynamic-fields');
      const generateBtn = document.getElementById('generate-btn');
      const generateError = document.getElementById('generate-error');
      const citationOutput = document.getElementById('citation-output');
      const citationActions = document.getElementById('citation-actions');
      const copyBtn = document.getElementById('copy-btn');
      const saveBtn = document.getElementById('save-btn');
      const formatTabs = document.getElementById('format-tabs');
      const autofillBtn = document.getElementById('autofill-btn');
      const autofillStatus = document.getElementById('autofill-status');
      const sourceUrlInput = document.getElementById('source-url');
      const urlAutofillRow = document.getElementById('url-autofill');

      const listContainer = document.getElementById('list-container');
      const savedListEl = document.getElementById('saved-list');
      const exportFormatSel = document.getElementById('export-format');
      const copyAllBtn = document.getElementById('copy-all-btn');
      const clearAllBtn = document.getElementById('clear-all-btn');

      let activeFormat = 'apa';
      let currentCitations = null; // { apa, mla, chicago, harvard, raw }
      let savedCitations = []; // array of citation objects

      // ---- Field Definitions per Source Type ----
      const fieldDefs = {
        website: [
          { id: 'author', label: 'Author(s)', placeholder: 'Last, First M. (separate multiple with ;)' },
          { id: 'title', label: 'Page Title', placeholder: 'Title of the web page' },
          { id: 'site-name', label: 'Website Name', placeholder: 'e.g., The New York Times' },
          { id: 'pub-date', label: 'Publication Date', placeholder: 'YYYY, Month Day', type: 'text' },
          { id: 'access-date', label: 'Access Date', placeholder: 'YYYY, Month Day', type: 'text' },
          { id: 'url', label: 'URL', placeholder: 'https://...' }
        ],
        book: [
          { id: 'author', label: 'Author(s)', placeholder: 'Last, First M. (separate multiple with ;)' },
          { id: 'title', label: 'Book Title', placeholder: 'Title of the book' },
          { id: 'publisher', label: 'Publisher', placeholder: 'e.g., Oxford University Press' },
          { id: 'pub-year', label: 'Publication Year', placeholder: 'e.g., 2024' },
          { id: 'edition', label: 'Edition', placeholder: 'e.g., 3rd (leave blank for 1st)' },
          { id: 'editors', label: 'Editor(s)', placeholder: 'Last, First M. (if applicable)' },
          { id: 'url', label: 'URL / DOI', placeholder: 'https://doi.org/...' }
        ],
        journal: [
          { id: 'author', label: 'Author(s)', placeholder: 'Last, First M. (separate multiple with ;)' },
          { id: 'title', label: 'Article Title', placeholder: 'Title of the article' },
          { id: 'journal-name', label: 'Journal Name', placeholder: 'e.g., Nature' },
          { id: 'pub-year', label: 'Publication Year', placeholder: 'e.g., 2024' },
          { id: 'volume', label: 'Volume', placeholder: 'e.g., 12' },
          { id: 'issue', label: 'Issue', placeholder: 'e.g., 3' },
          { id: 'pages', label: 'Pages', placeholder: 'e.g., 45-67' },
          { id: 'url', label: 'URL / DOI', placeholder: 'https://doi.org/...' }
        ],
        newspaper: [
          { id: 'author', label: 'Author(s)', placeholder: 'Last, First M. (separate multiple with ;)' },
          { id: 'title', label: 'Article Title', placeholder: 'Title of the article' },
          { id: 'newspaper-name', label: 'Newspaper Name', placeholder: 'e.g., The Washington Post' },
          { id: 'pub-date', label: 'Publication Date', placeholder: 'YYYY, Month Day' },
          { id: 'pages', label: 'Page(s)', placeholder: 'e.g., A1, A4' },
          { id: 'url', label: 'URL', placeholder: 'https://...' }
        ],
        video: [
          { id: 'author', label: 'Creator / Uploader', placeholder: 'Channel or person name' },
          { id: 'title', label: 'Video Title', placeholder: 'Title of the video' },
          { id: 'site-name', label: 'Platform', placeholder: 'e.g., YouTube, Vimeo' },
          { id: 'pub-date', label: 'Upload Date', placeholder: 'YYYY, Month Day' },
          { id: 'url', label: 'URL', placeholder: 'https://...' }
        ],
        podcast: [
          { id: 'author', label: 'Host(s)', placeholder: 'Last, First M. (separate multiple with ;)' },
          { id: 'title', label: 'Episode Title', placeholder: 'Title of the episode' },
          { id: 'podcast-name', label: 'Podcast Name', placeholder: 'e.g., Serial' },
          { id: 'publisher', label: 'Publisher / Network', placeholder: 'e.g., NPR' },
          { id: 'pub-date', label: 'Publication Date', placeholder: 'YYYY, Month Day' },
          { id: 'episode-num', label: 'Episode Number', placeholder: 'e.g., 42' },
          { id: 'url', label: 'URL', placeholder: 'https://...' }
        ]
      };

      // ---- Render Fields ----
      function renderFields() {
        const type = sourceType.value;
        const fields = fieldDefs[type];
        dynamicFields.innerHTML = '';
        fields.forEach(f => {
          const group = document.createElement('div');
          group.className = 'input-group';
          const label = document.createElement('label');
          label.setAttribute('for', 'field-' + f.id);
          label.textContent = f.label;
          const input = document.createElement('input');
          input.type = f.type || 'text';
          input.id = 'field-' + f.id;
          input.placeholder = f.placeholder || '';
          group.appendChild(label);
          group.appendChild(input);
          dynamicFields.appendChild(group);
        });
        // Show/hide URL autofill row
        urlAutofillRow.style.display = (type === 'website' || type === 'newspaper' || type === 'video') ? 'flex' : 'none';
      }

      function getField(id) {
        const el = document.getElementById('field-' + id);
        return el ? el.value.trim() : '';
      }

      // ---- Parse Authors ----
      function parseAuthors(raw) {
        if (!raw) return [];
        return raw.split(';').map(a => a.trim()).filter(Boolean);
      }

      function authorLastFirst(name) {
        // Already in Last, First format
        if (name.includes(',')) return name.trim();
        const parts = name.trim().split(/\s+/);
        if (parts.length === 1) return parts[0];
        const last = parts.pop();
        return last + ', ' + parts.join(' ');
      }

      function authorFirstLast(name) {
        if (!name.includes(',')) return name.trim();
        const parts = name.split(',').map(s => s.trim());
        return parts[1] + ' ' + parts[0];
      }

      function initialsOnly(name) {
        // "Last, First M." → "Last, F. M."
        const lf = authorLastFirst(name);
        const parts = lf.split(',').map(s => s.trim());
        if (parts.length < 2) return lf;
        const firstParts = parts[1].split(/\s+/);
        const initials = firstParts.map(p => p.charAt(0).toUpperCase() + '.').join(' ');
        return parts[0] + ', ' + initials;
      }

      // ---- Date Helpers ----
      function parseDate(raw) {
        if (!raw) return null;
        const d = new Date(raw);
        if (isNaN(d.getTime())) {
          // Try extracting year
          const ym = raw.match(/(\d{4})/);
          return ym ? { year: ym[1], month: '', day: '', full: raw } : null;
        }
        const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
        return {
          year: String(d.getFullYear()),
          month: months[d.getMonth()],
          day: String(d.getDate()),
          full: raw
        };
      }

      function apaDate(raw) {
        const d = parseDate(raw);
        if (!d) return '(n.d.)';
        if (d.month && d.day && d.day !== 'NaN') return '(' + d.year + ', ' + d.month + ' ' + d.day + ')';
        return '(' + d.year + ')';
      }

      function mlaDate(raw) {
        const d = parseDate(raw);
        if (!d) return '';
        if (d.month && d.day && d.day !== 'NaN') return d.day + ' ' + d.month.substring(0,3) + '. ' + d.year;
        return d.year;
      }

      function chicagoDate(raw) {
        const d = parseDate(raw);
        if (!d) return '';
        if (d.month && d.day && d.day !== 'NaN') return d.month + ' ' + d.day + ', ' + d.year;
        return d.year;
      }

      function harvardDate(raw) {
        const d = parseDate(raw);
        if (!d) return '(no date)';
        return '(' + d.year + ')';
      }

      function harvardYear(raw) {
        const d = parseDate(raw);
        return d ? d.year : 'no date';
      }

      // ---- Format Authors per Style ----
      function apaAuthors(authors) {
        if (!authors.length) return '';
        const formatted = authors.map(a => initialsOnly(a));
        if (formatted.length === 1) return formatted[0];
        if (formatted.length === 2) return formatted[0] + ', & ' + formatted[1];
        if (formatted.length <= 20) return formatted.slice(0, -1).join(', ') + ', & ' + formatted[formatted.length - 1];
        return formatted.slice(0, 19).join(', ') + ', ... ' + formatted[formatted.length - 1];
      }

      function mlaAuthors(authors) {
        if (!authors.length) return '';
        if (authors.length === 1) return authorLastFirst(authors[0]);
        if (authors.length === 2) return authorLastFirst(authors[0]) + ', and ' + authorFirstLast(authors[1]);
        return authorLastFirst(authors[0]) + ', et al.';
      }

      function chicagoAuthors(authors) {
        if (!authors.length) return '';
        if (authors.length === 1) return authorLastFirst(authors[0]);
        if (authors.length === 2) return authorLastFirst(authors[0]) + ', and ' + authorFirstLast(authors[1]);
        if (authors.length <= 10) {
          const parts = [authorLastFirst(authors[0])];
          for (let i = 1; i < authors.length - 1; i++) parts.push(authorFirstLast(authors[i]));
          return parts.join(', ') + ', and ' + authorFirstLast(authors[authors.length - 1]);
        }
        return authorLastFirst(authors[0]) + ', et al.';
      }

      function harvardAuthors(authors) {
        if (!authors.length) return '';
        const formatted = authors.map(a => initialsOnly(a));
        if (formatted.length === 1) return formatted[0];
        if (formatted.length === 2) return formatted[0] + ' and ' + formatted[1];
        if (formatted.length <= 3) return formatted.slice(0, -1).join(', ') + ' and ' + formatted[formatted.length - 1];
        return formatted[0] + ' et al.';
      }

      // ---- Citation Generators ----
      function generateWebsite(data) {
        const a = parseAuthors(data.author);
        const title = data.title;
        const siteName = data['site-name'];
        const date = data['pub-date'] || data['access-date'];
        const accessDate = data['access-date'];
        const url = data.url;

        const apa = (a.length ? apaAuthors(a) + ' ' : '') + apaDate(date) + '. ' + (title ? title + '. ' : '') + (siteName ? '<i>' + siteName + '</i>. ' : '') + (url || '');
        const mla = (a.length ? mlaAuthors(a) + '. ' : '') + (title ? '&ldquo;' + title + '.&rdquo; ' : '') + (siteName ? '<i>' + siteName + '</i>, ' : '') + mlaDate(date) + (url ? ', ' + url : '') + '.';
        const chi = (a.length ? chicagoAuthors(a) + '. ' : '') + (title ? '&ldquo;' + title + '.&rdquo; ' : '') + (siteName ? '<i>' + siteName + '</i>. ' : '') + (chicagoDate(date) ? chicagoDate(date) + '. ' : '') + (url || '') + '.';
        const har = (a.length ? harvardAuthors(a) + ' ' : '') + harvardDate(date) + ' ' + (title ? '<i>' + title + '</i>. ' : '') + (siteName ? siteName + '. ' : '') + (url ? 'Available at: ' + url : '') + (accessDate ? ' (Accessed: ' + chicagoDate(accessDate) + ')' : '') + '.';
        return { apa, mla, chicago: chi, harvard: har };
      }

      function generateBook(data) {
        const a = parseAuthors(data.author);
        const title = data.title;
        const pub = data.publisher;
        const year = data['pub-year'];
        const ed = data.edition;
        const url = data.url;
        const edStr = ed ? ' (' + ed + ' ed.)' : '';

        const apa = (a.length ? apaAuthors(a) + ' ' : '') + '(' + (year || 'n.d.') + '). <i>' + title + '</i>' + edStr + '. ' + (pub ? pub + '. ' : '') + (url || '');
        const mla = (a.length ? mlaAuthors(a) + '. ' : '') + '<i>' + title + '</i>. ' + (ed ? ed + ' ed., ' : '') + (pub ? pub + ', ' : '') + (year || '') + '.';
        const chi = (a.length ? chicagoAuthors(a) + '. ' : '') + '<i>' + title + '</i>. ' + (ed ? ed + ' ed. ' : '') + (pub ? pub + ', ' : '') + (year || '') + '.';
        const har = (a.length ? harvardAuthors(a) + ' ' : '') + '(' + (year || 'no date') + ') <i>' + title + '</i>.' + (ed ? ' ' + ed + ' edn.' : '') + (pub ? ' ' + pub + '.' : '') + (url ? ' Available at: ' + url : '');
        return { apa, mla, chicago: chi, harvard: har };
      }

      function generateJournal(data) {
        const a = parseAuthors(data.author);
        const title = data.title;
        const journal = data['journal-name'];
        const year = data['pub-year'];
        const vol = data.volume;
        const iss = data.issue;
        const pages = data.pages;
        const url = data.url;

        const volIss = vol ? ', <i>' + vol + '</i>' + (iss ? '(' + iss + ')' : '') : '';
        const apa = (a.length ? apaAuthors(a) + ' ' : '') + '(' + (year || 'n.d.') + '). ' + title + '. <i>' + (journal || '') + '</i>' + volIss + (pages ? ', ' + pages : '') + '. ' + (url || '');
        const mla = (a.length ? mlaAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo; <i>' + (journal || '') + '</i>' + (vol ? ', vol. ' + vol : '') + (iss ? ', no. ' + iss : '') + (year ? ', ' + year : '') + (pages ? ', pp. ' + pages : '') + '.';
        const chi = (a.length ? chicagoAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo; <i>' + (journal || '') + '</i>' + (vol ? ' ' + vol : '') + (iss ? ', no. ' + iss : '') + (year ? ' (' + year + ')' : '') + (pages ? ': ' + pages : '') + '.';
        const har = (a.length ? harvardAuthors(a) + ' ' : '') + '(' + (year || 'no date') + ') &lsquo;' + title + '&rsquo;, <i>' + (journal || '') + '</i>' + (vol ? ', ' + vol : '') + (iss ? '(' + iss + ')' : '') + (pages ? ', pp. ' + pages : '') + '.' + (url ? ' Available at: ' + url : '');
        return { apa, mla, chicago: chi, harvard: har };
      }

      function generateNewspaper(data) {
        const a = parseAuthors(data.author);
        const title = data.title;
        const paper = data['newspaper-name'];
        const date = data['pub-date'];
        const pages = data.pages;
        const url = data.url;

        const apa = (a.length ? apaAuthors(a) + ' ' : '') + apaDate(date) + '. ' + title + '. <i>' + (paper || '') + '</i>' + (pages ? ', ' + pages : '') + '. ' + (url || '');
        const mla = (a.length ? mlaAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo; <i>' + (paper || '') + '</i>, ' + mlaDate(date) + (pages ? ', ' + pages : '') + '.';
        const chi = (a.length ? chicagoAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo; <i>' + (paper || '') + '</i>, ' + chicagoDate(date) + '.';
        const har = (a.length ? harvardAuthors(a) + ' ' : '') + harvardDate(date) + ' &lsquo;' + title + '&rsquo;, <i>' + (paper || '') + '</i>' + (pages ? ', ' + pages : '') + '.' + (url ? ' Available at: ' + url : '');
        return { apa, mla, chicago: chi, harvard: har };
      }

      function generateVideo(data) {
        const a = parseAuthors(data.author);
        const title = data.title;
        const platform = data['site-name'] || 'YouTube';
        const date = data['pub-date'];
        const url = data.url;

        const apa = (a.length ? apaAuthors(a) + ' ' : '') + apaDate(date) + '. <i>' + title + '</i> [Video]. ' + platform + '. ' + (url || '');
        const mla = (a.length ? mlaAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo; <i>' + platform + '</i>, ' + mlaDate(date) + (url ? ', ' + url : '') + '.';
        const chi = (a.length ? chicagoAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo; ' + platform + ' video' + (chicagoDate(date) ? ', ' + chicagoDate(date) : '') + '. ' + (url || '') + '.';
        const har = (a.length ? harvardAuthors(a) + ' ' : '') + harvardDate(date) + ' <i>' + title + '</i> [Video]. ' + platform + '.' + (url ? ' Available at: ' + url : '');
        return { apa, mla, chicago: chi, harvard: har };
      }

      function generatePodcast(data) {
        const a = parseAuthors(data.author);
        const title = data.title;
        const podName = data['podcast-name'];
        const pub = data.publisher;
        const date = data['pub-date'];
        const epNum = data['episode-num'];
        const url = data.url;

        const epStr = epNum ? '(No. ' + epNum + ')' : '';
        const apa = (a.length ? apaAuthors(a) + ' (Host). ' : '') + apaDate(date) + '. ' + title + ' ' + epStr + ' [Audio podcast episode]. In <i>' + (podName || '') + '</i>. ' + (pub ? pub + '. ' : '') + (url || '');
        const mla = (a.length ? mlaAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo; <i>' + (podName || '') + '</i>' + (pub ? ', ' + pub : '') + ', ' + mlaDate(date) + (url ? ', ' + url : '') + '.';
        const chi = (a.length ? chicagoAuthors(a) + '. ' : '') + '&ldquo;' + title + '.&rdquo;' + (epNum ? ' Episode ' + epNum + '.' : '') + ' In <i>' + (podName || '') + '</i>.' + (pub ? ' ' + pub + '.' : '') + (chicagoDate(date) ? ' ' + chicagoDate(date) + '.' : '') + ' ' + (url || '') + '.';
        const har = (a.length ? harvardAuthors(a) + ' ' : '') + harvardDate(date) + ' &lsquo;' + title + '&rsquo;, <i>' + (podName || '') + '</i>' + (epNum ? ', episode ' + epNum : '') + '.' + (pub ? ' ' + pub + '.' : '') + (url ? ' Available at: ' + url : '');
        return { apa, mla, chicago: chi, harvard: har };
      }

      // ---- Main Generate ----
      function generate() {
        generateError.textContent = '';
        const type = sourceType.value;
        const data = {};
        fieldDefs[type].forEach(f => { data[f.id] = getField(f.id); });

        // Also grab source-url for website types
        if (type === 'website' || type === 'newspaper' || type === 'video') {
          if (!data.url && sourceUrlInput.value.trim()) data.url = sourceUrlInput.value.trim();
        }

        // Require at least a title
        if (!data.title) {
          generateError.textContent = 'Please enter at least a title for your source.';
          return;
        }

        const generators = { website: generateWebsite, book: generateBook, journal: generateJournal, newspaper: generateNewspaper, video: generateVideo, podcast: generatePodcast };
        currentCitations = generators[type](data);
        currentCitations.raw = { type, ...data };

        renderCitation();
        citationActions.style.display = 'flex';
      }

      function renderCitation() {
        if (!currentCitations) return;
        const text = currentCitations[activeFormat];
        citationOutput.innerHTML = '<div class="citation-text">' + text + '</div>';
      }

      // ---- Tabs ----
      formatTabs.addEventListener('click', (e) => {
        if (!e.target.classList.contains('tab-btn')) return;
        formatTabs.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        activeFormat = e.target.dataset.format;
        renderCitation();
      });

      // ---- Copy ----
      copyBtn.addEventListener('click', () => {
        if (!currentCitations) return;
        const temp = document.createElement('div');
        temp.innerHTML = currentCitations[activeFormat];
        const plain = temp.textContent || temp.innerText;
        navigator.clipboard.writeText(plain).then(() => {
          copyBtn.textContent = 'Copied!';
          setTimeout(() => { copyBtn.textContent = 'Copy Citation'; }, 1500);
        });
      });

      // ---- Save ----
      saveBtn.addEventListener('click', () => {
        if (!currentCitations) return;
        savedCitations.push({ ...currentCitations });
        renderSavedList();
        saveBtn.textContent = 'Saved!';
        setTimeout(() => { saveBtn.textContent = 'Save to List'; }, 1500);
      });

      function renderSavedList() {
        if (savedCitations.length === 0) {
          listContainer.style.display = 'none';
          return;
        }
        listContainer.style.display = 'block';
        const fmt = exportFormatSel.value;
        savedListEl.innerHTML = '';
        savedCitations.forEach((c, i) => {
          const item = document.createElement('div');
          item.className = 'saved-item';
          item.draggable = true;
          item.dataset.index = i;

          const grip = document.createElement('span');
          grip.className = 'drag-grip';
          grip.textContent = '\u2261';

          const text = document.createElement('div');
          text.className = 'saved-text';
          text.innerHTML = c[fmt];

          const actions = document.createElement('div');
          actions.className = 'saved-actions';

          const copyOne = document.createElement('button');
          copyOne.className = 'action-btn tiny-btn';
          copyOne.textContent = 'Copy';
          copyOne.onclick = () => {
            const temp = document.createElement('div');
            temp.innerHTML = c[fmt];
            navigator.clipboard.writeText(temp.textContent || temp.innerText).then(() => {
              copyOne.textContent = 'Copied!';
              setTimeout(() => { copyOne.textContent = 'Copy'; }, 1200);
            });
          };

          const removeOne = document.createElement('button');
          removeOne.className = 'action-btn tiny-btn danger';
          removeOne.textContent = 'Remove';
          removeOne.onclick = () => {
            savedCitations.splice(i, 1);
            renderSavedList();
          };

          actions.appendChild(copyOne);
          actions.appendChild(removeOne);
          item.appendChild(grip);
          item.appendChild(text);
          item.appendChild(actions);
          savedListEl.appendChild(item);

          // Drag-and-drop reorder
          item.addEventListener('dragstart', (e) => {
            e.dataTransfer.setData('text/plain', i);
            item.classList.add('dragging');
          });
          item.addEventListener('dragend', () => item.classList.remove('dragging'));
          item.addEventListener('dragover', (e) => { e.preventDefault(); item.classList.add('drag-over'); });
          item.addEventListener('dragleave', () => item.classList.remove('drag-over'));
          item.addEventListener('drop', (e) => {
            e.preventDefault();
            item.classList.remove('drag-over');
            const from = parseInt(e.dataTransfer.getData('text/plain'));
            const to = i;
            if (from !== to) {
              const moved = savedCitations.splice(from, 1)[0];
              savedCitations.splice(to, 0, moved);
              renderSavedList();
            }
          });
        });
      }

      exportFormatSel.addEventListener('change', renderSavedList);

      copyAllBtn.addEventListener('click', () => {
        const fmt = exportFormatSel.value;
        const lines = savedCitations.map(c => {
          const temp = document.createElement('div');
          temp.innerHTML = c[fmt];
          return (temp.textContent || temp.innerText).trim();
        });
        navigator.clipboard.writeText(lines.join('\n\n')).then(() => {
          copyAllBtn.textContent = 'Copied All!';
          setTimeout(() => { copyAllBtn.textContent = 'Copy All'; }, 1500);
        });
      });

      clearAllBtn.addEventListener('click', () => {
        if (savedCitations.length && confirm('Remove all saved citations?')) {
          savedCitations = [];
          renderSavedList();
        }
      });

      // ---- Auto-fill from URL ----
      autofillBtn.addEventListener('click', async () => {
        const url = sourceUrlInput.value.trim();
        if (!url) { autofillStatus.textContent = 'Enter a URL first.'; return; }
        autofillStatus.textContent = 'Fetching metadata...';
        autofillStatus.className = 'status-msg';
        try {
          const resp = await fetch(url, { mode: 'cors' });
          if (!resp.ok) throw new Error('Fetch failed');
          const html = await resp.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');

          const getMeta = (names) => {
            for (const n of names) {
              const el = doc.querySelector('meta[property="' + n + '"]') || doc.querySelector('meta[name="' + n + '"]');
              if (el) return el.getAttribute('content');
            }
            return '';
          };

          const title = getMeta(['og:title', 'twitter:title']) || doc.querySelector('title')?.textContent || '';
          const author = getMeta(['author', 'article:author', 'og:article:author']);
          const siteName = getMeta(['og:site_name']);
          const pubDate = getMeta(['article:published_time', 'date', 'pubdate', 'og:article:published_time']);

          if (title) setFieldValue('title', title);
          if (author) setFieldValue('author', author);
          if (siteName) setFieldValue('site-name', siteName);
          if (pubDate) setFieldValue('pub-date', pubDate);
          setFieldValue('url', url);

          autofillStatus.textContent = 'Metadata extracted' + (title ? '' : ' (limited data found)') + '.';
          autofillStatus.className = 'status-msg success';
        } catch (e) {
          autofillStatus.textContent = 'Could not fetch — CORS may be blocking. Enter details manually.';
          autofillStatus.className = 'status-msg error';
          setFieldValue('url', url);
        }
      });

      function setFieldValue(id, val) {
        const el = document.getElementById('field-' + id);
        if (el && val) el.value = val;
      }

      // ---- Events ----
      sourceType.addEventListener('change', renderFields);
      generateBtn.addEventListener('click', generate);

      // Initialize
      renderFields();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
