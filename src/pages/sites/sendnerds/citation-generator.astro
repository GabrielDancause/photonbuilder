    .output-section { position: relative; }
    .results-sticky { position: sticky; top: 2rem; background: var(--bg-color); border-radius: 12px; padding: 1.5rem; border: 1px solid var(--border-color); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); }
    .results-sticky h3 { margin-top: 0; margin-bottom: 1rem; text-align: center; }

    .format-tabs { display: flex; gap: 0; border: 1px solid var(--border-color); border-radius: 8px; overflow: hidden; margin-bottom: 1rem; }
    .tab-btn { flex: 1; background: transparent; color: var(--text-secondary); border: none; padding: 0.6rem 0.5rem; font-weight: 600; font-size: 0.82rem; cursor: pointer; transition: all 0.15s; border-right: 1px solid var(--border-color); }
    .tab-btn:last-child { border-right: none; }
    .tab-btn.active { background: var(--accent-color); color: #fff; }
    .tab-btn:hover:not(.active) { background: color-mix(in srgb, var(--accent-color) 8%, transparent); }

    .citation-output { min-height: 80px; padding: 1rem; background: color-mix(in srgb, var(--accent-color) 4%, transparent); border: 1px solid var(--border-color); border-radius: 8px; line-height: 1.65; font-size: 0.92rem; color: var(--text-primary); word-break: break-word; }
    .citation-output .placeholder-text { color: var(--text-secondary); font-size: 0.88rem; text-align: center; margin: 0; }
    .citation-text { hanging-punctuation: first; text-indent: -2rem; padding-left: 2rem; }

    .citation-actions { display: flex; gap: 0.5rem; margin-top: 0.75rem; }

    /* Saved List */
    .list-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 2rem 0; }
    .list-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1rem; }
    .list-header h3 { margin: 0; font-size: 1.2rem; }
    .list-controls { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
    .list-controls select { width: auto; padding: 0.4rem 0.6rem; font-size: 0.82rem; }

    .saved-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.85rem; background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; margin-bottom: 0.5rem; transition: border-color 0.2s; }
    .saved-item.dragging { opacity: 0.5; }
    .saved-item.drag-over { border-color: var(--accent-color); }
    .drag-grip { cursor: grab; font-size: 1.3rem; color: var(--text-secondary); user-select: none; line-height: 1; padding-top: 0.1rem; }
    .saved-text { flex: 1; font-size: 0.88rem; line-height: 1.55; color: var(--text-primary); word-break: break-word; }
    .saved-text .citation-text { text-indent: 0; padding-left: 0; }
    .saved-actions { display: flex; flex-direction: column; gap: 0.3rem; flex-shrink: 0; }

    /* Explainer */
    .explainer { margin: 3rem 0; line-height: 1.7; }
    .explainer h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1rem; color: var(--text-primary); }
    .explainer h3 { font-size: 1.3rem; font-weight: 700; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--text-primary); }
    .explainer p { margin-bottom: 1.25rem; color: var(--text-secondary); }
    .explainer code { background: var(--bg-color); border: 1px solid var(--border-color); padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; color: var(--accent-color); }

    /* FAQ */
    .faq-section { margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 2rem; }
    .faq-section h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1.5rem; }
