    @media (max-width: 850px) { .tool-grid { grid-template-columns: 1fr; } }

    .section-heading { font-size: 1.25rem; font-weight: 700; margin-top: 0; margin-bottom: 1rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; }

    .input-group { margin-bottom: 0.85rem; }
