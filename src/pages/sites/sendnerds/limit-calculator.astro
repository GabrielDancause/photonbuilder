  <script is:inline>
    const inputFunction = document.getElementById('limit-function');
    const inputTarget = document.getElementById('limit-target');
    const selectDirection = document.getElementById('limit-direction');
    const resultValue = document.getElementById('limit-result');
    const errorState = document.getElementById('limit-error');
    const breakdown = document.getElementById('limit-breakdown');
    const leftValSpan = document.getElementById('left-val');
    const rightValSpan = document.getElementById('right-val');

    // Basic Math parser
    function parseExpression(expr, xVal) {
      try {
        let safeExpr = expr.toLowerCase();

        // Replace implicit multiplication (e.g., 2x to 2*x)
        safeExpr = safeExpr.replace(/(\d)(x)/g, '$1*$2');
        safeExpr = safeExpr.replace(/(x)(\d)/g, '$1*$2');
        safeExpr = safeExpr.replace(/(\))(\()/g, '$1*$2');
        safeExpr = safeExpr.replace(/(\d)(\()/g, '$1*$2');
        safeExpr = safeExpr.replace(/(\))(x)/g, '$1*$2');

        // Handle Math functions
        const mathFuncs = ['sin', 'cos', 'tan', 'asin', 'acos', 'atan', 'sqrt', 'exp', 'log', 'abs'];
        mathFuncs.forEach(func => {
          const regex = new RegExp(func + '\\(', 'g');
          safeExpr = safeExpr.replace(regex, 'Math.' + func + '(');
        });

        // ln is log
        safeExpr = safeExpr.replace(/ln\(/g, 'Math.log(');

        // Pi and e
        safeExpr = safeExpr.replace(/\bpi\b/g, 'Math.PI');
        safeExpr = safeExpr.replace(/\be\b/g, 'Math.E');

        // Handle power ^ to Math.pow
        while (safeExpr.includes('^')) {
          safeExpr = safeExpr.replace(/([a-zA-Z0-9_.]+|\([^()]+\))\s*\^\s*([a-zA-Z0-9_.]+|\([^()]+\))/, 'Math.pow($1,$2)');
          // Fallback if regex fails to fully parse nested parens (simple approximation)
          if (safeExpr.includes('^')) {
            safeExpr = safeExpr.replace(/\^/g, '**');
          }
        }

        // Replace x with actual value, carefully wrapped
        safeExpr = safeExpr.replace(/\bx\b/g, `(${xVal})`);

        // Evaluate
        const result = new Function(`return ${safeExpr}`)();

        if (typeof result !== 'number' || isNaN(result)) {
          return null;
        }
        return result;
      } catch (e) {
        return null;
      }
    }

    function formatNumber(num) {
      if (Math.abs(num) > 1e10) return "∞";
      if (Math.abs(num) < 1e-10) return "0";

      // Round to 5 decimal places to eliminate floating point artifacts
      return Number(Math.round(num + "e5") + "e-5").toString();
    }

    function calculateLimit() {
      const expr = inputFunction.value.trim();
      const targetStr = inputTarget.value.trim().toLowerCase();
      const direction = selectDirection.value;

      errorState.style.display = 'none';
      resultValue.style.color = 'var(--accent-color)';

      if (!expr) {
        showError("Please enter a valid function.");
        return;
      }

      let a;
      let isInfinity = false;

      if (targetStr === 'infinity' || targetStr === 'inf' || targetStr === '∞') {
        a = 1e9; // Large number for infinity approx
        isInfinity = true;
      } else if (targetStr === '-infinity' || targetStr === '-inf' || targetStr === '-∞') {
        a = -1e9;
        isInfinity = true;
      } else {
        a = parseFloat(targetStr);
        if (isNaN(a)) {
          showError("Target must be a number or 'infinity'.");
          return;
        }
      }

      const delta = isInfinity ? (a * 0.99) : 1e-7; // Tiny step

      // Test points
      const xLeft = isInfinity ? (a > 0 ? a * 0.1 : a * 10) : a - delta;
      const xRight = isInfinity ? (a > 0 ? a * 10 : a * 0.1) : a + delta;

      const yLeft = parseExpression(expr, xLeft);
      const yRight = parseExpression(expr, xRight);

      if (yLeft === null && yRight === null) {
        showError("Invalid mathematical expression. Check syntax (e.g., use brackets).");
        return;
      }

      breakdown.style.display = 'block';

      let leftFormatted = yLeft !== null ? formatNumber(yLeft) : 'Undefined';
      let rightFormatted = yRight !== null ? formatNumber(yRight) : 'Undefined';

      leftValSpan.textContent = leftFormatted;
      rightValSpan.textContent = rightFormatted;

      let finalLimit = "Undefined";

      if (direction === 'left') {
        finalLimit = leftFormatted;
        breakdown.style.display = 'none';
      } else if (direction === 'right') {
        finalLimit = rightFormatted;
        breakdown.style.display = 'none';
      } else {
        // Two-sided
        if (leftFormatted === rightFormatted && leftFormatted !== 'Undefined') {
          finalLimit = leftFormatted;
        } else if (leftFormatted === '∞' && rightFormatted === '∞') {
          finalLimit = '∞';
        } else if (leftFormatted === '-∞' && rightFormatted === '-∞') {
          finalLimit = '-∞';
        } else {
          finalLimit = "Does Not Exist (DNE)";
          resultValue.style.color = 'var(--text-primary)';
        }
      }

      resultValue.textContent = finalLimit;
    }

    function showError(msg) {
      errorState.textContent = msg;
      errorState.style.display = 'block';
      resultValue.textContent = "--";
      breakdown.style.display = 'none';
    }

    inputFunction.addEventListener('input', calculateLimit);
    inputTarget.addEventListener('input', calculateLimit);
    selectDirection.addEventListener('change', calculateLimit);

    // Initial calc
    calculateLimit();
  </script>

