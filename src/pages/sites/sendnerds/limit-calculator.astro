    .explainer li { margin-bottom: 0.5rem; }

    .formula-block { font-family: 'Courier New', Courier, monospace; background: var(--bg-color); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); text-align: center; font-size: 1.2rem; font-weight: 600; color: var(--text-primary); margin: 1.5rem 0; }
    code { background: var(--bg-color); border: 1px solid var(--border-color); padding: 0.2rem 0.4rem; border-radius: 4px; font-family: monospace; font-size: 0.9em; }

    .faq-section { margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 2rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; list-style-position: inside; }
    .faq-section details p { margin: 1rem 0 0 0; color: var(--text-secondary); line-height: 1.6; }

    @media (max-width: 600px) {
      .target-group { grid-template-columns: 1fr; }
      .result-breakdown { flex-direction: column; gap: 0.5rem; }
    }
  </style>

