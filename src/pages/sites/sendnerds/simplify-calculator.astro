  <script is:inline>
    // Simplification Logic
    function gcd(a, b) {
      a = Math.abs(a);
      b = Math.abs(b);
      while (b) {
        let t = b;
        b = a % b;
        a = t;
      }
      return a;
    }

    function simplifyFraction(numerator, denominator) {
      if (denominator === 0) return "Error: Division by zero";
      if (numerator === 0) return "0";

      let divisor = gcd(numerator, denominator);
      let num = numerator / divisor;
      let den = denominator / divisor;

      // Handle signs
      if (den < 0) {
        num = -num;
        den = -den;
      }

      if (den === 1) return num.toString();
      return num + "/" + den;
    }

    // Basic polynomial term parsing
    // e.g. "3x^2", "-x", "5"
    function parseTerms(expr) {
      // Remove spaces
      expr = expr.replace(/\s+/g, "");

      // Match terms like +3x^2, -5y, +x, -2
      let termsMatch = expr.match(/[+-]?[^+-]+/g);
      if (!termsMatch) return null;

      let parsedTerms = [];
      for (let t of termsMatch) {
        if (!t) continue;

        // Extract sign
        let sign = 1;
        let rest = t;
        if (t[0] === '+') { sign = 1; rest = t.substring(1); }
        else if (t[0] === '-') { sign = -1; rest = t.substring(1); }

        // Extract coefficient
        let coeffMatch = rest.match(/^(\d*\.?\d*)/);
        let coeffStr = coeffMatch ? coeffMatch[1] : "";
        let coeff = 1;
        if (coeffStr !== "") {
          coeff = parseFloat(coeffStr);
        } else if (rest.match(/^[a-zA-Z]/)) {
          coeff = 1; // e.g. "x" -> coeff 1
        } else {
           continue; // likely empty
        }

        // Extract variable and exponent
        let varStr = rest.substring(coeffStr.length);

        parsedTerms.push({ coeff: coeff * sign, var: varStr });
      }
      return parsedTerms;
    }

    function simplifyPolynomials(expr) {
      // Very basic addition/subtraction of like terms
      let terms = parseTerms(expr);
      if (!terms || terms.length === 0) return null;

      let combined = {};
      for (let t of terms) {
        if (combined[t.var] === undefined) combined[t.var] = 0;
        combined[t.var] += t.coeff;
      }

      let vars = Object.keys(combined);

      // Sort vars: constants (empty string) last, then alphabetically
      vars.sort((a, b) => {
        if (a === "" && b !== "") return 1;
        if (a !== "" && b === "") return -1;
        return a.localeCompare(b);
      });

      let result = "";
      for (let i = 0; i < vars.length; i++) {
        let v = vars[i];
        let c = combined[v];
        if (Math.abs(c) < 1e-10) continue; // Skip zero coefficients

        // Format coefficient
        let cStr = c.toString();
        if (v !== "") {
           if (c === 1) cStr = "";
           if (c === -1) cStr = "-";
        }

        // Format term
        let termStr = cStr + v;

        if (result === "") {
          result = termStr;
        } else {
          if (c > 0) result += " + " + termStr;
          else result += " - " + termStr.replace(/^-/, ""); // Remove internal minus
        }
      }

      if (result === "") return "0";
      return result;
    }

    function simplifyExpression(input) {
      input = input.trim();
      if (!input) return "";

      // Check if it's a simple fraction like a/b
      let fractionMatch = input.match(/^(-?\d+)\s*\/\s*(-?\d+)$/);
      if (fractionMatch) {
        return simplifyFraction(parseInt(fractionMatch[1], 10), parseInt(fractionMatch[2], 10));
      }

      // Check if it's polynomial addition/subtraction
      // Only allow characters: 0-9, a-z, A-Z, +, -, ., ^, space
      if (/^[a-zA-Z0-9+\-\.\^\s]+$/.test(input) && !input.includes('/')) {
         let polyRes = simplifyPolynomials(input);
         if (polyRes !== null && polyRes !== input.replace(/\s+/g,"")) {
            return polyRes;
         }
      }

      // Safe evaluate simple arithmetic without letters
      if (/^[0-9+\-*/().\s]+$/.test(input)) {
        try {
          // Safe eval using Function
          let res = new Function('return ' + input)();
          if (Number.isFinite(res)) {
            // Check if it's an integer
            if (Number.isInteger(res)) return res.toString();
            // Otherwise round to 4 decimal places to avoid float issues
            return Math.round(res * 10000) / 10000;
          }
        } catch (e) {
          // ignore error and fall through
        }
      }

      return null;
    }

    const inputEl = document.getElementById('expression-input');
    const errorEl = document.getElementById('error-message');
    const resultCard = document.getElementById('result-card');
    const resultDisplay = document.getElementById('result-display');

    inputEl.addEventListener('input', function() {
      const val = this.value;
      if (!val) {
        errorEl.style.display = 'none';
        resultCard.style.display = 'none';
        return;
      }

      const result = simplifyExpression(val);

      if (result !== null && result !== "" && !result.toString().startsWith("Error")) {
        errorEl.style.display = 'none';
        resultDisplay.textContent = result;
        resultCard.style.display = 'block';
      } else if (result && result.toString().startsWith("Error")) {
        errorEl.style.display = 'block';
        errorEl.textContent = result;
        resultCard.style.display = 'none';
      } else {
        // Invalid or unsupported expression format
        let isComplex = /[a-zA-Z]/.test(val) && /[\*\/()]/.test(val);
        if (isComplex) {
           errorEl.style.display = 'block';
           errorEl.textContent = "Complex algebraic expressions with multiplication/division of variables are currently unsupported in this basic version. Try addition/subtraction of like terms or numeric fractions.";
        } else {
           errorEl.style.display = 'none';
        }
        resultCard.style.display = 'none';
      }
    });
  </script>

