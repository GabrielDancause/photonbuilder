  { name: "University of Wisconsin-Madison", range: "1350 - 1510" },
  { name: "Boston University", range: "1400 - 1540" },
  { name: "University of Illinois Urbana-Champaign", range: "1340 - 1530" },
  { name: "William & Mary", range: "1360 - 1520" },
  { name: "Brandeis University", range: "1370 - 1530" },
  { name: "Case Western Reserve University", range: "1420 - 1520" },
  { name: "Georgia Institute of Technology", range: "1370 - 1530" },
  { name: "Northeastern University", range: "1430 - 1550" },
  { name: "Tulane University", range: "1380 - 1500" },
  { name: "Ohio State University", range: "1330 - 1460" },
