  { name: "Purdue University", range: "1260 - 1480" },
  { name: "Villanova University", range: "1360 - 1500" },
  { name: "Lehigh University", range: "1340 - 1490" }
];

const stateAverages = [
  { state: "Massachusetts", score: 1126 },
  { state: "Connecticut", score: 1045 },
  { state: "New Jersey", score: 1081 },
  { state: "New York", score: 1053 },
  { state: "California", score: 1083 },
  { state: "Texas", score: 978 },
  { state: "Florida", score: 966 },
  { state: "Illinois", score: 975 },
  { state: "Michigan", score: 971 },
  { state: "Pennsylvania", score: 1074 },
  { state: "Ohio", score: 1041 },
  { state: "Georgia", score: 1045 },
  { state: "Virginia", score: 1113 },
  { state: "Washington", score: 1082 },
  { state: "Colorado", score: 996 }
