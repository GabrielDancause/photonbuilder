---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Grade Calculator — Weighted, Final Exam & GPA",
  description: "Calculate your weighted grade average, find out what you need on your final exam, and convert between letter grades and GPA. Add assignments dynamically, visualize grade ranges, and run what-if scenarios.",
  category: "tool",
  published: "2026-03-21",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I calculate my weighted grade?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To calculate a weighted grade, multiply each assignment score by its weight (as a decimal), then add the results together. For example, if you scored 90% on homework worth 30% of your grade and 80% on an exam worth 70%, your weighted grade is (90 × 0.30) + (80 × 0.70) = 27 + 56 = 83%. Our calculator handles this automatically — just enter each assignment's score and weight."
        }
      },
      {
        "@type": "Question",
        "name": "What grade do I need on my final exam?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Use the formula: Required Final Score = (Desired Grade − Current Grade × (1 − Final Weight)) ÷ Final Weight. For example, if your current grade is 85%, the final is worth 30%, and you want a 90%, you need: (90 − 85 × 0.70) ÷ 0.30 = (90 − 59.5) ÷ 0.30 = 101.7%. Our Final Grade Calculator tab does this math instantly."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between weighted and unweighted grades?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An unweighted grade treats all assignments equally — a quiz and a midterm each count the same toward your average. A weighted grade assigns different importance to different categories. For instance, exams might count for 50% of your grade while homework counts for 20%. Most college courses use weighted grading because it lets professors emphasize the assessments that best measure learning."
        }
      },
      {
        "@type": "Question",
        "name": "How do letter grades convert to GPA?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "On the standard 4.0 scale used by most US colleges: A = 4.0, A− = 3.7, B+ = 3.3, B = 3.0, B− = 2.7, C+ = 2.3, C = 2.0, C− = 1.7, D+ = 1.3, D = 1.0, D− = 0.7, and F = 0.0. Some schools use plus/minus grading while others do not. Weighted GPAs at the high school level may exceed 4.0 when honors or AP courses add extra points."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if my assignment weights don't add up to 100%?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If your weights total less than 100%, it usually means some assignments haven't been graded yet. Our calculator normalizes the result by dividing the weighted total by the sum of entered weights, giving you an accurate current average. If weights exceed 100%, double-check your entries — this typically indicates a data-entry error, though some syllabi intentionally offer extra-credit categories that push the total above 100%."
        }
      },
      {
        "@type": "Question",
        "name": "How do I use the what-if analysis feature?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The what-if analysis lets you see how different scores on upcoming assignments would affect your overall grade. After entering your current assignments, use the what-if section to input a hypothetical score for your next assignment and its weight. The calculator instantly shows your projected final grade, helping you decide how much effort to invest in each remaining assignment or whether you can skip the final and still pass."
        }
      },
      {
        "@type": "Question",
        "name": "Can I calculate my grade if I have both weighted categories and individual assignments?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Enter each individual assignment as its own row with the appropriate weight. For example, if exams are worth 60% of your grade and you have two exams, enter each exam with a weight of 30%. If homework is worth 20% and you have 10 homework assignments, each one gets a weight of 2%. The calculator treats every row independently, so you can mix category-level weights and individual assignment weights as needed."
        }
      },
      {
        "@type": "Question",
        "name": "What is a good GPA for college admissions or graduate school?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For competitive undergraduate admissions, a GPA of 3.5 or higher (on a 4.0 scale) is generally considered strong. Ivy League and top-tier universities often expect 3.8 or above. For graduate school, most programs require a minimum of 3.0 for admission, though competitive programs in fields like law, medicine, and engineering often prefer 3.5 or higher. Keep in mind that GPA is only one factor — admissions committees also weigh test scores, extracurriculars, essays, and recommendations."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="sendnerds"
  title={meta.title}
  description={meta.description}
  canonical="https://photonbuilder.com/sendnerds/grade-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Grade Calculator</h1>
      <p class="subtitle">Calculate weighted averages, find out what you need on your final, and convert letter grades to GPA — all in one tool.</p>
    </div>

    <div class="calculator-container">
      <!-- Mode Tabs -->
      <div class="mode-tabs" id="mode-tabs">
        <button class="mode-btn active" data-mode="weighted">Weighted Grade</button>
        <button class="mode-btn" data-mode="final">Final Grade Calculator</button>
        <button class="mode-btn" data-mode="gpa">GPA Converter</button>
      </div>

      <!-- ========== WEIGHTED GRADE MODE ========== -->
      <div class="mode-panel active" id="panel-weighted">
        <div class="tool-grid">
          <div class="input-section">
            <h3 class="section-heading">Assignments</h3>
            <div class="assignment-table" id="assignment-table">
              <div class="table-header">
                <span class="col-name">Assignment</span>
                <span class="col-score">Score (%)</span>
                <span class="col-weight">Weight (%)</span>
                <span class="col-del"></span>
              </div>
              <div id="assignment-rows"></div>
            </div>
            <button id="add-row-btn" class="action-btn small-btn">+ Add Assignment</button>
            <button id="calc-weighted-btn" class="primary-btn">Calculate Grade</button>

            <!-- What-if Analysis -->
            <div class="whatif-section" id="whatif-section" style="display:none">
              <h3 class="section-heading">What-If Analysis</h3>
              <p class="hint-text">See how a future assignment score affects your overall grade.</p>
              <div class="whatif-inputs">
                <div class="input-group">
                  <label for="whatif-score">Hypothetical Score (%)</label>
                  <input type="number" id="whatif-score" min="0" max="200" placeholder="e.g., 85">
                </div>
                <div class="input-group">
                  <label for="whatif-weight">Weight (%)</label>
                  <input type="number" id="whatif-weight" min="0" max="100" placeholder="e.g., 20">
                </div>
              </div>
              <button id="calc-whatif-btn" class="action-btn">Calculate What-If</button>
              <div id="whatif-result" class="whatif-result"></div>
            </div>
          </div>

          <div class="output-section">
            <div class="results-sticky">
              <h3>Your Grade</h3>
              <div id="weighted-result" class="grade-result">
                <p class="placeholder-text">Add your assignments and click <strong>Calculate Grade</strong> to see your weighted average.</p>
              </div>
              <div id="grade-bar-container" class="grade-bar-container" style="display:none">
                <div class="grade-bar">
                  <div class="grade-segment seg-a">A</div>
                  <div class="grade-segment seg-b">B</div>
                  <div class="grade-segment seg-c">C</div>
                  <div class="grade-segment seg-d">D</div>
                  <div class="grade-segment seg-f">F</div>
                  <div class="grade-marker" id="grade-marker"></div>
                </div>
                <div class="grade-labels">
                  <span>100</span><span>90</span><span>80</span><span>70</span><span>60</span><span>0</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ========== FINAL GRADE MODE ========== -->
      <div class="mode-panel" id="panel-final">
        <div class="tool-grid">
          <div class="input-section">
            <h3 class="section-heading">Final Exam Calculator</h3>
            <p class="hint-text">Find the minimum score you need on your final to reach your target grade.</p>
            <div class="input-group">
              <label for="current-grade">Current Grade (%)</label>
              <input type="number" id="current-grade" min="0" max="200" step="0.1" placeholder="e.g., 85">
            </div>
            <div class="input-group">
              <label for="final-weight">Final Exam Weight (%)</label>
              <input type="number" id="final-weight" min="0" max="100" step="0.1" placeholder="e.g., 30">
            </div>
            <div class="input-group">
              <label for="desired-grade">Desired Final Grade (%)</label>
              <input type="number" id="desired-grade" min="0" max="100" step="0.1" placeholder="e.g., 90">
            </div>
            <button id="calc-final-btn" class="primary-btn">Calculate Required Score</button>
          </div>

          <div class="output-section">
            <div class="results-sticky">
              <h3>Required Final Score</h3>
              <div id="final-result" class="grade-result">
                <p class="placeholder-text">Enter your current grade, final exam weight, and desired grade to see what score you need.</p>
              </div>
              <!-- Quick targets -->
              <div id="final-targets" class="final-targets" style="display:none">
                <h4>Score Needed for Each Letter Grade</h4>
                <div id="targets-list" class="targets-list"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ========== GPA CONVERTER MODE ========== -->
      <div class="mode-panel" id="panel-gpa">
        <div class="tool-grid">
          <div class="input-section">
            <h3 class="section-heading">GPA Converter</h3>
            <p class="hint-text">Convert between letter grades, percentages, and GPA on the 4.0 scale.</p>
            <div class="input-group">
              <label for="gpa-input-type">Convert From</label>
              <select id="gpa-input-type">
                <option value="letter">Letter Grade</option>
                <option value="percentage">Percentage</option>
                <option value="gpa">GPA (4.0 scale)</option>
              </select>
            </div>
            <div id="gpa-input-field"></div>
            <button id="calc-gpa-btn" class="primary-btn">Convert</button>
          </div>

          <div class="output-section">
            <div class="results-sticky">
              <h3>Conversion Result</h3>
              <div id="gpa-result" class="grade-result">
                <p class="placeholder-text">Select an input type, enter a value, and click <strong>Convert</strong> to see the equivalent grades.</p>
              </div>
              <div class="gpa-reference" id="gpa-reference">
                <h4>Full GPA Scale Reference</h4>
                <table class="gpa-table">
                  <thead><tr><th>Letter</th><th>GPA</th><th>Percentage</th></tr></thead>
                  <tbody>
                    <tr><td>A+</td><td>4.0</td><td>97 – 100</td></tr>
                    <tr><td>A</td><td>4.0</td><td>93 – 96</td></tr>
                    <tr><td>A−</td><td>3.7</td><td>90 – 92</td></tr>
                    <tr><td>B+</td><td>3.3</td><td>87 – 89</td></tr>
                    <tr><td>B</td><td>3.0</td><td>83 – 86</td></tr>
                    <tr><td>B−</td><td>2.7</td><td>80 – 82</td></tr>
                    <tr><td>C+</td><td>2.3</td><td>77 – 79</td></tr>
                    <tr><td>C</td><td>2.0</td><td>73 – 76</td></tr>
                    <tr><td>C−</td><td>1.7</td><td>70 – 72</td></tr>
                    <tr><td>D+</td><td>1.3</td><td>67 – 69</td></tr>
                    <tr><td>D</td><td>1.0</td><td>63 – 66</td></tr>
                    <tr><td>D−</td><td>0.7</td><td>60 – 62</td></tr>
                    <tr><td>F</td><td>0.0</td><td>0 – 59</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Explainer -->
    <div class="explainer">
      <h2>How to Calculate Your Grade: A Complete Guide</h2>
      <p>Understanding how grades are calculated is essential for every student. Whether you are tracking your progress midway through a semester or planning how much effort to put into your final exam, knowing the math behind your grade gives you control over your academic outcomes. This guide covers weighted averages, final exam score calculations, GPA conversions, and strategies for using grade calculators effectively.</p>

      <h3>Understanding Weighted Grades</h3>
      <p>Most college and university courses use weighted grading systems. Rather than treating every assignment equally, professors assign different weights to different categories of work. A typical syllabus might allocate 15% to participation, 25% to homework, 25% to midterms, and 35% to the final exam. This means your final exam has more than twice the impact on your grade as your homework assignments combined.</p>
      <p>To calculate a weighted average manually, multiply each assignment's percentage score by its decimal weight (divide the weight percentage by 100), then sum all the products. If you scored 92% on homework (weight 25%) and 78% on a midterm (weight 25%), your weighted total so far is (92 × 0.25) + (78 × 0.25) = 23 + 19.5 = 42.5 out of 50 possible points, or 85% of the graded portion. Our weighted grade calculator handles this arithmetic automatically, normalizing for any ungraded weight.</p>

      <h3>What Grade Do I Need on My Final?</h3>
      <p>The final exam calculator answers the most common question students ask at the end of every semester: "What do I need on the final to get an A?" The formula is straightforward: Required Score = (Target Grade − Current Grade × (1 − Final Weight)) ÷ Final Weight. If your current grade is 88%, the final is worth 40% of your grade, and you want a 90%, you need (90 − 88 × 0.60) ÷ 0.40 = (90 − 52.8) ÷ 0.40 = 93%. Our calculator also shows you the score needed for every letter grade so you can set realistic goals.</p>

      <h3>GPA Conversion and What It Means</h3>
      <p>The Grade Point Average converts letter grades to a numerical scale, most commonly the 4.0 scale used across the United States. Each letter grade maps to a specific number of grade points: an A earns 4.0 points, a B earns 3.0, a C earns 2.0, a D earns 1.0, and an F earns 0. Plus and minus modifiers shift the value by 0.3 points (e.g., B+ = 3.3, B− = 2.7). Your cumulative GPA is the weighted average of grade points across all courses, with each course weighted by its credit hours.</p>
      <p>Understanding GPA thresholds matters for practical reasons: a 2.0 is the minimum to avoid academic probation at most schools, a 3.0 often qualifies you for the dean's list or graduate program admission, and a 3.5 or above signals high academic achievement for scholarships and competitive applications.</p>

      <h3>Explore More Academic Tools</h3>
      <p>Building a bibliography for a research paper? Our <a href="/citation-generator">Citation Generator</a> formats references in APA, MLA, Chicago, and Harvard styles instantly. For tracking your cumulative GPA across semesters, check out our <a href="/college-gpa-calculator">College GPA Calculator</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map(faq => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // ---- Mode Tabs ----
      const modeBtns = document.querySelectorAll('.mode-btn');
      const modePanels = document.querySelectorAll('.mode-panel');

      modeBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          modeBtns.forEach(b => b.classList.remove('active'));
          modePanels.forEach(p => p.classList.remove('active'));
          btn.classList.add('active');
          document.getElementById('panel-' + btn.dataset.mode).classList.add('active');
        });
      });

      // ---- GPA Scale Data ----
      const gpaScale = [
        { letter: 'A+', gpa: 4.0, min: 97, max: 100 },
        { letter: 'A',  gpa: 4.0, min: 93, max: 96 },
        { letter: 'A\u2212', gpa: 3.7, min: 90, max: 92 },
        { letter: 'B+', gpa: 3.3, min: 87, max: 89 },
        { letter: 'B',  gpa: 3.0, min: 83, max: 86 },
        { letter: 'B\u2212', gpa: 2.7, min: 80, max: 82 },
        { letter: 'C+', gpa: 2.3, min: 77, max: 79 },
        { letter: 'C',  gpa: 2.0, min: 73, max: 76 },
        { letter: 'C\u2212', gpa: 1.7, min: 70, max: 72 },
        { letter: 'D+', gpa: 1.3, min: 67, max: 69 },
        { letter: 'D',  gpa: 1.0, min: 63, max: 66 },
        { letter: 'D\u2212', gpa: 0.7, min: 60, max: 62 },
        { letter: 'F',  gpa: 0.0, min: 0,  max: 59 }
      ];

      // ========== WEIGHTED GRADE ==========
      const assignmentRows = document.getElementById('assignment-rows');
      const addRowBtn = document.getElementById('add-row-btn');
      const calcWeightedBtn = document.getElementById('calc-weighted-btn');
      const weightedResult = document.getElementById('weighted-result');
      const gradeBarContainer = document.getElementById('grade-bar-container');
      const gradeMarker = document.getElementById('grade-marker');
      const whatifSection = document.getElementById('whatif-section');
      let rowCount = 0;

      function addRow(name, score, weight) {
        rowCount++;
        const row = document.createElement('div');
        row.className = 'assignment-row';
        row.dataset.id = rowCount;
        row.innerHTML =
          '<input type="text" class="row-name" placeholder="Assignment ' + rowCount + '" value="' + (name || '') + '">' +
          '<input type="number" class="row-score" min="0" max="200" step="0.1" placeholder="0-100" value="' + (score !== undefined ? score : '') + '">' +
          '<input type="number" class="row-weight" min="0" max="100" step="0.1" placeholder="%" value="' + (weight !== undefined ? weight : '') + '">' +
          '<button class="del-row-btn" title="Remove">\u00d7</button>';
        assignmentRows.appendChild(row);
        row.querySelector('.del-row-btn').addEventListener('click', () => {
          row.remove();
          if (assignmentRows.children.length === 0) addRow();
        });
      }

      // Start with 3 empty rows
      addRow(); addRow(); addRow();

      addRowBtn.addEventListener('click', () => addRow());

      function getAssignments() {
        const rows = assignmentRows.querySelectorAll('.assignment-row');
        const items = [];
        rows.forEach(r => {
          const score = parseFloat(r.querySelector('.row-score').value);
          const weight = parseFloat(r.querySelector('.row-weight').value);
          if (!isNaN(score) && !isNaN(weight) && weight > 0) {
            items.push({ name: r.querySelector('.row-name').value || 'Assignment', score, weight });
          }
        });
        return items;
      }

      function calcWeighted(items) {
        if (!items.length) return null;
        let totalWeighted = 0, totalWeight = 0;
        items.forEach(a => { totalWeighted += a.score * a.weight; totalWeight += a.weight; });
        return totalWeight > 0 ? totalWeighted / totalWeight : null;
      }

      function letterFromPct(pct) {
        for (const g of gpaScale) { if (pct >= g.min) return g.letter; }
        return 'F';
      }

      function gpaFromPct(pct) {
        for (const g of gpaScale) { if (pct >= g.min) return g.gpa; }
        return 0.0;
      }

      function positionMarker(pct) {
        const clamped = Math.max(0, Math.min(100, pct));
        const pos = 100 - clamped;
        gradeMarker.style.left = pos + '%';
        gradeMarker.textContent = Math.round(pct * 10) / 10 + '%';
        gradeBarContainer.style.display = 'block';
      }

      calcWeightedBtn.addEventListener('click', () => {
        const items = getAssignments();
        if (!items.length) {
          weightedResult.innerHTML = '<p class="error-msg">Enter at least one assignment with a score and weight.</p>';
          gradeBarContainer.style.display = 'none';
          whatifSection.style.display = 'none';
          return;
        }
        const avg = calcWeighted(items);
        const letter = letterFromPct(avg);
        const gpa = gpaFromPct(avg);
        const totalWeight = items.reduce((s, a) => s + a.weight, 0);

        let html = '<div class="result-big">' + avg.toFixed(2) + '%</div>';
        html += '<div class="result-details">';
        html += '<span class="result-letter">' + letter + '</span>';
        html += '<span class="result-gpa">GPA: ' + gpa.toFixed(1) + '</span>';
        html += '</div>';
        if (Math.abs(totalWeight - 100) > 0.1) {
          html += '<p class="weight-note">Weights total ' + totalWeight.toFixed(1) + '% \u2014 result normalized to graded portion.</p>';
        }
        weightedResult.innerHTML = html;
        positionMarker(avg);
        whatifSection.style.display = 'block';
      });

      // ---- What-If ----
      const whatifScoreEl = document.getElementById('whatif-score');
      const whatifWeightEl = document.getElementById('whatif-weight');
      const calcWhatifBtn = document.getElementById('calc-whatif-btn');
      const whatifResultEl = document.getElementById('whatif-result');

      calcWhatifBtn.addEventListener('click', () => {
        const items = getAssignments();
        const ws = parseFloat(whatifScoreEl.value);
        const ww = parseFloat(whatifWeightEl.value);
        if (isNaN(ws) || isNaN(ww) || ww <= 0) {
          whatifResultEl.innerHTML = '<p class="error-msg">Enter a valid score and weight for the hypothetical assignment.</p>';
          return;
        }
        const combined = [...items, { name: 'What-If', score: ws, weight: ww }];
        const avg = calcWeighted(combined);
        const baseAvg = calcWeighted(items);
        const diff = avg - (baseAvg || 0);
        const sign = diff >= 0 ? '+' : '';
        whatifResultEl.innerHTML =
          '<div class="whatif-card">' +
          '<span class="whatif-projected">' + avg.toFixed(2) + '% (' + letterFromPct(avg) + ')</span>' +
          '<span class="whatif-diff">' + sign + diff.toFixed(2) + '% from current</span>' +
          '</div>';
        positionMarker(avg);
      });

      // ========== FINAL GRADE CALCULATOR ==========
      const calcFinalBtn = document.getElementById('calc-final-btn');
      const finalResult = document.getElementById('final-result');
      const finalTargets = document.getElementById('final-targets');
      const targetsList = document.getElementById('targets-list');

      calcFinalBtn.addEventListener('click', () => {
        const current = parseFloat(document.getElementById('current-grade').value);
        const weight = parseFloat(document.getElementById('final-weight').value);
        const desired = parseFloat(document.getElementById('desired-grade').value);
        if (isNaN(current) || isNaN(weight) || isNaN(desired)) {
          finalResult.innerHTML = '<p class="error-msg">Please fill in all three fields.</p>';
          finalTargets.style.display = 'none';
          return;
        }
        const w = weight / 100;
        const needed = (desired - current * (1 - w)) / w;

        let html = '<div class="result-big">' + needed.toFixed(2) + '%</div>';
        if (needed > 100) {
          html += '<p class="warning-msg">You need above 100% \u2014 this may not be achievable without extra credit.</p>';
        } else if (needed < 0) {
          html += '<p class="success-msg">You could score 0% on the final and still reach your target!</p>';
        } else {
          html += '<p class="result-details">Score at least <strong>' + needed.toFixed(1) + '%</strong> on your final (worth ' + weight + '% of your grade) to finish with a ' + desired + '%.</p>';
        }
        finalResult.innerHTML = html;

        // Show targets for each letter grade
        const letterTargets = [
          { letter: 'A', min: 93 }, { letter: 'A\u2212', min: 90 },
          { letter: 'B+', min: 87 }, { letter: 'B', min: 83 },
          { letter: 'B\u2212', min: 80 }, { letter: 'C+', min: 77 },
          { letter: 'C', min: 73 }, { letter: 'D', min: 63 }
        ];
        let targetsHtml = '';
        letterTargets.forEach(t => {
          const req = (t.min - current * (1 - w)) / w;
          let status = '';
          if (req > 100) status = ' <span class="tag-hard">Needs extra credit</span>';
          else if (req < 0) status = ' <span class="tag-easy">Guaranteed</span>';
          targetsHtml += '<div class="target-row"><span class="target-letter">' + t.letter + ' (' + t.min + '%)</span><span class="target-score">' + Math.max(0, req).toFixed(1) + '%' + status + '</span></div>';
        });
        targetsList.innerHTML = targetsHtml;
        finalTargets.style.display = 'block';
      });

      // ========== GPA CONVERTER ==========
      const gpaInputType = document.getElementById('gpa-input-type');
      const gpaInputField = document.getElementById('gpa-input-field');
      const calcGpaBtn = document.getElementById('calc-gpa-btn');
      const gpaResult = document.getElementById('gpa-result');

      function renderGpaInput() {
        const type = gpaInputType.value;
        if (type === 'letter') {
          let opts = gpaScale.map(g => '<option value="' + g.letter + '">' + g.letter + '</option>').join('');
          gpaInputField.innerHTML = '<div class="input-group"><label for="gpa-value">Letter Grade</label><select id="gpa-value">' + opts + '</select></div>';
        } else if (type === 'percentage') {
          gpaInputField.innerHTML = '<div class="input-group"><label for="gpa-value">Percentage (%)</label><input type="number" id="gpa-value" min="0" max="100" step="0.1" placeholder="e.g., 85"></div>';
        } else {
          gpaInputField.innerHTML = '<div class="input-group"><label for="gpa-value">GPA</label><input type="number" id="gpa-value" min="0" max="4.0" step="0.1" placeholder="e.g., 3.5"></div>';
        }
      }
      renderGpaInput();
      gpaInputType.addEventListener('change', renderGpaInput);

      calcGpaBtn.addEventListener('click', () => {
        const type = gpaInputType.value;
        const valEl = document.getElementById('gpa-value');
        const val = valEl.value;
        if (!val && val !== '0') {
          gpaResult.innerHTML = '<p class="error-msg">Please enter a value.</p>';
          return;
        }
        let letter, gpa, pctRange;

        if (type === 'letter') {
          const match = gpaScale.find(g => g.letter === val);
          if (!match) { gpaResult.innerHTML = '<p class="error-msg">Invalid letter grade.</p>'; return; }
          letter = match.letter;
          gpa = match.gpa;
          pctRange = match.min + ' \u2013 ' + match.max + '%';
        } else if (type === 'percentage') {
          const pct = parseFloat(val);
          if (isNaN(pct) || pct < 0 || pct > 100) { gpaResult.innerHTML = '<p class="error-msg">Enter a percentage between 0 and 100.</p>'; return; }
          const match = gpaScale.find(g => pct >= g.min);
          letter = match ? match.letter : 'F';
          gpa = match ? match.gpa : 0.0;
          pctRange = pct.toFixed(1) + '%';
        } else {
          const g = parseFloat(val);
          if (isNaN(g) || g < 0 || g > 4.0) { gpaResult.innerHTML = '<p class="error-msg">Enter a GPA between 0.0 and 4.0.</p>'; return; }
          let best = gpaScale[gpaScale.length - 1];
          for (const row of gpaScale) {
            if (g >= row.gpa - 0.15) { best = row; break; }
          }
          letter = best.letter;
          gpa = best.gpa;
          pctRange = best.min + ' \u2013 ' + best.max + '%';
        }

        gpaResult.innerHTML =
          '<div class="gpa-conversion-result">' +
          '<div class="conv-item"><span class="conv-label">Letter Grade</span><span class="conv-value">' + letter + '</span></div>' +
          '<div class="conv-item"><span class="conv-label">GPA (4.0)</span><span class="conv-value">' + gpa.toFixed(1) + '</span></div>' +
          '<div class="conv-item"><span class="conv-label">Percentage</span><span class="conv-value">' + pctRange + '</span></div>' +
          '</div>';
      });
    });
  </script>

