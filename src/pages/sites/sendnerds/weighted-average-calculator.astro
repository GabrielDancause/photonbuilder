---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Weighted Average Calculator | Sendnerds',
  description: 'Calculate weighted averages instantly. Add items with values and weights, see calculation steps, visualize the contribution of each item, and understand your data.',
  category: 'tool',
  keywords: ['weighted average calculator', 'calculate weighted average', 'weighted mean calculator', 'grade calculator', 'portfolio weight calculator', 'weighted score']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Weighted Average Calculator | Sendnerds",
    "description": "Calculate weighted averages instantly. Add items with values and weights, see calculation steps, visualize the contribution of each item, and understand your data.",
    "author": {
      "@type": "Organization",
      "name": "sendnerds.photonbuilder.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "sendnerds.photonbuilder.com"
    },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you calculate a weighted average?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To calculate a weighted average, multiply each value by its assigned weight. Then, sum all these calculated products together. Finally, divide this sum by the total sum of all weights."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between a simple average and a weighted average?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A simple average treats all values equally by adding them up and dividing by the count. A weighted average assigns a specific weight (or importance) to each value, so some values contribute more to the final result than others."
        }
      },
      {
        "@type": "Question",
        "name": "Can weights be percentages or decimals?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, weights can be represented as percentages, decimals, or whole numbers. The calculation method remains the same regardless of the format, as long as you divide the sum of the products by the sum of the weights."
        }
      },
      {
        "@type": "Question",
        "name": "Why are weighted averages used in grading?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Weighted averages are used in grading to give different assignments varying levels of importance. For instance, a final exam might be worth 40% of the overall grade, while homework is only worth 10%."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if my weights don't add up to 100% or 1?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If weights do not add up to 100% or 1, you simply divide the sum of the weighted values by the actual total sum of the weights provided. The formula inherently accounts for any total weight."
        }
      }
    ]
  }
]);
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <main class="wa-container">
    <section class="wa-hero">
      <div class="wa-hero-content">
        <h1 class="wa-hero-title">Weighted Average Calculator</h1>
        <p class="wa-hero-subtitle">Instantly calculate your weighted average with complete transparency. Add items with their values and weights, visualize the impact of each entry, and master your data with our interactive tool.</p>
        <div class="wa-hero-stats">
          <div class="wa-stat-badge"><span>✓</span> 100% Client-Side</div>
          <div class="wa-stat-badge"><span>✓</span> Visual Charts</div>
          <div class="wa-stat-badge"><span>✓</span> Step-by-Step Breakdown</div>
        </div>
        <a href="#calculator" class="wa-btn wa-btn-primary">Start Calculating</a>
      </div>
    </section>

    <section id="calculator" class="wa-calculator-section">
      <div class="wa-calc-grid">
        <div class="wa-calc-input-panel">
          <div class="wa-panel-header">
            <h2>Data Entries</h2>
            <button id="wa-clear-btn" class="wa-btn wa-btn-outline wa-btn-sm">Clear All</button>
          </div>
          <p class="wa-input-help">Enter the value and weight for each item. Weights can be percentages, decimals, or integers.</p>

          <div class="wa-entries-header">
            <div class="wa-col-name">Item Name (Optional)</div>
            <div class="wa-col-val">Value</div>
            <div class="wa-col-wt">Weight</div>
            <div class="wa-col-act"></div>
          </div>

          <div id="wa-entries-container" class="wa-entries-container">
            <!-- Dynamic entries will be injected here -->
          </div>

          <div class="wa-add-row">
            <button id="wa-add-btn" class="wa-btn wa-btn-secondary wa-btn-full">+ Add New Item</button>
          </div>

          <div id="wa-error-msg" class="wa-error-msg"></div>
        </div>

        <div class="wa-calc-result-panel">
          <div class="wa-result-card">
            <h3>Weighted Average</h3>
            <div id="wa-final-result" class="wa-final-result">0.00</div>
            <div class="wa-result-stats">
              <div class="wa-res-stat">
                <span class="wa-res-label">Sum of Values:</span>
                <span id="wa-sum-values" class="wa-res-val">0.00</span>
              </div>
              <div class="wa-res-stat">
                <span class="wa-res-label">Sum of Weights:</span>
                <span id="wa-sum-weights" class="wa-res-val">0.00</span>
              </div>
            </div>
          </div>

          <div class="wa-chart-card">
            <h3>Weight Distribution</h3>
            <div class="wa-chart-container" id="wa-chart-container">
              <!-- Dynamic bar chart here -->
              <div class="wa-empty-chart">Add data to see visualization</div>
            </div>
          </div>
        </div>
      </div>

      <div class="wa-breakdown-section">
        <h2>Calculation Steps</h2>
        <div class="wa-formula-display">
          <div class="wa-formula-top">(&Sigma; (Value &times; Weight))</div>
          <div class="wa-formula-line"></div>
          <div class="wa-formula-bottom">(&Sigma; Weight)</div>
        </div>

        <div class="wa-table-responsive">
          <table class="wa-breakdown-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Value (V)</th>
                <th>Weight (W)</th>
                <th>V &times; W</th>
                <th>Contribution %</th>
              </tr>
            </thead>
            <tbody id="wa-breakdown-body">
              <tr><td colspan="5" class="wa-text-center">No data entered yet.</td></tr>
            </tbody>
            <tfoot id="wa-breakdown-foot">
              <tr>
                <th>Total</th>
                <th id="wa-tot-val">-</th>
                <th id="wa-tot-wt">0</th>
                <th id="wa-tot-prod">0</th>
                <th>100%</th>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </section>

    <section class="wa-educational-section">
      <div class="wa-edu-header">
        <h2>Understanding Weighted Averages</h2>
        <p>A comprehensive guide to how they work, why they matter, and common use cases.</p>
      </div>

      <div class="wa-edu-grid">
        <div class="wa-edu-card">
          <div class="wa-edu-icon">📚</div>
          <h3>What is a Weighted Average?</h3>
          <p>Unlike a simple average where all numbers are treated equally, a weighted average assigns a specific weight (or level of importance) to each number. This means some values contribute more to the final result than others.</p>
          <div class="wa-edu-example">
            <strong>Formula:</strong><br/>
            <code>Weighted Avg = (w₁x₁ + w₂x₂ + ... + wₙxₙ) / (w₁ + w₂ + ... + wₙ)</code>
          </div>
        </div>

        <div class="wa-edu-card">
          <div class="wa-edu-icon">🎓</div>
          <h3>Use Case: Academic Grades</h3>
          <p>Teachers frequently use weighted averages to calculate final grades. For example, a syllabus might state that homework is 20%, quizzes are 30%, and the final exam is 50%. Even if you score 100% on homework, the final exam has a much larger impact.</p>
          <ul>
            <li>Homework: 90 × 0.20 = 18</li>
            <li>Quizzes: 85 × 0.30 = 25.5</li>
            <li>Final: 88 × 0.50 = 44</li>
            <li><strong>Total Grade: 87.5%</strong></li>
          </ul>
        </div>

        <div class="wa-edu-card">
          <div class="wa-edu-icon">📈</div>
          <h3>Use Case: Financial Portfolios</h3>
          <p>Investors use weighted averages to determine the overall return of a portfolio. If you have $10,000 in Stock A (10% return) and $40,000 in Stock B (5% return), the total portfolio return isn't simply 7.5%.</p>
          <p>The weights are the investment amounts. The weighted return calculates to <strong>6%</strong>, accurately reflecting the heavier investment in the lower-yielding stock.</p>
        </div>

        <div class="wa-edu-card">
          <div class="wa-edu-icon">📊</div>
          <h3>Use Case: Survey Data & Statistics</h3>
          <p>When analyzing survey results, researchers often apply weights to correct for demographic imbalances. If a sample has too few respondents from a specific age group compared to the general population, their responses are given a higher weight to ensure the final analysis is statistically representative.</p>
        </div>
      </div>

      <div class="wa-deep-dive">
        <h3>Simple Average vs. Weighted Average</h3>
        <p>Consider three test scores: 80, 90, and 100.</p>
        <div class="wa-comparison-table-wrapper">
          <table class="wa-comparison-table">
            <thead>
              <tr>
                <th>Calculation Type</th>
                <th>Method</th>
                <th>Result</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Simple Average</strong></td>
                <td>(80 + 90 + 100) / 3</td>
                <td><strong>90</strong></td>
              </tr>
              <tr>
                <td><strong>Weighted Average</strong><br/><small>(Test 1: 10%, Test 2: 20%, Test 3: 70%)</small></td>
                <td>(80×0.1) + (90×0.2) + (100×0.7)</td>
                <td><strong>96</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="wa-note">Notice how the weighted average is pulled heavily towards 100, because that test had a 70% weight.</p>
      </div>
    </section>

    <section class="wa-faq-section">
      <div class="wa-faq-header">
        <h2>Frequently Asked Questions</h2>
        <p>Common questions about calculating weighted averages.</p>
      </div>
      <div class="wa-faq-list">

        <div class="wa-faq-item">
          <button class="wa-faq-question" aria-expanded="false" aria-controls="faq-answer-0">
            How do you calculate a weighted average?
            <span class="wa-faq-icon">+</span>
          </button>
          <div id="faq-answer-0" class="wa-faq-answer">
            <p>To calculate a weighted average, multiply each value by its assigned weight. Then, sum all these calculated products together. Finally, divide this sum by the total sum of all weights.</p>
          </div>
        </div>

        <div class="wa-faq-item">
          <button class="wa-faq-question" aria-expanded="false" aria-controls="faq-answer-1">
            What is the difference between a simple average and a weighted average?
            <span class="wa-faq-icon">+</span>
          </button>
          <div id="faq-answer-1" class="wa-faq-answer">
            <p>A simple average treats all values equally by adding them up and dividing by the count. A weighted average assigns a specific weight (or importance) to each value, so some values contribute more to the final result than others.</p>
          </div>
        </div>

        <div class="wa-faq-item">
          <button class="wa-faq-question" aria-expanded="false" aria-controls="faq-answer-2">
            Can weights be percentages or decimals?
            <span class="wa-faq-icon">+</span>
          </button>
          <div id="faq-answer-2" class="wa-faq-answer">
            <p>Yes, weights can be represented as percentages, decimals, or whole numbers. The calculation method remains the same regardless of the format, as long as you divide the sum of the products by the sum of the weights.</p>
          </div>
        </div>

        <div class="wa-faq-item">
          <button class="wa-faq-question" aria-expanded="false" aria-controls="faq-answer-3">
            Why are weighted averages used in grading?
            <span class="wa-faq-icon">+</span>
          </button>
          <div id="faq-answer-3" class="wa-faq-answer">
            <p>Weighted averages are used in grading to give different assignments varying levels of importance. For instance, a final exam might be worth 40% of the overall grade, while homework is only worth 10%.</p>
          </div>
        </div>

        <div class="wa-faq-item">
          <button class="wa-faq-question" aria-expanded="false" aria-controls="faq-answer-4">
            What happens if my weights don't add up to 100% or 1?
            <span class="wa-faq-icon">+</span>
          </button>
          <div id="faq-answer-4" class="wa-faq-answer">
            <p>If weights do not add up to 100% or 1, you simply divide the sum of the weighted values by the actual total sum of the weights provided. The formula inherently accounts for any total weight.</p>
          </div>
        </div>

      </div>
    </section>

    <section class="wa-related-section">
      <h2>Related Calculators</h2>
      <div class="wa-related-grid">
        <a href="/average-calculator" class="wa-related-card">
          <h3>Average Calculator</h3>
          <p>Calculate the simple mean average of a dataset.</p>
        </a>
        <a href="/weighted-grade-calculator" class="wa-related-card">
          <h3>Weighted Grade Calculator</h3>
          <p>Specifically designed for students to calculate course grades.</p>
        </a>
        <a href="/gpa-calculator" class="wa-related-card">
          <h3>GPA Calculator</h3>
          <p>Calculate your semester and cumulative Grade Point Average.</p>
        </a>
        <a href="/final-grade-calculator" class="wa-related-card">
          <h3>Final Grade Calculator</h3>
          <p>Find out what you need on your final exam to pass.</p>
        </a>
      </div>
    </section>
  </main>

  <style is:inline>
    /*
      Scoped CSS for Weighted Average Calculator
      Using provided CSS variables:
      var(--accent-color), var(--card-bg), var(--text-primary),
      var(--text-secondary), var(--border-color), var(--bg-primary)
    */
    .wa-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem;
      font-family: system-ui, -apple-system, sans-serif;
      color: var(--text-primary);
      line-height: 1.6;
    }

    /* Typography & Utilities */
    .wa-text-center { text-align: center; }
    h1, h2, h3 { color: var(--text-primary); margin-top: 0; }

    /* Buttons */
    .wa-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      border: none;
      font-size: 1rem;
      text-decoration: none;
    }
    .wa-btn-sm {
      padding: 0.4rem 0.8rem;
      font-size: 0.875rem;
    }
    .wa-btn-primary {
      background: var(--accent-color);
      color: #fff;
    }
    .wa-btn-primary:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }
    .wa-btn-secondary {
      background: var(--bg-primary);
      color: var(--text-primary);
      border: 1px dashed var(--border-color);
    }
    .wa-btn-secondary:hover {
      background: var(--border-color);
    }
    .wa-btn-outline {
      background: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
    }
    .wa-btn-outline:hover {
      background: var(--bg-primary);
      color: var(--text-primary);
    }
    .wa-btn-full {
      width: 100%;
    }
    .wa-btn-danger {
      background: #ef4444;
      color: white;
      padding: 0.4rem 0.8rem;
    }
    .wa-btn-danger:hover {
      background: #dc2626;
    }

    /* Hero Section */
    .wa-hero {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--card-bg);
      border-radius: 16px;
      border: 1px solid var(--border-color);
      margin-bottom: 3rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }
    .wa-hero-title {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, var(--text-primary), var(--accent-color));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .wa-hero-subtitle {
      font-size: 1.2rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto 2rem;
    }
    .wa-hero-stats {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }
    .wa-stat-badge {
      background: var(--bg-primary);
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-size: 0.9rem;
      font-weight: 600;
      border: 1px solid var(--border-color);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .wa-stat-badge span { color: var(--accent-color); }

    /* Calculator Grid */
    .wa-calc-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }
    @media (min-width: 900px) {
      .wa-calc-grid {
        grid-template-columns: 3fr 2fr;
      }
    }

    /* Panels */
    .wa-calc-input-panel, .wa-calc-result-panel {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .wa-panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }
    .wa-input-help {
      color: var(--text-secondary);
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    /* Entries */
    .wa-entries-header {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 40px;
      gap: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border-color);
      margin-bottom: 1rem;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }
    .wa-entry-row {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 40px;
      gap: 1rem;
      margin-bottom: 1rem;
      align-items: center;
      animation: wa-fade-in 0.3s ease;
    }
    @keyframes wa-fade-in {
      from { opacity: 0; transform: translateY(5px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .wa-entry-input {
      width: 100%;
      padding: 0.6rem;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      background: var(--bg-primary);
      color: var(--text-primary);
      font-size: 1rem;
      transition: border-color 0.2s;
    }
    .wa-entry-input:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 2px rgba(0,0,0,0.05);
    }
    .wa-btn-remove {
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      border-radius: 6px;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1.2rem;
      transition: all 0.2s;
    }
    .wa-btn-remove:hover {
      background: #ef4444;
      color: white;
      border-color: #ef4444;
    }
    .wa-add-row {
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-color);
    }
    .wa-error-msg {
      color: #ef4444;
      font-size: 0.9rem;
      margin-top: 1rem;
      min-height: 20px;
    }

    /* Results Panel */
    .wa-calc-result-panel {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .wa-result-card {
      background: var(--bg-primary);
      border-radius: 8px;
      padding: 1.5rem;
      text-align: center;
      border: 1px solid var(--border-color);
    }
    .wa-final-result {
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--accent-color);
      margin: 1rem 0;
      line-height: 1;
    }
    .wa-result-stats {
      display: flex;
      justify-content: space-around;
      border-top: 1px solid var(--border-color);
      padding-top: 1rem;
      margin-top: 1rem;
    }
    .wa-res-stat {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    .wa-res-label {
      font-size: 0.8rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .wa-res-val {
      font-weight: 700;
      font-size: 1.1rem;
    }

    /* Chart */
    .wa-chart-card {
      background: var(--bg-primary);
      border-radius: 8px;
      padding: 1.5rem;
      border: 1px solid var(--border-color);
      flex-grow: 1;
    }
    .wa-chart-container {
      margin-top: 1.5rem;
      height: 200px;
      display: flex;
      align-items: flex-end;
      gap: 8px;
      padding-top: 20px;
      border-bottom: 2px solid var(--border-color);
      position: relative;
    }
    .wa-chart-bar-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      height: 100%;
      position: relative;
    }
    .wa-chart-bar {
      width: 100%;
      background: var(--accent-color);
      border-radius: 4px 4px 0 0;
      transition: height 0.4s ease;
      min-height: 2px;
      opacity: 0.8;
    }
    .wa-chart-bar:hover {
      opacity: 1;
    }
    .wa-chart-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: 8px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      width: 100%;
      text-align: center;
      position: absolute;
      bottom: -25px;
    }
    .wa-chart-val {
      position: absolute;
      top: -20px;
      font-size: 0.75rem;
      font-weight: bold;
      color: var(--text-primary);
    }
    .wa-empty-chart {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-secondary);
      font-style: italic;
    }

    /* Breakdown Section */
    .wa-breakdown-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 3rem;
    }
    .wa-formula-display {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin: 1.5rem 0 2.5rem;
      font-family: monospace;
      font-size: 1.2rem;
      color: var(--text-secondary);
    }
    .wa-formula-line {
      width: 250px;
      height: 2px;
      background: var(--border-color);
      margin: 0.5rem 0;
    }
    .wa-table-responsive {
      overflow-x: auto;
    }
    .wa-breakdown-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    .wa-breakdown-table th, .wa-breakdown-table td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-color);
    }
    .wa-breakdown-table th {
      background: var(--bg-primary);
      font-weight: 600;
      color: var(--text-secondary);
    }
    .wa-breakdown-table tfoot th {
      background: transparent;
      border-top: 2px solid var(--border-color);
      color: var(--text-primary);
      font-size: 1.1rem;
    }
    .wa-breakdown-table tbody tr:hover {
      background: var(--bg-primary);
    }

    /* Educational Section */
    .wa-educational-section {
      margin-bottom: 4rem;
    }
    .wa-edu-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .wa-edu-header h2 { font-size: 2rem; margin-bottom: 1rem; }
    .wa-edu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }
    .wa-edu-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      transition: transform 0.2s;
    }
    .wa-edu-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }
    .wa-edu-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .wa-edu-card h3 { margin-bottom: 1rem; font-size: 1.3rem; }
    .wa-edu-card p { color: var(--text-secondary); margin-bottom: 1.5rem; }
    .wa-edu-example {
      background: var(--bg-primary);
      padding: 1rem;
      border-radius: 8px;
      font-size: 0.9rem;
      border-left: 3px solid var(--accent-color);
    }
    .wa-deep-dive {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2.5rem;
    }
    .wa-comparison-table-wrapper {
      margin: 1.5rem 0;
      overflow-x: auto;
    }
    .wa-comparison-table {
      width: 100%;
      border-collapse: collapse;
    }
    .wa-comparison-table th, .wa-comparison-table td {
      padding: 1rem;
      border: 1px solid var(--border-color);
      text-align: left;
    }
    .wa-comparison-table th { background: var(--bg-primary); }
    .wa-note { font-style: italic; color: var(--text-secondary); font-size: 0.9rem; }

    /* FAQ Section */
    .wa-faq-section { margin-bottom: 4rem; }
    .wa-faq-header { text-align: center; margin-bottom: 2rem; }
    .wa-faq-list { max-width: 800px; margin: 0 auto; }
    .wa-faq-item {
      border: 1px solid var(--border-color);
      margin-bottom: 1rem;
      border-radius: 8px;
      background: var(--card-bg);
      overflow: hidden;
    }
    .wa-faq-question {
      width: 100%;
      text-align: left;
      padding: 1.25rem 1.5rem;
      background: transparent;
      border: none;
      font-weight: 600;
      font-size: 1.1rem;
      color: var(--text-primary);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .wa-faq-icon {
      font-size: 1.5rem;
      color: var(--accent-color);
      transition: transform 0.3s ease;
    }
    .wa-faq-question[aria-expanded="true"] .wa-faq-icon {
      transform: rotate(45deg);
    }
    .wa-faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      background: var(--bg-primary);
    }
    .wa-faq-question[aria-expanded="true"] + .wa-faq-answer {
      max-height: 500px;
    }
    .wa-faq-answer p {
      padding: 0 1.5rem 1.25rem;
      margin: 0;
      color: var(--text-secondary);
    }

    /* Related Section */
    .wa-related-section {
      margin-bottom: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border-color);
    }
    .wa-related-section h2 { margin-bottom: 2rem; }
    .wa-related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
    }
    .wa-related-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      text-decoration: none;
      color: inherit;
      transition: all 0.2s;
    }
    .wa-related-card:hover {
      border-color: var(--accent-color);
      transform: translateY(-3px);
    }
    .wa-related-card h3 {
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
      color: var(--accent-color);
    }
    .wa-related-card p {
      margin: 0;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    /* Mobile adjustments */
    @media (max-width: 600px) {
      .wa-entries-header { display: none; }
      .wa-entry-row {
        grid-template-columns: 1fr;
        gap: 0.5rem;
        background: var(--bg-primary);
        padding: 1rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        position: relative;
      }
      .wa-btn-remove {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        width: 30px;
        height: 30px;
        font-size: 1rem;
      }
      .wa-entry-input { margin-bottom: 0.25rem; }
      .wa-entry-input::placeholder { color: var(--text-secondary); }
    }
  </style>

  <script is:inline>
    (function() {
      // DOM Elements
      const entriesContainer = document.getElementById('wa-entries-container');
      const addBtn = document.getElementById('wa-add-btn');
      const clearBtn = document.getElementById('wa-clear-btn');
      const errorMsg = document.getElementById('wa-error-msg');

      const finalResultEl = document.getElementById('wa-final-result');
      const sumValuesEl = document.getElementById('wa-sum-values');
      const sumWeightsEl = document.getElementById('wa-sum-weights');

      const chartContainer = document.getElementById('wa-chart-container');
      const breakdownBody = document.getElementById('wa-breakdown-body');

      const totValEl = document.getElementById('wa-tot-val');
      const totWtEl = document.getElementById('wa-tot-wt');
      const totProdEl = document.getElementById('wa-tot-prod');

      // State
      let entries = [
        { id: generateId(), name: 'Assignment 1', value: 85, weight: 20 },
        { id: generateId(), name: 'Assignment 2', value: 92, weight: 30 },
        { id: generateId(), name: 'Final Exam', value: 88, weight: 50 }
      ];

      function generateId() {
        return Math.random().toString(36).substr(2, 9);
      }

      function formatNum(num) {
        return isNaN(num) ? '0.00' : Number(num).toFixed(2);
      }

      // Render Inputs
      function renderEntries() {
        entriesContainer.innerHTML = '';

        if (entries.length === 0) {
          const emptyMsg = document.createElement('div');
          emptyMsg.textContent = 'No items added yet. Click "Add New Item" to begin.';
          emptyMsg.style.padding = '1rem';
          emptyMsg.style.textAlign = 'center';
          emptyMsg.style.color = 'var(--text-secondary)';
          emptyMsg.style.fontStyle = 'italic';
          entriesContainer.appendChild(emptyMsg);
          return;
        }

        entries.forEach((entry, index) => {
          const row = document.createElement('div');
          row.className = 'wa-entry-row';
          row.dataset.id = entry.id;

          // Name Input
          const nameInput = document.createElement('input');
          nameInput.type = 'text';
          nameInput.className = 'wa-entry-input';
          nameInput.placeholder = window.innerWidth <= 600 ? 'Item Name' : 'e.g. Test 1';
          nameInput.value = entry.name;
          nameInput.addEventListener('input', (e) => updateEntry(entry.id, 'name', e.target.value));

          // Value Input
          const valInput = document.createElement('input');
          valInput.type = 'number';
          valInput.step = 'any';
          valInput.className = 'wa-entry-input';
          valInput.placeholder = window.innerWidth <= 600 ? 'Value' : '0';
          valInput.value = entry.value !== '' ? entry.value : '';
          valInput.addEventListener('input', (e) => updateEntry(entry.id, 'value', e.target.value));

          // Weight Input
          const wtInput = document.createElement('input');
          wtInput.type = 'number';
          wtInput.step = 'any';
          wtInput.className = 'wa-entry-input';
          wtInput.placeholder = window.innerWidth <= 600 ? 'Weight' : '0';
          wtInput.value = entry.weight !== '' ? entry.weight : '';
          wtInput.addEventListener('input', (e) => updateEntry(entry.id, 'weight', e.target.value));

          // Remove Btn
          const rmBtn = document.createElement('button');
          rmBtn.className = 'wa-btn-remove';
          rmBtn.innerHTML = '×';
          rmBtn.setAttribute('aria-label', 'Remove item');
          rmBtn.addEventListener('click', () => removeEntry(entry.id));

          row.appendChild(nameInput);
          row.appendChild(valInput);
          row.appendChild(wtInput);
          row.appendChild(rmBtn);

          entriesContainer.appendChild(row);
        });
      }

      // Handlers
      function addEntry() {
        entries.push({ id: generateId(), name: `Item ${entries.length + 1}`, value: '', weight: '' });
        renderEntries();
        calculate();
      }

      function removeEntry(id) {
        entries = entries.filter(e => e.id !== id);
        renderEntries();
        calculate();
      }

      function updateEntry(id, field, val) {
        const entry = entries.find(e => e.id === id);
        if (entry) {
          entry[field] = val;
          calculate();
        }
      }

      function clearAll() {
        entries = [{ id: generateId(), name: 'Item 1', value: '', weight: '' }];
        renderEntries();
        calculate();
        errorMsg.textContent = '';
      }

      // Calculation Core
      function calculate() {
        let sumWeights = 0;
        let sumProducts = 0;
        let sumValues = 0;
        let validEntriesCount = 0;
        let hasNegativeWeights = false;

        const processedEntries = entries.map(entry => {
          const v = parseFloat(entry.value);
          const w = parseFloat(entry.weight);

          if (!isNaN(v) && !isNaN(w)) {
            if (w < 0) hasNegativeWeights = true;
            sumWeights += w;
            sumProducts += (v * w);
            sumValues += v;
            validEntriesCount++;
            return { ...entry, v, w, prod: v * w, valid: true };
          }
          return { ...entry, valid: false };
        });

        // Validation
        if (hasNegativeWeights) {
          errorMsg.textContent = 'Warning: Negative weights are typically not used in standard weighted averages.';
        } else {
          errorMsg.textContent = '';
        }

        // Render Results
        if (validEntriesCount === 0 || sumWeights === 0) {
          finalResultEl.textContent = '0.00';
          sumValuesEl.textContent = '0.00';
          sumWeightsEl.textContent = '0.00';
          renderEmptyChart();
          renderEmptyBreakdown();
          return;
        }

        const weightedAvg = sumProducts / sumWeights;

        // Animate result if changed
        const currentResult = parseFloat(finalResultEl.textContent);
        if (currentResult !== weightedAvg && !isNaN(weightedAvg)) {
           finalResultEl.style.transform = 'scale(1.1)';
           setTimeout(() => finalResultEl.style.transform = 'scale(1)', 200);
        }

        finalResultEl.textContent = formatNum(weightedAvg);
        sumValuesEl.textContent = formatNum(sumValues);
        sumWeightsEl.textContent = formatNum(sumWeights);

        renderChart(processedEntries, sumWeights);
        renderBreakdown(processedEntries, sumValues, sumWeights, sumProducts);
      }

      function renderEmptyChart() {
        chartContainer.innerHTML = '<div class="wa-empty-chart">Add data to see visualization</div>';
      }

      function renderChart(data, totalWeight) {
        chartContainer.innerHTML = '';
        const validData = data.filter(d => d.valid && d.w > 0);

        if (validData.length === 0) {
          renderEmptyChart();
          return;
        }

        const maxWeight = Math.max(...validData.map(d => d.w));

        validData.forEach(item => {
          const wrapper = document.createElement('div');
          wrapper.className = 'wa-chart-bar-wrapper';

          const bar = document.createElement('div');
          bar.className = 'wa-chart-bar';
          // Height relative to max weight to ensure good visual scaling
          const heightPct = (item.w / maxWeight) * 100;
          // But ensure we have space for the label above
          bar.style.height = `calc(${heightPct}% - 30px)`;

          const valLabel = document.createElement('div');
          valLabel.className = 'wa-chart-val';
          valLabel.textContent = item.w;

          const label = document.createElement('div');
          label.className = 'wa-chart-label';
          label.textContent = item.name || 'Item';
          label.title = item.name;

          wrapper.appendChild(valLabel);
          wrapper.appendChild(bar);
          wrapper.appendChild(label);
          chartContainer.appendChild(wrapper);
        });
      }

      function renderEmptyBreakdown() {
        breakdownBody.innerHTML = '<tr><td colspan="5" class="wa-text-center">No valid data to calculate.</td></tr>';
        totValEl.textContent = '-';
        totWtEl.textContent = '0';
        totProdEl.textContent = '0';
      }

      function renderBreakdown(data, totalVal, totalWt, totalProd) {
        breakdownBody.innerHTML = '';

        const validData = data.filter(d => d.valid);

        if (validData.length === 0) {
          renderEmptyBreakdown();
          return;
        }

        validData.forEach(item => {
          const tr = document.createElement('tr');

          const tdName = document.createElement('td');
          tdName.textContent = item.name || 'Unnamed';

          const tdVal = document.createElement('td');
          tdVal.textContent = formatNum(item.v);

          const tdWt = document.createElement('td');
          tdWt.textContent = formatNum(item.w);

          const tdProd = document.createElement('td');
          tdProd.textContent = formatNum(item.prod);

          const tdContrib = document.createElement('td');
          const contribPct = totalWt > 0 ? ((item.w / totalWt) * 100) : 0;
          tdContrib.textContent = formatNum(contribPct) + '%';

          tr.appendChild(tdName);
          tr.appendChild(tdVal);
          tr.appendChild(tdWt);
          tr.appendChild(tdProd);
          tr.appendChild(tdContrib);

          breakdownBody.appendChild(tr);
        });

        totValEl.textContent = formatNum(totalVal);
        totWtEl.textContent = formatNum(totalWt);
        totProdEl.textContent = formatNum(totalProd);
      }

      // FAQ Accordion
      function initFAQ() {
        const questions = document.querySelectorAll('.wa-faq-question');
        questions.forEach(q => {
          q.addEventListener('click', () => {
            const isExpanded = q.getAttribute('aria-expanded') === 'true';

            // Optional: close others
            questions.forEach(otherQ => {
              if (otherQ !== q) {
                otherQ.setAttribute('aria-expanded', 'false');
              }
            });

            q.setAttribute('aria-expanded', !isExpanded);
          });
        });
      }

      // Init
      addBtn.addEventListener('click', addEntry);
      clearBtn.addEventListener('click', clearAll);

      renderEntries();
      calculate();
      initFAQ();

    })();
  </script>
</SiteLayout>
