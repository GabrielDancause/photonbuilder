---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Percentage Change Calculator | SiliconBased",
  description: "Calculate the exact percentage increase or decrease between two numbers. Perfect for finance, sales growth, weight loss tracking, or academic grading.",
  category: "tool",
  published: "2024-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you calculate percentage change?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate percentage change, subtract the old value from the new value, divide the result by the absolute value of the old value, and then multiply by 100. The formula is: ((New Value - Old Value) / |Old Value|) × 100."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between percentage change and percentage difference?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Percentage change measures the relative difference between an old (original) value and a new value over time. Percentage difference is used when comparing two numbers without a chronological order, calculated by dividing the absolute difference by the average of the two numbers."
      }
    },
    {
      "@type": "Question",
      "name": "Can percentage change be negative?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. If the new value is smaller than the old value, the calculation will result in a negative number, indicating a percentage decrease. For example, a drop from 100 to 80 is a -20% change."
      }
    },
    {
      "@type": "Question",
      "name": "Can percentage change be more than 100%?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. If a value more than doubles, the percentage change will exceed 100%. For example, an increase from 10 to 30 is a 200% increase (or +200% change)."
      }
    },
    {
      "@type": "Question",
      "name": "What if the starting value is zero?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If the original value is zero, calculating the percentage change mathematically results in division by zero, which is undefined. In practical terms, any increase from zero is typically considered a 'new' metric rather than a percentage growth."
      }
    }
  ]
};
---

<SiteLayout
  site="sendnerds"
  title="Percentage Change Calculator | SiliconBased"
  description="Calculate percentage increase or decrease between two numbers instantly."
  canonical="https://sendnerds.photonbuilder.com/percentage-change-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Percentage Change Calculator</h1>
      <p class="subtitle">Instantly find the percent increase or decrease between two numbers</p>
    </div>

    <div class="calculator-container">
      <div class="calc-card">
        <div class="input-row">
          <div class="input-group">
            <label for="oldValue">Original Value</label>
            <input type="number" id="oldValue" placeholder="e.g., 100" step="any">
          </div>
          <div class="arrow-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </div>
          <div class="input-group">
            <label for="newValue">New Value</label>
            <input type="number" id="newValue" placeholder="e.g., 150" step="any">
          </div>
        </div>

        <div class="result-display">
          <div class="result-label">Percentage Change:</div>
          <div class="result-value" id="percentResult">---</div>
          <div class="result-description" id="resultDesc">Enter values to calculate</div>
          <div class="formula-display" id="formulaDisplay"></div>
        </div>

        <div class="error-msg" id="errorMsg" style="display: none;"></div>
      </div>
    </div>

    <div class="explainer">
      <h2>How to Calculate Percentage Change</h2>
      <p>Percentage change is an essential mathematical concept used to express how a value changes relative to its original size. Whether you are tracking the growth of an investment portfolio, calculating a retail discount, determining a company's year-over-year revenue growth, or measuring a change in test scores, understanding this metric is crucial.</p>

      <h3>The Percentage Change Formula</h3>
      <p>The calculation is straightforward and follows this universally accepted formula:</p>

      <div class="formula-box">
        <strong>Percentage Change = ((New Value - Old Value) &divide; |Old Value|) &times; 100</strong>
      </div>

      <p>Here is the step-by-step breakdown of how the formula works in practice:</p>
      <ol>
        <li><strong>Find the absolute difference:</strong> Subtract the Old (Original) Value from the New Value. If the new value is larger, this number will be positive (an increase). If the new value is smaller, it will be negative (a decrease).</li>
        <li><strong>Divide by the Original Value:</strong> Take the result from Step 1 and divide it by the absolute value of the Original Value. (We use the absolute value of the original number so that if you start with a negative number, the direction of the change remains accurate).</li>
        <li><strong>Convert to a Percentage:</strong> Multiply the decimal result by 100 and add a percent sign (%).</li>
      </ol>

      <h3>Real-World Examples</h3>

      <h4>Example 1: Calculating a Price Increase</h4>
      <p>Suppose you bought a stock for $50 (Old Value), and a year later, it is worth $65 (New Value). What is the percentage change?</p>
      <ul>
        <li>Step 1: $65 - $50 = $15</li>
        <li>Step 2: $15 &divide; $50 = 0.30</li>
        <li>Step 3: 0.30 &times; 100 = <strong>30% increase</strong></li>
      </ul>

      <h4>Example 2: Calculating a Sales Decrease</h4>
      <p>A retail store sold 200 units of a product last month (Old Value). This month, they sold 150 units (New Value). What is the percentage change?</p>
      <ul>
        <li>Step 1: 150 - 200 = -50</li>
        <li>Step 2: -50 &divide; 200 = -0.25</li>
        <li>Step 3: -0.25 &times; 100 = <strong>-25% change (a 25% decrease)</strong></li>
      </ul>

      <h4>Example 3: Dealing with Negative Numbers</h4>
      <p>What if a company's profits went from -$10,000 (a loss) to $5,000 (a profit)?</p>
      <ul>
        <li>Step 1: $5,000 - (-$10,000) = $15,000</li>
        <li>Step 2: $15,000 &divide; |-$10,000| = 1.5</li>
        <li>Step 3: 1.5 &times; 100 = <strong>150% increase</strong></li>
      </ul>

      <h3>Percentage Change vs. Percentage Difference</h3>
      <p>It is very common to confuse "percentage change" with "percentage difference," but they are used in entirely different scenarios. You use <strong>Percentage Change</strong> when there is a clear chronological order—an old value that transformed into a new value over time. You use <strong>Percentage Difference</strong> when you are comparing two independent items of the same type without a strict "before and after" relationship (e.g., comparing the heights of two different buildings). In percentage difference, you divide the absolute difference by the <em>average</em> of the two numbers, rather than the original number.</p>

      <p>Mathematical calculations like this are essential not only in finance but also in understanding statistics. For example, if you are analyzing demographic shifts, a 10% change in population metrics could significantly alter probabilities and statistical distributions in demographic studies.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How do you calculate percentage change?</summary>
        <p>To calculate percentage change, subtract the old value from the new value, divide the result by the absolute value of the old value, and then multiply by 100. The formula is: ((New Value - Old Value) / |Old Value|) &times; 100.</p>
      </details>
      <details>
        <summary>What is the difference between percentage change and percentage difference?</summary>
        <p>Percentage change measures the relative difference between an old (original) value and a new value over time. Percentage difference is used when comparing two numbers without a chronological order, calculated by dividing the absolute difference by the average of the two numbers.</p>
      </details>
      <details>
        <summary>Can percentage change be negative?</summary>
        <p>Yes. If the new value is smaller than the old value, the calculation will result in a negative number, indicating a percentage decrease. For example, a drop from 100 to 80 is a -20% change.</p>
      </details>
      <details>
        <summary>Can percentage change be more than 100%?</summary>
        <p>Absolutely. If a value more than doubles, the percentage change will exceed 100%. For example, an increase from 10 to 30 is a 200% increase (or +200% change).</p>
      </details>
      <details>
        <summary>What if the starting value is zero?</summary>
        <p>If the original value is zero, calculating the percentage change mathematically results in division by zero, which is undefined. In practical terms, any increase from zero is typically considered a "new" metric rather than a percentage growth, or mathematically represented as infinity.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const oldInput = document.getElementById('oldValue');
      const newInput = document.getElementById('newValue');
      const resultEl = document.getElementById('percentResult');
      const resultDesc = document.getElementById('resultDesc');
      const formulaDisplay = document.getElementById('formulaDisplay');
      const errorMsgEl = document.getElementById('errorMsg');

      function calculateChange() {
        errorMsgEl.style.display = 'none';
        const oldValStr = oldInput.value.trim();
        const newValStr = newInput.value.trim();

        if (oldValStr === '' || newValStr === '') {
          resultEl.textContent = '---';
          resultDesc.textContent = 'Enter both values to calculate';
          formulaDisplay.innerHTML = '';
          resultEl.style.color = 'var(--text-primary)';
          return;
        }

        const oldVal = parseFloat(oldValStr);
        const newVal = parseFloat(newValStr);

        if (isNaN(oldVal) || isNaN(newVal)) {
          errorMsgEl.textContent = 'Please enter valid numbers.';
          errorMsgEl.style.display = 'block';
          resultEl.textContent = 'Error';
          resultDesc.textContent = '';
          formulaDisplay.innerHTML = '';
          return;
        }

        if (oldVal === 0) {
          if (newVal === 0) {
            resultEl.textContent = '0%';
            resultDesc.textContent = 'No change';
            formulaDisplay.innerHTML = `((0 - 0) / 0) &times; 100 = 0%`;
            resultEl.style.color = 'var(--text-primary)';
          } else {
            errorMsgEl.textContent = 'Cannot divide by zero. Original value cannot be 0.';
            errorMsgEl.style.display = 'block';
            resultEl.textContent = 'Undefined';
            resultDesc.textContent = 'Infinite increase';
            formulaDisplay.innerHTML = '';
            resultEl.style.color = '#ef4444';
          }
          return;
        }

        const difference = newVal - oldVal;
        const change = (difference / Math.abs(oldVal)) * 100;

        // Format to handle long decimals, max 4 decimal places, remove trailing zeros
        const formattedChange = parseFloat(change.toFixed(4)).toString();

        // Update UI
        if (change > 0) {
          resultEl.textContent = `+${formattedChange}%`;
          resultEl.style.color = '#22c55e'; // green
          resultDesc.textContent = `Increase of ${Math.abs(difference)} unit(s)`;
        } else if (change < 0) {
          resultEl.textContent = `${formattedChange}%`;
          resultEl.style.color = '#ef4444'; // red
          resultDesc.textContent = `Decrease of ${Math.abs(difference)} unit(s)`;
        } else {
          resultEl.textContent = '0%';
          resultEl.style.color = 'var(--text-primary)';
          resultDesc.textContent = 'No change';
        }

        formulaDisplay.innerHTML = `Calculation: ((${newVal} - ${oldVal}) / |${oldVal}|) &times; 100 = ${formattedChange}%`;
      }

      oldInput.addEventListener('input', calculateChange);
      newInput.addEventListener('input', calculateChange);
    });
  </script>

