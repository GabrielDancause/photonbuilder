---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Ratio Calculator",
  description: "Calculate, simplify, or scale ratios instantly with our free online ratio calculator. Perfect for developers, designers, and everyday math. See how it works.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a 1:1 ratio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 1:1 ratio represents two quantities that are perfectly equal. In design, a 1:1 aspect ratio forms a perfect square, commonly used for profile pictures and social media grid posts."
          }
        },
        {
          "@type": "Question",
          "name": "How do I calculate a ratio from a percentage?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To convert a percentage to a ratio, place the percentage number over 100 to create a fraction, and then simplify it to its lowest terms. For example, 75% becomes 75/100, which simplifies to the ratio 3:4."
          }
        },
        {
          "@type": "Question",
          "name": "What does \"scaling a ratio\" mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Scaling a ratio means multiplying or dividing both sides of the ratio by the same number to create an equivalent ratio. This is used to increase or decrease the total size of something while keeping the proportions identical."
          }
        },
        {
          "@type": "Question",
          "name": "Can a ratio have decimals?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, ratios can contain decimals (e.g., 2.5:1), but they are usually simplified into whole integer numbers (5:2) to make them easier to read and work with mathematically."
          }
        },
        {
          "@type": "Question",
          "name": "How do I solve a ratio with 3 parts (A:B:C)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To solve a three-part ratio when you know the total sum, add the ratio parts together to find the \"total parts\". Divide the total sum by the total parts to find the value of one part, then multiply that value by each individual ratio part."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      }
    }
  ]
};
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/sendnerds/ratio-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Ratio Calculator</h1>
      <p class="subtitle">Scale, simplify, and solve ratio proportions instantly.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-tabs">
        <button class="tab-btn active" data-tab="solve">Solve / Scale Ratio</button>
        <button class="tab-btn" data-tab="simplify">Simplify Ratio</button>
      </div>

      <div class="tab-content active" id="tab-solve">
        <p style="margin-bottom: 1.5rem; color: var(--text-secondary); text-align: center;">Enter three values to find the fourth (A : B = C : D)</p>

        <div class="ratio-equation">
          <div class="ratio-group">
            <div class="ratio-input-wrapper">
              <label for="valA">A</label>
              <input type="number" id="valA" step="any" placeholder="e.g. 16">
            </div>
            <span class="ratio-colon">:</span>
            <div class="ratio-input-wrapper">
              <label for="valB">B</label>
              <input type="number" id="valB" step="any" placeholder="e.g. 9">
            </div>
          </div>

          <span class="ratio-equals">=</span>

          <div class="ratio-group">
            <div class="ratio-input-wrapper">
              <label for="valC">C</label>
              <input type="number" id="valC" step="any" placeholder="e.g. 1920">
            </div>
            <span class="ratio-colon">:</span>
            <div class="ratio-input-wrapper">
              <label for="valD">D</label>
              <input type="number" id="valD" step="any" placeholder="e.g. ?">
            </div>
          </div>
        </div>

        <div class="result-card" id="solve-result" style="display: none;">
          <h3 style="margin-top:0; font-size:1.2rem; color:var(--text-secondary);">Result</h3>
          <div class="result-value" id="solve-value"></div>
          <p id="solve-detail" style="margin-top: 0.5rem; color: var(--text-secondary);"></p>
        </div>
      </div>

      <div class="tab-content" id="tab-simplify">
        <p style="margin-bottom: 1.5rem; color: var(--text-secondary); text-align: center;">Enter a ratio to simplify it to its lowest terms</p>

        <div class="ratio-equation" style="justify-content: center;">
          <div class="ratio-group" style="max-width: 400px;">
            <div class="ratio-input-wrapper">
              <label for="simpA">Value 1</label>
              <input type="number" id="simpA" step="any" placeholder="e.g. 1920">
            </div>
            <span class="ratio-colon">:</span>
            <div class="ratio-input-wrapper">
              <label for="simpB">Value 2</label>
              <input type="number" id="simpB" step="any" placeholder="e.g. 1080">
            </div>
          </div>
        </div>

        <div class="result-card" id="simp-result" style="display: none;">
          <h3 style="margin-top:0; font-size:1.2rem; color:var(--text-secondary);">Simplified Ratio</h3>
          <div class="result-value" id="simp-value"></div>
          <p id="simp-detail" style="margin-top: 0.5rem; color: var(--text-secondary);"></p>
        </div>
      </div>

    </div>

    <div class="explainer">
      <h2>Understanding Ratios: A Complete Guide</h2>
      <p>A ratio is a mathematical relationship between two quantities, indicating how many times the first number contains the second. Ratios are foundational to fields ranging from baking and chemistry to graphic design and computer programming. Understanding how to scale, simplify, and solve ratios allows you to maintain proportional relationships when resizing images, mixing solutions, or allocating resources.</p>

      <h3>How to Read and Write Ratios</h3>
      <p>Ratios can be written in three distinct formats, all representing the exact same mathematical relationship:</p>
      <ul>
        <li><strong>With a colon:</strong> <code>16:9</code> (commonly used for screen aspect ratios)</li>
        <li><strong>Using the word "to":</strong> <code>16 to 9</code></li>
        <li><strong>As a fraction:</strong> <code>16/9</code></li>
      </ul>
      <p>When solving ratio equations (also known as proportions), we are typically trying to find a missing value in two equivalent ratios. This is often written as <code>A : B = C : D</code>. For example, if a recipe requires 2 cups of flour for every 1 cup of sugar (a 2:1 ratio), and you want to use 4 cups of flour, the sugar must scale proportionally to 2 cups to maintain the 4:2 equivalent ratio.</p>

      <h3>How to Solve a Ratio Proportion</h3>
      <p>To solve a proportion where one value is missing, you can use the cross-multiplication method. Given the equation <code>A / B = C / D</code>, the cross products are equal: <code>A &times; D = B &times; C</code>.</p>
      <p>To isolate the missing variable, simply manipulate the algebraic equation. Our ratio calculator automates these exact formulas in real-time:</p>
      <ul>
        <li><strong>To find A:</strong> <code>A = (B &times; C) / D</code></li>
        <li><strong>To find B:</strong> <code>B = (A &times; D) / C</code></li>
        <li><strong>To find C:</strong> <code>C = (A &times; D) / B</code></li>
        <li><strong>To find D:</strong> <code>D = (B &times; C) / A</code></li>
      </ul>

      <h3>How to Simplify a Ratio</h3>
      <p>Simplifying a ratio reduces it to its lowest possible integer terms, much like simplifying a fraction. This is done by finding the Greatest Common Divisor (GCD) of the two numbers and dividing both numbers by that divisor.</p>
      <p>For example, to simplify the screen resolution <code>1920:1080</code>:</p>
      <ol>
        <li>Find the factors of 1920 and 1080.</li>
        <li>Identify the largest factor shared by both numbers. In this case, the GCD is 120.</li>
        <li>Divide both sides by 120: <code>1920 &divide; 120 = 16</code> and <code>1080 &divide; 120 = 9</code>.</li>
        <li>The simplified ratio is <strong>16:9</strong>.</li>
      </ol>
      <p>Our simplify tool also handles decimal values by temporarily scaling them up to whole numbers, finding the GCD, and reducing them back to their lowest integer representation.</p>

      <h3>Practical Applications for Developers</h3>
      <p>In web development and design, ratios are constantly utilized. The most common application is aspect ratios for responsive images and video embeds. Maintaining a strict <code>16:9</code> or <code>4:3</code> ratio ensures media elements scale smoothly across mobile and desktop viewports without distortion or stretching. Modern CSS even provides the <code>aspect-ratio</code> property to enforce these relationships natively.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is a 1:1 ratio?</summary>
        <p>A 1:1 ratio represents two quantities that are perfectly equal. In design, a 1:1 aspect ratio forms a perfect square, commonly used for profile pictures and social media grid posts.</p>
      </details>
      <details>
        <summary>How do I calculate a ratio from a percentage?</summary>
        <p>To convert a percentage to a ratio, place the percentage number over 100 to create a fraction, and then simplify it to its lowest terms. For example, 75% becomes 75/100, which simplifies to the ratio 3:4.</p>
      </details>
      <details>
        <summary>What does "scaling a ratio" mean?</summary>
        <p>Scaling a ratio means multiplying or dividing both sides of the ratio by the same number to create an equivalent ratio. This is used to increase or decrease the total size of something while keeping the proportions identical.</p>
      </details>
      <details>
        <summary>Can a ratio have decimals?</summary>
        <p>Yes, ratios can contain decimals (e.g., 2.5:1), but they are usually simplified into whole integer numbers (5:2) to make them easier to read and work with mathematically.</p>
      </details>
      <details>
        <summary>How do I solve a ratio with 3 parts (A:B:C)?</summary>
        <p>To solve a three-part ratio when you know the total sum, add the ratio parts together to find the "total parts". Divide the total sum by the total parts to find the value of one part, then multiply that value by each individual ratio part.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      // Tab switching logic
      const tabs = document.querySelectorAll('.tab-btn');
      const contents = document.querySelectorAll('.tab-content');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          contents.forEach(c => c.classList.remove('active'));

          tab.classList.add('active');
          document.getElementById(`tab-${tab.dataset.tab}`).classList.add('active');
        });
      });

      // --- Solve / Scale Ratio Logic ---
      const inputsSolve = ['valA', 'valB', 'valC', 'valD'].map(id => document.getElementById(id));
      const resSolveCard = document.getElementById('solve-result');
      const resSolveValue = document.getElementById('solve-value');
      const resSolveDetail = document.getElementById('solve-detail');

      function calculateSolve() {
        const vals = inputsSolve.map(input => {
          const v = parseFloat(input.value);
          return isNaN(v) ? null : v;
        });

        const filledCount = vals.filter(v => v !== null).length;

        if (filledCount === 3) {
          let a = vals[0], b = vals[1], c = vals[2], d = vals[3];
          let resultValue = 0;
          let targetId = '';

          if (a === null) {
            // x / b = c / d  => x = (b * c) / d
            if (d === 0) { showErrorSolve("Division by zero"); return; }
            resultValue = (b * c) / d;
            targetId = 'A';
          } else if (b === null) {
            // a / x = c / d => x = (a * d) / c
            if (c === 0) { showErrorSolve("Division by zero"); return; }
            resultValue = (a * d) / c;
            targetId = 'B';
          } else if (c === null) {
            // a / b = x / d => x = (a * d) / b
            if (b === 0) { showErrorSolve("Division by zero"); return; }
            resultValue = (a * d) / b;
            targetId = 'C';
          } else if (d === null) {
            // a / b = c / x => x = (b * c) / a
            if (a === 0) { showErrorSolve("Division by zero"); return; }
            resultValue = (b * c) / a;
            targetId = 'D';
          }

          // Format the number nicely (up to 4 decimal places)
          const formatted = Number(resultValue.toFixed(4)).toString();

          resSolveCard.style.display = 'block';
          resSolveValue.textContent = formatted;
          resSolveDetail.textContent = `Missing value ${targetId} = ${formatted}`;
        } else if (filledCount > 3) {
            showErrorSolve("Please clear one field to solve for it.");
        } else {
          resSolveCard.style.display = 'none';
        }
      }

      function showErrorSolve(msg) {
        resSolveCard.style.display = 'block';
        resSolveValue.textContent = "Error";
        resSolveDetail.textContent = msg;
      }

      inputsSolve.forEach(input => {
        if(input) input.addEventListener('input', calculateSolve);
      });

      // --- Simplify Ratio Logic ---
      const simpA = document.getElementById('simpA');
      const simpB = document.getElementById('simpB');
      const resSimpCard = document.getElementById('simp-result');
      const resSimpValue = document.getElementById('simp-value');
      const resSimpDetail = document.getElementById('simp-detail');

      function gcd(x, y) {
        x = Math.abs(x);
        y = Math.abs(y);
        while(y) {
          let t = y;
          y = x % y;
          x = t;
        }
        return x;
      }

      function calculateSimplify() {
        const a = parseFloat(simpA.value);
        const b = parseFloat(simpB.value);

        if (!isNaN(a) && !isNaN(b)) {
          if (b === 0 && a === 0) {
            resSimpCard.style.display = 'block';
            resSimpValue.textContent = "Undefined";
            resSimpDetail.textContent = "Both values cannot be zero.";
            return;
          }

          let aSimp, bSimp;
          let decimalPlaces = 0;

          // Handle decimals by multiplying by powers of 10
          const aStr = a.toString();
          const bStr = b.toString();
          if (aStr.includes('.')) decimalPlaces = Math.max(decimalPlaces, aStr.split('.')[1].length);
          if (bStr.includes('.')) decimalPlaces = Math.max(decimalPlaces, bStr.split('.')[1].length);

          const multiplier = Math.pow(10, decimalPlaces);
          const aInt = Math.round(a * multiplier);
          const bInt = Math.round(b * multiplier);

          const divisor = gcd(aInt, bInt);

          if (divisor === 0) {
            aSimp = aInt;
            bSimp = bInt;
          } else {
             aSimp = aInt / divisor;
             bSimp = bInt / divisor;
          }

          resSimpCard.style.display = 'block';
          resSimpValue.textContent = `${aSimp} : ${bSimp}`;

          if (divisor > 1 || multiplier > 1) {
             resSimpDetail.textContent = "Ratio simplified to lowest terms.";
          } else {
             resSimpDetail.textContent = "Ratio is already in lowest terms.";
          }
        } else {
          resSimpCard.style.display = 'none';
        }
      }

      [simpA, simpB].forEach(input => {
        if(input) input.addEventListener('input', calculateSimplify);
      });

    });
  </script>

  <style is:inline>
    /* Tabs */
    .calc-tabs { display: flex; gap: 1rem; margin-bottom: 2rem; border-bottom: 2px solid var(--border-color); }
    .tab-btn { background: transparent; color: var(--text-secondary); border: none; padding: 1rem 2rem; cursor: pointer; font-weight: 600; font-size: 1rem; border-radius: 0; position: relative; }
    .tab-btn:hover { color: var(--text-primary); background: transparent; }
    .tab-btn.active { color: var(--accent-color); }
    .tab-btn.active::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 100%; height: 2px; background: var(--accent-color); }
    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

    .ratio-equation { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 2rem; }
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }

    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }

    /* Custom calculator styles */
    .ratio-group { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 1.5rem; }
    .ratio-input-wrapper { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; flex: 1; }
    .ratio-colon { font-size: 2rem; font-weight: bold; padding: 0 0.5rem; color: var(--text-secondary); }
    .ratio-equals { font-size: 2rem; font-weight: bold; padding: 0 1rem; color: var(--text-secondary); }

    @media (max-width: 600px) {
      .ratio-group { flex-direction: column; }
      .ratio-colon { display: none; }
      .ratio-equals { padding: 1rem 0; }
    }
  </style>
</SiteLayout>
