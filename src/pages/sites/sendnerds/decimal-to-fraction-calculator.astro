---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Decimal to Fraction Calculator | Sendnerds',
  description: 'Convert decimals to fractions quickly and easily with our interactive calculator. View step-by-step simplification and repeating decimal conversions.',
  category: 'tool',
  keywords: ['decimal to fraction calculator', 'convert decimal to fraction', 'repeating decimal to fraction', 'decimal to fraction converter', 'math calculator', 'fraction simplifier']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "sendnerds.photonbuilder.com" },
    "publisher": { "@type": "Organization", "name": "sendnerds.photonbuilder.com" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you convert a decimal to a fraction?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To convert a decimal to a fraction, write the decimal over 1, then multiply both top and bottom by 10 for every number after the decimal point. Finally, simplify the fraction by finding the greatest common divisor."
        }
      },
      {
        "@type": "Question",
        "name": "What is 0.5 as a fraction?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "0.5 as a fraction is 1/2. You calculate this by writing 0.5/1, multiplying by 10/10 to get 5/10, and dividing by 5 to get 1/2."
        }
      },
      {
        "@type": "Question",
        "name": "How do I convert a repeating decimal to a fraction?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To convert a repeating decimal to a fraction, set the decimal to x, multiply x by a power of 10 equal to the number of repeating digits, subtract the original equation, and solve for x."
        }
      },
      {
        "@type": "Question",
        "name": "What is 0.75 as a fraction?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "0.75 as a fraction is 3/4. You get this by writing 75/100 and simplifying by dividing both the numerator and denominator by 25."
        }
      },
      {
        "@type": "Question",
        "name": "Why do we need to simplify fractions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Simplifying fractions makes them easier to read, understand, and use in further mathematical calculations by reducing the numbers to their smallest possible whole numbers."
        }
      }
    ]
  }
]);
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description} canonical="https://sendnerds.photonbuilder.com/decimal-to-fraction-calculator">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <div class="calculator-page">
    <section class="hero-section">
      <div class="hero-content">
        <h1>Decimal to Fraction <span>Calculator</span></h1>
        <p>Convert any decimal or repeating decimal into its simplest fractional form.</p>
        <div class="hero-stats">
          <div class="stat-badge">✨ Instant Results</div>
          <div class="stat-badge">🔢 Step-by-Step Proof</div>
          <div class="stat-badge">🔄 Repeating Decimals</div>
        </div>
      </div>
    </section>

    <div class="container">
      <div class="layout-grid">
        <main class="main-content">
          <div class="calculator-card">
            <div class="tabs">
              <button class="tab-btn active" onclick="switchTab('decimalToFraction')">Decimal to Fraction</button>
              <button class="tab-btn" onclick="switchTab('fractionToDecimal')">Fraction to Decimal</button>
            </div>

            <!-- Decimal to Fraction View -->
            <div id="decimalToFractionView" class="view active">
              <div class="input-group">
                <label for="decimalInput">Enter a Decimal Number:</label>
                <div class="input-wrapper">
                  <input type="number" id="decimalInput" step="any" placeholder="e.g., 3.14159 or 0.333" />
                  <button class="clear-btn" onclick="clearInput('decimalInput')" aria-label="Clear">×</button>
                </div>
                <div class="checkbox-group mt-3">
                  <input type="checkbox" id="isRepeating" onchange="toggleRepeatingInput()" />
                  <label for="isRepeating">This is a repeating decimal</label>
                </div>

                <div id="repeatingInputGroup" class="input-group hidden mt-3">
                  <label for="repeatingInput">Enter the repeating part:</label>
                  <input type="number" id="repeatingInput" placeholder="e.g., 3 if 0.333..." />
                </div>
              </div>

              <button class="calc-btn" onclick="calculateDecimalToFraction()">Convert to Fraction</button>
            </div>

            <!-- Fraction to Decimal View -->
            <div id="fractionToDecimalView" class="view hidden">
              <div class="fraction-input-group">
                <div class="input-box">
                  <label for="numeratorInput">Numerator</label>
                  <input type="number" id="numeratorInput" placeholder="e.g., 3" />
                </div>
                <div class="fraction-slash">/</div>
                <div class="input-box">
                  <label for="denominatorInput">Denominator</label>
                  <input type="number" id="denominatorInput" placeholder="e.g., 4" />
                </div>
              </div>
              <button class="calc-btn mt-4" onclick="calculateFractionToDecimal()">Convert to Decimal</button>
            </div>

            <div id="errorBox" class="error-box hidden"></div>

            <div id="resultBox" class="result-box hidden">
              <h2>Result</h2>
              <div id="mainResult" class="main-result"></div>
              <div id="mixedResult" class="mixed-result hidden"></div>

              <div class="visualization" id="visualization">
                <!-- Visual fraction bar will be generated here -->
              </div>

              <div class="steps-box" id="stepsBox">
                <h3>Step-by-Step Solution</h3>
                <div id="stepsContent"></div>
              </div>
            </div>
          </div>

          <section class="educational-section">
            <h2>How to Convert Decimals to Fractions</h2>
            <div class="edu-card">
              <h3>Terminating Decimals</h3>
              <p>A terminating decimal is a decimal that ends. To convert it into a fraction:</p>
              <ol>
                <li>Write down the decimal divided by 1, like this: <code>decimal / 1</code></li>
                <li>Multiply both top and bottom by 10 for every number after the decimal point. (For example, if there are two numbers after the decimal point, then use 100, if there are three then use 1000, etc.)</li>
                <li>Simplify (or reduce) the fraction to its lowest terms.</li>
              </ol>
            </div>

            <div class="edu-card mt-4">
              <h3>Repeating Decimals</h3>
              <p>A repeating decimal has a pattern of numbers that repeats infinitely. The process is a bit more complex:</p>
              <ol>
                <li>Let <code>x</code> equal the repeating decimal.</li>
                <li>Examine the repeating part to find its length (let's say <code>n</code> digits repeat).</li>
                <li>Multiply both sides of the equation by <code>10^n</code>.</li>
                <li>Subtract the original equation (x = ...) from the new equation to eliminate the repeating part.</li>
                <li>Solve for <code>x</code> by dividing.</li>
                <li>Simplify the resulting fraction.</li>
              </ol>
            </div>

            <div class="edu-card mt-4">
              <h3>Simplifying Fractions</h3>
              <p>Simplifying (or reducing) fractions means making the fraction as simple as possible. We do this by dividing the top and bottom by the highest number that can divide into both numbers exactly (the Greatest Common Divisor).</p>
            </div>
          </section>

