      font-size: 1.125rem;
    }

    .faq-item p {
      color: var(--text-secondary);
      margin: 0;
    }

    .sidebar {
      position: sticky;
      top: 2rem;
    }

    .related-tools {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.5rem;
    }

    .related-tools h3 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    .related-links {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .related-links li {
      margin-bottom: 0.75rem;
    }

    .related-links a {
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.2s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .related-links a::before {
      content: "▸";
      color: var(--accent-color);
    }

    .related-links a:hover {
      color: var(--accent-color);
    }

    .hidden {
      display: none !important;
    }

    .mt-3 { margin-top: 1rem; }
    .mt-4 { margin-top: 1.5rem; }
    .mt-5 { margin-top: 3rem; }
  </style>

  <script is:inline>
    // Utility functions
    function gcd(a, b) {
      a = Math.abs(a);
      b = Math.abs(b);
      return b === 0 ? a : gcd(b, a % b);
    }

    function switchTab(tabId) {
      document.querySelectorAll('.view').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));

      document.getElementById(tabId + 'View').classList.remove('hidden');
      event.target.classList.add('active');

      // Hide results when switching tabs
      document.getElementById('resultBox').classList.add('hidden');
      document.getElementById('errorBox').classList.add('hidden');
    }

    function clearInput(id) {
      document.getElementById(id).value = '';
      document.getElementById('resultBox').classList.add('hidden');
      document.getElementById('errorBox').classList.add('hidden');
    }

    function toggleRepeatingInput() {
      const isRepeating = document.getElementById('isRepeating').checked;
      const group = document.getElementById('repeatingInputGroup');
      if (isRepeating) {
        group.classList.remove('hidden');
      } else {
        group.classList.add('hidden');
        document.getElementById('repeatingInput').value = '';
      }
    }

    function formatFractionHTML(num, den) {
      return '<div class="fraction-display"><span class="fraction-numerator">' + num + '</span><span class="fraction-denominator">' + den + '</span></div>';
    }

    function createVisualization(num, den) {
      const visContainer = document.getElementById('visualization');
      const val = num / den;
      const pct = Math.min(100, Math.max(0, val * 100)); // clamp between 0 and 100

      let html = '<h4>Visual Representation</h4>';

      if (val > 1) {
        const whole = Math.floor(val);
        const remNum = num % den;

        html += '<p>Whole parts: ' + whole + '</p>';
        html += '<div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 10px;">';
        for(let i=0; i<whole; i++) {
          html += '<div class="vis-bar-container" style="flex:1; min-width:50px;"><div class="vis-fill" style="width: 100%"></div></div>';
        }
        html += '</div>';

        if (remNum > 0) {
          html += '<p>Fractional part: ' + remNum + '/' + den + '</p>';
          html += '<div class="vis-bar-container"><div class="vis-fill" style="width: ' + ((remNum/den)*100) + '%"></div></div>';
        }
      } else {
        html += '<div class="vis-bar-container"><div class="vis-fill" style="width: ' + pct + '%"></div></div>';
        html += '<div class="vis-label">' + num + ' out of ' + den + ' parts (' + pct.toFixed(1) + '%)</div>';
      }

      visContainer.innerHTML = html;
    }

    function displayError(msg) {
      const errorBox = document.getElementById('errorBox');
      errorBox.textContent = msg;
      errorBox.classList.remove('hidden');
      document.getElementById('resultBox').classList.add('hidden');
    }

    function calculateDecimalToFraction() {
      const decInput = document.getElementById('decimalInput').value.trim();
      const isRepeating = document.getElementById('isRepeating').checked;
      const repInput = document.getElementById('repeatingInput').value.trim();

      document.getElementById('errorBox').classList.add('hidden');

      if (!decInput) {
        displayError('Please enter a valid decimal number.');
        return;
      }

      const isNegative = decInput.startsWith('-');
      const decStr = decInput.replace('-', '');
      const parts = decStr.split('.');

      let wholePart = parts[0] || '0';
      let decPart = parts[1] || '';

      let num = 0;
      let den = 1;
      let steps = '';

      if (isRepeating && repInput) {
        // Handle repeating decimal
        if (false) { // if (!decStr.includes('.')) {
          displayError('Please enter a decimal point for repeating decimals.');
          return;
        }

        // Let's say we have 0.1(6)
        // decPart is '1' (non-repeating)
        // repInput is '6'

        const nonRepPart = decPart;
        const repLength = repInput.length;
        const nonRepLength = nonRepPart.length;

        // Math:
        // x = W.N(R)
        // x * 10^(N_len + R_len) = WNR.R
        // x * 10^(N_len) = WN.R
        // Subtract to solve for x

        const p1 = Math.pow(10, nonRepLength + repLength);
        const p2 = Math.pow(10, nonRepLength);

        const val1 = parseInt(wholePart + nonRepPart + repInput, 10);
        const val2 = parseInt(wholePart + nonRepPart, 10) || 0;

        num = val1 - val2;
        den = p1 - p2;

        steps += '<div class="step">Let x = ' + decInput + repInput + repInput + '...</div>';
        steps += '<div class="step">Multiply by ' + p1 + ': ' + p1 + 'x = ' + val1 + '.' + repInput + '...</div>';
        if (p2 > 1) {
          steps += '<div class="step">Multiply by ' + p2 + ': ' + p2 + 'x = ' + val2 + '.' + repInput + '...</div>';
        } else {
          steps += '<div class="step">Original equation: x = ' + val2 + '.' + repInput + '...</div>';
        }
        steps += '<div class="step">Subtract the two equations: (' + p1 + ' - ' + p2 + ')x = ' + val1 + ' - ' + val2 + '</div>';
        steps += '<div class="step">' + den + 'x = ' + num + '</div>';
        steps += '<div class="step">x = ' + num + ' / ' + den + '</div>';

      } else {
        // Normal decimal
        if (parts.length > 2) {
          displayError('Invalid decimal format.');
          return;
        }

        const decPlaces = decPart.length;
        den = Math.pow(10, decPlaces);
        num = parseInt(wholePart + decPart, 10);

        steps += '<div class="step">Write the decimal as a fraction: ' + decInput + ' / 1</div>';
        if (decPlaces > 0) {
          steps += '<div class="step">Multiply top and bottom by 10^' + decPlaces + ' (' + den + ') to remove decimal.</div>';
          steps += '<div class="step">Result: ' + num + ' / ' + den + '</div>';
        }
      }

      // Simplify
      const divisor = gcd(num, den);
      const simpNum = num / divisor;
      const simpDen = den / divisor;

      if (divisor > 1) {
        steps += '<div class="step">Find Greatest Common Divisor (GCD) of ' + num + ' and ' + den + ', which is ' + divisor + '.</div>';
        steps += '<div class="step">Divide numerator and denominator by ' + divisor + ' to simplify.</div>';
        steps += '<div class="step">Final simplified fraction: ' + formatFractionHTML(simpNum, simpDen) + '</div>';
      } else {
        steps += '<div class="step">The fraction ' + num + '/' + den + ' is already in its simplest form.</div>';
      }

      const finalNum = isNegative ? -simpNum : simpNum;

      // Update UI
      document.getElementById('mainResult').innerHTML = (isNegative ? '-' : '') + formatFractionHTML(simpNum, simpDen);

      const mixedRes = document.getElementById('mixedResult');
      if (simpNum > simpDen && simpDen !== 1) {
        const whole = Math.floor(simpNum / simpDen);
        const rem = simpNum % simpDen;
        mixedRes.innerHTML = 'Mixed Number: <span class="mixed-number">' + (isNegative ? '-' : '') + whole + ' ' + formatFractionHTML(rem, simpDen) + '</span>';
        mixedRes.classList.remove('hidden');
      } else {
        mixedRes.classList.add('hidden');
      }

      document.getElementById('stepsContent').innerHTML = steps;
      createVisualization(simpNum, simpDen);

      document.getElementById('resultBox').classList.remove('hidden');
    }

    function calculateFractionToDecimal() {
      const numInput = document.getElementById('numeratorInput').value.trim();
      const denInput = document.getElementById('denominatorInput').value.trim();

      document.getElementById('errorBox').classList.add('hidden');

      if (!numInput || !denInput) {
        displayError('Please enter both numerator and denominator.');
        return;
      }

      const num = parseFloat(numInput);
      const den = parseFloat(denInput);

      if (den === 0) {
        displayError('Denominator cannot be zero.');
        return;
      }

      const decimal = num / den;

      // UI Update
      document.getElementById('mainResult').innerHTML = decimal.toString();
      document.getElementById('mixedResult').classList.add('hidden');

      let steps = '<div class="step">To convert a fraction to a decimal, divide the numerator by the denominator.</div>';
      steps += '<div class="step">' + num + ' ÷ ' + den + ' = ' + decimal + '</div>';

      document.getElementById('stepsContent').innerHTML = steps;
      createVisualization(Math.abs(num), Math.abs(den));

      document.getElementById('resultBox').classList.remove('hidden');
    }
  </script>
</SiteLayout>
