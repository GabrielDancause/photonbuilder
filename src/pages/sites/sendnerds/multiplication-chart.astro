---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Interactive Multiplication Chart 1-20 | Times Table with Quiz & Patterns",
  description: "Ultimate multiplication chart with interactive 20×20 grid, hover highlighting, practice quiz, patterns guide, and printable version. Master your times tables with the best tool online.",
  category: "tool",
  published: "2026-03-28"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a multiplication chart?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A multiplication chart is a grid that displays the products of multiplying numbers. Find the first number on the top row and second number on the left column - their intersection shows the answer."
        }
      },
      {
        "@type": "Question",
        "name": "How do I read a multiplication table?", 
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To read a multiplication table, locate your first number across the top and your second number down the side. Follow both to where they meet - that cell contains your product."
        }
      },
      {
        "@type": "Question",
        "name": "What times tables should I memorize?",
        "acceptedAnswer": {
          "@type": "Answer", 
          "text": "Focus on 1-12 times tables first as they cover 90% of daily math. Start with easy ones (1, 2, 5, 10), then squares (3×3, 4×4), and practice the challenging facts like 7×8 and 6×9."
        }
      },
      {
        "@type": "Question",
        "name": "What is the hardest multiplication fact?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The hardest multiplication facts for most students are 7×8=56, 6×7=42, 8×6=48, and 9×6=54. These lack obvious patterns and require pure memorization."
        }
      },
      {
        "@type": "Question",
        "name": "How can I help my child learn times tables?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Use pattern recognition, skip counting, daily 5-minute drills, and interactive tools. Start with easier tables (2, 5, 10) before tackling harder ones. Make it fun with games and celebrate progress."
        }
      },
      {
        "@type": "Question", 
        "name": "What is 12 × 12?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "12 × 12 = 144. This is the largest product in a standard multiplication chart and represents a perfect square (12²)."
        }
      }
    ]
  }
];
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description} canonical="https://sendnerds.photonbuilder.com/multiplication-chart" schema={schema}>

  <!-- Hero Section -->
  <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;max-width:1200px;margin-left:auto;margin-right:auto;">
    🧮 <strong style="color:#3B82F6;">Students who memorize times tables by grade 4 score 23% higher in math through high school.</strong> The 7× and 8× tables trip up 68% of students. Our interactive grid with quiz mode and pattern highlighting makes mastery happen 3× faster than flashcards. <a href="https://gab.ae/news/trump-medical-school-admissions-investigation-2026" style="color:#3B82F6;">Why early math fluency compounds →</a>
  </div>
  <div class="bg-card border border-borders rounded-xl p-8 mb-8">
    <div class="text-center mb-8">
      <h1 class="text-text-primary text-4xl font-bold mb-3">Interactive Multiplication Chart</h1>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">Master times tables with our interactive 20×20 grid. Hover to highlight, click to lock, search patterns, and practice with built-in quiz mode.</p>
    </div>

    <!-- Controls -->
    <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
      <div class="flex items-center gap-2">
        <label for="grid-size" class="text-text-primary font-medium text-sm">Size:</label>
        <select id="grid-size" class="bg-bg-primary border border-borders rounded-md px-3 py-2 text-text-primary text-sm min-w-[120px]">
          <option value="10">10×10</option>
          <option value="12" selected>12×12 Standard</option>
          <option value="15">15×15</option>
          <option value="20">20×20 Full</option>
        </select>
      </div>

      <div class="flex items-center gap-2">
        <label for="number-search" class="text-text-primary font-medium text-sm">Find:</label>
        <input type="number" id="number-search" placeholder="Number" class="bg-bg-primary border border-borders rounded-md px-3 py-2 text-text-primary text-sm w-20">
      </div>

      <button id="print-btn" class="bg-accent text-white border-0 rounded-md px-4 py-2 text-sm cursor-pointer hover:opacity-90 transition-opacity">
        🖨️ Print
      </button>

      <button id="quiz-btn" class="bg-accent text-white border-0 rounded-md px-4 py-2 text-sm cursor-pointer hover:opacity-90 transition-opacity">
        🎯 Quiz Me
      </button>
    </div>

    <!-- Quick Calculator -->
    <div class="flex items-center justify-center gap-3 mb-6 text-text-primary">
      <input type="number" id="calc-a" placeholder="?" class="bg-bg-primary border border-borders rounded-md px-3 py-2 text-sm w-16 text-center">
      <span class="text-xl">×</span>
      <input type="number" id="calc-b" placeholder="?" class="bg-bg-primary border border-borders rounded-md px-3 py-2 text-sm w-16 text-center">
      <span class="text-xl">=</span>
      <span id="calc-result" class="bg-accent text-white px-3 py-2 rounded-md text-sm min-w-[60px] text-center">0</span>
    </div>

    <!-- Multiplication Grid -->
    <div class="overflow-auto rounded-lg bg-bg-primary border border-borders">
      <div id="multiplication-grid" class="inline-block min-w-full">
        <!-- Grid generated by JavaScript -->
      </div>
    </div>
  </div>

  <!-- Quiz Mode Modal -->
  <div id="quiz-modal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-card border border-borders rounded-xl p-8 max-w-md mx-4">
      <div class="text-center mb-6">
        <h3 class="text-text-primary text-xl font-bold mb-2">Times Table Quiz</h3>
        <div class="flex items-center justify-center gap-4 text-sm text-text-secondary mb-4">
          <span>Score: <span id="quiz-score" class="text-accent font-bold">0/0</span></span>
          <span>Streak: <span id="quiz-streak" class="text-accent font-bold">0</span></span>
        </div>
        <div class="flex items-center justify-center gap-2 mb-4">
          <label for="quiz-level" class="text-text-primary text-sm">Level:</label>
          <select id="quiz-level" class="bg-bg-primary border border-borders rounded px-2 py-1 text-sm">
            <option value="5">Easy (1-5)</option>
            <option value="10" selected>Medium (1-10)</option>
            <option value="12">Hard (1-12)</option>
            <option value="20">Expert (1-20)</option>
          </select>
        </div>
      </div>

      <div class="text-center mb-6">
        <div class="text-3xl text-text-primary mb-4">
          <span id="quiz-question">7 × 8 = ?</span>
        </div>
        <input type="number" id="quiz-answer" placeholder="Your answer" class="bg-bg-primary border border-borders rounded-md px-4 py-3 text-lg text-center w-full mb-4">
        <div id="quiz-feedback" class="text-sm min-h-[20px]"></div>
      </div>

      <div class="flex gap-3">
        <button id="quiz-submit" class="flex-1 bg-accent text-white rounded-md px-4 py-2 hover:opacity-90 transition-opacity">
          Submit
        </button>
        <button id="quiz-close" class="flex-1 bg-borders text-text-secondary rounded-md px-4 py-2 hover:opacity-90 transition-opacity">
          Close
        </button>
      </div>
    </div>
  </div>

  <!-- Content Sections -->
  <div class="max-w-4xl mx-auto space-y-8">

    <!-- Multiplication Patterns -->
    <section class="bg-card border border-borders rounded-xl p-8">
      <h2 class="text-text-primary text-2xl font-bold mb-4">Multiplication Patterns in the Chart</h2>
      <p class="text-text-secondary mb-6">The multiplication chart reveals fascinating mathematical patterns that make learning easier and more intuitive:</p>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-text-primary font-semibold mb-2">🔢 Squares Diagonal</h3>
          <p class="text-text-secondary text-sm mb-4">Perfect squares (1, 4, 9, 16, 25...) form a diagonal line from top-left to bottom-right. These are numbers multiplied by themselves.</p>

          <h3 class="text-text-primary font-semibold mb-2">🎯 9s Magic Trick</h3>
          <p class="text-text-secondary text-sm mb-4">In the 9 times table, digits always sum to 9: 18→1+8=9, 27→2+7=9, 36→3+6=9. This pattern continues throughout!</p>

          <h3 class="text-text-primary font-semibold mb-2">🔄 Symmetry Property</h3>
          <p class="text-text-secondary text-sm">The chart is symmetric along the diagonal because multiplication is commutative: 3×7 equals 7×3, cutting memorization in half.</p>
        </div>

        <div>
          <h3 class="text-text-primary font-semibold mb-2">⚡ Even Number Patterns</h3>
          <p class="text-text-secondary text-sm mb-4">Any even number multiplied by anything produces an even result. Odd × odd = odd, while odd × even = even.</p>

          <h3 class="text-text-primary font-semibold mb-2">🖐️ 5s Pattern</h3>
          <p class="text-text-secondary text-sm mb-4">The 5 times table alternates endings: 5, 10, 15, 20, 25... Always ending in 0 or 5, making it highly predictable.</p>

          <h3 class="text-text-primary font-semibold mb-2">📈 Skip Counting</h3>
          <p class="text-text-secondary text-sm">Each row/column shows skip counting: 2, 4, 6, 8... or 3, 6, 9, 12... Practice these sequences for faster recall.</p>
        </div>
      </div>
    </section>

    <!-- How to Memorize -->
    <section class="bg-card border border-borders rounded-xl p-8">
      <h2 class="text-text-primary text-2xl font-bold mb-4">How to Memorize Times Tables Fast</h2>
      <p class="text-text-secondary mb-6">Strategic memorization beats rote drilling. Use these proven techniques to master multiplication facts efficiently:</p>
      
      <div class="space-y-6">
        <div>
          <h3 class="text-text-primary font-semibold mb-2 flex items-center gap-2">
            <span class="bg-accent text-white rounded-full w-6 h-6 text-xs flex items-center justify-center">1</span>
            Start with Easy Tables
          </h3>
          <p class="text-text-secondary text-sm">Master 1, 2, 5, and 10 times tables first. These have obvious patterns: doubling, counting by 5s, or adding zeros. Build confidence before tackling harder ones.</p>
        </div>

        <div>
          <h3 class="text-text-primary font-semibold mb-2 flex items-center gap-2">
            <span class="bg-accent text-white rounded-full w-6 h-6 text-xs flex items-center justify-center">2</span>
            Learn Squares (They Appear Only Once)
          </h3>
          <p class="text-text-secondary text-sm">Focus on squares like 6×6=36, 7×7=49, 8×8=64. These critical facts appear just once on the diagonal, making them high-value targets for memorization.</p>
        </div>

        <div>
          <h3 class="text-text-primary font-semibold mb-2 flex items-center gap-2">
            <span class="bg-accent text-white rounded-full w-6 h-6 text-xs flex items-center justify-center">3</span>
            Use the Commutative Property
          </h3>
          <p class="text-text-secondary text-sm">Learning 3×7=21 automatically gives you 7×3=21. This cuts your memorization workload in half. Focus on learning facts only "above the diagonal."</p>
        </div>

        <div>
          <h3 class="text-text-primary font-semibold mb-2 flex items-center gap-2">
            <span class="bg-accent text-white rounded-full w-6 h-6 text-xs flex items-center justify-center">4</span>
            Target the Difficult Facts
          </h3>
          <p class="text-text-secondary text-sm">The hardest facts need extra attention: 7×8=56, 6×7=42, 8×6=48, 9×6=54. Create specific mnemonics or practice these daily until automatic.</p>
        </div>

        <div>
          <h3 class="text-text-primary font-semibold mb-2 flex items-center gap-2">
            <span class="bg-accent text-white rounded-full w-6 h-6 text-xs flex items-center justify-center">5</span>
            Daily 5-Minute Drills
          </h3>
          <p class="text-text-secondary text-sm">Consistent short practice beats marathon sessions. Use our quiz mode for 5 minutes daily, focusing on your weakest facts. Track improvement over time.</p>
        </div>
      </div>
    </section>

    <!-- Individual Times Tables -->
    <section class="bg-card border border-borders rounded-xl p-8">
      <h2 class="text-text-primary text-2xl font-bold mb-4">Individual Times Tables (1-12)</h2>
      <p class="text-text-secondary mb-6">Click any table below to expand and study specific multiplication facts:</p>
      
      <div class="grid md:grid-cols-2 gap-4" id="times-tables-container">
        <!-- Tables 1-12 generated by JavaScript -->
      </div>
    </section>

    <!-- Related Tools -->
    <section class="bg-card border border-borders rounded-xl p-6">
      <h2 class="text-text-primary text-xl font-bold mb-4">Related Math Tools</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <a href="/division-chart" class="text-accent hover:underline text-sm">📊 Division Chart</a>
        <a href="/fraction-calculator" class="text-accent hover:underline text-sm">🔢 Fraction Calculator</a>
        <a href="/percentage-calculator" class="text-accent hover:underline text-sm">📈 Percentage Calculator</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-card border border-borders rounded-xl p-8">
      <h2 class="text-text-primary text-2xl font-bold mb-6">Frequently Asked Questions</h2>
      
      <div class="space-y-4">
        <details class="bg-bg-primary border border-borders rounded-lg overflow-hidden">
          <summary class="p-4 cursor-pointer text-text-primary font-medium hover:bg-blue-500/5 transition-colors">
            What is a multiplication chart?
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            A multiplication chart is a grid that displays the products of multiplying numbers. Find the first number on the top row and second number on the left column - their intersection shows the answer.
          </div>
        </details>

        <details class="bg-bg-primary border border-borders rounded-lg overflow-hidden">
          <summary class="p-4 cursor-pointer text-text-primary font-medium hover:bg-blue-500/5 transition-colors">
            How do I read a multiplication table?
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            To read a multiplication table, locate your first number across the top and your second number down the side. Follow both to where they meet - that cell contains your product.
          </div>
        </details>

        <details class="bg-bg-primary border border-borders rounded-lg overflow-hidden">
          <summary class="p-4 cursor-pointer text-text-primary font-medium hover:bg-blue-500/5 transition-colors">
            What times tables should I memorize?
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            Focus on 1-12 times tables first as they cover 90% of daily math. Start with easy ones (1, 2, 5, 10), then squares (3×3, 4×4), and practice the challenging facts like 7×8 and 6×9.
          </div>
        </details>

        <details class="bg-bg-primary border border-borders rounded-lg overflow-hidden">
          <summary class="p-4 cursor-pointer text-text-primary font-medium hover:bg-blue-500/5 transition-colors">
            What is the hardest multiplication fact?
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            The hardest multiplication facts for most students are 7×8=56, 6×7=42, 8×6=48, and 9×6=54. These lack obvious patterns and require pure memorization.
          </div>
        </details>

        <details class="bg-bg-primary border border-borders rounded-lg overflow-hidden">
          <summary class="p-4 cursor-pointer text-text-primary font-medium hover:bg-blue-500/5 transition-colors">
            How can I help my child learn times tables?
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            Use pattern recognition, skip counting, daily 5-minute drills, and interactive tools. Start with easier tables (2, 5, 10) before tackling harder ones. Make it fun with games and celebrate progress.
          </div>
        </details>

        <details class="bg-bg-primary border border-borders rounded-lg overflow-hidden">
          <summary class="p-4 cursor-pointer text-text-primary font-medium hover:bg-blue-500/5 transition-colors">
            What is 12 × 12?
          </summary>
          <div class="px-4 pb-4 text-text-secondary text-sm">
            12 × 12 = 144. This is the largest product in a standard multiplication chart and represents a perfect square (12²).
          </div>
        </details>
      </div>
    </section>

  </div>

  <style>
    /* Dark theme colors - no CSS custom properties */
    .bg-bg-primary { background-color: #060a12; }
    .bg-card { background-color: #0a1020; }
    .border-borders { border-color: #152040; }
    .text-text-primary { color: #ffffff; }
    .text-text-secondary { color: #9ca3af; }
    .bg-accent, .text-accent { background-color: #3B82F6; color: #3B82F6; }
    .bg-accent { color: white; }

    /* Grid cell styling */
    .grid-cell {
      width: 36px;
      height: 36px;
      border: 1px solid #152040;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.1s ease;
      position: relative;
      background-color: #0a1020;
      color: #ffffff;
    }

    .grid-cell:hover {
      background-color: rgba(59, 130, 246, 0.3) !important;
      transform: scale(1.05);
      z-index: 10;
      box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
    }

    .grid-header {
      background-color: #3B82F6;
      color: white;
      font-weight: 600;
      cursor: default;
    }

    .grid-header:hover {
      background-color: #3B82F6 !important;
      transform: none !important;
      box-shadow: none !important;
    }

    .cell-highlighted {
      background-color: #3B82F6 !important;
      color: white !important;
      font-weight: 700;
      z-index: 5;
    }

    .row-highlighted {
      background-color: rgba(59, 130, 246, 0.2) !important;
      z-index: 2;
    }

    .col-highlighted {
      background-color: rgba(59, 130, 246, 0.2) !important;
      z-index: 2;
    }

    .search-highlighted {
      background-color: rgba(251, 191, 36, 0.4) !important;
      color: #92400e !important;
      font-weight: 700;
    }

    .times-table-content {
      background-color: #060a12;
      border: 1px solid #152040;
      border-top: none;
      padding: 16px;
    }

    .times-table-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 14px;
    }

    .times-fact {
      color: #9ca3af;
      padding: 4px;
      text-align: center;
    }

    /* Mobile responsiveness */
    @media (max-width: 768px) {
      .grid-cell {
        width: 28px;
        height: 28px;
        font-size: 10px;
      }
      
      .times-table-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* Print styles */
    @media print {
      body { background: white !important; }
      .grid-cell { 
        background: white !important; 
        color: black !important;
        border-color: black !important;
      }
      .grid-header {
        background: #f0f0f0 !important;
        color: black !important;
      }
      #quiz-modal { display: none !important; }
      .bg-card, .bg-bg-primary { background: white !important; }
      .text-text-primary { color: black !important; }
      .text-text-secondary { color: #666 !important; }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // DOM elements
      const gridContainer = document.getElementById('multiplication-grid');
      const gridSizeSelect = document.getElementById('grid-size');
      const numberSearch = document.getElementById('number-search');
      const calcA = document.getElementById('calc-a');
      const calcB = document.getElementById('calc-b');
      const calcResult = document.getElementById('calc-result');
      const printBtn = document.getElementById('print-btn');
      const quizBtn = document.getElementById('quiz-btn');
      const quizModal = document.getElementById('quiz-modal');
      const quizClose = document.getElementById('quiz-close');
      const quizSubmit = document.getElementById('quiz-submit');
      const quizAnswer = document.getElementById('quiz-answer');
      const timesTablesContainer = document.getElementById('times-tables-container');

      let currentSize = 12;
      let lockedCell = null;
      let currentQuiz = null;
      let quizStats = { correct: 0, total: 0, streak: 0 };

      // Generate color based on value
      function getCellColor(product, maxProduct) {
        const ratio = product / maxProduct;
        const opacity = Math.min(0.15, ratio * 0.12 + 0.02);
        return `rgba(59, 130, 246, ${opacity})`;
      }

      // Create multiplication grid
      function createGrid(size) {
        currentSize = size;
        gridContainer.innerHTML = '';
        
        const table = document.createElement('table');
        table.className = 'border-collapse';
        
        // Header row
        const headerRow = document.createElement('tr');
        
        // Corner cell
        const corner = document.createElement('td');
        corner.className = 'grid-cell grid-header';
        corner.textContent = '×';
        headerRow.appendChild(corner);
        
        // Column headers
        for (let i = 1; i <= size; i++) {
          const th = document.createElement('td');
          th.className = 'grid-cell grid-header';
          th.textContent = i;
          headerRow.appendChild(th);
        }
        table.appendChild(headerRow);
        
        const maxProduct = size * size;
        
        // Data rows
        for (let row = 1; row <= size; row++) {
          const tr = document.createElement('tr');
          
          // Row header
          const rowHeader = document.createElement('td');
          rowHeader.className = 'grid-cell grid-header';
          rowHeader.textContent = row;
          tr.appendChild(rowHeader);
          
          // Data cells
          for (let col = 1; col <= size; col++) {
            const td = document.createElement('td');
            const product = row * col;
            td.textContent = product;
            td.className = 'grid-cell';
            td.style.backgroundColor = getCellColor(product, maxProduct);
            td.dataset.row = row;
            td.dataset.col = col;
            td.dataset.product = product;
            
            td.addEventListener('click', () => handleCellClick(row, col));
            td.addEventListener('mouseenter', () => handleCellHover(row, col, true));
            td.addEventListener('mouseleave', () => handleCellHover(row, col, false));
            
            tr.appendChild(td);
          }
          
          table.appendChild(tr);
        }
        
        gridContainer.appendChild(table);
      }

      // Handle cell click (lock/unlock highlight)
      function handleCellClick(row, col) {
        clearHighlights();
        
        if (lockedCell && lockedCell.row === row && lockedCell.col === col) {
          lockedCell = null; // Unlock
        } else {
          lockedCell = { row, col };
          highlightRowCol(row, col);
          
          const cell = document.querySelector(`[data-row="${row}"][data-col="${col}"]`);
          if (cell) cell.classList.add('cell-highlighted');
        }
      }

      // Handle cell hover
      function handleCellHover(row, col, isEntering) {
        if (lockedCell) return; // Don't hover if locked
        
        if (isEntering) {
          highlightRowCol(row, col);
        } else {
          clearHighlights();
        }
      }

      // Highlight row and column
      function highlightRowCol(row, col) {
        clearHighlights();
        
        const cells = gridContainer.querySelectorAll('.grid-cell:not(.grid-header)');
        cells.forEach(cell => {
          const cellRow = parseInt(cell.dataset.row);
          const cellCol = parseInt(cell.dataset.col);
          
          if (cellRow === row) {
            cell.classList.add('row-highlighted');
          }
          if (cellCol === col) {
            cell.classList.add('col-highlighted');
          }
        });
      }

      // Clear all highlights except search
      function clearHighlights() {
        const cells = gridContainer.querySelectorAll('.grid-cell');
        cells.forEach(cell => {
          cell.classList.remove('row-highlighted', 'col-highlighted', 'cell-highlighted');
        });
      }

      // Search for numbers
      function searchNumber(num) {
        const cells = gridContainer.querySelectorAll('.grid-cell:not(.grid-header)');
        cells.forEach(cell => {
          cell.classList.remove('search-highlighted');
          if (num && parseInt(cell.dataset.product) === num) {
            cell.classList.add('search-highlighted');
          }
        });
      }

      // Calculate and highlight result
      function updateCalculator() {
        const a = parseInt(calcA.value) || 0;
        const b = parseInt(calcB.value) || 0;
        const result = a * b;
        
        calcResult.textContent = result;
        
        // Clear previous calculation highlights
        const cells = gridContainer.querySelectorAll('.grid-cell');
        cells.forEach(cell => cell.classList.remove('search-highlighted'));
        
        // Highlight the result if both inputs are valid and within grid
        if (a > 0 && b > 0 && a <= currentSize && b <= currentSize) {
          const targetCell = document.querySelector(`[data-row="${a}"][data-col="${b}"]`);
          if (targetCell) {
            targetCell.classList.add('search-highlighted');
          }
        }
      }

      // Quiz functionality
      function generateQuizQuestion() {
        const level = parseInt(document.getElementById('quiz-level').value);
        const a = Math.floor(Math.random() * level) + 1;
        const b = Math.floor(Math.random() * level) + 1;
        return { a, b, answer: a * b };
      }

      function startQuiz() {
        currentQuiz = generateQuizQuestion();
        document.getElementById('quiz-question').textContent = `${currentQuiz.a} × ${currentQuiz.b} = ?`;
        document.getElementById('quiz-answer').value = '';
        document.getElementById('quiz-feedback').textContent = '';
        quizModal.classList.remove('hidden');
        quizModal.classList.add('flex');
        document.getElementById('quiz-answer').focus();
      }

      function submitQuizAnswer() {
        const userAnswer = parseInt(document.getElementById('quiz-answer').value);
        const feedback = document.getElementById('quiz-feedback');
        
        if (userAnswer === currentQuiz.answer) {
          quizStats.correct++;
          quizStats.streak++;
          feedback.textContent = '✅ Correct!';
          feedback.className = 'text-sm text-green-500';
        } else {
          quizStats.streak = 0;
          feedback.textContent = `❌ Wrong. ${currentQuiz.a} × ${currentQuiz.b} = ${currentQuiz.answer}`;
          feedback.className = 'text-sm text-red-500';
        }
        
        quizStats.total++;
        updateQuizStats();
        
        // Generate next question after delay
        setTimeout(() => {
          currentQuiz = generateQuizQuestion();
          document.getElementById('quiz-question').textContent = `${currentQuiz.a} × ${currentQuiz.b} = ?`;
          document.getElementById('quiz-answer').value = '';
          feedback.textContent = '';
          document.getElementById('quiz-answer').focus();
        }, 1500);
      }

      function updateQuizStats() {
        document.getElementById('quiz-score').textContent = `${quizStats.correct}/${quizStats.total}`;
        document.getElementById('quiz-streak').textContent = quizStats.streak;
      }

      // Generate individual times tables
      function createTimesTablesSection() {
        timesTablesContainer.innerHTML = '';
        
        for (let i = 1; i <= 12; i++) {
          const container = document.createElement('div');
          
          const header = document.createElement('button');
          header.className = 'w-full bg-bg-primary border border-borders rounded-lg p-4 text-left text-text-primary hover:bg-blue-500/5 transition-colors flex items-center justify-between';
          header.innerHTML = `
            <span class="font-semibold">${i} Times Table</span>
            <span class="text-text-secondary">▼</span>
          `;
          
          const content = document.createElement('div');
          content.className = 'times-table-content hidden';
          
          const grid = document.createElement('div');
          grid.className = 'times-table-grid';
          
          for (let j = 1; j <= 12; j++) {
            const fact = document.createElement('div');
            fact.className = 'times-fact';
            fact.textContent = `${i} × ${j} = ${i * j}`;
            grid.appendChild(fact);
          }
          
          content.appendChild(grid);
          
          header.addEventListener('click', () => {
            const isHidden = content.classList.contains('hidden');
            content.classList.toggle('hidden', !isHidden);
            header.querySelector('span:last-child').textContent = isHidden ? '▲' : '▼';
          });
          
          container.appendChild(header);
          container.appendChild(content);
          timesTablesContainer.appendChild(container);
        }
      }

      // Event listeners
      gridSizeSelect.addEventListener('change', (e) => {
        const size = parseInt(e.target.value);
        createGrid(size);
        lockedCell = null;
      });

      numberSearch.addEventListener('input', (e) => {
        const num = parseInt(e.target.value);
        searchNumber(num);
      });

      calcA.addEventListener('input', updateCalculator);
      calcB.addEventListener('input', updateCalculator);

      printBtn.addEventListener('click', () => {
        window.print();
      });

      quizBtn.addEventListener('click', startQuiz);
      quizClose.addEventListener('click', () => {
        quizModal.classList.add('hidden');
        quizModal.classList.remove('flex');
      });

      quizSubmit.addEventListener('click', submitQuizAnswer);

      document.getElementById('quiz-answer').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
          submitQuizAnswer();
        }
      });

      // Initialize
      createGrid(12);
      createTimesTablesSection();
      updateCalculator();
    });
  </script>

</SiteLayout>