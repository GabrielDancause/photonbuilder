---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Place Value Chart: Interactive Number Explorer & Quiz",
  description: "Master place values from billions to thousandths with our interactive chart, number explorer, quiz mode, and comparison tool. Perfect for students and teachers.",
  category: "tool",
  published: "2026-03-29",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Place Value Chart: Learn Number Places from Billions to Thousandths",
    "description": "Interactive place value chart with number explorer, quiz mode, decimal places, and comparison tool for students learning number sense.",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased",
      "url": "https://photonbuilder.com/sendnerds"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SiliconBased",
      "url": "https://photonbuilder.com/sendnerds"
    },
    "datePublished": "2026-03-29",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://sendnerds.photonbuilder.com/place-value-chart"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is place value in math?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Place value is the value of each digit in a number based on its position. For example, in the number 5,432, the digit 5 is in the thousands place, so its value is 5,000. The digit 4 is in the hundreds place (value 400), 3 is in the tens place (value 30), and 2 is in the ones place (value 2)."
        }
      },
      {
        "@type": "Question",
        "name": "How do you read a place value chart?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Read a place value chart from left to right, starting with the largest place. Each column represents a power of 10. The digit in each column tells you how many of that place value the number contains. For example, if 7 is in the hundreds column, the number has 7 hundreds, or 700."
        }
      },
      {
        "@type": "Question",
        "name": "What is expanded form of a number?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Expanded form breaks a number into the sum of each digit multiplied by its place value. For example, 3,456 in expanded form is 3,000 + 400 + 50 + 6. This helps students understand that each digit contributes a different amount based on its position."
        }
      },
      {
        "@type": "Question",
        "name": "How do decimal place values work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Decimal place values extend the place value system to the right of the decimal point. The first place after the decimal is tenths (1/10), then hundredths (1/100), then thousandths (1/1000). For example, in 3.456, the 4 is in the tenths place (0.4), the 5 is in the hundredths place (0.05), and the 6 is in the thousandths place (0.006)."
        }
      },
      {
        "@type": "Question",
        "name": "Why is place value important?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Place value is the foundation of our number system. Understanding place value is essential for addition, subtraction, multiplication, division, rounding, comparing numbers, and working with decimals and large numbers. Without place value understanding, students cannot perform multi-digit arithmetic correctly."
        }
      }
    ]
  }
];
---
<SiteLayout site="sendnerds" title="Place Value Chart: Interactive Number Explorer & Quiz" description="Master place values from billions to thousandths with our interactive chart, number explorer, quiz mode, and comparison tool. Perfect for students and teachers." canonical="https://sendnerds.photonbuilder.com/place-value-chart" schema={schema}>
  <style is:inline>
    .page-content { max-width: 1100px; margin: 0 auto; padding: 1.5rem; }
    .hero { text-align: center; margin-bottom: 2rem; }
    .hero h1 { font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem; color: var(--text-primary, #1a1a2e); }
    .hero .subtitle { font-size: 1.1rem; color: var(--text-secondary, #555); margin: 0; }

    /* Tabs */
    .tabs { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; justify-content: center; }
    .tab-btn { padding: 0.6rem 1.2rem; border: 2px solid var(--border, #e0e0e0); border-radius: 999px; background: var(--card-bg, #fff); color: var(--text-primary, #333); font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; }
    .tab-btn:hover { border-color: #6c5ce7; color: #6c5ce7; }
    .tab-btn.active { background: #6c5ce7; color: #fff; border-color: #6c5ce7; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* Cards */
    .card { background: var(--card-bg, #fff); border: 1px solid var(--border, #e0e0e0); border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card h2 { font-size: 1.35rem; font-weight: 700; margin: 0 0 1rem; color: var(--text-primary, #1a1a2e); }
    .card h3 { font-size: 1.1rem; font-weight: 600; margin: 1rem 0 0.5rem; color: var(--text-primary, #1a1a2e); }

    /* Place Value Chart */
    .chart-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .pv-chart { display: flex; gap: 0; border: 2px solid var(--border, #ddd); border-radius: 0.75rem; overflow: hidden; min-width: 900px; }
    .pv-col { flex: 1; min-width: 80px; text-align: center; border-right: 1px solid var(--border, #ddd); transition: background 0.3s; }
    .pv-col:last-child { border-right: none; }
    .pv-col.decimal-sep { flex: 0 0 30px; min-width: 30px; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 900; background: var(--card-bg, #f8f8f8); color: var(--text-secondary, #666); }
    .pv-header { padding: 0.5rem 0.25rem; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.03em; color: #fff; }
    .pv-col.whole .pv-header { background: #6c5ce7; }
    .pv-col.decimal .pv-header { background: #00b894; }
    .pv-power { padding: 0.3rem 0.25rem; font-size: 0.7rem; color: var(--text-secondary, #888); background: var(--bg-alt, #f0f0f0); }
    .pv-example { padding: 0.3rem 0.25rem; font-size: 0.7rem; color: var(--text-secondary, #888); border-bottom: 1px solid var(--border, #ddd); }
    .pv-digit { padding: 1rem 0.25rem; font-size: 1.8rem; font-weight: 800; color: var(--text-primary, #333); min-height: 60px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
    .pv-col.highlighted { background: rgba(108, 92, 231, 0.12); }
    .pv-col.highlighted .pv-digit { color: #6c5ce7; transform: scale(1.15); }
    .pv-col.decimal.highlighted { background: rgba(0, 184, 148, 0.12); }
    .pv-col.decimal.highlighted .pv-digit { color: #00b894; }

    /* Explorer */
    .explorer-input-row { display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .explorer-input { flex: 1; min-width: 200px; padding: 0.75rem 1rem; font-size: 1.1rem; border: 2px solid var(--border, #ddd); border-radius: 0.75rem; background: var(--card-bg, #fff); color: var(--text-primary, #333); font-family: 'Courier New', monospace; }
    .explorer-input:focus { outline: none; border-color: #6c5ce7; box-shadow: 0 0 0 3px rgba(108,92,231,0.15); }
    .btn { padding: 0.75rem 1.5rem; border: none; border-radius: 0.75rem; font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: all 0.2s; }
    .btn-primary { background: #6c5ce7; color: #fff; }
    .btn-primary:hover { background: #5a4bd1; }
    .btn-secondary { background: var(--bg-alt, #f0f0f0); color: var(--text-primary, #333); border: 2px solid var(--border, #ddd); }
    .btn-secondary:hover { border-color: #6c5ce7; color: #6c5ce7; }
    .btn-success { background: #00b894; color: #fff; }
    .btn-success:hover { background: #00a381; }

    .breakdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem; }
    .breakdown-item { padding: 1rem; border-radius: 0.75rem; background: var(--bg-alt, #f5f5ff); border: 1px solid var(--border, #e0e0e0); }
    .breakdown-label { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary, #888); margin-bottom: 0.3rem; }
    .breakdown-value { font-size: 1.05rem; font-weight: 700; color: var(--text-primary, #333); word-break: break-all; }
    .breakdown-value.large { font-size: 0.9rem; }

    /* Quiz */
    .quiz-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .quiz-score { font-size: 1.1rem; font-weight: 700; color: #6c5ce7; }
    .quiz-progress { font-size: 0.9rem; color: var(--text-secondary, #888); }
    .quiz-question { font-size: 1.2rem; font-weight: 700; color: var(--text-primary, #333); margin-bottom: 1rem; line-height: 1.5; }
    .quiz-question .highlight-digit { display: inline-block; background: #6c5ce7; color: #fff; padding: 0.1em 0.35em; border-radius: 0.3em; font-family: 'Courier New', monospace; }
    .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem; }
    .quiz-option { padding: 0.85rem 1rem; border: 2px solid var(--border, #ddd); border-radius: 0.75rem; background: var(--card-bg, #fff); color: var(--text-primary, #333); font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.2s; text-align: center; }
    .quiz-option:hover:not(.disabled) { border-color: #6c5ce7; background: rgba(108,92,231,0.05); }
    .quiz-option.correct { border-color: #00b894; background: rgba(0,184,148,0.1); color: #00b894; }
    .quiz-option.wrong { border-color: #e74c3c; background: rgba(231,76,60,0.1); color: #e74c3c; }
    .quiz-option.disabled { cursor: default; opacity: 0.7; }
    .quiz-feedback { padding: 0.75rem 1rem; border-radius: 0.75rem; font-weight: 600; margin-bottom: 1rem; }
    .quiz-feedback.correct { background: rgba(0,184,148,0.1); color: #00b894; border: 1px solid #00b894; }
    .quiz-feedback.wrong { background: rgba(231,76,60,0.1); color: #e74c3c; border: 1px solid #e74c3c; }
    .quiz-results { text-align: center; padding: 2rem 1rem; }
    .quiz-results .score-big { font-size: 3rem; font-weight: 900; color: #6c5ce7; }
    .quiz-results .score-label { font-size: 1.1rem; color: var(--text-secondary, #666); margin: 0.5rem 0 1.5rem; }

    /* Comparison */
    .compare-row { display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; align-items: end; }
    .compare-field { flex: 1; min-width: 150px; }
    .compare-field label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary, #888); margin-bottom: 0.3rem; }
    .compare-field input { width: 100%; padding: 0.7rem 1rem; font-size: 1.05rem; border: 2px solid var(--border, #ddd); border-radius: 0.75rem; background: var(--card-bg, #fff); color: var(--text-primary, #333); font-family: 'Courier New', monospace; box-sizing: border-box; }
    .compare-field input:focus { outline: none; border-color: #6c5ce7; box-shadow: 0 0 0 3px rgba(108,92,231,0.15); }
    .compare-result { padding: 1.25rem; border-radius: 0.75rem; text-align: center; font-size: 1.3rem; font-weight: 800; margin-top: 0.5rem; }
    .compare-result.greater { background: rgba(108,92,231,0.1); color: #6c5ce7; }
    .compare-result.equal { background: rgba(0,184,148,0.1); color: #00b894; }
    .compare-aligned { margin-top: 1rem; }
    .compare-aligned table { width: 100%; border-collapse: collapse; font-family: 'Courier New', monospace; }
    .compare-aligned th { font-size: 0.65rem; font-weight: 700; color: var(--text-secondary, #888); text-transform: uppercase; padding: 0.4rem 0.3rem; border-bottom: 2px solid var(--border, #ddd); }
    .compare-aligned td { text-align: center; padding: 0.6rem 0.3rem; font-size: 1.2rem; font-weight: 700; border-bottom: 1px solid var(--border, #eee); }
    .compare-aligned tr.num-a td { color: #6c5ce7; }
    .compare-aligned tr.num-b td { color: #00b894; }
    .compare-aligned td.diff-col { background: rgba(231,76,60,0.08); }

    /* Decimal section */
    .decimal-example-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; margin-top: 1rem; }
    .decimal-example { padding: 1rem; border-radius: 0.75rem; background: rgba(0,184,148,0.06); border: 1px solid rgba(0,184,148,0.2); }
    .decimal-example .de-number { font-size: 1.4rem; font-weight: 800; color: #00b894; font-family: 'Courier New', monospace; }
    .decimal-example .de-desc { font-size: 0.9rem; color: var(--text-secondary, #666); margin-top: 0.3rem; }

    /* FAQ */
    .faq-section { margin-top: 2rem; }
    .faq-item { border-bottom: 1px solid var(--border, #eee); }
    .faq-q { padding: 1rem 0; font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; color: var(--text-primary, #333); }
    .faq-q::after { content: '+'; font-size: 1.3rem; font-weight: 400; color: var(--text-secondary, #888); transition: transform 0.2s; }
    .faq-item.open .faq-q::after { content: '−'; }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .faq-a-inner { padding: 0 0 1rem; color: var(--text-secondary, #555); line-height: 1.7; }
    .faq-item.open .faq-a { max-height: 300px; }

    /* Prose */
    .prose { margin-top: 2rem; }
    .prose h2 { font-size: 1.3rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--text-primary, #1a1a2e); }
    .prose p { color: var(--text-secondary, #555); line-height: 1.7; margin: 0 0 1rem; }
    .prose ul { color: var(--text-secondary, #555); line-height: 1.7; margin: 0 0 1rem; padding-left: 1.5rem; }

    /* Print */
    @media print {
      .tabs, .tab-btn, .explorer-input-row, .btn, .quiz-header, .quiz-options, .quiz-feedback, .compare-row, .faq-section, .no-print { display: none !important; }
      .tab-panel { display: block !important; }
      .page-content { padding: 0; max-width: 100%; }
      .card { border: 1px solid #ccc; break-inside: avoid; page-break-inside: avoid; }
      .pv-chart { min-width: 0; }
      .pv-col { min-width: 55px; }
      .hero h1 { font-size: 1.5rem; }
    }

    /* Dark theme */
    @media (prefers-color-scheme: dark) {
      .hero h1, .card h2, .card h3, .faq-q, .quiz-question, .breakdown-value { color: #e8e8f0; }
      .hero .subtitle, .breakdown-label, .faq-a-inner, .prose p, .prose ul { color: #a0a0b8; }
      .pv-power, .pv-example { background: rgba(255,255,255,0.04); color: #a0a0b8; }
      .pv-digit { color: #e8e8f0; }
      .breakdown-item { background: rgba(108,92,231,0.08); border-color: rgba(108,92,231,0.2); }
      .quiz-option { background: rgba(255,255,255,0.04); color: #e8e8f0; }
      .quiz-option:hover:not(.disabled) { background: rgba(108,92,231,0.1); }
      .decimal-example { background: rgba(0,184,148,0.08); border-color: rgba(0,184,148,0.25); }
      .decimal-example .de-desc { color: #a0a0b8; }
      .compare-result.greater { background: rgba(108,92,231,0.15); }
      .compare-result.equal { background: rgba(0,184,148,0.15); }
      .compare-aligned th { color: #a0a0b8; }
    }

    @media (max-width: 640px) {
      .hero h1 { font-size: 1.5rem; }
      .breakdown-grid { grid-template-columns: 1fr; }
      .quiz-options { grid-template-columns: 1fr; }
      .tabs { gap: 0.35rem; }
      .tab-btn { padding: 0.5rem 0.9rem; font-size: 0.8rem; }
    }
  </style>

  <div class="page-content">
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      🔢 <strong style="color:#3B82F6;">Place value understanding by grade 2 predicts math achievement through grade 8 — it's the foundation everything else builds on.</strong> Students who can fluently decompose 3,456 into 3 thousands + 4 hundreds + 5 tens + 6 ones master multiplication 2× faster. Explore, quiz, and compare numbers interactively. <a href="https://gab.ae/news/trump-medical-school-admissions-investigation-2026" style="color:#3B82F6;">Why foundational skills compound →</a>
    </div>
    <div class="hero">
      <h1>Place Value Chart</h1>
      <p class="subtitle">Interactive number explorer, quiz, and comparison tool for mastering place values</p>
    </div>

    <div class="tabs no-print">
      <button class="tab-btn active" data-tab="chart">Place Value Chart</button>
      <button class="tab-btn" data-tab="explorer">Number Explorer</button>
      <button class="tab-btn" data-tab="quiz">Quiz</button>
      <button class="tab-btn" data-tab="decimals">Decimals</button>
      <button class="tab-btn" data-tab="compare">Compare</button>
    </div>

    <!-- TAB 1: Place Value Chart -->
    <div class="tab-panel active" id="panel-chart">
      <div class="card">
        <h2>Interactive Place Value Chart</h2>
        <p style="color:var(--text-secondary,#666);margin:0 0 1rem;font-size:0.95rem;">Hover over any column to highlight it. Each column shows the place name, power of 10, and an example value.</p>
        <div class="chart-scroll">
          <div class="pv-chart" id="mainChart">
            <!-- built by JS -->
          </div>
        </div>
        <div style="margin-top:1rem;text-align:right;" class="no-print">
          <button class="btn btn-secondary" onclick="window.print()">🖨️ Print Chart</button>
        </div>
      </div>
    </div>

    <!-- TAB 2: Number Explorer -->
    <div class="tab-panel" id="panel-explorer">
      <div class="card">
        <h2>Number Explorer</h2>
        <p style="color:var(--text-secondary,#666);margin:0 0 1rem;font-size:0.95rem;">Enter any number to see its place value breakdown, written form, expanded form, and more.</p>
        <div class="explorer-input-row">
          <input type="text" id="explorerInput" class="explorer-input" placeholder="Enter a number, e.g. 4321.56" inputmode="decimal">
          <button class="btn btn-primary" id="exploreBtn">Explore</button>
          <button class="btn btn-secondary" id="exploreClear">Clear</button>
        </div>
        <div class="chart-scroll">
          <div class="pv-chart" id="explorerChart"></div>
        </div>
        <div class="breakdown-grid" id="explorerBreakdown"></div>
      </div>
    </div>

    <!-- TAB 3: Quiz -->
    <div class="tab-panel" id="panel-quiz">
      <div class="card">
        <h2>Place Value Quiz</h2>
        <div id="quizArea">
          <div style="text-align:center;padding:2rem 0;">
            <p style="color:var(--text-secondary,#666);margin-bottom:1.5rem;font-size:1.05rem;">Test your place value knowledge with 10 random questions!</p>
            <button class="btn btn-primary" id="startQuiz" style="font-size:1.1rem;padding:0.85rem 2.5rem;">Start Quiz</button>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB 4: Decimals -->
    <div class="tab-panel" id="panel-decimals">
      <div class="card">
        <h2>Decimal Place Values</h2>
        <p style="color:var(--text-secondary,#666);margin:0 0 1rem;font-size:0.95rem;">Place values extend to the right of the decimal point. Each position is 1/10 of the one before it.</p>
        <div class="chart-scroll">
          <div class="pv-chart" id="decimalChart"></div>
        </div>
        <h3>Examples</h3>
        <div class="decimal-example-grid">
          <div class="decimal-example">
            <div class="de-number">0.5</div>
            <div class="de-desc">5 tenths — like cutting a pizza into 10 slices and taking 5</div>
          </div>
          <div class="decimal-example">
            <div class="de-number">0.25</div>
            <div class="de-desc">2 tenths + 5 hundredths — a quarter of a dollar</div>
          </div>
          <div class="decimal-example">
            <div class="de-number">3.14</div>
            <div class="de-desc">3 ones + 1 tenth + 4 hundredths — approximately pi</div>
          </div>
          <div class="decimal-example">
            <div class="de-number">0.001</div>
            <div class="de-desc">1 thousandth — one milliliter in a liter</div>
          </div>
          <div class="decimal-example">
            <div class="de-number">12.750</div>
            <div class="de-desc">1 ten + 2 ones + 7 tenths + 5 hundredths + 0 thousandths</div>
          </div>
          <div class="decimal-example">
            <div class="de-number">99.999</div>
            <div class="de-desc">Almost 100 — every decimal place filled with 9</div>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB 5: Compare -->
    <div class="tab-panel" id="panel-compare">
      <div class="card">
        <h2>Number Comparison Tool</h2>
        <p style="color:var(--text-secondary,#666);margin:0 0 1rem;font-size:0.95rem;">Enter two numbers to align their place values side by side and see which is greater.</p>
        <div class="compare-row">
          <div class="compare-field">
            <label for="compareA">Number A</label>
            <input type="text" id="compareA" placeholder="e.g. 4521" inputmode="decimal">
          </div>
          <div class="compare-field">
            <label for="compareB">Number B</label>
            <input type="text" id="compareB" placeholder="e.g. 3897" inputmode="decimal">
          </div>
          <button class="btn btn-primary" id="compareBtn" style="align-self:end;">Compare</button>
        </div>
        <div id="compareResult"></div>
        <div id="compareAligned" class="compare-aligned"></div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="card faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q">What is place value in math?</div>
        <div class="faq-a"><div class="faq-a-inner">Place value is the value of each digit in a number based on its position. For example, in the number 5,432, the digit 5 is in the thousands place, so its value is 5,000. The digit 4 is in the hundreds place (value 400), 3 is in the tens place (value 30), and 2 is in the ones place (value 2).</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How do you read a place value chart?</div>
        <div class="faq-a"><div class="faq-a-inner">Read a place value chart from left to right, starting with the largest place. Each column represents a power of 10. The digit in each column tells you how many of that place value the number contains. For example, if 7 is in the hundreds column, the number has 7 hundreds, or 700.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What is expanded form of a number?</div>
        <div class="faq-a"><div class="faq-a-inner">Expanded form breaks a number into the sum of each digit multiplied by its place value. For example, 3,456 in expanded form is 3,000 + 400 + 50 + 6. This helps students understand that each digit contributes a different amount based on its position.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How do decimal place values work?</div>
        <div class="faq-a"><div class="faq-a-inner">Decimal place values extend the place value system to the right of the decimal point. The first place after the decimal is tenths (1/10), then hundredths (1/100), then thousandths (1/1000). For example, in 3.456, the 4 is in the tenths place (0.4), 5 is in the hundredths place (0.05), and 6 is in the thousandths place (0.006).</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Why is place value important?</div>
        <div class="faq-a"><div class="faq-a-inner">Place value is the foundation of our number system. Understanding place value is essential for addition, subtraction, multiplication, division, rounding, comparing numbers, and working with decimals and large numbers. Without place value understanding, students cannot perform multi-digit arithmetic correctly.</div></div>
      </div>
    </div>

    <!-- Educational Content -->
    <div class="prose">
      <h2>Understanding Place Value: A Complete Guide</h2>
      <p>Place value is one of the most fundamental concepts in mathematics. Our number system is a <strong>base-10</strong> (decimal) system, meaning each position in a number is worth 10 times the position to its right. This simple rule creates the entire structure for how we read, write, and work with numbers.</p>

      <h2>How the Place Value System Works</h2>
      <p>Every digit in a number has two properties: its <strong>face value</strong> (the digit itself, 0–9) and its <strong>place value</strong> (determined by its position). For the number 7,345:</p>
      <ul>
        <li><strong>7</strong> is in the thousands place → value is 7,000</li>
        <li><strong>3</strong> is in the hundreds place → value is 300</li>
        <li><strong>4</strong> is in the tens place → value is 40</li>
        <li><strong>5</strong> is in the ones place → value is 5</li>
      </ul>

      <h2>Whole Number Places</h2>
      <p>From right to left, whole number place values increase by a factor of 10: ones (10⁰), tens (10¹), hundreds (10²), thousands (10³), ten thousands (10⁴), hundred thousands (10⁵), millions (10⁶), ten millions (10⁷), hundred millions (10⁸), and billions (10⁹). Each group of three digits forms a <strong>period</strong> (ones, thousands, millions, billions).</p>

      <h2>Decimal Place Values</h2>
      <p>To the right of the decimal point, each position is worth 1/10 of the previous one: tenths (10⁻¹), hundredths (10⁻²), and thousandths (10⁻³). Understanding decimals is critical for working with money, measurements, and scientific data.</p>

      <h2>Tips for Teaching Place Value</h2>
      <ul>
        <li>Use physical manipulatives like base-10 blocks</li>
        <li>Practice writing numbers in expanded form regularly</li>
        <li>Play games that involve building numbers from digit cards</li>
        <li>Use a place value chart as a visual reference during lessons</li>
        <li>Connect place value to real-world contexts like money and measurement</li>
      </ul>
    </div>
  </div>

  <script is:inline>
  (function(){
    /* ===== PLACE DEFINITIONS ===== */
    const wholePlaces = [
      { name: 'Billions', power: '10⁹', example: '1,000,000,000', exp: 9 },
      { name: 'Hundred Millions', power: '10⁸', example: '100,000,000', exp: 8 },
      { name: 'Ten Millions', power: '10⁷', example: '10,000,000', exp: 7 },
      { name: 'Millions', power: '10⁶', example: '1,000,000', exp: 6 },
      { name: 'Hundred Thousands', power: '10⁵', example: '100,000', exp: 5 },
      { name: 'Ten Thousands', power: '10⁴', example: '10,000', exp: 4 },
      { name: 'Thousands', power: '10³', example: '1,000', exp: 3 },
      { name: 'Hundreds', power: '10²', example: '100', exp: 2 },
      { name: 'Tens', power: '10¹', example: '10', exp: 1 },
      { name: 'Ones', power: '10⁰', example: '1', exp: 0 },
    ];
    const decPlaces = [
      { name: 'Tenths', power: '10⁻¹', example: '0.1', exp: -1 },
      { name: 'Hundredths', power: '10⁻²', example: '0.01', exp: -2 },
      { name: 'Thousandths', power: '10⁻³', example: '0.001', exp: -3 },
    ];

    /* ===== BUILD CHART HTML ===== */
    function buildChart(containerId, places, showDecimal) {
      const el = document.getElementById(containerId);
      if (!el) return;
      let html = '';
      const wholes = places.filter(p => p.exp >= 0);
      const decs = places.filter(p => p.exp < 0);
      wholes.forEach(p => {
        html += '<div class="pv-col whole" data-exp="'+p.exp+'">' +
          '<div class="pv-header">'+p.name+'</div>' +
          '<div class="pv-power">'+p.power+'</div>' +
          '<div class="pv-example">'+p.example+'</div>' +
          '<div class="pv-digit" data-exp="'+p.exp+'"></div></div>';
      });
      if (showDecimal && decs.length) {
        html += '<div class="pv-col decimal-sep">.</div>';
        decs.forEach(p => {
          html += '<div class="pv-col decimal" data-exp="'+p.exp+'">' +
            '<div class="pv-header">'+p.name+'</div>' +
            '<div class="pv-power">'+p.power+'</div>' +
            '<div class="pv-example">'+p.example+'</div>' +
            '<div class="pv-digit" data-exp="'+p.exp+'"></div></div>';
        });
      }
      el.innerHTML = html;
      el.querySelectorAll('.pv-col:not(.decimal-sep)').forEach(col => {
        col.addEventListener('mouseenter', () => col.classList.add('highlighted'));
        col.addEventListener('mouseleave', () => col.classList.remove('highlighted'));
      });
    }

    buildChart('mainChart', wholePlaces.concat(decPlaces), true);
    buildChart('decimalChart', [
      { name: 'Ones', power: '10⁰', example: '1', exp: 0 },
      ...decPlaces
    ], true);

    /* ===== TABS ===== */
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
      });
    });

    /* ===== FAQ ===== */
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => q.parentElement.classList.toggle('open'));
    });

    /* ===== NUMBER UTILITIES ===== */
    function parseNum(str) {
      const s = str.replace(/,/g, '').trim();
      if (s === '' || isNaN(Number(s))) return null;
      return s;
    }

    function getDigitMap(numStr) {
      const negative = numStr.startsWith('-');
      const abs = negative ? numStr.slice(1) : numStr;
      const parts = abs.split('.');
      const whole = parts[0] || '0';
      const dec = parts[1] || '';
      const map = {};
      for (let i = 0; i < whole.length; i++) {
        const exp = whole.length - 1 - i;
        map[exp] = parseInt(whole[i], 10);
      }
      for (let i = 0; i < dec.length; i++) {
        map[-(i + 1)] = parseInt(dec[i], 10);
      }
      return { map, negative };
    }

    const ones = ['','one','two','three','four','five','six','seven','eight','nine',
      'ten','eleven','twelve','thirteen','fourteen','fifteen','sixteen','seventeen','eighteen','nineteen'];
    const tens = ['','','twenty','thirty','forty','fifty','sixty','seventy','eighty','ninety'];
    const scales = ['','thousand','million','billion','trillion'];

    function numberToWords(n) {
      if (n === 0) return 'zero';
      if (n < 0) return 'negative ' + numberToWords(-n);
      const num = Math.floor(n);
      const decPart = n.toString().split('.')[1];
      let words = '';
      if (num === 0) {
        words = 'zero';
      } else {
        const groups = [];
        let temp = num;
        while (temp > 0) { groups.push(temp % 1000); temp = Math.floor(temp / 1000); }
        const parts = [];
        for (let i = groups.length - 1; i >= 0; i--) {
          if (groups[i] === 0) continue;
          parts.push(threeDigitWords(groups[i]) + (scales[i] ? ' ' + scales[i] : ''));
        }
        words = parts.join(' ');
      }
      if (decPart) {
        const decWords = decPart.split('').map(d => ones[parseInt(d)] || 'zero').join(' ');
        words += ' point ' + decWords;
      }
      return words;
    }

    function threeDigitWords(n) {
      if (n === 0) return '';
      const h = Math.floor(n / 100);
      const r = n % 100;
      let s = '';
      if (h) s += ones[h] + ' hundred';
      if (r) {
        if (h) s += ' ';
        if (r < 20) s += ones[r];
        else { s += tens[Math.floor(r/10)]; if (r%10) s += '-' + ones[r%10]; }
      }
      return s;
    }

    function expandedForm(numStr) {
      const { map } = getDigitMap(numStr);
      const parts = [];
      const exps = Object.keys(map).map(Number).sort((a,b) => b - a);
      exps.forEach(exp => {
        const d = map[exp];
        if (d === 0) return;
        if (exp >= 0) parts.push((d * Math.pow(10, exp)).toLocaleString());
        else parts.push(d + ' × ' + (exp === -1 ? '0.1' : exp === -2 ? '0.01' : '0.001'));
      });
      return parts.join(' + ') || '0';
    }

    function scientificNotation(numStr) {
      const n = parseFloat(numStr);
      if (n === 0) return '0';
      return n.toExponential();
    }

    function formatNum(n) {
      return Number(n).toLocaleString('en-US', { maximumFractionDigits: 10 });
    }

    /* ===== EXPLORER ===== */
    function populateChart(chartId, numStr) {
      const chart = document.getElementById(chartId);
      if (!chart) return;
      const { map } = getDigitMap(numStr);
      chart.querySelectorAll('.pv-col:not(.decimal-sep)').forEach(col => {
        const exp = parseInt(col.dataset.exp);
        const digitEl = col.querySelector('.pv-digit');
        if (digitEl) {
          const d = map[exp];
          digitEl.textContent = d !== undefined ? d : '';
          if (d !== undefined && d !== 0) col.classList.add('highlighted');
          else col.classList.remove('highlighted');
        }
      });
    }

    const explorerChart = document.getElementById('explorerChart');
    buildChart('explorerChart', wholePlaces.concat(decPlaces), true);

    document.getElementById('exploreBtn').addEventListener('click', doExplore);
    document.getElementById('explorerInput').addEventListener('keydown', e => { if (e.key === 'Enter') doExplore(); });
    document.getElementById('exploreClear').addEventListener('click', () => {
      document.getElementById('explorerInput').value = '';
      document.getElementById('explorerBreakdown').innerHTML = '';
      buildChart('explorerChart', wholePlaces.concat(decPlaces), true);
    });

    function doExplore() {
      const raw = document.getElementById('explorerInput').value;
      const s = parseNum(raw);
      if (!s) return;
      populateChart('explorerChart', s);
      const bd = document.getElementById('explorerBreakdown');
      const n = parseFloat(s);
      bd.innerHTML =
        '<div class="breakdown-item"><div class="breakdown-label">Standard Form</div><div class="breakdown-value">'+formatNum(n)+'</div></div>' +
        '<div class="breakdown-item"><div class="breakdown-label">Written Form</div><div class="breakdown-value large">'+numberToWords(n)+'</div></div>' +
        '<div class="breakdown-item"><div class="breakdown-label">Expanded Form</div><div class="breakdown-value large">'+expandedForm(s)+'</div></div>' +
        '<div class="breakdown-item"><div class="breakdown-label">Scientific Notation</div><div class="breakdown-value">'+scientificNotation(s)+'</div></div>';
    }

    /* ===== QUIZ ===== */
    let quizState = { questions: [], current: 0, score: 0 };

    function randInt(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }

    function generateQuestions() {
      const qs = [];
      const placeNames = ['ones','tens','hundreds','thousands','ten thousands','hundred thousands','millions'];
      const placeExps =  [0, 1, 2, 3, 4, 5, 6];

      for (let i = 0; i < 10; i++) {
        const type = randInt(0, 2);
        if (type === 0) {
          // What is the value of digit X in number Y?
          const len = randInt(4, 7);
          const digits = [];
          for (let j = 0; j < len; j++) digits.push(j === 0 ? randInt(1,9) : randInt(0,9));
          const num = digits.join('');
          const pos = randInt(0, len - 1);
          const digit = digits[pos];
          const exp = len - 1 - pos;
          const value = digit * Math.pow(10, exp);
          const formatted = Number(num).toLocaleString();
          const wrongAnswers = new Set();
          wrongAnswers.add(value);
          while (wrongAnswers.size < 4) {
            const wExp = placeExps[randInt(0, Math.min(len - 1, placeExps.length - 1))];
            wrongAnswers.add(digit * Math.pow(10, wExp));
          }
          const options = shuffle([...wrongAnswers]);
          qs.push({
            question: 'What is the <strong>value</strong> of the digit <span class="highlight-digit">'+digit+'</span> in '+formatted+'?',
            options: options.map(o => o.toLocaleString()),
            answer: value.toLocaleString()
          });
        } else if (type === 1) {
          // Which digit is in the X place?
          const len = randInt(4, 7);
          const digits = [];
          for (let j = 0; j < len; j++) digits.push(j === 0 ? randInt(1,9) : randInt(0,9));
          const num = digits.join('');
          const pi = randInt(0, Math.min(len - 1, placeNames.length - 1));
          const exp = placeExps[pi];
          const pos = len - 1 - exp;
          const correctDigit = digits[pos];
          const formatted = Number(num).toLocaleString();
          const options = new Set();
          options.add(correctDigit);
          while (options.size < 4) options.add(randInt(0,9));
          qs.push({
            question: 'Which digit is in the <strong>'+placeNames[pi]+'</strong> place of '+formatted+'?',
            options: shuffle([...options]).map(String),
            answer: String(correctDigit)
          });
        } else {
          // Expanded to standard form
          const len = randInt(3, 5);
          const parts = [];
          const digits = [];
          for (let j = 0; j < len; j++) {
            const d = j === 0 ? randInt(1,9) : randInt(1,9);
            digits.push(d);
            parts.push((d * Math.pow(10, len - 1 - j)).toLocaleString());
          }
          const num = parseInt(digits.join(''));
          const expanded = parts.join(' + ');
          const wrongNums = new Set();
          wrongNums.add(num);
          while (wrongNums.size < 4) {
            const off = randInt(-500, 500);
            const w = num + off;
            if (w > 0) wrongNums.add(w);
          }
          qs.push({
            question: 'Write <strong>'+expanded+'</strong> in standard form:',
            options: shuffle([...wrongNums]).map(n => n.toLocaleString()),
            answer: num.toLocaleString()
          });
        }
      }
      return qs;
    }

    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = randInt(0, i);
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function renderQuiz() {
      const area = document.getElementById('quizArea');
      const s = quizState;
      if (s.current >= s.questions.length) {
        const pct = Math.round(s.score / s.questions.length * 100);
        area.innerHTML = '<div class="quiz-results"><div class="score-big">'+s.score+'/'+s.questions.length+'</div>' +
          '<div class="score-label">'+pct+'% correct</div>' +
          '<button class="btn btn-primary" id="retryQuiz">Try Again</button></div>';
        document.getElementById('retryQuiz').addEventListener('click', startQuiz);
        return;
      }
      const q = s.questions[s.current];
      let html = '<div class="quiz-header"><span class="quiz-score">Score: '+s.score+'/'+s.questions.length+'</span>' +
        '<span class="quiz-progress">Question '+(s.current+1)+' of '+s.questions.length+'</span></div>' +
        '<div class="quiz-question">'+q.question+'</div><div class="quiz-options">';
      q.options.forEach(opt => {
        html += '<button class="quiz-option" data-val="'+opt+'">'+opt+'</button>';
      });
      html += '</div><div id="quizFeedback"></div>';
      area.innerHTML = html;
      area.querySelectorAll('.quiz-option').forEach(btn => {
        btn.addEventListener('click', function() {
          if (this.classList.contains('disabled')) return;
          area.querySelectorAll('.quiz-option').forEach(b => b.classList.add('disabled'));
          const correct = this.dataset.val === q.answer;
          if (correct) { this.classList.add('correct'); s.score++; }
          else {
            this.classList.add('wrong');
            area.querySelectorAll('.quiz-option').forEach(b => {
              if (b.dataset.val === q.answer) b.classList.add('correct');
            });
          }
          document.getElementById('quizFeedback').innerHTML =
            '<div class="quiz-feedback '+(correct?'correct':'wrong')+'">'+
            (correct ? 'Correct!' : 'The answer is '+q.answer) + '</div>';
          setTimeout(() => { s.current++; renderQuiz(); }, 1500);
        });
      });
    }

    function startQuiz() {
      quizState = { questions: generateQuestions(), current: 0, score: 0 };
      renderQuiz();
    }

    document.getElementById('startQuiz').addEventListener('click', startQuiz);

    /* ===== COMPARISON ===== */
    document.getElementById('compareBtn').addEventListener('click', doCompare);

    function doCompare() {
      const aStr = parseNum(document.getElementById('compareA').value);
      const bStr = parseNum(document.getElementById('compareB').value);
      if (!aStr || !bStr) return;
      const a = parseFloat(aStr);
      const b = parseFloat(bStr);
      const resEl = document.getElementById('compareResult');
      const alignEl = document.getElementById('compareAligned');

      if (a > b) resEl.innerHTML = '<div class="compare-result greater">'+formatNum(a)+' &gt; '+formatNum(b)+'</div>';
      else if (b > a) resEl.innerHTML = '<div class="compare-result greater">'+formatNum(b)+' &gt; '+formatNum(a)+'</div>';
      else resEl.innerHTML = '<div class="compare-result equal">'+formatNum(a)+' = '+formatNum(b)+'</div>';

      // Aligned table
      const mapA = getDigitMap(aStr).map;
      const mapB = getDigitMap(bStr).map;
      const allExps = new Set([...Object.keys(mapA), ...Object.keys(mapB)].map(Number));
      // Ensure at least ones
      allExps.add(0);
      const sorted = [...allExps].sort((a,b) => b - a);
      const hasDecimal = sorted.some(e => e < 0);

      let thRow = '<tr>';
      let aRow = '<tr class="num-a">';
      let bRow = '<tr class="num-b">';
      sorted.forEach(exp => {
        const label = exp >= 0 ? wholePlaces.find(p => p.exp === exp) : decPlaces.find(p => p.exp === exp);
        const name = label ? label.name.replace(/ /g,'<br>') : (exp >= 0 ? '10^'+exp : '10^('+exp+')');
        const dA = mapA[exp] !== undefined ? mapA[exp] : '';
        const dB = mapB[exp] !== undefined ? mapB[exp] : '';
        const diff = dA !== dB ? ' class="diff-col"' : '';
        thRow += '<th>'+name+'</th>';
        aRow += '<td'+diff+'>'+dA+'</td>';
        bRow += '<td'+diff+'>'+dB+'</td>';
      });
      thRow += '</tr>'; aRow += '</tr>'; bRow += '</tr>';
      alignEl.innerHTML = '<div class="chart-scroll"><table>'+thRow+aRow+bRow+'</table></div>';
    }
  })();
  </script>
</SiteLayout>
