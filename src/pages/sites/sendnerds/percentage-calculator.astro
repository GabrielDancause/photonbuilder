    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2.5rem; margin: 2rem 0; }

    .calc-section { margin: 1rem 0; }
    .calc-section h3 { margin-top: 0; margin-bottom: 1.5rem; font-size: 1.2rem; color: var(--text-primary); text-align: center; }

    .calc-divider { border: 0; border-top: 1px dashed var(--border-color); margin: 3rem 0; opacity: 0.5; }

    .input-row { display: flex; align-items: flex-end; justify-content: center; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }

    .input-group-inline { display: flex; flex-direction: column; }
    .input-group-inline label { font-size: 0.9rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.5rem; text-align: center; }

    input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 140px; font-size: 1.1rem; text-align: center; }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .input-wrapper { position: relative; display: flex; align-items: center; width: 140px; }
    .input-wrapper input { width: 100%; padding-right: 2rem; }
    .suffix { position: absolute; right: 1rem; color: var(--text-secondary); pointer-events: none; }

    .result-box { display: flex; align-items: center; justify-content: center; gap: 1rem; background: color-mix(in srgb, var(--accent-color) 5%, transparent); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem; margin: 0 auto; max-width: 400px; }
    .result-box span:first-child { color: var(--text-secondary); font-weight: 600; }
    .result-val { font-size: 2rem; font-weight: 800; color: var(--accent-color); }
    .result-label { font-weight: 600; color: var(--text-secondary); font-size: 1.1rem; margin-left: 0.5rem; }

    .explainer { margin-top: 3rem; }
    .explainer h2 { margin-top: 2rem; color: var(--accent-color); }
    .explainer h3 { margin-top: 1.5rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer ul, .explainer ol { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer code { background: var(--card-bg); padding: 0.2rem 0.4rem; border-radius: 4px; font-family: monospace; color: var(--accent-color); border: 1px solid var(--border-color); }
    .explainer a { color: var(--accent-color); text-decoration: none; }
    .explainer a:hover { text-decoration: underline; }

    .faq-section { margin-top: 3rem; }
    .faq-section h2 { margin-bottom: 1.5rem; color: var(--accent-color); }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; color: var(--text-primary); }
    .faq-section details p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); }

    @media (max-width: 600px) {
      .calculator-container { padding: 1.5rem; }
      .input-row { flex-direction: column; align-items: center; gap: 1rem; }
      .input-group-inline { width: 100%; max-width: 250px; }
      input, .input-wrapper { width: 100%; }
      .result-box { flex-direction: column; gap: 0.5rem; }
    }
  </style>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
