---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Percentage Calculator - Compute Growth, Decrease & Change",
  description: "Stop struggling with percentage formulas. Instantly calculate percentage increases, decreases, or find out exactly what X% of Y is with our interactive tool...",
  category: "tool",
  published: "2024-05-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Silicon Based"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Silicon Based"
    },
    "datePublished": meta.published,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you calculate the percentage of a number?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To find the percentage of a number, multiply the number by the percentage fraction (percentage / 100). For example, to find 20% of 50, you calculate 50 * (20 / 100) = 10."
        }
      },
      {
        "@type": "Question",
        "name": "How do I calculate percentage growth or increase?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Percentage growth is calculated by taking the difference between the new value and the old value, dividing that difference by the old value, and then multiplying by 100. The formula is: ((New Value - Old Value) / Old Value) * 100."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between percentage change and percentage difference?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Percentage change measures the change of a value over time relative to its old value (e.g., price increase). Percentage difference measures the difference between two arbitrary values without a specific chronological order, usually by dividing the absolute difference by their average."
        }
      },
      {
        "@type": "Question",
        "name": "Can a percentage increase be more than 100%?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, absolutely. A 100% increase means the value has doubled. A 200% increase means the value has tripled. There is no mathematical limit to how high a percentage increase can be."
        }
      },
      {
        "@type": "Question",
        "name": "Can a percentage decrease be more than 100%?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Typically, no. A 100% decrease means a value has reached zero. In most practical contexts (like price drops or population decline), you cannot go below zero, making 100% the maximum decrease."
        }
      }
    ]
  }
];
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description} canonical="https://sendnerds.photonbuilder.com/percentage-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Percentage Calculator</h1>
      <p class="subtitle">Quickly calculate percentages, growth rates, and differences without having to remember the formulas.</p>
    </div>

    <div class="calculator-container">

      <!-- Tool 1: X is what percent of Y -->
      <div class="calc-section">
        <h3>What is X% of Y?</h3>
        <div class="input-row">
          <div class="input-group-inline">
            <label for="t1-x">What is</label>
            <div class="input-wrapper">
              <input type="number" id="t1-x" placeholder="20" step="any">
              <span class="suffix">%</span>
            </div>
          </div>
          <div class="input-group-inline">
            <label for="t1-y">of</label>
            <input type="number" id="t1-y" placeholder="150" step="any">
          </div>
        </div>
        <div class="result-box">
          <span>Result:</span>
          <span id="t1-result" class="result-val">--</span>
        </div>
      </div>

      <hr class="calc-divider" />

      <!-- Tool 2: What % is X of Y -->
      <div class="calc-section">
        <h3>X is what percent of Y?</h3>
        <div class="input-row">
          <div class="input-group-inline">
            <input type="number" id="t2-x" placeholder="30" step="any">
          </div>
          <div class="input-group-inline">
            <label for="t2-y">is what % of</label>
            <input type="number" id="t2-y" placeholder="150" step="any">
          </div>
        </div>
        <div class="result-box">
          <span>Result:</span>
          <span id="t2-result" class="result-val">--%</span>
        </div>
      </div>

      <hr class="calc-divider" />

      <!-- Tool 3: Percentage Change -->
      <div class="calc-section">
        <h3>Percentage Change (Increase/Decrease)</h3>
        <div class="input-row">
          <div class="input-group-inline">
            <label for="t3-old">From</label>
            <input type="number" id="t3-old" placeholder="100" step="any">
          </div>
          <div class="input-group-inline">
            <label for="t3-new">To</label>
            <input type="number" id="t3-new" placeholder="120" step="any">
          </div>
        </div>
        <div class="result-box">
          <span>Result:</span>
          <span id="t3-result" class="result-val">--%</span>
          <span id="t3-label" class="result-label"></span>
        </div>
      </div>

    </div>

    <div class="explainer">
      <h2>Understanding Percentage Calculations</h2>
      <p>Percentages are a fundamental mathematical concept used in almost every aspect of daily life, from calculating tips at a restaurant to analyzing corporate financial growth. The term "percent" simply means "per hundred." A percentage is a number or ratio expressed as a fraction of 100. Our calculator suite simplifies the three most common ways people interact with percentages.</p>

      <h3>1. Finding the Percentage of a Number</h3>
      <p>This is the most straightforward calculation. It answers the question: <em>"What is X% of Y?"</em></p>
      <p><strong>Formula:</strong> <code>(X / 100) &times; Y = Result</code></p>
      <p><strong>Example:</strong> What is 20% of 150?</p>
      <ul>
        <li>Convert the percentage to a decimal: 20 / 100 = 0.20</li>
        <li>Multiply the decimal by the whole number: 0.20 &times; 150 = 30</li>
        <li>So, 20% of 150 is 30.</li>
      </ul>
      <p>This formula is what you use when calculating sales tax, a tip, or a discount on an item.</p>

      <h3>2. Finding What Percentage One Number is of Another</h3>
      <p>This calculation determines the proportional relationship between two numbers. It answers the question: <em>"X is what percent of Y?"</em></p>
      <p><strong>Formula:</strong> <code>(X / Y) &times; 100 = Percentage Result</code></p>
      <p><strong>Example:</strong> 30 is what percent of 150?</p>
      <ul>
        <li>Divide the part by the whole: 30 / 150 = 0.20</li>
        <li>Convert the decimal to a percentage: 0.20 &times; 100 = 20%</li>
        <li>So, 30 is 20% of 150.</li>
      </ul>
      <p>This formula is frequently used in academia to calculate unweighted grades on a test. If you're looking for more complex academic grading tools involving weights and target finals, check out our <a href="/grade-calculator">Grade Calculator</a>.</p>

      <h3>3. Calculating Percentage Change (Growth or Decrease)</h3>
      <p>Percentage change is used to track how a value shifts over time. This is critical in business (revenue growth), finance (stock returns), and statistics (population shifts). It answers the question: <em>"What is the percentage increase or decrease from an old value to a new value?"</em></p>
      <p><strong>Formula:</strong> <code>((New Value - Old Value) / |Old Value|) &times; 100 = Percentage Change</code></p>
      <p><strong>Example of Growth:</strong> Your website traffic went from 1,000 visitors last month to 1,250 visitors this month. What is the growth rate?</p>
      <ul>
        <li>Find the difference: 1,250 - 1,000 = +250</li>
        <li>Divide by the old value: 250 / 1,000 = 0.25</li>
        <li>Convert to a percentage: 0.25 &times; 100 = 25% Increase</li>
      </ul>
      <p><strong>Example of Decrease:</strong> The price of a laptop dropped from $1,000 to $800. What is the percentage decrease?</p>
      <ul>
        <li>Find the difference: 800 - 1,000 = -200</li>
        <li>Divide by the old value: -200 / 1,000 = -0.20</li>
        <li>Convert to a percentage: -0.20 &times; 100 = -20% (A 20% Decrease)</li>
      </ul>

      <h3>Percentage Change vs. Percentage Difference</h3>
      <p>It's important to distinguish between percentage <em>change</em> and percentage <em>difference</em>. Percentage change always involves an old value and a new value—there is chronological directionality. You are comparing how a specific metric moved from Point A in time to Point B.</p>
      <p>Percentage difference is used when comparing two values that are not necessarily linked by time, and you want to know how different they are relative to their average. For example, comparing the heights of two different buildings. The formula for percentage difference is <code>(|Value A - Value B| / ((Value A + Value B) / 2)) &times; 100</code>. Our calculator above specifically handles Percentage Change.</p>

      <h3>Common Pitfalls to Avoid</h3>
      <ul>
        <li><strong>Adding percentages incorrectly:</strong> A 10% increase followed by a 10% decrease does not bring you back to the original number. If you start with $100, add 10% ($110), and then take 10% off $110, you are left with $99.</li>
        <li><strong>Using the wrong base for percentage change:</strong> Always divide the difference by the <em>original (old)</em> value, never the new value.</li>
        <li><strong>Confusing percentage points with percentage increase:</strong> If an interest rate goes from 5% to 6%, it increased by 1 <em>percentage point</em>. However, the <em>percentage increase</em> is actually 20% (because 1 is 20% of 5).</li>
      </ul>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map(faq => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    function formatNumber(num) {
      if (isNaN(num) || !isFinite(num)) return '--';
      return Number.isInteger(num) ? num.toString() : num.toFixed(2).replace(/\.?0+$/, '');
    }

    // Tool 1
    const t1X = document.getElementById('t1-x');
    const t1Y = document.getElementById('t1-y');
    const t1Result = document.getElementById('t1-result');

    function calcT1() {
      const x = parseFloat(t1X.value);
      const y = parseFloat(t1Y.value);
      if (!isNaN(x) && !isNaN(y)) {
        t1Result.textContent = formatNumber((x / 100) * y);
      } else {
        t1Result.textContent = '--';
      }
    }
    t1X.addEventListener('input', calcT1);
    t1Y.addEventListener('input', calcT1);

    // Tool 2
    const t2X = document.getElementById('t2-x');
    const t2Y = document.getElementById('t2-y');
    const t2Result = document.getElementById('t2-result');

    function calcT2() {
      const x = parseFloat(t2X.value);
      const y = parseFloat(t2Y.value);
      if (!isNaN(x) && !isNaN(y) && y !== 0) {
        t2Result.textContent = formatNumber((x / y) * 100) + '%';
      } else {
        t2Result.textContent = '--%';
      }
    }
    t2X.addEventListener('input', calcT2);
    t2Y.addEventListener('input', calcT2);

    // Tool 3
    const t3Old = document.getElementById('t3-old');
    const t3New = document.getElementById('t3-new');
    const t3Result = document.getElementById('t3-result');
    const t3Label = document.getElementById('t3-label');

    function calcT3() {
      const oldVal = parseFloat(t3Old.value);
      const newVal = parseFloat(t3New.value);

      t3Label.textContent = '';
      t3Result.style.color = 'var(--accent-color)';

      if (!isNaN(oldVal) && !isNaN(newVal) && oldVal !== 0) {
        const diff = newVal - oldVal;
        const percentChange = (diff / Math.abs(oldVal)) * 100;

        t3Result.textContent = formatNumber(Math.abs(percentChange)) + '%';

        if (percentChange > 0) {
          t3Label.textContent = 'Increase';
          t3Result.style.color = '#22c55e';
        } else if (percentChange < 0) {
          t3Label.textContent = 'Decrease';
          t3Result.style.color = '#ef4444';
        } else {
          t3Label.textContent = 'No Change';
          t3Result.style.color = 'var(--text-primary)';
        }
      } else {
        t3Result.textContent = '--%';
      }
    }
    t3Old.addEventListener('input', calcT3);
    t3New.addEventListener('input', calcT3);

  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
