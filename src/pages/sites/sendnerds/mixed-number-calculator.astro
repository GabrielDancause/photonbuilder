---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Mixed Number Calculator | Add, Subtract, Multiply & Divide",
  description: "Instantly solve math problems involving mixed numbers and fractions. How does improper fraction conversion actually work? We break down the steps.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      },
      "publisher": {
        "@type": "Organization",
        "name": "SiliconBased",
        "logo": {
          "@type": "ImageObject",
          "url": "https://sendnerds.photonbuilder.com/logo.png"
        }
      },
      "datePublished": meta.published
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a mixed number?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A mixed number is a numerical value that combines a whole number and a proper fraction. For example, 2 1/2 is a mixed number representing the sum of 2 and a half."
          }
        },
        {
          "@type": "Question",
          "name": "How do you convert a mixed number to an improper fraction?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Multiply the whole number by the denominator of the fraction, then add the numerator to that product. Place the resulting sum over the original denominator."
          }
        },
        {
          "@type": "Question",
          "name": "Can you multiply mixed numbers directly?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, it is highly recommended to first convert each mixed number into an improper fraction before multiplying the numerators and denominators together."
          }
        },
        {
          "@type": "Question",
          "name": "What happens if I subtract and get a negative fraction?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If the fractional part you are subtracting is larger than the fractional part you are subtracting from, you must 'borrow' 1 from the whole number portion, converting it into an equivalent fraction before subtracting."
          }
        },
        {
          "@type": "Question",
          "name": "How do you divide mixed numbers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "First, convert both mixed numbers to improper fractions. Then, flip the second fraction (find its reciprocal) and multiply the two fractions together."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description} canonical="https://sendnerds.photonbuilder.com/mixed-number-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Mixed Number Calculator</h1>
      <p class="subtitle">Calculate addition, subtraction, multiplication, and division of mixed numbers.</p>
    </div>

    <div class="calculator-container">
      <div class="mixed-inputs-container">
        <!-- Operand 1 -->
        <div class="fraction-group">
          <div class="fraction-label">First Number</div>
          <div class="mixed-number-input">
            <input type="number" id="whole1" placeholder="Whole" value="2">
            <div class="fraction-part">
              <input type="number" id="num1" placeholder="Num" value="1">
              <div class="fraction-bar"></div>
              <input type="number" id="den1" placeholder="Den" value="2">
            </div>
          </div>
        </div>

        <!-- Operator -->
        <div class="operator-group">
          <select id="operator">
            <option value="+">+</option>
            <option value="-">-</option>
            <option value="*">&times;</option>
            <option value="/">&divide;</option>
          </select>
        </div>

        <!-- Operand 2 -->
        <div class="fraction-group">
          <div class="fraction-label">Second Number</div>
          <div class="mixed-number-input">
            <input type="number" id="whole2" placeholder="Whole" value="1">
            <div class="fraction-part">
              <input type="number" id="num2" placeholder="Num" value="3">
              <div class="fraction-bar"></div>
              <input type="number" id="den2" placeholder="Den" value="4">
            </div>
          </div>
        </div>
      </div>

      <div class="error-msg" id="calc-error">Denominators cannot be zero.</div>

      <div class="result-card">
        <div class="result-label">Result:</div>
        <div class="result-display" id="result-display">
          <!-- Populated by JS -->
          <span class="res-whole">4</span>
          <div class="res-fraction">
            <span class="res-num">1</span>
            <span class="res-den">4</span>
          </div>
        </div>
        <div class="result-improper" id="result-improper">= 17 / 4</div>
        <div class="result-decimal" id="result-decimal">= 4.25</div>
      </div>

      <div class="cross-link-box">
        Need to compute exponential growth or decay? Try our <a href="/log-calculator">Logarithm Calculator</a>.
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Mixed Numbers</h2>
      <p>
        A mixed number (also known as a mixed fraction) is a combination of a whole number and a proper fraction. They are often used in everyday measurements, such as recipes (e.g., 1 &frac12; cups of flour), carpentry (e.g., a board that is 4 &frac34; inches wide), and timekeeping (e.g., 2 &frac14; hours).
      </p>
      <p>
        While mixed numbers are easy to visualize and communicate, performing mathematical operations on them—like addition, subtraction, multiplication, and division—can be cumbersome if you don't follow the proper mathematical procedures. The most reliable method for manipulating mixed numbers is to temporarily convert them into <strong>improper fractions</strong>.
      </p>

      <h3>What is an Improper Fraction?</h3>
      <p>
        An improper fraction is a fraction where the numerator (the top number) is greater than or equal to the denominator (the bottom number). For instance, the mixed number 2 &frac12; is equivalent to the improper fraction 5/2. While they look "top-heavy," improper fractions are mathematically much easier to multiply and divide than mixed numbers.
      </p>

      <h3>How to Convert a Mixed Number to an Improper Fraction</h3>
      <p>
        The conversion process involves three simple steps:
      </p>
      <ol>
        <li><strong>Multiply:</strong> Multiply the whole number part by the denominator of the fractional part.</li>
        <li><strong>Add:</strong> Add the result from step 1 to the numerator of the fractional part. This new number becomes your new numerator.</li>
        <li><strong>Keep the Denominator:</strong> The denominator remains the same.</li>
      </ol>
      <p>
        <strong>Example:</strong> Convert 3 &frac25; to an improper fraction.
        <br />
        1. Multiply whole number (3) by denominator (5): 3 &times; 5 = 15.
        <br />
        2. Add the numerator (2): 15 + 2 = 17.
        <br />
        3. Keep the denominator: The improper fraction is <strong>17/5</strong>.
      </p>

      <h3>Arithmetic Operations with Mixed Numbers</h3>

      <h4>1. Addition</h4>
      <p>
        When adding mixed numbers, you can often simply add the whole numbers together and the fractions together separately. However, if the fractions have different denominators, you must first find a Common Denominator. Furthermore, if the resulting fractional part forms an improper fraction (e.g., 5/4), you must carry over the whole value to the integer portion.
      </p>
      <p>
        Our calculator handles this gracefully by converting everything to improper fractions first, adding them, and then converting the final result back into a simplified mixed number.
      </p>

      <h4>2. Subtraction</h4>
      <p>
        Subtraction follows similar rules to addition, but introduces a complication known as "borrowing." If the fractional part of the number you are subtracting is larger than the fractional part of the number you are subtracting from, you cannot subtract them directly. You must borrow 1 from the whole number, converting it into a fraction (like 4/4 or 8/8), and add it to your starting fraction before completing the subtraction. By converting to improper fractions beforehand, the need for borrowing is completely bypassed, making the calculation foolproof.
      </p>

      <h4>3. Multiplication</h4>
      <p>
        Unlike addition, you <strong>cannot</strong> simply multiply the whole numbers together and the fractions together. Doing so will yield an incorrect result. To multiply mixed numbers, you <em>must</em> convert them to improper fractions first.
      </p>
      <p>
        Once converted, you multiply the numerators together to get the new numerator, and multiply the denominators together to get the new denominator. Finally, simplify the resulting fraction and convert it back to a mixed number if necessary.
      </p>

      <h4>4. Division</h4>
      <p>
        Division of mixed numbers is essentially the same process as multiplication, but with one critical extra step. After converting both mixed numbers into improper fractions, you must find the <strong>reciprocal</strong> of the second fraction (the divisor). Finding the reciprocal simply means flipping the numerator and denominator.
      </p>
      <p>
        Once the second fraction is flipped, you change the division operation to multiplication and proceed as normal: multiply across the top and across the bottom, then simplify. This technique is often taught using the acronym KCF: Keep (the first fraction), Change (the sign to multiplication), Flip (the second fraction).
      </p>

      <h3>Simplifying the Result</h3>
      <p>
        Whether adding, subtracting, multiplying, or dividing, the final step is almost always to simplify the resulting fraction. This involves finding the Greatest Common Divisor (GCD) of the numerator and denominator, and dividing both by that number. Our interactive tool automatically computes the GCD for every calculation to ensure your answers are always provided in their simplest possible form.
      </p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema["@graph"][1].mainEntity.map(faq => (
        <details class="faq-item">
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Inputs
      const w1 = document.getElementById('whole1');
      const n1 = document.getElementById('num1');
      const d1 = document.getElementById('den1');

      const op = document.getElementById('operator');

      const w2 = document.getElementById('whole2');
      const n2 = document.getElementById('num2');
      const d2 = document.getElementById('den2');

      // Displays
      const errorEl = document.getElementById('calc-error');
      const resultDisplay = document.getElementById('result-display');
      const resultImproper = document.getElementById('result-improper');
      const resultDecimal = document.getElementById('result-decimal');

      // Helper: Greatest Common Divisor
      function gcd(a, b) {
        a = Math.abs(a);
        b = Math.abs(b);
        while (b) {
          let temp = b;
          b = a % b;
          a = temp;
        }
        return a;
      }

      function calculate() {
        // Parse inputs, defaulting empty strings to 0
        const whole1 = parseInt(w1.value) || 0;
        const num1 = parseInt(n1.value) || 0;
        const den1 = parseInt(d1.value) || 1; // Default den to 1 to avoid zero div

        const operator = op.value;

        const whole2 = parseInt(w2.value) || 0;
        const num2 = parseInt(n2.value) || 0;
        const den2 = parseInt(d2.value) || 1;

        // Validation: Denominators cannot be zero
        if (parseInt(d1.value) === 0 || parseInt(d2.value) === 0) {
          errorEl.style.display = 'block';
          errorEl.textContent = 'Denominators cannot be zero.';
          hideResults();
          return;
        } else {
          errorEl.style.display = 'none';
        }

        // Convert to improper fractions
        // For negative whole numbers, the fraction is also negative
        let impNum1 = (Math.abs(whole1) * den1) + num1;
        if (whole1 < 0) impNum1 = -impNum1;
        // If whole is 0 but user meant negative fraction, we can't easily capture that with separate inputs
        // unless we allow negative numerators. Let's account for negative numerators:
        if (whole1 === 0 && num1 < 0) impNum1 = num1;

        let impNum2 = (Math.abs(whole2) * den2) + num2;
        if (whole2 < 0) impNum2 = -impNum2;
        if (whole2 === 0 && num2 < 0) impNum2 = num2;

        let resNum = 0;
        let resDen = 1;

        // Perform Operation on improper fractions
        if (operator === '+') {
          resNum = (impNum1 * den2) + (impNum2 * den1);
          resDen = den1 * den2;
        } else if (operator === '-') {
          resNum = (impNum1 * den2) - (impNum2 * den1);
          resDen = den1 * den2;
        } else if (operator === '*') {
          resNum = impNum1 * impNum2;
          resDen = den1 * den2;
        } else if (operator === '/') {
          if (impNum2 === 0) {
            errorEl.style.display = 'block';
            errorEl.textContent = 'Cannot divide by zero.';
            hideResults();
            return;
          }
          resNum = impNum1 * den2;
          resDen = den1 * impNum2;
        }

        // Handle negative denominator
        if (resDen < 0) {
          resNum = -resNum;
          resDen = -resDen;
        }

        // Simplify Result
        const divisor = gcd(resNum, resDen);
        resNum = resNum / divisor;
        resDen = resDen / divisor;

        // Convert back to mixed number for primary display
        let isNegative = resNum < 0;
        let absNum = Math.abs(resNum);

        let outWhole = Math.floor(absNum / resDen);
        let outNum = absNum % resDen;

        if (isNegative && outWhole > 0) {
          outWhole = -outWhole;
        } else if (isNegative && outWhole === 0) {
          outNum = -outNum;
        }

        renderResults(outWhole, outNum, resDen, resNum, resDen);
      }

      function hideResults() {
        resultDisplay.innerHTML = '<span class="res-whole">---</span>';
        resultImproper.style.display = 'none';
        resultDecimal.style.display = 'none';
      }

      function renderResults(w, n, d, impNum, impDen) {
        let html = '';

        // Build Mixed Number HTML
        if (w !== 0 && n !== 0) {
          html += '<span class="res-whole">' + w + '</span>';
          html += '<div class="res-fraction"><span class="res-num">' + Math.abs(n) + '</span><span class="res-den">' + d + '</span></div>';
        } else if (w !== 0 && n === 0) {
          html += '<span class="res-whole">' + w + '</span>';
        } else if (w === 0 && n !== 0) {
          html += '<div class="res-fraction"><span class="res-num">' + n + '</span><span class="res-den">' + d + '</span></div>';
        } else {
          html += '<span class="res-whole">0</span>';
        }

        resultDisplay.innerHTML = html;

        // Improper string
        if (n !== 0 && w !== 0) {
          resultImproper.style.display = 'block';
          resultImproper.textContent = '= ' + impNum + ' / ' + impDen;
        } else {
          resultImproper.style.display = 'none';
        }

        // Decimal string
        const dec = impNum / impDen;
        resultDecimal.style.display = 'block';
        // Check if integer or very short decimal
        if (Number.isInteger(dec)) {
          resultDecimal.textContent = '= ' + dec;
        } else {
          // Format long decimals to 4 places
          resultDecimal.textContent = '= ' + parseFloat(dec.toFixed(4));
        }
      }

      // Add listeners to all inputs
      const inputs = [w1, n1, d1, op, w2, n2, d2];
      inputs.forEach(input => {
        input.addEventListener('input', calculate);
        input.addEventListener('change', calculate); // for select dropdown
      });

      // Initial execution
      calculate();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .mixed-inputs-container { display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2rem;}
    @media (max-width: 700px) { .mixed-inputs-container { flex-direction: column; gap: 2rem; } }

    .fraction-group { display: flex; flex-direction: column; align-items: center; }
    .fraction-label { font-size: 0.9rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }

    .mixed-number-input { display: flex; align-items: center; gap: 0.75rem; }
    .mixed-number-input input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); border-radius: 8px; font-size: 1.1rem; text-align: center; font-family: var(--font-mono); }
    .mixed-number-input input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    /* Whole number input */
    .mixed-number-input > input { width: 70px; height: 60px; font-size: 1.4rem;}

    /* Fraction part */
    .fraction-part { display: flex; flex-direction: column; gap: 0.25rem; align-items: center; }
    .fraction-part input { width: 60px; height: 40px; }
    .fraction-bar { width: 100%; height: 2px; background-color: var(--border-color); }

    .operator-group select { background: var(--bg-color); color: var(--accent-color); border: 2px solid var(--border-color); border-radius: 12px; padding: 0.75rem 1rem; font-size: 1.5rem; font-weight: 800; cursor: pointer; text-align: center; margin-top: 1.5rem; }
    .operator-group select:focus { outline: none; border-color: var(--accent-color); }
    @media (max-width: 700px) { .operator-group select { margin-top: 0; } }

    .error-msg { color: #ef4444; font-size: 0.9rem; margin-top: 0.5rem; display: none; text-align: center; background: rgba(239, 68, 68, 0.1); padding: 0.75rem; border-radius: 8px; border: 1px solid rgba(239, 68, 68, 0.2); margin-bottom: 1.5rem;}

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 2rem; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem;}
    .result-label { color: var(--text-secondary); font-size: 0.95rem; text-transform: uppercase; font-weight: 600; letter-spacing: 1px;}

    .result-display { display: flex; align-items: center; gap: 0.5rem; color: var(--accent-color); font-family: var(--font-mono); }
    .res-whole { font-size: 3.5rem; font-weight: 800; line-height: 1;}
    .res-fraction { display: flex; flex-direction: column; align-items: center; gap: 0.25rem; font-size: 1.75rem; font-weight: 700;}
    .res-num { border-bottom: 3px solid var(--accent-color); padding: 0 0.5rem 0.2rem; }
    .res-den { padding: 0.2rem 0.5rem 0;}

    .result-improper { font-size: 1.25rem; font-family: var(--font-mono); color: var(--text-secondary); margin-top: 0.5rem;}
    .result-decimal { font-size: 1.25rem; font-family: var(--font-mono); color: var(--text-secondary); }

    .cross-link-box { padding: 1rem; background: color-mix(in srgb, var(--accent-color) 5%, transparent); border-left: 4px solid var(--accent-color); border-radius: 0 8px 8px 0; font-size: 0.95rem; margin-top: 1.5rem; }
    .cross-link-box a { color: var(--accent-color); font-weight: 600; text-decoration: none; }
    .cross-link-box a:hover { text-decoration: underline; }

    .explainer { margin-top: 3rem; }
    .explainer h2 { font-size: 1.8rem; color: var(--accent-color); margin-bottom: 1.5rem; }
    .explainer h3 { font-size: 1.3rem; margin: 2rem 0 1rem; }
    .explainer h4 { font-size: 1.1rem; margin: 1.5rem 0 0.75rem; color: var(--text-primary); }
    .explainer p { margin-bottom: 1.2rem; line-height: 1.7; color: var(--text-secondary); }
    .explainer ul, .explainer ol { margin-left: 1.5rem; margin-bottom: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.8rem; }
    .explainer strong { color: var(--text-primary); }

    .faq-section { margin-top: 4rem; }
    .faq-item { margin-bottom: 1rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; overflow: hidden; }
    .faq-item summary { font-weight: 600; padding: 1.2rem; cursor: pointer; list-style: none; position: relative; color: var(--text-primary); }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; position: absolute; right: 1.2rem; top: 50%; transform: translateY(-50%); font-size: 1.2rem; color: var(--accent-color); }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p { padding: 0 1.2rem 1.2rem; margin: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
