---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Typing Speed Test — Check Your WPM in Seconds",
  description: "Test your typing speed with this free online WPM test. See live words per minute, accuracy percentage, and error highlighting. Choose 15s, 30s, 60s, or 120s tests with common words, quotes, code snippets, and number drills.",
  category: "tool",
  published: "2026-03-21",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a good typing speed?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The average typing speed is about 40 words per minute (WPM). A speed of 60–70 WPM is considered above average, while professional typists and programmers often reach 80–100 WPM. Competitive typists and stenographers can exceed 150–200 WPM. For most office jobs, 50–60 WPM with high accuracy is sufficient."
        }
      },
      {
        "@type": "Question",
        "name": "How is WPM calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Words per minute (WPM) is calculated by dividing the total number of characters typed (including spaces) by 5 to get a standardized 'word' count, then dividing by the elapsed time in minutes. For example, if you type 300 characters in 60 seconds, your WPM is (300 ÷ 5) ÷ 1 = 60 WPM. Raw WPM counts all keystrokes, while net (adjusted) WPM subtracts errors from the total."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between raw WPM and net WPM?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Raw WPM measures your total typing speed regardless of mistakes — every character you type counts. Net WPM (also called adjusted WPM) penalizes errors by subtracting incorrect words from your raw score. For example, if your raw WPM is 70 and you made 5 word-errors in one minute, your net WPM would be 65. Net WPM is generally considered the more meaningful metric because it rewards both speed and accuracy."
        }
      },
      {
        "@type": "Question",
        "name": "How can I improve my typing speed?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Focus on accuracy first — speed follows naturally. Use proper finger placement on the home row (ASDF for the left hand, JKL; for the right). Practice regularly with typing tests, aiming for at least 10–15 minutes daily. Avoid looking at the keyboard (touch typing). Start with common words to build muscle memory, then progress to quotes and code snippets. Many typists see a 10–20 WPM improvement within a few weeks of consistent practice."
        }
      },
      {
        "@type": "Question",
        "name": "Why does the test use different text categories?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Different text categories test different skills. Common words build core muscle memory with frequently used letter combinations. Quotes introduce punctuation, capital letters, and natural sentence flow. Code snippets train you on special characters like brackets, semicolons, and camelCase — essential for programmers. Number drills improve number row proficiency. Practicing across all categories builds well-rounded typing ability."
        }
      },
      {
        "@type": "Question",
        "name": "What typing speed do I need for a programming job?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While there is no strict minimum, most professional developers type between 50–80 WPM. More important than raw speed is comfort with special characters (brackets, semicolons, operators) and accuracy. Slow but accurate typing is far more productive than fast typing with many errors, since debugging typos wastes more time than typing slowly. A consistent 60 WPM with 95%+ accuracy is an excellent target for developers."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate should my typing be?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Professional typists aim for 97% accuracy or higher. For general use, 95% accuracy is a solid benchmark. Below 90%, errors significantly impact your effective speed because corrections take extra time. When practicing, it is better to slow down and maintain 95%+ accuracy than to type fast with many mistakes — your speed will naturally increase as accuracy becomes habitual."
        }
      },
      {
        "@type": "Question",
        "name": "Does typing speed really matter in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, typing speed still matters. Despite voice input and AI tools, the keyboard remains the primary input method for most knowledge work, programming, and communication. Faster typing reduces the friction between thinking and expressing ideas, which improves productivity in emails, documents, code, and chat. Studies show that faster typists report less cognitive load during writing tasks, freeing mental energy for the content itself rather than the mechanics of typing."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="sendnerds"
  title={meta.title}
  description={meta.description}
  canonical="https://sendnerds.photonbuilder.com/typing-speed-test"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      ⌨️ <strong style="color:#3B82F6;">Average typing speed is 40 WPM. Top remote workers hit 80+ WPM.</strong> Doubling your speed saves 2+ hours/day on emails, essays, and code. In a remote-first job market, typing speed is a competitive advantage. <a href="https://gab.ae/news/global-freelance-economy-record-growth-2026" style="color:#3B82F6;">Why remote skills matter →</a>
    </div>
    <div class="hero">
      <h1>Typing Speed Test</h1>
      <p class="subtitle">Measure your words per minute, track accuracy in real time, and beat your personal best. Choose your duration and text category, then start typing.</p>
    </div>

    <div class="test-container">
      <!-- Settings Bar -->
      <div class="settings-bar">
        <div class="setting-group">
          <label>Duration</label>
          <div class="btn-group" id="duration-btns">
            <button data-time="15">15s</button>
            <button data-time="30" class="active">30s</button>
            <button data-time="60">60s</button>
            <button data-time="120">120s</button>
          </div>
        </div>
        <div class="setting-group">
          <label>Text</label>
          <div class="btn-group" id="category-btns">
            <button data-cat="words" class="active">Common Words</button>
            <button data-cat="quotes">Quotes</button>
            <button data-cat="code">Code</button>
            <button data-cat="numbers">Numbers</button>
          </div>
        </div>
      </div>

      <!-- Live Stats -->
      <div class="live-stats" id="live-stats">
        <div class="stat-item">
          <span class="stat-value" id="live-wpm">0</span>
          <span class="stat-label">WPM</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="live-accuracy">100</span>
          <span class="stat-label">Accuracy %</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="live-timer">30</span>
          <span class="stat-label">Seconds</span>
        </div>
      </div>

      <!-- Text Display -->
      <div class="text-display" id="text-display"></div>

      <!-- Input -->
      <input type="text" id="typing-input" class="typing-input" placeholder="Start typing here..." autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">

      <!-- Controls -->
      <div class="controls">
        <button id="restart-btn" class="action-btn">Restart</button>
        <button id="new-text-btn" class="action-btn">New Text</button>
      </div>

      <!-- Results Panel (hidden until test complete) -->
      <div class="results-panel" id="results-panel" style="display:none">
        <h2>Results</h2>
        <div class="results-grid">
          <div class="result-card primary-card">
            <span class="rc-value" id="res-wpm">0</span>
            <span class="rc-label">WPM (Net)</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-raw-wpm">0</span>
            <span class="rc-label">Raw WPM</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-accuracy">0%</span>
            <span class="rc-label">Accuracy</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-chars">0</span>
            <span class="rc-label">Characters</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-errors">0</span>
            <span class="rc-label">Errors</span>
          </div>
          <div class="result-card">
            <span class="rc-value" id="res-pb">—</span>
            <span class="rc-label">Personal Best</span>
          </div>
        </div>

        <!-- Speed Rating -->
        <div class="speed-rating" id="speed-rating"></div>

        <!-- WPM Chart -->
        <div class="chart-wrap">
          <h3>WPM Over Time</h3>
          <canvas id="wpm-chart" width="800" height="220"></canvas>
        </div>
      </div>
    </div>

    <!-- Speed Comparison -->
    <div class="comparison-section">
      <h2>How Fast Is Your Typing?</h2>
      <div class="speed-tiers">
        <div class="tier">
          <div class="tier-bar" style="width:15%"></div>
          <div class="tier-info"><strong>Beginner</strong> <span>&lt; 30 WPM</span></div>
        </div>
        <div class="tier">
          <div class="tier-bar" style="width:30%"></div>
          <div class="tier-info"><strong>Average</strong> <span>30–50 WPM</span></div>
        </div>
        <div class="tier">
          <div class="tier-bar" style="width:50%"></div>
          <div class="tier-info"><strong>Above Average</strong> <span>50–70 WPM</span></div>
        </div>
        <div class="tier">
          <div class="tier-bar" style="width:70%"></div>
          <div class="tier-info"><strong>Fast</strong> <span>70–100 WPM</span></div>
        </div>
        <div class="tier">
          <div class="tier-bar" style="width:85%"></div>
          <div class="tier-info"><strong>Pro</strong> <span>100–150 WPM</span></div>
        </div>
        <div class="tier">
          <div class="tier-bar" style="width:100%"></div>
          <div class="tier-info"><strong>Stenographer</strong> <span>200+ WPM</span></div>
        </div>
      </div>
    </div>

    <!-- Explainer -->
    <div class="explainer">
      <h2>The Complete Guide to Typing Speed Tests</h2>
      <p>Typing speed is one of the most practical skills you can develop in the digital age. Whether you are a student, professional, or programmer, faster and more accurate typing directly translates to increased productivity. This guide explains how typing tests work, what the numbers mean, and how to use practice to improve your words per minute.</p>

      <h3>How Typing Speed Is Measured</h3>
      <p>The standard unit for typing speed is words per minute (WPM). Since words vary in length, typing tests use a standardized word length of five characters (including spaces). If you type 250 characters in one minute, your WPM is 250 ÷ 5 = 50 WPM. This standardization allows fair comparison regardless of the specific text being typed. Raw WPM counts every keystroke, while net WPM subtracts errors to give a more realistic measure of productive typing speed.</p>

      <h3>Why Accuracy Matters More Than Speed</h3>
      <p>A common mistake among people trying to improve their typing is chasing speed at the expense of accuracy. Every error you make requires correction, which costs two or more additional keystrokes (backspace plus retyping). At 95% accuracy, roughly 1 in 20 characters is wrong. At 90% accuracy, that drops to 1 in 10 — meaning you spend a significant portion of your typing time fixing mistakes. The most efficient path to faster typing is to first achieve consistent 97%+ accuracy at a comfortable speed, then gradually push faster while maintaining that accuracy floor.</p>

      <h3>Touch Typing and Proper Technique</h3>
      <p>Touch typing — typing without looking at the keyboard — is the foundation of fast typing. Place your index fingers on F and J (which have raised bumps for tactile reference) and let each finger cover its designated zone of keys. Your left hand covers A–G and the keys above and below, while your right hand covers H–; and its corresponding rows. Thumbs rest on the space bar. This technique feels slow at first, but once the muscle memory develops, it is dramatically faster than hunt-and-peck because your eyes never leave the screen.</p>

      <h3>Choosing the Right Practice Mode</h3>
      <p>Our typing test offers four text categories, each serving a different training purpose. Common words build muscle memory for the letter combinations you use most often in everyday writing. Quotes add natural punctuation, capitalization, and sentence structure. Code snippets are essential for developers, training you on brackets, semicolons, operators, and mixed-case identifiers. Number drills strengthen your number-row proficiency, which is often the weakest area for most typists. Rotating through all categories creates well-rounded typing ability.</p>

      <h3>Related Tools</h3>
      <p>Working on an essay or research paper? Our <a href="/citation-generator">Citation Generator</a> formats your sources in APA, MLA, and Chicago styles. Need to calculate your course grades? Try our <a href="/grade-calculator">Grade Calculator</a> for weighted averages and GPA conversion.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map(faq => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // ---- Text Banks ----
      const texts = {
        words: [
          "the be to of and a in that have i it for not on with he as you do at this but his by from they we say her she or an will my one all would there their what so up out if about who get which go me when make can like time no just him know take people into year your good some could them see other than then now look only come its over think also back after use two how our work first well way even new want because any these give day most us",
          "about after again air all along also an and another any are around as at away back be because been before began being below between both but by came can come could day did different do does each end even every few find first for from get give go going good great had has have he help her here him his home house how i if in into is it its just know large last left let life like line little long look made make man many may me more most much must my name never new next no not now number of off old on one only or other our out over own part people place point",
          "small state still such take tell than that the them then there these they thing think this those through time to too two under up us use very want water way we well were what when where which while who why will with word work world would write year you your been call come could day did each find first from get go had has have her him his how its just know like long look made make many more most much must name new next not now number old one only other our out over own part people point right same say see she some still take tell than that the their them then there",
          "able about above accept across act actually add after again against ago agree air all allow almost along already also always an and animal another answer any anything appear area arm around arrive art ask at away back bad ball bank base be beat beautiful because become bed before began begin behind believe below beside best better between big bird black blood blue board body bone book both bottom box boy bring brother build burn business but buy by call came can car care carry case cat catch cause center certain change child city"
        ],
        quotes: [
          "The only way to do great work is to love what you do. If you have not found it yet, keep looking. Do not settle. As with all matters of the heart, you will know when you find it.",
          "It is not the strongest of the species that survives, nor the most intelligent, but the one most responsive to change. In the long history of humankind, those who learned to collaborate and improvise most effectively have prevailed.",
          "Two things are infinite: the universe and human stupidity; and I am not sure about the universe. The important thing is not to stop questioning. Curiosity has its own reason for existing.",
          "In three words I can sum up everything I have learned about life: it goes on. The best time to plant a tree was twenty years ago. The second best time is now.",
          "The greatest glory in living lies not in never falling, but in rising every time we fall. Life is what happens when you are busy making other plans. The purpose of our lives is to be happy.",
          "You miss one hundred percent of the shots you do not take. Whether you think you can or you think you cannot, you are right. The future belongs to those who believe in the beauty of their dreams.",
          "Success is not final, failure is not fatal: it is the courage to continue that counts. It always seems impossible until it is done. The only impossible journey is the one you never begin.",
          "Be yourself; everyone else is already taken. Do what you can, with what you have, where you are. Believe you can and you are halfway there. Act as if what you do makes a difference, because it does."
        ],
        code: [
          "function fibonacci(n) { if (n <= 1) return n; return fibonacci(n - 1) + fibonacci(n - 2); } const result = fibonacci(10); console.log(result);",
          "const fetchData = async (url) => { try { const response = await fetch(url); const data = await response.json(); return data; } catch (error) { console.error(error); } };",
          "class Stack { constructor() { this.items = []; } push(item) { this.items.push(item); } pop() { return this.items.pop(); } peek() { return this.items[this.items.length - 1]; } isEmpty() { return this.items.length === 0; } }",
          "const sortArray = (arr) => { if (arr.length <= 1) return arr; const pivot = arr[0]; const left = arr.filter((x, i) => i > 0 && x <= pivot); const right = arr.filter(x => x > pivot); return [...sortArray(left), pivot, ...sortArray(right)]; };",
          "for (let i = 0; i < matrix.length; i++) { for (let j = 0; j < matrix[i].length; j++) { if (matrix[i][j] === target) { return { row: i, col: j }; } } } return null;",
          "const debounce = (func, delay) => { let timer; return (...args) => { clearTimeout(timer); timer = setTimeout(() => func(...args), delay); }; }; const handleInput = debounce((e) => search(e.target.value), 300);"
        ],
        numbers: [
          "192 384 576 768 1024 2048 4096 8192 16384 32768 65536 128 256 512 1000 2000 5000 10000 25000 50000 100 200 300 400 500 600 700 800 900 1100 1200 1500 1800 2100 2400 2700 3000 3500 4000 4500",
          "3.14159 2.71828 1.61803 0.57721 1.41421 2.23607 1.73205 2.44949 0.69315 2.30259 9.81 6.674 3.0 1.602 6.022 8.314 1.381 5.670 6.626 2.998",
          "phone: 555-0123 zip: 90210 code: 8675309 pin: 1234 year: 2026 price: $49.99 score: 98.6 temp: 72.5 height: 5.11 weight: 185.4 id: 007 room: 404 port: 8080 hex: 0xFF count: 1024",
          "12 + 7 = 19 and 45 - 18 = 27 then 8 * 6 = 48 next 144 / 12 = 12 also 25 + 37 = 62 plus 100 - 43 = 57 times 9 * 11 = 99 divided 256 / 16 = 16 sum 33 + 67 = 100 diff 80 - 35 = 45"
        ]
      };

      // ---- State ----
      let duration = 30;
      let category = 'words';
      let testText = '';
      let charIndex = 0;
      let errors = 0;
      let totalCharsTyped = 0;
      let correctChars = 0;
      let timer = null;
      let timeLeft = 0;
      let started = false;
      let finished = false;
      let startTime = 0;
      let wpmHistory = [];
      let wpmTimeStamps = [];

      // ---- DOM ----
      const textDisplay = document.getElementById('text-display');
      const typingInput = document.getElementById('typing-input');
      const liveWpm = document.getElementById('live-wpm');
      const liveAccuracy = document.getElementById('live-accuracy');
      const liveTimer = document.getElementById('live-timer');
      const resultsPanel = document.getElementById('results-panel');
      const restartBtn = document.getElementById('restart-btn');
      const newTextBtn = document.getElementById('new-text-btn');

      // ---- Duration & Category Buttons ----
      document.querySelectorAll('#duration-btns button').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#duration-btns button').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          duration = parseInt(btn.dataset.time);
          resetTest();
        });
      });

      document.querySelectorAll('#category-btns button').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('#category-btns button').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          category = btn.dataset.cat;
          resetTest();
        });
      });

      // ---- Text Generation ----
      function generateText() {
        const bank = texts[category];
        const chosen = bank[Math.floor(Math.random() * bank.length)];
        // For words/numbers, shuffle to add variety
        if (category === 'words' || category === 'numbers') {
          const words = chosen.split(/\s+/);
          for (let i = words.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [words[i], words[j]] = [words[j], words[i]];
          }
          // Take enough words for the duration
          const count = Math.max(50, duration * 3);
          const result = [];
          while (result.length < count) {
            result.push(...words);
          }
          return result.slice(0, count).join(' ');
        }
        // For quotes/code, concatenate multiple if needed
        const shuffled = [...bank].sort(() => Math.random() - 0.5);
        return shuffled.slice(0, Math.max(2, Math.ceil(duration / 15))).join(' ');
      }

      function renderText() {
        textDisplay.innerHTML = '';
        for (let i = 0; i < testText.length; i++) {
          const span = document.createElement('span');
          span.textContent = testText[i];
          span.className = 'char';
          if (i === 0) span.classList.add('current');
          textDisplay.appendChild(span);
        }
      }

      // ---- Reset ----
      function resetTest() {
        clearInterval(timer);
        started = false;
        finished = false;
        charIndex = 0;
        errors = 0;
        totalCharsTyped = 0;
        correctChars = 0;
        timeLeft = duration;
        wpmHistory = [];
        wpmTimeStamps = [];
        startTime = 0;
        testText = generateText();
        renderText();
        typingInput.value = '';
        typingInput.disabled = false;
        liveWpm.textContent = '0';
        liveAccuracy.textContent = '100';
        liveTimer.textContent = duration;
        resultsPanel.style.display = 'none';
        typingInput.focus();
      }

      // ---- Timer ----
      function startTimer() {
        startTime = Date.now();
        timeLeft = duration;
        timer = setInterval(() => {
          const elapsed = (Date.now() - startTime) / 1000;
          timeLeft = Math.max(0, duration - Math.floor(elapsed));
          liveTimer.textContent = timeLeft;

          // Record WPM snapshot every second
          const minutes = elapsed / 60;
          if (minutes > 0) {
            const currentWpm = Math.round((correctChars / 5) / minutes);
            wpmHistory.push(currentWpm);
            wpmTimeStamps.push(Math.floor(elapsed));
          }

          // Update live WPM
          if (minutes > 0) {
            liveWpm.textContent = Math.round((correctChars / 5) / minutes);
          }

          if (timeLeft <= 0) {
            endTest();
          }
        }, 1000);
      }

      // ---- Typing Handler ----
      typingInput.addEventListener('input', (e) => {
        if (finished) return;
        if (!started) {
          started = true;
          startTimer();
        }

        const inputVal = typingInput.value;
        const chars = textDisplay.querySelectorAll('.char');

        // Process current character
        const typed = inputVal[inputVal.length - 1];
        if (charIndex < testText.length && typed !== undefined) {
          totalCharsTyped++;
          if (typed === testText[charIndex]) {
            chars[charIndex].classList.add('correct');
            chars[charIndex].classList.remove('current');
            correctChars++;
            charIndex++;
          } else {
            chars[charIndex].classList.add('incorrect');
            chars[charIndex].classList.remove('current');
            errors++;
            charIndex++;
          }

          // Mark next char as current
          if (charIndex < testText.length) {
            chars[charIndex].classList.add('current');
            // Auto-scroll text display
            const currentChar = chars[charIndex];
            const displayRect = textDisplay.getBoundingClientRect();
            const charRect = currentChar.getBoundingClientRect();
            if (charRect.top > displayRect.top + displayRect.height - 40) {
              textDisplay.scrollTop += charRect.height * 2;
            }
          }

          // Update live accuracy
          if (totalCharsTyped > 0) {
            liveAccuracy.textContent = Math.round((correctChars / totalCharsTyped) * 100);
          }

          // Clear input to prevent buildup
          typingInput.value = '';

          // Check if we typed all text
          if (charIndex >= testText.length) {
            endTest();
          }
        }
      });

      // Handle backspace — we don't allow backspace in this test for simplicity
      typingInput.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace') {
          e.preventDefault();
        }
        if (e.key === 'Tab') {
          e.preventDefault();
          resetTest();
        }
      });

      // ---- End Test ----
      function endTest() {
        clearInterval(timer);
        finished = true;
        typingInput.disabled = true;

        const elapsed = (Date.now() - startTime) / 1000;
        const minutes = elapsed / 60;
        const rawWpm = minutes > 0 ? Math.round((totalCharsTyped / 5) / minutes) : 0;
        const netWpm = minutes > 0 ? Math.max(0, Math.round(((correctChars / 5)) / minutes)) : 0;
        const accuracy = totalCharsTyped > 0 ? Math.round((correctChars / totalCharsTyped) * 100) : 0;

        // Display results
        document.getElementById('res-wpm').textContent = netWpm;
        document.getElementById('res-raw-wpm').textContent = rawWpm;
        document.getElementById('res-accuracy').textContent = accuracy + '%';
        document.getElementById('res-chars').textContent = totalCharsTyped;
        document.getElementById('res-errors').textContent = errors;

        // Personal best (localStorage)
        const pbKey = 'typing-pb-' + duration + '-' + category;
        const currentPb = parseInt(localStorage.getItem(pbKey)) || 0;
        let pbText = currentPb + ' WPM';
        if (netWpm > currentPb) {
          localStorage.setItem(pbKey, netWpm);
          pbText = netWpm + ' WPM (New!)';
        }
        document.getElementById('res-pb').textContent = pbText;

        // Speed rating
        const ratingEl = document.getElementById('speed-rating');
        let ratingLabel, ratingClass;
        if (netWpm < 30) { ratingLabel = 'Beginner'; ratingClass = 'rating-beginner'; }
        else if (netWpm < 50) { ratingLabel = 'Average'; ratingClass = 'rating-average'; }
        else if (netWpm < 70) { ratingLabel = 'Above Average'; ratingClass = 'rating-above'; }
        else if (netWpm < 100) { ratingLabel = 'Fast'; ratingClass = 'rating-fast'; }
        else if (netWpm < 150) { ratingLabel = 'Pro'; ratingClass = 'rating-pro'; }
        else { ratingLabel = 'Stenographer'; ratingClass = 'rating-steno'; }
        ratingEl.innerHTML = '<span class="rating-badge ' + ratingClass + '">' + ratingLabel + '</span> <span class="rating-desc">' + netWpm + ' WPM</span>';

        // Draw WPM chart
        drawChart();

        resultsPanel.style.display = 'block';
        resultsPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // ---- WPM Chart (Canvas) ----
      function drawChart() {
        const canvas = document.getElementById('wpm-chart');
        const ctx = canvas.getContext('2d');
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx.scale(dpr, dpr);
        const w = rect.width;
        const h = rect.height;

        ctx.clearRect(0, 0, w, h);

        if (wpmHistory.length < 2) return;

        const maxWpm = Math.max(...wpmHistory, 10);
        const padTop = 20, padBottom = 30, padLeft = 40, padRight = 15;
        const chartW = w - padLeft - padRight;
        const chartH = h - padTop - padBottom;

        // Determine colors based on computed styles
        const style = getComputedStyle(document.documentElement);
        const textColor = style.getPropertyValue('--text') || '#333';
        const accentColor = style.getPropertyValue('--accent') || '#2563eb';

        // Grid lines
        ctx.strokeStyle = textColor.trim();
        ctx.globalAlpha = 0.1;
        ctx.lineWidth = 1;
        const gridLines = 4;
        for (let i = 0; i <= gridLines; i++) {
          const y = padTop + (chartH / gridLines) * i;
          ctx.beginPath();
          ctx.moveTo(padLeft, y);
          ctx.lineTo(w - padRight, y);
          ctx.stroke();
        }
        ctx.globalAlpha = 1;

        // Y-axis labels
        ctx.fillStyle = textColor.trim();
        ctx.globalAlpha = 0.5;
        ctx.font = '11px system-ui, sans-serif';
        ctx.textAlign = 'right';
        for (let i = 0; i <= gridLines; i++) {
          const y = padTop + (chartH / gridLines) * i;
          const val = Math.round(maxWpm * (1 - i / gridLines));
          ctx.fillText(val, padLeft - 6, y + 4);
        }

        // X-axis labels
        ctx.textAlign = 'center';
        const step = Math.max(1, Math.floor(wpmHistory.length / 6));
        for (let i = 0; i < wpmHistory.length; i += step) {
          const x = padLeft + (i / (wpmHistory.length - 1)) * chartW;
          ctx.fillText(wpmTimeStamps[i] + 's', x, h - 8);
        }
        ctx.globalAlpha = 1;

        // Draw line
        ctx.beginPath();
        ctx.strokeStyle = accentColor.trim();
        ctx.lineWidth = 2.5;
        ctx.lineJoin = 'round';
        ctx.lineCap = 'round';
        for (let i = 0; i < wpmHistory.length; i++) {
          const x = padLeft + (i / (wpmHistory.length - 1)) * chartW;
          const y = padTop + chartH - (wpmHistory[i] / maxWpm) * chartH;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.stroke();

        // Fill area under line
        ctx.lineTo(padLeft + chartW, padTop + chartH);
        ctx.lineTo(padLeft, padTop + chartH);
        ctx.closePath();
        ctx.fillStyle = accentColor.trim();
        ctx.globalAlpha = 0.08;
        ctx.fill();
        ctx.globalAlpha = 1;

        // Dots on data points (max ~20)
        const dotStep = Math.max(1, Math.floor(wpmHistory.length / 20));
        ctx.fillStyle = accentColor.trim();
        for (let i = 0; i < wpmHistory.length; i += dotStep) {
          const x = padLeft + (i / (wpmHistory.length - 1)) * chartW;
          const y = padTop + chartH - (wpmHistory[i] / maxWpm) * chartH;
          ctx.beginPath();
          ctx.arc(x, y, 3, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // ---- Controls ----
      restartBtn.addEventListener('click', resetTest);
      newTextBtn.addEventListener('click', resetTest);

      // ---- Focus management ----
      textDisplay.addEventListener('click', () => {
        if (!finished) typingInput.focus();
      });

      // ---- Init ----
      resetTest();
    });
  </script>

