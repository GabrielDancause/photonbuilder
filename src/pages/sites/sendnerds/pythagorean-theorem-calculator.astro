---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Pythagorean Theorem Calculator | Find Any Side of a Right Triangle",
  description: "Calculate any missing side of a right triangle instantly. Interactive visual triangle, step-by-step solutions, exact √ answers, Pythagorean triples reference, and proof visualization.",
  category: "tool",
  published: "2026-03-28",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Pythagorean Theorem Calculator: Find the Missing Side of Any Right Triangle",
    "description": "Use the Pythagorean theorem (a² + b² = c²) to calculate any missing side of a right triangle. Interactive SVG visualization, step-by-step solutions, and common Pythagorean triples.",
    "author": { "@type": "Organization", "name": "SendNerds", "url": "https://sendnerds.photonbuilder.com" },
    "publisher": { "@type": "Organization", "name": "SendNerds", "url": "https://sendnerds.photonbuilder.com" },
    "datePublished": "2026-03-28",
    "mainEntityOfPage": { "@type": "WebPage", "@id": "https://sendnerds.photonbuilder.com/pythagorean-theorem-calculator" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is the Pythagorean theorem?", "acceptedAnswer": { "@type": "Answer", "text": "The Pythagorean theorem states that in a right triangle, the square of the hypotenuse (c) equals the sum of the squares of the other two sides (a and b). Written as a² + b² = c², it's one of the most fundamental relationships in geometry, discovered by the ancient Greek mathematician Pythagoras around 500 BCE." } },
      { "@type": "Question", "name": "How do I find the hypotenuse of a right triangle?", "acceptedAnswer": { "@type": "Answer", "text": "To find the hypotenuse, square both known sides, add them together, and take the square root: c = √(a² + b²). For example, if side a = 3 and side b = 4, then c = √(9 + 16) = √25 = 5." } },
      { "@type": "Question", "name": "Does the Pythagorean theorem work for all triangles?", "acceptedAnswer": { "@type": "Answer", "text": "No, the Pythagorean theorem only works for right triangles — triangles with exactly one 90° angle. For non-right triangles, you would use the Law of Cosines: c² = a² + b² − 2ab·cos(C), which is a generalization of the Pythagorean theorem." } },
      { "@type": "Question", "name": "What is a Pythagorean triple?", "acceptedAnswer": { "@type": "Answer", "text": "A Pythagorean triple is a set of three positive integers (a, b, c) that satisfy a² + b² = c². The most famous example is (3, 4, 5). Other common triples include (5, 12, 13), (8, 15, 17), and (7, 24, 25). Any multiple of a triple is also a triple — for example, (6, 8, 10) is 2× the (3, 4, 5) triple." } },
      { "@type": "Question", "name": "Who invented the Pythagorean theorem?", "acceptedAnswer": { "@type": "Answer", "text": "While named after the Greek mathematician Pythagoras (c. 570–495 BCE), the relationship was known to Babylonian mathematicians over 1,000 years earlier, as evidenced by the clay tablet Plimpton 322 (c. 1800 BCE). Ancient Indian and Chinese mathematicians also independently discovered the theorem. Pythagoras (or his school) is credited with the first known formal proof." } }
    ]
  }
];
---

<SiteLayout title={meta.title} description={meta.description} site="sendnerds">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <style>
    .pyth-container { max-width: 900px; margin: 0 auto; padding: 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #c8d6e5; }
    h1 { font-size: 2rem; color: #f1f5f9; text-align: center; margin-bottom: 8px; }
    .subtitle { text-align: center; color: #64748b; margin-bottom: 32px; font-size: 1.05rem; }
    h2 { font-size: 1.4rem; color: #e2e8f0; margin: 40px 0 16px; border-bottom: 1px solid #152040; padding-bottom: 8px; }
    h3 { font-size: 1.15rem; color: #cbd5e1; margin: 24px 0 12px; }

    .calc-card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 28px; margin-bottom: 24px; }
    .mode-tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
    .mode-tab { padding: 10px 18px; border: 1px solid #152040; border-radius: 8px; background: #0a1020; color: #94a3b8; cursor: pointer; font-size: 0.95rem; transition: all 0.2s; }
    .mode-tab:hover { border-color: #3B82F6; color: #c8d6e5; }
    .mode-tab.active { background: #1e3a5f; border-color: #3B82F6; color: #fff; }

    .calc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; align-items: start; }
    @media (max-width: 700px) { .calc-layout { grid-template-columns: 1fr; } }

    .input-group { margin-bottom: 16px; }
    .input-group label { display: block; font-size: 0.85rem; color: #94a3b8; margin-bottom: 6px; font-family: 'JetBrains Mono', monospace; }
    .input-group input { width: 100%; padding: 10px 14px; background: #060a12; border: 1px solid #152040; border-radius: 8px; color: #f1f5f9; font-size: 1.05rem; font-family: 'JetBrains Mono', monospace; box-sizing: border-box; }
    .input-group input:focus { outline: none; border-color: #3B82F6; box-shadow: 0 0 0 2px rgba(59,130,246,0.15); }
    .input-group input:disabled { opacity: 0.4; cursor: not-allowed; }
    .input-group .hint { font-size: 0.78rem; color: #3B82F6; margin-top: 4px; font-style: italic; }

    .btn-calc { width: 100%; padding: 12px; background: #3B82F6; color: #fff; border: none; border-radius: 8px; font-size: 1rem; cursor: pointer; font-weight: 600; transition: background 0.2s; margin-top: 8px; }
    .btn-calc:hover { background: #2563eb; }

    .svg-wrap { display: flex; justify-content: center; align-items: center; min-height: 260px; }
    .svg-wrap svg { max-width: 100%; }

    .result-box { background: #060a12; border: 1px solid #152040; border-radius: 10px; padding: 20px; margin-top: 20px; }
    .result-box .res-label { font-size: 0.8rem; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .result-box .res-value { font-size: 1.6rem; color: #3B82F6; font-family: 'JetBrains Mono', monospace; font-weight: 700; }
    .result-box .res-exact { font-size: 1rem; color: #94a3b8; font-family: 'JetBrains Mono', monospace; margin-top: 4px; }

    .steps { margin-top: 16px; }
    .step { display: flex; gap: 12px; margin-bottom: 10px; align-items: flex-start; }
    .step-num { background: #1e3a5f; color: #3B82F6; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; flex-shrink: 0; }
    .step-text { color: #c8d6e5; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; line-height: 1.5; }

    .triples-table { width: 100%; border-collapse: collapse; margin: 16px 0; }
    .triples-table th { background: #0f1b30; color: #94a3b8; padding: 10px 16px; text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #152040; }
    .triples-table td { padding: 10px 16px; border-bottom: 1px solid #0f1629; color: #c8d6e5; font-family: 'JetBrains Mono', monospace; }
    .triples-table tr:hover td { background: #0a1020; }
    .check { color: #22c55e; }

    .app-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 16px 0; }
    @media (max-width: 600px) { .app-grid { grid-template-columns: 1fr; } }
    .app-card { background: #0a1020; border: 1px solid #152040; border-radius: 10px; padding: 20px; }
    .app-card .app-icon { font-size: 1.8rem; margin-bottom: 8px; }
    .app-card h4 { color: #e2e8f0; margin: 0 0 8px; font-size: 1rem; }
    .app-card p { color: #94a3b8; font-size: 0.9rem; margin: 0; line-height: 1.5; }

    .proof-container { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 24px; text-align: center; }
    .proof-controls { display: flex; gap: 8px; justify-content: center; margin-top: 16px; flex-wrap: wrap; }
    .proof-btn { padding: 8px 16px; border: 1px solid #152040; border-radius: 6px; background: #060a12; color: #94a3b8; cursor: pointer; font-size: 0.85rem; transition: all 0.2s; }
    .proof-btn:hover { border-color: #3B82F6; color: #c8d6e5; }
    .proof-btn.active { background: #1e3a5f; border-color: #3B82F6; color: #fff; }
    .proof-caption { color: #94a3b8; font-size: 0.9rem; margin-top: 12px; line-height: 1.5; }

    .faq-section { margin-top: 40px; }
    .faq-item { border: 1px solid #152040; border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
    .faq-q { padding: 16px 20px; background: #0a1020; cursor: pointer; display: flex; justify-content: space-between; align-items: center; color: #e2e8f0; font-weight: 500; }
    .faq-q:hover { background: #0f1629; }
    .faq-arrow { transition: transform 0.2s; color: #3B82F6; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }
    .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.3s, padding 0.3s; }
    .faq-item.open .faq-a { max-height: 300px; padding: 16px 20px; }
    .faq-a p { color: #94a3b8; line-height: 1.7; margin: 0; }

    .related-links { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 12px; }
    .related-link { padding: 8px 16px; background: #0a1020; border: 1px solid #152040; border-radius: 8px; color: #3B82F6; text-decoration: none; font-size: 0.9rem; transition: all 0.2s; }
    .related-link:hover { border-color: #3B82F6; background: #0f1629; }
  </style>

  <div class="pyth-container">
    <h1>Pythagorean Theorem Calculator</h1>
    <p class="subtitle">Find any missing side of a right triangle — with step-by-step solutions and visual proof</p>

    <div class="calc-card">
      <div class="mode-tabs">
        <button class="mode-tab active" data-mode="hyp" onclick="setMode('hyp')">Find Hypotenuse (c)</button>
        <button class="mode-tab" data-mode="a" onclick="setMode('a')">Find Side a</button>
        <button class="mode-tab" data-mode="b" onclick="setMode('b')">Find Side b</button>
      </div>

      <div class="calc-layout">
        <div>
          <div class="input-group">
            <label>Side a (opposite)</label>
            <input type="number" id="sideA" placeholder="e.g. 3" min="0.001" step="any" oninput="calculate()">
            <div class="hint" id="hintA"></div>
          </div>
          <div class="input-group">
            <label>Side b (adjacent)</label>
            <input type="number" id="sideB" placeholder="e.g. 4" min="0.001" step="any" oninput="calculate()">
            <div class="hint" id="hintB"></div>
          </div>
          <div class="input-group">
            <label>Side c (hypotenuse)</label>
            <input type="number" id="sideC" placeholder="e.g. 5" min="0.001" step="any" oninput="calculate()">
            <div class="hint" id="hintC"></div>
          </div>
        </div>
        <div class="svg-wrap" id="triangleSvg"></div>
      </div>

      <div class="result-box" id="resultBox" style="display:none;">
        <div class="res-label">Result</div>
        <div class="res-value" id="resValue"></div>
        <div class="res-exact" id="resExact"></div>
        <div class="steps" id="steps"></div>
      </div>
    </div>

    <!-- Pythagorean Triples -->
    <h2>Common Pythagorean Triples</h2>
    <p>A Pythagorean triple is a set of three positive integers where a² + b² = c² — meaning all three sides are whole numbers with no decimals. These are the building blocks of right-triangle geometry.</p>
    <table class="triples-table">
      <thead><tr><th>Side a</th><th>Side b</th><th>Hypotenuse c</th><th>Verify</th></tr></thead>
      <tbody>
        <tr><td>3</td><td>4</td><td>5</td><td><span class="check">9 + 16 = 25 ✓</span></td></tr>
        <tr><td>5</td><td>12</td><td>13</td><td><span class="check">25 + 144 = 169 ✓</span></td></tr>
        <tr><td>8</td><td>15</td><td>17</td><td><span class="check">64 + 225 = 289 ✓</span></td></tr>
        <tr><td>7</td><td>24</td><td>25</td><td><span class="check">49 + 576 = 625 ✓</span></td></tr>
        <tr><td>20</td><td>21</td><td>29</td><td><span class="check">400 + 441 = 841 ✓</span></td></tr>
        <tr><td>9</td><td>40</td><td>41</td><td><span class="check">81 + 1600 = 1681 ✓</span></td></tr>
        <tr><td>11</td><td>60</td><td>61</td><td><span class="check">121 + 3600 = 3721 ✓</span></td></tr>
      </tbody>
    </table>
    <p>Any integer multiple of a triple is also a triple. For example, doubling (3, 4, 5) gives (6, 8, 10), and tripling it gives (9, 12, 15). This means infinitely many Pythagorean triples exist.</p>

    <!-- Real-World Applications -->
    <h2>Real-World Applications</h2>
    <div class="app-grid">
      <div class="app-card">
        <div class="app-icon">🏗️</div>
        <h4>Construction & Carpentry</h4>
        <p>Builders use the 3-4-5 rule to verify corners are perfectly square. Measure 3 feet along one wall and 4 feet along the other — if the diagonal is exactly 5 feet, the corner is a true 90° angle. This technique has been used for thousands of years.</p>
      </div>
      <div class="app-card">
        <div class="app-icon">🧭</div>
        <h4>Navigation & Distance</h4>
        <p>GPS systems calculate the straight-line distance between two points using the Pythagorean theorem. If you walk 300 meters east and 400 meters north, the direct distance back to your starting point is 500 meters.</p>
      </div>
      <div class="app-card">
        <div class="app-icon">🪜</div>
        <h4>Ladder Safety</h4>
        <p>OSHA recommends a 4:1 ratio for ladder placement. A 20-foot ladder should have its base 5 feet from the wall. The theorem confirms the ladder reaches √(20² − 5²) = √375 ≈ 19.4 feet up the wall.</p>
      </div>
      <div class="app-card">
        <div class="app-icon">📺</div>
        <h4>Screen Sizes</h4>
        <p>TV and monitor sizes are measured diagonally. A display that's 48 inches wide and 27 inches tall has a diagonal of √(48² + 27²) = √3033 ≈ 55 inches. That's how manufacturers get the advertised screen size.</p>
      </div>
    </div>

    <!-- Visual Proof -->
    <h2>Visual Proof: Why a² + b² = c²</h2>
    <div class="proof-container">
      <svg id="proofSvg" viewBox="0 0 500 400" width="500" height="400"></svg>
      <div class="proof-controls">
        <button class="proof-btn active" data-proof="squares" onclick="showProof('squares')">Area of Squares</button>
        <button class="proof-btn" data-proof="rearrange" onclick="showProof('rearrange')">Rearrangement</button>
      </div>
      <p class="proof-caption" id="proofCaption">The square on the hypotenuse (green, area 25) equals the sum of the squares on the two legs (blue area 9 + red area 16 = 25).</p>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">What is the Pythagorean theorem? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>The Pythagorean theorem states that in a right triangle, the square of the hypotenuse (the side opposite the right angle) equals the sum of the squares of the other two sides. Written as a² + b² = c², it's one of the most fundamental relationships in geometry. Discovered by the ancient Greek mathematician Pythagoras around 500 BCE, though Babylonian mathematicians knew the relationship over 1,000 years earlier.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">How do I find the hypotenuse of a right triangle? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>To find the hypotenuse: (1) Square side a, (2) Square side b, (3) Add the results, (4) Take the square root. For example, if a = 3 and b = 4: 3² + 4² = 9 + 16 = 25, and √25 = 5. So the hypotenuse is 5. This calculator handles all the math and shows each step.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">Does the Pythagorean theorem work for all triangles? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>No — it only applies to right triangles (triangles with one 90° angle). For other triangles, use the Law of Cosines: c² = a² + b² − 2ab·cos(C). When angle C is exactly 90°, cos(90°) = 0, and the formula simplifies back to a² + b² = c². So the Pythagorean theorem is actually a special case of the Law of Cosines.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">What is a Pythagorean triple? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>A Pythagorean triple is a set of three positive integers (a, b, c) where a² + b² = c². The smallest and most famous is (3, 4, 5). Others include (5, 12, 13) and (8, 15, 17). Any integer multiple of a triple is also a triple — so (6, 8, 10) and (9, 12, 15) also qualify. There are infinitely many primitive triples (where a, b, c share no common factor).</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">Who invented the Pythagorean theorem? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>While named after the Greek mathematician Pythagoras (c. 570–495 BCE), the relationship was known much earlier. The Babylonian clay tablet Plimpton 322 (c. 1800 BCE) contains Pythagorean triples, and ancient Indian mathematicians documented the theorem in the Sulba Sutras (c. 800 BCE). Chinese mathematicians proved it independently in the Zhoubi Suanjing. Pythagoras (or his school) is credited with the first known formal proof.</p></div>
      </div>
    </div>

    <!-- Related -->
    <h2>Related Tools</h2>
    <div class="related-links">
      <a href="/multiplication-chart" class="related-link">Multiplication Chart</a>
      <a href="/average-calculator" class="related-link">Average Calculator</a>
      <a href="/aspect-ratio-calc" class="related-link">Aspect Ratio Calculator</a>
    </div>
  </div>

  <script is:inline>
    let currentMode = 'hyp';

    function setMode(mode) {
      currentMode = mode;
      document.querySelectorAll('.mode-tab').forEach(t => t.classList.toggle('active', t.dataset.mode === mode));
      const a = document.getElementById('sideA');
      const b = document.getElementById('sideB');
      const c = document.getElementById('sideC');
      a.disabled = false; b.disabled = false; c.disabled = false;
      document.getElementById('hintA').textContent = '';
      document.getElementById('hintB').textContent = '';
      document.getElementById('hintC').textContent = '';
      if (mode === 'hyp') { c.disabled = true; c.value = ''; document.getElementById('hintC').textContent = '← calculated'; }
      if (mode === 'a') { a.disabled = true; a.value = ''; document.getElementById('hintA').textContent = '← calculated'; }
      if (mode === 'b') { b.disabled = true; b.value = ''; document.getElementById('hintB').textContent = '← calculated'; }
      calculate();
    }

    function calculate() {
      const a = parseFloat(document.getElementById('sideA').value);
      const b = parseFloat(document.getElementById('sideB').value);
      const c = parseFloat(document.getElementById('sideC').value);
      const box = document.getElementById('resultBox');
      let result, exact, stepsHtml;

      if (currentMode === 'hyp' && a > 0 && b > 0) {
        const aS = a * a, bS = b * b, sum = aS + bS;
        result = Math.sqrt(sum);
        const sqrtInt = Number.isInteger(sum) && Number.isInteger(Math.sqrt(sum));
        exact = sqrtInt ? `= ${Math.round(result)}` : `= √${roundN(sum)} ≈ ${roundN(result)}`;
        stepsHtml = buildSteps([
          `a² = ${roundN(a)}² = ${roundN(aS)}`,
          `b² = ${roundN(b)}² = ${roundN(bS)}`,
          `a² + b² = ${roundN(aS)} + ${roundN(bS)} = ${roundN(sum)}`,
          `c = √${roundN(sum)} ${sqrtInt ? '= ' + Math.round(result) : '≈ ' + roundN(result)}`
        ]);
        document.getElementById('resValue').textContent = `c = ${roundN(result)}`;
        document.getElementById('resExact').textContent = `Exact: √(${roundN(aS)} + ${roundN(bS)}) ${exact}`;
        drawTriangle(a, b, result);
      } else if (currentMode === 'a' && b > 0 && c > 0) {
        if (c <= b) { box.style.display = 'none'; drawTriangle(0, b, c); return; }
        const cS = c * c, bS = b * b, diff = cS - bS;
        result = Math.sqrt(diff);
        const sqrtInt = Number.isInteger(diff) && Number.isInteger(Math.sqrt(diff));
        exact = sqrtInt ? `= ${Math.round(result)}` : `= √${roundN(diff)} ≈ ${roundN(result)}`;
        stepsHtml = buildSteps([
          `c² = ${roundN(c)}² = ${roundN(cS)}`,
          `b² = ${roundN(b)}² = ${roundN(bS)}`,
          `a² = c² − b² = ${roundN(cS)} − ${roundN(bS)} = ${roundN(diff)}`,
          `a = √${roundN(diff)} ${sqrtInt ? '= ' + Math.round(result) : '≈ ' + roundN(result)}`
        ]);
        document.getElementById('resValue').textContent = `a = ${roundN(result)}`;
        document.getElementById('resExact').textContent = `Exact: √(${roundN(cS)} − ${roundN(bS)}) ${exact}`;
        drawTriangle(result, b, c);
      } else if (currentMode === 'b' && a > 0 && c > 0) {
        if (c <= a) { box.style.display = 'none'; drawTriangle(a, 0, c); return; }
        const cS = c * c, aS = a * a, diff = cS - aS;
        result = Math.sqrt(diff);
        const sqrtInt = Number.isInteger(diff) && Number.isInteger(Math.sqrt(diff));
        exact = sqrtInt ? `= ${Math.round(result)}` : `= √${roundN(diff)} ≈ ${roundN(result)}`;
        stepsHtml = buildSteps([
          `c² = ${roundN(c)}² = ${roundN(cS)}`,
          `a² = ${roundN(a)}² = ${roundN(aS)}`,
          `b² = c² − a² = ${roundN(cS)} − ${roundN(aS)} = ${roundN(diff)}`,
          `b = √${roundN(diff)} ${sqrtInt ? '= ' + Math.round(result) : '≈ ' + roundN(result)}`
        ]);
        document.getElementById('resValue').textContent = `b = ${roundN(result)}`;
        document.getElementById('resExact').textContent = `Exact: √(${roundN(cS)} − ${roundN(aS)}) ${exact}`;
        drawTriangle(a, result, c);
      } else {
        box.style.display = 'none';
        drawTriangle(3, 4, 5);
        return;
      }

      document.getElementById('steps').innerHTML = stepsHtml;
      box.style.display = 'block';
    }

    function roundN(n) { return Math.round(n * 10000) / 10000; }

    function buildSteps(arr) {
      return arr.map((s, i) => `<div class="step"><span class="step-num">${i + 1}</span><span class="step-text">${s}</span></div>`).join('');
    }

    function drawTriangle(a, b, c) {
      const wrap = document.getElementById('triangleSvg');
      if (!a && !b && !c) { a = 3; b = 4; c = 5; }
      const maxSide = Math.max(a || 1, b || 1, c || 1);
      const scale = 180 / maxSide;
      const bLen = (b || 4) * scale;
      const aLen = (a || 3) * scale;
      const ox = 60, oy = 260;

      // Triangle points: right angle at bottom-left
      const p1 = [ox, oy]; // right angle
      const p2 = [ox + bLen, oy]; // along base
      const p3 = [ox, oy - aLen]; // up

      // Determine which side is calculated
      let aColor = '#3B82F6', bColor = '#3B82F6', cColor = '#3B82F6';
      if (currentMode === 'hyp') cColor = '#22c55e';
      else if (currentMode === 'a') aColor = '#22c55e';
      else if (currentMode === 'b') bColor = '#22c55e';

      const sq = 14;
      const svg = `<svg viewBox="0 0 380 300" width="380" height="300">
        <!-- Triangle -->
        <polygon points="${p1.join(',')},${p2.join(',')},${p3.join(',')}" fill="rgba(59,130,246,0.06)" stroke="#3B82F6" stroke-width="2"/>
        <!-- Right angle marker -->
        <polyline points="${ox},${oy - sq} ${ox + sq},${oy - sq} ${ox + sq},${oy}" fill="none" stroke="#64748b" stroke-width="1.5"/>
        <!-- Side labels -->
        <text x="${ox - 20}" y="${oy - aLen / 2}" fill="${aColor}" font-size="15" font-family="JetBrains Mono,monospace" font-weight="700" text-anchor="middle">a${a > 0 ? ' = ' + roundN(a) : ''}</text>
        <text x="${ox + bLen / 2}" y="${oy + 22}" fill="${bColor}" font-size="15" font-family="JetBrains Mono,monospace" font-weight="700" text-anchor="middle">b${b > 0 ? ' = ' + roundN(b) : ''}</text>
        <text x="${ox + bLen / 2 + 18}" y="${oy - aLen / 2 - 6}" fill="${cColor}" font-size="15" font-family="JetBrains Mono,monospace" font-weight="700" text-anchor="start">c${c > 0 ? ' = ' + roundN(c) : ''}</text>
        <!-- Angle labels -->
        <text x="${ox + bLen - 8}" y="${oy - 8}" fill="#94a3b8" font-size="11" text-anchor="end">α</text>
        <text x="${ox + 14}" y="${oy - aLen + 16}" fill="#94a3b8" font-size="11">β</text>
        <text x="${ox + 18}" y="${oy - 4}" fill="#64748b" font-size="10">90°</text>
        <!-- Formula -->
        <text x="190" y="290" fill="#64748b" font-size="13" font-family="JetBrains Mono,monospace" text-anchor="middle">a² + b² = c²</text>
      </svg>`;
      wrap.innerHTML = svg;
    }

    // Proof visualizations
    function showProof(type) {
      document.querySelectorAll('.proof-btn').forEach(b => b.classList.toggle('active', b.dataset.proof === type));
      const svg = document.getElementById('proofSvg');
      const cap = document.getElementById('proofCaption');

      if (type === 'squares') {
        // Classic squares on each side of a 3-4-5 triangle
        const s = 40; // scale
        svg.innerHTML = `
          <!-- Triangle -->
          <polygon points="100,250 220,250 100,130" fill="rgba(59,130,246,0.08)" stroke="#3B82F6" stroke-width="2"/>
          <polyline points="100,236 114,236 114,250" fill="none" stroke="#64748b" stroke-width="1"/>
          <!-- Square on a (3): left side going left -->
          <rect x="${100 - 3*s}" y="${250 - 3*s}" width="${3*s}" height="${3*s}" fill="rgba(59,130,246,0.15)" stroke="#3B82F6" stroke-width="1.5"/>
          <text x="${100 - 1.5*s}" y="${250 - 1.5*s + 5}" fill="#3B82F6" font-size="16" font-weight="700" text-anchor="middle" font-family="JetBrains Mono,monospace">a² = 9</text>
          <!-- Square on b (4): bottom going down -->
          <rect x="100" y="250" width="${4*s}" height="${4*s}" fill="rgba(239,68,68,0.15)" stroke="#ef4444" stroke-width="1.5" transform="rotate(0)"/>
          <text x="${100 + 2*s}" y="${250 + 2*s + 5}" fill="#ef4444" font-size="16" font-weight="700" text-anchor="middle" font-family="JetBrains Mono,monospace">b² = 16</text>
          <!-- Square on c (5): along hypotenuse -->
          <rect x="260" y="60" width="${5*s}" height="${5*s}" fill="rgba(34,197,94,0.12)" stroke="#22c55e" stroke-width="1.5" transform="rotate(${Math.atan2(120, 120) * 180 / Math.PI}, 260, 60)" opacity="0.6"/>
          <text x="350" y="160" fill="#22c55e" font-size="16" font-weight="700" text-anchor="middle" font-family="JetBrains Mono,monospace">c² = 25</text>
          <!-- Labels -->
          <text x="85" y="195" fill="#c8d6e5" font-size="13" text-anchor="end" font-family="JetBrains Mono,monospace">a=3</text>
          <text x="160" y="268" fill="#c8d6e5" font-size="13" text-anchor="middle" font-family="JetBrains Mono,monospace">b=4</text>
          <text x="170" y="180" fill="#c8d6e5" font-size="13" text-anchor="start" font-family="JetBrains Mono,monospace">c=5</text>
          <!-- Equation -->
          <text x="250" y="380" fill="#94a3b8" font-size="15" text-anchor="middle" font-family="JetBrains Mono,monospace">9 + 16 = 25 ✓</text>
        `;
        cap.textContent = 'The square on the hypotenuse (green, area 25) equals the sum of the squares on the two legs (blue area 9 + red area 16 = 25).';
      } else {
        // Rearrangement proof
        svg.innerHTML = `
          <!-- Large square (a+b)² = 7×7 -->
          <rect x="50" y="30" width="280" height="280" fill="none" stroke="#64748b" stroke-width="1.5"/>
          <!-- Four triangles -->
          <polygon points="50,30 170,30 50,150" fill="rgba(59,130,246,0.2)" stroke="#3B82F6" stroke-width="1.5"/>
          <polygon points="170,30 330,30 330,150" fill="rgba(59,130,246,0.2)" stroke="#3B82F6" stroke-width="1.5"/>
          <polygon points="330,150 330,310 210,310" fill="rgba(59,130,246,0.2)" stroke="#3B82F6" stroke-width="1.5"/>
          <polygon points="50,150 50,310 210,310" fill="rgba(59,130,246,0.2)" stroke="#3B82F6" stroke-width="1.5"/>
          <!-- Inner square c² -->
          <polygon points="170,30 330,150 210,310 50,150" fill="rgba(34,197,94,0.15)" stroke="#22c55e" stroke-width="2"/>
          <text x="190" y="175" fill="#22c55e" font-size="18" font-weight="700" text-anchor="middle" font-family="JetBrains Mono,monospace">c²</text>
          <!-- Triangle labels -->
          <text x="95" y="80" fill="#3B82F6" font-size="12" font-family="JetBrains Mono,monospace">½ab</text>
          <text x="265" y="80" fill="#3B82F6" font-size="12" font-family="JetBrains Mono,monospace">½ab</text>
          <text x="280" y="255" fill="#3B82F6" font-size="12" font-family="JetBrains Mono,monospace">½ab</text>
          <text x="95" y="255" fill="#3B82F6" font-size="12" font-family="JetBrains Mono,monospace">½ab</text>
          <!-- Side labels -->
          <text x="110" y="22" fill="#94a3b8" font-size="12" font-family="JetBrains Mono,monospace">a</text>
          <text x="250" y="22" fill="#94a3b8" font-size="12" font-family="JetBrains Mono,monospace">b</text>
          <!-- Equation -->
          <text x="190" y="345" fill="#94a3b8" font-size="13" text-anchor="middle" font-family="JetBrains Mono,monospace">(a+b)² = c² + 4·(½ab)</text>
          <text x="190" y="370" fill="#94a3b8" font-size="13" text-anchor="middle" font-family="JetBrains Mono,monospace">a² + 2ab + b² = c² + 2ab</text>
          <text x="190" y="395" fill="#e2e8f0" font-size="15" font-weight="700" text-anchor="middle" font-family="JetBrains Mono,monospace">∴ a² + b² = c²</text>
        `;
        cap.textContent = 'Four identical right triangles arranged inside a square of side (a+b). The inner tilted square has area c². Since the big square = c² + 4 triangles, and also = (a+b)², we get a² + b² = c².';
      }
    }

    function toggleFaq(el) {
      el.parentElement.classList.toggle('open');
    }

    // Initialize
    setMode('hyp');
    showProof('squares');
    drawTriangle(3, 4, 5);
  </script>

