  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Elements
      const sideA = document.getElementById('sideA');
      const sideB = document.getElementById('sideB');
      const sideC = document.getElementById('sideC');
      const calcBtn = document.getElementById('calcBtn');
      const clearBtn = document.getElementById('clearBtn');
      const errorMsg = document.getElementById('errorMsg');
      const resultBox = document.getElementById('resultBox');
      const stepsBox = document.getElementById('stepsBox');
      const solutionSteps = document.getElementById('solutionSteps');

      const convA = document.getElementById('convA');
      const convB = document.getElementById('convB');
      const convC = document.getElementById('convC');
      const checkConvBtn = document.getElementById('checkConvBtn');
      const convResult = document.getElementById('convResult');

      const showMoreBtn = document.getElementById('showMoreTriples');

      // Visual elements
      const trianglePoly = document.getElementById('trianglePoly');
      const labelA = document.getElementById('labelA');
      const labelB = document.getElementById('labelB');
      const labelC = document.getElementById('labelC');
      const rightAngleSquare = document.getElementById('rightAngleSquare');

      // Update diagram based on proportions
      function updateVisual(a, b) {
        // Base SVG is 200x200, workable area 20 to 180 (160x160)
        // Let's normalize so the larger side is 140 pixels.
        if(!a || !b) return;

        const maxSide = Math.max(a, b);
        const scale = 140 / maxSide;

        const width = a * scale;
        const height = b * scale;

        // Origin at bottom left (20, 180)
        const x1 = 20;
        const y1 = 180;

        const x2 = 20 + width;
        const y2 = 180;

        const x3 = 20;
        const y3 = 180 - height;

        // Update polygon points
        trianglePoly.setAttribute('points', `${x3},${y3} ${x1},${y1} ${x2},${y2}`);

        // Update labels
        labelA.setAttribute('x', 20 + width / 2);
        labelA.setAttribute('y', 195);

        labelB.setAttribute('x', 5);
        labelB.setAttribute('y', 180 - height / 2);

        labelC.setAttribute('x', 20 + width / 2 + 10);
        labelC.setAttribute('y', 180 - height / 2 - 10);
      }

      function showError(msg) {
        errorMsg.textContent = msg;
        errorMsg.style.display = 'block';
        resultBox.innerHTML = '<p class="placeholder-text">Please fix errors to calculate.</p>';
        stepsBox.style.display = 'none';
      }

      function hideError() {
        errorMsg.style.display = 'none';
      }

      function formatNum(num) {
        return Number.isInteger(num) ? num.toString() : num.toFixed(4);
      }

      function calculate() {
        hideError();

        const aVal = sideA.value.trim();
        const bVal = sideB.value.trim();
        const cVal = sideC.value.trim();

        let a = aVal ? parseFloat(aVal) : null;
        let b = bVal ? parseFloat(bVal) : null;
        let c = cVal ? parseFloat(cVal) : null;

        let filledCount = [a, b, c].filter(val => val !== null).length;

        if (filledCount < 2) {
          showError("Please enter exactly two values.");
          return;
        }

        if (filledCount === 3) {
          showError("Please leave one field blank to calculate.");
          return;
        }

        if ((a !== null && a <= 0) || (b !== null && b <= 0) || (c !== null && c <= 0)) {
          showError("Sides must be greater than zero.");
          return;
        }

        if (c !== null && a !== null && c <= a) {
          showError("Hypotenuse (c) must be strictly greater than leg (a).");
          return;
        }

        if (c !== null && b !== null && c <= b) {
          showError("Hypotenuse (c) must be strictly greater than leg (b).");
          return;
        }

        let resultHTML = '';
        let stepsHTML = '';

        // Find C
        if (a !== null && b !== null && c === null) {
          const cSquared = (a * a) + (b * b);
          c = Math.sqrt(cSquared);

          resultHTML = `
            <h3>Hypotenuse (c)</h3>
            <div class="result-value">${formatNum(c)}</div>
          `;

          stepsHTML = `
            <div class="step-line">Formula: a² + b² = c²</div>
            <div class="step-line">${a}² + ${b}² = c²</div>
            <div class="step-line">${formatNum(a*a)} + ${formatNum(b*b)} = c²</div>
            <div class="step-line">${formatNum(cSquared)} = c²</div>
            <div class="step-line">c = √${formatNum(cSquared)}</div>
            <div class="step-line">c = ${formatNum(c)}</div>
          `;

          sideC.value = formatNum(c);
        }
        // Find A
        else if (b !== null && c !== null && a === null) {
          const aSquared = (c * c) - (b * b);
          a = Math.sqrt(aSquared);

          resultHTML = `
            <h3>Leg (a)</h3>
            <div class="result-value">${formatNum(a)}</div>
          `;

          stepsHTML = `
            <div class="step-line">Formula: a² + b² = c²</div>
            <div class="step-line">a² + ${b}² = ${c}²</div>
            <div class="step-line">a² + ${formatNum(b*b)} = ${formatNum(c*c)}</div>
            <div class="step-line">a² = ${formatNum(c*c)} - ${formatNum(b*b)}</div>
            <div class="step-line">a² = ${formatNum(aSquared)}</div>
            <div class="step-line">a = √${formatNum(aSquared)}</div>
            <div class="step-line">a = ${formatNum(a)}</div>
          `;

          sideA.value = formatNum(a);
        }
        // Find B
        else if (a !== null && c !== null && b === null) {
          const bSquared = (c * c) - (a * a);
          b = Math.sqrt(bSquared);

          resultHTML = `
            <h3>Leg (b)</h3>
            <div class="result-value">${formatNum(b)}</div>
          `;

          stepsHTML = `
            <div class="step-line">Formula: a² + b² = c²</div>
            <div class="step-line">${a}² + b² = ${c}²</div>
            <div class="step-line">${formatNum(a*a)} + b² = ${formatNum(c*c)}</div>
            <div class="step-line">b² = ${formatNum(c*c)} - ${formatNum(a*a)}</div>
            <div class="step-line">b² = ${formatNum(bSquared)}</div>
            <div class="step-line">b = √${formatNum(bSquared)}</div>
            <div class="step-line">b = ${formatNum(b)}</div>
          `;

          sideB.value = formatNum(b);
        }

        resultBox.innerHTML = resultHTML;
        solutionSteps.innerHTML = stepsHTML;
        stepsBox.style.display = 'block';

        updateVisual(a, b);
      }

      function checkConverse() {
        const v1 = parseFloat(convA.value);
        const v2 = parseFloat(convB.value);
        const hyp = parseFloat(convC.value);

        if(isNaN(v1) || isNaN(v2) || isNaN(hyp)) {
          convResult.innerHTML = '<p class="error-msg" style="display:block">Please enter all three sides.</p>';
          return;
        }

        if (v1 <= 0 || v2 <= 0 || hyp <= 0) {
          convResult.innerHTML = '<p class="error-msg" style="display:block">Sides must be positive numbers.</p>';
          return;
        }

        const maxSide = Math.max(v1, v2, hyp);
        if (maxSide !== hyp) {
          convResult.innerHTML = '<p class="error-msg" style="display:block">The "Longest Side" field must contain the largest number.</p>';
          return;
        }

        const sumSquares = (v1 * v1) + (v2 * v2);
        const hypSquare = hyp * hyp;

        // Account for floating point precision issues
        const isRight = Math.abs(sumSquares - hypSquare) < 0.0001;

        if (isRight) {
          convResult.innerHTML = `
            <h3 style="color: #10b981; margin-bottom: 0.5rem;">Yes, it's a Right Triangle! ✅</h3>
            <p>${v1}² + ${v2}² = ${hyp}²</p>
            <p>${formatNum(v1*v1)} + ${formatNum(v2*v2)} = ${formatNum(hypSquare)}</p>
          `;
        } else {
          convResult.innerHTML = `
            <h3 style="color: #ef4444; margin-bottom: 0.5rem;">No, not a Right Triangle ❌</h3>
            <p>${v1}² + ${v2}² ≠ ${hyp}²</p>
            <p>${formatNum(sumSquares)} ≠ ${formatNum(hypSquare)}</p>
          `;
        }
      }

      calcBtn.addEventListener('click', calculate);
      checkConvBtn.addEventListener('click', checkConverse);

      clearBtn.addEventListener('click', () => {
        sideA.value = '';
        sideB.value = '';
        sideC.value = '';
        hideError();
        resultBox.innerHTML = '<p class="placeholder-text">Enter two sides to see the result.</p>';
        stepsBox.style.display = 'none';

        // Reset visual
        trianglePoly.setAttribute('points', '20,180 180,180 20,20');
        labelA.setAttribute('x', '100');
        labelA.setAttribute('y', '195');
        labelB.setAttribute('x', '5');
        labelB.setAttribute('y', '100');
        labelC.setAttribute('x', '110');
        labelC.setAttribute('y', '90');
      });

      // Auto-calculate on enter key
      [sideA, sideB, sideC].forEach(input => {
        input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') calculate();
        });
      });

      [convA, convB, convC].forEach(input => {
        input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') checkConverse();
        });
      });

      if(showMoreBtn) {
        showMoreBtn.addEventListener('click', () => {
          const rows = document.querySelectorAll('.extended-row');
          rows.forEach(row => {
            row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
          });
          showMoreBtn.textContent = showMoreBtn.textContent === 'Show More Triples' ? 'Show Less' : 'Show More Triples';
        });
      }
    });
  </script>
</SiteLayout>
