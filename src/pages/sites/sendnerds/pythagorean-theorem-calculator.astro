---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Pythagorean Theorem Calculator | Sendnerds',
  description: 'Calculate the hypotenuse or missing side of any right triangle instantly. Step-by-step solutions, interactive diagrams, and Pythagorean triples.',
  category: 'tool',
  keywords: ['pythagorean theorem calculator', 'right triangle calculator', 'hypotenuse calculator', 'pythagorean theorem solver', 'find missing side of triangle', 'pythagorean triples']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "sendnerds.photonbuilder.com" },
    "publisher": { "@type": "Organization", "name": "sendnerds.photonbuilder.com" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you calculate the Pythagorean theorem?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Pythagorean theorem is calculated using the formula a² + b² = c², where 'c' is the hypotenuse and 'a' and 'b' are the other two legs of the right triangle. To find the hypotenuse, square the other two sides, add them together, and take the square root."
        }
      },
      {
        "@type": "Question",
        "name": "What is the formula to find the missing side of a right triangle?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you are missing a leg (a or b), the formula is rearranged to a = √(c² - b²) or b = √(c² - a²). If you are missing the hypotenuse (c), the formula is c = √(a² + b²)."
        }
      },
      {
        "@type": "Question",
        "name": "What are the most common Pythagorean triples?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most common Pythagorean triples are (3, 4, 5), (5, 12, 13), (8, 15, 17), and (7, 24, 25). Multiples of these triples, such as (6, 8, 10), also form right triangles."
        }
      },
      {
        "@type": "Question",
        "name": "Does the Pythagorean theorem work for all triangles?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, the Pythagorean theorem strictly applies only to right-angled triangles (triangles that have one 90-degree angle). For non-right triangles, you must use the Law of Cosines."
        }
      },
      {
        "@type": "Question",
        "name": "How do you determine if a triangle is a right triangle?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can use the converse of the Pythagorean theorem. If the square of the longest side equals the sum of the squares of the other two sides (a² + b² = c²), then the triangle is a right triangle."
        }
      }
    ]
  }
]);
---
<SiteLayout site="sendnerds" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <main class="calculator-page">
    <header class="hero">
      <h1>Pythagorean Theorem Calculator</h1>
      <p class="subtitle">Instantly find the hypotenuse or missing leg of any right triangle. View step-by-step solutions and interactive visual diagrams.</p>
    </header>

    <div class="calc-container">
      <div class="calc-panel">
        <h2>Calculate Missing Side</h2>
        <p class="instruction">Enter any two sides to find the third. Leave the unknown side blank.</p>

        <div class="input-group">
          <label for="sideA">Side a (Leg):</label>
          <input type="number" id="sideA" placeholder="e.g., 3" step="any" min="0">
        </div>

        <div class="input-group">
          <label for="sideB">Side b (Leg):</label>
          <input type="number" id="sideB" placeholder="e.g., 4" step="any" min="0">
        </div>

        <div class="input-group">
          <label for="sideC">Side c (Hypotenuse):</label>
          <input type="number" id="sideC" placeholder="e.g., 5" step="any" min="0">
        </div>

        <div class="actions">
          <button id="calcBtn" class="primary-btn">Calculate</button>
          <button id="clearBtn" class="secondary-btn">Clear</button>
        </div>

        <div id="errorMsg" class="error-msg" style="display: none;"></div>
      </div>

      <div class="result-panel">
        <h2>Result & Visual</h2>

        <div class="visual-wrapper">
          <svg id="triangleVisual" viewBox="0 0 200 200" width="100%" height="250" xmlns="http://www.w3.org/2000/svg">
            <!-- Default right triangle -->
            <polygon id="trianglePoly" points="20,180 180,180 20,20" fill="color-mix(in srgb, var(--accent-color) 20%, transparent)" stroke="var(--accent-color)" stroke-width="3" stroke-linejoin="round"/>
            <rect id="rightAngleSquare" x="20" y="160" width="20" height="20" fill="transparent" stroke="var(--text-secondary)" stroke-width="2"/>
            <text id="labelA" x="100" y="195" text-anchor="middle" fill="var(--text-primary)" font-weight="bold">a</text>
            <text id="labelB" x="5" y="100" text-anchor="middle" fill="var(--text-primary)" font-weight="bold">b</text>
            <text id="labelC" x="110" y="90" text-anchor="middle" fill="var(--accent-color)" font-weight="bold">c</text>
          </svg>
        </div>

        <div id="resultBox" class="result-box">
          <p class="placeholder-text">Enter two sides to see the result.</p>
        </div>

        <div id="stepsBox" class="steps-box" style="display: none;">
          <h3>Step-by-Step Solution</h3>
          <div id="solutionSteps"></div>
        </div>
      </div>
    </div>

    <div class="calc-container converse-container" style="margin-top: 3rem;">
      <div class="calc-panel">
        <h2>Converse Theorem Checker</h2>
        <p class="instruction">Enter all three sides to check if they form a right triangle.</p>

        <div class="input-grid">
          <div class="input-group">
            <label for="convA">Side 1:</label>
            <input type="number" id="convA" placeholder="Side" step="any" min="0">
          </div>
          <div class="input-group">
            <label for="convB">Side 2:</label>
            <input type="number" id="convB" placeholder="Side" step="any" min="0">
          </div>
          <div class="input-group">
            <label for="convC">Longest Side:</label>
            <input type="number" id="convC" placeholder="Longest" step="any" min="0">
          </div>
        </div>

        <button id="checkConvBtn" class="primary-btn full-width">Check Triangle</button>
      </div>
      <div class="result-panel">
        <div id="convResult" class="conv-result-box">
          <p class="placeholder-text">Enter three sides to verify.</p>
        </div>
      </div>
    </div>

    <section class="educational-content">
      <h2>Understanding the Pythagorean Theorem</h2>
      <div class="content-cards">
        <div class="card">
          <h3>The Formula</h3>
          <p>The Pythagorean theorem is mathematically expressed as <strong>a² + b² = c²</strong>.</p>
          <ul>
            <li><strong>a</strong> and <strong>b</strong> represent the two legs of the right triangle.</li>
            <li><strong>c</strong> represents the hypotenuse, which is always the longest side and opposite the right angle.</li>
          </ul>
        </div>
        <div class="card">
          <h3>When to Use It</h3>
          <p>You can use this theorem whenever you have a right-angled triangle (one angle exactly 90 degrees) and you know the lengths of exactly two of its sides. It is heavily used in architecture, navigation, and computer graphics.</p>
        </div>
        <div class="card">
          <h3>Finding a Leg vs Hypotenuse</h3>
          <p>If finding the hypotenuse, you add the squared legs: <code>c = √(a² + b²)</code>. If finding a missing leg, you subtract the known leg's square from the hypotenuse's square: <code>a = √(c² - b²)</code>.</p>
        </div>
      </div>
    </section>

    <section class="triples-section">
      <h2>Common Pythagorean Triples</h2>
      <p>A Pythagorean triple consists of three positive integers a, b, and c, such that a² + b² = c². Memorizing common triples can save you from calculating.</p>

