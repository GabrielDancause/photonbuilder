---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "2x2 Matrix Eigenvalue Calculator",
  description: "Struggling with linear algebra homework? Calculate the eigenvalues, trace, and determinant of any 2x2 matrix instantly with step-by-step formulas.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "url": "https://photonbuilder.com/sendnerds/eigenvalue-calculator",
      "author": { "@type": "Organization", "name": "Siliconbased.dev" },
      "publisher": { "@type": "Organization", "name": "Siliconbased.dev" },
      "datePublished": meta.published
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an eigenvalue?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An eigenvalue is a scalar that indicates how much an eigenvector is stretched or shrunk during a linear transformation. If a matrix represents a transformation, the eigenvectors are the directions that remain unchanged, and the eigenvalues are the scale factors in those directions."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate the eigenvalues of a 2x2 matrix?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To find the eigenvalues of a 2x2 matrix, you set up the characteristic equation: det(A - &lambda;I) = 0. This expands into the quadratic equation &lambda;&sup2; - Tr(A)&lambda; + det(A) = 0, where Tr(A) is the trace and det(A) is the determinant. You then solve for &lambda; using the quadratic formula."
          }
        },
        {
          "@type": "Question",
          "name": "What is the trace of a matrix?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The trace of a square matrix is the sum of the elements on its main diagonal (from top-left to bottom-right). For a 2x2 matrix [[a, b], [c, d]], the trace is simply a + d. Interestingly, the sum of a matrix's eigenvalues always equals its trace."
          }
        },
        {
          "@type": "Question",
          "name": "Can eigenvalues be complex numbers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. If the discriminant in the characteristic quadratic equation (Trace&sup2; - 4 &times; Determinant) is negative, the matrix will have complex (or imaginary) eigenvalues. This often geometrically corresponds to a rotation transformation rather than a simple scaling."
          }
        },
        {
          "@type": "Question",
          "name": "What does a zero eigenvalue mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If a matrix has an eigenvalue of zero, it means the matrix is singular (non-invertible) and its determinant is zero. Geometrically, it implies that the linear transformation squashes at least one dimension of space down to the origin."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout site="sendnerds" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/sendnerds/eigenvalue-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Eigenvalue Calculator</h1>
      <p class="subtitle">Instantly calculate the eigenvalues, trace, and determinant of a 2x2 matrix.</p>
    </div>

    <div class="calculator-container">
      <div class="matrix-input-container">
        <p style="text-align: center; font-weight: 600; margin-bottom: 1rem;">Enter Matrix A</p>
        <div class="matrix-grid">
          <div class="matrix-bracket left"></div>
          <div class="matrix-cells">
            <input type="number" id="mat-a" placeholder="a" value="1" step="any">
            <input type="number" id="mat-b" placeholder="b" value="2" step="any">
            <input type="number" id="mat-c" placeholder="c" value="3" step="any">
            <input type="number" id="mat-d" placeholder="d" value="4" step="any">
          </div>
          <div class="matrix-bracket right"></div>
        </div>
        <p id="matrix-error" style="display: none; color: #ef4444; text-align: center; font-size: 0.85rem; margin-top: 1rem;">Please enter valid numbers in all fields.</p>
      </div>

      <div class="results-grid">
        <div class="stat-card">
          <div class="calc-result-label">Trace (Tr)</div>
          <div class="stat-value" id="trace-result">5</div>
          <div class="stat-formula">a + d</div>
        </div>
        <div class="stat-card">
          <div class="calc-result-label">Determinant (Det)</div>
          <div class="stat-value" id="det-result">-2</div>
          <div class="stat-formula">ad - bc</div>
        </div>
      </div>

      <div class="result-card">
        <div class="calc-result-label">Eigenvalues (&lambda;)</div>
        <div class="result-value" id="eigen-result">&lambda;&#8321; = 5.372, &lambda;&#8322; = -0.372</div>
        <div class="characteristic-eq" id="char-eq">&lambda;&sup2; - 5&lambda; - 2 = 0</div>
      </div>
    </div>

    <div class="explainer">
      <h2>How to Calculate Eigenvalues</h2>
      <p>Linear algebra forms the foundation of modern computer science, physics, and machine learning. One of the most critical concepts in linear algebra is the <strong>eigenvalue</strong>. Geometrically, when a linear transformation (represented by a matrix) is applied to a vector, most vectors change direction. However, certain special vectors—known as eigenvectors—only change in scale, not direction. The scaling factor is the eigenvalue.</p>
      <p>This calculator specifically solves for the eigenvalues of a 2x2 matrix. For a 2x2 matrix, the calculation boils down to finding the roots of a characteristic quadratic equation.</p>

      <h3>The Characteristic Equation</h3>
      <p>To find the eigenvalues (denoted by the Greek letter Lambda, &lambda;) of a square matrix <code>A</code>, you must solve the characteristic equation:</p>
      <div class="highlight-box" style="text-align: center; font-size: 1.2rem; font-family: var(--font-mono);">
        det(A - &lambda;I) = 0
      </div>
      <p>Where <code>I</code> is the identity matrix. For a standard 2x2 matrix composed of variables <code>a, b, c, d</code>, this expands into the following quadratic equation:</p>
      <div class="highlight-box" style="text-align: center; font-size: 1.2rem; font-family: var(--font-mono);">
        &lambda;&sup2; - (a + d)&lambda; + (ad - bc) = 0
      </div>

      <h3>Step-by-Step Methodology</h3>
      <p>Our calculator follows a specific three-step methodology to instantly evaluate your inputs:</p>

      <h4>1. Calculate the Trace</h4>
      <p>The trace of a matrix is simply the sum of the elements on its main diagonal. In our 2x2 matrix, the trace is <code>a + d</code>. A fascinating property of matrices is that the sum of the eigenvalues will always exactly equal the trace of the matrix.</p>

      <h4>2. Calculate the Determinant</h4>
      <p>The determinant of a 2x2 matrix is calculated using the formula <code>(a &times; d) - (b &times; c)</code>. Geometrically, the determinant represents the scaling factor of the area (in 2D space) during the linear transformation. Just as the sum of eigenvalues equals the trace, the product of the eigenvalues will always exactly equal the determinant.</p>

      <h4>3. Solve the Quadratic Formula</h4>
      <p>By substituting the Trace and Determinant back into the characteristic equation, we get:</p>
      <div class="highlight-box" style="text-align: center; font-size: 1.2rem; font-family: var(--font-mono);">
        &lambda;&sup2; - Tr(A)&lambda; + Det(A) = 0
      </div>
      <p>To solve for &lambda;, we apply the standard quadratic formula:</p>
      <div class="highlight-box" style="text-align: center; font-size: 1.2rem; font-family: var(--font-mono);">
        &lambda; = [Tr(A) &plusmn; &radic;(Tr(A)&sup2; - 4&times;Det(A))] / 2
      </div>

      <h3>Real vs. Complex Eigenvalues</h3>
      <p>The term inside the square root—<code>Tr(A)&sup2; - 4&times;Det(A)</code>—is known as the discriminant. Depending on the value of the discriminant, a 2x2 matrix will have different types of eigenvalues:</p>
      <ul>
        <li><strong>Discriminant > 0:</strong> Two distinct real eigenvalues. The matrix stretches or squashes space in two distinct directions.</li>
        <li><strong>Discriminant = 0:</strong> One repeated real eigenvalue.</li>
        <li><strong>Discriminant &lt; 0:</strong> Two complex (imaginary) conjugate eigenvalues. Geometrically, this indicates that the linear transformation includes a rotation, meaning no real vectors maintain their original direction.</li>
      </ul>

    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is an eigenvalue?</summary>
        <p>An eigenvalue is a scalar that indicates how much an eigenvector is stretched or shrunk during a linear transformation. If a matrix represents a transformation, the eigenvectors are the directions that remain unchanged, and the eigenvalues are the scale factors in those directions.</p>
      </details>
      <details>
        <summary>How do you calculate the eigenvalues of a 2x2 matrix?</summary>
        <p>To find the eigenvalues of a 2x2 matrix, you set up the characteristic equation: det(A - &lambda;I) = 0. This expands into the quadratic equation &lambda;&sup2; - Tr(A)&lambda; + det(A) = 0, where Tr(A) is the trace and det(A) is the determinant. You then solve for &lambda; using the quadratic formula.</p>
      </details>
      <details>
        <summary>What is the trace of a matrix?</summary>
        <p>The trace of a square matrix is the sum of the elements on its main diagonal (from top-left to bottom-right). For a 2x2 matrix [[a, b], [c, d]], the trace is simply a + d. Interestingly, the sum of a matrix's eigenvalues always equals its trace.</p>
      </details>
      <details>
        <summary>Can eigenvalues be complex numbers?</summary>
        <p>Yes. If the discriminant in the characteristic quadratic equation (Trace&sup2; - 4 &times; Determinant) is negative, the matrix will have complex (or imaginary) eigenvalues. This often geometrically corresponds to a rotation transformation rather than a simple scaling.</p>
      </details>
      <details>
        <summary>What does a zero eigenvalue mean?</summary>
        <p>If a matrix has an eigenvalue of zero, it means the matrix is singular (non-invertible) and its determinant is zero. Geometrically, it implies that the linear transformation squashes at least one dimension of space down to the origin.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputA = document.getElementById('mat-a');
      const inputB = document.getElementById('mat-b');
      const inputC = document.getElementById('mat-c');
      const inputD = document.getElementById('mat-d');
      const inputs = [inputA, inputB, inputC, inputD];

      const matrixError = document.getElementById('matrix-error');
      const traceResult = document.getElementById('trace-result');
      const detResult = document.getElementById('det-result');
      const eigenResult = document.getElementById('eigen-result');
      const charEq = document.getElementById('char-eq');

      function formatNumber(num) {
        if (Number.isInteger(num)) return num.toString();
        return num.toFixed(3).replace(/\.?0+$/, '');
      }

      function calculateEigenvalues() {
        const a = parseFloat(inputA.value);
        const b = parseFloat(inputB.value);
        const c = parseFloat(inputC.value);
        const d = parseFloat(inputD.value);

        if (isNaN(a) || isNaN(b) || isNaN(c) || isNaN(d)) {
          matrixError.style.display = 'block';
          traceResult.textContent = '-';
          detResult.textContent = '-';
          eigenResult.innerHTML = '&lambda; = ?';
          charEq.innerHTML = '&lambda;&sup2; - ?&lambda; + ? = 0';
          return;
        }

        matrixError.style.display = 'none';

        const trace = a + d;
        const det = (a * d) - (b * c);

        traceResult.textContent = formatNumber(trace);
        detResult.textContent = formatNumber(det);

        // Characteristic Equation: lambda^2 - (a+d)lambda + (ad-bc) = 0
        const signTrace = trace >= 0 ? '-' : '+';
        const signDet = det >= 0 ? '+' : '-';
        const absTrace = Math.abs(trace);
        const absDet = Math.abs(det);

        let eqString = '&lambda;&sup2;';
        if (absTrace !== 0) eqString += ` ${signTrace} ${formatNumber(absTrace)}&lambda;`;
        if (absDet !== 0) eqString += ` ${signDet} ${formatNumber(absDet)}`;
        eqString += ' = 0';
        charEq.innerHTML = eqString;

        // Solve using quadratic formula: x = [ -b +/- sqrt(b^2 - 4ac) ] / 2a
        // Here, a = 1, b = -trace, c = det
        const discriminant = (trace * trace) - (4 * det);

        if (discriminant > 0) {
          // Two real eigenvalues
          const l1 = (trace + Math.sqrt(discriminant)) / 2;
          const l2 = (trace - Math.sqrt(discriminant)) / 2;
          eigenResult.innerHTML = `&lambda;&#8321; = ${formatNumber(l1)}, &lambda;&#8322; = ${formatNumber(l2)}`;
        } else if (discriminant === 0) {
          // One repeated real eigenvalue
          const l = trace / 2;
          eigenResult.innerHTML = `&lambda; = ${formatNumber(l)}`;
        } else {
          // Complex eigenvalues
          const realPart = trace / 2;
          const imagPart = Math.sqrt(Math.abs(discriminant)) / 2;

          let realStr = realPart === 0 ? '' : formatNumber(realPart);
          let imagStr = formatNumber(imagPart) + 'i';

          if (realPart === 0) {
             eigenResult.innerHTML = `&lambda;&#8321; = ${imagStr}, &lambda;&#8322; = -${imagStr}`;
          } else {
             eigenResult.innerHTML = `&lambda;&#8321; = ${realStr} + ${imagStr}, &lambda;&#8322; = ${realStr} - ${imagStr}`;
          }
        }
      }

      inputs.forEach(input => {
        input.addEventListener('input', calculateEigenvalues);
      });

      // Initial calculation
      calculateEigenvalues();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .matrix-input-container { margin-bottom: 2rem; }
    .matrix-grid { display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
    .matrix-cells { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; width: 240px; }
    .matrix-bracket { width: 15px; height: 120px; border: 2px solid var(--text-primary); }
    .matrix-bracket.left { border-right: none; }
    .matrix-bracket.right { border-left: none; }

    input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem; border-radius: 8px; width: 100%; font-size: 1.1rem; font-family: var(--font-mono); text-align: center; }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .results-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
    .stat-card { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem; text-align: center; }
    .stat-value { font-size: 1.75rem; font-weight: 700; color: var(--text-primary); font-family: var(--font-mono); margin: 0.25rem 0; }
    .stat-formula { font-size: 0.85rem; color: var(--text-secondary); font-family: var(--font-mono); }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; text-align: center; }
    .result-value { font-size: 2rem; font-weight: 800; color: var(--accent-color); font-family: var(--font-mono); margin: 0.5rem 0; }
    .characteristic-eq { font-size: 1rem; color: var(--text-secondary); font-family: var(--font-mono); }

    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }

    @media (max-width: 600px) {
      .results-grid { grid-template-columns: 1fr; }
      .result-value { font-size: 1.5rem; }
    }
  </style>
</SiteLayout>
