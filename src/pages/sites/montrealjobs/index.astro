---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const title = 'Montreal Jobs — Graphic Design + AI Jobs Research (South Shore)';
const description = 'Comprehensive research on graphic design and AI-enhanced design jobs in Montreal and South Shore region. Real job listings, salary data, and market analysis for March 2026.';
const canonical = 'https://montrealjobs.photonbuilder.com/';
---

<SiteLayout 
