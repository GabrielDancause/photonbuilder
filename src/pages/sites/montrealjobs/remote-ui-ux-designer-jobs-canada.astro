export const meta = {
  title: "Remote UI/UX Designer Jobs in Canada — March 2026",
  description: "Curated list of remote UI/UX and Product Designer jobs hiring in Canada. Updated March 2026 with salaries, companies, and direct links.",
  category: "guide",
  published: "2026-03-15",
