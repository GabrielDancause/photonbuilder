---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "TDEE Calculator: Total Daily Energy Expenditure",
  description: "Find out exactly how many calories your body burns every day. The answer might change how you approach your fitness goals forever...",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased",
      "url": "https://photonbuilder.com/health"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is TDEE and why does it matter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "TDEE stands for Total Daily Energy Expenditure. It represents the total number of calories you burn in a given day, taking into account your basal metabolic rate (BMR) and your physical activity level. Knowing your TDEE is crucial because it serves as the baseline for weight management: consuming fewer calories than your TDEE leads to weight loss, while consuming more leads to weight gain."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate are TDEE calculators?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "TDEE calculators provide a highly educated estimate based on population averages using established formulas like Mifflin-St Jeor. While generally accurate within a 10-15% margin for most people, individual variations in muscle mass, genetics, and non-exercise activity thermogenesis (NEAT) mean you should treat the result as a starting point and adjust based on real-world progress."
        }
      },
      {
        "@type": "Question",
        "name": "Should I recalculate my TDEE as I lose weight?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. As you lose body mass, your body requires less energy to maintain itself and move around. It is recommended to recalculate your TDEE for every 5-10 pounds of weight loss to ensure you remain in an appropriate caloric deficit."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between BMR and TDEE?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basal Metabolic Rate (BMR) is the number of calories your body burns at complete rest just to keep your organs functioning. TDEE includes your BMR plus the calories burned through daily movement, digestion, and deliberate exercise."
        }
      },
      {
        "@type": "Question",
        "name": "Does this calculator account for body fat percentage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This specific calculator uses the Mifflin-St Jeor equation, which relies on height, weight, age, and sex. It does not use body fat percentage. If you know your exact body fat percentage, the Katch-McArdle formula may provide a slightly more personalized BMR estimate, especially for very lean or obese individuals."
        }
      }
    ]
  }
];
---

<SiteLayout site="health" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/health/tdee-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Total Daily Energy Expenditure Calculator</h1>
      <p class="subtitle">Calculate your daily calorie burn to optimize your health and fitness goals.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-group">
          <label for="gender">Gender</label>
          <select id="gender">
            <option value="male">Male</option>
            <option value="female">Female</option>
          </select>
        </div>

        <div class="input-group">
          <label for="age">Age (years)</label>
          <input type="number" id="age" min="15" max="120" value="30" placeholder="e.g. 30" />
          <div class="error-msg" id="age-error">Please enter a valid age between 15 and 120.</div>
        </div>

        <div class="input-group">
          <label for="weight">Weight (kg)</label>
          <input type="number" id="weight" min="30" max="300" value="70" placeholder="e.g. 70" />
          <div class="error-msg" id="weight-error">Please enter a valid weight between 30 and 300 kg.</div>
        </div>

        <div class="input-group">
          <label for="height">Height (cm)</label>
          <input type="number" id="height" min="100" max="250" value="170" placeholder="e.g. 170" />
          <div class="error-msg" id="height-error">Please enter a valid height between 100 and 250 cm.</div>
        </div>
      </div>

      <div class="input-group" style="margin-top: 1.5rem;">
        <label for="activity">Activity Level</label>
        <select id="activity">
          <option value="1.2">Sedentary (office job, little to no exercise)</option>
          <option value="1.375">Lightly Active (light exercise 1-3 days/week)</option>
          <option value="1.55">Moderately Active (moderate exercise 3-5 days/week)</option>
          <option value="1.725">Very Active (heavy exercise 6-7 days/week)</option>
          <option value="1.9">Extra Active (very heavy exercise, physical job)</option>
        </select>
      </div>

      <div class="result-card">
        <h3>Your Maintenance Calories (TDEE)</h3>
        <div class="result-value" id="tdee-result">2,000</div>
        <p style="margin-top: 0.5rem; color: var(--text-secondary);">calories per day</p>
      </div>

      <div class="macros-grid" id="macros-container">
        <div class="macro-card">
          <h4>Cutting</h4>
          <p class="macro-desc">20% Deficit</p>
          <div class="macro-value" id="cut-cals">1,600</div>
        </div>
        <div class="macro-card">
          <h4>Bulking</h4>
          <p class="macro-desc">10% Surplus</p>
          <div class="macro-value" id="bulk-cals">2,200</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Your Total Daily Energy Expenditure (TDEE)</h2>
      <p>
        Your Total Daily Energy Expenditure (TDEE) is an estimation of how many calories you burn per day when exercise is taken into account. It is calculated by first figuring out your Basal Metabolic Rate (BMR), then multiplying that value by an activity multiplier. Understanding your TDEE is the cornerstone of any structured approach to weight management, whether your goal is to lose fat, build muscle, or simply maintain your current physique.
      </p>

      <h3>The Science Behind the Calculation</h3>
      <p>
        Our calculator utilizes the <strong>Mifflin-St Jeor Equation</strong>, which is widely considered by nutritionists and dietitians to be the most accurate predictive equation for calculating BMR in healthy individuals. The formula relies on four primary variables: your sex, weight, height, and age.
      </p>
      <p>
        The Basal Metabolic Rate represents the absolute minimum amount of energy your body requires to perform basic life-sustaining functions—like breathing, circulating blood, and maintaining brain function—if you were to stay in bed all day.
      </p>
      <p>The specific formulas are:</p>
      <ul>
        <li><strong>For Men:</strong> BMR = (10 × weight in kg) + (6.25 × height in cm) - (5 × age in years) + 5</li>
        <li><strong>For Women:</strong> BMR = (10 × weight in kg) + (6.25 × height in cm) - (5 × age in years) - 161</li>
      </ul>

      <h3>Activity Multipliers Explained</h3>
      <p>
        Once your BMR is calculated, it must be multiplied by an activity factor (often called the Katch-McArdle multipliers) to account for the energy expended through daily movement, work, and deliberate exercise. The standard multipliers are:
      </p>
      <ul>
        <li><strong>Sedentary (1.2):</strong> Little to no exercise, desk job.</li>
        <li><strong>Lightly Active (1.375):</strong> Light exercise or sports 1-3 days a week.</li>
        <li><strong>Moderately Active (1.55):</strong> Moderate exercise or sports 3-5 days a week.</li>
        <li><strong>Very Active (1.725):</strong> Hard exercise or sports 6-7 days a week.</li>
        <li><strong>Extra Active (1.9):</strong> Very hard exercise, physical job, or training twice a day.</li>
      </ul>

      <h3>How to Apply Your TDEE</h3>
      <p>
        Knowing your TDEE allows you to make informed decisions about your daily caloric intake. If your goal is weight loss (cutting), you should aim to consume fewer calories than your TDEE. A standard, sustainable approach is a 15-20% caloric deficit. This forces your body to tap into stored energy (fat) to make up the difference.
      </p>
      <p>
        Conversely, if your goal is muscle gain (bulking), you need to provide your body with a caloric surplus—typically 10-15% above your TDEE. This extra energy is used to synthesize new muscle tissue when paired with resistance training.
      </p>
      <p>
        It is important to remember that as your weight changes, your TDEE will change as well. A lighter body requires less energy to move and maintain, so you will need to periodically recalculate your numbers to ensure continued progress. We recommend recalculating after every 5 to 10 pounds of weight change.
      </p>

      <h3>Related Tools</h3>
      <p>
        If you are working with complex nutritional tracking or recipe formulation, you might also find our <a href="/fraction-calculator">Fraction Calculator</a> useful for scaling recipes and managing exact macronutrient portions.
      </p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is TDEE and why does it matter?</summary>
        <p>TDEE stands for Total Daily Energy Expenditure. It represents the total number of calories you burn in a given day, taking into account your basal metabolic rate (BMR) and your physical activity level. Knowing your TDEE is crucial because it serves as the baseline for weight management: consuming fewer calories than your TDEE leads to weight loss, while consuming more leads to weight gain.</p>
      </details>
      <details>
        <summary>How accurate are TDEE calculators?</summary>
        <p>TDEE calculators provide a highly educated estimate based on population averages using established formulas like Mifflin-St Jeor. While generally accurate within a 10-15% margin for most people, individual variations in muscle mass, genetics, and non-exercise activity thermogenesis (NEAT) mean you should treat the result as a starting point and adjust based on real-world progress.</p>
      </details>
      <details>
        <summary>Should I recalculate my TDEE as I lose weight?</summary>
        <p>Yes. As you lose body mass, your body requires less energy to maintain itself and move around. It is recommended to recalculate your TDEE for every 5-10 pounds of weight loss to ensure you remain in an appropriate caloric deficit.</p>
      </details>
      <details>
        <summary>What is the difference between BMR and TDEE?</summary>
        <p>Basal Metabolic Rate (BMR) is the number of calories your body burns at complete rest just to keep your organs functioning. TDEE includes your BMR plus the calories burned through daily movement, digestion, and deliberate exercise.</p>
      </details>
      <details>
        <summary>Does this calculator account for body fat percentage?</summary>
        <p>This specific calculator uses the Mifflin-St Jeor equation, which relies on height, weight, age, and sex. It does not use body fat percentage. If you know your exact body fat percentage, the Katch-McArdle formula may provide a slightly more personalized BMR estimate, especially for very lean or obese individuals.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    const ageInput = document.getElementById('age');
    const weightInput = document.getElementById('weight');
    const heightInput = document.getElementById('height');
    const genderSelect = document.getElementById('gender');
    const activitySelect = document.getElementById('activity');

    const tdeeResult = document.getElementById('tdee-result');
    const cutCals = document.getElementById('cut-cals');
    const bulkCals = document.getElementById('bulk-cals');

    const ageError = document.getElementById('age-error');
    const weightError = document.getElementById('weight-error');
    const heightError = document.getElementById('height-error');

    function calculateTDEE() {
      const age = parseFloat(ageInput.value);
      const weight = parseFloat(weightInput.value);
      const height = parseFloat(heightInput.value);
      const gender = genderSelect.value;
      const activity = parseFloat(activitySelect.value);

      let hasError = false;

      if (isNaN(age) || age < 15 || age > 120) {
        ageError.style.display = 'block';
        hasError = true;
      } else {
        ageError.style.display = 'none';
      }

      if (isNaN(weight) || weight < 30 || weight > 300) {
        weightError.style.display = 'block';
        hasError = true;
      } else {
        weightError.style.display = 'none';
      }

      if (isNaN(height) || height < 100 || height > 250) {
        heightError.style.display = 'block';
        hasError = true;
      } else {
        heightError.style.display = 'none';
      }

      if (hasError) {
        tdeeResult.textContent = '--';
        cutCals.textContent = '--';
        bulkCals.textContent = '--';
        return;
      }

      // Mifflin-St Jeor Equation
      let bmr = (10 * weight) + (6.25 * height) - (5 * age);
      if (gender === 'male') {
        bmr += 5;
      } else {
        bmr -= 161;
      }

      const tdee = Math.round(bmr * activity);
      const cut = Math.round(tdee * 0.8); // 20% deficit
      const bulk = Math.round(tdee * 1.1); // 10% surplus

      tdeeResult.textContent = tdee.toLocaleString();
      cutCals.textContent = cut.toLocaleString();
      bulkCals.textContent = bulk.toLocaleString();
    }

    [ageInput, weightInput, heightInput, genderSelect, activitySelect].forEach(input => {
      input.addEventListener('input', calculateTDEE);
    });

    // Initial calculation
    calculateTDEE();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      margin: 2rem 0;
    }

    .calc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
    }

    .input-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    input, select {
      background: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1rem;
      border-radius: 8px;
      width: 100%;
      font-size: 1rem;
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .error-msg {
      color: #ef4444;
      font-size: 0.85rem;
      margin-top: 0.25rem;
      display: none;
    }

    .result-card {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border: 1px solid var(--accent-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin: 2rem 0 1.5rem;
      text-align: center;
    }

    .result-card h3 {
      margin: 0 0 0.5rem 0;
      color: var(--text-primary);
    }

    .result-value {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent-color);
    }

    .macros-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .macro-card {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      text-align: center;
    }

    .macro-card h4 {
      margin: 0 0 0.25rem 0;
      font-size: 1.2rem;
    }

    .macro-desc {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-bottom: 0.75rem;
    }

    .macro-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .explainer {
      margin: 3rem 0;
      line-height: 1.7;
    }

    .explainer h2, .explainer h3 {
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    .explainer p {
      margin-bottom: 1rem;
      color: var(--text-secondary);
    }

    .explainer ul {
      margin-left: 1.5rem;
      margin-bottom: 1.5rem;
      color: var(--text-secondary);
    }

    .explainer li {
      margin-bottom: 0.5rem;
    }

    .explainer a {
      color: var(--accent-color);
      text-decoration: none;
      font-weight: 600;
    }

    .explainer a:hover {
      text-decoration: underline;
    }

    .faq-section {
      margin-top: 3rem;
    }

    .faq-section details {
      margin: 1rem 0;
      padding: 1rem;
      background: var(--card-bg);
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .faq-section summary {
      font-weight: 600;
      cursor: pointer;
      color: var(--text-primary);
    }

    .faq-section details p {
      margin-top: 1rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>
</SiteLayout>
