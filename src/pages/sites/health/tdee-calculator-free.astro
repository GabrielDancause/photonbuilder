---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const title = "Free TDEE Calculator: Total Daily Energy Expenditure";
const description = "Discover exactly how many calories you burn each day. Stop guessing your macros—calculate your highly accurate TDEE based on the Mifflin-St Jeor formula.";
const canonical = "https://photonbuilder.com/health/tdee-calculator-free";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": title,
      "description": description,
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Article",
      "headline": title,
      "description": description,
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      },
      "publisher": {
        "@type": "Organization",
        "name": "SiliconBased",
        "logo": {
          "@type": "ImageObject",
          "url": "https://photonbuilder.com/health/logo.png"
        }
      },
      "datePublished": "2026-03-15",
      "dateModified": "2026-03-15"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is TDEE?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TDEE stands for Total Daily Energy Expenditure. It is the total number of calories your body burns in a 24-hour period, factoring in your basal metabolic rate (BMR), exercise, daily movement (NEAT), and digestion."
          }
        },
        {
          "@type": "Question",
          "name": "How is TDEE calculated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This calculator uses the Mifflin-St Jeor equation to estimate your Basal Metabolic Rate (BMR), which is currently considered the most accurate standard formula. The BMR is then multiplied by an activity multiplier to determine your TDEE."
          }
        },
        {
          "@type": "Question",
          "name": "Should I eat my TDEE to lose weight?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Eating exactly your TDEE will result in weight maintenance. To lose weight, you must eat fewer calories than your TDEE (a caloric deficit). A typical deficit is 300-500 calories below TDEE per day."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between BMR and TDEE?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "BMR (Basal Metabolic Rate) is the calories your body burns simply to stay alive at rest (breathing, organ function). TDEE includes BMR plus all the extra calories you burn through daily movement and exercise."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I recalculate my TDEE?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You should recalculate your TDEE every time you lose or gain 5-10 pounds, or if your daily activity levels change significantly, as these factors directly alter your energy expenditure."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Free TDEE Calculator: Total Daily Energy Expenditure",
  description: "Discover exactly how many calories you burn each day. Stop guessing your macros—calculate your highly accurate TDEE based on the Mifflin-St Jeor formula.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout site="health" title={title} description={description} canonical={canonical} schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Free TDEE Calculator</h1>
      <p class="subtitle">Calculate your Total Daily Energy Expenditure with precision.</p>
    </div>

    <div class="calculator-container">
      <div class="input-grid">
        <div class="form-group">
          <label for="gender">Biological Gender</label>
          <select id="gender">
            <option value="m">Male</option>
            <option value="f">Female</option>
          </select>
        </div>

        <div class="form-group">
          <label for="age">Age</label>
          <input type="number" id="age" min="1" max="120" placeholder="Years" />
          <div id="age-error" class="error-msg">Please enter a valid age.</div>
        </div>

        <div class="form-group">
          <label for="unit-sys">Measurement System</label>
          <select id="unit-sys">
            <option value="imperial">Imperial (lbs, ft/in)</option>
            <option value="metric">Metric (kg, cm)</option>
          </select>
        </div>
      </div>

      <!-- Metric Inputs -->
      <div class="input-grid" id="metric-inputs" style="display: none;">
        <div class="form-group">
          <label for="weight-kg">Weight (kg)</label>
          <input type="number" id="weight-kg" step="0.1" placeholder="e.g. 75" />
          <div id="weight-kg-error" class="error-msg">Valid weight required.</div>
        </div>
        <div class="form-group">
          <label for="height-cm">Height (cm)</label>
          <input type="number" id="height-cm" step="0.1" placeholder="e.g. 175" />
          <div id="height-cm-error" class="error-msg">Valid height required.</div>
        </div>
      </div>

      <!-- Imperial Inputs -->
      <div id="imperial-inputs">
        <div class="input-grid">
          <div class="form-group">
            <label for="weight-lbs">Weight (lbs)</label>
            <input type="number" id="weight-lbs" step="0.1" placeholder="e.g. 165" />
            <div id="weight-lbs-error" class="error-msg">Valid weight required.</div>
          </div>
          <div class="form-group">
            <label>Height</label>
            <div style="display: flex; gap: 0.5rem;">
              <input type="number" id="height-ft" placeholder="ft" />
              <input type="number" id="height-in" placeholder="in" />
            </div>
            <div id="height-imp-error" class="error-msg">Valid height required.</div>
          </div>
        </div>
      </div>

      <div class="form-group" style="margin-top: 1rem;">
        <label for="activity">Activity Level</label>
        <select id="activity">
          <option value="1.2">Sedentary (Office job, little to no exercise)</option>
          <option value="1.375">Lightly Active (Light exercise/sports 1-3 days/week)</option>
          <option value="1.55">Moderately Active (Moderate exercise/sports 3-5 days/week)</option>
          <option value="1.725">Very Active (Hard exercise/sports 6-7 days a week)</option>
          <option value="1.9">Extra Active (Very hard physical job or training twice a day)</option>
        </select>
      </div>

      <div class="result-card">
        <div style="color: var(--text-secondary); margin-bottom: 0.5rem; font-weight: 600;">Maintenance Calories (TDEE)</div>
        <div class="result-value" id="tdee-display">-- <span style="font-size: 1.5rem;">kcal/day</span></div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; text-align: center; font-size: 1.1rem;">
          <div>
            <div style="font-weight: 600; color: #3b82f6;">Cut (Deficit)</div>
            <div id="cut-display" style="font-family: var(--font-mono); font-weight: 700;">--</div>
          </div>
          <div>
            <div style="font-weight: 600; color: #ef4444;">Bulk (Surplus)</div>
            <div id="bulk-display" style="font-family: var(--font-mono); font-weight: 700;">--</div>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding TDEE and Human Metabolism</h2>

      <p>
        <strong>Total Daily Energy Expenditure (TDEE)</strong> is the absolute total number of calories your body burns in a 24-hour period. It is the most vital metric to understand when attempting to lose fat, gain muscle, or maintain your current physique. Much like analyzing statistical significance with a <a href="/sites/siliconbased/p-value-calculator">p-value calculator</a> in a clinical nutrition study, understanding the precise variance in your energy expenditure allows for data-driven, objective adjustments to your diet, eliminating the need for guesswork and crash diets.
      </p>

      <h3>The Four Components of TDEE</h3>
      <p>Many people incorrectly assume that exercise is the primary driver of their daily calorie burn. In reality, your TDEE is not a single biological process, but rather the sum of four distinct mechanisms of energy expenditure. Understanding these components is the key to mastering your metabolism:</p>

      <ul>
        <li><strong>Basal Metabolic Rate (BMR) (~70% of TDEE):</strong> This is the sheer amount of energy required to keep your body alive at rest. If you were to lay in bed all day and not move a single muscle, your body would still burn calories to fuel organ function, brain activity, cellular repair, blood circulation, and respiration. Because BMR is the largest contributor to TDEE, individuals with more mass (especially muscle mass) have significantly higher basal metabolic rates.</li>
        <li><strong>Non-Exercise Activity Thermogenesis (NEAT) (~15% of TDEE):</strong> NEAT accounts for the calories burned through spontaneous, non-structured daily movements. This includes walking from your car to the office, typing on a keyboard, fidgeting, doing household chores, and even maintaining your posture while sitting. NEAT varies wildly from person to person. A construction worker might burn thousands of calories via NEAT, while an office worker might burn almost none. It is the most easily manipulatable factor of TDEE outside of structured exercise.</li>
        <li><strong>Thermic Effect of Food (TEF) (~10% of TDEE):</strong> The body requires energy to digest, absorb, and metabolize the food you eat. Interestingly, different macronutrients require drastically different amounts of energy to process. Protein has the highest thermic effect (up to 30% of its calories are burned simply during digestion), carbohydrates are in the middle (5-10%), while fats have the lowest thermic effect (around 3%). This is one reason high-protein diets are often recommended for fat loss.</li>
        <li><strong>Exercise Activity Thermogenesis (EAT) (~5% of TDEE):</strong> EAT accounts for the calories explicitly burned during structured exercise, such as weightlifting, running on a treadmill, or playing sports. Surprisingly to many, structured exercise makes up the smallest portion of total daily energy expenditure for the average person, underscoring the saying that "you cannot out-train a bad diet."</li>
      </ul>

      <h3>The Science Behind the Mifflin-St Jeor Equation</h3>
      <p>
        To accurately estimate TDEE, we must first calculate the Basal Metabolic Rate (BMR) to establish a baseline. Over the past century, scientists and nutritionists have developed several formulas, including the Harris-Benedict equation (created in 1919) and the Katch-McArdle equation (which requires knowing your exact body fat percentage).
      </p>
      <p>
        However, extensive peer-reviewed research (dating back to 1990) has established the <strong>Mifflin-St Jeor equation</strong> as the most universally accurate standard formula for estimating BMR in modern populations, applying reliably to both normal-weight and obese individuals. It relies on four easily measurable variables: gender, age, weight, and height.
      </p>

      <p>The core formulas for calculating BMR via Mifflin-St Jeor are:</p>
      <div style="background: rgba(0,0,0,0.05); padding: 1rem; border-radius: 8px; margin: 1rem 0; font-family: var(--font-mono); font-size: 0.95rem;">
        <strong>Men:</strong> BMR = (10 &times; weight in kg) + (6.25 &times; height in cm) - (5 &times; age in years) + 5<br>
        <strong>Women:</strong> BMR = (10 &times; weight in kg) + (6.25 &times; height in cm) - (5 &times; age in years) - 161
      </div>

      <h3>Applying the Activity Multiplier (Katch-McArdle)</h3>
      <p>
        Once the baseline BMR is calculated, it must be multiplied by an Activity Factor (which mathematically incorporates your NEAT and EAT) to output the final TDEE. These multipliers scale linearly based on your lifestyle and average weekly movement:
      </p>
      <ul>
        <li><strong>Sedentary (1.2):</strong> You work a desk job, do minimal walking, and engage in little to no structured exercise.</li>
        <li><strong>Lightly Active (1.375):</strong> You engage in light exercise or sports 1 to 3 days a week, or you have a job requiring some standing or walking (e.g., a teacher or retail worker).</li>
        <li><strong>Moderately Active (1.55):</strong> You engage in moderate exercise or sports 3 to 5 days a week.</li>
        <li><strong>Very Active (1.725):</strong> You engage in hard exercise 6 to 7 days a week, or you work a highly physical manual labor job.</li>
        <li><strong>Extra Active (1.9):</strong> You undergo intense twice-daily training (like a professional athlete), or you have a grueling manual labor career (e.g., construction or farming).</li>
      </ul>

      <h3>How to Use Your TDEE Data to Reach Your Goals</h3>
      <p>
        Understanding your precise maintenance calories is only step one. Step two is manipulating those calories based on your specific physiological goals. The laws of thermodynamics dictate body weight: if energy in exceeds energy out, weight is gained. If energy out exceeds energy in, weight is lost.
      </p>
      <p>
        <strong>For Weight Loss (Cutting):</strong> You must establish a caloric deficit. A pound of human body fat contains approximately 3,500 calories of stored energy. Therefore, maintaining a daily deficit of 500 calories below your TDEE (500 x 7 days = 3,500) will theoretically result in roughly 1 pound of fat loss per week. Aggressive deficits (e.g., 1000 calories/day) can yield faster weight loss but drastically increase the risk of muscle loss, fatigue, and metabolic adaptation.
      </p>
      <p>
        <strong>For Muscle Gain (Bulking):</strong> To build lean tissue efficiently without excess fat accumulation, a slight caloric surplus is required. Your body needs extra energy to synthesize new muscle proteins. A conservative surplus of 200 to 300 calories above your TDEE is generally recommended for steady, lean muscle growth (often called a "lean bulk"). Massive surpluses (e.g., +1000 calories/day) will mostly result in excess fat storage, not faster muscle growth.
      </p>
      <p>
        <em>Important Note: Human metabolism is highly dynamic, not static. As you lose weight, your body physically becomes smaller and subsequently requires less energy to maintain itself, meaning your BMR and TDEE will drop. It is crucial to use this calculator to recalculate your TDEE every 5 to 10 pounds of body weight change to ensure your caloric targets remain accurate and effective.</em>
      </p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is TDEE?</summary>
        <p>TDEE stands for Total Daily Energy Expenditure. It is the total number of calories your body burns in a 24-hour period, factoring in your basal metabolic rate (BMR), exercise, daily movement (NEAT), and digestion.</p>
      </details>
      <details>
        <summary>How is TDEE calculated?</summary>
        <p>This calculator uses the Mifflin-St Jeor equation to estimate your Basal Metabolic Rate (BMR), which is currently considered the most accurate standard formula. The BMR is then multiplied by an activity multiplier to determine your TDEE.</p>
      </details>
      <details>
        <summary>Should I eat my TDEE to lose weight?</summary>
        <p>No. Eating exactly your TDEE will result in weight maintenance. To lose weight, you must eat fewer calories than your TDEE (a caloric deficit). A typical deficit is 300-500 calories below TDEE per day.</p>
      </details>
      <details>
        <summary>What is the difference between BMR and TDEE?</summary>
        <p>BMR (Basal Metabolic Rate) is the calories your body burns simply to stay alive at rest (breathing, organ function). TDEE includes BMR plus all the extra calories you burn through daily movement and exercise.</p>
      </details>
      <details>
        <summary>How often should I recalculate my TDEE?</summary>
        <p>You should recalculate your TDEE every time you lose or gain 5-10 pounds, or if your daily activity levels change significantly, as these factors directly alter your energy expenditure.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const genderEl = document.getElementById('gender');
      const ageEl = document.getElementById('age');
      const unitSysEl = document.getElementById('unit-sys');
      const activityEl = document.getElementById('activity');

      const metricInputs = document.getElementById('metric-inputs');
      const imperialInputs = document.getElementById('imperial-inputs');

      const weightKg = document.getElementById('weight-kg');
      const heightCm = document.getElementById('height-cm');
      const weightLbs = document.getElementById('weight-lbs');
      const heightFt = document.getElementById('height-ft');
      const heightIn = document.getElementById('height-in');

      const tdeeDisplay = document.getElementById('tdee-display');
      const cutDisplay = document.getElementById('cut-display');
      const bulkDisplay = document.getElementById('bulk-display');

      // Error elements
      const errors = {
        age: document.getElementById('age-error'),
        wKg: document.getElementById('weight-kg-error'),
        hCm: document.getElementById('height-cm-error'),
        wLbs: document.getElementById('weight-lbs-error'),
        hImp: document.getElementById('height-imp-error'),
      };

      function resetErrors() {
        Object.values(errors).forEach(el => el.style.display = 'none');
      }

      function calculateTDEE() {
        resetErrors();

        let hasError = false;
        let isComplete = true;

        const gender = genderEl.value;
        const sys = unitSysEl.value;
        const activity = parseFloat(activityEl.value);

        const ageStr = ageEl.value;
        if (ageStr.trim() === '') isComplete = false;
        const age = parseInt(ageStr, 10);
        if (ageStr.trim() !== '' && (isNaN(age) || age <= 0 || age > 120)) {
          errors.age.style.display = 'block';
          hasError = true;
        }

        let w_kg = 0;
        let h_cm = 0;

        if (sys === 'metric') {
          const wkStr = weightKg.value;
          const hcStr = heightCm.value;

          if (wkStr.trim() === '' || hcStr.trim() === '') isComplete = false;

          w_kg = parseFloat(wkStr);
          h_cm = parseFloat(hcStr);

          if (wkStr.trim() !== '' && (isNaN(w_kg) || w_kg <= 0)) {
            errors.wKg.style.display = 'block';
            hasError = true;
          }
          if (hcStr.trim() !== '' && (isNaN(h_cm) || h_cm <= 0)) {
            errors.hCm.style.display = 'block';
            hasError = true;
          }
        } else {
          const wlStr = weightLbs.value;
          const hfStr = heightFt.value;
          const hiStr = heightIn.value;

          if (wlStr.trim() === '' || (hfStr.trim() === '' && hiStr.trim() === '')) isComplete = false;

          const w_lbs = parseFloat(wlStr);
          const h_ft = parseFloat(hfStr || 0);
          const h_in = parseFloat(hiStr || 0);

          if (wlStr.trim() !== '' && (isNaN(w_lbs) || w_lbs <= 0)) {
            errors.wLbs.style.display = 'block';
            hasError = true;
          }
          if ((hfStr.trim() !== '' || hiStr.trim() !== '') && (isNaN(h_ft) || isNaN(h_in) || (h_ft <= 0 && h_in <= 0))) {
            errors.hImp.style.display = 'block';
            hasError = true;
          }

          w_kg = w_lbs * 0.453592;
          h_cm = ((h_ft * 12) + h_in) * 2.54;
        }

        if (hasError || !isComplete) {
          tdeeDisplay.innerHTML = '-- <span style="font-size: 1.5rem;">kcal/day</span>';
          cutDisplay.textContent = '--';
          bulkDisplay.textContent = '--';
          return;
        }

        // Mifflin-St Jeor
        let bmr = (10 * w_kg) + (6.25 * h_cm) - (5 * age);
        if (gender === 'm') {
          bmr += 5;
        } else {
          bmr -= 161;
        }

        const tdee = bmr * activity;

        tdeeDisplay.innerHTML = Math.round(tdee).toLocaleString() + ' <span style="font-size: 1.5rem;">kcal/day</span>';
        cutDisplay.textContent = Math.round(tdee - 500).toLocaleString() + ' kcal';
        bulkDisplay.textContent = Math.round(tdee + 250).toLocaleString() + ' kcal';
      }

      function toggleUnits() {
        if (unitSysEl.value === 'metric') {
          metricInputs.style.display = 'grid';
          imperialInputs.style.display = 'none';
        } else {
          metricInputs.style.display = 'none';
          imperialInputs.style.display = 'block';
        }
        calculateTDEE();
      }

      // Listeners
      genderEl.addEventListener('change', calculateTDEE);
      ageEl.addEventListener('input', calculateTDEE);
      activityEl.addEventListener('change', calculateTDEE);

      weightKg.addEventListener('input', calculateTDEE);
      heightCm.addEventListener('input', calculateTDEE);

      weightLbs.addEventListener('input', calculateTDEE);
      heightFt.addEventListener('input', calculateTDEE);
      heightIn.addEventListener('input', calculateTDEE);

      unitSysEl.addEventListener('change', toggleUnits);

      // Init
      toggleUnits();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .subtitle { color: var(--text-secondary); font-size: 1.15rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }

    .input-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
    .form-group { margin-bottom: 1.5rem; }
    .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: var(--text-primary); }

    input, select {
      background: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1rem;
      border-radius: 8px;
      width: 100%;
      font-size: 1rem;
      font-family: inherit;
    }
    input:focus, select:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .error-msg {
      color: #ef4444;
      font-size: 0.85rem;
      margin-top: 0.5rem;
      display: none;
    }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 2rem; margin-top: 2rem; text-align: center; }
    .result-value { font-size: 3rem; font-weight: 800; color: var(--accent-color); font-family: var(--font-mono); line-height: 1; }

    .explainer { margin-top: 3rem; }
    .explainer h2 { font-size: 1.8rem; margin-top: 2rem; margin-bottom: 1rem; color: var(--accent-color); }
    .explainer h3 { font-size: 1.4rem; margin-top: 1.5rem; margin-bottom: 0.75rem; }
    .explainer h4 { font-size: 1.2rem; margin-top: 1.2rem; margin-bottom: 0.5rem; }
    .explainer p { margin-bottom: 1.25rem; font-size: 1.05rem; line-height: 1.7; color: var(--text-secondary); }
    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; font-size: 1.05rem; }
    .explainer a { color: var(--accent-color); text-decoration: none; }
    .explainer a:hover { text-decoration: underline; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; color: var(--accent-color); text-align: center; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; color: var(--text-primary); }
    .faq-section details p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
