---
import SiteLayout from "../../../layouts/SiteLayout.astro";


export const meta = {
  title: 'Energy Audit Checklist',
  description: 'Inspect your home for air leaks around windows/doors, check insulation levels in the attic, inspect HVAC equipment, and review lighting. Identifying these issues is the first step to major savings.',
  category: 'guide',
};

const hvacTips = [
  { tip: "Programmable Thermostat", detail: "Set back temperature by 7°-10°F for 8 hours a day from its normal setting.", savings: "$50/year" },
  { tip: "Filter Schedule", detail: "Replace your HVAC filter every 1-3 months to improve efficiency.", savings: "5-15% of AC energy" },
  { tip: "Sealing Leaks", detail: "Seal around windows, doors, and vents with caulk and weatherstripping.", savings: "10-20% on bills" },
  { tip: "Annual Maintenance", detail: "Schedule professional HVAC tune-ups to ensure peak performance.", savings: "Prevents repairs" },
  { tip: "Clear Vents", detail: "Move furniture and rugs away from heating and cooling vents.", savings: "Improves airflow" },
  { tip: "Ceiling Fans", detail: "Use fans in summer to feel cooler; reverse in winter to push warm air down.", savings: "Allows 4°F change" }
];

const lightingTips = [
  { tip: "LED Conversion", detail: "Replace incandescent bulbs with Energy Star certified LEDs.", savings: "$225/year" },
  { tip: "Natural Light", detail: "Open blinds during the day instead of turning on lamps.", savings: "$0 daytime lighting" },
  { tip: "Task Lighting", detail: "Use lamps for specific tasks instead of illuminating the whole room.", savings: "Targeted use" },
  { tip: "Motion Sensors", detail: "Install sensors or timers in low-traffic areas like hallways or closets.", savings: "Prevents waste" },
  { tip: "Clean Fixtures", detail: "Dust bulbs and fixtures regularly to maximize light output.", savings: "Optimal brightness" }
];

const applianceTips = [
  { tip: "Energy Star Appliances", detail: "Upgrade old appliances to Energy Star certified models.", savings: "10-50% less energy" },
  { tip: "Phantom Loads", detail: "Unplug electronics when not in use or use smart power strips.", savings: "$100/year" },
  { tip: "Full Loads Only", detail: "Wait until the dishwasher or washing machine is full before running.", savings: "Saves water/energy" },
  { tip: "Cold Water Wash", detail: "Wash laundry in cold water instead of hot.", savings: "$60/year" },
  { tip: "Air Dry Dishes", detail: "Turn off the heated dry cycle on your dishwasher.", savings: "15% of dishwasher energy" },
  { tip: "Clean Refrigerator Coils", detail: "Vacuum the coils behind your fridge to maintain efficiency.", savings: "Improves cooling" },
  { tip: "Oven Usage", detail: "Use a microwave or toaster oven for small meals.", savings: "Uses less energy" }
];

const homeStructureTips = [
  { tip: "Attic Insulation", detail: "Add insulation to your attic to prevent heat loss/gain.", savings: "10-50% on bills" },
  { tip: "Weatherstripping", detail: "Apply weatherstripping to doors and windows.", savings: "Up to 20% savings" },
  { tip: "Water Heater Temperature", detail: "Lower your water heater setting to 120°F.", savings: "Up to $60/year" },
  { tip: "Water Heater Blanket", detail: "Wrap your older water heater in an insulating blanket.", savings: "7-16% in water heating" },
  { tip: "Low-Flow Fixtures", detail: "Install low-flow showerheads and faucet aerators.", savings: "25-60% less water" },
  { tip: "Smart Power Strips", detail: "Use advanced power strips to cut off power to idle electronics.", savings: "Reduces phantom loads" },
  { tip: "Energy Audit", detail: "Perform a DIY or professional home energy audit.", savings: "Identifies ROI improvements" }
];

const seasonalTips = [
  { tip: "Winter Heating", detail: "Open curtains on south-facing windows during the day to let sunlight in.", savings: "Free solar heat" },
  { tip: "Summer Cooling", detail: "Close blinds and curtains during the hottest part of the day.", savings: "Reduces heat gain" },
  { tip: "Draft Snakes", detail: "Place draft snakes at the bottom of doors to block cold winter air.", savings: "Inexpensive comfort fix" },
  { tip: "A/C Condenser Clearance", detail: "Keep the area around your outdoor A/C unit clear of debris.", savings: "Improves efficiency" },
  { tip: "Humidifier Usage", detail: "Use a humidifier in winter; moist air feels warmer.", savings: "Allows lower thermostat" }
];

const guides = [
  { title: "Energy Audit Checklist", description: "Inspect your home for air leaks around windows/doors, check insulation levels in the attic, inspect HVAC equipment, and review lighting. Identifying these issues is the first step to major savings." },
  { title: "Solar ROI Recap", description: "Installing solar panels can drastically reduce or eliminate electricity bills. While upfront costs are high, federal tax credits and state incentives can reduce the payback period to 5-9 years, with decades of free energy thereafter." },
  { title: "LED Conversion Savings Calculator", description: "Replacing just 15 inefficient incandescent bulbs with LEDs can save you about $50 per year. LEDs use up to 90% less energy and last up to 25 times longer than traditional incandescent bulbs." }
];

const faqs = [
  { q: "What is a phantom load?", a: "A phantom load, or standby power, is the energy consumed by electronics and appliances even when they are turned off but still plugged in. This can account for up to 10% of residential energy use." },
  { q: "How much can I save with a programmable thermostat?", a: "By setting your thermostat back 7°-10°F for 8 hours a day from its normal setting, you can save as much as 10% a year on heating and cooling." },
  { q: "Are Energy Star appliances really worth the cost?", a: "Yes. While they may have a higher upfront cost, Energy Star appliances use 10-50% less energy than standard models, which translates to significant savings on your utility bills over the life of the appliance." },
  { q: "Why should I lower my water heater temperature?", a: "Water heating accounts for about 18% of the energy consumed in your home. Lowering the temperature from 140°F to 120°F not only saves energy but also slows mineral buildup and corrosion in your water heater and pipes." },
  { q: "What is the most cost-effective energy saving improvement?", a: "Air sealing and adding insulation are typically the most cost-effective ways to improve energy efficiency and comfort, often yielding savings of 10-20% on heating and cooling bills." }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Energy Saving Tips: 30 Ways to Lower Your Bill",
    "description": "Discover 30 actionable ways to lower your energy bills. Covering HVAC optimization, appliance efficiency, lighting, insulation, and seasonal tips.",
    "author": {
      "@type": "Organization",
      "name": "I Just Want To"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  }
];
---
<SiteLayout
  site="ijustwantto"
  title="Best Energy Saving Tips: 30 Ways to Lower Your Bill"
  description="Discover 30 actionable ways to lower your energy bills. Covering HVAC optimization, appliance efficiency, lighting, insulation, and seasonal tips."
  canonical="https://ijustwantto.live/energy-saving-tips"
  schema={JSON.stringify(schema)}
>
  <div class="page-wrapper">
    <div class="hero">
      <h1>Best Energy Saving Tips</h1>
      <p>Discover 30 actionable ways to lower your energy bills. Covering HVAC optimization, appliance efficiency, lighting, insulation, and seasonal tips.</p>
    </div>

    <section class="content-section">
      <div class="page-content">

        <h2>HVAC Optimization</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Tip</th>
                <th>Detail</th>
                <th>Average Savings</th>
              </tr>
            </thead>
            <tbody>
              {hvacTips.map(item => (
                <tr>
                  <td><strong>{item.tip}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.savings}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Lighting</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Tip</th>
                <th>Detail</th>
                <th>Average Savings</th>
              </tr>
            </thead>
            <tbody>
              {lightingTips.map(item => (
                <tr>
                  <td><strong>{item.tip}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.savings}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Appliance Efficiency</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Tip</th>
                <th>Detail</th>
                <th>Average Savings</th>
              </tr>
            </thead>
            <tbody>
              {applianceTips.map(item => (
                <tr>
                  <td><strong>{item.tip}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.savings}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Home Structure & Water</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Tip</th>
                <th>Detail</th>
                <th>Average Savings</th>
              </tr>
            </thead>
            <tbody>
              {homeStructureTips.map(item => (
                <tr>
                  <td><strong>{item.tip}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.savings}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Seasonal Tips</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Tip</th>
                <th>Detail</th>
                <th>Average Savings</th>
              </tr>
            </thead>
            <tbody>
              {seasonalTips.map(item => (
                <tr>
                  <td><strong>{item.tip}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.savings}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Energy Savings Guides</h2>
        <div class="winners-grid">
          {guides.map(guide => (
            <div class="winner-card">
              <span class="winner-label">Guide</span>
              <strong>{guide.title}</strong>
              <span class="winner-reason">{guide.description}</span>
            </div>
          ))}
        </div>

        <h2>Frequently Asked Questions</h2>
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .page-wrapper {
    --text-primary: #1f2937;
    --text-secondary: #4b5563;
    --accent-color: #3b82f6;
    --card-bg: #ffffff;
    --border-color: #e5e7eb;
    --bg-color: #f9fafb;

    font-family: system-ui, -apple-system, sans-serif;
    color: var(--text-primary);
    background-color: var(--bg-color);
  }

  .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
  .hero { text-align: center; padding: 3rem 0 2rem; }
  .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
  .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

  .content-section { margin-bottom: 3rem; }
  .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
  .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
  .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

  .content-section ul { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; padding-left: 1.5rem; }
  .content-section li { margin-bottom: 0.5rem; }

  strong { color: var(--text-primary); }

  /* Winners Grid */
  .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
  .winner-card strong { font-size: 1.05rem; }
  .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

  /* Comparison Table */
  .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
  td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--card-bg); }

  /* FAQ */
  .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
  .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
  .faq-item p { margin-bottom: 0; }

  @media (max-width: 600px) {
    .hero h1 { font-size: 1.6rem; }
    .winners-grid { grid-template-columns: 1fr; }
  }
</style>
