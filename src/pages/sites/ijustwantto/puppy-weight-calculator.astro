  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // FAQ toggle
      var questions = document.querySelectorAll('.faq-question');
      questions.forEach(function(q) {
        q.addEventListener('click', function() {
          var answer = this.nextElementSibling;
          answer.classList.toggle('show');
        });
      });

      // Calculator Logic
      var calcBtn = document.getElementById('calcBtn');
      if (calcBtn) {
        calcBtn.addEventListener('click', function() {
          var size = document.getElementById('breedSize').value;
          var age = parseFloat(document.getElementById('ageWeeks').value);
          var weight = parseFloat(document.getElementById('currentWeight').value);

          var ageError = document.getElementById('ageError');
          var weightError = document.getElementById('weightError');
          var hasError = false;

          if (isNaN(age) || age < 1 || age > 100) {
            ageError.style.display = 'block';
            hasError = true;
          } else {
            ageError.style.display = 'none';
          }

          if (isNaN(weight) || weight <= 0) {
            weightError.style.display = 'block';
            hasError = true;
          } else {
            weightError.style.display = 'none';
          }

          if (hasError) return;

          var percentAdult = 0;

          if (size === 'toy') {
            if (age <= 12) percentAdult = (age / 12) * 50;
            else if (age < 40) percentAdult = 50 + ((age - 12) / 28) * 50;
            else percentAdult = 100;
          } else if (size === 'small') {
            if (age <= 15) percentAdult = (age / 15) * 50;
            else if (age < 45) percentAdult = 50 + ((age - 15) / 30) * 50;
            else percentAdult = 100;
          } else if (size === 'medium') {
            if (age <= 18) percentAdult = (age / 18) * 50;
            else if (age < 52) percentAdult = 50 + ((age - 18) / 34) * 50;
            else percentAdult = 100;
          } else if (size === 'large') {
            if (age <= 22) percentAdult = (age / 22) * 50;
            else if (age < 65) percentAdult = 50 + ((age - 22) / 43) * 50;
            else percentAdult = 100;
          } else {
            if (age <= 25) percentAdult = (age / 25) * 50;
            else if (age < 78) percentAdult = 50 + ((age - 25) / 53) * 50;
            else percentAdult = 100;
          }

          percentAdult = Math.max(5, Math.min(100, percentAdult));
          var adultWeight = weight / (percentAdult / 100);

          document.getElementById('resultsArea').classList.add('show');
          document.getElementById('predictedWeight').textContent = adultWeight.toFixed(1) + ' lbs';

          var lowRange = (adultWeight * 0.9).toFixed(1);
          var highRange = (adultWeight * 1.1).toFixed(1);
          document.getElementById('weightRange').textContent = 'Estimated Range: ' + lowRange + ' to ' + highRange + ' lbs';

          drawChart(size, adultWeight, age, weight);
        });
      }

      function drawChart(size, adultWeight, currentAge, currentWeight) {
        var box = document.getElementById('chartBox');
        box.innerHTML = '';

        var maxAge = 52;
        if (size === 'large') maxAge = 65;
        if (size === 'giant') maxAge = 78;
        if (currentAge > maxAge) maxAge = currentAge + 10;

        var w = box.clientWidth;
        var h = box.clientHeight;

        var points = [];
        for (var i = 0; i <= maxAge; i += 4) {
          var p = getPercent(size, i);
          var wVal = adultWeight * (p / 100);
          points.push({age: i, w: wVal});
        }

        for (var i = 0; i < points.length - 1; i++) {
          var p1 = points[i];
          var p2 = points[i+1];

          var x1 = (p1.age / maxAge) * w;
          var y1 = h - ((p1.w / (adultWeight * 1.1)) * h);

          var x2 = (p2.age / maxAge) * w;
          var y2 = h - ((p2.w / (adultWeight * 1.1)) * h);

          var len = Math.sqrt(Math.pow(x2-x1, 2) + Math.pow(y2-y1, 2));
          var angle = Math.atan2(y2-y1, x2-x1) * 180 / Math.PI;

          var line = document.createElement('div');
          line.className = 'chart-line';
          line.style.width = len + 'px';
          line.style.left = x1 + 'px';
          line.style.top = y1 + 'px';
          line.style.transform = 'rotate(' + angle + 'deg)';
          line.style.opacity = '0.5';
          box.appendChild(line);
        }

        var cx = (Math.min(currentAge, maxAge) / maxAge) * w;
        var cy = h - ((currentWeight / (adultWeight * 1.1)) * h);

        var cPt = document.createElement('div');
        cPt.className = 'chart-point';
        cPt.style.left = cx + 'px';
        cPt.style.top = cy + 'px';
        cPt.style.background = '#ff4444';
        cPt.style.width = '12px';
        cPt.style.height = '12px';
        cPt.title = 'Current: ' + currentAge + ' wks, ' + currentWeight + ' lbs';
        box.appendChild(cPt);

        var ax = w;
        var ay = h - ((adultWeight / (adultWeight * 1.1)) * h);
        var aPt = document.createElement('div');
        aPt.className = 'chart-point';
        aPt.style.left = ax + 'px';
        aPt.style.top = ay + 'px';
        aPt.title = 'Adult: ' + adultWeight.toFixed(1) + ' lbs';
        box.appendChild(aPt);
      }

      function getPercent(size, age) {
        var p = 0;
        if (size === 'toy') {
          if (age <= 12) p = (age / 12) * 50;
          else if (age < 40) p = 50 + ((age - 12) / 28) * 50;
          else p = 100;
        } else if (size === 'small') {
          if (age <= 15) p = (age / 15) * 50;
          else if (age < 45) p = 50 + ((age - 15) / 30) * 50;
          else p = 100;
        } else if (size === 'medium') {
          if (age <= 18) p = (age / 18) * 50;
          else if (age < 52) p = 50 + ((age - 18) / 34) * 50;
          else p = 100;
        } else if (size === 'large') {
          if (age <= 22) p = (age / 22) * 50;
          else if (age < 65) p = 50 + ((age - 22) / 43) * 50;
          else p = 100;
        } else {
          if (age <= 25) p = (age / 25) * 50;
          else if (age < 78) p = 50 + ((age - 25) / 53) * 50;
          else p = 100;
        }
        return Math.max(0, Math.min(100, p));
      }
    });
  </script>
