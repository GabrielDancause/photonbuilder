---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Pace Calculator | Calculate Running Speed & Finish Times",
  description: "Discover the exact running speed you need to crush your next personal best. Our free pace calculator reveals the hidden numbers behind your marathon, 5K, or daily jog—find out how fast you really need to go.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Pace Calculator: Calculate Running Speed and Finish Times",
    "description": "Calculate running pace, finish times, and race distances with our real-time pace calculator. Learn the formulas, training strategies, and secrets to a faster finish.",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I calculate my running pace?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To calculate your running pace, simply divide the total time you spent running by the total distance you covered. For example, if you ran 5 miles in 45 minutes, your pace is 9 minutes per mile. Our calculator does this math for you instantly."
        }
      },
      {
        "@type": "Question",
        "name": "What is a good pace for a 5K?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 'good' 5K pace depends on your fitness level and experience. Beginners often target a pace between 10 to 12 minutes per mile, resulting in a finish time of 31 to 37 minutes. Elite runners can maintain paces well under 5 minutes per mile."
        }
      },
      {
        "@type": "Question",
        "name": "How does treadmill pace correlate to outdoor running?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Treadmill pace can feel easier because there is no wind resistance and the belt helps propel your legs. Setting your treadmill to a 1% incline closely simulates the energy expenditure of running outdoors on a flat surface at the same pace."
        }
      },
      {
        "@type": "Question",
        "name": "What pace do I need to run a sub-2 hour half marathon?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To finish a half marathon (13.1 miles) in under 2 hours, you need to maintain an average pace of at least 9 minutes and 9 seconds per mile, or 5 minutes and 41 seconds per kilometer."
        }
      },
      {
        "@type": "Question",
        "name": "Is it better to run for time or distance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Both have benefits. Running for time is excellent for beginners building endurance or for recovery days, as it focuses on sustained effort rather than speed. Running for distance is crucial when training for specific race lengths, like a 10K or marathon, where you need to prepare your body for the exact mileage."
        }
      }
    ]
  }
];
---
<SiteLayout site="ijustwantto" title={meta.title} description={meta.description} canonical="https://ijustwantto.live/pace-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Pace Calculator</h1>
      <p class="subtitle">Instantly calculate your running pace, distance, or finish time.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-mode-selector">
        <label for="calc-mode">What do you want to calculate?</label>
        <select id="calc-mode" class="mode-select">
          <option value="pace">Pace (Requires Distance & Time)</option>
          <option value="time">Time (Requires Distance & Pace)</option>
          <option value="distance">Distance (Requires Time & Pace)</option>
        </select>
      </div>

      <div class="calc-grid">
        <!-- Distance Section -->
        <div class="calc-section" id="section-distance">
          <h3>Distance</h3>
          <div class="input-row">
            <div class="input-group">
              <label for="dist-value">Value</label>
              <input type="number" id="dist-value" min="0" step="any" placeholder="e.g. 5" />
            </div>
            <div class="input-group">
              <label for="dist-unit">Unit / Event</label>
              <select id="dist-unit">
                <option value="mi">Miles</option>
                <option value="km">Kilometers</option>
                <option value="m">Meters</option>
                <optgroup label="Popular Events">
                  <option value="3.10686">5K (3.1 mi)</option>
                  <option value="6.21371">10K (6.2 mi)</option>
                  <option value="13.1094">Half Marathon (13.1 mi)</option>
                  <option value="26.2188">Marathon (26.2 mi)</option>
                </optgroup>
              </select>
            </div>
          </div>
          <div class="error-msg" id="error-distance">Please enter a valid distance.</div>
        </div>

        <!-- Time Section -->
        <div class="calc-section" id="section-time">
          <h3>Time</h3>
          <div class="input-row time-inputs">
            <div class="input-group">
              <label for="time-hr">Hours</label>
              <input type="number" id="time-hr" min="0" placeholder="00" />
            </div>
            <div class="input-group">
              <label for="time-min">Minutes</label>
              <input type="number" id="time-min" min="0" max="59" placeholder="00" />
            </div>
            <div class="input-group">
              <label for="time-sec">Seconds</label>
              <input type="number" id="time-sec" min="0" max="59" placeholder="00" />
            </div>
          </div>
          <div class="error-msg" id="error-time">Please enter a valid time.</div>
        </div>

        <!-- Pace Section -->
        <div class="calc-section" id="section-pace">
          <h3>Pace</h3>
          <div class="input-row pace-inputs">
            <div class="input-group">
              <label for="pace-min">Minutes</label>
              <input type="number" id="pace-min" min="0" placeholder="00" />
            </div>
            <div class="input-group">
              <label for="pace-sec">Seconds</label>
              <input type="number" id="pace-sec" min="0" max="59" placeholder="00" />
            </div>
            <div class="input-group">
              <label for="pace-unit">Per</label>
              <select id="pace-unit">
                <option value="mi">Mile</option>
                <option value="km">Kilometer</option>
              </select>
            </div>
          </div>
          <div class="error-msg" id="error-pace">Please enter a valid pace.</div>
        </div>
      </div>

      <div class="result-card">
        <p class="calc-result-label" id="result-label">Calculated Pace</p>
        <div class="result-value" id="result-value">--:-- / mi</div>
      </div>

      <div class="reset-wrapper">
         <button id="reset-btn" class="reset-btn">Reset Calculator</button>
      </div>
    </div>

    <div class="explainer">
      <h2>The Definitive Guide to Running Pace and Performance</h2>

      <p>Whether you're lacing up your shoes for your very first couch-to-5K or toeing the start line of your tenth marathon, understanding your running pace is one of the most fundamental aspects of endurance training. Running pace isn't just a metric to obsess over on your GPS watch; it's a critical tool for regulating exertion, predicting race finish times, and ensuring your body adapts optimally to your training regimen. Our interactive pace calculator simplifies the math, allowing you to instantly figure out your pace, target finish times, or the distance you need to cover.</p>

      <h3>The Mathematics of Movement: How Pace is Calculated</h3>
      <p>At its core, pace is a measure of speed expressed in a slightly different format. While a car's speed is typically measured in miles per hour (mph) or kilometers per hour (km/h), a runner's pace is calculated as the time it takes to cover a single unit of distance—usually minutes per mile (min/mi) or minutes per kilometer (min/km).</p>

      <p>The universal formula for determining pace is incredibly straightforward:</p>
      <div class="formula-box">
        <code>Pace = Time ÷ Distance</code>
      </div>

      <p>However, doing this math in your head on the fly is notoriously difficult because time is measured in base-60 (60 seconds in a minute, 60 minutes in an hour) rather than base-10. For instance, if you run 3 miles in 25 minutes and 30 seconds, you first have to convert the time entirely to seconds (1,530 seconds), divide by the distance (510 seconds per mile), and then convert that back into minutes and seconds (8 minutes and 30 seconds per mile). This mathematical friction is exactly why a dedicated pace calculator is an essential bookmark for any runner.</p>

      <h3>Why Pace Control is the Secret to Personal Bests</h3>
      <p>A common mistake among novice runners is the "fly and die" approach—starting a race or a workout at a blazing fast pace fueled by adrenaline, only to crash spectacularly as lactic acid builds up and glycogen stores become depleted. Mastering pace control allows you to distribute your energy evenly across the duration of your run.</p>

      <p><strong>Even Splits vs. Negative Splits:</strong> In racing parlance, a "split" refers to the time it takes to complete a specific segment of the race (like a single mile or kilometer). Running "even splits" means covering every segment at exactly the same pace. Running "negative splits" means intentionally running the first half of your run slightly slower than the second half. Many world records from the 5K up to the marathon have been set using a negative split strategy, as it conserves energy and allows the body to warm up fully before demanding maximum exertion.</p>

      <h3>Training Paces: Slowing Down to Speed Up</h3>
      <p>One of the most counterintuitive principles of modern endurance training is that to run faster on race day, you must run slower on most of your training days. Elite coaches frequently employ a polarized training model, often referred to as the 80/20 rule, where 80% of running is done at an easy pace, and 20% is done at a hard pace. Here is how different paces fit into a well-rounded training plan:</p>

      <ul>
        <li><strong>Easy Pace:</strong> This should make up the bulk of your weekly mileage. You should be able to hold a full conversation without gasping for air. Physiologically, this pace builds capillary density, increases mitochondria in your muscle cells, and strengthens ligaments without requiring prolonged recovery.</li>
        <li><strong>Tempo Pace (Lactate Threshold):</strong> Often described as "comfortably hard," this pace is roughly the speed you could sustain for one hour. Training at tempo pace improves your body's ability to clear lactic acid from your bloodstream, allowing you to run faster for longer before fatigue sets in.</li>
        <li><strong>Interval Pace (VO2 Max):</strong> These are fast, hard repetitions interspersed with recovery jogs. This pace is significantly faster than your 5K race pace and is designed to improve your maximum oxygen uptake, running economy, and biomechanical efficiency.</li>
        <li><strong>Race Pace:</strong> This is the specific pace you need to maintain to hit your goal finish time. Practicing at race pace helps your body and mind become intimately familiar with the exact cadence and effort level required for your target event.</li>
      </ul>

      <h3>Environmental Variables: When the Math Doesn't Match Reality</h3>
      <p>While a pace calculator provides a mathematically perfect output, real-world running happens outside the vacuum of a spreadsheet. Several external factors will force you to adjust your pace expectations on the fly.</p>

      <p><strong>Terrain and Elevation:</strong> A 9:00 min/mi pace on a flat, paved trail requires significantly less effort than the exact same pace on a muddy, technical trail with 500 feet of elevation gain. Many runners use the concept of "Grade Adjusted Pace" (GAP) to estimate what their effort would equate to on a flat surface. Uphill running increases cardiovascular demand, while steep downhill running punishes the quadriceps with intense eccentric muscle contractions.</p>

      <p><strong>Weather Conditions:</strong> Heat and humidity drastically reduce performance. When the body gets hot, it diverts blood away from the working muscles and toward the skin to facilitate cooling through sweat. High humidity prevents sweat from evaporating efficiently, exacerbating the problem. Runners often see their heart rates spike at paces that would normally feel easy on a cool, crisp autumn morning. Wind resistance is another factor; a strong headwind can easily add 15 to 30 seconds per mile to your pace for the same effort level.</p>

      <h3>Metric vs. Imperial: Navigating Distance Conversions</h3>
      <p>The running world exists in a hybrid state of metric and imperial measurements. While track workouts are usually measured in meters (400m repeats) and many road races use kilometers (5K, 10K), runners in the United States and the UK often discuss their daily mileage and pacing in miles. Knowing the key conversions is vital:</p>
      <ul>
        <li>1 Mile = 1.609 Kilometers</li>
        <li>1 Kilometer = 0.621 Miles</li>
        <li>A 5K is 3.1 miles</li>
        <li>A 10K is 6.2 miles</li>
        <li>A Half Marathon is 13.1 miles (21.1 kilometers)</li>
        <li>A Marathon is 26.2 miles (42.2 kilometers)</li>
      </ul>
      <p>Our calculator automatically handles these conversions. If you input your target 10K time, you can easily toggle between seeing your required pace in minutes per mile or minutes per kilometer.</p>

      <h3>Applying Pace Data to Your Next Run</h3>
      <p>Now that you understand the mechanics behind the numbers, how do you put this into practice? Start by picking a goal race or a specific distance. If your goal is to break 2 hours in a half marathon, input a distance of 13.1 miles and a time of 1 hour, 59 minutes, and 59 seconds. The calculator will reveal that you need to maintain a pace of 9:09 per mile.</p>

      <p>With that target pace in mind, you can structure your training blocks. You might run your easy days at a 10:30 pace, complete your tempo runs at an 8:45 pace, and spend a few weeks doing mile repeats at your exact 9:09 race pace to lock in the muscle memory. By demystifying the mathematics of speed, a pace calculator transforms ambiguous fitness goals into actionable, data-driven training plans.</p>

      <p><em>(And if your feet are sore after logging all those miles and you're thinking about tackling an indoor home improvement project instead, be sure to check out our <a href="/square-foot-calculator">Square Foot Calculator</a> to easily estimate materials for your next renovation!)</em></p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How do I calculate my running pace?</summary>
        <p>To calculate your running pace, simply divide the total time you spent running by the total distance you covered. For example, if you ran 5 miles in 45 minutes, your pace is 9 minutes per mile. Because time involves base-60 math (60 seconds in a minute), using a digital calculator is usually the easiest method to get an accurate result.</p>
      </details>
      <details>
        <summary>What is a good pace for a 5K?</summary>
        <p>A "good" 5K pace depends entirely on your age, fitness level, and running experience. Beginners often target a pace between 10 to 12 minutes per mile, resulting in a finish time of roughly 31 to 37 minutes. Intermediate runners frequently aim for 8 to 9 minutes per mile, while elite runners can maintain paces well under 5 minutes per mile.</p>
      </details>
      <details>
        <summary>How does treadmill pace correlate to outdoor running?</summary>
        <p>Treadmill pace can feel physically easier because there is no wind resistance to battle against, and the motorized belt helps assist the turnover of your legs. To closely simulate the physiological energy expenditure of running outdoors on a flat surface at your target pace, most coaches recommend setting the treadmill to a 1% incline.</p>
      </details>
      <details>
        <summary>What pace do I need to run a sub-2 hour half marathon?</summary>
        <p>To finish a half marathon (which is exactly 13.1094 miles) in under 2 hours, you need to maintain an average pace of at least 9 minutes and 9 seconds per mile, or 5 minutes and 41 seconds per kilometer. Hitting slightly under this (like a 9:05 pace) provides a small buffer for aid stations or crowded course conditions.</p>
      </details>
      <details>
        <summary>Is it better to run for time or distance?</summary>
        <p>Both methods have significant benefits depending on your goals. Running for time is excellent for beginners building baseline endurance or for recovery days, as it focuses on sustained cardiovascular effort rather than arbitrary speed. Running for distance is crucial when training for specific race lengths, like a 10K or marathon, where you physically need to prepare your muscles and joints for the exact mileage of the event.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    // Elements
    const modeSelect = document.getElementById('calc-mode');

    // Sections
    const secDist = document.getElementById('section-distance');
    const secTime = document.getElementById('section-time');
    const secPace = document.getElementById('section-pace');

    // Inputs
    const distVal = document.getElementById('dist-value');
    const distUnit = document.getElementById('dist-unit');

    const timeHr = document.getElementById('time-hr');
    const timeMin = document.getElementById('time-min');
    const timeSec = document.getElementById('time-sec');

    const paceMin = document.getElementById('pace-min');
    const paceSec = document.getElementById('pace-sec');
    const paceUnit = document.getElementById('pace-unit');

    // Result
    const resLabel = document.getElementById('result-label');
    const resValue = document.getElementById('result-value');

    // Errors
    const errDist = document.getElementById('error-distance');
    const errTime = document.getElementById('error-time');
    const errPace = document.getElementById('error-pace');

    const resetBtn = document.getElementById('reset-btn');

    // State management for UI
    function updateMode() {
      const mode = modeSelect.value;

      // Reset disabled states and visual opacities
      secDist.classList.remove('disabled-section');
      secTime.classList.remove('disabled-section');
      secPace.classList.remove('disabled-section');

      distVal.disabled = false;
      timeHr.disabled = false;
      timeMin.disabled = false;
      timeSec.disabled = false;
      paceMin.disabled = false;
      paceSec.disabled = false;

      if (mode === 'pace') {
        secPace.classList.add('disabled-section');
        paceMin.disabled = true;
        paceSec.disabled = true;
        resLabel.textContent = "Calculated Pace";
      } else if (mode === 'time') {
        secTime.classList.add('disabled-section');
        timeHr.disabled = true;
        timeMin.disabled = true;
        timeSec.disabled = true;
        resLabel.textContent = "Calculated Time";
      } else if (mode === 'distance') {
        secDist.classList.add('disabled-section');
        distVal.disabled = true;
        resLabel.textContent = "Calculated Distance";
      }

      calculate();
    }

    function getDistanceInMiles() {
      let val = parseFloat(distVal.value);
      if (isNaN(val) || val <= 0) return null;

      let unit = distUnit.value;

      // Handle predefined values that were placed in the value attribute
      // If it's one of the event options, the value is already in miles
      const eventValues = ['3.10686', '6.21371', '13.1094', '26.2188'];
      if (eventValues.includes(unit)) {
        val = parseFloat(unit);
        unit = 'mi';
      }

      if (unit === 'km') return val * 0.621371;
      if (unit === 'm') return val * 0.000621371;
      return val; // mi
    }

    function getTimeInSeconds() {
      let h = parseFloat(timeHr.value) || 0;
      let m = parseFloat(timeMin.value) || 0;
      let s = parseFloat(timeSec.value) || 0;
      let total = h * 3600 + m * 60 + s;
      return total > 0 ? total : null;
    }

    function getPaceInSecondsPerMile() {
      let m = parseFloat(paceMin.value) || 0;
      let s = parseFloat(paceSec.value) || 0;
      let totalSec = m * 60 + s;
      if (totalSec <= 0) return null;

      let unit = paceUnit.value;
      if (unit === 'km') {
        // totalSec is seconds per km. Convert to seconds per mile.
        return totalSec / 0.621371;
      }
      return totalSec; // mi
    }

    function formatTime(totalSeconds) {
      if (!isFinite(totalSeconds) || totalSeconds < 0) return "--:--";
      let h = Math.floor(totalSeconds / 3600);
      let m = Math.floor((totalSeconds % 3600) / 60);
      let s = Math.round(totalSeconds % 60);

      if (s === 60) {
        s = 0;
        m++;
      }
      if (m === 60) {
        m = 0;
        h++;
      }

      let sStr = s.toString().padStart(2, '0');
      let mStr = m.toString().padStart(2, '0');

      if (h > 0) {
        return `${h}:${mStr}:${sStr}`;
      }
      return `${mStr}:${sStr}`;
    }

    function calculate() {
      const mode = modeSelect.value;

      errDist.style.display = 'none';
      errTime.style.display = 'none';
      errPace.style.display = 'none';

      let dMiles = getDistanceInMiles();
      let tSecs = getTimeInSeconds();
      let pSecsPerMile = getPaceInSecondsPerMile();

      // Auto-fill distVal if a popular event is selected
      if (['3.10686', '6.21371', '13.1094', '26.2188'].includes(distUnit.value)) {
        if (!distVal.disabled) {
           distVal.value = distUnit.value;
           distUnit.value = 'mi';
           dMiles = getDistanceInMiles();
        }
      }

      if (mode === 'pace') {
        if (dMiles && tSecs) {
          let pacePerMile = tSecs / dMiles;
          let outPace = paceUnit.value === 'km' ? pacePerMile * 0.621371 : pacePerMile;

          resValue.textContent = `${formatTime(outPace)} / ${paceUnit.value}`;
        } else {
          resValue.textContent = `--:-- / ${paceUnit.value}`;
          if ((distVal.value !== '' && !dMiles) ||
             ((timeHr.value !== '' || timeMin.value !== '' || timeSec.value !== '') && !tSecs)) {
            if (distVal.value !== '' && !dMiles) errDist.style.display = 'block';
            if ((timeHr.value !== '' || timeMin.value !== '' || timeSec.value !== '') && !tSecs) errTime.style.display = 'block';
          }
        }
      }
      else if (mode === 'time') {
        if (dMiles && pSecsPerMile) {
          let outTime = dMiles * pSecsPerMile;
          resValue.textContent = formatTime(outTime);
        } else {
          resValue.textContent = `--:--:--`;
          if ((distVal.value !== '' && !dMiles) ||
             ((paceMin.value !== '' || paceSec.value !== '') && !pSecsPerMile)) {
            if (distVal.value !== '' && !dMiles) errDist.style.display = 'block';
            if ((paceMin.value !== '' || paceSec.value !== '') && !pSecsPerMile) errPace.style.display = 'block';
          }
        }
      }
      else if (mode === 'distance') {
        if (tSecs && pSecsPerMile) {
          let distMiles = tSecs / pSecsPerMile;
          let outDist = distUnit.value === 'km' ? distMiles / 0.621371 : (distUnit.value === 'm' ? distMiles / 0.000621371 : distMiles);

          let formattedDist = new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 }).format(outDist);

          let unitLabel = 'mi';
          if(distUnit.value === 'km') unitLabel = 'km';
          if(distUnit.value === 'm') unitLabel = 'm';

          resValue.textContent = `${formattedDist} ${unitLabel}`;
        } else {
          resValue.textContent = `-- ${distUnit.value === 'mi' ? 'mi' : (distUnit.value === 'km' ? 'km' : 'm')}`;
          if (((timeHr.value !== '' || timeMin.value !== '' || timeSec.value !== '') && !tSecs) ||
             ((paceMin.value !== '' || paceSec.value !== '') && !pSecsPerMile)) {
            if ((timeHr.value !== '' || timeMin.value !== '' || timeSec.value !== '') && !tSecs) errTime.style.display = 'block';
            if ((paceMin.value !== '' || paceSec.value !== '') && !pSecsPerMile) errPace.style.display = 'block';
          }
        }
      }
    }

    // Event Listeners
    modeSelect.addEventListener('change', updateMode);

    [distVal, distUnit, timeHr, timeMin, timeSec, paceMin, paceSec, paceUnit].forEach(el => {
      el.addEventListener('input', calculate);
      el.addEventListener('change', calculate); // For selects
    });

    resetBtn.addEventListener('click', () => {
      distVal.value = '';
      distUnit.value = 'mi';
      timeHr.value = '';
      timeMin.value = '';
      timeSec.value = '';
      paceMin.value = '';
      paceSec.value = '';
      paceUnit.value = 'mi';
      modeSelect.value = 'pace';
      updateMode();
    });

    // Init
    updateMode();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }

    .calc-mode-selector { margin-bottom: 2rem; text-align: center; }
    .calc-mode-selector label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: var(--text-primary); font-size: 1.1rem; }
    .mode-select { max-width: 350px; margin: 0 auto; font-size: 1rem; padding: 0.75rem; text-align: center; font-weight: 500;}

    .calc-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: 2rem; }
    @media (min-width: 768px) {
      .calc-grid { grid-template-columns: repeat(3, 1fr); }
    }

    .calc-section { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; transition: opacity 0.3s; }
    .calc-section h3 { margin-top: 0; margin-bottom: 1rem; font-size: 1.1rem; text-align: center; color: var(--text-primary); }

    .disabled-section { opacity: 0.5; pointer-events: none; }

    .input-row { display: flex; gap: 0.5rem; flex-direction: column; }
    .time-inputs, .pace-inputs { flex-direction: row; }
    .time-inputs .input-group, .pace-inputs .input-group { flex: 1; }

    .input-group { display: flex; flex-direction: column; margin-bottom: 0.5rem; }
    .input-group label { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem; }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem; border-radius: 6px; width: 100%; font-size: 1rem; font-family: var(--font-mono); }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    input:disabled, select:disabled { background: color-mix(in srgb, var(--border-color) 20%, var(--bg-color)); cursor: not-allowed; }

    .error-msg { color: #ef4444; font-size: 0.85rem; margin-top: 0.5rem; display: none; text-align: center; font-weight: 500;}

