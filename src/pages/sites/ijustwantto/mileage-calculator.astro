  <script is:inline>
    (function() {
      var distanceInput = document.getElementById('distance');
      var fuelInput = document.getElementById('fuel');
      var priceInput = document.getElementById('price');

      var distanceError = document.getElementById('distance-error');
      var fuelError = document.getElementById('fuel-error');

      var resultMpg = document.getElementById('result-mpg');
      var resultCpm = document.getElementById('result-cpm');
      var resultTotal = document.getElementById('result-total');

      function calculate() {
        var distanceVal = distanceInput.value;
        var fuelVal = fuelInput.value;
        var priceVal = priceInput.value;

        var distance = parseFloat(distanceVal);
        var fuel = parseFloat(fuelVal);
        var price = parseFloat(priceVal);

        var hasError = false;

        if (distanceVal !== '' && (isNaN(distance) || distance <= 0)) {
          distanceError.style.display = 'block';
          hasError = true;
        } else {
          distanceError.style.display = 'none';
        }

        if (fuelVal !== '' && (isNaN(fuel) || fuel <= 0)) {
          fuelError.style.display = 'block';
          hasError = true;
        } else {
          fuelError.style.display = 'none';
        }

        if (hasError || isNaN(distance) || isNaN(fuel) || distance <= 0 || fuel <= 0) {
          resultMpg.textContent = '--';
          resultCpm.textContent = '--';
          resultTotal.textContent = '--';
          return;
        }

        var mpg = distance / fuel;
        resultMpg.textContent = mpg.toFixed(2) + ' MPG';

        if (!isNaN(price) && price > 0) {
          var totalCost = fuel * price;
          var costPerMile = totalCost / distance;

          resultCpm.textContent = '$' + costPerMile.toFixed(2);
          resultTotal.textContent = '$' + totalCost.toFixed(2);
        } else {
          resultCpm.textContent = '--';
          resultTotal.textContent = '--';
        }
      }

      distanceInput.addEventListener('input', calculate);
      fuelInput.addEventListener('input', calculate);
      priceInput.addEventListener('input', calculate);
    })();
  </script>

