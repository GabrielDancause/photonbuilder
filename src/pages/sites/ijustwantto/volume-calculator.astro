  <script is:inline>
    // Constants
    const PI = Math.PI;

    // State
    let currentShape = 'cube';

    // Elements
    const shapeBtns = document.querySelectorAll('.shape-btn');
    const inputGroups = document.querySelectorAll('.input-group');
    const calcBtn = document.getElementById('calcBtn');
    const unitSelect = document.getElementById('unit');
    const shapeModel = document.getElementById('shapeModel');
    const formulaText = document.getElementById('formulaText');
    const stepByStep = document.getElementById('stepByStep');
    const lblUnit = document.getElementById('lbl-unit');

    // FAQ Toggle
    const faqQuestions = document.querySelectorAll('.faq-question');
    faqQuestions.forEach(q => {
      q.addEventListener('click', () => {
        const answer = q.nextElementSibling;
        const icon = q.querySelector('span');
        if (answer.classList.contains('open')) {
          answer.classList.remove('open');
          icon.textContent = '+';
        } else {
          answer.classList.add('open');
          icon.textContent = '-';
        }
      });
    });

    // Shape Selection
    shapeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        shapeBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentShape = btn.dataset.shape;

        inputGroups.forEach(group => group.classList.remove('active'));
        document.getElementById('inputs-' + currentShape).classList.add('active');

        updateVisualization(currentShape);
        updateFormulaText(currentShape);
        clearResults();
      });
    });

    unitSelect.addEventListener('change', () => {
      const u = unitSelect.value;
      lblUnit.textContent = u + '³';
      calculateVolume();
    });

    function updateVisualization(shape) {
      shapeModel.innerHTML = '';
      shapeModel.className = '';

      if (shape === 'cube' || shape === 'rect') {
        shapeModel.className = 'shape-3d';
        shapeModel.innerHTML = '<div class="cube-face front">Front</div><div class="cube-face back">Back</div><div class="cube-face right">Right</div><div class="cube-face left">Left</div><div class="cube-face top">Top</div><div class="cube-face bottom">Bottom</div>';
      } else if (shape === 'cylinder' || shape === 'cone') {
        shapeModel.className = 'cylinder-3d';
        shapeModel.innerHTML = '<div class="cylinder-face cylinder-top"></div><div class="cylinder-face cylinder-bottom"></div><div class="cylinder-side"></div>';
      } else if (shape === 'sphere') {
        shapeModel.className = 'sphere-3d';
      } else if (shape === 'pyramid') {
        shapeModel.className = 'shape-3d';
        shapeModel.innerHTML = '<div class="cube-face bottom">Base</div><div class="cube-face front" style="clip-path: polygon(50% 0%, 0% 100%, 100% 100%); transform-origin: bottom; transform: translateZ(50px) rotateX(30deg);">Side</div><div class="cube-face back" style="clip-path: polygon(50% 0%, 0% 100%, 100% 100%); transform-origin: bottom; transform: rotateY(180deg) translateZ(50px) rotateX(30deg);">Side</div>';
      }
    }

    function updateFormulaText(shape) {
      const formulas = {
        cube: 'V = a³',
        rect: 'V = l × w × h',
        cylinder: 'V = π × r² × h',
        sphere: 'V = 4/3 × π × r³',
        cone: 'V = 1/3 × π × r² × h',
        pyramid: 'V = 1/3 × l × w × h'
      };
      formulaText.textContent = formulas[shape];
    }

    function clearResults() {
      document.getElementById('res-base').textContent = '0.00';
      document.getElementById('res-ft').textContent = '0.00';
      document.getElementById('res-gal').textContent = '0.00';
      document.getElementById('res-liters').textContent = '0.00';
      stepByStep.textContent = 'Waiting for input...';

      // Hide errors
      document.querySelectorAll('.error-msg').forEach(msg => msg.style.display = 'none');
    }

    function validateInput(id) {
      const el = document.getElementById(id);
      const err = document.getElementById('err-' + id);
      const val = parseFloat(el.value);
      if (isNaN(val) || val <= 0) {
        err.style.display = 'block';
        return null;
      }
      err.style.display = 'none';
      return val;
    }

    function calculateVolume() {
      let volumeBase = 0;
      let steps = '';

      if (currentShape === 'cube') {
        const a = validateInput('cube-side');
        if (a === null) return;
        volumeBase = Math.pow(a, 3);
        steps = 'V = ' + a + '³ = ' + volumeBase.toFixed(4);
      }
      else if (currentShape === 'rect') {
        const l = validateInput('rect-l');
        const w = validateInput('rect-w');
        const h = validateInput('rect-h');
        if (l === null || w === null || h === null) return;
        volumeBase = l * w * h;
        steps = 'V = ' + l + ' × ' + w + ' × ' + h + ' = ' + volumeBase.toFixed(4);
      }
      else if (currentShape === 'cylinder') {
        const r = validateInput('cyl-r');
        const h = validateInput('cyl-h');
        if (r === null || h === null) return;
        volumeBase = PI * Math.pow(r, 2) * h;
        steps = 'V = π × ' + r + '² × ' + h + ' = 3.14159 × ' + Math.pow(r,2) + ' × ' + h + ' = ' + volumeBase.toFixed(4);
      }
      else if (currentShape === 'sphere') {
        const r = validateInput('sph-r');
        if (r === null) return;
        volumeBase = (4/3) * PI * Math.pow(r, 3);
        steps = 'V = 4/3 × π × ' + r + '³ = 1.333 × 3.14159 × ' + Math.pow(r,3) + ' = ' + volumeBase.toFixed(4);
      }
      else if (currentShape === 'cone') {
        const r = validateInput('cone-r');
        const h = validateInput('cone-h');
        if (r === null || h === null) return;
        volumeBase = (1/3) * PI * Math.pow(r, 2) * h;
        steps = 'V = 1/3 × π × ' + r + '² × ' + h + ' = 0.333 × 3.14159 × ' + Math.pow(r,2) + ' × ' + h + ' = ' + volumeBase.toFixed(4);
      }
      else if (currentShape === 'pyramid') {
        const l = validateInput('pyr-l');
        const w = validateInput('pyr-w');
        const h = validateInput('pyr-h');
        if (l === null || w === null || h === null) return;
        volumeBase = (1/3) * l * w * h;
        steps = 'V = 1/3 × ' + l + ' × ' + w + ' × ' + h + ' = ' + volumeBase.toFixed(4);
      }

      // Display base volume
      document.getElementById('res-base').textContent = volumeBase.toLocaleString(undefined, {maximumFractionDigits: 2});
      stepByStep.textContent = steps;

      // Conversions based on unit input
      const u = unitSelect.value;
      let volumeInCubicMeters = 0;

      if (u === 'in') {
        volumeInCubicMeters = volumeBase * 0.0000163871;
      } else if (u === 'ft') {
        volumeInCubicMeters = volumeBase * 0.0283168;
      } else if (u === 'cm') {
        volumeInCubicMeters = volumeBase * 0.000001;
      } else if (u === 'm') {
        volumeInCubicMeters = volumeBase;
      }

      // Calculate standard outputs
      const volumeInCubicFeet = volumeInCubicMeters * 35.3147;
      const volumeInGallons = volumeInCubicMeters * 264.172;
      const volumeInLiters = volumeInCubicMeters * 1000;

      document.getElementById('res-ft').textContent = volumeInCubicFeet.toLocaleString(undefined, {maximumFractionDigits: 2});
      document.getElementById('res-gal').textContent = volumeInGallons.toLocaleString(undefined, {maximumFractionDigits: 2});
      document.getElementById('res-liters').textContent = volumeInLiters.toLocaleString(undefined, {maximumFractionDigits: 2});

      // Animate visualization based on size (pseudo-feedback)
      shapeModel.style.transform = 'scale(' + Math.min(1.2, Math.max(0.8, volumeBase / 100)) + ')';
      setTimeout(() => {
         shapeModel.style.transform = '';
      }, 500);
    }

    calcBtn.addEventListener('click', calculateVolume);

    // Add enter key support
    document.querySelectorAll('.input-field input').forEach(input => {
      input.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') calculateVolume();
      });
    });

    // Initialize
    updateVisualization('cube');
    updateFormulaText('cube');
  </script>

