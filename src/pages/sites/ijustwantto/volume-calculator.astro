      padding: 1.5rem;
      border-radius: 1rem;
      border: 1px solid var(--border-color);
      margin-bottom: 2rem;
    }
    .formula-math {
      font-family: monospace;
      font-size: 1.25rem;
      text-align: center;
      margin: 1rem 0;
      color: var(--accent-color);
    }

    .visualization {
      width: 100%;
      height: 200px;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      perspective: 800px;
      margin-bottom: 2rem;
      overflow: hidden;
      position: relative;
    }
    .shape-3d {
      width: 100px;
      height: 100px;
      transform-style: preserve-3d;
      transition: transform 1s ease-in-out;
      animation: rotate 10s infinite linear;
    }
    @keyframes rotate {
      from { transform: rotateX(0) rotateY(0); }
      to { transform: rotateX(360deg) rotateY(360deg); }
    }

    /* 3D Shape CSS (Cube example) */
    .cube-face {
      position: absolute;
      width: 100px;
      height: 100px;
      background: rgba(139, 92, 246, 0.4);
      border: 2px solid var(--accent-color);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      color: white;
      font-weight: bold;
      backdrop-filter: blur(2px);
    }
    .front  { transform: translateZ(50px); }
    .back   { transform: rotateY(180deg) translateZ(50px); }
    .right  { transform: rotateY(90deg) translateZ(50px); }
    .left   { transform: rotateY(-90deg) translateZ(50px); }
    .top    { transform: rotateX(90deg) translateZ(50px); }
    .bottom { transform: rotateX(-90deg) translateZ(50px); }

    /* Cylinder Visualization */
    .cylinder-3d {
      width: 100px;
      height: 120px;
      position: relative;
      transform-style: preserve-3d;
      animation: rotate-y 8s infinite linear;
    }
    @keyframes rotate-y {
      from { transform: rotateY(0deg) rotateX(15deg); }
      to { transform: rotateY(360deg) rotateX(15deg); }
    }
    .cylinder-face {
      position: absolute;
      background: rgba(139, 92, 246, 0.5);
      border: 1px solid var(--accent-color);
    }
    .cylinder-top, .cylinder-bottom {
      width: 100px;
      height: 100px;
      border-radius: 50%;
    }
    .cylinder-top { transform: rotateX(90deg) translateZ(60px); }
    .cylinder-bottom { transform: rotateX(90deg) translateZ(-60px); }
    .cylinder-side {
      width: 100px;
      height: 120px;
      background: linear-gradient(90deg, rgba(139,92,246,0.8), rgba(139,92,246,0.3), rgba(139,92,246,0.8));
      border: none;
      opacity: 0.8;
      border-radius: 10px; /* Approximate visual */
    }

    /* Sphere Visualization */
    .sphere-3d {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, rgba(139, 92, 246, 0.8), rgba(40, 20, 100, 0.9));
      box-shadow: inset -10px -10px 20px rgba(0,0,0,0.5), 0 10px 20px rgba(0,0,0,0.3);
      position: relative;
      animation: pulse 4s infinite alternate;
    }
    @keyframes pulse {
      from { transform: scale(1); }
      to { transform: scale(1.05); }
    }

