---

<SiteLayout
  site="ijustwantto"
  title="Stair Calculator - Calculate Rise, Run & Stringer"
  description="Calculate stair rise, run, stringer length, and steps. Check building code compliance for safe and comfortable stairs."
  canonical="https://ijustwantto.live/stair-calculator" schema={schema}
>
  <style>

        * {
