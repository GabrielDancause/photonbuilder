---
import SiteLayout from "../../../layouts/SiteLayout.astro";


export const meta = {
  title: 'DIY vs Store-Bought Products',
  description: 'Store-bought cleaners offer convenience and specific chemical actions, while DIY options (vinegar, baking soda, lemon) are eco-friendly, cost-effective, and safe for most surfaces.',
  category: 'guide',
};

const kitchenChecklist = [
  { task: "Oven", detail: "Apply baking soda paste overnight, scrub interior, wipe down glass, clean racks.", frequency: "Seasonal", method: "Deep Clean" },
  { task: "Refrigerator", detail: "Empty all shelves, wash drawers with soapy water, wipe down interior walls, vacuum coils behind.", frequency: "Seasonal", method: "Deep Clean" },
  { task: "Grout & Tile", detail: "Scrub with a stiff brush and hydrogen peroxide/baking soda mix.", frequency: "Monthly", method: "Deep Clean" },
  { task: "Microwave", detail: "Steam clean with a bowl of water and lemon slices for 5 minutes, wipe down.", frequency: "Weekly", method: "Speed Cleaning" },
  { task: "Cabinets", detail: "Wipe down cabinet fronts and hardware with degreaser or soapy water.", frequency: "Monthly", method: "Deep Clean" }
];

const bathroomChecklist = [
  { task: "Shower Tile & Grout", detail: "Spray with white vinegar, let sit 15 mins, scrub grout lines with a toothbrush.", frequency: "Monthly", method: "Deep Clean" },
  { task: "Toilet", detail: "Clean inside bowl, base, under the seat, and behind the tank.", frequency: "Weekly", method: "Deep Clean" },
  { task: "Mold & Mildew", detail: "Treat spots with hydrogen peroxide or a bleach solution; ensure good ventilation.", frequency: "Seasonal", method: "Deep Clean" },
  { task: "Mirrors", detail: "Wipe with a microfiber cloth and glass cleaner (or vinegar/water mix) for a streak-free shine.", frequency: "Weekly", method: "Speed Cleaning" },
  { task: "Exhaust Fan", detail: "Vacuum dust from the cover, wipe down with a damp cloth.", frequency: "Seasonal", method: "Deep Clean" }
];

const bedroomChecklist = [
  { task: "Mattress", detail: "Vacuum the surface, sprinkle with baking soda, let sit for 1 hour, vacuum again.", frequency: "Seasonal", method: "Deep Clean" },
  { task: "Curtains & Blinds", detail: "Wash curtains according to care tag; wipe blinds with a microfiber duster.", frequency: "Seasonal", method: "Deep Clean" },
  { task: "Under Bed", detail: "Declutter items stored underneath, vacuum dust bunnies.", frequency: "Monthly", method: "Declutter First" },
  { task: "Closet", detail: "Take out all clothes, wipe down shelves, donate unwanted items, reorganize.", frequency: "Seasonal", method: "Declutter First" },
  { task: "Baseboards", detail: "Wipe down with a damp soapy rag or dryer sheet to repel dust.", frequency: "Monthly", method: "Deep Clean" }
];

const livingRoomChecklist = [
  { task: "Upholstery", detail: "Vacuum couch cushions, spot treat stains, wash removable covers.", frequency: "Seasonal", method: "Deep Clean" },
  { task: "Baseboards", detail: "Dust and wipe down with a damp microfiber cloth.", frequency: "Monthly", method: "Deep Clean" },
  { task: "Carpets & Rugs", detail: "Move furniture, vacuum thoroughly, and shampoo or steam clean.", frequency: "Seasonal", method: "Deep Clean" },
  { task: "Electronics", detail: "Dust TV screens and consoles with a dry microfiber cloth.", frequency: "Weekly", method: "Speed Cleaning" },
  { task: "Ceiling Fans", detail: "Use a pillowcase to trap dust off fan blades, then wipe down.", frequency: "Monthly", method: "Deep Clean" }
];

const guides = [
  { title: "DIY vs Store-Bought Products", description: "Store-bought cleaners offer convenience and specific chemical actions, while DIY options (vinegar, baking soda, lemon) are eco-friendly, cost-effective, and safe for most surfaces." },
  { title: "Microfiber Cloth System", description: "Color-code your microfiber cloths (e.g., blue for glass, yellow for bathroom, green for kitchen) to prevent cross-contamination. Wash them without fabric softener to maintain absorbency." },
  { title: "Eco-Friendly Cleaning", description: "Opt for natural ingredients like white vinegar for glass and descaling, baking soda for gentle scrubbing, and castile soap for all-purpose cleaning to reduce harsh chemicals in your home." }
];

const faqs = [
  { q: "What is the decluttering first approach?", a: "Before you start cleaning, remove items that don't belong in the room, throw away trash, and put away things that are out of place. This clears the surfaces so you can actually clean them without moving clutter around." },
  { q: "What is the speed cleaning method?", a: "Speed cleaning involves setting a timer (e.g., 15 minutes), focusing on high-impact areas, carrying all your supplies in a caddy, and working top-to-bottom, left-to-right to maximize efficiency." },
  { q: "How do I create a realistic cleaning schedule?", a: "Break tasks into daily (dishes, wipe counters), weekly (vacuum, clean bathrooms), monthly (clean baseboards, wash windows), and seasonal (deep clean oven, shampoo carpets) routines." },
  { q: "Is DIY cleaner as effective as store-bought?", a: "For most everyday dirt, grease, and grime, DIY cleaners using vinegar, baking soda, and soap are highly effective. However, for serious disinfecting (like raw meat spills or heavy mold), commercial disinfectants or bleach may be required." },
  { q: "How often should I deep clean my mattress?", a: "You should deep clean your mattress at least twice a year. Vacuum it, treat any stains, and deodorize it with baking soda to extend its life and reduce allergens." }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Ultimate Deep Cleaning Checklist: Room-by-Room Guide",
    "description": "Master your home maintenance with our ultimate room-by-room deep cleaning checklist. Discover tips for the kitchen, bathroom, bedroom, and living room.",
    "author": {
      "@type": "Organization",
      "name": "I Just Want To"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  }
];
---
<SiteLayout
  site="ijustwantto"
  title="Ultimate Deep Cleaning Checklist: Room-by-Room Guide"
  description="Master your home maintenance with our ultimate room-by-room deep cleaning checklist. Discover tips for the kitchen, bathroom, bedroom, and living room."
  canonical="https://ijustwantto.live/deep-cleaning-checklist"
  schema={JSON.stringify(schema)}
>
  <div class="page-wrapper">
    <div class="hero">
      <h1>Ultimate Deep Cleaning Checklist</h1>
      <p>Master your home maintenance with our ultimate room-by-room deep cleaning checklist, featuring DIY eco-friendly options, speed cleaning techniques, and a comprehensive cleaning schedule.</p>
    </div>

    <section class="content-section">
      <div class="page-content">

        <h2>Kitchen Checklist</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Task</th>
                <th>Detail</th>
                <th>Frequency</th>
                <th>Method</th>
              </tr>
            </thead>
            <tbody>
              {kitchenChecklist.map(item => (
                <tr>
                  <td><strong>{item.task}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.frequency}</td>
                  <td>{item.method}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Bathroom Checklist</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Task</th>
                <th>Detail</th>
                <th>Frequency</th>
                <th>Method</th>
              </tr>
            </thead>
            <tbody>
              {bathroomChecklist.map(item => (
                <tr>
                  <td><strong>{item.task}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.frequency}</td>
                  <td>{item.method}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Bedroom Checklist</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Task</th>
                <th>Detail</th>
                <th>Frequency</th>
                <th>Method</th>
              </tr>
            </thead>
            <tbody>
              {bedroomChecklist.map(item => (
                <tr>
                  <td><strong>{item.task}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.frequency}</td>
                  <td>{item.method}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Living Room Checklist</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Task</th>
                <th>Detail</th>
                <th>Frequency</th>
                <th>Method</th>
              </tr>
            </thead>
            <tbody>
              {livingRoomChecklist.map(item => (
                <tr>
                  <td><strong>{item.task}</strong></td>
                  <td>{item.detail}</td>
                  <td>{item.frequency}</td>
                  <td>{item.method}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Cleaning Guides & Methods</h2>
        <div class="winners-grid">
          {guides.map(guide => (
            <div class="winner-card">
              <span class="winner-label">Guide</span>
              <strong>{guide.title}</strong>
              <span class="winner-reason">{guide.description}</span>
            </div>
          ))}
        </div>

        <h2>Frequently Asked Questions</h2>
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .page-wrapper {
    --text-primary: #1f2937;
    --text-secondary: #4b5563;
    --accent-color: #3b82f6;
    --card-bg: #ffffff;
    --border-color: #e5e7eb;
    --bg-color: #f9fafb;

    font-family: system-ui, -apple-system, sans-serif;
    color: var(--text-primary);
    background-color: var(--bg-color);
  }

  .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
  .hero { text-align: center; padding: 3rem 0 2rem; }
  .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
  .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

  .content-section { margin-bottom: 3rem; }
  .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
  .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
  .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

  .content-section ul { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; padding-left: 1.5rem; }
  .content-section li { margin-bottom: 0.5rem; }

  strong { color: var(--text-primary); }

  /* Winners Grid */
  .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
  .winner-card strong { font-size: 1.05rem; }
  .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

  /* Comparison Table */
  .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
  td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--card-bg); }

  /* FAQ */
  .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
  .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
  .faq-item p { margin-bottom: 0; }

  @media (max-width: 600px) {
    .hero h1 { font-size: 1.6rem; }
    .winners-grid { grid-template-columns: 1fr; }
  }
</style>
