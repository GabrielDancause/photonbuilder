  <div class="container">
    <h1>Wallpaper Calculator</h1>
    <p class="subtitle">Calculate how much wallpaper you need — total wall area, rolls required, and material cost</p>

    <main>
      <div class="card">
        <h2>Room Dimensions</h2>

        <div class="unit-toggle">
