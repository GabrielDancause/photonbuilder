    </main>
  </div>

  <script is:inline>
    var ROLL_PRESETS = [
      { label: "US Standard", w: 20.5, l: 33, sub: '20.5" × 33 ft' },
      { label: "European", w: 21, l: 33, sub: '21" × 33 ft' },
      { label: "Custom", w: 0, l: 0, sub: "Enter below" }
    ];

    var openings = [];
    var currentUnit = "ft";

    // Build roll size buttons
    var rollEl = document.getElementById("rollSizes");
    ROLL_PRESETS.forEach(function(r, i) {
      var b = document.createElement("button");
      b.type = "button";
      b.className = "roll-btn" + (i === 0 ? " active" : "");
      b.innerHTML = '<span class="size-label">' + r.label + '</span><span class="size-sub">' + r.sub + '</span>';
      b.addEventListener("click", function() {
        rollEl.querySelectorAll(".roll-btn").forEach(function(x) { x.classList.remove("active"); });
        b.classList.add("active");
        if (r.w > 0) {
          document.getElementById("rollWidth").value = r.w;
          document.getElementById("rollLength").value = r.l;
        }
      });
      rollEl.appendChild(b);
    });

    // Unit toggle
    document.querySelectorAll(".unit-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        currentUnit = this.dataset.unit;
        document.querySelectorAll(".unit-btn").forEach(function(b) { b.classList.remove("active"); });
        this.classList.add("active");
        var lbl = currentUnit;
        document.getElementById("unitLabelL").textContent = lbl;
        document.getElementById("unitLabelW").textContent = lbl;
        document.getElementById("unitLabelH").textContent = lbl;
        document.getElementById("unitLabelOW").textContent = lbl;
        document.getElementById("unitLabelOH").textContent = lbl;
      });
    });

    // Openings management
    function renderOpenings() {
      var list = document.getElementById("openingList");
      list.innerHTML = "";
      openings.forEach(function(o, idx) {
        var area = o.w * o.h;
        var unitLabel = o.unit === "m" ? "m" : "ft";
        var areaLabel = o.unit === "m" ? " m\u00B2" : " sq ft";
        var div = document.createElement("div");
        div.className = "opening-item";
        div.innerHTML = '<span class="opening-info">' + o.type.charAt(0).toUpperCase() + o.type.slice(1) +
          ' — ' + o.w + ' × ' + o.h + ' ' + unitLabel + '</span>' +
          '<span class="opening-area">' + area.toFixed(1) + areaLabel + '</span>' +
          '<button type="button" class="remove-btn" data-idx="' + idx + '">×</button>';
        list.appendChild(div);
      });
      list.querySelectorAll(".remove-btn").forEach(function(btn) {
        btn.addEventListener("click", function() {
          openings.splice(parseInt(this.dataset.idx), 1);
          renderOpenings();
        });
      });
    }

    document.getElementById("addOpeningBtn").addEventListener("click", function() {
      var type = document.getElementById("openingType").value;
      var w = parseFloat(document.getElementById("openingW").value);
      var h = parseFloat(document.getElementById("openingH").value);
      if (isNaN(w) || isNaN(h) || w <= 0 || h <= 0) return;
      openings.push({ type: type, w: w, h: h, unit: currentUnit });
      renderOpenings();
    });

    function fmt(n) { return "$" + n.toFixed(2); }

    document.getElementById("calcBtn").addEventListener("click", function() {
      var roomL = parseFloat(document.getElementById("roomLength").value);
      var roomW = parseFloat(document.getElementById("roomWidth").value);
      var roomH = parseFloat(document.getElementById("roomHeight").value);
      var rollWidthIn = parseFloat(document.getElementById("rollWidth").value);
      var rollLengthFt = parseFloat(document.getElementById("rollLength").value);
      var patternRepeatIn = parseFloat(document.getElementById("patternRepeat").value) || 0;
      var wastePercent = parseFloat(document.getElementById("wasteFactor").value) / 100;
      var pricePerRoll = parseFloat(document.getElementById("pricePerRoll").value) || 0;

      if (isNaN(roomL) || isNaN(roomW) || isNaN(roomH) || roomL <= 0 || roomW <= 0 || roomH <= 0) return;

      // Convert to feet if in meters
      var L = roomL, W = roomW, H = roomH;
      if (currentUnit === "m") {
        L *= 3.28084; W *= 3.28084; H *= 3.28084;
      }

      // Total wall area (perimeter × height)
      var perimeter = 2 * (L + W);
      var grossWallArea = perimeter * H;

      // Subtract openings
      var totalOpeningArea = 0;
      openings.forEach(function(o) {
        var area = o.w * o.h;
        if (o.unit === "m") area *= 10.7639;
        totalOpeningArea += area;
      });
      var usableArea = Math.max(0, grossWallArea - totalOpeningArea);

      // Roll coverage calculation
      var rollWidthFt = rollWidthIn / 12;
      var rollLengthIn = rollLengthFt * 12;
      var wallHeightIn = H * 12;

      // Strip height: wall height + 4 inches for trimming
      var stripHeight = wallHeightIn + 4;

      // If pattern repeat, adjust strip height
      if (patternRepeatIn > 0) {
        stripHeight = Math.ceil(stripHeight / patternRepeatIn) * patternRepeatIn;
      }

      // Number of strips per roll
      var stripsPerRoll = Math.floor(rollLengthIn / stripHeight);
      if (stripsPerRoll < 1) stripsPerRoll = 1;

      // Coverage per roll (usable)
      var coveragePerRoll = stripsPerRoll * rollWidthFt * H;

      // Total strips needed to cover the perimeter
      var totalStripsNeeded = Math.ceil(perimeter / rollWidthFt);

      // Rolls needed (before waste)
      var rollsRaw = totalStripsNeeded / stripsPerRoll;
      // Apply the area reduction for openings
      var areaRatio = grossWallArea > 0 ? usableArea / grossWallArea : 1;
      var rollsAdjusted = rollsRaw * areaRatio;
      // Add waste
      var rollsNeeded = Math.ceil(rollsAdjusted * (1 + wastePercent));
      if (rollsNeeded < 1) rollsNeeded = 1;

      // Display results
      document.getElementById("rWallArea").textContent = grossWallArea.toFixed(1);
      document.getElementById("rWallAreaDesc").textContent = "sq ft" + (currentUnit === "m" ? " (" + (2 * (roomL + roomW) * roomH).toFixed(1) + " m\u00B2)" : "");
      document.getElementById("rUsableArea").textContent = usableArea.toFixed(1);
      document.getElementById("rUsableAreaDesc").textContent = totalOpeningArea > 0 ? (totalOpeningArea.toFixed(1) + " sq ft subtracted") : "no openings subtracted";
      document.getElementById("rRolls").textContent = rollsNeeded;
      document.getElementById("rRollsDesc").textContent = "single rolls (" + Math.ceil(rollsNeeded / 2) + " double rolls)";
      document.getElementById("rStrips").textContent = stripsPerRoll;
      document.getElementById("rStripsDesc").textContent = (stripHeight / 12).toFixed(1) + " ft per strip";

      // Cost breakdown
      var wallpaperCost = rollsNeeded * pricePerRoll;
      var pasteCost = usableArea * 0.10;
      var toolsCost = 25;
      var totalCost = wallpaperCost + pasteCost + toolsCost;

      document.getElementById("cRolls").textContent = rollsNeeded + " rolls";
      document.getElementById("cWallpaper").textContent = fmt(wallpaperCost);
      document.getElementById("cPaste").textContent = fmt(pasteCost);
      document.getElementById("cTools").textContent = fmt(toolsCost);
      document.getElementById("cTotal").textContent = fmt(totalCost);
      document.getElementById("costBreakdown").style.display = pricePerRoll > 0 ? "block" : "none";

      document.getElementById("results").classList.add("active");
    });
  </script>

  <!-- Related Tools -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">Related Tools</p>
      <div class="grid gap-3">
        <a href="/tile-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Tile Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Calculate how many tiles you need for floors and walls →</p>
        </a>
        <a href="/paint-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Paint Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Estimate how much paint you need for any room →</p>
        </a>
      </div>
    </div>
  </div>
</SiteLayout>
