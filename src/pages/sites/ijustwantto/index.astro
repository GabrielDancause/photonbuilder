---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "I Just Want To — Construction & Home Improvement",
  "url": "https://ijustwantto.live/",
  "description": "Free construction calculators for contractors and DIYers. Get the math right so you can get back to building."
};
---

<SiteLayout
  site="ijustwantto"
  title="I Just Want To — Construction & Home Improvement"
  description="Free construction calculators for contractors and DIYers. Get the math right so you can get back to building."
  canonical="https://ijustwantto.live/"
  schema={schema}
>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Construction & Home Improvement</div>
      <h1>I Just Want To</h1>
      <p>Free construction calculators for contractors and DIYers. Get the math right so you can get back to building.</p>
    </div>
  </div>

  <!-- Pillar Guides -->
  <div class="section-container" id="pillars">
    <div class="section-header">
      <span class="section-tag">📚 PILLAR GUIDES</span>
      <h2 class="section-title">Complete Guides</h2>
      <p class="section-sub">Comprehensive, in-depth guides covering entire topics.</p>
    </div>
    <div class="tools-grid">
      <a class="tool-card" href="/guide-energy-complete"><span class="tool-emoji">📚</span><h3 class="tool-name">Guide Energy Complete</h3><p class="tool-desc">Comprehensive guide covering everything you need to know</p></a>
      <a class="tool-card" href="/guide-exterior-complete"><span class="tool-emoji">📚</span><h3 class="tool-name">Guide Exterior Complete</h3><p class="tool-desc">Comprehensive guide covering everything you need to know</p></a>
      <a class="tool-card" href="/guide-materials-complete"><span class="tool-emoji">📚</span><h3 class="tool-name">Guide Materials Complete</h3><p class="tool-desc">Comprehensive guide covering everything you need to know</p></a>
    </div>
  </div>

  <!-- Tools -->
  <div class="section-container" id="tools">
    <div class="section-header">
      <span class="section-tag">🛠️ TOOLS</span>
      <h2 class="section-title">Calculators & Tools</h2>
      <p class="section-sub">Free, instant calculators — no sign-ups required.</p>
    </div>
    <div class="tools-grid">
      <a class="tool-card" href="/btu-calculator"><span class="tool-emoji">🌡️</span><h3 class="tool-name">BTU Calculator</h3><p class="tool-desc">Calculate and analyze btu calculator</p></a>
      <a class="tool-card" href="/concrete-calculator"><span class="tool-emoji">🧱</span><h3 class="tool-name">Concrete Calculator</h3><p class="tool-desc">Calculate and analyze concrete calculator</p></a>
      <a class="tool-card" href="/deck-calculator"><span class="tool-emoji">🪵</span><h3 class="tool-name">Deck Calculator</h3><p class="tool-desc">Calculate and analyze deck calculator</p></a>
      <a class="tool-card" href="/drywall-calculator"><span class="tool-emoji">🧱</span><h3 class="tool-name">Drywall Calculator</h3><p class="tool-desc">Calculate and analyze drywall calculator</p></a>
      <a class="tool-card" href="/electricity-cost-calculator"><span class="tool-emoji">⚡</span><h3 class="tool-name">Electricity Cost Calculator</h3><p class="tool-desc">Calculate and analyze electricity cost calculator</p></a>
      <a class="tool-card" href="/fence-calculator"><span class="tool-emoji">🏡</span><h3 class="tool-name">Fence Calculator</h3><p class="tool-desc">Calculate and analyze fence calculator</p></a>
      <a class="tool-card" href="/gravel-calculator"><span class="tool-emoji">🪨</span><h3 class="tool-name">Gravel Calculator</h3><p class="tool-desc">Calculate and analyze gravel calculator</p></a>
      <a class="tool-card" href="/lumber-calculator"><span class="tool-emoji">🪵</span><h3 class="tool-name">Lumber Calculator</h3><p class="tool-desc">Calculate and analyze lumber calculator</p></a>
      <a class="tool-card" href="/mulch-calculator"><span class="tool-emoji">🌿</span><h3 class="tool-name">Mulch Calculator</h3><p class="tool-desc">Calculate and analyze mulch calculator</p></a>
      <a class="tool-card" href="/paint-calculator"><span class="tool-emoji">🎨</span><h3 class="tool-name">Paint Calculator</h3><p class="tool-desc">Calculate and analyze paint calculator</p></a>
      <a class="tool-card" href="/roof-pitch"><span class="tool-emoji">📐</span><h3 class="tool-name">Roof Pitch</h3><p class="tool-desc">Calculate and analyze roof pitch</p></a>
      <a class="tool-card" href="/solar-calculator"><span class="tool-emoji">☀️</span><h3 class="tool-name">Solar Calculator</h3><p class="tool-desc">Calculate and analyze solar calculator</p></a>
      <a class="tool-card" href="/sqft-calculator"><span class="tool-emoji">📐</span><h3 class="tool-name">Sqft Calculator</h3><p class="tool-desc">Calculate and analyze sqft calculator</p></a>
      <a class="tool-card" href="/stair-calculator"><span class="tool-emoji">🪜</span><h3 class="tool-name">Stair Calculator</h3><p class="tool-desc">Calculate and analyze stair calculator</p></a>
      <a class="tool-card" href="/tile-calculator"><span class="tool-emoji">🔲</span><h3 class="tool-name">Tile Calculator</h3><p class="tool-desc">Calculate and analyze tile calculator</p></a>
    </div>
  </div>

  <!-- Studies -->
  <div class="section-container" id="studies">
    <div class="section-header">
      <span class="section-tag">🔬 STUDIES</span>
      <h2 class="section-title">Original Research</h2>
      <p class="section-sub">Data-driven analysis and insights.</p>
    </div>
    <div class="guides-grid">
      <a class="guide-card" href="/electricity-costs"><span class="section-tag" style="margin-bottom: 8px;">RESEARCH</span><h3 class="guide-name">Electricity Costs</h3><p class="guide-desc">Data-driven analysis and research</p></a>
    </div>
  </div>

  <!-- Guides -->
  <div class="section-container" id="guides">
    <div class="section-header">
      <span class="section-tag">📚 GUIDES</span>
      <h2 class="section-title">How-To Guides</h2>
      <p class="section-sub">Step-by-step guides to get the job done right.</p>
    </div>
    <div class="guides-grid">
      <a class="guide-card" href="/guide-insulation"><span class="guide-emoji">🏠</span><h3 class="guide-name">Guide Insulation</h3><p class="guide-desc">Step-by-step guide</p></a>
      <a class="guide-card" href="/guide-paint-room"><span class="guide-emoji">🎨</span><h3 class="guide-name">Guide Paint Room</h3><p class="guide-desc">Step-by-step guide</p></a>
    </div>
  </div>

  <!-- Lists -->
  <div class="section-container" id="lists">
    <div class="section-header">
      <span class="section-tag">📋 LISTS</span>
      <h2 class="section-title">Curated Lists</h2>
      <p class="section-sub">The best tools, products, and resources.</p>
    </div>
    <div class="lists-grid">
      <a class="list-card" href="/list-air-purifiers"><span class="list-emoji">🌬️</span><h3 class="list-name">List Air Purifiers</h3><p class="list-desc">Curated comparison and rankings</p></a>
      <a class="list-card" href="/list-home-tools"><span class="list-emoji">🛠️</span><h3 class="list-name">List Home Tools</h3><p class="list-desc">Curated comparison and rankings</p></a>
    </div>
  </div>
</SiteLayout>

<style>
  .hero { text-align: center; padding: 100px 24px 70px; position: relative; }
  .hero::before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--accent-color) 8%, transparent) 0%, transparent 60%); }
  .hero-content { position: relative; z-index: 1; }
  .hero .tagline { color: var(--accent-color); font-size: .85rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 16px; }
  .hero h1 { font-size: 3rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 20px; background: linear-gradient(135deg, #fff, var(--accent-color)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-align: left; }
  .hero p { color: #5a6a80; font-size: 1.05rem; max-width: 540px; margin: 0 auto; }
  .section-container { max-width: 1200px; margin: 0 auto; padding: 60px 24px; }
  .section-header { text-align: center; margin-bottom: 40px; }
  .section-tag { display: inline-block; background: color-mix(in srgb, var(--accent-color) 10%, transparent); color: var(--accent-color); font-size: .7rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1px; margin-bottom: 12px; }
  .section-title { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 8px; letter-spacing: -.8px; }
  .section-sub { color: #5a6a80; font-size: 1rem; }
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .tool-card { background: #0c1218; border: 1px solid #1a2230; border-radius: 12px; padding: 20px; text-decoration: none; color: inherit; display: block; transition: all .2s ease; }
  .tool-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .tool-emoji { font-size: 1.4rem; margin-bottom: 8px; display: block; }
  .tool-name { font-size: .95rem; font-weight: 700; color: #e0e8f0; margin-bottom: 6px; }
  .tool-desc { font-size: .8rem; color: #6a7a90; line-height: 1.4; }
  .guides-grid, .lists-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
  .guide-card, .list-card { background: #0c1218; border: 1px solid #1a2230; border-radius: 14px; padding: 24px 20px; text-decoration: none; color: inherit; display: block; transition: all .2s ease; }
  .guide-card:hover, .list-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .guide-emoji, .list-emoji { font-size: 1.5rem; margin-bottom: 10px; display: block; }
  .guide-name, .list-name { font-size: 1rem; font-weight: 700; color: #e0e8f0; margin-bottom: 6px; }
  .guide-desc, .list-desc { font-size: .85rem; color: #6a7a90; line-height: 1.4; }
  @media (max-width: 768px) {
    .hero h1 { font-size: 2.2rem; }
    .hero { padding: 70px 20px 50px; }
    .section-container { padding: 40px 20px; }
    .tools-grid, .guides-grid, .lists-grid { grid-template-columns: 1fr; }
  }
</style>
