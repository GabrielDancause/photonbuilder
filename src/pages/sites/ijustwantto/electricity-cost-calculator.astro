---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Electricity Cost Calculator",
      "url": "https://ijustwantto.live/electricity-cost-calculator",
      "description": "Calculate your electricity costs per appliance and estimate your total household electricity bill.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How is electricity cost calculated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Electricity cost is calculated by multiplying the appliance's power consumption in kilowatts (kW) by the hours of use, and then multiplying that by your local electricity rate per kilowatt-hour (kWh)."
          }
        },
        {
          "@type": "Question",
          "name": "What appliances use the most electricity?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Typically, heating and cooling systems (like ACs and space heaters), water heaters, and large appliances like electric dryers and EV chargers consume the most electricity in a household."
          }
        },
        {
          "@type": "Question",
          "name": "How can I reduce my electricity bill?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can reduce your electricity bill by using energy-efficient appliances (like LED lights), unplugging devices when not in use, running major appliances during off-peak hours, and adjusting your thermostat."
          }
        },
        {
          "@type": "Question",
          "name": "What is a kilowatt-hour (kWh)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A kilowatt-hour (kWh) is a unit of energy equal to one kilowatt (1,000 watts) of power used for one hour. It is the standard billing unit used by utility companies."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my electricity bill so high in the summer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "High summer electricity bills are usually due to increased use of air conditioning, which requires a significant amount of energy to cool your home against the outside heat."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="ijustwantto"
  title="Electricity Cost Calculator | Estimate Household Appliance Bills"
  description="Calculate your household electricity costs. Compare appliance usage, estimate your monthly electric bill, and find ways to save energy."
  canonical="https://ijustwantto.live/electricity-cost-calculator"
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-5 py-12">
    <h1 class="text-3xl font-bold text-[var(--accent-color)] mb-2 text-center">Electricity Cost Calculator</h1>
    <p class="text-center text-[var(--text-secondary)] mb-8">Estimate your daily, monthly, and yearly electricity costs per appliance.</p>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-8">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">1. Set Electricity Rate</h2>

      <div class="mb-4">
        <label for="rate-input" class="block text-white mb-2 font-mono">Electricity Rate ($/kWh)</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-secondary)] font-mono">$</span>
          <input type="number" id="rate-input" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 pl-8 text-white font-mono" value="0.16" min="0" step="0.01">
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <button class="rate-preset text-xs font-mono bg-green-500/10 text-green-400 px-3 py-1.5 rounded border border-green-500/20 hover:bg-green-500/20 transition-colors" data-rate="0.16">US Avg ($0.16)</button>
        <button class="rate-preset text-xs font-mono bg-blue-500/10 text-blue-400 px-3 py-1.5 rounded border border-blue-500/20 hover:bg-blue-500/20 transition-colors" data-rate="0.13">Canada Avg ($0.13)</button>
        <button class="rate-preset text-xs font-mono bg-yellow-500/10 text-yellow-400 px-3 py-1.5 rounded border border-yellow-500/20 hover:bg-yellow-500/20 transition-colors" data-rate="0.28">EU Avg ($0.28)</button>
      </div>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-8">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">2. Add Appliances</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label for="preset-appliance" class="block text-white mb-2 font-mono text-sm">Preset Appliances</label>
          <select id="preset-appliance" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono">
            <option value="">-- Select Preset --</option>
            <option value="AC" data-watts="1500">Air Conditioner (1500W)</option>
            <option value="Space Heater" data-watts="1500">Space Heater (1500W)</option>
            <option value="Fridge" data-watts="150">Refrigerator (150W)</option>
            <option value="Washing Machine" data-watts="500">Washing Machine (500W)</option>
            <option value="Dryer" data-watts="3000">Clothes Dryer (3000W)</option>
            <option value="Dishwasher" data-watts="1800">Dishwasher (1800W)</option>
            <option value="TV" data-watts="100">Television (100W)</option>
            <option value="Gaming PC" data-watts="500">Gaming PC (500W)</option>
            <option value="Laptop" data-watts="60">Laptop (60W)</option>
            <option value="LED Light" data-watts="10">LED Light Bulb (10W)</option>
            <option value="Microwave" data-watts="1000">Microwave (1000W)</option>
            <option value="EV Charger" data-watts="7200">EV Charger (7200W)</option>
          </select>
        </div>

        <div class="flex items-end">
          <button id="add-preset-btn" class="w-full bg-[var(--accent-color)] text-[var(--bg-color)] font-bold py-3 px-4 rounded-lg hover:opacity-90 transition-opacity">Add Preset</button>
        </div>
      </div>

      <div class="border-t border-[var(--border-color)] my-6 relative">
        <span class="absolute left-1/2 -translate-x-1/2 -top-3 bg-[var(--card-bg)] px-3 text-[var(--text-secondary)] text-sm font-mono">OR CUSTOM</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <div>
          <label for="custom-name" class="block text-white mb-2 font-mono text-sm">Name</label>
          <input type="text" id="custom-name" placeholder="e.g. Aquarium" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono">
        </div>
        <div>
          <label for="custom-watts" class="block text-white mb-2 font-mono text-sm">Wattage (W)</label>
          <input type="number" id="custom-watts" placeholder="e.g. 200" min="0" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono">
        </div>
        <div>
          <label for="custom-hours" class="block text-white mb-2 font-mono text-sm">Hours/Day</label>
          <input type="number" id="custom-hours" placeholder="e.g. 24" min="0" max="24" step="0.5" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono">
        </div>
      </div>
      <button id="add-custom-btn" class="w-full bg-transparent border border-[var(--accent-color)] text-[var(--accent-color)] font-bold py-3 px-4 rounded-lg hover:bg-[var(--accent-color)] hover:text-[var(--bg-color)] transition-colors">Add Custom Appliance</button>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-8">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">3. Cost Breakdown</h2>

      <div id="appliance-list" class="space-y-3 mb-6">
        <!-- Appliances will be injected here -->
        <p id="empty-state" class="text-center text-[var(--text-secondary)] py-4 font-mono italic">No appliances added yet.</p>
      </div>

      <div class="border-t border-[var(--border-color)] pt-6 mt-6">
        <h3 class="text-xl font-bold text-white mb-4">Total Estimate</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4 text-center">
            <span class="block text-[var(--text-secondary)] text-sm mb-1">Daily</span>
            <span id="total-daily" class="block text-2xl font-mono text-white font-bold">$0.00</span>
          </div>
          <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4 text-center">
            <span class="block text-[var(--text-secondary)] text-sm mb-1">Monthly</span>
            <span id="total-monthly" class="block text-2xl font-mono text-[var(--accent-color)] font-bold">$0.00</span>
          </div>
          <div class="bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4 text-center">
            <span class="block text-[var(--text-secondary)] text-sm mb-1">Yearly</span>
            <span id="total-yearly" class="block text-2xl font-mono text-white font-bold">$0.00</span>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-12 hidden" id="chart-container-wrapper">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Top Consumers</h2>
      <div class="h-[400px]">
        <canvas id="costChart"></canvas>
      </div>
    </div>

    <div class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Tips for Reducing Electricity Costs</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="font-bold text-white mb-2">Upgrade to LED Lighting</h3>
          <p class="text-[var(--text-secondary)] text-sm">LED bulbs use up to 90% less energy than incandescent bulbs and last 25 times longer, providing significant long-term savings.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="font-bold text-white mb-2">Slay "Vampire" Power</h3>
          <p class="text-[var(--text-secondary)] text-sm">Electronics plugged in on standby still draw power. Use smart power strips to cut off electricity to devices not in active use.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="font-bold text-white mb-2">Optimize Climate Control</h3>
          <p class="text-[var(--text-secondary)] text-sm">Adjusting your thermostat by just 1-2 degrees can reduce heating and cooling costs significantly. Use a programmable thermostat.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="font-bold text-white mb-2">Run Large Appliances at Night</h3>
          <p class="text-[var(--text-secondary)] text-sm">If your utility company offers time-of-use rates, running the dishwasher or laundry during off-peak hours can lower your rate.</p>
        </div>
      </div>
    </div>

    <div class="mb-12 bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Methodology</h2>
      <p class="text-[var(--text-secondary)] mb-3">Our calculator uses standard formulas to estimate your electricity costs:</p>
      <ul class="list-disc pl-5 text-[var(--text-secondary)] space-y-2 font-mono text-sm">
        <li>Daily Cost = (Wattage × Hours Used / 1000) × Electricity Rate</li>
        <li>Monthly Cost = Daily Cost × 30.4 (average days in a month)</li>
        <li>Yearly Cost = Daily Cost × 365</li>
      </ul>
      <p class="text-[var(--text-secondary)] mt-4 text-sm">Note: Actual consumption varies by appliance age, efficiency rating, and exact usage patterns. Appliances with thermostats (like fridges and ACs) cycle on and off, so they do not draw maximum wattage continuously. For best estimates on cycling appliances, enter the estimated active hours rather than total hours plugged in.</p>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-4 group">
          <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
            How is electricity cost calculated?
            <span class="text-[var(--accent-color)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-[var(--text-secondary)]">Electricity cost is calculated by multiplying the appliance's power consumption in kilowatts (kW) by the hours of use, and then multiplying that by your local electricity rate per kilowatt-hour (kWh). The formula is: Cost = (Watts / 1000) × Hours × Rate.</p>
        </details>

        <details class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-4 group">
          <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
            What appliances use the most electricity?
            <span class="text-[var(--accent-color)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-[var(--text-secondary)]">Typically, heating and cooling systems (like ACs and space heaters), water heaters, and large appliances like electric dryers and EV chargers consume the most electricity in a household due to their high wattage requirements.</p>
        </details>

        <details class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-4 group">
          <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
            How can I reduce my electricity bill?
            <span class="text-[var(--accent-color)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-[var(--text-secondary)]">You can reduce your electricity bill by using energy-efficient appliances (like LED lights), unplugging devices when not in use, running major appliances during off-peak hours, sealing air leaks, and adjusting your thermostat.</p>
        </details>

        <details class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-4 group">
          <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
            What is a kilowatt-hour (kWh)?
            <span class="text-[var(--accent-color)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-[var(--text-secondary)]">A kilowatt-hour (kWh) is a unit of energy equal to one kilowatt (1,000 watts) of power used for one hour. It is the standard billing unit used by utility companies to measure and charge for your household's total energy consumption.</p>
        </details>

        <details class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-lg p-4 group">
          <summary class="font-bold text-white cursor-pointer list-none flex justify-between items-center">
            Why is my electricity bill so high in the summer?
            <span class="text-[var(--accent-color)] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <p class="mt-3 text-[var(--text-secondary)]">High summer electricity bills are usually due to increased use of air conditioning, which requires a significant amount of energy to cool your home against the outside heat. Additionally, refrigerators and freezers work harder in warm weather.</p>
        </details>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Data State
      let appliances = [
        // Default example appliance
        { id: 'app-init', name: 'Refrigerator', watts: 150, hours: 24 }
      ];
      let chartInstance = null;

      // DOM Elements
      const rateInput = document.getElementById('rate-input');
      const ratePresets = document.querySelectorAll('.rate-preset');

      const presetSelect = document.getElementById('preset-appliance');
      const addPresetBtn = document.getElementById('add-preset-btn');

      const customNameInput = document.getElementById('custom-name');
      const customWattsInput = document.getElementById('custom-watts');
      const customHoursInput = document.getElementById('custom-hours');
      const addCustomBtn = document.getElementById('add-custom-btn');

      const applianceListEl = document.getElementById('appliance-list');
      const emptyStateEl = document.getElementById('empty-state');

      const totalDailyEl = document.getElementById('total-daily');
      const totalMonthlyEl = document.getElementById('total-monthly');
      const totalYearlyEl = document.getElementById('total-yearly');

      const chartWrapper = document.getElementById('chart-container-wrapper');

      // Helper functions
      const formatCurrency = (val) => {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      };

      const getRate = () => {
        const val = parseFloat(rateInput.value);
        return isNaN(val) || val < 0 ? 0.16 : val;
      };

      const calculateCosts = (app) => {
        const rate = getRate();
        const dailyKwh = (app.watts * app.hours) / 1000;
        const dailyCost = dailyKwh * rate;

        return {
          daily: dailyCost,
          monthly: dailyCost * 30.4,
          yearly: dailyCost * 365
        };
      };

      // Chart setup
      const updateChart = () => {
        if (appliances.length === 0) {
          chartWrapper.classList.add('hidden');
          return;
        }

        chartWrapper.classList.remove('hidden');

        // Sort by monthly cost descending
        const sortedData = [...appliances].map(app => {
          return { name: app.name, cost: calculateCosts(app).monthly };
        }).sort((a, b) => b.cost - a.cost).slice(0, 10); // Top 10

        const labels = sortedData.map(d => d.name);
        const data = sortedData.map(d => d.cost);

        const ctx = document.getElementById('costChart').getContext('2d');

        // Get CSS vars for theming
        const style = getComputedStyle(document.body);
        const accentColor = style.getPropertyValue('--accent-color').trim() || '#3b82f6';
        const borderColor = style.getPropertyValue('--border-color').trim() || '#374151';
        const textColor = style.getPropertyValue('--text-secondary').trim() || '#9ca3af';

        if (chartInstance) {
          chartInstance.data.labels = labels;
          chartInstance.data.datasets[0].data = data;
          chartInstance.update();
        } else {
          chartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
              labels: labels,
              datasets: [{
                label: 'Monthly Cost ($)',
                data: data,
                backgroundColor: accentColor,
                borderColor: accentColor,
                borderWidth: 1,
                borderRadius: 4
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: {
                legend: { display: false },
                tooltip: {
                  callbacks: {
                    label: function(context) {
                      return formatCurrency(context.raw) + ' / month';
                    }
                  }
                }
              },
              scales: {
                y: {
                  beginAtZero: true,
                  grid: { color: borderColor },
                  ticks: { color: textColor, callback: (val) => '$' + val }
                },
                x: {
                  grid: { display: false },
                  ticks: { color: textColor, maxRotation: 45, minRotation: 45 }
                }
              }
            }
          });
        }
      };

      // UI Updates
      const renderApplianceList = () => {
        applianceListEl.innerHTML = '';

        if (appliances.length === 0) {
          emptyStateEl.style.display = 'block';
          applianceListEl.appendChild(emptyStateEl);
        } else {
          emptyStateEl.style.display = 'none';
        }

        let sumDaily = 0;

        appliances.forEach(app => {
          const costs = calculateCosts(app);
          sumDaily += costs.daily;

          const item = document.createElement('div');
          item.className = 'bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-4';

          item.innerHTML = `
            <div class="flex-1">
              <div class="font-bold text-white">${app.name}</div>
              <div class="text-[var(--text-secondary)] text-sm font-mono mt-1">
                ${app.watts}W • ${app.hours} hrs/day
              </div>
            </div>
            <div class="flex flex-row items-center gap-4 md:gap-6 w-full md:w-auto justify-between md:justify-end">
              <div class="text-right">
                <div class="text-[var(--accent-color)] font-bold font-mono text-lg">${formatCurrency(costs.monthly)}<span class="text-xs text-[var(--text-secondary)] font-normal ml-1">/mo</span></div>
                <div class="text-[var(--text-secondary)] text-xs font-mono">${formatCurrency(costs.daily)}/day</div>
              </div>
              <button class="remove-btn text-red-400 hover:text-red-300 hover:bg-red-400/10 p-2 rounded transition-colors" data-id="${app.id}" aria-label="Remove">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          `;

          applianceListEl.appendChild(item);
        });

        // Attach remove events
        document.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const id = e.currentTarget.getAttribute('data-id');
            appliances = appliances.filter(a => a.id !== id);
            renderApplianceList();
            updateChart();
          });
        });

        // Update Totals
        const sumMonthly = sumDaily * 30.4;
        const sumYearly = sumDaily * 365;

        totalDailyEl.textContent = formatCurrency(sumDaily);
        totalMonthlyEl.textContent = formatCurrency(sumMonthly);
        totalYearlyEl.textContent = formatCurrency(sumYearly);
      };

      // Events
      rateInput.addEventListener('input', () => {
        renderApplianceList();
        updateChart();
      });

      ratePresets.forEach(btn => {
        btn.addEventListener('click', (e) => {
          rateInput.value = e.target.getAttribute('data-rate');
          renderApplianceList();
          updateChart();
        });
      });

      addPresetBtn.addEventListener('click', () => {
        if (!presetSelect.value) return;

        const option = presetSelect.options[presetSelect.selectedIndex];
        const name = option.text.split(' (')[0];
        const watts = parseInt(option.getAttribute('data-watts'));

        // Default hours based on typical usage
        let defaultHours = 2;
        if (name === 'Refrigerator') defaultHours = 24;
        else if (name === 'Air Conditioner' || name === 'Space Heater') defaultHours = 8;
        else if (name === 'LED Light Bulb') defaultHours = 5;
        else if (name === 'Dishwasher' || name === 'Washing Machine' || name === 'Clothes Dryer') defaultHours = 1;

        appliances.push({
          id: 'app-' + Date.now(),
          name: name,
          watts: watts,
          hours: defaultHours
        });

        presetSelect.value = '';
        renderApplianceList();
        updateChart();
      });

      addCustomBtn.addEventListener('click', () => {
        const name = customNameInput.value.trim();
        const watts = parseFloat(customWattsInput.value);
        const hours = parseFloat(customHoursInput.value);

        if (!name || isNaN(watts) || isNaN(hours) || watts < 0 || hours < 0 || hours > 24) {
          alert('Please enter valid details. Hours must be between 0 and 24.');
          return;
        }

        appliances.push({
          id: 'app-' + Date.now(),
          name: name,
          watts: watts,
          hours: hours
        });

        customNameInput.value = '';
        customWattsInput.value = '';
        customHoursInput.value = '';

        renderApplianceList();
        updateChart();
      });

      // Initial render
      renderApplianceList();
      updateChart();
    });
  </script>
</SiteLayout>
