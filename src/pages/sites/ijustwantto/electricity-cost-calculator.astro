---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Electricity Cost Calculator — Appliance Energy Cost & kWh',
  description: 'Interactive calculator showing exactly how much your appliances cost to run. Enter wattage, hours, and electricity rate to see daily, weekly, monthly, and yearly costs. Compare appliances and discover savings.',
  category: 'calculator',
  keywords: ['electricity cost calculator', 'appliance energy cost', 'kwh calculator', 'monthly electricity bill', 'compare appliance cost', 'energy saving tips']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "ijustwantto" },
    "publisher": { "@type": "Organization", "name": "ijustwantto" },
    "datePublished": "2026-03-22",
    "dateModified": "2026-03-22"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I calculate my electricity cost?",
        "acceptedAnswer": { "@type": "Answer", "text": "Multiply the appliance wattage by the number of hours used per day, then divide by 1,000 to get kWh. Multiply kWh by your electricity rate ($/kWh) to get the daily cost. For example, a 1,500W space heater running 8 hours at $0.16/kWh costs: 1,500 × 8 ÷ 1,000 × $0.16 = $1.92/day." }
      },
      {
        "@type": "Question",
        "name": "What is the average electricity rate in the US?",
        "acceptedAnswer": { "@type": "Answer", "text": "The average residential electricity rate in the US is approximately $0.16 per kWh, though rates vary significantly by state. Hawaii has the highest rates (over $0.40/kWh), while states like Louisiana and Washington have some of the lowest (under $0.10/kWh)." }
      },
      {
        "@type": "Question",
        "name": "How many kWh does the average US household use per month?",
        "acceptedAnswer": { "@type": "Answer", "text": "The average US household uses about 886 kWh per month, which translates to roughly $142 per month at the national average rate. Usage varies by region, climate, home size, and the number of occupants." }
      },
      {
        "@type": "Question",
        "name": "What appliances use the most electricity?",
        "acceptedAnswer": { "@type": "Answer", "text": "The biggest electricity consumers in most homes are central air conditioning (3,500W), electric water heaters (4,500W), clothes dryers (5,000W), space heaters (1,500W), and electric ovens (2,500W). HVAC systems typically account for the largest share of household electricity bills." }
      },
      {
        "@type": "Question",
        "name": "How can I lower my electricity bill?",
        "acceptedAnswer": { "@type": "Answer", "text": "Switch to LED bulbs, use a programmable thermostat, unplug devices when not in use (phantom loads), run appliances during off-peak hours, upgrade to Energy Star-rated appliances, seal air leaks, and consider solar panels for long-term savings." }
      }
    ]
  }
]);
---

<SiteLayout site="ijustwantto" title={meta.title} description={meta.description} canonical="https://ijustwantto.live/electricity-cost-calculator">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <section class="mill-hero">
    <div class="mill-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>Electricity Cost Calculator</h1>
    <p class="mill-hero-hook">Your AC costs <strong>$150/month</strong>. Here are 8 ways to cut it.<br/>The math will surprise you.</p>
    <div class="mill-hero-stats">
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-highest"></span>
        <span class="mill-stat-label">Highest Cost</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num" id="hero-lowest"></span>
        <span class="mill-stat-label">Lowest Cost</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num">~16¢</span>
        <span class="mill-stat-label">Avg US Rate / kWh</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="mill-section">
    <h2 class="mill-section-title">Calculate Appliance Cost</h2>
    <p class="mill-section-sub">Select an appliance or enter custom numbers to see your monthly and yearly cost.</p>

    <div class="mill-calc-container">
      <div class="mill-calc-inputs">
        <div class="mill-input-group">
          <label for="appliance-select">Appliance</label>
          <select id="appliance-select">
            <option value="">— Select an appliance —</option>
            <option value="custom">Custom (enter your own)</option>
          </select>
        </div>

        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="input-wattage">Wattage (W)</label>
            <input type="number" id="input-wattage" min="1" max="10000" step="10" />
          </div>
          <div class="mill-input-group">
            <label for="input-rate">Electricity Rate ($/kWh)</label>
            <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="input-rate" min="0.01" max="1.00" step="0.01" value="0.16" /></div>
          </div>
        </div>

        <div class="mill-input-group">
          <label for="hours-slider">Usage: <strong id="hours-display">8 hrs/day</strong></label>
          <input type="range" id="hours-slider" min="1" max="24" value="8" />
          <div class="mill-slider-labels"><span>1 hr</span><span>12 hrs</span><span>24 hrs</span></div>
        </div>

        <button id="calc-btn" class="mill-btn">Calculate Cost</button>
      </div>

      <!-- RESULTS -->
      <div class="mill-calc-results" id="results-panel" style="display:none;">
        <div class="mill-result-header">
          <div class="mill-result-title" id="result-appliance-name">Your Results</div>
          <div class="mill-result-age">Monthly Cost <strong id="result-monthly">—</strong></div>
          <div class="mill-result-years">Yearly Cost: <span id="result-yearly">—</span></div>
        </div>

        <!-- BREAKDOWN -->
        <div class="mill-milestones" id="breakdown-container"></div>

        <!-- ANIMATED BAR CHART -->
        <div class="mill-chart-wrap">
          <div class="mill-chart-title">Cost Over 1 Year</div>
          <div class="mill-chart" id="cost-chart"></div>
        </div>

        <div class="mill-insight" id="result-insight"></div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="mill-section">
    <h2 class="mill-section-title">Compare Two Appliances</h2>
    <p class="mill-section-sub">See how choosing a more efficient appliance changes your yearly cost.</p>

    <div class="mill-compare-controls">
      <div class="mill-input-group">
        <label for="compare-a">Appliance A</label>
        <select id="compare-a"></select>
      </div>
      <div class="mill-vs">VS</div>
      <div class="mill-input-group">
        <label for="compare-b">Appliance B</label>
        <select id="compare-b"></select>
      </div>
      <button id="compare-btn" class="mill-btn">Compare</button>
    </div>

    <div class="mill-compare-results" id="compare-results" style="display:none;">
      <div class="mill-compare-cards">
        <div class="mill-compare-card" id="compare-card-a"></div>
        <div class="mill-compare-card" id="compare-card-b"></div>
      </div>
      <div class="mill-compare-race" id="compare-race"></div>
    </div>
  </section>

  <!-- ENERGY SAVING TIPS -->
  <section class="mill-section">
    <h2 class="mill-section-title">8 Ways to Cut Your Energy Bill</h2>
    <div class="mill-levers">
      <div class="mill-lever-card">
        <h3>1. Adjust Your Thermostat</h3>
        <p>Set your thermostat 7-10 degrees back for 8 hours a day from its normal setting.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>10% / year</strong></div>
      </div>
      <div class="mill-lever-card">
        <h3>2. Unplug Phantom Loads</h3>
        <p>Unplug chargers, TVs, and computers when not in use, or use a smart power strip.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>$100 - $200 / year</strong></div>
      </div>
      <div class="mill-lever-card">
        <h3>3. Switch to LED Bulbs</h3>
        <p>Replace incandescent bulbs with LEDs. They use 75% less energy and last 25 times longer.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>$225 / year</strong></div>
      </div>
      <div class="mill-lever-card">
        <h3>4. Use Cold Water for Laundry</h3>
        <p>Heating water accounts for about 90% of the energy your washing machine uses.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>$60 / year</strong></div>
      </div>
      <div class="mill-lever-card">
        <h3>5. Seal Leaks and Insulate</h3>
        <p>Add weather stripping to doors and windows and ensure your attic is properly insulated.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>15% / year</strong></div>
      </div>
      <div class="mill-lever-card">
        <h3>6. Maintain HVAC Systems</h3>
        <p>Clean or replace filters regularly to ensure your system runs efficiently.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>5-15% / year</strong></div>
      </div>
      <div class="mill-lever-card">
        <h3>7. Run Full Loads</h3>
        <p>Only run your dishwasher and washing machine when they are full.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>$50 / year</strong></div>
      </div>
      <div class="mill-lever-card">
        <h3>8. Upgrade Appliances</h3>
        <p>Look for the ENERGY STAR label when replacing old appliances for significant long-term savings.</p>
        <div class="mill-lever-impact">Projected Savings: <strong>$100+ / year</strong></div>
      </div>
    </div>
  </section>

  <!-- SOLAR ROI CALCULATOR -->
  <section class="mill-section">
    <h2 class="mill-section-title">Solar Panel ROI</h2>
    <p class="mill-section-sub">Thinking about going solar? Estimate your break-even point.</p>
    <div class="mill-calc-container" style="max-width: 600px; margin: 0 auto;">
      <div class="mill-calc-inputs">
        <div class="mill-input-group">
          <label for="solar-cost">System Cost (after tax credits)</label>
          <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="solar-cost" min="1000" max="100000" step="500" value="15000" /></div>
        </div>
        <div class="mill-input-group">
          <label for="solar-savings">Average Monthly Savings</label>
          <div class="mill-input-wrap"><span class="mill-input-prefix">$</span><input type="number" id="solar-savings" min="10" max="1000" step="10" value="150" /></div>
        </div>
        <button id="solar-btn" class="mill-btn">Calculate ROI</button>
      </div>
      <div class="mill-calc-results" id="solar-results" style="display:none; text-align: center; padding: 1.5rem;">
        <div class="mill-result-title">Estimated Break-Even</div>
        <div class="mill-result-age" style="font-size: 2.5rem;"><strong id="solar-years">—</strong> years</div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mill-section">
    <h2 class="mill-section-title">Frequently Asked Questions</h2>
    <div class="mill-faq">
      <details class="mill-faq-item">
        <summary>How do I calculate my electricity cost?</summary>
        <p>Multiply the appliance wattage by the number of hours used per day, then divide by 1,000 to get kWh. Multiply kWh by your electricity rate ($/kWh) to get the daily cost. For example, a 1,500W space heater running 8 hours at $0.16/kWh costs: 1,500 × 8 ÷ 1,000 × $0.16 = $1.92/day.</p>
      </details>
      <details class="mill-faq-item">
        <summary>What is the average electricity rate in the US?</summary>
        <p>The average residential electricity rate in the US is approximately $0.16 per kWh, though rates vary significantly by state. Hawaii has the highest rates (over $0.40/kWh), while states like Louisiana and Washington have some of the lowest (under $0.10/kWh).</p>
      </details>
      <details class="mill-faq-item">
        <summary>How many kWh does the average US household use per month?</summary>
        <p>The average US household uses about 886 kWh per month, which translates to roughly $142 per month at the national average rate. Usage varies by region, climate, home size, and the number of occupants.</p>
      </details>
      <details class="mill-faq-item">
        <summary>What appliances use the most electricity?</summary>
        <p>The biggest electricity consumers in most homes are central air conditioning (3,500W), electric water heaters (4,500W), clothes dryers (5,000W), space heaters (1,500W), and electric ovens (2,500W). HVAC systems typically account for the largest share of household electricity bills.</p>
      </details>
      <details class="mill-faq-item">
        <summary>How can I lower my electricity bill?</summary>
        <p>Switch to LED bulbs, use a programmable thermostat, unplug devices when not in use (phantom loads), run appliances during off-peak hours, upgrade to Energy Star-rated appliances, seal air leaks, and consider solar panels for long-term savings.</p>
      </details>
    </div>
  </section>

  <div class="mill-disclaimer">
    <p><strong>Disclaimer:</strong> This calculator uses simplified assumptions including constant wattage and fixed electricity rates. Real-world costs will vary based on fluctuating rates, tiered pricing, exact appliance models, and actual usage patterns.</p>
  </div>
</SiteLayout>

<style is:global>
  /* ===== ELECTRICITY COST CALCULATOR ===== */
  :root {
    --accent-color: #2DB89A;
    --accent-hover: #26a086;
  }
  .mill-page { max-width: 1100px; margin: 0 auto; }
  .mill-hero {
    text-align: center;
    padding: 2.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(45,184,154,0.12) 0%, rgba(45,184,154,0.02) 60%, rgba(45,184,154,0.08) 100%);
    border-bottom: 1px solid var(--border-color, #152040);
    position: relative;
    overflow: hidden;
  }
  .mill-hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(45,184,154,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(45,184,154,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    background: rgba(45,184,154,0.15);
    color: var(--accent-color);
    border: 1px solid rgba(45,184,154,0.3);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1.2rem;
  }
  .mill-hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--text-primary, #c8d0de);
  }
  .mill-hero h1 em {
    font-style: normal;
    color: var(--accent-color);
  }
  .mill-hero-hook {
    font-size: 1.1rem;
    color: var(--text-secondary, #94a3b8);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.5;
  }
  .mill-hero-hook strong {
    color: var(--text-primary, #c8d0de);
  }
  .mill-hero-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    max-width: 700px;
    margin: 0 auto;
  }
  .mill-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--bg-color, #0f172a);
    border: 1px solid var(--border-color, #1e293b);
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    min-width: 140px;
    gap: 0.3rem;
  }
  .mill-stat-num {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent-color);
    white-space: nowrap;
  }
  .mill-stat-label {
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* SECTIONS */
  .mill-section {
    padding: 2.5rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .mill-section-title {
    font-size: 1.6rem;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .mill-section-sub {
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  /* CALCULATOR */
  .mill-calc-container {
    display: grid;
    gap: 2rem;
  }
  .mill-calc-inputs {
    background: var(--card-bg, #152040);
    border: 1px solid var(--border-color, #1e293b);
    border-radius: 12px;
    padding: 1.5rem;
  }
  @media (min-width: 768px) {
    .mill-calc-container { grid-template-columns: 1fr 1fr; }
  }
  .mill-input-group {
    margin-bottom: 1.2rem;
  }
  .mill-input-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.5rem;
  }
  .mill-input-group label strong {
    color: var(--text-primary, #c8d0de);
  }
  .mill-input-row {
    display: flex;
    gap: 1rem;
  }
  .mill-input-row > div {
    flex: 1;
  }
  .mill-calc-inputs input[type="number"],
  .mill-calc-inputs select,
  .mill-compare-controls select {
    width: 100%;
    background: var(--bg-color, #0f172a);
    border: 1px solid var(--border-color, #1e293b);
    color: var(--text-primary, #c8d0de);
    padding: 0.7rem;
    border-radius: 6px;
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.2s;
  }
  .mill-calc-inputs input[type="number"]:focus,
  .mill-calc-inputs select:focus,
  .mill-compare-controls select:focus {
    outline: none;
    border-color: var(--accent-color);
  }
  .mill-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .mill-input-prefix {
    position: absolute;
    left: 0.8rem;
    color: var(--text-secondary, #94a3b8);
    font-weight: 600;
  }
  .mill-input-wrap input {
    padding-left: 1.8rem !important;
  }
  input[type="range"] {
    width: 100%;
    margin: 0.5rem 0;
    accent-color: var(--accent-color);
  }
  .mill-slider-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--text-secondary, #94a3b8);
  }
  .mill-btn {
    width: 100%;
    background: var(--accent-color);
    color: #fff;
    border: none;
    padding: 0.8rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    margin-top: 0.5rem;
  }
  .mill-btn:hover { background: var(--accent-hover); }
  .mill-btn:active { transform: scale(0.98); }

  /* RESULTS */
  .mill-calc-results {
    background: var(--card-bg, #152040);
    border: 1px solid var(--border-color, #1e293b);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }
  .mill-result-header {
    text-align: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color, #1e293b);
  }
  .mill-result-title {
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }
  .mill-result-age {
    font-size: 1.2rem;
    color: var(--text-primary, #c8d0de);
  }
  .mill-result-age strong {
    font-size: 2.2rem;
    color: var(--accent-color);
    display: block;
    line-height: 1.1;
    margin: 0.2rem 0;
  }
  .mill-result-years {
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
  }
  .mill-result-years span {
    font-weight: 700;
    color: var(--text-primary, #c8d0de);
  }

  /* MILESTONES (BREAKDOWN) */
  .mill-milestones {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .mill-milestone {
    background: var(--bg-color, #0f172a);
    padding: 0.8rem;
    border-radius: 6px;
    text-align: center;
    border: 1px solid var(--border-color, #1e293b);
  }
  .mill-milestone-label {
    font-size: 0.75rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.2rem;
  }
  .mill-milestone-val {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary, #c8d0de);
  }

  /* CHART */
  .mill-chart-wrap {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }
  .mill-chart-title {
    font-size: 0.85rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.8rem;
    text-align: center;
  }
  .mill-chart {
    height: 120px;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    position: relative;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border-color, #1e293b);
  }
  .mill-chart-bar-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
    position: relative;
  }
  .mill-chart-bar {
    width: 100%;
    max-width: 20px;
    background: var(--accent-color);
    border-radius: 2px 2px 0 0;
    transition: height 0.5s ease-out;
  }
  .mill-chart-bar-label {
    position: absolute;
    bottom: -20px;
    font-size: 0.65rem;
    color: var(--text-secondary, #94a3b8);
  }

  .mill-insight {
    background: rgba(45,184,154,0.1);
    border-left: 3px solid var(--accent-color);
    padding: 0.8rem;
    font-size: 0.85rem;
    color: var(--text-primary, #c8d0de);
    border-radius: 0 4px 4px 0;
    line-height: 1.4;
  }
  .mill-insight strong { color: var(--accent-color); }

  /* COMPARE */
  .mill-compare-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--card-bg, #152040);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border-color, #1e293b);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .mill-compare-controls .mill-input-group {
    flex: 1;
    min-width: 200px;
    margin: 0;
  }
  .mill-vs {
    font-weight: 800;
    color: var(--text-secondary, #94a3b8);
    padding: 0.5rem;
    margin-top: 1rem;
  }
  .mill-compare-controls .mill-btn {
    flex: 0 0 auto;
    width: auto;
    padding: 0.7rem 1.5rem;
    margin-top: 1.4rem;
  }
  .mill-compare-results {
    background: var(--card-bg, #152040);
    border: 1px solid var(--border-color, #1e293b);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .mill-compare-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .mill-compare-card {
    background: var(--bg-color, #0f172a);
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--border-color, #1e293b);
    text-align: center;
  }
  .mill-cc-title { font-size: 0.9rem; color: var(--text-secondary, #94a3b8); margin-bottom: 0.5rem; }
  .mill-cc-val { font-size: 1.6rem; font-weight: 700; color: var(--text-primary, #c8d0de); margin-bottom: 0.2rem; }
  .mill-cc-val.win { color: var(--accent-color); }
  .mill-cc-sub { font-size: 0.8rem; color: var(--text-secondary, #94a3b8); }

  .mill-compare-race {
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color, #1e293b);
  }
  .mill-race-track {
    background: var(--bg-color, #0f172a);
    height: 30px;
    border-radius: 15px;
    margin-bottom: 1rem;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-color, #1e293b);
  }
  .mill-race-bar {
    height: 100%;
    background: var(--text-secondary, #94a3b8);
    border-radius: 15px;
    display: flex;
    align-items: center;
    padding-left: 10px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #0f172a;
    transition: width 1s ease-out;
    white-space: nowrap;
  }
  .mill-race-bar.win { background: var(--accent-color); }
  .mill-race-diff {
    text-align: center;
    font-size: 0.95rem;
    color: var(--text-primary, #c8d0de);
  }
  .mill-race-diff strong { color: var(--accent-color); }

  /* LEVERS (TIPS) */
  .mill-levers {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 600px) {
    .mill-levers { grid-template-columns: 1fr 1fr; }
  }
  .mill-lever-card {
    background: var(--card-bg, #152040);
    border: 1px solid var(--border-color, #1e293b);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .mill-lever-card h3 {
    font-size: 1.1rem;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.5rem;
  }
  .mill-lever-card p {
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .mill-lever-impact {
    font-size: 0.85rem;
    color: var(--text-primary, #c8d0de);
    background: rgba(255,255,255,0.05);
    padding: 0.5rem 0.8rem;
    border-radius: 4px;
    display: inline-block;
  }
  .mill-lever-impact strong {
    color: var(--accent-color);
  }

  /* FAQ */
  .mill-faq {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mill-faq-item {
    background: var(--card-bg, #152040);
    border: 1px solid var(--border-color, #1e293b);
    border-radius: 8px;
    overflow: hidden;
  }
  .mill-faq-item summary {
    padding: 1.2rem;
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
    cursor: pointer;
    list-style: none;
    position: relative;
  }
  .mill-faq-item summary::-webkit-details-marker { display: none; }
  .mill-faq-item summary::after {
    content: '+';
    position: absolute;
    right: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.2rem;
    color: var(--accent-color);
  }
  .mill-faq-item[open] summary::after { content: '-'; }
  .mill-faq-item p {
    padding: 0 1.2rem 1.2rem;
    color: var(--text-secondary, #94a3b8);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .mill-disclaimer {
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    font-size: 0.8rem;
    color: var(--text-secondary, #94a3b8);
    text-align: center;
    line-height: 1.6;
  }
  .mill-disclaimer p { margin: 0; }
</style>

<script is:inline>
(function() {
  'use strict';

  var APPLIANCES = [
    { name: 'Central Air Conditioner', wattage: 3500, hours: 8 },
    { name: 'Electric Water Heater', wattage: 4500, hours: 3 },
    { name: 'Space Heater', wattage: 1500, hours: 8 },
    { name: 'Refrigerator', wattage: 400, hours: 24 }, // runs 24/7 but cycles
    { name: 'Clothes Dryer', wattage: 3000, hours: 1 },
    { name: 'Electric Oven', wattage: 2500, hours: 1 },
    { name: 'Desktop Computer', wattage: 200, hours: 8 },
    { name: 'Laptop', wattage: 50, hours: 8 },
    { name: 'Television (LED)', wattage: 100, hours: 5 },
    { name: 'Dishwasher', wattage: 1800, hours: 1 },
    { name: 'Microwave', wattage: 1000, hours: 0.5 },
    { name: 'Incandescent Bulb', wattage: 60, hours: 5 },
    { name: 'LED Bulb', wattage: 10, hours: 5 },
    { name: 'EV Charger (Level 2)', wattage: 7200, hours: 3 }
  ];

  function fmt(n) {
    if (n >= 1000) return '$' + n.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0});
    return '$' + n.toFixed(2);
  }

  function calculateCosts(wattage, hoursPerDay, ratePerKwh) {
    var kwhPerDay = (wattage * hoursPerDay) / 1000;
    var costPerDay = kwhPerDay * ratePerKwh;
    return {
      daily: costPerDay,
      weekly: costPerDay * 7,
      monthly: costPerDay * 30,
      yearly: costPerDay * 365,
      kwhMonthly: kwhPerDay * 30
    };
  }

  var appSelect = document.getElementById('appliance-select');
  var compareA = document.getElementById('compare-a');
  var compareB = document.getElementById('compare-b');

  APPLIANCES.forEach(function(a, i) {
    var opt = document.createElement('option');
    opt.value = i;
    opt.textContent = a.name;
    appSelect.appendChild(opt);
    compareA.appendChild(opt.cloneNode(true));
    compareB.appendChild(opt.cloneNode(true));
  });

  compareA.value = '11'; // Incandescent
  compareB.value = '12'; // LED

  var inputWattage = document.getElementById('input-wattage');
  var inputRate = document.getElementById('input-rate');
  var hoursSlider = document.getElementById('hours-slider');
  var hoursDisplay = document.getElementById('hours-display');

  // Hero Stats
  var acCosts = calculateCosts(3500, 8, 0.16);
  document.getElementById('hero-highest').textContent = fmt(acCosts.monthly) + '/mo';
  var ledCosts = calculateCosts(10, 5, 0.16);
  document.getElementById('hero-lowest').textContent = fmt(ledCosts.yearly) + '/yr';

  appSelect.addEventListener('change', function() {
    var val = this.value;
    if (val === 'custom') {
      inputWattage.value = '';
      hoursSlider.value = 8;
    } else if (val !== '') {
      var a = APPLIANCES[val];
      inputWattage.value = a.wattage;
      hoursSlider.value = a.hours;
    }
    hoursDisplay.textContent = hoursSlider.value + ' hrs/day';
  });

  hoursSlider.addEventListener('input', function() {
    hoursDisplay.textContent = this.value + ' hrs/day';
    appSelect.value = 'custom';
  });

  inputWattage.addEventListener('input', function() { appSelect.value = 'custom'; });

  document.getElementById('calc-btn').addEventListener('click', function() {
    var w = parseFloat(inputWattage.value);
    var h = parseFloat(hoursSlider.value);
    var r = parseFloat(inputRate.value);

    if (isNaN(w) || w <= 0 || isNaN(h) || isNaN(r)) {
      alert('Please enter valid numbers.');
      return;
    }

    var costs = calculateCosts(w, h, r);
    var isCustom = appSelect.value === 'custom' || appSelect.value === '';
    var appName = isCustom ? 'Custom Appliance' : APPLIANCES[appSelect.value].name;

    document.getElementById('result-appliance-name').textContent = appName;
    document.getElementById('result-monthly').textContent = fmt(costs.monthly);
    document.getElementById('result-yearly').textContent = fmt(costs.yearly);

    var bdContainer = document.getElementById('breakdown-container');
    bdContainer.innerHTML = '';
    var m1 = document.createElement('div'); m1.className = 'mill-milestone';
    m1.innerHTML = '<div class="mill-milestone-label">Daily Cost</div><div class="mill-milestone-val">' + fmt(costs.daily) + '</div>';
    var m2 = document.createElement('div'); m2.className = 'mill-milestone';
    m2.innerHTML = '<div class="mill-milestone-label">Weekly Cost</div><div class="mill-milestone-val">' + fmt(costs.weekly) + '</div>';
    bdContainer.appendChild(m1);
    bdContainer.appendChild(m2);

    // Insight
    var insight = document.getElementById('result-insight');
    insight.innerHTML = 'This appliance uses <strong>' + Math.round(costs.kwhMonthly) + ' kWh</strong> per month. Reducing usage by just 2 hours a day would save you <strong>' + fmt((costs.yearly / h) * 2) + '</strong> per year.';

    // Chart
    var chart = document.getElementById('cost-chart');
    chart.innerHTML = '';
    var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    var cumulative = 0;
    months.forEach(function(m, i) {
      cumulative += costs.monthly;
      var group = document.createElement('div');
      group.className = 'mill-chart-bar-group';
      var bar = document.createElement('div');
      bar.className = 'mill-chart-bar';
      bar.style.height = '0px';

      var targetHeight = Math.max((cumulative / costs.yearly) * 100, 5); // min 5px

      if (i % 2 === 0) {
        var label = document.createElement('div');
        label.className = 'mill-chart-bar-label';
        label.textContent = m;
        group.appendChild(label);
      }
      group.appendChild(bar);
      chart.appendChild(group);

      setTimeout(function() {
        bar.style.height = targetHeight + 'px';
      }, 50 * i);
    });

    var panel = document.getElementById('results-panel');
    panel.style.display = 'flex';
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  // Compare
  document.getElementById('compare-btn').addEventListener('click', function() {
    var vA = compareA.value;
    var vB = compareB.value;
    if (vA === '' || vB === '') { alert('Please select two appliances to compare.'); return; }

    var a = APPLIANCES[vA];
    var b = APPLIANCES[vB];
    var r = parseFloat(inputRate.value) || 0.16;

    var cA = calculateCosts(a.wattage, a.hours, r);
    var cB = calculateCosts(b.wattage, b.hours, r);

    var cardA = document.getElementById('compare-card-a');
    var cardB = document.getElementById('compare-card-b');

    var isALower = cA.yearly < cB.yearly;

    cardA.innerHTML = '<div class="mill-cc-title">' + a.name + '</div><div class="mill-cc-val ' + (isALower ? 'win' : '') + '">' + fmt(cA.yearly) + '</div><div class="mill-cc-sub">/ year</div>';
    cardB.innerHTML = '<div class="mill-cc-title">' + b.name + '</div><div class="mill-cc-val ' + (!isALower ? 'win' : '') + '">' + fmt(cB.yearly) + '</div><div class="mill-cc-sub">/ year</div>';

    var diff = Math.abs(cA.yearly - cB.yearly);
    var winnerName = isALower ? a.name : b.name;

    var maxYearly = Math.max(cA.yearly, cB.yearly);
    var pctA = Math.max((cA.yearly / maxYearly) * 100, 15);
    var pctB = Math.max((cB.yearly / maxYearly) * 100, 15);

    var race = document.getElementById('compare-race');
    race.innerHTML = '';

    var trackA = document.createElement('div'); trackA.className = 'mill-race-track';
    var barA = document.createElement('div'); barA.className = 'mill-race-bar ' + (isALower ? 'win' : ''); barA.style.width = '0%'; barA.textContent = a.name;
    trackA.appendChild(barA);

    var trackB = document.createElement('div'); trackB.className = 'mill-race-track';
    var barB = document.createElement('div'); barB.className = 'mill-race-bar ' + (!isALower ? 'win' : ''); barB.style.width = '0%'; barB.textContent = b.name;
    trackB.appendChild(barB);

    var diffEl = document.createElement('div'); diffEl.className = 'mill-race-diff';
    diffEl.innerHTML = 'Choosing <strong>' + winnerName + '</strong> saves you <strong>' + fmt(diff) + '</strong> per year.';

    race.appendChild(trackA);
    race.appendChild(trackB);
    race.appendChild(diffEl);

    document.getElementById('compare-results').style.display = 'block';

    setTimeout(function() {
      barA.style.width = pctA + '%';
      barB.style.width = pctB + '%';
    }, 50);
  });

  // Solar ROI
  document.getElementById('solar-btn').addEventListener('click', function() {
    var cost = parseFloat(document.getElementById('solar-cost').value);
    var savings = parseFloat(document.getElementById('solar-savings').value);
    if(isNaN(cost) || isNaN(savings) || savings <= 0) return;
    var months = cost / savings;
    var years = months / 12;
    document.getElementById('solar-years').textContent = years.toFixed(1);
    document.getElementById('solar-results').style.display = 'block';
  });

})();
</script>
