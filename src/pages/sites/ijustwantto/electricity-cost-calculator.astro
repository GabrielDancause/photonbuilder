---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Electricity Cost Calculator",
      "url": "https://ijustwantto.live/electricity-cost-calculator",
      "description": "Calculate your electricity costs by appliance. Compare presets, add custom appliances, and see a visual breakdown of your energy usage.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How is electricity cost calculated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Electricity cost is calculated by multiplying the wattage of an appliance by the hours it is used to get watt-hours, dividing by 1000 to get kilowatt-hours (kWh), and then multiplying by your local electricity rate ($/kWh)."
          }
        },
        {
          "@type": "Question",
          "name": "What appliances use the most electricity?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Heating and cooling systems (AC, heaters, water heaters) are typically the biggest energy consumers in a home, followed by large appliances like dryers, ovens, and refrigerators."
          }
        },
        {
          "@type": "Question",
          "name": "How can I find my local electricity rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can find your local electricity rate on your monthly utility bill, usually listed as a cost per kilowatt-hour (kWh)."
          }
        },
        {
          "@type": "Question",
          "name": "Why does my refrigerator cost so much to run?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Although refrigerators may have a lower wattage than a dryer or heater, they run 24 hours a day, 365 days a year, making their cumulative energy consumption relatively high."
          }
        },
        {
          "@type": "Question",
          "name": "What is a phantom load?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A phantom load (or vampire power) is the electricity consumed by electronic devices while they are plugged in but turned off or in standby mode, such as TVs, computers, and chargers."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Electricity Cost Calculator",
  description: "Calculate your electricity costs by appliance. Compare presets, add custom appliances, and see a visual breakdown of your energy usage.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="ijustwantto"
  title="Electricity Cost Calculator"
  description="Calculate your electricity costs by appliance. Compare presets, add custom appliances, and see a visual breakdown of your energy usage."
  canonical="https://ijustwantto.live/electricity-cost-calculator"
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-5 py-12">
    <h1 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Electricity Cost Calculator</h1>
    <p class="text-[var(--text-secondary)] mb-10 text-lg">Add your appliances to estimate daily, monthly, and yearly electricity costs.</p>

    <!-- Settings Card -->
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-8 shadow-sm">
      <h2 class="text-xl font-bold text-white mb-4">1. Set Electricity Rate</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="rate-preset">Rate Preset</label>
          <select id="rate-preset" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
            <option value="custom">Custom Rate</option>
            <option value="0.16" selected>US Average ($0.16/kWh)</option>
            <option value="0.13">Canada Average ($0.13/kWh)</option>
            <option value="0.28">EU Average ($0.28/kWh)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="custom-rate">Cost per kWh ($)</label>
          <div class="relative">
            <span class="absolute left-3 top-3 text-[var(--text-secondary)] font-mono">$</span>
            <input type="number" id="custom-rate" value="0.16" min="0" step="0.01" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 pl-8 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
          </div>
        </div>
      </div>
    </div>

    <!-- Add Appliance Card -->
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-8 shadow-sm">
      <h2 class="text-xl font-bold text-white mb-4">2. Add Appliance</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="appliance-preset">Appliance Preset</label>
          <select id="appliance-preset" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
            <option value="custom">Custom Appliance</option>
            <option value='{"name":"AC (Central)","watts":3500,"hours":8}'>AC (Central) - 3500W</option>
            <option value='{"name":"AC (Window)","watts":1500,"hours":8}'>AC (Window) - 1500W</option>
            <option value='{"name":"Space Heater","watts":1500,"hours":6}'>Space Heater - 1500W</option>
            <option value='{"name":"Refrigerator","watts":150,"hours":24}'>Refrigerator - 150W (Avg)</option>
            <option value='{"name":"Washing Machine","watts":500,"hours":1}'>Washing Machine - 500W</option>
            <option value='{"name":"Dryer","watts":3000,"hours":1}'>Dryer - 3000W</option>
            <option value='{"name":"Dishwasher","watts":1800,"hours":1}'>Dishwasher - 1800W</option>
            <option value='{"name":"Microwave","watts":1000,"hours":0.5}'>Microwave - 1000W</option>
            <option value='{"name":"Oven","watts":3000,"hours":1}'>Oven - 3000W</option>
            <option value='{"name":"TV","watts":100,"hours":4}'>TV - 100W</option>
            <option value='{"name":"Gaming PC","watts":500,"hours":4}'>Gaming PC - 500W</option>
            <option value='{"name":"Laptop","watts":60,"hours":8}'>Laptop - 60W</option>
            <option value='{"name":"LED Light Bulb","watts":10,"hours":6}'>LED Light Bulb - 10W</option>
            <option value='{"name":"EV Charger (L2)","watts":7200,"hours":4}'>EV Charger (Level 2) - 7200W</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="appliance-name">Name</label>
          <input type="text" id="appliance-name" placeholder="e.g. My PC" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="appliance-watts">Wattage (W)</label>
          <input type="number" id="appliance-watts" min="1" step="1" placeholder="Watts" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="appliance-hours">Hours per Day</label>
          <input type="number" id="appliance-hours" min="0.1" max="24" step="0.1" placeholder="Hours" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
        </div>
      </div>

      <button id="add-btn" class="w-full bg-[var(--accent-color)] hover:bg-opacity-90 text-[var(--bg-color)] font-bold py-3 px-4 rounded-lg transition-colors">
        + Add Appliance
      </button>
    </div>

    <!-- Appliance List & Summary -->
    <div id="results-section" class="hidden">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Your Appliances</h2>

      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl overflow-hidden mb-8 shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-[var(--bg-color)] border-b border-[var(--border-color)]">
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Appliance</th>
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Daily</th>
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Monthly</th>
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Yearly</th>
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm text-right">Action</th>
              </tr>
            </thead>
            <tbody id="appliances-list">
              <!-- JS Injected -->
            </tbody>
            <tfoot class="border-t border-[var(--border-color)] bg-[var(--bg-color)] bg-opacity-50">
              <tr>
                <td class="p-4 font-bold text-white">Total Cost</td>
                <td class="p-4 font-bold text-[var(--accent-color)] font-mono" id="total-daily">$0.00</td>
                <td class="p-4 font-bold text-[var(--accent-color)] font-mono" id="total-monthly">$0.00</td>
                <td class="p-4 font-bold text-[var(--accent-color)] font-mono" id="total-yearly">$0.00</td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

      <!-- Chart -->
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-12 shadow-sm">
        <h3 class="text-xl font-bold text-[var(--accent-color)] mb-6 text-center">Monthly Cost Breakdown</h3>
        <div class="h-[400px]">
          <canvas id="chart"></canvas>
        </div>
      </div>
    </div>

    <!-- Methodology & FAQ -->
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Methodology</h2>
      <p class="text-[var(--text-secondary)] mb-4">
        This calculator estimates your electricity costs based on the formula:
      </p>
      <div class="bg-[var(--bg-color)] p-4 rounded-lg border border-[var(--border-color)] mb-4 font-mono text-sm text-[var(--accent-color)] text-center overflow-x-auto">
        Cost = (Wattage &times; Hours Used / 1000) &times; Electricity Rate
      </div>
      <p class="text-[var(--text-secondary)]">
        The calculated monthly cost assumes an average of 30.4 days per month, and the yearly cost assumes 365 days. The preset wattages are averages; actual consumption varies depending on the specific model, age, and settings of your appliance. Refrigerator wattage is averaged over 24 hours, as they cycle on and off throughout the day.
      </p>
    </div>

    <div class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">How is electricity cost calculated?</h3>
          <p class="text-[var(--text-secondary)]">Electricity cost is calculated by multiplying the wattage of an appliance by the hours it is used to get watt-hours, dividing by 1000 to get kilowatt-hours (kWh), and then multiplying by your local electricity rate ($/kWh).</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">What appliances use the most electricity?</h3>
          <p class="text-[var(--text-secondary)]">Heating and cooling systems (AC, heaters, water heaters) are typically the biggest energy consumers in a home, followed by large appliances like dryers, ovens, and refrigerators.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">How can I find my local electricity rate?</h3>
          <p class="text-[var(--text-secondary)]">You can find your local electricity rate on your monthly utility bill, usually listed as a cost per kilowatt-hour (kWh). It may be a flat rate or a tiered rate based on usage.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">Why does my refrigerator cost so much to run?</h3>
          <p class="text-[var(--text-secondary)]">Although refrigerators may have a lower wattage than a dryer or heater, they run 24 hours a day, 365 days a year, making their cumulative energy consumption relatively high over time.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">What is a phantom load?</h3>
          <p class="text-[var(--text-secondary)]">A phantom load (or vampire power) is the electricity consumed by electronic devices while they are plugged in but turned off or in standby mode, such as TVs, computers, and chargers.</p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    const formatMoney = (amount) => {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
    };

    let appliances = [];
    let currentRate = 0.16;
    let chartInstance = null;

    const ratePreset = document.getElementById('rate-preset');
    const customRate = document.getElementById('custom-rate');
    const appPreset = document.getElementById('appliance-preset');
    const appName = document.getElementById('appliance-name');
    const appWatts = document.getElementById('appliance-watts');
    const appHours = document.getElementById('appliance-hours');
    const addBtn = document.getElementById('add-btn');
    const resultsSection = document.getElementById('results-section');
    const appliancesList = document.getElementById('appliances-list');
    const totalDailyEl = document.getElementById('total-daily');
    const totalMonthlyEl = document.getElementById('total-monthly');
    const totalYearlyEl = document.getElementById('total-yearly');

    // Handle Rate changes
    if (ratePreset) {
      ratePreset.addEventListener('change', (e) => {
        if (e.target.value !== 'custom') {
          customRate.value = e.target.value;
          currentRate = parseFloat(e.target.value);
          updateUI();
        }
      });
    }

    if (customRate) {
      customRate.addEventListener('input', (e) => {
        ratePreset.value = 'custom';
        currentRate = parseFloat(e.target.value) || 0;
        updateUI();
      });
    }

    // Handle Appliance Preset changes
    if (appPreset) {
      appPreset.addEventListener('change', (e) => {
        if (e.target.value === 'custom') {
          appName.value = '';
          appWatts.value = '';
          appHours.value = '';
        } else {
          try {
            const data = JSON.parse(e.target.value);
            appName.value = data.name;
            appWatts.value = data.watts;
            appHours.value = data.hours;
          } catch(err) {
            console.error("Invalid preset data");
          }
        }
      });
    }

    // Add Appliance
    if (addBtn) {
      addBtn.addEventListener('click', () => {
        const name = appName.value.trim();
        const watts = parseFloat(appWatts.value);
        const hours = parseFloat(appHours.value);

        if (!name || isNaN(watts) || isNaN(hours) || watts <= 0 || hours <= 0 || hours > 24) {
          alert('Please enter a valid name, wattage (> 0), and hours per day (0.1 - 24).');
          return;
        }

        appliances.push({ id: Date.now(), name, watts, hours });

        // Reset inputs to custom state
        appPreset.value = 'custom';
        appName.value = '';
        appWatts.value = '';
        appHours.value = '';

        updateUI();
      });
    }

    // Remove Appliance
    window.removeAppliance = (id) => {
      appliances = appliances.filter(app => app.id !== id);
      updateUI();
    };

    function updateUI() {
      if (appliances.length === 0) {
        resultsSection.classList.add('hidden');
        return;
      }

      resultsSection.classList.remove('hidden');

      let totalDaily = 0;
      let html = '';

      const chartLabels = [];
      const chartData = [];

      appliances.forEach(app => {
        // kWh per day = (watts * hours) / 1000
        const kwhDaily = (app.watts * app.hours) / 1000;
        const costDaily = kwhDaily * currentRate;
        const costMonthly = costDaily * 30.4;
        const costYearly = costDaily * 365;

        totalDaily += costDaily;

        chartLabels.push(app.name);
        chartData.push(costMonthly);

        html += `
          <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
            <td class="p-4">
              <div class="font-bold text-white">${app.name}</div>
              <div class="text-xs text-[var(--text-secondary)]"><span class="text-xs font-mono bg-green-500/10 text-green-400 px-2 py-0.5 rounded">${app.watts}W</span> &middot; ${app.hours}h/day</div>
            </td>
            <td class="p-4 text-white font-mono">${formatMoney(costDaily)}</td>
            <td class="p-4 text-white font-mono">${formatMoney(costMonthly)}</td>
            <td class="p-4 text-white font-mono">${formatMoney(costYearly)}</td>
            <td class="p-4 text-right">
              <button onclick="removeAppliance(${app.id})" class="text-red-400 hover:text-red-300 text-sm font-semibold transition-colors">Remove</button>
            </td>
          </tr>
        `;
      });

      appliancesList.innerHTML = html;

      totalDailyEl.innerText = formatMoney(totalDaily);
      totalMonthlyEl.innerText = formatMoney(totalDaily * 30.4);
      totalYearlyEl.innerText = formatMoney(totalDaily * 365);

      updateChart(chartLabels, chartData);
    }

    function updateChart(labels, data) {
      const ctx = document.getElementById('chart').getContext('2d');

      if (chartInstance) {
        chartInstance.destroy();
      }

      // Generate colors for chart
      const bgColors = data.map((_, i) => {
        const hue = (i * 137.5) % 360; // Golden angle for distribution
        return `hsla(${hue}, 70%, 60%, 0.7)`;
      });
      const borderColors = data.map((_, i) => {
        const hue = (i * 137.5) % 360;
        return `hsl(${hue}, 70%, 60%)`;
      });

      Chart.defaults.color = '#94a3b8'; // text-secondary
      Chart.defaults.font.family = "'Inter', sans-serif";

      chartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Monthly Cost ($)',
            data: data,
            backgroundColor: bgColors,
            borderColor: borderColors,
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  let label = context.dataset.label || '';
                  if (label) {
                    label += ': ';
                  }
                  if (context.parsed.y !== null) {
                    label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(context.parsed.y);
                  }
                  return label;
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(255, 255, 255, 0.05)',
                drawBorder: false
              },
              ticks: {
                callback: function(value) {
                  return '$' + value;
                }
              }
            },
            x: {
              grid: {
                display: false,
                drawBorder: false
              }
            }
          }
        }
      });
    }

  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-energy-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Home Energy Efficiency Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
