    var CATS = {all:"All",lighting:"Lighting",kitchen:"Kitchen",hvac:"HVAC",laundry:"Laundry",electronics:"Electronics",utility:"Utility"};
    var activeCat = "all";
    var hList = [];

    // Build category tabs
    var tabsEl = document.getElementById("catTabs");
    Object.keys(CATS).forEach(function(key) {
      var b = document.createElement("button");
      b.type = "button";
      b.className = "cat-tab" + (key === "all" ? " active" : "");
      b.textContent = CATS[key];
      b.addEventListener("click", function() {
        activeCat = key;
        tabsEl.querySelectorAll(".cat-tab").forEach(function(t){ t.classList.remove("active"); });
        b.classList.add("active");
        renderGrid();
      });
      tabsEl.appendChild(b);
    });

    function renderGrid() {
      var g = document.getElementById("appGrid");
      g.innerHTML = "";
      var list = activeCat === "all" ? DB : DB.filter(function(a){ return a.c === activeCat; });
      list.forEach(function(a) {
        var b = document.createElement("button");
        b.type = "button";
        b.className = "appliance-btn";
        b.innerHTML = '<span>' + a.n + '</span><span class="watt">' + a.w + 'W</span>';
        b.addEventListener("click", function() {
          document.getElementById("wattage").value = a.w;
          document.getElementById("hours").value = a.h;
          window._selectedName = a.n;
        });
        g.appendChild(b);
      });
    }
    renderGrid();

    function fmt(n) { return "$" + n.toFixed(2); }
    function fk(n) { return n.toFixed(2); }

    document.getElementById("calcForm").addEventListener("submit", function(e) {
      e.preventDefault();
      var w = parseFloat(document.getElementById("wattage").value);
      var h = parseFloat(document.getElementById("hours").value);
      var r = parseFloat(document.getElementById("rate").value);
      if (isNaN(w) || isNaN(h) || isNaN(r)) return;
      var dk = (w * h) / 1000;
      var dc = dk * r;
      document.getElementById("rDaily").textContent = fmt(dc);
      document.getElementById("rDailyKwh").textContent = fk(dk);
      document.getElementById("rWeekly").textContent = fmt(dc * 7);
      document.getElementById("rWeeklyKwh").textContent = fk(dk * 7);
      document.getElementById("rMonthly").textContent = fmt(dc * 30);
      document.getElementById("rMonthlyKwh").textContent = fk(dk * 30);
      document.getElementById("rYearly").textContent = fmt(dc * 365);
      document.getElementById("rYearlyKwh").textContent = fk(dk * 365);
      document.getElementById("results").classList.add("active");
    });

    // Multi-appliance
    document.getElementById("addBtn").addEventListener("click", function() {
      var w = parseFloat(document.getElementById("wattage").value);
      var h = parseFloat(document.getElementById("hours").value);
      var r = parseFloat(document.getElementById("rate").value);
      if (isNaN(w) || isNaN(h) || isNaN(r) || w <= 0) return;
      var name = window._selectedName || (w + "W Appliance");
      var match = DB.find(function(a){ return a.w === w; });
      if (match && !window._selectedName) name = match.n;
      window._selectedName = null;
      var dk = (w * h) / 1000;
      hList.push({ name: name, w: w, h: h, r: r, dk: dk, mc: dk * r * 30, yc: dk * r * 365 });
      renderList();
    });

    function renderList() {
      var el = document.getElementById("appList");
      el.innerHTML = "";
      if (!hList.length) {
        document.getElementById("totals").style.display = "none";
        document.getElementById("comparison").style.display = "none";
        return;
      }
      hList.forEach(function(item, i) {
        var row = document.createElement("div");
        row.className = "app-list-item";
        row.innerHTML = '<div class="info"><span class="name">' + item.name + '</span><span class="detail"> · ' + item.w + 'W · ' + item.h + 'h/day</span></div>' +
          '<span class="cost">' + fmt(item.mc) + '/mo</span>' +
          '<button class="remove-btn" data-i="' + i + '">×</button>';
        el.appendChild(row);
      });
      el.querySelectorAll(".remove-btn").forEach(function(b) {
        b.addEventListener("click", function() {
          hList.splice(parseInt(this.dataset.i), 1);
          renderList();
        });
      });
      var tmc = hList.reduce(function(s, x){ return s + x.mc; }, 0);
      var tdc = hList.reduce(function(s, x){ return s + x.dk * x.r; }, 0);
      var tyc = hList.reduce(function(s, x){ return s + x.yc; }, 0);
      var tkwh = hList.reduce(function(s, x){ return s + x.dk * 30; }, 0);
      document.getElementById("tMonthly").textContent = fmt(tmc);
      document.getElementById("tDaily").textContent = fmt(tdc);
      document.getElementById("tYearly").textContent = fmt(tyc);
      document.getElementById("tKwh").textContent = fk(tkwh) + " kWh";
      document.getElementById("totals").style.display = "block";

      // Comparison bars
      var avg = 142;
      var mx = Math.max(tmc, avg) * 1.2;
      document.getElementById("yourBar").style.width = ((tmc / mx) * 100) + "%";
      document.getElementById("avgBar").style.width = ((avg / mx) * 100) + "%";
      document.getElementById("yourLabel").textContent = fmt(tmc);
      document.getElementById("comparison").style.display = "block";
    }
  </script>

