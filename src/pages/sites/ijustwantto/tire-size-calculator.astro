---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tire Size Calculator & Speedometer Error Tool",
  description: "Upgrading your wheels? Discover exactly how your new tire size impacts your speedometer accuracy, gearing, and vehicle clearance before making a costly mistake.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you read a tire size correctly?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A typical tire size like 225/65R17 is broken down into three main parts. The '225' represents the tire width in millimeters from sidewall to sidewall. The '65' is the aspect ratio, meaning the sidewall height is 65% of the width. The 'R' stands for radial construction, and '17' indicates the wheel diameter in inches."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I put bigger tires on my car?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Installing larger tires increases the overall diameter of your wheel setup. This causes your speedometer to read slower than your actual speed, effectively altering your final drive ratio. It can also reduce wheel well clearance, potentially causing rubbing when turning or going over bumps, and may decrease acceleration and braking performance due to increased unsprung weight."
        }
      },
      {
        "@type": "Question",
        "name": "How much difference in tire size is acceptable?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "As a general rule of thumb, it is recommended to keep the overall diameter of your new tires within 3% of the original factory tires. Exceeding this 3% threshold can cause significant issues with anti-lock braking systems (ABS), traction control, and speedometer accuracy, and may lead to mechanical wear over time."
        }
      },
      {
        "@type": "Question",
        "name": "Does changing tire size affect gas mileage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, changing your tire size can significantly affect fuel economy. Larger, heavier tires increase rolling resistance and aerodynamic drag, which generally decreases miles per gallon (MPG). Additionally, because a larger tire travels further per revolution, your odometer will record fewer miles than actually traveled, artificially making your MPG calculation appear even lower."
        }
      },
      {
        "@type": "Question",
        "name": "Why is my speedometer wrong after changing tires?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your vehicle calculates speed based on the number of wheel revolutions over time, calibrated to the factory tire diameter. When you install larger tires, they travel a greater distance per revolution. Because the computer still thinks it's spinning the smaller factory tires, your speedometer will display a speed that is slower than your actual physical speed."
        }
      }
    ]
  }
];
---

<SiteLayout site="ijustwantto" title={meta.title} description={meta.description} canonical="https://ijustwantto.live/tire-size-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Tire Size Calculator</h1>
      <p class="subtitle">Compare tire dimensions, calculate speedometer error, and visualize clearance changes.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="tire-input-group">
          <h3>Current Tire (OEM)</h3>
          <div class="input-row">
            <div class="input-field">
              <label for="width1">Width (mm)</label>
              <input type="number" id="width1" value="225" min="100" max="400" step="5">
            </div>
            <div class="input-separator">/</div>
            <div class="input-field">
              <label for="aspect1">Aspect Ratio</label>
              <input type="number" id="aspect1" value="65" min="20" max="100" step="5">
            </div>
            <div class="input-separator">R</div>
            <div class="input-field">
              <label for="wheel1">Wheel (in)</label>
              <input type="number" id="wheel1" value="17" min="10" max="30" step="1">
            </div>
          </div>
        </div>

        <div class="tire-input-group">
          <h3>New Tire</h3>
          <div class="input-row">
            <div class="input-field">
              <label for="width2">Width (mm)</label>
              <input type="number" id="width2" value="245" min="100" max="400" step="5">
            </div>
            <div class="input-separator">/</div>
            <div class="input-field">
              <label for="aspect2">Aspect Ratio</label>
              <input type="number" id="aspect2" value="65" min="20" max="100" step="5">
            </div>
            <div class="input-separator">R</div>
            <div class="input-field">
              <label for="wheel2">Wheel (in)</label>
              <input type="number" id="wheel2" value="17" min="10" max="30" step="1">
            </div>
          </div>
        </div>
      </div>

      <div id="error-message" class="error-state" style="display: none;">
        Please enter valid positive numbers for all tire dimensions.
      </div>

      <div class="results-table-container">
        <table class="results-table">
          <thead>
            <tr>
              <th>Dimension</th>
              <th>Current Tire</th>
              <th>New Tire</th>
              <th>Difference</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Diameter</td>
              <td id="dia1">-</td>
              <td id="dia2">-</td>
              <td id="dia-diff" class="diff-col">-</td>
            </tr>
            <tr>
              <td>Width</td>
              <td id="wid1">-</td>
              <td id="wid2">-</td>
              <td id="wid-diff" class="diff-col">-</td>
            </tr>
            <tr>
              <td>Sidewall</td>
              <td id="sid1">-</td>
              <td id="sid2">-</td>
              <td id="sid-diff" class="diff-col">-</td>
            </tr>
            <tr>
              <td>Circumference</td>
              <td id="cir1">-</td>
              <td id="cir2">-</td>
              <td id="cir-diff" class="diff-col">-</td>
            </tr>
            <tr>
              <td>Revs / Mile</td>
              <td id="rev1">-</td>
              <td id="rev2">-</td>
              <td id="rev-diff" class="diff-col">-</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="speedometer-section">
        <h3>Speedometer Error</h3>
        <p class="speed-desc">When your speedometer reads <strong>65 mph</strong>, your actual speed will be:</p>
        <div class="result-card">
          <div class="result-value" id="actual-speed">-- mph</div>
          <div class="diameter-variance" id="dia-variance-alert">Diameter variance: --%</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Tire Sizes and the Mathematics of Upgrades</h2>
      <p>Whether you're looking to improve your vehicle's off-road capability, enhance its aesthetic appeal, or simply replace worn-out rubber, understanding the mechanics of tire sizing is crucial. Modifying your tire dimensions isn't just about making sure the new wheels fit inside the wheel wells; it fundamentally alters the physics of how your vehicle interacts with the road. The interactive tire size calculator provided above takes the guesswork out of this process, providing precise mathematical comparisons between your original equipment manufacturer (OEM) tires and your proposed upgrade.</p>

      <p>Before making a costly purchase, it is highly recommended to use this tool alongside our <a href="/annuity-calculator">financial calculators</a> to ensure your automotive investments align with your long-term budget. Now, let's dive into the core methodologies and formulas used to determine tire dimensions.</p>

      <h3>How to Read a Metric Tire Size</h3>
      <p>Most modern passenger vehicles use the P-Metric or Euro-Metric tire sizing system. A typical sequence looks like <strong>225/65R17</strong>. While this string of characters might appear cryptic, it provides all the necessary variables to mathematically construct the tire's physical profile.</p>

      <ul>
        <li><strong>Width (225):</strong> The first number represents the section width of the tire in millimeters, measured from the widest point of the inner sidewall to the widest point of the outer sidewall when mounted on an appropriately sized rim.</li>
        <li><strong>Aspect Ratio (65):</strong> The second number is a percentage, not an absolute measurement. It represents the height of the sidewall as a percentage of the section width. In this example, the sidewall height is 65% of 225mm.</li>
        <li><strong>Construction (R):</strong> The letter indicates internal construction. "R" stands for Radial, meaning the internal ply cords radiate at 90 degrees to the direction of travel. You might also encounter "D" for Diagonal bias or "B" for Bias-belted, though these are increasingly rare on modern consumer vehicles.</li>
        <li><strong>Wheel Diameter (17):</strong> The final number represents the diameter of the wheel (rim) that the tire is designed to fit, measured in inches. Notice the mixing of metric (millimeters) and imperial (inches) units, which requires conversion during mathematical operations.</li>
      </ul>

      <h3>The Mathematics of Tire Dimensions</h3>
      <p>To accurately compare two tires, we must calculate their overall diameter, sidewall height, circumference, and the resulting revolutions per mile. Because tire sizes use a mixture of metric and imperial units, a conversion factor of 25.4 (the number of millimeters in one inch) is critical.</p>

      <h4>Calculating Sidewall Height</h4>
      <p>First, we determine the physical height of the sidewall. Because the aspect ratio is a percentage, we multiply the width by the aspect ratio divided by 100. To convert this from millimeters to inches for easier calculation of the overall diameter, we divide the result by 25.4.</p>
      <p><em>Sidewall Height (inches) = (Width × (Aspect Ratio / 100)) / 25.4</em></p>

      <h4>Calculating Overall Diameter</h4>
      <p>A tire consists of the wheel in the center, flanked by the sidewall on both the top and bottom. Therefore, the overall diameter is simply the diameter of the wheel plus twice the sidewall height.</p>
      <p><em>Overall Diameter (inches) = Wheel Diameter + (2 × Sidewall Height)</em></p>
      <p>This single metric is the most important factor when upgrading. A general automotive industry rule of thumb states that a replacement tire's overall diameter should remain within 3% of the factory original. Exceeding this variance places undue stress on the drivetrain, alters the effectiveness of anti-lock braking systems (ABS) and electronic stability control (ESC), and severely impacts gearing.</p>

      <h4>Calculating Circumference and Revolutions Per Mile</h4>
      <p>The circumference dictates how far the vehicle travels forward with exactly one full rotation of the tire. Using standard geometry, we multiply the overall diameter by Pi (π, approximately 3.14159).</p>
      <p><em>Circumference (inches) = Overall Diameter × π</em></p>
      <p>To understand the impact on the vehicle's odometer and speedometer, we calculate how many times the tire revolves over the course of exactly one mile. Since there are 63,360 inches in a mile, we divide this constant by the circumference.</p>
      <p><em>Revolutions per Mile = 63,360 / Circumference</em></p>

      <h3>The Impact of Tire Size on Speedometer Accuracy</h3>
      <p>Your vehicle's speedometer does not measure how fast you are moving relative to the stationary ground. Instead, it measures rotational velocity—specifically, how fast the transmission output shaft or wheel hubs are spinning. The vehicle's onboard computer is programmed at the factory to convert this rotational speed into miles per hour (MPH) or kilometers per hour (KPH) based on the exact circumference of the factory-installed OEM tires.</p>
      <p>When you install a tire with a larger overall diameter, its circumference increases. This means that for every single revolution of the wheel, the vehicle travels a greater physical distance than it did previously. However, the computer is unaware of this mechanical change; it still expects the vehicle to travel the original, shorter distance per revolution.</p>
      <p>As a result, an oversized tire causes your speedometer to read slower than your actual road speed. If the new tire is 5% larger in circumference, your actual speed is 5% faster than what is displayed on the dashboard. This hidden variance is a frequent cause of unexpected speeding tickets following a suspension lift and tire upgrade.</p>
      <p>Conversely, installing a tire with a smaller overall diameter forces the wheel to rotate more times to cover the same distance. The computer registers these extra rotations and incorrectly assumes you are traveling faster, resulting in a speedometer reading that is higher than your true speed.</p>

      <h3>Gearing, Torque, and Unsprung Weight</h3>
      <p>Beyond speedometer discrepancies, tire size fundamentally alters your vehicle's effective gearing. Upgrading to significantly larger, heavier tires acts as an overdrive gear. While this might theoretically lower highway cruising RPMs, it actively reduces the mechanical advantage of your engine and transmission.</p>
      <p>This loss of mechanical advantage manifests as sluggish acceleration, reduced hill-climbing ability, and diminished towing capacity. To compensate, off-road enthusiasts frequently re-gear their vehicle's differentials (changing the ring and pinion ratios) to restore the factory powerband when running massive mud-terrain tires.</p>
      <p>Furthermore, larger tires increase unsprung weight—the mass of the suspension, wheels, and other components not supported by the vehicle's springs. An increase in unsprung weight forces the shock absorbers to work significantly harder to keep the tire in contact with irregular road surfaces, often leading to a harsher ride quality and accelerated wear on steering linkages, ball joints, and wheel bearings. It also dramatically increases rotational inertia, meaning your brakes must absorb substantially more kinetic energy to bring the heavier rotating mass to a stop, significantly increasing braking distances.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map(faq => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>
  </div>

  <script is:inline>
    function calculateTire() {
      // Get Tire 1 values
      const w1 = parseFloat(document.getElementById('width1').value);
      const a1 = parseFloat(document.getElementById('aspect1').value);
      const d1 = parseFloat(document.getElementById('wheel1').value);

      // Get Tire 2 values
      const w2 = parseFloat(document.getElementById('width2').value);
      const a2 = parseFloat(document.getElementById('aspect2').value);
      const d2 = parseFloat(document.getElementById('wheel2').value);

      const errorMsg = document.getElementById('error-message');

      if (isNaN(w1) || isNaN(a1) || isNaN(d1) || isNaN(w2) || isNaN(a2) || isNaN(d2) ||
          w1 <= 0 || a1 <= 0 || d1 <= 0 || w2 <= 0 || a2 <= 0 || d2 <= 0) {
        errorMsg.style.display = 'block';
        return;
      }
      errorMsg.style.display = 'none';

      // Tire 1 Calculations
      const sw1 = (w1 * (a1 / 100)) / 25.4; // Sidewall height in inches
      const od1 = (sw1 * 2) + d1; // Overall diameter in inches
      const circ1 = od1 * Math.PI; // Circumference in inches
      const rev1 = 63360 / circ1; // Revolutions per mile
      const wInches1 = w1 / 25.4; // Width in inches

      // Tire 2 Calculations
      const sw2 = (w2 * (a2 / 100)) / 25.4; // Sidewall height in inches
      const od2 = (sw2 * 2) + d2; // Overall diameter in inches
      const circ2 = od2 * Math.PI; // Circumference in inches
      const rev2 = 63360 / circ2; // Revolutions per mile
      const wInches2 = w2 / 25.4; // Width in inches

      // Populate Table
      const updateCell = (id, val1, val2, suffix) => {
        document.getElementById(id + '1').textContent = val1.toFixed(2) + suffix;
        document.getElementById(id + '2').textContent = val2.toFixed(2) + suffix;
        const diff = val2 - val1;
        const diffEl = document.getElementById(id + '-diff');
        const sign = diff > 0 ? '+' : '';
        diffEl.textContent = sign + diff.toFixed(2) + suffix;
        diffEl.style.color = diff === 0 ? 'var(--text-secondary)' : (diff > 0 ? '#10b981' : '#ef4444');
      };

      updateCell('dia', od1, od2, '"');
      updateCell('wid', wInches1, wInches2, '"');
      updateCell('sid', sw1, sw2, '"');
      updateCell('cir', circ1, circ2, '"');
      updateCell('rev', rev1, rev2, '');

      // Speedometer Error
      // If rev1 is the baseline, true speed = (rev1 / rev2) * indicated_speed
      const indicatedSpeed = 65;
      const trueSpeed = (rev1 / rev2) * indicatedSpeed;
      document.getElementById('actual-speed').textContent = trueSpeed.toFixed(1) + ' mph';

      const diaVariance = ((od2 - od1) / od1) * 100;
      const alertEl = document.getElementById('dia-variance-alert');
      alertEl.textContent = 'Diameter variance: ' + (diaVariance > 0 ? '+' : '') + diaVariance.toFixed(2) + '%';

      if (Math.abs(diaVariance) > 3) {
        alertEl.style.color = '#ef4444'; // Red if > 3%
        alertEl.textContent += ' ⚠️ Exceeds 3% recommended limit';
      } else {
        alertEl.style.color = 'var(--text-secondary)';
      }
    }

    // Attach event listeners
    const inputs = document.querySelectorAll('input');
    inputs.forEach(input => {
      input.addEventListener('input', calculateTire);
    });

    // Initial calculation
    calculateTire();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
    @media (max-width: 640px) { .calc-grid { grid-template-columns: 1fr; } }

    .tire-input-group h3 { margin-top: 0; margin-bottom: 1rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; }
    .input-row { display: flex; align-items: flex-end; gap: 0.5rem; }
    .input-field { flex: 1; }
    .input-field label { display: block; font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.25rem; }
    .input-separator { padding-bottom: 0.75rem; font-weight: bold; color: var(--text-secondary); }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 0.5rem; border-radius: 8px; width: 100%; font-size: 1rem; text-align: center; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .error-state { background: color-mix(in srgb, #ef4444 10%, transparent); color: #ef4444; border: 1px solid #ef4444; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; text-align: center; font-weight: 600; }

    .results-table-container { overflow-x: auto; margin-bottom: 2rem; }
    .results-table { width: 100%; border-collapse: collapse; text-align: center; }
    .results-table th, .results-table td { padding: 1rem; border-bottom: 1px solid var(--border-color); }
    .results-table th { background: color-mix(in srgb, var(--bg-color) 50%, transparent); font-weight: 600; color: var(--text-secondary); }
    .diff-col { font-weight: 600; }

    .speedometer-section { text-align: center; }
    .speed-desc { margin-bottom: 1rem; color: var(--text-secondary); }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); margin-bottom: 0.5rem; }
    .diameter-variance { font-size: 1rem; font-weight: 600; }

    .explainer { margin-top: 3rem; line-height: 1.7; }
    .explainer h2 { margin-top: 2rem; margin-bottom: 1rem; }
    .explainer h3 { margin-top: 1.5rem; margin-bottom: 0.75rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer ul { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }

    .faq-section { margin-top: 3rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .faq-section p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
