---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Indoor Plants for Beginners: Top 20 Houseplants Ranked",
    "description": "Discover the 20 best indoor plants for beginners, ranked by difficulty. Includes care instructions, light requirements, and toxicity information.",
    "author": {
      "@type": "Organization",
      "name": "I Just Want To"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the easiest indoor plant to keep alive?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Snake Plant (Sansevieria) and ZZ Plant (Zamioculcas zamiifolia) are widely considered the easiest indoor plants. They tolerate low light and irregular watering better than almost any other houseplant."
        }
      },
      {
        "@type": "Question",
        "name": "How often should I water my indoor plants?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Watering frequency depends on the plant, pot size, and environment. A general rule for most houseplants is to let the top 1-2 inches of soil dry out before watering again. Overwatering is the most common cause of plant death."
        }
      },
      {
        "@type": "Question",
        "name": "Which indoor plants are safe for cats and dogs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Spider Plants, Boston Ferns, Parlor Palms, and certain succulents like Haworthia and Echeveria are non-toxic to pets. Always verify a plant's toxicity before bringing it into a home with animals."
        }
      },
      {
        "@type": "Question",
        "name": "Why are the leaves on my plant turning yellow?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yellow leaves are most often a sign of overwatering or poor drainage. Ensure your pot has drainage holes and the soil isn't soggy. Less common causes include under-watering, lack of light, or nutrient deficiency."
        }
      },
      {
        "@type": "Question",
        "name": "When is the best time to repot my houseplants?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The best time to repot most houseplants is in early spring, just before their active growing season begins. You should repot when roots are growing out of the drainage holes or circling the surface."
        }
      }
    ]
  }
];

