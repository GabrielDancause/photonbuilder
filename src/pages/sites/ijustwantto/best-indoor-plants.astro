const renderDifficulty = (level: number) => {
  const circles = [];
  for (let i = 1; i <= 5; i++) {
    circles.push(`<span class="diff-circle ${i <= level ? 'filled' : ''}"></span>`);
  }
  return circles.join('');
};

const getDifficultyLabel = (level: number) => {
  if (level === 1) return "Near Indestructible";
  if (level === 2) return "Very Easy";
  if (level === 3) return "Easy/Moderate";
  if (level === 4) return "Needs Attention";
  return "Fussy / Experienced Beginners Only";
};

// Sort plants by difficulty as requested
const sortedPlants = plants.sort((a, b) => a.difficulty - b.difficulty);
---

<SiteLayout
  site="ijustwantto"
  title="Best Indoor Plants for Beginners: Top 20 Ranked | I Just Want To"
  description="Discover the 20 best indoor plants for beginners, ranked by difficulty. Includes care instructions, light requirements, and toxicity information."
  canonical="https://ijustwantto.live/best-indoor-plants"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>The 20 Best Indoor Plants for Beginners</h1>
      <p>Transform your space with these low-maintenance, beautiful houseplants. Ranked from near-indestructible to slightly fussy.</p>
    </div>

    <div class="content-section">
      <p>Adding greenery to your home doesn't require a green thumb. Countless houseplants have adapted to survive in typical indoor environments with minimal care. Whether you have low-light rooms, forget to water, or have curious pets, there is a perfect plant for your situation.</p>

      <p>We've compiled the top 20 indoor plants for beginners. Each plant is ranked on a difficulty scale of 1 to 5, where 1 means "near indestructible" and 5 means "requires a bit more attention but still manageable for an ambitious beginner."</p>

      <h2>The Top 20 Houseplants Ranked</h2>

      <div class="plants-container">
        {sortedPlants.map((plant, index) => (
          <div class="plant-card">
            <div class="plant-header">
              <h3><span>#{index + 1}</span> {plant.name}</h3>
              <div class="difficulty-rating">
                <div class="diff-circles" set:html={renderDifficulty(plant.difficulty)}></div>
                <span class="diff-label">{getDifficultyLabel(plant.difficulty)}</span>
              </div>
            </div>

            <div class="plant-details">
              <div class="detail-row">
                <strong><span class="icon">☀️</span> Light:</strong> {plant.light}
              </div>
              <div class="detail-row">
                <strong><span class="icon">💧</span> Water:</strong> {plant.water}
              </div>
              <div class="detail-row">
                <strong><span class="icon">🐾</span> Pet Safety:</strong>
                <span class={plant.toxic.includes("Non-toxic") ? "safe" : "warning"}>{plant.toxic}</span>
              </div>
              <div class="detail-row">
                <strong><span class="icon">🌬️</span> Air Purifying:</strong> {plant.air}
              </div>
              <div class="detail-row">
                <strong><span class="icon">📈</span> Growth Rate:</strong> {plant.growth}
              </div>
              <div class="detail-row problems">
                <strong><span class="icon">⚠️</span> Common Problems:</strong> {plant.problems}
              </div>
            </div>
          </div>
        ))}
      </div>

      <h2>Houseplant Care Fundamentals</h2>
      <p>Even the easiest plants need the right foundation to thrive. Master these four basic concepts, and you'll be able to keep almost any beginner plant alive.</p>

      <div class="care-section">
        <h3>1. Potting Soil Types</h3>
        <p>Never use garden dirt for indoor plants. It's too heavy and compacts easily, suffocating roots. Instead, use specific mixes:</p>
        <ul>
          <li><strong>Standard Potting Mix:</strong> Good for most tropical plants (Pothos, Philodendrons). Usually contains peat moss or coco coir, perlite, and pine bark.</li>
          <li><strong>Cactus/Succulent Mix:</strong> Essential for Snake Plants, ZZ Plants, Jade, and Aloe. This mix contains extra sand or pumice for rapid drainage.</li>
          <li><strong>Orchid Bark/Chunky Mix:</strong> Ideal for epiphytes like Monstera and certain ferns. Allows for maximum airflow around the roots.</li>
        </ul>
      </div>

      <div class="care-section">
        <h3>2. Fertilizing Schedule</h3>
        <p>Plants only need "food" when they are actively growing. Over-fertilizing can burn roots and damage the plant.</p>
        <ul>
          <li><strong>Spring and Summer:</strong> This is the active growing season. Fertilize once a month using a balanced, water-soluble liquid fertilizer diluted to half-strength.</li>
          <li><strong>Fall and Winter:</strong> Stop fertilizing entirely. Plants naturally slow down their growth during shorter, darker days.</li>
        </ul>
      </div>

      <div class="care-section">
        <h3>3. Recognizing Common Pests</h3>
        <p>Keep an eye out for these uninvited guests. Catching them early makes them easy to treat with Neem oil or insecticidal soap.</p>
        <ul>
          <li><strong>Fungus Gnats:</strong> Tiny black flies around the soil surface. Usually a sign of overwatering. Let the top soil dry out completely.</li>
          <li><strong>Spider Mites:</strong> Microscopic pests that create fine webbing under leaves. They love dry, warm air. Increase humidity and wipe leaves down.</li>
          <li><strong>Mealybugs:</strong> Look like tiny, fuzzy white cotton balls stuck in the crevices of stems and leaves. Wipe them away with a cotton swab dipped in rubbing alcohol.</li>
        </ul>
      </div>

      <div class="care-section">
        <h3>4. When to Repot</h3>
        <p>Many beginners make the mistake of repotting a plant as soon as they bring it home. Don't do this! The plant needs time to acclimate to your home's light and humidity. Wait at least a few weeks, or ideally until spring. You should only repot when:</p>
        <ul>
          <li>Roots are growing out of the bottom drainage holes.</li>
          <li>The soil dries out incredibly fast (within 2 days of watering).</li>
          <li>The plant is severely root-bound, pushing itself up and out of the pot.</li>
          <li><strong>Pro-tip:</strong> When repotting, only go up one pot size (about 1-2 inches larger in diameter). A pot that is too large holds excess wet soil, leading to root rot.</li>
        </ul>
      </div>
    </div>

    <!-- FAQs -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>What is the easiest indoor plant to keep alive?</h3>
          <p>The Snake Plant (Sansevieria) and ZZ Plant (Zamioculcas zamiifolia) are widely considered the easiest indoor plants. They tolerate low light and irregular watering better than almost any other houseplant.</p>
        </div>
        <div class="faq-item">
          <h3>How often should I water my indoor plants?</h3>
          <p>Watering frequency depends on the plant, pot size, and environment. A general rule for most houseplants is to let the top 1-2 inches of soil dry out before watering again. Overwatering is the most common cause of plant death.</p>
        </div>
        <div class="faq-item">
          <h3>Which indoor plants are safe for cats and dogs?</h3>
          <p>Spider Plants, Boston Ferns, Parlor Palms, and certain succulents like Haworthia and Echeveria are non-toxic to pets. Always verify a plant's toxicity before bringing it into a home with animals.</p>
        </div>
        <div class="faq-item">
          <h3>Why are the leaves on my plant turning yellow?</h3>
          <p>Yellow leaves are most often a sign of overwatering or poor drainage. Ensure your pot has drainage holes and the soil isn't soggy. Less common causes include under-watering, lack of light, or nutrient deficiency.</p>
        </div>
        <div class="faq-item">
          <h3>When is the best time to repot my houseplants?</h3>
          <p>The best time to repot most houseplants is in early spring, just before their active growing season begins. You should repot when roots are growing out of the drainage holes or circling the surface.</p>
        </div>
      </div>
    </div>
  </div>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .content-section { margin-bottom: 3rem; line-height: 1.7; }
    .content-section p { margin-bottom: 1.2rem; }
    .content-section h2 { font-size: 1.8rem; margin: 2.5rem 0 1.5rem; color: var(--accent-color); border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }

    .plants-container { display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 3rem; }
    .plant-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }

    .plant-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; flex-wrap: wrap; gap: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; }
    .plant-header h3 { font-size: 1.4rem; margin: 0; display: flex; align-items: center; gap: 0.5rem; }
    .plant-header h3 span { color: var(--text-secondary); font-size: 1.2rem; font-weight: normal; }

    .difficulty-rating { display: flex; flex-direction: column; align-items: flex-end; }
    .diff-circles { display: flex; gap: 4px; margin-bottom: 4px; }
    .diff-circle { width: 12px; height: 12px; border-radius: 50%; background: var(--border-color); border: 1px solid var(--text-secondary); }
    .diff-circle.filled { background: var(--accent-color); border-color: var(--accent-color); }
    .diff-label { font-size: 0.8rem; color: var(--text-secondary); font-weight: 500; }

    .plant-details { display: grid; grid-template-columns: 1fr; gap: 0.8rem; }
    @media (min-width: 768px) {
      .plant-details { grid-template-columns: 1fr 1fr; }
      .plant-details .problems { grid-column: 1 / -1; }
    }
    .detail-row { font-size: 0.95rem; }
    .detail-row .icon { display: inline-block; width: 24px; text-align: center; }
    .detail-row strong { color: inherit; }
    .safe { color: #10b981; font-weight: 600; }
    .warning { color: #f59e0b; font-weight: 600; }
    .problems { margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px dashed var(--border-color); color: var(--text-secondary); }

    .care-section { background: var(--card-bg); border-left: 4px solid var(--accent-color); padding: 1.5rem; margin-bottom: 1.5rem; border-radius: 0 8px 8px 0; }
    .care-section h3 { margin-top: 0; font-size: 1.3rem; margin-bottom: 0.8rem; }
    .care-section ul { margin-bottom: 0; padding-left: 1.5rem; }
    .care-section li { margin-bottom: 0.5rem; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; text-align: center; border-bottom: none; }
    .faq-item { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); }
    .faq-item:last-child { border-bottom: none; }
    .faq-item h3 { font-size: 1.2rem; margin-bottom: 0.8rem; }
    .faq-item p { color: var(--text-secondary); line-height: 1.6; }

    @media (max-width: 600px) {
      .plant-header { flex-direction: column; align-items: flex-start; }
      .difficulty-rating { align-items: flex-start; }
    }
  </style>
</SiteLayout>