---
import SiteLayout from "../../../layouts/SiteLayout.astro";


export const meta = {
  title: 'Soil Mixes',
  description: 'Use well-draining soil for most tropicals. Succulents need specialized cactus mix containing perlite and sand for fast drainage. A general tropical mix is 2 parts potting soil, 1 part perlite, and 1 part orchid bark.',
  category: 'list',
};

const lowLightPlants = [
  { name: "Pothos", light: "Low to Bright Indirect", water: "Allow top 1-2 inches of soil to dry", humidity: "Average", toxicity: "Toxic to pets", difficulty: "Very Easy" },
  { name: "Snake Plant", light: "Low to Bright Indirect", water: "Allow soil to dry completely", humidity: "Average", toxicity: "Toxic to pets", difficulty: "Very Easy" },
  { name: "ZZ Plant", light: "Low to Bright Indirect", water: "Allow soil to dry completely", humidity: "Average", toxicity: "Toxic to pets", difficulty: "Very Easy" },
  { name: "Cast Iron Plant", light: "Low Light", water: "Allow top 1-2 inches of soil to dry", humidity: "Average", toxicity: "Non-toxic", difficulty: "Easy" },
  { name: "Parlor Palm", light: "Low to Bright Indirect", water: "Keep soil lightly moist", humidity: "High", toxicity: "Non-toxic", difficulty: "Easy" }
];

const brightIndirectPlants = [
  { name: "Monstera Deliciosa", light: "Bright Indirect", water: "Allow top 2-3 inches of soil to dry", humidity: "High", toxicity: "Toxic to pets", difficulty: "Easy" },
  { name: "Fiddle Leaf Fig", light: "Bright Indirect", water: "Allow top 1-2 inches of soil to dry", humidity: "High", toxicity: "Toxic to pets", difficulty: "Moderate" },
  { name: "Rubber Plant", light: "Bright Indirect", water: "Allow top 1-2 inches of soil to dry", humidity: "Average", toxicity: "Toxic to pets", difficulty: "Easy" },
  { name: "Bird of Paradise", light: "Bright Indirect to Direct", water: "Allow top 2 inches of soil to dry", humidity: "High", toxicity: "Toxic to pets", difficulty: "Moderate" },
  { name: "Chinese Evergreen", light: "Medium to Bright Indirect", water: "Allow top 1 inch of soil to dry", humidity: "Average", toxicity: "Toxic to pets", difficulty: "Easy" }
];

const succulents = [
  { name: "Jade Plant", light: "Bright Indirect to Direct", water: "Allow soil to dry completely", humidity: "Low", toxicity: "Toxic to pets", difficulty: "Easy" },
  { name: "Aloe Vera", light: "Bright Indirect to Direct", water: "Allow soil to dry completely", humidity: "Low", toxicity: "Toxic to pets", difficulty: "Easy" },
  { name: "String of Pearls", light: "Bright Indirect", water: "Allow soil to dry completely", humidity: "Low", toxicity: "Toxic to pets", difficulty: "Moderate" },
  { name: "Zebra Haworthia", light: "Bright Indirect", water: "Allow soil to dry completely", humidity: "Low", toxicity: "Non-toxic", difficulty: "Easy" },
  { name: "Echeveria", light: "Bright Indirect to Direct", water: "Allow soil to dry completely", humidity: "Low", toxicity: "Non-toxic", difficulty: "Easy" }
];

const trailingPlants = [
  { name: "Heartleaf Philodendron", light: "Low to Bright Indirect", water: "Allow top 1-2 inches of soil to dry", humidity: "Average", toxicity: "Toxic to pets", difficulty: "Very Easy" },
  { name: "String of Hearts", light: "Bright Indirect", water: "Allow top 1-2 inches of soil to dry", humidity: "Average to High", toxicity: "Non-toxic", difficulty: "Moderate" },
  { name: "English Ivy", light: "Medium to Bright Indirect", water: "Keep soil lightly moist", humidity: "High", toxicity: "Toxic to pets", difficulty: "Moderate" },
  { name: "Spider Plant", light: "Bright Indirect", water: "Allow top 1-2 inches of soil to dry", humidity: "Average", toxicity: "Non-toxic", difficulty: "Very Easy" },
  { name: "Tradescantia Zebrina", light: "Bright Indirect", water: "Allow top 1-2 inches of soil to dry", humidity: "Average", toxicity: "Toxic to pets", difficulty: "Easy" }
];

const guides = [
  { title: "Soil Mixes", description: "Use well-draining soil for most tropicals. Succulents need specialized cactus mix containing perlite and sand for fast drainage. A general tropical mix is 2 parts potting soil, 1 part perlite, and 1 part orchid bark." },
  { title: "Repotting Guide", description: "Repot only when roots grow out of drainage holes or circle the pot, usually every 1-2 years in spring. Only move up 1-2 inches in pot diameter." },
  { title: "Pest Identification", description: "Look out for mealybugs (white cottony spots), spider mites (fine webbing), fungus gnats (small flying bugs), and scale (brown bumps). Treat with neem oil or insecticidal soap." }
];

const faqs = [
  { q: "How often should I water my indoor plants?", a: "It depends on the plant, but as a general rule, allow the top few inches of soil to dry out before watering again. Succulents need to dry out completely." },
  { q: "What does 'bright indirect light' mean?", a: "It means a bright spot near a window but out of direct sunlight. A south or east-facing window with a sheer curtain is ideal." },
  { q: "Why are the leaves on my plant turning yellow?", a: "Yellow leaves are usually a sign of overwatering, but can also indicate underwatering, poor drainage, or a nutrient deficiency." },
  { q: "How can I increase humidity for my tropical plants?", a: "Group plants together, use a pebble tray with water, mist them occasionally, or run a small humidifier nearby." },
  { q: "Which houseplants are safe for cats and dogs?", a: "Spider Plants, Parlor Palms, Cast Iron Plants, and String of Hearts are popular pet-safe options. Always check toxicity before bringing a new plant home." }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Indoor Plants for Beginners: 20 Easy-Care Houseplants",
    "description": "Discover 20 beginner-friendly indoor plants. Learn about their light needs, watering schedules, humidity preferences, toxicity, and care difficulty.",
    "author": {
      "@type": "Organization",
      "name": "I Just Want To"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  }
];
---
<SiteLayout
  site="ijustwantto"
  title="Best Indoor Plants for Beginners: 20 Easy-Care Houseplants"
  description="Discover 20 beginner-friendly indoor plants. Learn about their light needs, watering schedules, humidity preferences, toxicity, and care difficulty."
  canonical="https://ijustwantto.live/best-indoor-plants"
  schema={JSON.stringify(schema)}
>
  <div class="page-wrapper">
    <div class="hero">
      <h1>Best Indoor Plants for Beginners</h1>
      <p>Discover 20 beginner-friendly indoor plants, ranging from low-light favorites to stunning succulents, complete with care guides.</p>
    </div>

    <section class="content-section">
      <div class="page-content">

        <h2>Low Light Plants</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Plant Name</th>
                <th>Light Needs</th>
                <th>Watering Schedule</th>
                <th>Humidity Preference</th>
                <th>Toxicity</th>
                <th>Difficulty</th>
              </tr>
            </thead>
            <tbody>
              {lowLightPlants.map(plant => (
                <tr>
                  <td><strong>{plant.name}</strong></td>
                  <td>{plant.light}</td>
                  <td>{plant.water}</td>
                  <td>{plant.humidity}</td>
                  <td>{plant.toxicity}</td>
                  <td>{plant.difficulty}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Bright Indirect Plants</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Plant Name</th>
                <th>Light Needs</th>
                <th>Watering Schedule</th>
                <th>Humidity Preference</th>
                <th>Toxicity</th>
                <th>Difficulty</th>
              </tr>
            </thead>
            <tbody>
              {brightIndirectPlants.map(plant => (
                <tr>
                  <td><strong>{plant.name}</strong></td>
                  <td>{plant.light}</td>
                  <td>{plant.water}</td>
                  <td>{plant.humidity}</td>
                  <td>{plant.toxicity}</td>
                  <td>{plant.difficulty}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Succulents</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Plant Name</th>
                <th>Light Needs</th>
                <th>Watering Schedule</th>
                <th>Humidity Preference</th>
                <th>Toxicity</th>
                <th>Difficulty</th>
              </tr>
            </thead>
            <tbody>
              {succulents.map(plant => (
                <tr>
                  <td><strong>{plant.name}</strong></td>
                  <td>{plant.light}</td>
                  <td>{plant.water}</td>
                  <td>{plant.humidity}</td>
                  <td>{plant.toxicity}</td>
                  <td>{plant.difficulty}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Trailing Plants</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Plant Name</th>
                <th>Light Needs</th>
                <th>Watering Schedule</th>
                <th>Humidity Preference</th>
                <th>Toxicity</th>
                <th>Difficulty</th>
              </tr>
            </thead>
            <tbody>
              {trailingPlants.map(plant => (
                <tr>
                  <td><strong>{plant.name}</strong></td>
                  <td>{plant.light}</td>
                  <td>{plant.water}</td>
                  <td>{plant.humidity}</td>
                  <td>{plant.toxicity}</td>
                  <td>{plant.difficulty}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h2>Plant Care Guides</h2>
        <div class="winners-grid">
          {guides.map(guide => (
            <div class="winner-card">
              <span class="winner-label">Guide</span>
              <strong>{guide.title}</strong>
              <span class="winner-reason">{guide.description}</span>
            </div>
          ))}
        </div>

        <h2>Frequently Asked Questions</h2>
        {faqs.map(f => (
          <div class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>

<style>
  .page-wrapper {
    --text-primary: #1f2937;
    --text-secondary: #4b5563;
    --accent-color: #3b82f6;
    --card-bg: #ffffff;
    --border-color: #e5e7eb;
    --bg-color: #f9fafb;

    font-family: system-ui, -apple-system, sans-serif;
    color: var(--text-primary);
    background-color: var(--bg-color);
  }

  .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
  .hero { text-align: center; padding: 3rem 0 2rem; }
  .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
  .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

  .content-section { margin-bottom: 3rem; }
  .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
  .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
  .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

  .content-section ul { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; padding-left: 1.5rem; }
  .content-section li { margin-bottom: 0.5rem; }

  strong { color: var(--text-primary); }

  /* Winners Grid */
  .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
  .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
  .winner-card strong { font-size: 1.05rem; }
  .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

  /* Comparison Table */
  .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
  td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--card-bg); }

  /* FAQ */
  .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
  .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
  .faq-item p { margin-bottom: 0; }

  @media (max-width: 600px) {
    .hero h1 { font-size: 1.6rem; }
    .winners-grid { grid-template-columns: 1fr; }
  }
</style>