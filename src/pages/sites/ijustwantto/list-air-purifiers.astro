---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best Air Purifiers 2025: Top Picks by Room Size & Filter Type",
  "name": "Best Air Purifiers",
  "url": "https://ijustwantto.live/list-air-purifiers.html",
  "description": "A curated list of the best air purifiers. Compare key metrics like room size, filter type, noise level, and price to find the perfect fit for your home.",
  "author": {
    "@type": "Organization",
    "name": "ijustwantto.live"
  },
  "publisher": {
    "@type": "Organization",
    "name": "GAB Ventures"
  }
};
---

<SiteLayout
  site="ijustwantto"
  title="Best Air Purifiers 2025 | ijustwantto.live"
  description="Compare the best air purifiers by room size, filter type, noise level, and price. Find the right HEPA, activated carbon, and UV purifier for your home."
  canonical="https://ijustwantto.live/list-air-purifiers" schema={schema}
>
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
