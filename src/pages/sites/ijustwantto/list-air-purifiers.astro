            top: -10px;
            right: 1.5rem;
            background-color: var(--accent-color);
            color: #000;
            font-weight: 800;
            font-size: 0.875rem;
            padding: 0.25rem 0.75rem;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
