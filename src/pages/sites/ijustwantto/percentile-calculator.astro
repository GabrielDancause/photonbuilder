  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const datasetInput = document.getElementById('dataset');
      const targetValueInput = document.getElementById('target-value');
      const targetPercentileInput = document.getElementById('percentile-target');
      const calculateBtn = document.getElementById('calculate-btn');
      const clearBtn = document.getElementById('clear-btn');
      const errorMsg = document.getElementById('dataset-error');
      const resultsContainer = document.getElementById('results-container');
      const chartSection = document.getElementById('chart-section');

      // Calculate Percentile Function (Value to Percentile Rank)
      function getPercentileRank(data, value) {
        let countBelow = 0;
        let countEqual = 0;

        for (let i = 0; i < data.length; i++) {
          if (data[i] < value) {
            countBelow++;
          } else if (data[i] === value) {
            countEqual++;
          }
        }

        // Formula: (Count Below + (0.5 * Count Equal)) / Total Count * 100
        const rank = ((countBelow + (0.5 * countEqual)) / data.length) * 100;
        return rank;
      }

      // Calculate Value at Percentile (Percentile to Value)
      function getValueAtPercentile(data, p) {
        if (p <= 0) return data[0];
        if (p >= 100) return data[data.length - 1];

        const index = (p / 100) * (data.length - 1);
        const lower = Math.floor(index);
        const upper = lower + 1;
        const weight = index % 1;

        if (upper >= data.length) return data[lower];

        // Linear interpolation
        return data[lower] * (1 - weight) + data[upper] * weight;
      }

      // Format numbers
      function fmt(num, decimals = 2) {
        return Number(num).toLocaleString('en-US', {
          minimumFractionDigits: 0,
          maximumFractionDigits: decimals
        });
      }

      function handleCalculate() {
        // Parse input
        const rawText = datasetInput.value;
        const numbers = rawText
          .split(/[,\s\n]+/)
          .map(s => s.trim())
          .filter(s => s !== '')
          .map(Number)
          .filter(n => !isNaN(n));

        if (numbers.length < 2) {
          errorMsg.style.display = 'block';
          resultsContainer.style.display = 'none';
          chartSection.style.display = 'none';
          return;
        }

        errorMsg.style.display = 'none';

        // Sort data
        const sortedData = [...numbers].sort((a, b) => a - b);

        // Summary stats
        const n = sortedData.length;
        const min = sortedData[0];
        const max = sortedData[n - 1];
        const sum = sortedData.reduce((acc, val) => acc + val, 0);
        const mean = sum / n;

        // Calculate key percentiles
        const p25 = getValueAtPercentile(sortedData, 25);
        const p50 = getValueAtPercentile(sortedData, 50); // median
        const p75 = getValueAtPercentile(sortedData, 75);
        const p90 = getValueAtPercentile(sortedData, 90);
        const p99 = getValueAtPercentile(sortedData, 99);

        // Update DOM for summary
        document.getElementById('res-count').textContent = fmt(n, 0);
        document.getElementById('res-min').textContent = fmt(min);
        document.getElementById('res-max').textContent = fmt(max);
        document.getElementById('res-mean').textContent = fmt(mean);

        document.getElementById('res-p25').textContent = fmt(p25);
        document.getElementById('res-p50').textContent = fmt(p50);
        document.getElementById('res-p75').textContent = fmt(p75);
        document.getElementById('res-p90').textContent = fmt(p90);
        document.getElementById('res-p99').textContent = fmt(p99);

        // Handle Target Value
        const targetValueRaw = targetValueInput.value;
        const targetResultBox = document.getElementById('target-result-box');

        if (targetValueRaw !== '') {
          const tv = Number(targetValueRaw);
          const rank = getPercentileRank(sortedData, tv);

          document.getElementById('target-result-value').textContent = `${fmt(rank, 1)}th`;
          document.getElementById('target-result-desc').textContent = `The value ${tv} is greater than ${fmt(rank, 1)}% of the dataset.`;
          targetResultBox.style.display = 'block';
        } else {
          targetResultBox.style.display = 'none';
        }

        // Handle Target Percentile
        const pTargetRaw = targetPercentileInput.value;
        const pTargetResultBox = document.getElementById('p-target-result-box');

        if (pTargetRaw !== '') {
          const pt = Number(pTargetRaw);
          if (pt >= 0 && pt <= 100) {
            const valAtP = getValueAtPercentile(sortedData, pt);
            document.getElementById('p-target-result-value').textContent = fmt(valAtP);
            document.getElementById('p-target-result-desc').textContent = `The value at the ${pt}th percentile is ${fmt(valAtP)}.`;
            pTargetResultBox.style.display = 'block';
          } else {
             pTargetResultBox.style.display = 'none';
          }
        } else {
          pTargetResultBox.style.display = 'none';
        }

        // Show results
        resultsContainer.style.display = 'block';

        // Draw Chart
        drawChart(sortedData, min, max, p25, p50, p75, targetValueRaw !== '' ? Number(targetValueRaw) : null);
        chartSection.style.display = 'block';

        // Scroll to results on mobile
        if (window.innerWidth < 768) {
          resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      function drawChart(data, min, max, q1, median, q3, targetVal) {
        const track = document.getElementById('chart-track');
        const markers = document.getElementById('chart-markers');

        document.getElementById('chart-min-label').textContent = fmt(min);
        document.getElementById('chart-max-label').textContent = fmt(max);

        track.innerHTML = '';
        markers.innerHTML = '';

        const range = max - min;

        // Prevent division by zero if all values are identical
        if (range === 0) {
            track.innerHTML = '<div style="text-align:center; color: var(--text-secondary); line-height: 40px;">All values are identical.</div>';
            return;
        }

        // Add data points
        data.forEach(val => {
          const pct = ((val - min) / range) * 100;
          const point = document.createElement('div');
          point.className = 'chart-point';
          point.style.left = `${pct}%`;
          track.appendChild(point);
        });

        // Add Target Value Point
        if (targetVal !== null) {
           let clampedTarget = Math.max(min, Math.min(max, targetVal)); // Keep within visual bounds
           const pct = ((clampedTarget - min) / range) * 100;
           const targetPoint = document.createElement('div');
           targetPoint.className = 'chart-point target-point';
           targetPoint.style.left = `${pct}%`;
           targetPoint.title = `Target: ${targetVal}`;
           track.appendChild(targetPoint);
        }

        // Add Quartile Markers
        const addMarker = (val, label, isMedian = false) => {
          const pct = ((val - min) / range) * 100;
          const marker = document.createElement('div');
          marker.className = `chart-marker ${isMedian ? 'marker-median' : ''}`;
          marker.style.left = `${pct}%`;

          marker.innerHTML = `
            <div class="marker-line"></div>
            <div class="marker-label">${label}</div>
          `;
          markers.appendChild(marker);
        };

        addMarker(q1, 'Q1');
        addMarker(median, 'Median', true);
        addMarker(q3, 'Q3');
      }

      function handleClear() {
        datasetInput.value = '';
        targetValueInput.value = '';
        targetPercentileInput.value = '';
        resultsContainer.style.display = 'none';
        chartSection.style.display = 'none';
        errorMsg.style.display = 'none';
      }

      calculateBtn.addEventListener('click', handleCalculate);
      clearBtn.addEventListener('click', handleClear);

      // Allow enter key on inputs to trigger calculation
      targetValueInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleCalculate();
      });
      targetPercentileInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleCalculate();
      });
    });
  </script>


