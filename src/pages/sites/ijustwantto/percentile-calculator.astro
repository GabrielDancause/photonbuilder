            <div class="input-group">
              <label for="percentile-target">Target Percentile (Optional)</label>
              <input type="number" id="percentile-target" placeholder="Enter a percentile (0-100) to find its value" min="0" max="100" step="any">
              <div class="help-text">Leave blank if you just want to see quartiles and summary stats.</div>
            </div>

            <button id="calculate-btn" class="calc-button">Calculate Percentiles</button>
            <button id="clear-btn" class="clear-button">Clear</button>
          </div>

          <div class="calculator-card results-card" id="results-container" style="display: none;">
