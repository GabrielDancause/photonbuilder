  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Elements
      const baseTypeRadios = document.querySelectorAll('input[name="baseType"]');
      const baseLabel = document.getElementById('baseLabel');
      const baseInput = document.getElementById('baseInput');
      const baseUnit = document.getElementById('baseUnit');
      const baseError = document.getElementById('baseError');

      const heightInput = document.getElementById('heightInput');
      const heightUnit = document.getElementById('heightUnit');
      const heightError = document.getElementById('heightError');

      const resultUnit = document.getElementById('resultUnit');

      const resVolume = document.getElementById('resVolume');
      const unitVolume = document.getElementById('unitVolume');
      const resLateral = document.getElementById('resLateral');
      const unitLateral = document.getElementById('unitLateral');
      const resTotalArea = document.getElementById('resTotalArea');
      const unitTotalArea = document.getElementById('unitTotalArea');

      const diagram = document.getElementById('diagram');
      const labelR = document.getElementById('labelR');
      const labelH = document.getElementById('labelH');

      // Constants
      const PI = Math.PI;

      // Conversion factors to meters (base unit for calculations)
      const toMeters = {
        'in': 0.0254,
        'ft': 0.3048,
        'cm': 0.01,
        'm': 1
      };

      // Output conversions from cubic meters
      const fromCubicMeters = {
        'in3': 1 / Math.pow(0.0254, 3),
        'ft3': 1 / Math.pow(0.3048, 3),
        'cm3': 1000000,
        'm3': 1,
        'gal': 264.172, // US liquid gallons
        'l': 1000
      };

      // Output conversions from square meters
      const fromSquareMeters = {
        'in': 1 / Math.pow(0.0254, 2),
        'ft': 1 / Math.pow(0.3048, 2),
        'cm': 10000,
        'm': 1
      };

      const resultUnitLabels = {
        'in3': 'Cubic Inches (in³)',
        'ft3': 'Cubic Feet (ft³)',
        'cm3': 'Cubic Centimeters (cm³)',
        'm3': 'Cubic Meters (m³)',
        'gal': 'US Gallons (gal)',
        'l': 'Liters (L)'
      };

      const areaUnitLabels = {
        'in3': 'Square Inches (in²)', // mapped from requested volume unit preference roughly
        'ft3': 'Square Feet (ft²)',
        'cm3': 'Square Centimeters (cm²)',
        'm3': 'Square Meters (m²)',
        'gal': 'Square Feet (ft²)', // fallback
        'l': 'Square Meters (m²)' // fallback
      };

      // Determine what base unit mapped to area
      function getAreaUnitKey(volKey) {
          if (volKey === 'in3') return 'in';
          if (volKey === 'ft3' || volKey === 'gal') return 'ft';
          if (volKey === 'cm3') return 'cm';
          if (volKey === 'm3' || volKey === 'l') return 'm';
          return 'in';
      }

      function getAreaUnitLabel(volKey) {
          if (volKey === 'in3') return 'Square Inches (in²)';
          if (volKey === 'ft3' || volKey === 'gal') return 'Square Feet (ft²)';
          if (volKey === 'cm3') return 'Square Centimeters (cm²)';
          if (volKey === 'm3' || volKey === 'l') return 'Square Meters (m²)';
          return 'Square Inches (in²)';
      }

      function updateLabels() {
        const isDiameter = document.querySelector('input[name="baseType"]:checked').value === 'diameter';
        baseLabel.textContent = isDiameter ? 'Diameter (d)' : 'Radius (r)';
        calculate();
      }

      function formatNumber(num) {
        if (num === 0) return "0.00";
        if (num < 0.01) return num.toExponential(4);
        return num.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 4 });
      }

      function validateInput(input, errorElement) {
        const val = parseFloat(input.value);
        if (input.value !== '' && (isNaN(val) || val <= 0)) {
          errorElement.classList.add('visible');
          return null;
        }
        errorElement.classList.remove('visible');
        return isNaN(val) ? 0 : val;
      }

      function updateDiagram(r, h, isDiameter) {
        if (r > 0 && h > 0) {
          labelR.textContent = isDiameter ? `d = ${r}` : `r = ${r}`;
          labelH.textContent = `h = ${h}`;

          // Visual scaling logic
          // max height 160px, max width 150px
          let ratio = r / h; // actually diameter / height conceptually

          let diaCss = 150;
          let hCss = 160;

          if (ratio > 1) {
              // wider than tall
              hCss = Math.max(40, 150 / ratio);
          } else {
              // taller than wide
              diaCss = Math.max(40, 160 * ratio);
          }

          diagram.style.width = `${diaCss}px`;
          diagram.style.height = `${hCss + 40}px`;
          const body = diagram.querySelector('.cylinder-body');
          if(body) body.style.height = `${hCss}px`;
        } else {
          labelR.textContent = isDiameter ? `d = 0` : `r = 0`;
          labelH.textContent = `h = 0`;
          diagram.style.width = '150px';
          diagram.style.height = '200px';
          const body = diagram.querySelector('.cylinder-body');
          if(body) body.style.height = `160px`;
        }
      }

      function calculate() {
        const isDiameter = document.querySelector('input[name="baseType"]:checked').value === 'diameter';

        let baseVal = validateInput(baseInput, baseError);
        let heightVal = validateInput(heightInput, heightError);

        if (baseVal === null || heightVal === null) {
          resVolume.textContent = "Error";
          resLateral.textContent = "Error";
          resTotalArea.textContent = "Error";
          return;
        }

        if (baseVal === 0 || heightVal === 0) {
          resVolume.textContent = "0.00";
          resLateral.textContent = "0.00";
          resTotalArea.textContent = "0.00";
          updateDiagram(baseVal, heightVal, isDiameter);
          return;
        }

        updateDiagram(baseVal, heightVal, isDiameter);

        // Convert base to radius in meters
        let radiusMeters = baseVal * toMeters[baseUnit.value];
        if (isDiameter) {
          radiusMeters = radiusMeters / 2;
        }

        // Convert height to meters
        let heightMeters = heightVal * toMeters[heightUnit.value];

        // Core calculations in metric (meters)
        const volumeM3 = PI * Math.pow(radiusMeters, 2) * heightMeters;
        const lateralAreaM2 = 2 * PI * radiusMeters * heightMeters;
        const totalAreaM2 = lateralAreaM2 + (2 * PI * Math.pow(radiusMeters, 2));

        // Output conversions
        const outVolKey = resultUnit.value;
        const outAreaKey = getAreaUnitKey(outVolKey);

        const finalVolume = volumeM3 * fromCubicMeters[outVolKey];
        const finalLateral = lateralAreaM2 * fromSquareMeters[outAreaKey];
        const finalTotalArea = totalAreaM2 * fromSquareMeters[outAreaKey];

        // Update UI
        resVolume.textContent = formatNumber(finalVolume);
        unitVolume.textContent = resultUnitLabels[outVolKey];

        resLateral.textContent = formatNumber(finalLateral);
        unitLateral.textContent = getAreaUnitLabel(outVolKey);

        resTotalArea.textContent = formatNumber(finalTotalArea);
        unitTotalArea.textContent = getAreaUnitLabel(outVolKey);
      }

      // Event Listeners
      baseTypeRadios.forEach(radio => radio.addEventListener('change', updateLabels));
      baseInput.addEventListener('input', calculate);
      baseUnit.addEventListener('change', calculate);
      heightInput.addEventListener('input', calculate);
      heightUnit.addEventListener('change', calculate);
      resultUnit.addEventListener('change', calculate);

      // Initialize
      updateLabels();
    });
  </script>
