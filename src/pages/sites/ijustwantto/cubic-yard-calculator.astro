---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Cubic Yard Calculator",
  description: "Stop guessing how much material you need. Our interactive cubic yard calculator accurately determines volume for concrete, mulch, topsoil, and more.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Cubic Yard Calculator: Find Volume for Concrete and Mulch",
      "description": "Calculate cubic yards accurately for your landscaping and construction projects. Convert length, width, and depth into cubic yard volume.",
      "author": {
        "@type": "Organization",
        "name": "ijustwantto.live",
        "url": "https://ijustwantto.live"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do you calculate cubic yards?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To calculate cubic yards, multiply the length by the width by the depth in feet to get the volume in cubic feet. Then, divide the result by 27 because there are 27 cubic feet in one cubic yard."
          }
        },
        {
          "@type": "Question",
          "name": "How many bags of concrete make a cubic yard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "It depends on the bag size. You need about 45 bags of 80 lb concrete, 60 bags of 60 lb concrete, or 90 bags of 40 lb concrete to make exactly one cubic yard."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a cubic yard of topsoil cover?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "One cubic yard of topsoil will cover approximately 324 square feet at a depth of 1 inch, 162 square feet at a depth of 2 inches, or 108 square feet at a depth of 3 inches."
          }
        },
        {
          "@type": "Question",
          "name": "What is the formula for cubic yards?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The formula is: Cubic Yards = (Length in feet × Width in feet × Depth in feet) ÷ 27."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a cubic yard of mulch weigh?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A cubic yard of mulch typically weighs between 400 and 800 pounds, depending on the moisture content and the type of wood used."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout site="ijustwantto" title={meta.title} description={meta.description} canonical="https://ijustwantto.live/cubic-yard-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Cubic Yard Calculator</h1>
      <p class="subtitle">Calculate volume in cubic yards for concrete, dirt, mulch, and landscaping materials.</p>
    </div>
    <div class="calculator-container" id="cubicyard-calc-root">
      <div class="input-row">
        <div class="input-group">
          <label for="length-input">Length</label>
          <div class="flex-input">
            <input type="number" id="length-input" placeholder="0" min="0" step="any">
            <select id="length-unit">
              <option value="ft">Feet</option>
              <option value="in">Inches</option>
              <option value="yd">Yards</option>
              <option value="m">Meters</option>
            </select>
          </div>
        </div>

        <div class="input-group">
          <label for="width-input">Width</label>
          <div class="flex-input">
            <input type="number" id="width-input" placeholder="0" min="0" step="any">
            <select id="width-unit">
              <option value="ft">Feet</option>
              <option value="in">Inches</option>
              <option value="yd">Yards</option>
              <option value="m">Meters</option>
            </select>
          </div>
        </div>
      </div>

      <div class="input-group">
        <label for="depth-input">Depth / Thickness</label>
        <div class="flex-input">
          <input type="number" id="depth-input" placeholder="0" min="0" step="any">
          <select id="depth-unit">
            <option value="in">Inches</option>
            <option value="ft">Feet</option>
            <option value="yd">Yards</option>
            <option value="m">Meters</option>
          </select>
        </div>
      </div>

      <div class="result-card">
        <div class="result-label">Total Volume Required</div>
        <div class="result-value"><span id="result-yards">0.00</span> <span style="font-size: 1.5rem; color: var(--text-primary);">yd&sup3;</span></div>
        <div class="secondary-results" id="secondary-results" style="display: none;">
          <div><span id="result-feet">0.00</span> cubic feet (ft&sup3;)</div>
          <div><span id="result-meters">0.00</span> cubic meters (m&sup3;)</div>
        </div>
      </div>

      <div class="material-estimates" id="material-estimates" style="display: none;">
        <h3>Common Material Estimates</h3>
        <div class="estimate-grid">
          <div class="estimate-item">
            <div class="estimate-title">Concrete (80 lb bags)</div>
            <div class="estimate-val" id="est-concrete-80">0 bags</div>
          </div>
          <div class="estimate-item">
            <div class="estimate-title">Concrete (60 lb bags)</div>
            <div class="estimate-val" id="est-concrete-60">0 bags</div>
          </div>
          <div class="estimate-item">
            <div class="estimate-title">Mulch (2 cu ft bags)</div>
            <div class="estimate-val" id="est-mulch">0 bags</div>
          </div>
          <div class="estimate-item">
            <div class="estimate-title">Topsoil (40 lb bags)</div>
            <div class="estimate-val" id="est-topsoil">0 bags</div>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer" id="explainer-content">
      <h2>How to Calculate Cubic Yards</h2>
      <p>Whether you are pouring a concrete patio, filling raised garden beds with topsoil, or spreading mulch across your front yard, buying bulk materials requires knowing your project's volume in cubic yards. Ordering too little halts your project, and ordering too much wastes money. Our calculator processes length, width, and depth to instantly provide accurate volume requirements.</p>

      <h3>What is a Cubic Yard?</h3>
      <p>A cubic yard is a standard unit of volume measurement used primarily in the United States and Canada for construction and landscaping materials. Visualizing it is simple: imagine a cube where the length, width, and height are all exactly 1 yard (or 3 feet) long.</p>
      <p>Because volume is calculated by multiplying three dimensions together (3 ft &times; 3 ft &times; 3 ft), one cubic yard is exactly equal to 27 cubic feet.</p>

      <h3>The Cubic Yard Formula</h3>
      <p>If you prefer to calculate the volume manually, the standard mathematical formula involves converting all your measurements into feet before doing the final calculation. The formula is:</p>

      <div style="background: var(--card-bg); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border-color); text-align: center; font-family: var(--font-mono); font-size: 1.1rem; margin: 1.5rem 0;">
        Volume (yd&sup3;) = (Length in ft &times; Width in ft &times; Depth in ft) &divide; 27
      </div>

      <h4>Step-by-Step Manual Calculation</h4>
      <ol>
        <li><strong>Measure your area:</strong> Find the length and width of the space you want to cover.</li>
        <li><strong>Determine the depth:</strong> Decide how thick you need the material to be. For example, mulch is typically spread 2 to 3 inches thick, while a standard concrete sidewalk is 4 inches thick.</li>
        <li><strong>Convert all measurements to feet:</strong> This is the step where most mistakes happen. If your depth is in inches, you must divide by 12 to convert it to feet (e.g., 3 inches = 3 / 12 = 0.25 feet).</li>
        <li><strong>Multiply the dimensions:</strong> Multiply Length &times; Width &times; Depth to get the total volume in <em>cubic feet</em>.</li>
        <li><strong>Convert to cubic yards:</strong> Divide the total cubic feet by 27.</li>
      </ol>

      <h3>Common Material Coverage Estimates</h3>
      <p>When you go to the hardware store, you won't always buy materials by the cubic yard. Often, materials are sold in smaller, manageable bags. Here is how a single cubic yard translates to common retail packaging:</p>

      <h4>Concrete</h4>
      <p>Pouring concrete requires precision. One cubic yard of concrete weighs approximately 4,000 pounds. To yield one cubic yard, you will need:</p>
      <ul>
        <li>About <strong>45 bags</strong> of 80 lb concrete mix.</li>
        <li>About <strong>60 bags</strong> of 60 lb concrete mix.</li>
        <li>About <strong>90 bags</strong> of 40 lb concrete mix.</li>
      </ul>
      <p><em>Pro Tip:</em> Always add a 5% to 10% waste margin to your concrete order to account for uneven subgrades, spills, and form spreading. If you need to quickly find the prime factors of your required bag count to arrange them in perfectly even rows, check out our <a href="/factor-calculator">factor calculator</a>.</p>

      <h4>Mulch and Soil</h4>
      <p>Bagged mulch is typically sold by volume rather than weight, usually in 2 cubic foot bags. Since there are 27 cubic feet in a yard, you need <strong>13.5 bags</strong> (typically rounded up to 14) of 2 cu ft mulch to equal one cubic yard.</p>
      <p>Topsoil is often sold in 40 lb bags. Depending on the moisture content and specific blend, you will generally need between <strong>50 to 55 bags</strong> of 40 lb topsoil to equal one cubic yard.</p>

      <h3>Practical Application Example</h3>
      <p>Let's say you want to pour a new concrete patio that is 12 feet long, 10 feet wide, and 4 inches thick.</p>
      <ol>
        <li>First, convert the 4-inch depth to feet: 4 &divide; 12 = 0.333 feet.</li>
        <li>Multiply the dimensions: 12 ft &times; 10 ft &times; 0.333 ft = 40 cubic feet.</li>
        <li>Divide by 27: 40 &divide; 27 = <strong>1.48 cubic yards</strong>.</li>
      </ol>
      <p>You would order 1.5 cubic yards of concrete from a ready-mix company, or purchase about sixty-seven 80 lb bags if mixing it yourself.</p>
    </div>

    <section class="faq-section" id="faq-content">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How do you calculate cubic yards?</summary>
        <p>To calculate cubic yards, multiply the length by the width by the depth in feet to get the volume in cubic feet. Then, divide the result by 27 because there are 27 cubic feet in one cubic yard.</p>
      </details>
      <details>
        <summary>How many bags of concrete make a cubic yard?</summary>
        <p>It depends on the bag size. You need about 45 bags of 80 lb concrete, 60 bags of 60 lb concrete, or 90 bags of 40 lb concrete to make exactly one cubic yard.</p>
      </details>
      <details>
        <summary>How much does a cubic yard of topsoil cover?</summary>
        <p>One cubic yard of topsoil will cover approximately 324 square feet at a depth of 1 inch, 162 square feet at a depth of 2 inches, or 108 square feet at a depth of 3 inches.</p>
      </details>
      <details>
        <summary>What is the formula for cubic yards?</summary>
        <p>The standard formula is: Cubic Yards = (Length in feet &times; Width in feet &times; Depth in feet) &divide; 27.</p>
      </details>
      <details>
        <summary>How much does a cubic yard of mulch weigh?</summary>
        <p>A cubic yard of mulch typically weighs between 400 and 800 pounds, depending heavily on the moisture content, the type of wood used, and how finely it is shredded.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = [
        document.getElementById('length-input'),
        document.getElementById('width-input'),
        document.getElementById('depth-input')
      ];
      const units = [
        document.getElementById('length-unit'),
        document.getElementById('width-unit'),
        document.getElementById('depth-unit')
      ];

      const resultYards = document.getElementById('result-yards');
      const resultFeet = document.getElementById('result-feet');
      const resultMeters = document.getElementById('result-meters');
      const secondaryResults = document.getElementById('secondary-results');
      const materialEstimates = document.getElementById('material-estimates');

      const estConcrete80 = document.getElementById('est-concrete-80');
      const estConcrete60 = document.getElementById('est-concrete-60');
      const estMulch = document.getElementById('est-mulch');
      const estTopsoil = document.getElementById('est-topsoil');

      function convertToFeet(value, unit) {
        if (isNaN(value) || value < 0) return 0;
        switch (unit) {
          case 'in': return value / 12;
          case 'yd': return value * 3;
          case 'm': return value * 3.28084;
          case 'ft':
          default: return value;
        }
      }

      function calculate() {
        const l = parseFloat(inputs[0].value);
        const w = parseFloat(inputs[1].value);
        const d = parseFloat(inputs[2].value);

        // Don't calculate if any essential input is missing or invalid
        if (isNaN(l) || isNaN(w) || isNaN(d) || l < 0 || w < 0 || d < 0) {
          resultYards.textContent = "0.00";
          secondaryResults.style.display = 'none';
          materialEstimates.style.display = 'none';
          return;
        }

        const lFt = convertToFeet(l, units[0].value);
        const wFt = convertToFeet(w, units[1].value);
        const dFt = convertToFeet(d, units[2].value);

        const cubicFeet = lFt * wFt * dFt;
        const cubicYards = cubicFeet / 27;
        const cubicMeters = cubicFeet * 0.0283168;

        if (cubicYards > 0) {
          resultYards.textContent = cubicYards.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
          resultFeet.textContent = cubicFeet.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
          resultMeters.textContent = cubicMeters.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

          secondaryResults.style.display = 'flex';

          // Estimates
          // Concrete: 1 cubic yard = 4000 lbs approx
          const lbsConcrete = cubicYards * 4000;
          estConcrete80.textContent = Math.ceil(lbsConcrete / 80).toLocaleString() + ' bags';
          estConcrete60.textContent = Math.ceil(lbsConcrete / 60).toLocaleString() + ' bags';

          // Mulch: 1 cu yd = 27 cu ft / 2 cu ft bag = 13.5 bags
          estMulch.textContent = Math.ceil(cubicYards * 13.5).toLocaleString() + ' bags';

          // Topsoil: ~50 bags of 40lb per yard
          estTopsoil.textContent = Math.ceil(cubicYards * 50).toLocaleString() + ' bags';

          materialEstimates.style.display = 'block';
        } else {
          resultYards.textContent = "0.00";
          secondaryResults.style.display = 'none';
          materialEstimates.style.display = 'none';
        }
      }

      inputs.forEach(input => input.addEventListener('input', calculate));
      units.forEach(select => select.addEventListener('change', calculate));
    });
  </script>

  <style is:inline>
    .input-row { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    @media (min-width: 600px) { .input-row { grid-template-columns: 1fr 1fr; } }
    .input-group { margin-bottom: 1.5rem; }
    .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
    .flex-input { display: flex; gap: 0.5rem; }
    .flex-input input { flex: 2; }
    .flex-input select { flex: 1; min-width: 90px; }

    .secondary-results { font-size: 0.95rem; color: var(--text-secondary); margin-top: 1rem; display: flex; flex-direction: column; gap: 0.25rem; }

    .material-estimates { margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem; }
    .material-estimates h3 { text-align: center; margin-bottom: 1.5rem; font-size: 1.2rem; }
    .estimate-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    @media (min-width: 600px) { .estimate-grid { grid-template-columns: repeat(4, 1fr); } }
    .estimate-item { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem; text-align: center; }
    .estimate-title { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.5rem; }
    .estimate-val { font-weight: 700; color: var(--accent-color); font-size: 1.1rem; }

    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }

    .explainer { margin: 3rem 0; line-height: 1.7; }
    .explainer h2 { margin-top: 2rem; margin-bottom: 1rem; color: var(--accent-color); }
    .explainer h3 { margin-top: 1.5rem; margin-bottom: 0.5rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer ul, .explainer ol { margin-bottom: 1rem; padding-left: 2rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
  </style>
</SiteLayout>