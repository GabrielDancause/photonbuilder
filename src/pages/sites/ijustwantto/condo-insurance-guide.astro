    .faq-section { margin-top: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem 1.5rem; margin-bottom: 1rem; }
    .faq-item h4 { margin-top: 0; margin-bottom: 0.5rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; font-size: 0.95rem; color: var(--text-secondary); }
  </style>
</SiteLayout>
