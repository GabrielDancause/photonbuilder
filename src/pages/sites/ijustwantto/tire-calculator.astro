---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tire Size Calculator - Compare Dimensions & Speedometer Variance",
  description: "Upgrading your wheels? Find out exactly how your new tire dimensions compare to your stock setup and discover the hidden impact on your speedometer.",
  category: "tool",
  published: "2024-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What do the numbers on my tire mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The numbers on a tire (like 225/45R17) represent three key dimensions. The first number (225) is the tire width in millimeters. The second number (45) is the aspect ratio, meaning the sidewall height is 45% of the width. The final number (17) is the wheel/rim diameter in inches."
        }
      },
      {
        "@type": "Question",
        "name": "How does tire size affect my speedometer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Your car's computer measures speed based on wheel rotations. If you install larger diameter tires, they cover more ground per rotation than the stock tires. As a result, your speedometer will read slower than your actual speed. Conversely, smaller tires make the speedometer read faster than your actual speed."
        }
      },
      {
        "@type": "Question",
        "name": "How do I calculate overall tire diameter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To calculate overall tire diameter in inches: first, find the sidewall height in millimeters by multiplying the width by the aspect ratio percentage. Convert that height to inches by dividing by 25.4. Finally, multiply the sidewall height in inches by 2 (for top and bottom) and add the wheel diameter."
        }
      },
      {
        "@type": "Question",
        "name": "What is the maximum tire size change recommended?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Automotive experts generally recommend keeping your new tire diameter within 3% of the original factory tire diameter. Exceeding this 3% rule can severely impact your vehicle's anti-lock braking system (ABS), traction control, speedometer accuracy, and transmission shifting points."
        }
      },
      {
        "@type": "Question",
        "name": "Will wider tires fit on my current rims?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wider tires can sometimes fit on stock rims, but every rim width has an approved range of tire widths. If you mount a tire that is too wide for the rim, the sidewalls will bulge excessively, leading to poor handling and dangerous bead seat failures. Always consult the tire manufacturer's rim width specifications."
        }
      }
    ]
  }
];
