          <label class="check-item"><input type="checkbox" class="budget-item" data-min="600" data-max="1500"> <span>Heated Floors (Radiant)</span> <span class="cost-range">$600 - $1,500</span></label>
        </div>

        <div class="checklist-group">
          <h3>Major Modifications</h3>
          <label class="check-item"><input type="checkbox" class="budget-item" data-min="1000" data-max="3000"> <span>Relocate Plumbing Lines (Per fixture)</span> <span class="cost-range">$1,000 - $3,000</span></label>
          <label class="check-item"><input type="checkbox" class="budget-item" data-min="500" data-max="1500"> <span>Demolition & Disposal</span> <span class="cost-range">$500 - $1,500</span></label>
          <label class="check-item"><input type="checkbox" class="budget-item" data-min="300" data-max="800"> <span>Permits & Inspections</span> <span class="cost-range">$300 - $800</span></label>
