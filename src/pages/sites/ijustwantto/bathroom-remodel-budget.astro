          <label class="check-item"><input type="checkbox" class="budget-item" data-min="1500" data-max="3000"> <span>Floor Tile (Natural Stone)</span> <span class="cost-range">$1,500 - $3,000</span></label>
        </div>

        <div class="checklist-group">
          <h3>Vanity, Storage & Electrical</h3>
          <label class="check-item"><input type="checkbox" class="budget-item" data-min="400" data-max="1200"> <span>Stock Vanity (Single Sink)</span> <span class="cost-range">$400 - $1,200</span></label>
          <label class="check-item"><input type="checkbox" class="budget-item" data-min="1200" data-max="3500"> <span>Custom Double Vanity</span> <span class="cost-range">$1,200 - $3,500</span></label>
          <label class="check-item"><input type="checkbox" class="budget-item" data-min="300" data-max="800"> <span>Countertop (Quartz/Granite)</span> <span class="cost-range">$300 - $800</span></label>
          <label class="check-item"><input type="checkbox" class="budget-item" data-min="200" data-max="600"> <span>Vanity Lighting & Mirror</span> <span class="cost-range">$200 - $600</span></label>
