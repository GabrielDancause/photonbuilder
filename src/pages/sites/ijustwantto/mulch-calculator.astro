---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Mulch Calculator",
      "url": "https://ijustwantto.live/mulch-calculator",
      "description": "Calculate exactly how much mulch you need for your landscaping project. Estimate cubic yards, add multiple beds, apply a waste factor, and calculate total cost.",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "All",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much mulch do I need?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To calculate the amount of mulch needed, measure the length and width of your bed in feet, multiply them to get the square footage, and then multiply by the desired depth in inches divided by 12 to get cubic feet. Divide the cubic feet by 27 to get cubic yards."
          }
        },
        {
          "@type": "Question",
          "name": "How deep should I apply mulch?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A depth of 2 to 3 inches is generally recommended for new beds to retain moisture and suppress weeds. For refreshing an existing layer, 1 to 2 inches is usually sufficient."
          }
        },
        {
          "@type": "Question",
          "name": "What is a waste factor?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A waste factor accounts for irregularities in the bed shape, settling, and spillage during application. A 5-10% waste factor is typical for mulch projects to ensure you don't run short."
          }
        },
        {
          "@type": "Question",
          "name": "How many cubic feet are in a cubic yard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There are 27 cubic feet in one cubic yard (3 feet x 3 feet x 3 feet)."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="ijustwantto"
  title="Mulch Calculator - Estimate Cubic Yards & Cost"
  description="Calculate exactly how much mulch you need for your landscaping project. Estimate cubic yards, add multiple beds, apply a waste factor, and calculate total cost."
  canonical="https://ijustwantto.live/mulch-calculator"
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-5 py-12">
    <h1 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Mulch Calculator</h1>
    <p class="text-[var(--text-secondary)] mb-10 text-lg">Calculate cubic yards and estimate the cost of mulch for your landscaping beds.</p>

    <!-- Project Settings -->
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-8 shadow-sm">
      <h2 class="text-xl font-bold text-white mb-4">1. Project Settings</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="mulch-type">Mulch Type & Price</label>
          <select id="mulch-type" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none mb-3">
            <option value="custom">Custom Price</option>
            <option value="30" selected>Hardwood ($30/yd³)</option>
            <option value="45">Cedar ($45/yd³)</option>
            <option value="90">Rubber ($90/yd³)</option>
            <option value="25">Pine Bark ($25/yd³)</option>
            <option value="35">Dyed ($35/yd³)</option>
          </select>
          <div class="relative">
            <span class="absolute left-3 top-3 text-[var(--text-secondary)] font-mono">$</span>
            <input type="number" id="custom-price" value="30" min="0" step="0.01" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 pl-8 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
          </div>
          <p class="text-xs text-[var(--text-secondary)] mt-2">Price per cubic yard</p>
        </div>

        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="waste-factor">
            Waste Factor: <span id="waste-val" class="text-[var(--accent-color)]">10%</span>
          </label>
          <input type="range" id="waste-factor" min="5" max="15" step="1" value="10" class="w-full mt-2 mb-2 accent-[var(--accent-color)]">
          <p class="text-xs text-[var(--text-secondary)]">Accounts for irregular shapes and settling (5-15% recommended).</p>
        </div>
      </div>
    </div>

    <!-- Add Bed Card -->
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-8 shadow-sm">
      <h2 class="text-xl font-bold text-white mb-4">2. Add Bed Dimensions</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
        <div class="col-span-2 md:col-span-1">
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="bed-name">Bed Name</label>
          <input type="text" id="bed-name" placeholder="Front Yard" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="bed-length">Length (ft)</label>
          <input type="number" id="bed-length" min="0.1" step="0.1" placeholder="0" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="bed-width">Width (ft)</label>
          <input type="number" id="bed-width" min="0.1" step="0.1" placeholder="0" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-semibold text-[var(--text-secondary)] mb-2" for="bed-depth">Depth (inches)</label>
          <input type="number" id="bed-depth" min="0.5" step="0.5" value="3" class="w-full bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg p-3 text-white font-mono focus:border-[var(--accent-color)] focus:outline-none">
        </div>
      </div>

      <div class="mb-6 flex flex-wrap gap-2">
        <span class="text-sm text-[var(--text-secondary)] py-1">Depth Presets:</span>
        <button id="preset-2in" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] text-xs py-1 px-3 rounded transition-colors">2" (Refresh)</button>
        <button id="preset-3in" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] text-xs py-1 px-3 rounded transition-colors">3" (New Beds)</button>
        <button id="preset-4in" class="bg-[var(--bg-color)] border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-color)] text-xs py-1 px-3 rounded transition-colors">4" (Weed Suppression)</button>
      </div>

      <button id="add-btn" class="w-full bg-[var(--accent-color)] hover:bg-opacity-90 text-[var(--bg-color)] font-bold py-3 px-4 rounded-lg transition-colors">
        + Add Bed
      </button>
    </div>

    <!-- Results -->
    <div id="results-section" class="hidden">
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm text-center">
        <h2 class="text-xl font-bold text-white mb-2">Total Mulch Needed</h2>
        <div class="text-4xl font-bold text-[var(--accent-color)] mb-2 font-mono" id="total-yards">0.0 yd³</div>
        <div class="text-lg text-[var(--text-secondary)] font-mono mb-4" id="total-cost">$0.00</div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6 text-sm border-t border-[var(--border-color)] pt-6">
          <div>
            <div class="text-[var(--text-secondary)] mb-1">Total Area</div>
            <div class="font-bold text-white font-mono" id="total-sqft">0 sq ft</div>
          </div>
          <div>
            <div class="text-[var(--text-secondary)] mb-1">Raw Volume</div>
            <div class="font-bold text-white font-mono" id="raw-yards">0.0 yd³</div>
          </div>
          <div>
            <div class="text-[var(--text-secondary)] mb-1">Waste (<span id="waste-display-pct">0</span>%)</div>
            <div class="font-bold text-white font-mono" id="waste-yards">0.0 yd³</div>
          </div>
          <div>
            <div class="text-[var(--text-secondary)] mb-1">Bags (2 cu ft)</div>
            <div class="font-bold text-white font-mono" id="total-bags">0</div>
          </div>
        </div>
      </div>

      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Your Beds</h2>

      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl overflow-hidden mb-8 shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-[var(--bg-color)] border-b border-[var(--border-color)]">
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Bed</th>
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Dimensions</th>
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm">Volume</th>
                <th class="p-4 text-[var(--text-secondary)] font-semibold text-sm text-right">Action</th>
              </tr>
            </thead>
            <tbody id="beds-list">
              <!-- JS Injected -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Chart -->
      <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 mb-12 shadow-sm">
        <h3 class="text-xl font-bold text-[var(--accent-color)] mb-6 text-center">Mulch Volume per Bed (yd³)</h3>
        <div class="h-[300px]">
          <canvas id="chart"></canvas>
        </div>
      </div>
    </div>

    <!-- Methodology & FAQ -->
    <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 mb-8 shadow-sm">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-4">Methodology</h2>
      <p class="text-[var(--text-secondary)] mb-4">
        This calculator estimates cubic yards of mulch using standard landscaping volume formulas:
      </p>
      <div class="bg-[var(--bg-color)] p-4 rounded-lg border border-[var(--border-color)] mb-4 font-mono text-sm text-[var(--accent-color)] text-center overflow-x-auto">
        Square Footage = Length (ft) &times; Width (ft)
      </div>
      <div class="bg-[var(--bg-color)] p-4 rounded-lg border border-[var(--border-color)] mb-4 font-mono text-sm text-[var(--accent-color)] text-center overflow-x-auto">
        Cubic Yards = (Square Footage &times; (Depth in inches / 12)) / 27
      </div>
      <p class="text-[var(--text-secondary)]">
        The raw cubic yards are then multiplied by your selected waste factor (1 + waste%) to determine the total required yards. Bag estimates assume standard 2 cubic foot bags (13.5 bags per cubic yard).
      </p>
    </div>

    <div class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--accent-color)] mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">How much mulch do I need?</h3>
          <p class="text-[var(--text-secondary)]">To calculate the amount of mulch needed, measure the length and width of your bed in feet, multiply them to get the square footage, and then multiply by the desired depth in inches divided by 12 to get cubic feet. Divide the cubic feet by 27 to get cubic yards.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">How deep should I apply mulch?</h3>
          <p class="text-[var(--text-secondary)]">A depth of 2 to 3 inches is generally recommended for new beds to retain moisture and suppress weeds. For refreshing an existing layer, 1 to 2 inches is usually sufficient.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">What is a waste factor?</h3>
          <p class="text-[var(--text-secondary)]">A waste factor accounts for irregularities in the bed shape, settling, and spillage during application. A 5-10% waste factor is typical for mulch projects to ensure you don't run short.</p>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5">
          <h3 class="text-lg font-bold text-white mb-2">How many cubic feet are in a cubic yard?</h3>
          <p class="text-[var(--text-secondary)]">There are 27 cubic feet in one cubic yard (3 feet x 3 feet x 3 feet).</p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    const formatMoney = (amount) => {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
    };

    let beds = [];
    let currentPrice = 30;
    let wastePct = 10;
    let chartInstance = null;

    // Elements
    const mulchType = document.getElementById('mulch-type');
    const customPrice = document.getElementById('custom-price');
    const wasteFactor = document.getElementById('waste-factor');
    const wasteVal = document.getElementById('waste-val');

    const bedName = document.getElementById('bed-name');
    const bedLength = document.getElementById('bed-length');
    const bedWidth = document.getElementById('bed-width');
    const bedDepth = document.getElementById('bed-depth');
    const addBtn = document.getElementById('add-btn');

    const preset2in = document.getElementById('preset-2in');
    const preset3in = document.getElementById('preset-3in');
    const preset4in = document.getElementById('preset-4in');

    const resultsSection = document.getElementById('results-section');
    const bedsList = document.getElementById('beds-list');

    const totalYardsEl = document.getElementById('total-yards');
    const totalCostEl = document.getElementById('total-cost');
    const totalSqftEl = document.getElementById('total-sqft');
    const rawYardsEl = document.getElementById('raw-yards');
    const wasteYardsEl = document.getElementById('waste-yards');
    const wasteDisplayPct = document.getElementById('waste-display-pct');
    const totalBagsEl = document.getElementById('total-bags');

    // Settings Handlers
    if (mulchType) {
      mulchType.addEventListener('change', (e) => {
        if (e.target.value !== 'custom') {
          customPrice.value = e.target.value;
          currentPrice = parseFloat(e.target.value);
          updateUI();
        }
      });
    }

    if (customPrice) {
      customPrice.addEventListener('input', (e) => {
        mulchType.value = 'custom';
        currentPrice = parseFloat(e.target.value) || 0;
        updateUI();
      });
    }

    if (wasteFactor) {
      wasteFactor.addEventListener('input', (e) => {
        wastePct = parseInt(e.target.value) || 0;
        if (wasteVal) wasteVal.innerText = wastePct + '%';
        updateUI();
      });
    }

    // Presets
    const setDepth = (depth) => {
      if (bedDepth) bedDepth.value = depth;
    };
    if (preset2in) preset2in.addEventListener('click', () => setDepth(2));
    if (preset3in) preset3in.addEventListener('click', () => setDepth(3));
    if (preset4in) preset4in.addEventListener('click', () => setDepth(4));

    // Add Bed
    if (addBtn) {
      addBtn.addEventListener('click', () => {
        const name = bedName.value.trim() || `Bed ${beds.length + 1}`;
        const length = parseFloat(bedLength.value);
        const width = parseFloat(bedWidth.value);
        const depth = parseFloat(bedDepth.value);

        if (isNaN(length) || isNaN(width) || isNaN(depth) || length <= 0 || width <= 0 || depth <= 0) {
          alert('Please enter valid positive numbers for length, width, and depth.');
          return;
        }

        const sqft = length * width;
        // Cubic yards = sqft * (depth / 12) / 27
        const cubicYards = (sqft * (depth / 12)) / 27;

        beds.push({ id: Date.now(), name, length, width, depth, sqft, cubicYards });

        // Reset inputs
        bedName.value = '';
        bedLength.value = '';
        bedWidth.value = '';
        // Keep depth as it's often reused

        updateUI();
      });
    }

    // Remove Bed
    window.removeBed = (id) => {
      beds = beds.filter(bed => bed.id !== id);
      updateUI();
    };

    function updateUI() {
      if (beds.length === 0) {
        if (resultsSection) resultsSection.classList.add('hidden');
        return;
      }

      if (resultsSection) resultsSection.classList.remove('hidden');

      let totalSqft = 0;
      let rawYards = 0;
      let html = '';

      const chartLabels = [];
      const chartData = [];

      beds.forEach(bed => {
        totalSqft += bed.sqft;
        rawYards += bed.cubicYards;

        chartLabels.push(bed.name);
        chartData.push(bed.cubicYards.toFixed(2));

        html += `
          <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-color)] transition-colors">
            <td class="p-4">
              <div class="font-bold text-white">${bed.name}</div>
              <div class="text-xs text-[var(--text-secondary)]">${bed.sqft.toFixed(1)} sq ft</div>
            </td>
            <td class="p-4">
              <div class="text-white font-mono">${bed.length}ft &times; ${bed.width}ft</div>
              <div class="text-xs text-[var(--text-secondary)]">@ ${bed.depth}" depth</div>
            </td>
            <td class="p-4 text-white font-mono">${bed.cubicYards.toFixed(2)} yd³</td>
            <td class="p-4 text-right">
              <button onclick="removeBed(${bed.id})" class="text-red-400 hover:text-red-300 text-sm font-semibold transition-colors">Remove</button>
            </td>
          </tr>
        `;
      });

      if (bedsList) bedsList.innerHTML = html;

      const wasteMultiplier = 1 + (wastePct / 100);
      const totalYards = rawYards * wasteMultiplier;
      const wasteYards = totalYards - rawYards;
      const totalCost = totalYards * currentPrice;
      const totalBags = Math.ceil(totalYards * 13.5); // 27 cu ft per yd / 2 cu ft per bag = 13.5 bags/yd

      if (totalYardsEl) totalYardsEl.innerText = totalYards.toFixed(2) + ' yd³';
      if (totalCostEl) totalCostEl.innerText = formatMoney(totalCost);
      if (totalSqftEl) totalSqftEl.innerText = totalSqft.toFixed(1) + ' sq ft';
      if (rawYardsEl) rawYardsEl.innerText = rawYards.toFixed(2) + ' yd³';
      if (wasteYardsEl) wasteYardsEl.innerText = wasteYards.toFixed(2) + ' yd³';
      if (wasteDisplayPct) wasteDisplayPct.innerText = wastePct;
      if (totalBagsEl) totalBagsEl.innerText = totalBags;

      updateChart(chartLabels, chartData);
    }

    function updateChart(labels, data) {
      const canvas = document.getElementById('chart');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');

      if (chartInstance) {
        chartInstance.destroy();
      }

      // Generate colors for chart
      const bgColors = data.map((_, i) => {
        const hue = (i * 137.5) % 360; // Golden angle for distribution
        return `hsla(${hue}, 70%, 60%, 0.7)`;
      });
      const borderColors = data.map((_, i) => {
        const hue = (i * 137.5) % 360;
        return `hsl(${hue}, 70%, 60%)`;
      });

      if (typeof Chart === 'undefined') return;

      Chart.defaults.color = '#94a3b8'; // text-secondary
      Chart.defaults.font.family = "'Inter', sans-serif";

      chartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Cubic Yards (Raw)',
            data: data,
            backgroundColor: bgColors,
            borderColor: borderColors,
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  let label = context.dataset.label || '';
                  if (label) {
                    label += ': ';
                  }
                  if (context.parsed.y !== null) {
                    label += context.parsed.y + ' yd³';
                  }
                  return label;
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: {
                color: 'rgba(255, 255, 255, 0.05)',
                drawBorder: false
              },
              ticks: {
                callback: function(value) {
                  return value + ' yd³';
                }
              }
            },
            x: {
              grid: {
                display: false,
                drawBorder: false
              }
            }
          }
        }
      });
    }
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">📚 Complete Guide</p>
      <a href="/guide-materials-complete" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <h3 class="text-base font-bold text-white">Construction Materials Calculator Guide</h3>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Read the full guide →</p>
      </a>
    </div>
  </div>
</SiteLayout>
