  <script is:inline>

        // Accordion Functionality
        document.querySelectorAll('.accordion-header').forEach(button => {
            button.addEventListener('click', () => {
                const accordion = button.parentElement;
                const content = accordion.querySelector('.accordion-content');

                // Toggle active class
                accordion.classList.toggle('active');

                // Animate height
                if (accordion.classList.contains('active')) {
                    content.style.maxHeight = content.scrollHeight + "px";
                } else {
                    content.style.maxHeight = "0";
                }
            });
        });

        // Search/Filter Functionality
        const searchInput = document.getElementById('searchInput');
        const contentSections = document.querySelectorAll('.content-section');
        const searchableItems = document.querySelectorAll('.searchable-item');
        const noResultsMessage = document.getElementById('noResults');

        searchInput.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase().trim();
            let totalVisibleItems = 0;

            if (searchTerm === '') {
                // Reset everything if search is empty
                searchableItems.forEach(item => item.classList.remove('hidden'));
                contentSections.forEach(section => section.classList.remove('hidden'));
                noResultsMessage.style.display = 'none';

                // Close accordions on reset
                document.querySelectorAll('.accordion.active').forEach(acc => {
                    acc.classList.remove('active');
                    acc.querySelector('.accordion-content').style.maxHeight = '0';
                });
                return;
            }

            // Filter items within sections
            contentSections.forEach(section => {
                let sectionHasVisibleItems = false;
                const sectionItems = section.querySelectorAll('.searchable-item');

                // Check if the section tags themselves match the search
                const sectionTags = section.getAttribute('data-tags') || '';
                const sectionMatches = sectionTags.toLowerCase().includes(searchTerm) ||
                                     section.querySelector('h2').textContent.toLowerCase().includes(searchTerm);

                sectionItems.forEach(item => {
                    const searchableText = (item.getAttribute('data-search') || '') + ' ' +
                                         (item.textContent || '').toLowerCase();

                    if (sectionMatches || searchableText.toLowerCase().includes(searchTerm)) {
                        item.classList.remove('hidden');
                        sectionHasVisibleItems = true;
                        totalVisibleItems++;

                        // If it's an accordion, open it automatically when it matches a search
                        if (item.classList.contains('accordion') && !item.classList.contains('active')) {
                            item.classList.add('active');
                            const content = item.querySelector('.accordion-content');
                            // Use a slight timeout to ensure display:block has taken effect before animating height
                            setTimeout(() => {
                                content.style.maxHeight = content.scrollHeight + "px";
                            }, 10);
                        }
                    } else {
                        item.classList.add('hidden');

                        // Close hidden accordions
                        if (item.classList.contains('accordion') && item.classList.contains('active')) {
                            item.classList.remove('active');
                            item.querySelector('.accordion-content').style.maxHeight = '0';
                        }
                    }
                });

                // Hide the whole section if it has no matching items
                if (sectionHasVisibleItems || sectionMatches) {
                    section.classList.remove('hidden');
                    // If section matches but items don't, show all items in that section
                    if (sectionMatches && !sectionHasVisibleItems) {
                        sectionItems.forEach(item => {
                            item.classList.remove('hidden');
                            totalVisibleItems++;
                        });
                    }
                } else {
                    section.classList.add('hidden');
                }
            });

            // Show 'No Results' message if necessary
            if (totalVisibleItems === 0) {
                noResultsMessage.style.display = 'block';
            } else {
                noResultsMessage.style.display = 'none';
            }
        });

        // Copy Routine Functionality
        function copyRoutine(routineId) {
            const routineBlock = document.getElementById(routineId);
            const title = routineBlock.querySelector('h4').textContent;
            const items = routineBlock.querySelectorAll('.routine-list li');

            let textToCopy = `${title}\n${'-'.repeat(title.length)}\n`;

            items.forEach(item => {
                const exercise = item.querySelector('span:first-child').textContent;
                const setsReps = item.querySelector('span:last-child').textContent;
                textToCopy += `• ${exercise} - ${setsReps}\n`;
            });

            navigator.clipboard.writeText(textToCopy).then(() => {
                const btn = routineBlock.querySelector('.copy-btn');
                const originalHTML = btn.innerHTML;

                // Change icon to checkmark
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#2DB89A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                btn.style.borderColor = 'var(--accent-color)';
                btn.style.color = 'var(--accent-color)';

                setTimeout(() => {
                    btn.innerHTML = originalHTML;
                    btn.style.borderColor = '';
                    btn.style.color = '';
                }, 2000);
            }).catch(err => {
                console.error('Failed to copy: ', err);
                alert('Failed to copy to clipboard.');
            });
        }

  </script>
