---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Couch to 5K: Complete Plan",
    "name": "Couch to 5K Plan",
    "url": "https://ijustwantto.live/guide-running-plan",
    "description": "A comprehensive 8-week running plan for absolute beginners. Includes training schedule, tips, and injury prevention.",
    "author": {
      "@type": "Organization",
      "name": "ijustwantto.live"
    },
    "publisher": {
      "@type": "Organization",
      "name": "GAB Ventures"
    }
  }
];
---

<SiteLayout
  site="ijustwantto"
  title="Couch to 5K: Complete Plan | ijustwantto.live"
  description="8-week running plan for absolute beginners. Training schedule, tips, and injury prevention to get you from the couch to running 5K."
  canonical="https://ijustwantto.live/guide-running-plan"
  schema={schemas}
>

  <style>









        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        h1 {
            font-size: 2.25rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
            letter-spacing: -0.025em;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1.125rem;
            max-width: 600px;
            margin: 0 auto;
        }

        .search-container {
            margin-bottom: 2rem;
            position: relative;
        }

        .search-input {
            width: 100%;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 1rem 1rem 1rem 3rem;
            border-radius: 8px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 3px rgba(45, 184, 154, 0.1);
        }

        .search-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            pointer-events: none;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-top: 3rem;
            margin-bottom: 1.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--border-color);
        }

        .section-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffffff;
            margin: 0;
        }

        .section-icon {
            color: var(--accent-color);
            display: flex;
            align-items: center;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            transition: transform 0.2s, border-color 0.2s;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .card:hover {
            border-color: var(--accent-color);
            transform: translateY(-2px);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }

        .card h3 {
            font-size: 1.125rem;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 0.25rem;
        }

        .card-desc {
            color: var(--text-secondary);
            font-size: 0.875rem;
            margin-bottom: 1rem;
            flex-grow: 1;
        }

        .card-meta {
            font-family: var(--font-mono);
            font-size: 0.75rem;
            color: var(--text-secondary);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
            border-top: 1px solid var(--border-color);
        }

        .tag {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
        }

        .table-wrapper {
            overflow-x: auto;
            margin-bottom: 2rem;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th, td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            font-weight: 600;
            color: #ffffff;
            background-color: rgba(0, 0, 0, 0.2);
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .td-mono {
            font-family: var(--font-mono);
            color: var(--accent-color);
        }

        .td-highlight {
            color: #ffffff;
            font-weight: 500;
        }

        .accordion {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            margin-bottom: 1rem;
            overflow: hidden;
        }

        .accordion-header {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.25rem 1.5rem;
            background: none;
            border: none;
            color: #ffffff;
            font-family: var(--font-ui);
            font-size: 1.125rem;
            font-weight: 600;
            cursor: pointer;
            text-align: left;
            transition: background-color 0.2s;
        }

        .accordion-header:hover {
            background-color: rgba(255, 255, 255, 0.02);
        }

        .accordion-icon {
            color: var(--accent-color);
            transition: transform 0.3s ease;
        }

        .accordion.active .accordion-icon {
            transform: rotate(180deg);
        }

        .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
            background-color: var(--bg-color);
        }

        .accordion-inner {
            padding: 1.5rem;
            border-top: 1px solid var(--border-color);
        }

        .routine-block {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            position: relative;
        }

        .routine-block h4 {
            color: #ffffff;
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .routine-list {
            list-style-type: none;
            font-family: var(--font-mono);
            font-size: 0.875rem;
            color: var(--text-primary);
        }

        .routine-list li {
            margin-bottom: 0.25rem;
            display: flex;
            justify-content: space-between;
            padding: 0.25rem 0;
        }

        .routine-list li span:last-child {
            color: var(--text-secondary);
        }

        .routine-list li.bold-row span {
            font-weight: 600;
            color: #ffffff;
        }

        .copy-btn {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 0.4rem;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .copy-btn:hover {
            color: var(--accent-color);
            border-color: var(--accent-color);
        }

        .copy-btn svg {
            width: 16px;
            height: 16px;
        }

        /* SEO Section */
        .seo-content {
            margin-top: 4rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
        }

        .seo-content h2 {
            color: var(--text-primary);
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            margin-top: 2rem;
        }

        .seo-content h2:first-child {
            margin-top: 0;
        }

        .seo-content p {
            margin-bottom: 1rem;
        }

        .seo-content ul {
            margin-bottom: 1rem;
            padding-left: 1.5rem;
        }

        .seo-content li {
            margin-bottom: 0.5rem;
        }







        /* Utility classes for filtering */
        .hidden {
            display: none !important;
        }

        .no-results {
            text-align: center;
            padding: 2rem;
            color: var(--text-secondary);
            font-style: italic;
            display: none;
        }

        @media (max-width: 600px) {
            h1 { font-size: 1.75rem; }
            .card-grid { grid-template-columns: 1fr; }
            .section-header h2 { font-size: 1.25rem; }
            .routine-list li { flex-direction: column; }
        }

  </style>
  <div class="container">
        <main>
            <div class="search-container">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" id="searchInput" class="search-input" placeholder="Search schedule, workouts, tips, or injuries..." aria-label="Search guide content">
            </div>

            <div id="noResults" class="no-results">
                No matching content found. Try a different search term.
            </div>

            <!-- Schedule Section -->
            <section class="content-section" data-tags="schedule weeks 1 2 3 4 5 6 7 8 training plan run walk routine">
                <div class="section-header">
                    <div class="section-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    </div>
                    <h2>The 8-Week Schedule</h2>
                </div>

                <!-- Week 1 -->
                <div class="accordion searchable-item" data-search="week 1 run 1 min walk 1.5 min repeat 8x">
                    <button class="accordion-header">
                        <span>Week 1</span>
                        <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-inner">
                            <p style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.875rem;">Begin with a brisk 5-minute warmup walk. Then, alternate 60 seconds of running, with 90 seconds of walking. Perform 3 times this week.</p>
                            <div class="routine-block" id="routine-w1">
                                <button class="copy-btn" onclick="copyRoutine('routine-w1')" title="Copy Routine" aria-label="Copy Week 1 Routine to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Week 1 Routine (Do 3x)</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li><span>Run</span><span>1 min</span></li>
                                    <li><span>Walk</span><span>1.5 mins</span></li>
                                    <li class="bold-row"><span>Repeat Run/Walk Cycle</span><span>8 times total</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Week 2 -->
                <div class="accordion searchable-item" data-search="week 2 run 1.5 min walk 2 min repeat 6x">
                    <button class="accordion-header">
                        <span>Week 2</span>
                        <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-inner">
                            <p style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.875rem;">Begin with a brisk 5-minute warmup walk. Then, alternate 90 seconds of running, with 2 minutes of walking. Perform 3 times this week.</p>
                            <div class="routine-block" id="routine-w2">
                                <button class="copy-btn" onclick="copyRoutine('routine-w2')" title="Copy Routine" aria-label="Copy Week 2 Routine to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Week 2 Routine (Do 3x)</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li><span>Run</span><span>1.5 mins</span></li>
                                    <li><span>Walk</span><span>2 mins</span></li>
                                    <li class="bold-row"><span>Repeat Run/Walk Cycle</span><span>6 times total</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Week 3 -->
                <div class="accordion searchable-item" data-search="week 3 run 90s walk 90s run 3m walk 3m">
                    <button class="accordion-header">
                        <span>Week 3</span>
                        <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-inner">
                            <p style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.875rem;">Things get interesting here with a longer 3-minute run mixed in. Perform 3 times this week.</p>
                            <div class="routine-block" id="routine-w3">
                                <button class="copy-btn" onclick="copyRoutine('routine-w3')" title="Copy Routine" aria-label="Copy Week 3 Routine to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Week 3 Routine (Do 3x)</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li><span>Run / Walk</span><span>90s / 90s</span></li>
                                    <li><span>Run / Walk</span><span>3 mins / 3 mins</span></li>
                                    <li><span>Run / Walk</span><span>90s / 90s</span></li>
                                    <li><span>Run / Walk</span><span>3 mins / 3 mins</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Week 4 -->
                <div class="accordion searchable-item" data-search="week 4 run 3m walk 90s run 5m walk 2.5m">
                    <button class="accordion-header">
                        <span>Week 4</span>
                        <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-inner">
                            <p style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.875rem;">Increasing the duration with a 5-minute run segment. Perform 3 times this week.</p>
                            <div class="routine-block" id="routine-w4">
                                <button class="copy-btn" onclick="copyRoutine('routine-w4')" title="Copy Routine" aria-label="Copy Week 4 Routine to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Week 4 Routine (Do 3x)</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li><span>Run / Walk</span><span>3 mins / 90s</span></li>
                                    <li><span>Run / Walk</span><span>5 mins / 2.5 mins</span></li>
                                    <li><span>Run / Walk</span><span>3 mins / 90s</span></li>
                                    <li><span>Run</span><span>5 mins</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Week 5 -->
                <div class="accordion searchable-item" data-search="week 5 different workouts run 20m 20 mins milestone">
                    <button class="accordion-header">
                        <span>Week 5</span>
                        <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-inner">
                            <p style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.875rem;">This week has 3 different workouts ending with the infamous 20-minute run. You can do this!</p>
                            <div class="routine-block" id="routine-w5-d1">
                                <button class="copy-btn" onclick="copyRoutine('routine-w5-d1')" title="Copy Routine" aria-label="Copy Week 5 Day 1 to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Day 1</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li><span>Run / Walk</span><span>5 mins / 3 mins</span></li>
                                    <li><span>Run / Walk</span><span>5 mins / 3 mins</span></li>
                                    <li><span>Run</span><span>5 mins</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
                            <div class="routine-block" id="routine-w5-d2">
                                <button class="copy-btn" onclick="copyRoutine('routine-w5-d2')" title="Copy Routine" aria-label="Copy Week 5 Day 2 to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Day 2</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li><span>Run / Walk</span><span>8 mins / 5 mins</span></li>
                                    <li><span>Run</span><span>8 mins</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
                            <div class="routine-block" id="routine-w5-d3">
                                <button class="copy-btn" onclick="copyRoutine('routine-w5-d3')" title="Copy Routine" aria-label="Copy Week 5 Day 3 to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Day 3</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li class="bold-row"><span>Run (No walking breaks)</span><span>20 mins</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Week 6 -->
                <div class="accordion searchable-item" data-search="week 6 different workouts run 22m 22 mins">
                    <button class="accordion-header">
                        <span>Week 6</span>
                        <svg class="accordion-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="accordion-content">
                        <div class="accordion-inner">
                            <p style="margin-bottom: 1rem; color: var(--text-secondary); font-size: 0.875rem;">Another week of varying workouts as we transition towards continuous running.</p>
                            <div class="routine-block" id="routine-w6-d1">
                                <button class="copy-btn" onclick="copyRoutine('routine-w6-d1')" title="Copy Routine" aria-label="Copy Week 6 Day 1 to clipboard">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                </button>
                                <h4>Day 1</h4>
                                <ul class="routine-list">
                                    <li><span>Warmup Walk</span><span>5 mins</span></li>
                                    <li><span>Run / Walk</span><span>5 mins / 3 mins</span></li>
                                    <li><span>Run / Walk</span><span>8 mins / 3 mins</span></li>
                                    <li><span>Run</span><span>5 mins</span></li>
                                    <li><span>Cooldown Walk</span><span>5 mins</span></li>
                                </ul>
                            </div>
