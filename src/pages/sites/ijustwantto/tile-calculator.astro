  <div class="container">
    <div style="background:rgba(45,184,154,0.08);border:1px solid rgba(45,184,154,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      🪨 <strong style="color:#2DB89A;">Buying 10% extra tile for waste is standard — but complex layouts need 15-20%.</strong> Running short mid-project costs 2-3× more (rush shipping + dye lot mismatch). Calculate your exact tile count, boxes, and total cost before you order. <a href="https://gab.ae/news/energy-costs-rising-oil-prices-electricity-bills-2026" style="color:#2DB89A;">Why material costs keep rising →</a>
    </div>
    <h1>Tile Calculator</h1>
    <p class="subtitle">Calculate how much tile you need — total area, number of tiles, boxes, and material cost</p>

    <main>
      <div class="card">
        <h2>Room Dimensions</h2>

        <div class="unit-toggle">
          <button type="button" class="unit-btn active" data-unit="ft">Feet</button>
          <button type="button" class="unit-btn" data-unit="m">Meters</button>
        </div>

        <div class="form-row">
          <div class="form-group form-col">
            <label for="roomLength">Length (<span id="unitLabelL">ft</span>)</label>
            <input type="number" id="roomLength" required min="0.1" step="0.01" placeholder="e.g. 12">
          </div>
          <div class="form-group form-col">
            <label for="roomWidth">Width (<span id="unitLabelW">ft</span>)</label>
            <input type="number" id="roomWidth" required min="0.1" step="0.01" placeholder="e.g. 10">
          </div>
        </div>
      </div>

      <div class="card">
        <h2>Tile Size</h2>
        <label style="margin-bottom:0.35rem;">Select a common size or enter custom dimensions</label>
        <div class="tile-sizes" id="tileSizes"></div>

        <div class="form-row">
          <div class="form-group form-col">
            <label for="tileW">Tile Width (inches)</label>
            <input type="number" id="tileW" required min="0.5" step="0.25" placeholder="12" value="12">
          </div>
          <div class="form-group form-col">
            <label for="tileH">Tile Height (inches)</label>
            <input type="number" id="tileH" required min="0.5" step="0.25" placeholder="12" value="12">
          </div>
        </div>
      </div>

      <div class="card">
        <h2>Layout Options</h2>

        <div class="form-group">
          <label>Pattern</label>
          <div class="pattern-options" id="patternOptions"></div>
        </div>

        <div class="form-row">
          <div class="form-group form-col">
            <label for="groutWidth">Grout Width</label>
            <select id="groutWidth">
              <option value="0.0625">1/16"</option>
              <option value="0.125" selected>1/8"</option>
              <option value="0.1875">3/16"</option>
              <option value="0.25">1/4"</option>
              <option value="0.375">3/8"</option>
              <option value="0.5">1/2"</option>
            </select>
          </div>
          <div class="form-group form-col">
            <label for="wasteFactor">Waste Factor (%)</label>
            <input type="number" id="wasteFactor" required min="0" max="50" step="1" value="10">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group form-col">
            <label for="tilesPerBox">Tiles per Box</label>
            <input type="number" id="tilesPerBox" required min="1" step="1" placeholder="e.g. 10" value="10">
          </div>
        </div>
      </div>

      <div class="card">
        <h2>Cost Estimator (Optional)</h2>
        <div class="form-row">
          <div class="form-group form-col">
            <label for="pricePerSqft">Tile Price ($ per sq ft)</label>
            <input type="number" id="pricePerSqft" min="0" step="0.01" placeholder="e.g. 3.50" value="3.50">
          </div>
        </div>
      </div>

      <button type="button" class="calc-btn" id="calcBtn">Calculate Tiles Needed</button>

      <div id="results" class="results">
        <div class="card">
          <h2>Results</h2>
          <div class="macros-grid">
            <div class="macro-card">
              <h3>Total Room Area</h3>
              <div class="value" id="rArea">0</div>
              <div class="desc" id="rAreaDesc">sq ft</div>
            </div>
            <div class="macro-card">
              <h3>Tiles Needed</h3>
              <div class="value" id="rTiles">0</div>
              <div class="desc" id="rTilesDesc">includes waste</div>
            </div>
