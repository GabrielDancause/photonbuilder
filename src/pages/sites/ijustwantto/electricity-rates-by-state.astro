---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Electricity Rates by State",
      "url": "https://ijustwantto.live/electricity-rates-by-state",
      "description": "Compare electricity rates across all 50 US states. See average residential rates, monthly bills, and how each state compares to the national average. Enter your usage to calculate your bill in every state.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Which US state has the cheapest electricity?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "As of 2024–2025, Louisiana, Idaho, and Washington consistently have the cheapest residential electricity rates in the US, typically under 10 cents per kWh. These low rates are largely due to abundant hydroelectric power (Washington, Idaho) and favorable natural gas prices (Louisiana)."
          }
        },
        {
          "@type": "Question",
          "name": "Which US state has the most expensive electricity?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hawaii has the highest electricity rates in the US at over 40 cents per kWh, primarily because the state relies heavily on imported petroleum for power generation. Other high-rate states include Connecticut, Massachusetts, Rhode Island, and California."
          }
        },
        {
          "@type": "Question",
          "name": "What is the average electricity rate in the United States?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The national average residential electricity rate is approximately 16.6 cents per kWh as of 2024. This translates to an average monthly bill of about $147 for a typical household using 886 kWh per month. Rates vary significantly by state and region."
          }
        },
        {
          "@type": "Question",
          "name": "Why do electricity rates vary so much between states?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Electricity rates vary due to differences in fuel sources (coal, natural gas, hydro, nuclear), infrastructure costs, state regulations and taxes, climate-driven demand, transmission distances, and whether the state has a deregulated or regulated energy market. States with abundant local energy resources tend to have lower rates."
          }
        },
        {
          "@type": "Question",
          "name": "How much does the average American spend on electricity per month?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The average American household spends about $147 per month on electricity. However, this varies widely — from around $90/month in states like Utah and Washington to over $170/month in states like Connecticut and Alabama. Hawaii residents pay the most at roughly $190/month despite lower usage."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Electricity Rates by State — US Energy Costs",
  description: "Compare electricity rates across all 50 US states. See average residential rates in cents/kWh, monthly bills, and estimate your cost in each state.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="ijustwantto"
  title="Electricity Rates by State — Compare US Energy Costs 2025 | ijustwantto.live"
  description="Compare electricity rates across all 50 US states. See average residential rates (cents/kWh), monthly bills, and calculate what your bill would be in each state."
  canonical="https://ijustwantto.live/electricity-rates-by-state"
  schema={schema}
>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-ui); background-color: var(--bg-color); color: var(--text-primary); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    .container { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
    h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; color: #ffffff; text-align: center; }
    p.subtitle { color: var(--text-secondary); font-size: 1rem; text-align: center; margin-bottom: 2rem; }
    .card { background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
    .card h2 { font-size: 1.15rem; font-weight: 700; color: #ffffff; margin-bottom: 1rem; }
    .form-group { margin-bottom: 1rem; }
    label { display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-primary); }
    input[type="number"] {
      width: 100%; background-color: var(--bg-color); border: 1px solid var(--border-color); color: var(--text-primary);
      padding: 0.75rem; border-radius: 6px; font-family: var(--font-ui); font-size: 1rem; transition: border-color 0.2s; appearance: none;
    }
    input[type="number"]:focus { outline: none; border-color: var(--accent-color); }
    button.calc-btn {
      width: 100%; background-color: var(--accent-color); color: #000000; border: none; padding: 1rem; border-radius: 6px;
      font-size: 1rem; font-weight: 600; cursor: pointer; transition: background-color 0.2s; margin-top: 1rem; font-family: var(--font-ui);
    }
    button.calc-btn:hover { background-color: var(--accent-hover); }

    /* Summary cards */
    .summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem; }
    .summary-card {
      background-color: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.25rem;
      text-align: center;
    }
    .summary-card h3 { font-size: 0.8rem; color: var(--text-secondary); font-weight: 500; margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .summary-card .value { font-family: var(--font-mono); font-size: 1.25rem; color: var(--accent-color); font-weight: 600; }
    .summary-card .label { font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem; }
    .summary-card.cheapest { border-color: #22c55e; }
    .summary-card.cheapest .value { color: #22c55e; }
    .summary-card.expensive { border-color: #ef4444; }
    .summary-card.expensive .value { color: #ef4444; }

    /* Table */
    .table-controls { display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; align-items: center; }
    .search-input {
      flex: 1; min-width: 160px; background-color: var(--bg-color); border: 1px solid var(--border-color); color: var(--text-primary);
      padding: 0.6rem 0.75rem; border-radius: 6px; font-family: var(--font-ui); font-size: 0.875rem;
    }
    .search-input:focus { outline: none; border-color: var(--accent-color); }
    .sort-btn {
      background-color: var(--bg-color); border: 1px solid var(--border-color); border-radius: 6px; padding: 0.5rem 0.75rem;
      font-size: 0.75rem; color: var(--text-secondary); cursor: pointer; transition: all 0.2s; font-family: var(--font-ui); white-space: nowrap;
    }
    .sort-btn:hover, .sort-btn.active { border-color: var(--accent-color); color: var(--accent-color); }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    thead th {
      text-align: left; padding: 0.75rem 0.5rem; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color); cursor: pointer; user-select: none; white-space: nowrap;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    thead th:hover { color: var(--accent-color); }
    thead th .arrow { font-size: 0.65rem; margin-left: 0.25rem; }
    tbody tr { border-bottom: 1px solid var(--border-color); transition: background-color 0.15s; }
    tbody tr:hover { background-color: rgba(255,255,255,0.03); }
    tbody td { padding: 0.65rem 0.5rem; }
    td.state-name { font-weight: 600; color: var(--text-primary); }
    td.rate { font-family: var(--font-mono); color: var(--accent-color); }
    td.bill { font-family: var(--font-mono); }
    .vs-avg { font-size: 0.75rem; font-weight: 600; padding: 0.15rem 0.4rem; border-radius: 4px; display: inline-block; }
    .vs-avg.above { color: #ef4444; background-color: rgba(239,68,68,0.1); }
    .vs-avg.below { color: #22c55e; background-color: rgba(34,197,94,0.1); }
    .vs-avg.avg { color: var(--text-secondary); background-color: rgba(255,255,255,0.05); }
    .yoy { font-size: 0.8rem; }
    .yoy.up { color: #ef4444; }
    .yoy.down { color: #22c55e; }
    .yoy.flat { color: var(--text-secondary); }
    .rank { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-secondary); }
    .cheapest-tag, .expensive-tag { font-size: 0.65rem; font-weight: 700; padding: 0.1rem 0.35rem; border-radius: 3px; margin-left: 0.5rem; }
    .cheapest-tag { color: #22c55e; background-color: rgba(34,197,94,0.15); }
    .expensive-tag { color: #ef4444; background-color: rgba(239,68,68,0.15); }

    /* Custom bill column */
    .custom-bill { font-family: var(--font-mono); color: var(--accent-color); font-weight: 600; }

    .seo-content { margin-top: 3rem; }
    .seo-content h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: #ffffff; }
    .seo-content h3 { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: #ffffff; }
    .seo-content p { margin-bottom: 1rem; color: var(--text-secondary); }
    .seo-content ul { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .seo-content li { margin-bottom: 0.5rem; }

    @media (min-width: 640px) {
      .summary-grid { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <div class="container">
    <h1>Electricity Rates by State</h1>
    <p class="subtitle">Compare residential electricity rates across all 50 US states — updated with 2024/2025 EIA data</p>

    <main>
      <!-- Summary Cards -->
      <div class="summary-grid">
        <div class="summary-card cheapest">
          <h3>Cheapest State</h3>
          <div class="value">Idaho</div>
          <div class="label">8.6¢/kWh</div>
        </div>
        <div class="summary-card expensive">
          <h3>Most Expensive</h3>
          <div class="value">Hawaii</div>
          <div class="label">43.6¢/kWh</div>
        </div>
        <div class="summary-card">
          <h3>National Average</h3>
          <div class="value">16.6¢</div>
          <div class="label">per kWh</div>
        </div>
        <div class="summary-card">
          <h3>Avg Monthly Bill</h3>
          <div class="value">$147</div>
          <div class="label">886 kWh/mo</div>
        </div>
      </div>

      <!-- Calculator -->
      <div class="card">
        <h2>Your Bill in Every State</h2>
        <p style="color:var(--text-secondary);font-size:0.875rem;margin-bottom:1rem;">Enter your monthly kWh usage to see what your bill would cost in each state.</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end;">
          <div class="form-group" style="flex:1;min-width:180px;margin-bottom:0;">
            <label for="customKwh">Monthly Usage (kWh)</label>
            <input type="number" id="customKwh" min="1" step="1" placeholder="e.g. 886" value="886">
          </div>
          <button type="button" class="calc-btn" id="calcBtn" style="flex:0 0 auto;width:auto;padding:0.75rem 2rem;margin-top:0;">Calculate</button>
        </div>
      </div>

      <!-- Table -->
      <div class="card">
        <h2>All 50 States — Residential Electricity Rates</h2>
        <div class="table-controls">
          <input type="text" class="search-input" id="searchInput" placeholder="Search states...">
          <button class="sort-btn active" data-sort="rate-asc">Cheapest First</button>
          <button class="sort-btn" data-sort="rate-desc">Most Expensive</button>
          <button class="sort-btn" data-sort="name">A–Z</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th data-col="rank">#</th>
                <th data-col="name">State <span class="arrow"></span></th>
                <th data-col="rate">Rate (¢/kWh) <span class="arrow"></span></th>
                <th data-col="bill">Avg Bill/Mo <span class="arrow"></span></th>
                <th data-col="vs">vs National Avg</th>
                <th data-col="yoy">YoY Change</th>
                <th data-col="custom" id="customHeader" style="display:none;">Your Bill</th>
              </tr>
            </thead>
            <tbody id="tableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- Top 5 / Bottom 5 -->
      <div class="card">
        <h2>5 Cheapest States for Electricity</h2>
        <div id="cheapList"></div>
      </div>
      <div class="card">
        <h2>5 Most Expensive States for Electricity</h2>
        <div id="expensiveList"></div>
      </div>

      <!-- SEO Content -->
      <div class="seo-content">
        <h2>Understanding Electricity Rates Across the US</h2>
        <p>Electricity rates in the United States vary dramatically from state to state, driven by differences in energy sources, infrastructure costs, regulations, and local demand. The national average residential rate sits at approximately <strong>16.6 cents per kWh</strong>, but individual states range from under 9 cents to over 43 cents per kWh.</p>

        <h3>Why Are Some States So Much Cheaper?</h3>
        <p>States with the lowest electricity rates typically benefit from one or more of these factors: abundant hydroelectric power (Washington, Idaho, Oregon), low-cost natural gas (Louisiana, Oklahoma, Arkansas), significant nuclear generation (Illinois), or deregulated markets with strong competition. Geographic isolation and reliance on imported fuels — as in Hawaii and Alaska — drive rates higher.</p>

        <h3>How Are Electricity Rates Set?</h3>
        <p>In regulated markets (about 35 states), utility companies propose rates to a public utility commission, which approves or modifies them. In deregulated states (like Texas, Pennsylvania, and Ohio), consumers can choose their electricity provider, and competition helps set prices. Both systems factor in fuel costs, infrastructure maintenance, transmission losses, and state/local taxes.</p>

        <h3>The Impact on Monthly Bills</h3>
        <p>Your monthly bill depends on both the rate and your consumption. A household in Washington paying 10.5¢/kWh and using 886 kWh pays about $93/month, while the same usage in Connecticut at 29.3¢/kWh costs $260/month — nearly three times as much. Climate plays a huge role in consumption: hot southern states use more AC, while northern states may have higher heating costs (though many heat with gas, not electricity).</p>

        <h3>Year-Over-Year Rate Changes</h3>
        <p>Electricity rates have been rising nationally at roughly 3–6% per year, driven by infrastructure upgrades, the transition to renewable energy, and rising fuel costs. Some states have seen sharper increases due to extreme weather events, grid modernization efforts, or shifts in fuel markets.</p>

        <h2>Frequently Asked Questions</h2>

        <h3>Which US state has the cheapest electricity?</h3>
        <p>Idaho, Louisiana, and Washington consistently have the lowest residential electricity rates in the US, typically under 10 cents per kWh. Idaho benefits from abundant hydroelectric power, Louisiana from cheap natural gas, and Washington from the massive Columbia River hydroelectric system.</p>

        <h3>Which US state has the most expensive electricity?</h3>
        <p>Hawaii has the highest rates at over 43 cents per kWh due to its reliance on imported petroleum. On the mainland, Connecticut, Massachusetts, and Rhode Island have the highest rates, typically between 25–30 cents per kWh.</p>

        <h3>What is the average electricity rate in the US?</h3>
        <p>The national average residential electricity rate is approximately 16.6 cents per kWh. The average US household uses about 886 kWh per month, resulting in an average monthly bill of roughly $147.</p>

        <h3>Why do electricity rates vary so much between states?</h3>
        <p>Rates vary due to differences in fuel sources, infrastructure costs, state regulations and taxes, climate-driven demand, transmission distances, and whether the state has a deregulated or regulated energy market.</p>

        <h3>How can I lower my electricity bill regardless of my state's rates?</h3>
        <p>Focus on reducing consumption: switch to LED lighting, use a programmable thermostat, seal air leaks, upgrade to Energy Star appliances, and consider solar panels. In deregulated states, you can also shop around for a cheaper electricity provider.</p>

        <h2>Related Tools</h2>
        <ul>
          <li><a href="/electricity-cost-calculator" style="color:var(--accent-color);">Electricity Cost Calculator</a> — Calculate the cost of running any appliance</li>
          <li><a href="/solar-panel-calculator" style="color:var(--accent-color);">Solar Panel Calculator</a> — Estimate savings from going solar</li>
          <li><a href="/btu-calculator" style="color:var(--accent-color);">BTU Calculator</a> — Size your AC or heater for any room</li>
        </ul>
      </div>
    </main>
  </div>

  <script is:inline>
    // EIA-sourced approximate 2024/2025 residential electricity data for all 50 states
    // rate = cents/kWh, avgKwh = avg monthly consumption, yoy = year-over-year % change
    var STATES = [
      { name:"Alabama", abbr:"AL", rate:14.6, avgKwh:1120, yoy:3.5 },
      { name:"Alaska", abbr:"AK", rate:24.2, avgKwh:590, yoy:2.8 },
      { name:"Arizona", abbr:"AZ", rate:14.1, avgKwh:1030, yoy:5.2 },
      { name:"Arkansas", abbr:"AR", rate:12.2, avgKwh:1080, yoy:3.1 },
      { name:"California", abbr:"CA", rate:27.8, avgKwh:540, yoy:6.4 },
      { name:"Colorado", abbr:"CO", rate:14.8, avgKwh:700, yoy:4.3 },
      { name:"Connecticut", abbr:"CT", rate:29.3, avgKwh:700, yoy:5.8 },
      { name:"Delaware", abbr:"DE", rate:14.9, avgKwh:870, yoy:3.2 },
      { name:"Florida", abbr:"FL", rate:15.5, avgKwh:1050, yoy:4.0 },
      { name:"Georgia", abbr:"GA", rate:14.1, avgKwh:1050, yoy:3.6 },
      { name:"Hawaii", abbr:"HI", rate:43.6, avgKwh:510, yoy:2.1 },
      { name:"Idaho", abbr:"ID", rate:8.6, avgKwh:940, yoy:3.0 },
      { name:"Illinois", abbr:"IL", rate:14.5, avgKwh:720, yoy:4.8 },
      { name:"Indiana", abbr:"IN", rate:14.6, avgKwh:900, yoy:3.4 },
      { name:"Iowa", abbr:"IA", rate:14.0, avgKwh:860, yoy:2.9 },
      { name:"Kansas", abbr:"KS", rate:14.5, avgKwh:870, yoy:3.7 },
      { name:"Kentucky", abbr:"KY", rate:12.4, avgKwh:1060, yoy:3.3 },
      { name:"Louisiana", abbr:"LA", rate:9.8, avgKwh:1140, yoy:2.7 },
      { name:"Maine", abbr:"ME", rate:22.2, avgKwh:530, yoy:4.5 },
      { name:"Maryland", abbr:"MD", rate:16.1, avgKwh:880, yoy:4.1 },
      { name:"Massachusetts", abbr:"MA", rate:28.5, avgKwh:590, yoy:5.6 },
      { name:"Michigan", abbr:"MI", rate:18.3, avgKwh:650, yoy:4.7 },
      { name:"Minnesota", abbr:"MN", rate:14.5, avgKwh:770, yoy:3.2 },
      { name:"Mississippi", abbr:"MS", rate:12.8, avgKwh:1080, yoy:3.0 },
      { name:"Missouri", abbr:"MO", rate:12.9, avgKwh:1020, yoy:3.5 },
      { name:"Montana", abbr:"MT", rate:11.9, avgKwh:800, yoy:4.1 },
      { name:"Nebraska", abbr:"NE", rate:12.0, avgKwh:920, yoy:2.6 },
      { name:"Nevada", abbr:"NV", rate:13.3, avgKwh:920, yoy:4.8 },
      { name:"New Hampshire", abbr:"NH", rate:24.2, avgKwh:590, yoy:5.1 },
      { name:"New Jersey", abbr:"NJ", rate:18.2, avgKwh:680, yoy:4.3 },
      { name:"New Mexico", abbr:"NM", rate:14.3, avgKwh:660, yoy:3.9 },
      { name:"New York", abbr:"NY", rate:22.6, avgKwh:590, yoy:4.6 },
      { name:"North Carolina", abbr:"NC", rate:13.0, avgKwh:970, yoy:3.4 },
      { name:"North Dakota", abbr:"ND", rate:11.5, avgKwh:1070, yoy:2.4 },
      { name:"Ohio", abbr:"OH", rate:14.1, avgKwh:830, yoy:3.8 },
      { name:"Oklahoma", abbr:"OK", rate:11.4, avgKwh:1050, yoy:3.1 },
      { name:"Oregon", abbr:"OR", rate:11.8, avgKwh:870, yoy:3.5 },
      { name:"Pennsylvania", abbr:"PA", rate:17.0, avgKwh:800, yoy:4.2 },
      { name:"Rhode Island", abbr:"RI", rate:27.0, avgKwh:570, yoy:5.3 },
      { name:"South Carolina", abbr:"SC", rate:14.1, avgKwh:1050, yoy:3.2 },
      { name:"South Dakota", abbr:"SD", rate:12.7, avgKwh:940, yoy:2.8 },
      { name:"Tennessee", abbr:"TN", rate:12.3, avgKwh:1100, yoy:3.0 },
      { name:"Texas", abbr:"TX", rate:14.0, avgKwh:1130, yoy:4.5 },
      { name:"Utah", abbr:"UT", rate:10.6, avgKwh:800, yoy:3.2 },
      { name:"Vermont", abbr:"VT", rate:21.0, avgKwh:540, yoy:4.0 },
      { name:"Virginia", abbr:"VA", rate:13.7, avgKwh:1030, yoy:3.6 },
      { name:"Washington", abbr:"WA", rate:10.5, avgKwh:930, yoy:3.8 },
      { name:"West Virginia", abbr:"WV", rate:12.7, avgKwh:960, yoy:2.9 },
      { name:"Wisconsin", abbr:"WI", rate:16.0, avgKwh:670, yoy:3.4 },
      { name:"Wyoming", abbr:"WY", rate:11.1, avgKwh:830, yoy:2.5 }
    ];

    var NAT_AVG = 16.6;
    var currentSort = "rate-asc";
    var customKwh = null;

    function fmt(n) { return "$" + n.toFixed(2); }

    function sortStates(list, key) {
      var sorted = list.slice();
      switch(key) {
        case "rate-asc": sorted.sort(function(a,b){ return a.rate - b.rate; }); break;
        case "rate-desc": sorted.sort(function(a,b){ return b.rate - a.rate; }); break;
        case "name": sorted.sort(function(a,b){ return a.name.localeCompare(b.name); }); break;
        case "bill-asc": sorted.sort(function(a,b){ return (a.rate*a.avgKwh) - (b.rate*b.avgKwh); }); break;
        case "bill-desc": sorted.sort(function(a,b){ return (b.rate*b.avgKwh) - (a.rate*a.avgKwh); }); break;
        case "yoy-desc": sorted.sort(function(a,b){ return b.yoy - a.yoy; }); break;
      }
      return sorted;
    }

    function getVsClass(rate) {
      var pct = ((rate - NAT_AVG) / NAT_AVG) * 100;
      if (pct > 2) return "above";
      if (pct < -2) return "below";
      return "avg";
    }

    function getVsText(rate) {
      var pct = ((rate - NAT_AVG) / NAT_AVG) * 100;
      if (Math.abs(pct) < 2) return "≈ avg";
      return (pct > 0 ? "+" : "") + pct.toFixed(0) + "%";
    }

    function getYoyClass(yoy) {
      if (yoy > 4) return "up";
      if (yoy < 2) return "down";
      return "flat";
    }

    // Get sorted by rate for cheapest/expensive rank
    var byRate = sortStates(STATES, "rate-asc");
    var cheapestName = byRate[0].name;
    var expensiveName = byRate[byRate.length - 1].name;

    function renderTable() {
      var search = document.getElementById("searchInput").value.toLowerCase();
      var filtered = STATES.filter(function(s) {
        return s.name.toLowerCase().indexOf(search) !== -1 || s.abbr.toLowerCase().indexOf(search) !== -1;
      });
      var sorted = sortStates(filtered, currentSort);
      var tbody = document.getElementById("tableBody");
      tbody.innerHTML = "";

      // Rank by rate
      var rankMap = {};
      byRate.forEach(function(s, i) { rankMap[s.abbr] = i + 1; });

      sorted.forEach(function(s) {
        var bill = (s.rate * s.avgKwh / 100);
        var tr = document.createElement("tr");
        var tag = "";
        if (s.name === cheapestName) tag = '<span class="cheapest-tag">LOWEST</span>';
        if (s.name === expensiveName) tag = '<span class="expensive-tag">HIGHEST</span>';

        var customCell = "";
        if (customKwh !== null) {
          var cb = (s.rate * customKwh / 100);
          customCell = '<td class="custom-bill">' + fmt(cb) + '</td>';
        }

        tr.innerHTML = '<td class="rank">' + rankMap[s.abbr] + '</td>' +
          '<td class="state-name">' + s.name + ' <span style="color:var(--text-secondary);font-weight:400;">(' + s.abbr + ')</span>' + tag + '</td>' +
          '<td class="rate">' + s.rate.toFixed(1) + '¢</td>' +
          '<td class="bill">' + fmt(bill) + '</td>' +
          '<td><span class="vs-avg ' + getVsClass(s.rate) + '">' + getVsText(s.rate) + '</span></td>' +
          '<td><span class="yoy ' + getYoyClass(s.yoy) + '">+' + s.yoy.toFixed(1) + '%</span></td>' +
          customCell;
        tbody.appendChild(tr);
      });
    }

    function renderTopLists() {
      var cheapest = byRate.slice(0, 5);
      var expensive = byRate.slice(-5).reverse();

      var cheapEl = document.getElementById("cheapList");
      cheapEl.innerHTML = "";
      cheapest.forEach(function(s, i) {
        var bill = (s.rate * s.avgKwh / 100);
        var d = document.createElement("div");
        d.style.cssText = "display:flex;justify-content:space-between;align-items:center;padding:0.75rem;background:var(--bg-color);border:1px solid var(--border-color);border-radius:6px;margin-bottom:0.5rem;";
        d.innerHTML = '<div><span style="color:#22c55e;font-weight:700;margin-right:0.5rem;">#' + (i+1) + '</span><span style="font-weight:600;">' + s.name + '</span></div>' +
          '<div style="text-align:right;"><span style="font-family:var(--font-mono);color:#22c55e;font-weight:600;">' + s.rate.toFixed(1) + '¢/kWh</span><span style="color:var(--text-secondary);font-size:0.8rem;margin-left:0.75rem;">' + fmt(bill) + '/mo</span></div>';
        cheapEl.appendChild(d);
      });

      var expEl = document.getElementById("expensiveList");
      expEl.innerHTML = "";
      expensive.forEach(function(s, i) {
        var bill = (s.rate * s.avgKwh / 100);
        var d = document.createElement("div");
        d.style.cssText = "display:flex;justify-content:space-between;align-items:center;padding:0.75rem;background:var(--bg-color);border:1px solid var(--border-color);border-radius:6px;margin-bottom:0.5rem;";
        d.innerHTML = '<div><span style="color:#ef4444;font-weight:700;margin-right:0.5rem;">#' + (50 - i) + '</span><span style="font-weight:600;">' + s.name + '</span></div>' +
          '<div style="text-align:right;"><span style="font-family:var(--font-mono);color:#ef4444;font-weight:600;">' + s.rate.toFixed(1) + '¢/kWh</span><span style="color:var(--text-secondary);font-size:0.8rem;margin-left:0.75rem;">' + fmt(bill) + '/mo</span></div>';
        expEl.appendChild(d);
      });
    }

    // Sort buttons
    document.querySelectorAll(".sort-btn").forEach(function(btn) {
      btn.addEventListener("click", function() {
        document.querySelectorAll(".sort-btn").forEach(function(b){ b.classList.remove("active"); });
        btn.classList.add("active");
        currentSort = btn.dataset.sort;
        renderTable();
      });
    });

    // Column header sorting
    document.querySelectorAll("thead th").forEach(function(th) {
      th.addEventListener("click", function() {
        var col = th.dataset.col;
        if (col === "rate") currentSort = currentSort === "rate-asc" ? "rate-desc" : "rate-asc";
        else if (col === "name") currentSort = "name";
        else if (col === "bill") currentSort = currentSort === "bill-asc" ? "bill-desc" : "bill-asc";
        else if (col === "yoy") currentSort = "yoy-desc";
        document.querySelectorAll(".sort-btn").forEach(function(b){ b.classList.remove("active"); });
        renderTable();
      });
    });

    // Search
    document.getElementById("searchInput").addEventListener("input", renderTable);

    // Custom kWh calculator
    document.getElementById("calcBtn").addEventListener("click", function() {
      var val = parseFloat(document.getElementById("customKwh").value);
      if (isNaN(val) || val <= 0) return;
      customKwh = val;
      document.getElementById("customHeader").style.display = "";
      renderTable();
    });

    // Initial render
    renderTable();
    renderTopLists();
  </script>

  <!-- Pillar Guide Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">Related Tools</p>
      <div class="grid gap-3">
        <a href="/electricity-cost-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Electricity Cost Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Calculate the cost of running any appliance →</p>
        </a>
        <a href="/solar-panel-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Solar Panel Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Estimate how much you could save with solar →</p>
        </a>
        <a href="/btu-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">BTU Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Size your AC or heater for any room →</p>
        </a>
      </div>
    </div>
  </div>
</SiteLayout>
