---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Coming Soon — Content Roadmap', description: 'See what tools, guides, and research are coming next to I Just Want To Live.', category: 'guides', published: '2026-03-15' };

const SITE_ID = 'ijustwantto';

const allPages = import.meta.glob('./*.astro', { eager: true });
const publishedCount = Object.keys(allPages).filter(k => !k.includes('index') && !k.includes('coming-soon')).length;

const categories = [
  {
    icon: '🧱',
    title: 'Construction Calculators',
    description: 'Concrete, lumber, tile, and material calculators',
    total: 33,
    items: [
      { name: 'Concrete Calculator', searches: '262,000', status: 'published', href: '/ijustwantto/concrete-calculator' },
      { name: 'Square Foot Calculator', searches: '41,000', status: 'published', href: '/ijustwantto/square-foot-calculator' },
      { name: 'Gravel Calculator', searches: '30,000', status: 'published', href: '/ijustwantto/gravel-calculator' },
      { name: 'Cubic Feet Calculator', searches: '27,000', status: 'published', href: '/ijustwantto/cubic-feet-calculator' },
      { name: 'Cubic Yard Calculator', searches: '25,000', status: 'published', href: '/ijustwantto/cubic-yard-calculator' },
      { name: 'Mulch Calculator', searches: '23,000', status: 'published', href: '/ijustwantto/mulch-calculator' },
      { name: 'Sq Ft Calculator', searches: '22,000', status: 'published', href: '/ijustwantto/sq-ft-calculator' },
      { name: 'Stair Calculator', searches: '18,000', status: 'published', href: '/ijustwantto/stair-calculator' }
    ]
  },
  {
    icon: '⚡',
    title: 'Energy & Utilities',
    description: 'Solar, electricity, BTU, and energy cost tools',
    total: 7,
    items: [
      { name: 'Btu Calculator', searches: '7,800', status: 'published', href: '/ijustwantto/btu-calculator' },
      { name: 'Solar Calculator', searches: '6,000', status: 'published', href: '/ijustwantto/solar-calculator' },
      { name: 'Insulation Calculator', searches: '2,300', status: 'building', href: '' },
      { name: 'Guide Insulation', searches: '—', status: 'published', href: '/ijustwantto/guide-insulation' },
      { name: 'Electricity Cost Calculator', searches: '—', status: 'published', href: '/ijustwantto/electricity-cost-calculator' },
      { name: 'Guide Energy Complete', searches: '—', status: 'published', href: '/ijustwantto/guide-energy-complete' },
      { name: 'Electricity Costs', searches: '—', status: 'published', href: '/ijustwantto/electricity-costs' }
    ]
  },
  {
    icon: '🏠',
    title: 'Home Improvement Guides',
    description: 'Renovation guides, DIY tips, and contractor advice',
    total: 11,
    items: [
      { name: 'Guide Exterior Complete', searches: '—', status: 'published', href: '/ijustwantto/guide-exterior-complete' },
      { name: 'Home Renovation Timeline', searches: '—', status: 'published', href: '/ijustwantto/home-renovation-timeline' },
      { name: 'Renovation Permit Guide', searches: '—', status: 'published', href: '/ijustwantto/renovation-permit-guide' },
      { name: 'Home Inspection Checklist', searches: '—', status: 'published', href: '/ijustwantto/home-inspection-checklist' },
      { name: 'Diy Vs Contractor', searches: '—', status: 'published', href: '/ijustwantto/diy-vs-contractor' },
      { name: 'Home Renovation Guide', searches: '—', status: 'published', href: '/ijustwantto/home-renovation-guide' },
      { name: 'How To Unclog A Drain', searches: '—', status: 'published', href: '/ijustwantto/how-to-unclog-a-drain' },
      { name: 'Guide Materials Complete', searches: '—', status: 'published', href: '/ijustwantto/guide-materials-complete' }
    ]
  },
  {
    icon: '🔨',
    title: 'Home Tools',
    description: 'General home improvement tools and resources',
    total: 44,
    items: [
      { name: 'Scientific Calculator', searches: '353,000', status: 'building', href: '' },
      { name: 'Desmos Scientific Calculator', searches: '101,000', status: 'building', href: '' },
      { name: 'Volume Calculator', searches: '28,000', status: 'building', href: '' },
      { name: 'Weight Calculator', searches: '20,000', status: 'building', href: '' },
      { name: 'Circumference Calculator', searches: '19,000', status: 'published', href: '/ijustwantto/circumference-calculator' },
      { name: 'Square Feet Calculator', searches: '17,000', status: 'published', href: '/ijustwantto/square-feet-calculator' },
      { name: 'Ideal Body Weight Calculator', searches: '15,000', status: 'building', href: '' },
      { name: 'Area Calculator', searches: '14,000', status: 'building', href: '' }
    ]
  }
];
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID}>
  <style is:inline>
    .coming-soon-hero { text-align: center; padding: 3rem 1rem 2rem; max-width: 800px; margin: 0 auto; }
    .coming-soon-hero h1 { font-size: 2.2rem; margin-bottom: 0.5rem; background: linear-gradient(135deg, var(--accent), #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .coming-soon-hero p { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.6; }
    .stats-bar { display: flex; justify-content: center; gap: 2rem; padding: 1.5rem; margin: 0 auto 2rem; max-width: 700px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; }
    .stat { text-align: center; }
    .stat-number { font-size: 1.8rem; font-weight: 700; color: var(--accent); }
    .stat-label { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem; }
    .category-section { max-width: 900px; margin: 0 auto 2.5rem; padding: 0 1rem; }
    .category-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
    .category-header h2 { font-size: 1.4rem; margin: 0; }
    .category-count { background: var(--card-bg); border: 1px solid var(--border); padding: 0.15rem 0.6rem; border-radius: 20px; font-size: 0.75rem; color: var(--text-secondary); }
    .category-desc { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }
    .items-grid { display: grid; gap: 0.5rem; }
    .item-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; transition: border-color 0.2s; }
    .item-row:hover { border-color: var(--accent); }
    .item-row a { color: var(--text-primary); text-decoration: none; font-weight: 500; }
    .item-row a:hover { color: var(--accent); }
    .item-name { font-weight: 500; }
    .item-right { display: flex; align-items: center; gap: 1rem; }
    .item-searches { font-size: 0.8rem; color: var(--text-secondary); }
    .badge { font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; }
    .badge-published { background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }
    .badge-building { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
    .more-coming { text-align: center; padding: 1rem; color: var(--text-secondary); font-size: 0.9rem; border-top: 1px solid var(--border); margin-top: 0.5rem; }
    @media (max-width: 640px) { .stats-bar { flex-wrap: wrap; gap: 1rem; } .item-searches { display: none; } .coming-soon-hero h1 { font-size: 1.6rem; } }
  </style>

  <div class="coming-soon-hero">
    <h1>📋 Content Roadmap</h1>
    <p>Here's what's published and what's coming next.</p>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-number">{publishedCount}</div>
      <div class="stat-label">Published</div>
    </div>
    <div class="stat">
      <div class="stat-number">49</div>
      <div class="stat-label">In Pipeline</div>
    </div>
    <div class="stat">
      <div class="stat-number">4</div>
      <div class="stat-label">Categories</div>
    </div>
  </div>

  {categories.map(cat => (
    <div class="category-section">
      <div class="category-header">
        <span style="font-size:1.5rem">{cat.icon}</span>
        <h2>{cat.title}</h2>
        <span class="category-count">{cat.total} planned</span>
      </div>
      <p class="category-desc">{cat.description}</p>
      <div class="items-grid">
        {cat.items.map(item => (
          <div class="item-row">
            {item.status === 'published' && item.href ? (
              <a href={item.href}>{item.name}</a>
            ) : (
              <span class="item-name">{item.name}</span>
            )}
            <div class="item-right">
              <span class="item-searches">{item.searches}/mo</span>
              <span class={`badge ${item.status === 'published' ? 'badge-published' : 'badge-building'}`}>
                {item.status === 'published' ? '✓ Live' : '🔨 Building'}
              </span>
            </div>
          </div>
        ))}
      </div>
      {cat.total > 8 && (
        <div class="more-coming">+ {cat.total - 8} more {cat.title.toLowerCase()} coming soon</div>
      )}
    </div>
  ))}
</SiteLayout>
