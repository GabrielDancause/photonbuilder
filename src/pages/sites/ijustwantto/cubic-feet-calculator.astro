    .related-tools-card p { margin: 0; font-size: 0.95rem; color: var(--text-secondary); }
    .related-tools-card a { color: var(--accent-color); text-decoration: none; font-weight: 600; }
    .related-tools-card a:hover { text-decoration: underline; }

    .explainer { line-height: 1.7; font-size: 1.05rem; color: var(--text-primary); margin-bottom: 4rem; }
    .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; font-weight: 800; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    .explainer h3 { font-size: 1.4rem; margin: 1.8rem 0 0.8rem; font-weight: 700; }
    .explainer h4 { font-size: 1.2rem; margin: 1.5rem 0 0.5rem; font-weight: 600; }
    .explainer p { margin-bottom: 1.2rem; }
    .explainer ul, .explainer ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .explainer li { margin-bottom: 0.5rem; }
    .formula-box { background: var(--bg-color); border: 1px solid var(--border-color); border-left: 4px solid var(--accent-color); padding: 1rem 1.5rem; margin: 1.5rem 0; font-family: monospace; font-size: 1.1rem; font-weight: 600; border-radius: 0 8px 8px 0; }

    .faq-section { border-top: 2px solid var(--border-color); padding-top: 2rem; margin-top: 3rem; }
    .faq-section h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); overflow: hidden; }
    .faq-section summary { font-weight: 600; cursor: pointer; padding: 1.25rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .faq-section summary::-webkit-details-marker { display: none; }
    .faq-section summary::after { content: '+'; font-size: 1.5rem; color: var(--text-secondary); line-height: 1; transition: transform 0.2s; }
    .faq-section details[open] summary::after { content: '−'; transform: rotate(180deg); }
    .faq-content { padding: 0 1.25rem 1.25rem; color: var(--text-secondary); line-height: 1.6; border-top: 1px solid var(--border-color); margin-top: 0.5rem; padding-top: 1rem; }
    .faq-content p:last-child { margin-bottom: 0; }
  </style>
</SiteLayout>
