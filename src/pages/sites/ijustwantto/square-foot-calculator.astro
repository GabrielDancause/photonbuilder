    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .explainer li { margin-bottom: 0.5rem; }
    .formula-box { background: var(--card-bg); border-left: 4px solid var(--accent-color); padding: 1rem; margin: 1.5rem 0; border-radius: 0 8px 8px 0; font-size: 1.2rem; font-weight: 600; text-align: center; font-family: var(--font-mono); color: var(--accent-color); }

    .faq-section details { margin: 1rem 0; padding: 1rem 1.5rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); font-size: 1.1rem; }
    .faq-section details p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>

