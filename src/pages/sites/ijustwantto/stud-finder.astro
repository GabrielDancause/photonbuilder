<script is:inline>
// Wall anatomy interactive functionality
const wallElements = document.querySelectorAll('[data-info]');
const infoTitle = document.getElementById('info-title');
const infoText = document.getElementById('info-text');

const wallInfo = {
  drywall: {
    title: 'Drywall',
    text: 'Standard drywall is 1/2" or 5/8" thick gypsum board. This is what you see and paint on. Most stud finders work by detecting density changes behind this layer.'
  },
  stud: {
    title: '2x4 or 2x6 Stud',
    text: 'Wooden vertical supports, typically 16" or 24" on center. These provide the structural framework for the wall and are what you want to hit when hanging heavy items.'
  },
  wire: {
    title: 'Electrical Wire',
    text: 'Electrical cables run horizontally through holes drilled in studs, usually 12-16 inches from the floor. Always use wire detection when drilling into walls.'
  },
  pipe: {
    title: 'Plumbing Pipe',
    text: 'Water supply or waste pipes may run through walls, especially in bathrooms and kitchens. These can cause false positives on electronic stud finders.'
  },
  insulation: {
    title: 'Insulation',
    text: 'Fiberglass or foam insulation fills the cavity between studs for thermal and sound dampening. This hollow space is why walls sound different when you tap them.'
  },
  'bottom-plate': {
    title: 'Bottom Plate',
    text: 'Horizontal 2x4 that all studs are attached to. This sits on top of the floor joists and foundation, providing the base for the wall frame.'
  }
};

wallElements.forEach(element => {
  element.addEventListener('click', () => {
    const info = wallInfo[element.dataset.info];
    if (info) {
      infoTitle.textContent = info.title;
      infoText.textContent = info.text;
    }
  });
});

// Stud spacing calculator
function calculateStuds() {
  const wallWidth = parseInt(document.getElementById('wall-width').value) || 8;
  const studSpacing = parseInt(document.getElementById('stud-spacing').value) || 16;
  const startOffset = parseFloat(document.getElementById('start-offset').value) || 0;
  
  const wallWidthInches = wallWidth * 12;
  const studs = [];
  
  // Calculate stud positions
  let position = startOffset;
  while (position <= wallWidthInches) {
    studs.push(position);
    position += studSpacing;
  }
  
  // Visual representation
  const visual = document.getElementById('stud-visual');
  visual.innerHTML = '';
  
  const scale = Math.min(600, visual.clientWidth - 40) / wallWidthInches;
  
  studs.forEach(pos => {
    const studElement = document.createElement('div');
    studElement.style.position = 'absolute';
    studElement.style.left = pos * scale + 'px';
    studElement.style.top = '10px';
    studElement.style.width = '6px';
    studElement.style.height = '60px';
    studElement.style.background = '#2DB89A';
    studElement.style.borderRadius = '3px';
    studElement.title = `Stud at ${pos}"`;
    visual.appendChild(studElement);
  });
  
  // Text list
  const list = document.getElementById('stud-list');
  list.innerHTML = `
    <strong>Wall: ${wallWidth}' (${wallWidthInches}")</strong><br>
    <strong>Spacing: ${studSpacing}" OC</strong><br>
    <strong>Total studs: ${studs.length}</strong><br><br>
    <strong>Stud locations from left edge:</strong><br>
    ${studs.map(pos => `${pos}"`).join(', ')}
  `;
}

// Add event listeners for calculator inputs
document.getElementById('wall-width').addEventListener('input', calculateStuds);
document.getElementById('stud-spacing').addEventListener('change', calculateStuds);
document.getElementById('start-offset').addEventListener('input', calculateStuds);

// Initialize calculator
calculateStuds();
</script>
</SiteLayout>