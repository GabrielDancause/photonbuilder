  .table-header > div {
    padding: 1rem;
    background: #0a1020;
    border-radius: 6px;
    text-align: center;
  }

  .table-row {
    display: contents;
  }

  .table-row > div {
    padding: 1rem;
    border: 1px solid #2DB89A;
    border-radius: 6px;
    background: #0a1020;
  }

  /* Problem Cards */
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .problem-card {
    background: #152040;
    border-left: 4px solid #FF6B6B;
    border-radius: 0 8px 8px 0;
    padding: 1.5rem;
  }

  .problem-card h3 {
    color: #FF6B6B;
    margin-bottom: 1rem;
  }

  /* Building Types */
  .spacing-table {
    background: #152040;
    border-radius: 8px;
    overflow: hidden;
  }

  .spacing-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    border-bottom: 1px solid #2DB89A;
  }

  .spacing-row:last-child {
    border-bottom: none;
  }

  .building-type {
    background: #0a1020;
    padding: 1rem 1.5rem;
    font-weight: 600;
    color: #2DB89A;
  }

  .spacing-info {
    padding: 1rem 1.5rem;
  }

  /* Anchor Cards */
  .anchor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

