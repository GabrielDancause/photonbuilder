          <h3 class="text-base font-bold text-white">Electricity Cost Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Budget for utility costs at your new home →</p>
        </a>
        <a href="/tile-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Tile Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Plan your renovation flooring project →</p>
        </a>
      </div>
    </div>
