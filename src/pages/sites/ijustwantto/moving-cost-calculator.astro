        <a href="/tile-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Tile Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Calculate tile needed for your new home renovations →</p>
        </a>
      </div>
    </div>
  </div>
