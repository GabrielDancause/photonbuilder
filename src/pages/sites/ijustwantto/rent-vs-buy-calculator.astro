      <div class="grid gap-3">
        <a href="/electricity-cost-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Electricity Cost Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Estimate your monthly electricity costs by appliance →</p>
        </a>
      </div>
    </div>
  </div>
