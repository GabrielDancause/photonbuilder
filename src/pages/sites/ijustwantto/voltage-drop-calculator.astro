    }

    .tip-item { padding: 0.75rem 0; border-bottom: 1px solid var(--border-color); }
    .tip-item:last-child { border-bottom: none; }
    .tip-item strong { color: var(--text-primary); }
    .tip-item p { color: var(--text-secondary); font-size: 0.875rem; margin-top: 0.25rem; }

    @media (min-width: 640px) {
