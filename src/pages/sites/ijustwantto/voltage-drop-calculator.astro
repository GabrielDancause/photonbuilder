---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Voltage Drop Calculator",
      "url": "https://ijustwantto.live/voltage-drop-calculator",
      "description": "Calculate voltage drop in electrical wiring for home projects. Enter voltage, current, wire gauge, distance, and conductor material to check NEC compliance and get wire size recommendations.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an acceptable voltage drop for residential wiring?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The NEC (National Electrical Code) recommends no more than 3% voltage drop for branch circuits and no more than 5% total voltage drop from the service entrance to the farthest outlet. For a 120V circuit, 3% equals 3.6V, so the voltage at the outlet should be at least 116.4V."
          }
        },
        {
          "@type": "Question",
          "name": "How do I calculate voltage drop in a wire?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Voltage drop is calculated using the formula: VD = (2 × L × R × I) / 1000, where L is the one-way length in feet, R is the wire resistance in ohms per 1,000 feet, and I is the current in amps. The factor of 2 accounts for the round-trip distance of current flow through hot and neutral conductors."
          }
        },
        {
          "@type": "Question",
          "name": "Does wire length affect voltage drop?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, voltage drop increases proportionally with wire length. This is why long wire runs — such as detached garages, outdoor lighting, well pumps, and EV chargers — often require upsizing the wire gauge to keep voltage drop within acceptable limits."
          }
        },
        {
          "@type": "Question",
          "name": "Is copper or aluminum wire better for reducing voltage drop?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Copper has lower resistance than aluminum (about 61% less for the same gauge), resulting in less voltage drop. However, aluminum is lighter and cheaper. For equivalent performance, you typically need to go up two wire sizes when using aluminum instead of copper (e.g., use 2 AWG aluminum instead of 4 AWG copper)."
          }
        },
        {
          "@type": "Question",
          "name": "What happens if voltage drop is too high?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Excessive voltage drop causes lights to dim, motors to run hot and inefficiently, sensitive electronics to malfunction, and heaters to produce less heat. Motors are especially vulnerable — low voltage forces them to draw more current, which can overheat windings and shorten their lifespan significantly."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Voltage Drop Calculator — Wire Size & NEC Compliance",
  description: "Calculate voltage drop in electrical wiring for home projects. Enter voltage, current, wire gauge, and distance to check NEC compliance and get wire size recommendations.",
  category: "tool",
  published: "2026-03-21",
};
---

