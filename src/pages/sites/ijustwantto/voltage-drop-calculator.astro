        <a href="/electricity-cost-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Electricity Cost Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Calculate the cost to run any appliance →</p>
        </a>
        <a href="/btu-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">BTU Calculator</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Size your AC or heater for any room →</p>
        </a>
      </div>
    </div>
  </div>
