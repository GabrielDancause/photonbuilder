      width: 100%; border-collapse: collapse; font-size: 0.8rem;
    }
    table.wire-table th {
      text-align: left; padding: 0.6rem 0.75rem; border-bottom: 2px solid var(--border-color);
      color: var(--text-secondary); font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
