import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Bundling Insurance Guide: When to Combine Auto & Home Savings",
    "description": "Learn the pros and cons of bundling home and auto insurance, how much you can actually save, and when it makes financial sense NOT to bundle.",
    "author": {
      "@type": "Organization",
      "name": "I Just Want To"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does bundling home and auto insurance save?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "On average, bundling your home and auto insurance can save you between 10% and 25% on your total combined premiums, depending on the insurance provider and your specific risk profile."
        }
      },
      {
        "@type": "Question",
        "name": "Is it always cheaper to bundle insurance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, it is not always cheaper. If you have a poor driving record, a specialized home, or live in a high-risk area, finding the cheapest individual policies from separate companies might yield a lower total cost than a bundled discount from one provider."
        }
      },
      {
        "@type": "Question",
        "name": "Can I unbundle my insurance policies later?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, you can cancel or switch policies at any time. If you drop one policy (like auto) and keep the other (like home) with the same company, you will simply lose the multi-policy discount on the remaining policy."
