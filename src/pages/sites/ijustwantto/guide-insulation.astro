---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Home Insulation Guide - Types & R-Values",
    "description": "A comprehensive reference guide for home insulation. Compare fiberglass, spray foam, cellulose, and mineral wool. Find recommended R-values for your climate zone.",
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    },
    "publisher": {
      "@type": "Organization",
      "name": "ijustwantto.live",
      "logo": {
        "@type": "ImageObject",
        "url": "https://ijustwantto.live/favicon.ico"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://ijustwantto.live/guide-insulation"
    }
  }
];
