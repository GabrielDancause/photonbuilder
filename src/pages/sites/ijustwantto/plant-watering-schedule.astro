---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Plant Watering Schedule",
      "url": "https://ijustwantto.live/plant-watering-schedule",
      "description": "Create personalized watering schedules for your houseplants. Add plants from a database of 40+ common houseplants, customize location and pot size, and get a weekly calendar showing which plants need water today.",
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How often should I water my houseplants?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Watering frequency depends on the plant species, pot size, light exposure, humidity, and season. Most tropical houseplants like pothos and philodendrons need water every 7-10 days. Succulents and cacti need water every 14-21 days. During winter, most plants need less frequent watering because growth slows down."
          }
        },
        {
          "@type": "Question",
          "name": "How do I know if I'm overwatering my plants?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Signs of overwatering include yellowing leaves, mushy stems, mold on the soil surface, fungus gnats, and a sour smell from the soil. The soil may stay wet for extended periods. To avoid overwatering, always check if the top inch of soil is dry before watering, and ensure your pots have drainage holes."
          }
        },
        {
          "@type": "Question",
          "name": "Should I water my plants more in summer or winter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most houseplants need more frequent watering in spring and summer when they are actively growing and temperatures are higher. In fall and winter, growth slows and evaporation decreases, so you should reduce watering frequency by about 25-50%. This schedule tool automatically adjusts for seasonal changes."
          }
        },
        {
          "@type": "Question",
          "name": "Does pot size affect how often I should water?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, pot size significantly affects watering frequency. Smaller pots (4 inches or less) dry out faster and may need watering twice as often as larger pots. Large pots (10+ inches) retain moisture longer and need less frequent watering. The material also matters — terracotta dries faster than plastic or ceramic."
          }
        },
        {
          "@type": "Question",
          "name": "What is the best time of day to water houseplants?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The best time to water houseplants is in the morning. This allows excess moisture to evaporate during the day, reducing the risk of fungal diseases and root rot. Avoid watering at night when cooler temperatures and lower light levels keep soil wet longer. If morning isn't possible, early afternoon is the next best option."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Plant Watering Schedule — Houseplant Care Calendar & Reminders",
  description: "Create personalized watering schedules for 40+ houseplants. Track last watered dates, get daily reminders, and view a weekly calendar tailored to your plants' needs.",
  category: "tool",
  published: "2026-03-21",
};
