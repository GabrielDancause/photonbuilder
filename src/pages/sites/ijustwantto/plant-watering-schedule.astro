      { n:"String of Hearts",d:10,c:"vine",light:"bright",hum:"low" },
      { n:"Hoya",d:10,c:"vine",light:"medium-bright",hum:"average" },
      { n:"Tradescantia",d:5,c:"vine",light:"medium-bright",hum:"average" },
      { n:"Croton",d:5,c:"tropical",light:"bright",hum:"high" },
      { n:"Dieffenbachia",d:7,c:"tropical",light:"medium",hum:"average" },
      { n:"Anthurium",d:7,c:"tropical",light:"medium-bright",hum:"high" },
      { n:"Orchid (Phalaenopsis)",d:10,c:"flowering",light:"medium-bright",hum:"high" },
      { n:"African Violet",d:5,c:"flowering",light:"medium",hum:"average" },
      { n:"Begonia",d:5,c:"flowering",light:"medium-bright",hum:"high" },
      { n:"Cyclamen",d:7,c:"flowering",light:"medium",hum:"average" },
      { n:"Cast Iron Plant",d:14,c:"tropical",light:"low",hum:"low" },
      { n:"Ponytail Palm",d:14,c:"succulent",light:"bright",hum:"low" },
      { n:"Yucca",d:10,c:"succulent",light:"bright",hum:"low" },
      { n:"Norfolk Island Pine",d:7,c:"tropical",light:"medium-bright",hum:"average" },
      { n:"Swiss Cheese Plant",d:7,c:"tropical",light:"medium-bright",hum:"high" },
      { n:"Wandering Jew",d:5,c:"vine",light:"medium-bright",hum:"average" }
    ];

    var CATS = { all:"All", tropical:"Tropical", succulent:"Succulent", cactus:"Cactus", fern:"Fern", palm:"Palm", vine:"Vine", flowering:"Flowering" };
    var activeCat = "all";
    var myPlants = [];
    var calWeekOffset = 0;

    // Load from localStorage
    try {
      var saved = localStorage.getItem("pw_plants");
      if (saved) myPlants = JSON.parse(saved);
    } catch(e) {}

    // Auto-detect season
    var month = new Date().getMonth();
    var autoSeason = month >= 2 && month <= 4 ? "spring" : month >= 5 && month <= 7 ? "summer" : month >= 8 && month <= 10 ? "fall" : "winter";
    document.getElementById("season").value = autoSeason;

    // Category tabs
    var tabsEl = document.getElementById("catTabs");
    Object.keys(CATS).forEach(function(key) {
      var b = document.createElement("button");
      b.type = "button";
      b.className = "cat-tab" + (key === "all" ? " active" : "");
      b.textContent = CATS[key];
      b.addEventListener("click", function() {
        activeCat = key;
        tabsEl.querySelectorAll(".cat-tab").forEach(function(t){ t.classList.remove("active"); });
        b.classList.add("active");
        renderGrid();
      });
      tabsEl.appendChild(b);
    });

    function renderGrid() {
      var g = document.getElementById("plantGrid");
      g.innerHTML = "";
      var list = activeCat === "all" ? DB : DB.filter(function(a){ return a.c === activeCat; });
      list.forEach(function(p) {
        var b = document.createElement("button");
        b.type = "button";
        b.className = "plant-btn";
        b.innerHTML = '<span>' + p.n + '</span><span class="freq">' + p.d + 'd</span>';
        b.addEventListener("click", function() {
          document.getElementById("plantName").value = p.n;
          document.getElementById("waterDays").value = p.d;
        });
        g.appendChild(b);
      });
    }
    renderGrid();

    // Adjust watering days based on factors
    function adjustDays(base, location, potSize, season) {
      var d = base;
      // Location adjustment
      if (location === "window") d *= 0.85;
      else if (location === "shelf") d *= 1.2;
      else if (location === "bathroom") d *= 1.3;
      else if (location === "outdoor") d *= 0.7;
      // Pot size adjustment
      if (potSize === "small") d *= 0.7;
      else if (potSize === "large") d *= 1.25;
      else if (potSize === "xlarge") d *= 1.5;
      // Season adjustment
      if (season === "summer") d *= 0.8;
      else if (season === "winter") d *= 1.4;
      else if (season === "fall") d *= 1.15;
      return Math.max(1, Math.round(d));
    }

    function save() {
      try { localStorage.setItem("pw_plants", JSON.stringify(myPlants)); } catch(e) {}
    }

    function daysBetween(d1, d2) {
      return Math.floor((d2 - d1) / (1000 * 60 * 60 * 24));
    }

    function todayStr() {
      var d = new Date();
      return d.getFullYear() + "-" + String(d.getMonth()+1).padStart(2,"0") + "-" + String(d.getDate()).padStart(2,"0");
    }

    function dateStr(d) {
      return d.getFullYear() + "-" + String(d.getMonth()+1).padStart(2,"0") + "-" + String(d.getDate()).padStart(2,"0");
    }

    // Add plant
    document.getElementById("addForm").addEventListener("submit", function(e) {
      e.preventDefault();
      var name = document.getElementById("plantName").value.trim();
      var days = parseInt(document.getElementById("waterDays").value);
      var loc = document.getElementById("location").value;
      var pot = document.getElementById("potSize").value;
      var szn = document.getElementById("season").value;
      if (!name || isNaN(days)) return;
      var adjusted = adjustDays(days, loc, pot, szn);
      myPlants.push({
        id: Date.now(),
        name: name,
        baseDays: days,
        adjustedDays: adjusted,
        location: loc,
        potSize: pot,
        season: szn,
        lastWatered: todayStr(),
        added: todayStr()
      });
      save();
      renderAll();
      document.getElementById("plantName").value = "";
      document.getElementById("waterDays").value = "7";
    });

    function getStatus(plant) {
      var last = new Date(plant.lastWatered + "T00:00:00");
      var now = new Date();
      now.setHours(0,0,0,0);
      var elapsed = daysBetween(last, now);
      var remaining = plant.adjustedDays - elapsed;
      if (remaining < 0) return { text: Math.abs(remaining) + "d overdue", cls: "status-overdue", needsWater: true, overdue: true };
      if (remaining === 0) return { text: "Water today!", cls: "status-soon", needsWater: true, overdue: false };
      if (remaining <= 1) return { text: "Tomorrow", cls: "status-soon", needsWater: false, overdue: false };
      return { text: "In " + remaining + "d", cls: "status-ok", needsWater: false, overdue: false };
    }

    function waterPlant(id) {
      myPlants.forEach(function(p) { if (p.id === id) p.lastWatered = todayStr(); });
      save();
      renderAll();
    }

    function removePlant(id) {
      myPlants = myPlants.filter(function(p) { return p.id !== id; });
      save();
      renderAll();
    }

    function renderMyPlants() {
      var el = document.getElementById("myPlants");
      if (!myPlants.length) {
        el.innerHTML = '<div class="empty-state">No plants added yet. Use the form above to add your first plant.</div>';
        return;
      }
      el.innerHTML = "";
      myPlants.forEach(function(plant) {
        var s = getStatus(plant);
        var locLabel = { window:"Window", desk:"Desk", shelf:"Shelf", bathroom:"Bathroom", outdoor:"Outdoor" }[plant.location] || plant.location;
        var potLabel = { small:"Small pot", medium:"Medium pot", large:"Large pot", xlarge:"XL pot" }[plant.potSize] || plant.potSize;
        var row = document.createElement("div");
        row.className = "plant-list-item";
        row.innerHTML = '<div class="info"><span class="name">' + plant.name + '</span><span class="detail"> · ' + locLabel + ' · ' + potLabel + ' · Every ' + plant.adjustedDays + 'd</span></div>' +
          '<span class="status ' + s.cls + '">' + s.text + '</span>' +
          '<div class="plant-actions">' +
          '<button class="action-btn water-btn" data-id="' + plant.id + '" title="Mark as watered">&#128167;</button>' +
          '<button class="action-btn remove-btn" data-id="' + plant.id + '" title="Remove plant">&times;</button>' +
          '</div>';
        el.appendChild(row);
      });
      el.querySelectorAll(".water-btn").forEach(function(b) {
        b.addEventListener("click", function() { waterPlant(parseInt(this.dataset.id)); });
      });
      el.querySelectorAll(".remove-btn").forEach(function(b) {
        b.addEventListener("click", function() { removePlant(parseInt(this.dataset.id)); });
      });
    }

    function renderToday() {
      var list = document.getElementById("todayList");
      var todayPlants = myPlants.filter(function(p) { var s = getStatus(p); return s.needsWater; });
      if (!myPlants.length) {
        list.innerHTML = '<div class="no-tasks">Add plants below to see your daily watering tasks.</div>';
        return;
      }
      if (!todayPlants.length) {
        list.innerHTML = '<div class="no-tasks">All plants are happy! No watering needed today.</div>';
        return;
      }
      list.innerHTML = "";
      todayPlants.forEach(function(p) {
        var s = getStatus(p);
        var row = document.createElement("div");
        row.className = "today-item";
        row.innerHTML = '<span class="tname">' + p.name + (s.overdue ? ' <span style="color:#f87171;font-size:0.75rem;">(' + s.text + ')</span>' : '') + '</span>' +
          '<button class="tbtn" data-id="' + p.id + '">Mark Watered</button>';
        list.appendChild(row);
      });
      list.querySelectorAll(".tbtn").forEach(function(b) {
        b.addEventListener("click", function() {
          waterPlant(parseInt(this.dataset.id));
        });
      });
    }

    function renderStats() {
      var total = myPlants.length;
      var todayCount = 0;
      var overdueCount = 0;
      var healthyCount = 0;
      myPlants.forEach(function(p) {
        var s = getStatus(p);
        if (s.overdue) overdueCount++;
        else if (s.needsWater) todayCount++;
        else healthyCount++;
      });
      document.getElementById("statTotal").textContent = total;
      document.getElementById("statToday").textContent = todayCount + overdueCount;
      document.getElementById("statOverdue").textContent = overdueCount;
      document.getElementById("statHealthy").textContent = healthyCount;
    }

    function renderCalendar() {
      var grid = document.getElementById("calGrid");
      grid.innerHTML = "";
      var days = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];
      days.forEach(function(d) {
        var hdr = document.createElement("div");
        hdr.className = "cal-header";
        hdr.textContent = d;
        grid.appendChild(hdr);
      });

      // Get Monday of current week + offset
      var now = new Date();
      now.setHours(0,0,0,0);
      var dayOfWeek = now.getDay();
      var monday = new Date(now);
      monday.setDate(now.getDate() - ((dayOfWeek + 6) % 7) + (calWeekOffset * 7));

      var todayS = todayStr();
      var monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
      var startMonth = monthNames[monday.getMonth()];
      var endDate = new Date(monday);
      endDate.setDate(monday.getDate() + 6);
      var endMonth = monthNames[endDate.getMonth()];
      var title = startMonth === endMonth
        ? startMonth + " " + monday.getDate() + " - " + endDate.getDate() + ", " + monday.getFullYear()
        : startMonth + " " + monday.getDate() + " - " + endMonth + " " + endDate.getDate() + ", " + monday.getFullYear();
      document.getElementById("calTitle").textContent = title;

      for (var i = 0; i < 7; i++) {
        var cellDate = new Date(monday);
        cellDate.setDate(monday.getDate() + i);
        var cellStr = dateStr(cellDate);
        var cell = document.createElement("div");
        cell.className = "cal-day" + (cellStr === todayS ? " today" : "");
        var numDiv = '<div class="day-num">' + cellDate.getDate() + '</div>';
        var tags = "";
        myPlants.forEach(function(p) {
          var last = new Date(p.lastWatered + "T00:00:00");
          var diffFromLast = daysBetween(last, cellDate);
          if (diffFromLast >= 0 && diffFromLast % p.adjustedDays === 0 && diffFromLast > 0) {
            var isOverdue = cellDate < new Date(todayS + "T00:00:00");
            tags += '<span class="cal-plant-tag' + (isOverdue ? ' overdue' : '') + '">' + p.name + '</span>';
          }
          // Show today if it's the water day
          if (cellStr === p.lastWatered && diffFromLast === 0) {
            // Don't show on last watered day
          }
        });
        cell.innerHTML = numDiv + tags;
        grid.appendChild(cell);
      }
    }

    document.getElementById("calPrev").addEventListener("click", function() { calWeekOffset--; renderCalendar(); });
    document.getElementById("calNext").addEventListener("click", function() { calWeekOffset++; renderCalendar(); });

    function renderAll() {
      renderMyPlants();
      renderToday();
      renderStats();
      renderCalendar();
    }

    renderAll();
  </script>

  <!-- Related Tools Link -->
  <div class="max-w-3xl mx-auto px-5 pt-8 pb-12">
    <div class="border-t border-[var(--border-color)] pt-8">
      <p class="text-xs font-bold text-[var(--accent-color)] tracking-wide uppercase mb-2">Related Tools</p>
      <div class="grid gap-3">
        <a href="/sourdough-timer" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
          <h3 class="text-base font-bold text-white">Sourdough Timer</h3>
          <p class="text-sm text-[var(--text-secondary)] mt-1">Track your sourdough baking schedule step by step &rarr;</p>
        </a>
      </div>
    </div>
  </div>
</SiteLayout>
