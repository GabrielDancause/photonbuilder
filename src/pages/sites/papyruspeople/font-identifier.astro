---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Font Identifier — Free Online Tool',
  description: 'Identify fonts by answering questions about their visual characteristics. Interactive font finder questionnaire matches serif, sans-serif, rounded, geometric, and more styles from 50+ popular fonts with live previews.',
  category: 'tool',
  published: '2026-03-24'
};

const SITE_ID = 'papyruspeople';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "What Font Is This? — Font Identifier",
    "url": "https://papyruspeople.photonbuilder.com/font-identifier",
    "description": "Identify fonts by their visual characteristics. Answer questions about serif style, stroke weight, x-height, and more to find matching fonts from a database of 50+ popular typefaces.",
    "applicationCategory": "DesignApplication",
    "operatingSystem": "All"
  },
