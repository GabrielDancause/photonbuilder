          options: [
            { label: 'Low — strokes are uniform thickness', value: 'low', desc: 'Minimal variation between thick and thin parts' },
            { label: 'Medium — some variation', value: 'medium', desc: 'Noticeable but subtle thickness changes' },
            { label: 'High — dramatic thick/thin difference', value: 'high', desc: 'Very visible contrast, like in Didot or Playfair' },
            { label: 'Not sure', value: 'any', desc: 'Skip this question' }
          ],
          filter: (font, val) => val === 'any' || font.contrast === val
        },
        {
          id: 'weight',
          text: 'How heavy/thick are the letter strokes overall?',
          options: [
            { label: 'Thin / light', value: 'thin', desc: 'Delicate, airy strokes' },
            { label: 'Medium / regular', value: 'medium', desc: 'Standard weight, not particularly thin or thick' },
            { label: 'Thick / bold', value: 'thick', desc: 'Heavy, commanding strokes' },
            { label: 'Not sure', value: 'any', desc: 'Skip this question' }
          ],
          filter: (font, val) => val === 'any' || font.weight === val
        },
        {
          id: 'mood',
          text: 'What mood or feeling does the font convey?',
          options: [
            { label: 'Neutral / professional', value: 'neutral', desc: 'Clean, no particular personality' },
            { label: 'Modern / tech-forward', value: 'modern', desc: 'Contemporary, digital feel' },
            { label: 'Elegant / sophisticated', value: 'elegant', desc: 'Refined, stylish, upscale' },
            { label: 'Friendly / approachable', value: 'friendly', desc: 'Warm, inviting, casual' },
            { label: 'Traditional / classic', value: 'traditional', desc: 'Timeless, bookish, authoritative' },
            { label: 'Bold / impactful', value: 'bold', desc: 'Strong, attention-grabbing' },
            { label: 'Fun / playful', value: 'fun', desc: 'Whimsical, casual, youthful' },
            { label: 'Not sure', value: 'any', desc: 'Skip this question' }
          ],
          filter: (font, val) => {
            if (val === 'any') return true;
            if (val === 'neutral') return font.mood === 'neutral' || font.mood === 'warm';
            return font.mood === val;
          }
        }
      ];

      // ── State ──
      let currentStep = 0;
      let answers = {};
      const loadedFonts = new Set();

      // ── DOM refs ──
      const questionContainer = document.getElementById('question-container');
      const progressFill = document.getElementById('progress-fill');
      const progressText = document.getElementById('progress-text');
      const btnBack = document.getElementById('btn-back');
      const btnReset = document.getElementById('btn-reset');
      const resultsArea = document.getElementById('results-area');
      const questionnaire = document.getElementById('questionnaire');
      const resultsList = document.getElementById('results-list');
      const resultsTitle = document.getElementById('results-title');
      const btnNewSearch = document.getElementById('btn-new-search');
      const previewTextInput = document.getElementById('preview-text-input');
      const previewSize = document.getElementById('preview-size');
      const previewSizeVal = document.getElementById('preview-size-val');
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabPanels = document.querySelectorAll('.tab-panel');

      // ── Helpers ──
      function loadGoogleFont(googleName) {
        if (loadedFonts.has(googleName)) return;
        loadedFonts.add(googleName);
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://fonts.googleapis.com/css2?family=' + googleName + ':wght@400;700&display=swap';
        document.head.appendChild(link);
      }

      function getActiveQuestions() {
        return QUESTIONS.filter(q => !q.showIf || q.showIf(answers));
      }

      function getMatchingFonts() {
        let matches = [...FONTS];
        const activeQs = getActiveQuestions();
        for (const q of activeQs) {
          if (answers[q.id] !== undefined) {
            matches = matches.filter(f => q.filter(f, answers[q.id]));
          }
        }
        return matches;
      }

      // ── Render question ──
      function renderQuestion() {
        const activeQs = getActiveQuestions();
        if (currentStep >= activeQs.length) {
          showResults();
          return;
        }

        const q = activeQs[currentStep];
        const total = activeQs.length;
        progressFill.style.width = ((currentStep + 1) / total * 100) + '%';
        progressText.textContent = 'Question ' + (currentStep + 1) + ' of ' + total;
        btnBack.disabled = currentStep === 0;

        let html = '<h3 class="question-text">' + q.text + '</h3>';
        html += '<div class="options-grid">';
        for (const opt of q.options) {
          const selected = answers[q.id] === opt.value ? ' selected' : '';
          html += '<button class="option-btn' + selected + '" data-qid="' + q.id + '" data-value="' + opt.value + '">';
          html += '<span class="option-label">' + opt.label + '</span>';
          html += '<span class="option-desc">' + opt.desc + '</span>';
          html += '</button>';
        }
        html += '</div>';

        // Show live match count
        const tempAnswers = { ...answers };
        const matchCounts = q.options.map(opt => {
          tempAnswers[q.id] = opt.value;
          let m = [...FONTS];
          for (const aq of activeQs) {
            if (tempAnswers[aq.id] !== undefined) {
              m = m.filter(f => aq.filter(f, tempAnswers[aq.id]));
            }
          }
          return m.length;
        });

        questionContainer.innerHTML = html;

        // Add match counts
        const optBtns = questionContainer.querySelectorAll('.option-btn');
        optBtns.forEach((btn, i) => {
          const badge = document.createElement('span');
          badge.className = 'match-badge';
          badge.textContent = matchCounts[i] + ' match' + (matchCounts[i] !== 1 ? 'es' : '');
          btn.appendChild(badge);

          btn.addEventListener('click', () => {
            const qid = btn.getAttribute('data-qid');
            const val = btn.getAttribute('data-value');
            answers[qid] = val;
            currentStep++;
            renderQuestion();
          });
        });
      }

      // ── Show results ──
      function showResults() {
        questionnaire.classList.add('hidden');
        resultsArea.classList.remove('hidden');

        const matches = getMatchingFonts();

        // If no exact matches, show all with scoring
        let displayFonts;
        if (matches.length === 0) {
          displayFonts = scoreFonts();
          resultsTitle.textContent = 'Closest Matches (' + displayFonts.length + ' fonts)';
        } else {
          displayFonts = matches.map(f => ({ font: f, score: 100 }));
          resultsTitle.textContent = matches.length + ' Matching Font' + (matches.length !== 1 ? 's' : '');
        }

        renderResults(displayFonts);
      }

      function scoreFonts() {
        const activeQs = getActiveQuestions();
        return FONTS.map(font => {
          let score = 0;
          let total = 0;
          for (const q of activeQs) {
            if (answers[q.id] !== undefined && answers[q.id] !== 'any') {
              total++;
              if (q.filter(font, answers[q.id])) score++;
            }
          }
          return { font, score: total > 0 ? Math.round(score / total * 100) : 50 };
        }).filter(r => r.score > 0).sort((a, b) => b.score - a.score).slice(0, 15);
      }

      function renderResults(displayFonts) {
        const previewText = previewTextInput.value || 'The quick brown fox jumps over the lazy dog';
        const size = previewSize.value;

        let html = '';
        for (const { font, score } of displayFonts) {
          loadGoogleFont(font.google);
          const tags = [font.category, font.style, font.mood].filter(Boolean);
          html += '<div class="result-card">';
          html += '<div class="result-header">';
          html += '<div class="result-name">' + font.name;
          if (score < 100) html += ' <span class="result-score">' + score + '% match</span>';
          html += '</div>';
          html += '<div class="result-tags">' + tags.map(t => '<span class="tag">' + t + '</span>').join('') + '</div>';
          html += '</div>';
          html += '<div class="result-preview" style="font-family:\'' + font.name + '\',sans-serif;font-size:' + size + 'px">' + previewText + '</div>';
          html += '</div>';
        }

        if (displayFonts.length === 0) {
          html = '<div class="no-results"><p>No fonts matched your criteria. Try starting over with different answers.</p></div>';
        }

        resultsList.innerHTML = html;
      }

      // ── Events: Identify tab ──
      btnBack.addEventListener('click', () => {
        if (currentStep > 0) {
          const activeQs = getActiveQuestions();
          const prevQ = activeQs[currentStep - 1];
          if (prevQ) delete answers[prevQ.id];
          currentStep--;
          renderQuestion();
        }
      });

      btnReset.addEventListener('click', resetQuiz);
      btnNewSearch.addEventListener('click', resetQuiz);

      function resetQuiz() {
        currentStep = 0;
        answers = {};
        questionnaire.classList.remove('hidden');
        resultsArea.classList.add('hidden');
        renderQuestion();
      }

      previewTextInput.addEventListener('input', () => {
        const matches = getMatchingFonts();
        const displayFonts = matches.length > 0 ? matches.map(f => ({ font: f, score: 100 })) : scoreFonts();
        renderResults(displayFonts);
      });

      previewSize.addEventListener('input', () => {
        previewSizeVal.textContent = previewSize.value + 'px';
        const matches = getMatchingFonts();
        const displayFonts = matches.length > 0 ? matches.map(f => ({ font: f, score: 100 })) : scoreFonts();
        renderResults(displayFonts);
      });

      // ── Tabs ──
      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const tab = btn.getAttribute('data-tab');
          tabBtns.forEach(b => b.classList.remove('active'));
          tabPanels.forEach(p => p.classList.remove('active'));
          btn.classList.add('active');
          document.getElementById('tab-' + tab).classList.add('active');
        });
      });

      // ── Compare tab ──
      const compareText = document.getElementById('compare-text');
      const compareSize = document.getElementById('compare-size');
      const compareSizeVal = document.getElementById('compare-size-val');
      const compareSelects = [
        document.getElementById('compare-font-1'),
        document.getElementById('compare-font-2'),
        document.getElementById('compare-font-3')
      ];
      const comparePreviews = [
        document.getElementById('compare-preview-1'),
        document.getElementById('compare-preview-2'),
        document.getElementById('compare-preview-3')
      ];

      // Populate compare selects
      const sortedFonts = [...FONTS].sort((a, b) => a.name.localeCompare(b.name));
      const defaults = ['Inter', 'Roboto', 'Merriweather'];
      compareSelects.forEach((sel, idx) => {
        sel.innerHTML = sortedFonts.map(f =>
          '<option value="' + f.name + '"' + (f.name === defaults[idx] ? ' selected' : '') + '>' + f.name + '</option>'
        ).join('');
      });

      function updateCompare() {
        const text = compareText.value || 'The quick brown fox jumps over the lazy dog';
        const size = compareSize.value;
        compareSizeVal.textContent = size + 'px';

        compareSelects.forEach((sel, idx) => {
          const fontName = sel.value;
          const font = FONTS.find(f => f.name === fontName);
          if (font) loadGoogleFont(font.google);
          comparePreviews[idx].style.fontFamily = "'" + fontName + "', sans-serif";
          comparePreviews[idx].style.fontSize = size + 'px';
          comparePreviews[idx].textContent = text;
        });
      }

      compareText.addEventListener('input', updateCompare);
      compareSize.addEventListener('input', updateCompare);
      compareSelects.forEach(sel => sel.addEventListener('change', updateCompare));

      // ── Init ──
      renderQuestion();
      updateCompare();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; margin-bottom: 2.5rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color, #2a2418); border-radius: 12px; padding: 2rem; }

    .tabs-row { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color, #2a2418); padding-bottom: 0.75rem; }
    .tab-btn { background: none; border: none; padding: 0.5rem 1.25rem; border-radius: 8px 8px 0 0; color: var(--text-secondary); font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s; border-bottom: 2px solid transparent; }
    .tab-btn.active { color: var(--accent-color, #D4A574); border-bottom-color: var(--accent-color, #D4A574); }
    .tab-btn:hover { color: var(--text-primary); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .question-progress { margin-bottom: 1.5rem; }
    .progress-bar { height: 6px; background: var(--border-color, #2a2418); border-radius: 3px; overflow: hidden; margin-bottom: 0.5rem; }
    .progress-fill { height: 100%; background: var(--accent-color, #D4A574); border-radius: 3px; transition: width 0.3s ease; }
    #progress-text { font-size: 0.8rem; color: var(--text-secondary); }

    .question-text { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.25rem; }

    .options-grid { display: flex; flex-direction: column; gap: 0.6rem; }
    .option-btn { display: flex; flex-wrap: wrap; align-items: center; gap: 0.25rem 0.75rem; width: 100%; text-align: left; padding: 0.9rem 1rem; border-radius: 8px; border: 1px solid var(--border-color, #2a2418); background: var(--bg-color, #0a0806); color: var(--text-primary); cursor: pointer; transition: all 0.2s; font-size: 0.95rem; }
    .option-btn:hover { border-color: var(--accent-color, #D4A574); }
    .option-btn.selected { border-color: var(--accent-color, #D4A574); background: rgba(212,165,116,0.08); }
    .option-label { font-weight: 600; }
    .option-desc { font-size: 0.82rem; color: var(--text-secondary); }
    .match-badge { margin-left: auto; font-size: 0.75rem; color: var(--text-secondary); background: var(--border-color, #2a2418); padding: 0.15rem 0.5rem; border-radius: 10px; white-space: nowrap; }

    .question-nav { display: flex; gap: 0.75rem; margin-top: 1.5rem; }
    .btn-primary, .btn-secondary { padding: 0.65rem 1.5rem; border-radius: 8px; font-size: 0.95rem; font-weight: 600; cursor: pointer; border: 1px solid transparent; transition: all 0.2s; }
    .btn-primary { background: var(--accent-color, #D4A574); color: #0a0806; border-color: var(--accent-color, #D4A574); }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { background: transparent; color: var(--text-primary); border-color: var(--border-color, #2a2418); }
    .btn-secondary:hover { border-color: var(--accent-color, #D4A574); color: var(--accent-color, #D4A574); }
    .btn-secondary:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-secondary:disabled:hover { border-color: var(--border-color, #2a2418); color: var(--text-primary); }

    .hidden { display: none !important; }

    .results-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
    .results-header h2 { font-size: 1.3rem; font-weight: 700; color: var(--text-primary); margin: 0; }
    .results-preview-input { margin-bottom: 0.75rem; }
    .results-preview-input label, .results-size-row label, .compare-input-row label, .compare-size-row label { display: block; margin-bottom: 0.35rem; font-weight: 600; font-size: 0.85rem; color: var(--text-secondary); }
    .results-preview-input input, .compare-input-row input { width: 100%; padding: 0.6rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-color, #2a2418); background: var(--bg-color, #0a0806); color: var(--text-primary); font-size: 0.95rem; box-sizing: border-box; }
    .results-preview-input input:focus, .compare-input-row input:focus { outline: none; border-color: var(--accent-color, #D4A574); }

    .results-size-row, .compare-size-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; }
    .results-size-row input[type="range"], .compare-size-row input[type="range"] { flex: 1; accent-color: var(--accent-color, #D4A574); }
    #preview-size-val, #compare-size-val { font-size: 0.85rem; color: var(--text-secondary); min-width: 3rem; }

    .result-card { border: 1px solid var(--border-color, #2a2418); border-radius: 8px; padding: 1.25rem; margin-bottom: 0.75rem; background: var(--bg-color, #0a0806); }
    .result-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.4rem; }
    .result-name { font-weight: 700; font-size: 1rem; color: var(--text-primary); }
    .result-score { font-weight: 400; font-size: 0.8rem; color: var(--accent-color, #D4A574); }
    .result-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
    .tag { font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 10px; background: var(--border-color, #2a2418); color: var(--text-secondary); }
    .result-preview { line-height: 1.4; color: var(--text-primary); padding: 0.5rem 0; word-break: break-word; min-height: 2em; }

    .no-results { padding: 2rem; text-align: center; }
    .no-results p { color: var(--text-secondary); }

    .compare-input-row { margin-bottom: 0.75rem; }
    .compare-selectors { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
    .compare-slot label { display: block; margin-bottom: 0.35rem; font-weight: 600; font-size: 0.85rem; color: var(--text-secondary); }
    .compare-slot select { width: 100%; padding: 0.6rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-color, #2a2418); background: var(--bg-color, #0a0806); color: var(--text-primary); font-size: 0.95rem; box-sizing: border-box; }
    .compare-slot select:focus { outline: none; border-color: var(--accent-color, #D4A574); }
    .compare-preview { margin-top: 0.75rem; padding: 1rem; border: 1px solid var(--border-color, #2a2418); border-radius: 8px; line-height: 1.4; color: var(--text-primary); word-break: break-word; min-height: 3em; background: var(--bg-color, #0a0806); }

    .content-section { margin-top: 2rem; }
    .content-section h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-primary); }
    .content-section h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .content-section p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.75rem; }

    .faq-item { border-bottom: 1px solid var(--border-color, #2a2418); padding-bottom: 1.25rem; margin-bottom: 1.25rem; }
    .faq-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .faq-item h3 { margin-top: 0; }

    .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
    .related-card { display: block; padding: 1.25rem; background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 8px; text-decoration: none; transition: border-color 0.2s; }
    .related-card:hover { border-color: var(--accent-color, #D4A574); }
    .related-card h3 { font-size: 1rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.4rem; }
    .related-card p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; line-height: 1.4; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.8rem; }
      .tabs-row { gap: 0; }
      .tab-btn { padding: 0.5rem 0.75rem; font-size: 0.85rem; }
      .question-nav { flex-direction: column; }
      .btn-secondary { width: 100%; text-align: center; }
      .results-header { flex-direction: column; }
    }
  </style>
</SiteLayout>
