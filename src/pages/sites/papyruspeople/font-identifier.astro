];

const relatedPages = [
  { url: '/sites/papyruspeople/fancy-text-generator', title: 'Fancy Text Generator', description: 'Generate cool text with 20+ Unicode styles for social media' },
  { url: '/sites/papyruspeople/lorem-ipsum-generator', title: 'Lorem Ipsum Generator', description: 'Generate dummy text in multiple styles for mockups and prototypes' }
