---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Ultimate 30-Point Proofreading Checklist & Guide',
  description: 'Proofreading guide with a 30-point checklist, common errors, homophone traps, recommended tools, and tips for self-editing vs professional editing.',
  category: 'list',
  published: '2026-04-10'
};

const SITE_ID = 'papyruspeople';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between proofreading and editing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Editing focuses on improving the flow, structure, and clarity of the content. Proofreading is the final stage, focusing strictly on correcting surface-level errors like spelling, grammar, punctuation, and formatting."
        }
      },
      {
        "@type": "Question",
        "name": "Why is reading backwards effective for proofreading?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Reading backwards forces your brain to look at each word individually out of context, preventing you from mentally auto-correcting errors and helping you catch typos and spelling mistakes more easily."
        }
      },
      {
        "@type": "Question",
        "name": "Should I proofread on screen or on print?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Printing your document and proofreading on paper is highly recommended. The change in medium helps you spot errors your eyes might gloss over on a screen. If you must use a screen, try changing the font or background color."
        }
      },
      {
        "@type": "Question",
        "name": "What are the most common homophone traps?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most frequent homophone traps include their/there/they're, your/you're, its/it's, affect/effect, and then/than. Spellcheckers often miss these because the words are spelled correctly but used in the wrong context."
        }
      },
      {
        "@type": "Question",
        "name": "Are proofreading tools like Grammarly enough?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While tools like Grammarly, ProWritingAid, and Hemingway are excellent for catching basic errors and improving readability, they are not flawless. They miss contextual errors and nuances, so manual proofreading is always necessary."
        }
      }
    ]
  }
];
---

<SiteLayout
  site={SITE_ID}
  title={meta.title}
  description={meta.description}
  schema={JSON.stringify(schema)}
  canonical="https://papyruspeople.photonbuilder.com/proofreading-checklist"
>
  <div class="page-content">
    <div class="hero">
      <h1>The Ultimate 30-Point Proofreading Checklist</h1>
      <p>Ensure your writing is flawless with our comprehensive professional proofreading guide, tools, and techniques.</p>
    </div>

    <div class="content-section card">
      <h2>30-Point Proofreading Checklist</h2>
      <ol>
        <li>Check for spelling errors (run spellcheck but don't rely on it exclusively).</li>
        <li>Verify all homophones are used correctly (their/there/they're, its/it's).</li>
        <li>Ensure subject-verb agreement.</li>
        <li>Check for consistent verb tense throughout the document.</li>
        <li>Look for run-on sentences and comma splices.</li>
        <li>Eliminate sentence fragments.</li>
        <li>Check for proper use of apostrophes (possession vs. plural).</li>
        <li>Ensure all quotation marks are paired correctly.</li>
        <li>Verify correct comma usage (e.g., Oxford comma consistency).</li>
        <li>Check for proper capitalization (titles, proper nouns, beginnings of sentences).</li>
        <li>Ensure consistent formatting (font sizes, headings, bullet points).</li>
        <li>Check that all hyperlinks work and lead to the correct destination.</li>
        <li>Verify the spelling of all proper names (people, companies, places).</li>
        <li>Check all facts, dates, and statistics for accuracy.</li>
        <li>Ensure consistent use of numbers (e.g., spelling out one through nine, using numerals for 10 and above).</li>
        <li>Look for missing words or double words (e.g., "the the").</li>
        <li>Check for consistent spelling conventions (e.g., American vs. British English).</li>
        <li>Ensure pronoun-antecedent agreement.</li>
        <li>Verify correct formatting of citations and references according to the chosen style guide.</li>
        <li>Check for consistent spacing between sentences (one space vs. two spaces).</li>
        <li>Ensure proper alignment and indentation of paragraphs.</li>
        <li>Check for widow and orphan lines in print documents.</li>
        <li>Verify that table and figure numbers match the text references.</li>
        <li>Check for proper use of hyphens, en dashes, and em dashes.</li>
        <li>Ensure consistent use of acronyms (spell out on first use).</li>
        <li>Look for passive voice and change to active voice where appropriate.</li>
        <li>Check for repetitive word usage or "crutch" words.</li>
        <li>Ensure logical flow and transitions between paragraphs.</li>
        <li>Check the title page and headers/footers for accuracy.</li>
        <li>Perform a final read-aloud or text-to-speech pass to catch awkward phrasing.</li>
      </ol>
    </div>

    <div class="content-section card">
      <h2>Common Errors by Category</h2>
      <h3>Spelling</h3>
      <p>Typos, transposed letters, and misspelled proper nouns are frequent. Always double-check names and technical terms.</p>
      <h3>Grammar</h3>
      <p>Subject-verb agreement issues, dangling modifiers, and incorrect pronoun usage can undermine your credibility.</p>
      <h3>Punctuation</h3>
      <p>Misplaced commas, missing apostrophes, and incorrect quote marks are common. Pay special attention to the Oxford comma.</p>
      <h3>Formatting</h3>
      <p>Inconsistent heading styles, mismatched fonts, and irregular spacing can make a document look unprofessional.</p>
      <h3>Consistency</h3>
      <p>Ensure consistent spelling conventions (US vs. UK), formatting styles, and terminology throughout the document.</p>
    </div>

    <div class="content-section card">
      <h2>Homophone Traps</h2>
      <p>These are words that sound the same but have different meanings and spellings. Spellcheckers often miss them.</p>
      <ul>
        <li><strong>Their / There / They're:</strong> Possession / Location / Contraction for "they are".</li>
        <li><strong>Its / It's:</strong> Possession / Contraction for "it is".</li>
        <li><strong>Your / You're:</strong> Possession / Contraction for "you are".</li>
        <li><strong>Affect / Effect:</strong> Verb (to influence) / Noun (the result).</li>
        <li><strong>Then / Than:</strong> Time or sequence / Comparison.</li>
      </ul>
    </div>

    <div class="content-section card">
      <h2>Advanced Proofreading Techniques</h2>
      <h3>Reading Backwards</h3>
      <p>Read your document starting from the last word and moving to the first. This breaks the logical flow, forcing you to focus on the spelling and structure of individual words rather than the meaning of the sentence.</p>
      <h3>Text-to-Speech Proofreading</h3>
      <p>Use text-to-speech software to have the document read aloud to you. Hearing the words can help you catch missing words, awkward phrasing, and run-on sentences that your eyes might skip over.</p>
      <h3>Print vs. Screen Reading</h3>
      <p>Reading on a screen tires the eyes and can cause you to miss errors. Printing your document and reviewing it with a red pen provides a fresh perspective and improves error detection.</p>
    </div>

    <div class="content-section card">
      <h2>Style Guide Basics</h2>
      <p>Adhering to a specific style guide ensures consistency in formatting, punctuation, and citation.</p>
      <ul>
        <li><strong>AP Style (Associated Press):</strong> Commonly used in journalism and PR. Drops the Oxford comma and spells out numbers one through nine.</li>
        <li><strong>Chicago Manual of Style (CMOS):</strong> Widely used in publishing and humanities. Uses the Oxford comma and complex citation systems.</li>
        <li><strong>MLA (Modern Language Association):</strong> Standard for academic writing in the humanities. Features specific rules for in-text citations and works cited pages.</li>
      </ul>
    </div>

    <div class="content-section card">
      <h2>Professional Proofreading</h2>
      <h3>Track Changes Tips</h3>
      <p>When using Microsoft Word or Google Docs, always enable "Track Changes" or "Suggesting" mode. This allows the author to review and accept or reject each correction individually.</p>
      <h3>Proofreading Marks & Symbols</h3>
      <p>Familiarize yourself with standard proofreading symbols if you are editing hard copies. These include symbols for "insert," "delete," "capitalize," "stet" (let it stand), and "new paragraph."</p>
      <h3>Tools</h3>
      <p>Leverage technology, but don't rely on it entirely. <strong>Grammarly</strong> is great for general checks, <strong>ProWritingAid</strong> offers in-depth style reports, and <strong>Hemingway Editor</strong> highlights complex sentences and passive voice.</p>
      <h3>Pricing for Freelance Proofreaders</h3>
      <p>Rates vary based on experience, document complexity, and turnaround time. Freelancers typically charge per word (e.g., $0.01 - $0.03/word), per page, or an hourly rate ($25 - $50+/hour).</p>
      <h3>Self-Editing vs. Professional Editing</h3>
      <p>Self-editing is essential for early drafts, but it's hard to spot your own mistakes because your brain knows what you <em>meant</em> to write. Professional editing provides an objective, trained eye to catch errors and improve overall quality.</p>
    </div>

    <div class="content-section card">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map((faq: any) => (
        <div class="faq-item">
          <h3>{faq.name}</h3>
          <p>{faq.acceptedAnswer.text}</p>
        </div>
      ))}
    </div>
  </div>

  <style>
    .page-content { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; margin-bottom: 2.5rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color, #2a2418); border-radius: 12px; padding: 2rem; }

    .content-section { margin-top: 2rem; }
    .content-section h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-primary); }
    .content-section h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .content-section p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.75rem; }
    ul { color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.75rem; }
    li { margin-bottom: 0.5rem; }

    .faq-item { border-bottom: 1px solid var(--border-color, #2a2418); padding-bottom: 1.25rem; margin-bottom: 1.25rem; }
    .faq-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .faq-item h3 { margin-top: 0; }
  </style>
</SiteLayout>
