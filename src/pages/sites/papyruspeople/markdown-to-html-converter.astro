  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const mdInput = document.getElementById('md-input');
      const htmlOutput = document.getElementById('html-output');
      const previewOutput = document.getElementById('preview-output');
      const copyBtn = document.getElementById('copy-btn');
      const tabBtns = document.querySelectorAll('.tab-btn');

      let activeTab = 'html';

      // Tab switching
      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          tabBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeTab = btn.dataset.tab;
          if (activeTab === 'html') {
            htmlOutput.style.display = '';
            previewOutput.style.display = 'none';
          } else {
            htmlOutput.style.display = 'none';
            previewOutput.style.display = '';
          }
        });
      });

      // Copy button
      copyBtn.addEventListener('click', () => {
        const html = markdownToHtml(mdInput.value);
        navigator.clipboard.writeText(html).then(() => {
          copyBtn.textContent = 'Copied!';
          setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
        });
      });

      // Markdown to HTML converter
      function escapeHtml(str) {
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      function markdownToHtml(md) {
        let html = md;

        // Fenced code blocks
        html = html.replace(/```(\w*)\n([\s\S]*?)```/g, function(_, lang, code) {
          const attr = lang ? ' class="language-' + escapeHtml(lang) + '"' : '';
          return '<pre><code' + attr + '>' + escapeHtml(code.replace(/\n$/, '')) + '</code></pre>';
        });

        // Split into lines for block-level processing
        const lines = html.split('\n');
        const output = [];
        let i = 0;

        while (i < lines.length) {
          const line = lines[i];

          // Skip already-processed code blocks
          if (line.startsWith('<pre><code')) {
            // Find the closing tag - it might be on the same line or span multiple
            let block = line;
            while (!block.includes('</code></pre>') && i + 1 < lines.length) {
              i++;
              block += '\n' + lines[i];
            }
            output.push(block);
            i++;
            continue;
          }

          // Horizontal rules
          if (/^(\*{3,}|-{3,}|_{3,})\s*$/.test(line.trim())) {
            output.push('<hr>');
            i++;
            continue;
          }

          // Headings
          const headingMatch = line.match(/^(#{1,6})\s+(.+)$/);
          if (headingMatch) {
            const level = headingMatch[1].length;
            output.push('<h' + level + '>' + processInline(headingMatch[2]) + '</h' + level + '>');
            i++;
            continue;
          }

          // Tables
          if (line.includes('|') && i + 1 < lines.length && /^\|?\s*[-:]+[-| :]*$/.test(lines[i + 1])) {
            const tableLines = [];
            let ti = i;
            while (ti < lines.length && lines[ti].includes('|')) {
              tableLines.push(lines[ti]);
              ti++;
            }
            if (tableLines.length >= 2) {
              output.push(parseTable(tableLines));
              i = ti;
              continue;
            }
          }

          // Blockquotes
          if (line.startsWith('>')) {
            const quoteLines = [];
            let qi = i;
            while (qi < lines.length && (lines[qi].startsWith('>') || (lines[qi].trim() !== '' && quoteLines.length > 0 && !lines[qi].startsWith('#')))) {
              if (!lines[qi].startsWith('>')) break;
              quoteLines.push(lines[qi].replace(/^>\s?/, ''));
              qi++;
            }
            output.push('<blockquote><p>' + processInline(quoteLines.join(' ')) + '</p></blockquote>');
            i = qi;
            continue;
          }

          // Unordered lists
          if (/^[\s]*[-*+]\s+/.test(line)) {
            const listItems = [];
            let li = i;
            while (li < lines.length && /^[\s]*[-*+]\s+/.test(lines[li])) {
              listItems.push(lines[li].replace(/^[\s]*[-*+]\s+/, ''));
              li++;
            }
            output.push('<ul>' + listItems.map(item => '<li>' + processInline(item) + '</li>').join('') + '</ul>');
            i = li;
            continue;
          }

          // Ordered lists
          if (/^[\s]*\d+\.\s+/.test(line)) {
            const listItems = [];
            let li = i;
            while (li < lines.length && /^[\s]*\d+\.\s+/.test(lines[li])) {
              listItems.push(lines[li].replace(/^[\s]*\d+\.\s+/, ''));
              li++;
            }
            output.push('<ol>' + listItems.map(item => '<li>' + processInline(item) + '</li>').join('') + '</ol>');
            i = li;
            continue;
          }

          // Empty lines
          if (line.trim() === '') {
            i++;
            continue;
          }

          // Paragraphs - collect consecutive non-empty lines
          const paraLines = [];
          let pi = i;
          while (pi < lines.length && lines[pi].trim() !== '' && !lines[pi].startsWith('#') && !lines[pi].startsWith('>') && !lines[pi].startsWith('<') && !/^[\s]*[-*+]\s+/.test(lines[pi]) && !/^[\s]*\d+\.\s+/.test(lines[pi]) && !/^(\*{3,}|-{3,}|_{3,})\s*$/.test(lines[pi].trim())) {
            paraLines.push(lines[pi]);
            pi++;
          }
          if (paraLines.length > 0) {
            output.push('<p>' + processInline(paraLines.join(' ')) + '</p>');
            i = pi;
          } else {
            output.push('<p>' + processInline(line) + '</p>');
            i++;
          }
        }

        return output.join('\n');
      }

      function processInline(text) {
        // Images (before links)
        text = text.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1">');
        // Links
        text = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
        // Bold + italic
        text = text.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
        // Bold
        text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
        text = text.replace(/__(.+?)__/g, '<strong>$1</strong>');
        // Italic
        text = text.replace(/\*(.+?)\*/g, '<em>$1</em>');
        text = text.replace(/_(.+?)_/g, '<em>$1</em>');
        // Strikethrough
        text = text.replace(/~~(.+?)~~/g, '<del>$1</del>');
        // Inline code
        text = text.replace(/`([^`]+)`/g, '<code>$1</code>');
        return text;
      }

      function parseTable(tableLines) {
        const parseRow = (row) => row.replace(/^\|/, '').replace(/\|$/, '').split('|').map(c => c.trim());
        const headers = parseRow(tableLines[0]);
        const alignRow = parseRow(tableLines[1]);
        const aligns = alignRow.map(cell => {
          if (cell.startsWith(':') && cell.endsWith(':')) return 'center';
          if (cell.endsWith(':')) return 'right';
          return 'left';
        });

        let table = '<table><thead><tr>';
        headers.forEach((h, idx) => {
          const align = aligns[idx] ? ' style="text-align:' + aligns[idx] + '"' : '';
          table += '<th' + align + '>' + processInline(h) + '</th>';
        });
        table += '</tr></thead><tbody>';

        for (let r = 2; r < tableLines.length; r++) {
          const cells = parseRow(tableLines[r]);
          table += '<tr>';
          cells.forEach((c, idx) => {
            const align = aligns[idx] ? ' style="text-align:' + aligns[idx] + '"' : '';
            table += '<td' + align + '>' + processInline(c) + '</td>';
          });
          table += '</tr>';
        }
        table += '</tbody></table>';
        return table;
      }

      function update() {
        const md = mdInput.value;
        const html = markdownToHtml(md);
        htmlOutput.textContent = html;
        previewOutput.innerHTML = html;
      }

      mdInput.addEventListener('input', update);
      update();
    });
  </script>

