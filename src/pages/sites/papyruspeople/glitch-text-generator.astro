    .card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 24px; margin-bottom: 20px; }

    .input-area { width: 100%; min-height: 80px; padding: 14px; background: #060a12; border: 1px solid #152040; border-radius: 10px; color: #f1f5f9; font-size: 1.1rem; font-family: inherit; resize: vertical; box-sizing: border-box; }
