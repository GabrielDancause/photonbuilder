  <script is:inline>
    // Combining character ranges
    const ABOVE = [
      0x0300,0x0301,0x0302,0x0303,0x0304,0x0305,0x0306,0x0307,0x0308,0x0309,
      0x030A,0x030B,0x030C,0x030D,0x030E,0x030F,0x0310,0x0311,0x0312,0x0313,
      0x0314,0x0315,0x031A,0x033D,0x033E,0x033F,0x0340,0x0341,0x0342,0x0343,
      0x0344,0x0346,0x034A,0x034B,0x034C,0x0350,0x0351,0x0352,0x0357,0x035B,
      0x0360,0x0361
    ];
    const MIDDLE = [0x0334,0x0335,0x0336,0x0337,0x0338,0x0347,0x0348,0x0349];
    const BELOW = [
      0x0316,0x0317,0x0318,0x0319,0x031C,0x031D,0x031E,0x031F,0x0320,0x0321,
      0x0322,0x0323,0x0324,0x0325,0x0326,0x0327,0x0328,0x0329,0x032A,0x032B,
      0x032C,0x032D,0x032E,0x032F,0x0330,0x0331,0x0332,0x0333,0x0339,0x033A,
      0x033B,0x033C,0x0345,0x0353,0x0354,0x0355,0x0356,0x0359,0x035A,0x035C
    ];

    function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    function glitchify(text, intensity, direction) {
      let result = '';
      for (const char of text) {
        result += char;
        if (char === ' ' || char === '\n') continue;
        const n = Math.floor(Math.random() * intensity) + 1;
        for (let i = 0; i < n; i++) {
          if (direction === 'up') result += String.fromCharCode(rand(ABOVE));
          else if (direction === 'down') result += String.fromCharCode(rand(BELOW));
          else if (direction === 'mid') result += String.fromCharCode(rand(MIDDLE));
          else if (direction === 'updown') result += String.fromCharCode(rand(Math.random() > 0.5 ? ABOVE : BELOW));
          else {
            const r = Math.random();
            if (r < 0.45) result += String.fromCharCode(rand(ABOVE));
            else if (r < 0.9) result += String.fromCharCode(rand(BELOW));
            else result += String.fromCharCode(rand(MIDDLE));
          }
        }
      }
      return result;
    }

    function generate() {
      const text = document.getElementById('inputText').value;
      const intensity = parseInt(document.getElementById('intensity').value);
      const direction = document.getElementById('direction').value;
      document.getElementById('intensityVal').textContent = intensity;
      document.getElementById('outputText').textContent = glitchify(text, intensity, direction);
      renderPreviews(text);
    }

    function renderPreviews(text) {
      if (!text) text = 'Hello World';
      const grid = document.getElementById('previewGrid');
      const styles = [
        { label: 'Subtle', int: 3, dir: 'all' },
        { label: 'Standard', int: 8, dir: 'all' },
        { label: 'Heavy', int: 15, dir: 'all' },
        { label: 'Maximum Chaos', int: 20, dir: 'all' },
        { label: 'Creeping Up', int: 6, dir: 'up' },
        { label: 'Dripping Down', int: 6, dir: 'down' }
      ];
      grid.innerHTML = '';
      styles.forEach(s => {
        const card = document.createElement('div');
        card.className = 'preview-card';
        card.onclick = () => { setPreset(s.int, s.dir); };
        card.innerHTML = `<div class="preview-label">${s.label} (${s.int})</div><div class="preview-text">${glitchify(text.slice(0, 20), s.int, s.dir)}</div>`;
        grid.appendChild(card);
      });
    }

    function setPreset(int, dir) {
      document.getElementById('intensity').value = int;
      document.getElementById('direction').value = dir;
      document.querySelectorAll('.preset').forEach(p => p.classList.remove('active'));
      generate();
    }

    function copyOutput() {
      const text = document.getElementById('outputText').textContent;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copyBtn');
        btn.textContent = '✓ Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = '📋 Copy to Clipboard'; btn.classList.remove('copied'); }, 2000);
      });
    }

    generate();
  </script>

