---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Lorem Ipsum Generator',
  description: 'Generate lorem ipsum dummy text instantly. Choose from Classic, Hipster, Pirate, Corporate, and Bacon Ipsum styles. Free placeholder text generator.',
  category: 'tool',
  published: '2026-03-24'
};

const SITE_ID = 'papyruspeople';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Lorem Ipsum Generator",
    "description": "Generate placeholder dummy text in multiple styles including Classic Lorem Ipsum, Hipster Ipsum, Pirate Ipsum, Corporate Ipsum, and Bacon Ipsum.",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "All"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Lorem Ipsum?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Lorem Ipsum is placeholder text used in the printing and typesetting industry since the 1500s. It originates from a scrambled passage of 'De Finibus Bonorum et Malorum' by Cicero, written in 45 BC. Designers and developers use it to fill layouts before final copy is available, allowing them to focus on visual design without being distracted by readable content."
        }
      },
      {
        "@type": "Question",
        "name": "Why use a lorem ipsum generator instead of writing placeholder text manually?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A lorem ipsum generator saves time and produces consistent, realistic-looking text blocks. It lets you specify exact amounts — by paragraph, word count, sentence count, or even byte size — so your placeholder text precisely matches the space you need to fill. Manual placeholder text tends to be repetitive and inconsistent in length."
        }
      },
      {
        "@type": "Question",
        "name": "What are the different Lorem Ipsum styles available?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This generator offers five styles: Classic Lorem Ipsum (traditional Latin-based text), Hipster Ipsum (trendy artisanal words), Pirate Ipsum (nautical pirate-themed text), Corporate Ipsum (business jargon and buzzwords), and Bacon Ipsum (meat-themed placeholder text). Each style produces natural-looking paragraphs while adding personality to your mockups."
        }
      },
      {
        "@type": "Question",
        "name": "Can I generate Lorem Ipsum with HTML tags?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The generator includes an option to wrap each paragraph in HTML <p> tags, making it easy to paste directly into your HTML code. You can also add line breaks between paragraphs for plain text formatting. Both options are available via toggle switches in the generator settings."
        }
      },
      {
        "@type": "Question",
        "name": "What does 'Start with Lorem ipsum dolor sit amet' mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This option ensures the generated text begins with the traditional opening phrase 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.' This is a common convention in design and development — it immediately signals to anyone viewing the layout that the text is placeholder content, not final copy."
        }
      },
      {
        "@type": "Question",
        "name": "How do I generate text by byte size?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Select 'Byte Size' as the generation mode and enter your target size in bytes. The generator will produce text that matches your specified byte count as closely as possible. This is useful for testing database field limits, API payload sizes, or file size constraints where character count alone is not sufficient."
        }
      }
    ]
  }
];

const relatedPages = [
  { url: '/character-counter', title: 'Character Counter', description: 'Count characters, words, sentences, and paragraphs in real time' },
  { url: '/fancy-text-generator', title: 'Fancy Text Generator', description: 'Generate cool text with 20+ Unicode styles for social media' }
];
---

<SiteLayout
  site={SITE_ID}
  title={meta.title}
  description={meta.description}
  schema={schema} canonical="https://papyruspeople.photonbuilder.com/lorem-ipsum-generator"
>
  <div class="page-content">
    <div style="background:rgba(212,165,116,0.08);border:1px solid rgba(212,165,116,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      📝 <strong style="color:#D4A574;">Freelance designers are in record demand.</strong> With web design projects up 23%, you need placeholder text fast. Generate lorem ipsum in multiple styles for mockups and wireframes. <a href="https://gab.ae/news/global-freelance-economy-record-growth-2026" style="color:#D4A574;">The design boom →</a>
    </div>
    <div class="hero">
      <h1>Lorem Ipsum Generator</h1>
      <p>Generate dummy text and placeholder text in multiple styles. Perfect for mockups, wireframes, and design prototypes.</p>
    </div>

    <div class="tool-container card">
      <div class="options-row">
        <div class="option-group">
          <label for="gen-mode">Generate by</label>
          <select id="gen-mode">
            <option value="paragraphs">Paragraphs</option>
            <option value="words">Word Count</option>
            <option value="sentences">Sentence Count</option>
            <option value="bytes">Byte Size</option>
          </select>
        </div>
        <div class="option-group">
          <label for="gen-count">Amount</label>
          <input type="number" id="gen-count" value="5" min="1" max="100">
        </div>
        <div class="option-group">
          <label for="gen-style">Style</label>
          <select id="gen-style">
            <option value="classic">Classic Lorem Ipsum</option>
            <option value="hipster">Hipster Ipsum</option>
            <option value="pirate">Pirate Ipsum</option>
            <option value="corporate">Corporate Ipsum</option>
            <option value="bacon">Bacon Ipsum</option>
          </select>
        </div>
      </div>

      <div class="toggle-row">
        <label class="toggle-label">
          <input type="checkbox" id="opt-start" checked>
          <span>Start with "Lorem ipsum dolor sit amet"</span>
        </label>
        <label class="toggle-label">
          <input type="checkbox" id="opt-ptags">
          <span>Wrap in HTML &lt;p&gt; tags</span>
        </label>
        <label class="toggle-label">
          <input type="checkbox" id="opt-breaks" checked>
          <span>Add line breaks between paragraphs</span>
        </label>
      </div>

      <div class="actions-row">
        <button id="btn-generate" class="btn-primary">Generate</button>
        <button id="btn-copy" class="btn-secondary">Copy to Clipboard</button>
      </div>

      <div class="output-area">
        <div class="output-stats" id="output-stats"></div>
        <div id="output" class="output-text"></div>
      </div>
    </div>

    <div class="content-section card">
      <h2>What Is Lorem Ipsum?</h2>
      <p><strong>Lorem Ipsum</strong> is the standard <strong>dummy text</strong> used by the printing and typesetting industry since the 1500s. It originates from a scrambled excerpt of Cicero's <em>De Finibus Bonorum et Malorum</em> (45 BC). Today, designers, developers, and content creators rely on a <strong>lorem ipsum generator</strong> to produce realistic <strong>placeholder text</strong> that fills layouts without distracting from visual design.</p>
      <p>This free <strong>placeholder text generator</strong> goes beyond the basics. Choose from five unique text styles — Classic, Hipster, Pirate, Corporate, and Bacon — and generate text by paragraph count, word count, sentence count, or byte size. Whether you're prototyping a website, building a mobile app, or drafting a print layout, this <strong>lipsum generator</strong> gives you exactly the filler text you need.</p>

      <h3>How to Use the Lorem Ipsum Generator</h3>
      <p>Select your generation mode (paragraphs, words, sentences, or bytes), set the amount, pick a style, and click <strong>Generate</strong>. Toggle the options to start with the traditional opening phrase, add HTML paragraph tags for direct code pasting, or include line breaks for plain text formatting. The live preview updates instantly so you can fine-tune the output before copying.</p>

      <h3>Classic vs. Alternative Ipsum Styles</h3>
      <p><strong>Classic Lorem Ipsum</strong> uses the traditional pseudo-Latin text that has been the industry standard for centuries. <strong>Hipster Ipsum</strong> adds trendy artisanal vocabulary for a modern feel. <strong>Pirate Ipsum</strong> brings nautical flair with seafaring terms. <strong>Corporate Ipsum</strong> fills your mockups with boardroom-ready business jargon. And <strong>Bacon Ipsum</strong> satisfies your carnivorous design needs with meat-themed text.</p>

      <h3>When to Use Placeholder Text</h3>
      <p>Use <strong>dummy text</strong> whenever final content isn't ready but you need to evaluate typography, spacing, and layout. Common use cases include website wireframes, app prototypes, graphic design mockups, email templates, and presentation slides. The key advantage of a <strong>dummy text generator</strong> is that it produces natural-looking text blocks that approximate real content length and flow.</p>
    </div>

    <div class="content-section card">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>What is Lorem Ipsum?</h3>
        <p>Lorem Ipsum is placeholder text used in the printing and typesetting industry since the 1500s. It originates from a scrambled passage of "De Finibus Bonorum et Malorum" by Cicero, written in 45 BC. Designers and developers use it to fill layouts before final copy is available, allowing them to focus on visual design without being distracted by readable content.</p>
      </div>

      <div class="faq-item">
        <h3>Why use a lorem ipsum generator instead of writing placeholder text manually?</h3>
        <p>A lorem ipsum generator saves time and produces consistent, realistic-looking text blocks. It lets you specify exact amounts — by paragraph, word count, sentence count, or even byte size — so your placeholder text precisely matches the space you need to fill. Manual placeholder text tends to be repetitive and inconsistent in length.</p>
      </div>

      <div class="faq-item">
        <h3>What are the different Lorem Ipsum styles available?</h3>
        <p>This generator offers five styles: Classic Lorem Ipsum (traditional Latin-based text), Hipster Ipsum (trendy artisanal words), Pirate Ipsum (nautical pirate-themed text), Corporate Ipsum (business jargon and buzzwords), and Bacon Ipsum (meat-themed placeholder text). Each style produces natural-looking paragraphs while adding personality to your mockups.</p>
      </div>

      <div class="faq-item">
        <h3>Can I generate Lorem Ipsum with HTML tags?</h3>
        <p>Yes. The generator includes an option to wrap each paragraph in HTML &lt;p&gt; tags, making it easy to paste directly into your HTML code. You can also add line breaks between paragraphs for plain text formatting. Both options are available via toggle switches in the generator settings.</p>
      </div>

      <div class="faq-item">
        <h3>What does "Start with Lorem ipsum dolor sit amet" mean?</h3>
        <p>This option ensures the generated text begins with the traditional opening phrase "Lorem ipsum dolor sit amet, consectetur adipiscing elit." This is a common convention in design and development — it immediately signals to anyone viewing the layout that the text is placeholder content, not final copy.</p>
      </div>

      <div class="faq-item">
        <h3>How do I generate text by byte size?</h3>
        <p>Select "Byte Size" as the generation mode and enter your target size in bytes. The generator will produce text that matches your specified byte count as closely as possible. This is useful for testing database field limits, API payload sizes, or file size constraints where character count alone is not sufficient.</p>
      </div>
    </div>

    <div class="content-section card">
      <h2>Related Tools</h2>
      <div class="related-grid">
        {relatedPages.map(page => (
          <a href={page.url} class="related-card">
            <h3>{page.title}</h3>
            <p>{page.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const modeEl = document.getElementById('gen-mode');
      const countEl = document.getElementById('gen-count');
      const styleEl = document.getElementById('gen-style');
      const optStart = document.getElementById('opt-start');
      const optPtags = document.getElementById('opt-ptags');
      const optBreaks = document.getElementById('opt-breaks');
      const btnGenerate = document.getElementById('btn-generate');
      const btnCopy = document.getElementById('btn-copy');
      const outputEl = document.getElementById('output');
      const statsEl = document.getElementById('output-stats');

      const CLASSIC_WORDS = [
        'lorem','ipsum','dolor','sit','amet','consectetur','adipiscing','elit','sed','do',
        'eiusmod','tempor','incididunt','ut','labore','et','dolore','magna','aliqua','enim',
        'ad','minim','veniam','quis','nostrud','exercitation','ullamco','laboris','nisi',
        'aliquip','ex','ea','commodo','consequat','duis','aute','irure','in','reprehenderit',
        'voluptate','velit','esse','cillum','fugiat','nulla','pariatur','excepteur','sint',
        'occaecat','cupidatat','non','proident','sunt','culpa','qui','officia','deserunt',
        'mollit','anim','id','est','laborum','at','vero','eos','accusamus','iusto','odio',
        'dignissimos','ducimus','blanditiis','praesentium','voluptatum','deleniti','atque',
        'corrupti','quos','dolores','quas','molestias','excepturi','occaecati','cupiditate',
        'provident','similique','mollitia','animi','fuga','harum','rerum','necessitatibus',
        'saepe','eveniet','voluptates','repudiandae','recusandae','itaque','earum','hic',
        'tenetur','sapiente','delectus','reiciendis','voluptatibus','maiores','alias',
        'perferendis','doloribus','asperiores','repellat','temporibus','quibusdam','illum',
        'fugit','nemo','ipsam','inventore','veritatis','quasi','architecto','beatae','vitae',
        'dicta','explicabo','natus','error','perspiciatis','unde','omnis','iste',
        'accusantium','doloremque','laudantium','totam','rem','aperiam','eaque','ipsa',
        'quae','ab','illo','placeat','facere','possimus','eligendi','optio','cumque',
        'nihil','impedit','quo','minus','maxime','nostrum','exercitationem','ullam',
        'corporis','suscipit','laboriosam','aliquid','commodi','consequatur'
      ];

      const HIPSTER_WORDS = [
        'artisan','aesthetic','biodiesel','brunch','bushwick','chambray','chartreuse',
        'chia','cold-pressed','craft','crucifix','distillery','dreamcatcher','echo',
        'ethical','everyday','flannel','flexitarian','fanny','gentrify','gluten-free',
        'gochujang','hashtag','helvetica','heirloom','hoodie','humblebrag','intelligentsia',
        'jean','kale','keytar','kickstarter','kinfolk','knausgaard','kombucha','letterpress',
        'listicle','lomo','lumbersexual','marfa','meditation','messenger','microdosing',
        'migas','mixtape','mumblecore','mustache','neutra','normcore','occupy','offal',
        'organic','paleo','photo','pickled','pinterest','pitchfork','plaid','polaroid',
        'portland','post-ironic','pour-over','poutine','quinoa','raclette','raw','denim',
        'retro','salvia','scenester','schlitz','seitan','selvage','semiotics','shabby',
        'chic','shoreditch','single-origin','skateboard','slow-carb','small-batch',
        'snackwave','sriracha','stumptown','subway','sustainable','swag','synth','tacos',
        'tattooed','taxidermy','thundercats','tilde','tofu','tote','bag','truffaut',
        'tumblr','twee','typewriter','umami','unicorn','vape','vegan','venmo','vinyl',
        'waistcoat','wayfarers','williamsburg','wolf','yolo','yr','banjo','bitters',
        'blog','copper','mug','celiac','chicharrones','coloring','book','cornhole'
      ];

      const PIRATE_WORDS = [
        'ahoy','anchor','avast','aye','barnacle','bilge','blackbeard','blimey','booty',
        'bow','brig','brigantine','buccaneer','cannon','capn','cargo','chest','compass',
        'corsair','crew','crow','cutlass','dagger','davy','jones','deck','doubloon',
        'flag','fleet','forecastle','galleon','gangplank','grog','gunwale','harbor',
        'helm','hull','island','jack','jolly','roger','keelhaul','kraken','landlubber',
        'loot','mainsail','maroon','mast','matey','mutiny','navy','ocean','parley',
        'parrot','pegleg','pirate','plank','plunder','port','privateer','quarterdeck',
        'quartermaster','raid','rigging','rum','sail','sailor','scallywag','schooner',
        'scurvy','sea','shanty','ship','shipwreck','shore','skull','crossbones',
        'starboard','stern','swab','sword','tide','treasure','vessel','voyage','whale',
        'wind','yo-ho-ho','bucko','shiver','timbers','arr','dead','men','tell','tales',
        'walk','the','plank','sea','dog','high','seas','seven','seas','buried','gold',
        'cannon','ball','hook','hand','poop','deck','sail','ho','thar','she','blows'
      ];

      const CORPORATE_WORDS = [
        'synergy','leverage','paradigm','ecosystem','scalable','stakeholder','deliverable',
        'bandwidth','holistic','proactive','streamline','actionable','innovate','disrupt',
        'optimize','benchmark','milestone','pipeline','roadmap','agile','alignment',
        'best-in-class','bottom-line','circle-back','core-competency','cross-functional',
        'deep-dive','drill-down','empower','end-to-end','evangelize','game-changer',
        'granular','growth-hack','ideate','impact','incentivize','initiative','iterate',
        'key-performance','learnings','low-hanging','fruit','metric','move-the-needle',
        'next-generation','north-star','onboarding','operationalize','pain-point','pivot',
        'platform','robust','roi','runway','scale','seamless','silo','solution',
        'space','sprint','strategy','sustainable','takeaway','thought-leadership',
        'touchpoint','transform','transparency','value-add','velocity','vertical',
        'visibility','wheelhouse','win-win','workflow','world-class','zero-sum',
        'blockchain','cloud-native','data-driven','digital-first','enterprise',
        'future-proof','hyperscale','machine-learning','microservice','omnichannel',
        'real-time','results-oriented','revenue','customer-centric','market-leading',
        'mission-critical','resource','talent','capital','integration','deployment'
      ];

      const BACON_WORDS = [
        'bacon','ipsum','dolor','amet','biltong','bresaola','buffalo','burgdoggen',
        'capicola','chicken','chislic','chuck','corned','beef','cow','cupim','doner',
        'drumstick','fatback','filet','mignon','flank','frankfurter','ground','round',
        'ham','hock','hamburger','jowl','kevin','kielbasa','landjaeger','leberkas',
        'meatball','meatloaf','pancetta','pastrami','pepperoni','picanha','pork','belly',
        'chop','loin','prosciutto','ribeye','rump','salami','sausage','shank',
        'shankle','short','loin','ribs','shoulder','sirloin','spare','ribs','steak',
        'strip','swine','t-bone','tail','tenderloin','tongue','tri-tip','turkey',
        'venison','andouille','barbecue','brisket','carnitas','chorizo','cured',
        'grilled','jerky','lamb','leg','marinated','meat','oven-roasted','pulled',
        'rack','roast','seasoned','smoked','spicy','stuffed','wagyu','bratwurst',
        'coppa','guanciale','lonza','mortadella','nduja','porchetta','sopressata',
        'speck','boudin','tasso','confit','rillettes','terrine','galantine'
      ];

      const WORD_BANKS = { classic: CLASSIC_WORDS, hipster: HIPSTER_WORDS, pirate: PIRATE_WORDS, corporate: CORPORATE_WORDS, bacon: BACON_WORDS };

      const CLASSIC_OPENER = 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.';

      function randInt(min, max) {
        return Math.floor(Math.random() * (max - min + 1)) + min;
      }

      function pickRandom(arr) {
        return arr[Math.floor(Math.random() * arr.length)];
      }

      function capitalize(str) {
        return str.charAt(0).toUpperCase() + str.slice(1);
      }

      function generateSentence(words, minW, maxW) {
        const count = randInt(minW, maxW);
        const selected = [];
        for (let i = 0; i < count; i++) {
          selected.push(pickRandom(words));
        }
        return capitalize(selected.join(' ')) + '.';
      }

      function generateParagraph(words, minSentences, maxSentences) {
        const count = randInt(minSentences, maxSentences);
        const sentences = [];
        for (let i = 0; i < count; i++) {
          sentences.push(generateSentence(words, 6, 18));
        }
        return sentences.join(' ');
      }

      function generateByParagraphs(numParagraphs, style, startClassic) {
        const words = WORD_BANKS[style];
        const paragraphs = [];
        for (let i = 0; i < numParagraphs; i++) {
          paragraphs.push(generateParagraph(words, 4, 8));
        }
        if (startClassic && paragraphs.length > 0) {
          paragraphs[0] = CLASSIC_OPENER + ' ' + paragraphs[0];
        }
        return paragraphs;
      }

      function generateByWords(targetWords, style, startClassic) {
        const words = WORD_BANKS[style];
        let result = [];
        if (startClassic) {
          const openerWords = CLASSIC_OPENER.replace('.', '').split(/\s+/);
          result = result.concat(openerWords);
        }
        while (result.length < targetWords) {
          result.push(pickRandom(words));
        }
        result = result.slice(0, targetWords);
        // Split into paragraphs of ~40-60 words
        const paragraphs = [];
        let i = 0;
        while (i < result.length) {
          const pLen = Math.min(randInt(40, 60), result.length - i);
          const chunk = result.slice(i, i + pLen);
          // Form sentences from chunk
          const sentences = [];
          let j = 0;
          while (j < chunk.length) {
            const sLen = Math.min(randInt(6, 15), chunk.length - j);
            const s = chunk.slice(j, j + sLen);
            sentences.push(capitalize(s.join(' ')) + '.');
            j += sLen;
          }
          paragraphs.push(sentences.join(' '));
          i += pLen;
        }
        return paragraphs;
      }

      function generateBySentences(targetSentences, style, startClassic) {
        const words = WORD_BANKS[style];
        const sentences = [];
        if (startClassic && targetSentences > 0) {
          sentences.push(CLASSIC_OPENER);
          targetSentences--;
        }
        for (let i = 0; i < targetSentences; i++) {
          sentences.push(generateSentence(words, 6, 18));
        }
        // Group into paragraphs of 3-6 sentences
        const paragraphs = [];
        let i = 0;
        while (i < sentences.length) {
          const pLen = Math.min(randInt(3, 6), sentences.length - i);
          paragraphs.push(sentences.slice(i, i + pLen).join(' '));
          i += pLen;
        }
        return paragraphs;
      }

      function generateByBytes(targetBytes, style, startClassic) {
        const words = WORD_BANKS[style];
        let text = startClassic ? CLASSIC_OPENER + ' ' : '';
        while (new TextEncoder().encode(text).length < targetBytes) {
          text += pickRandom(words) + ' ';
        }
        // Trim to target byte size
        const encoder = new TextEncoder();
        while (encoder.encode(text).length > targetBytes && text.length > 0) {
          text = text.slice(0, -1);
        }
        // Split into paragraphs roughly
        const wordsArr = text.trim().split(/\s+/);
        const paragraphs = [];
        let i = 0;
        while (i < wordsArr.length) {
          const pLen = Math.min(randInt(40, 60), wordsArr.length - i);
          const chunk = wordsArr.slice(i, i + pLen);
          const sentences = [];
          let j = 0;
          while (j < chunk.length) {
            const sLen = Math.min(randInt(6, 15), chunk.length - j);
            const s = chunk.slice(j, j + sLen);
            sentences.push(capitalize(s.join(' ')) + '.');
            j += sLen;
          }
          paragraphs.push(sentences.join(' '));
          i += pLen;
        }
        return paragraphs;
      }

      function generate() {
        const mode = modeEl.value;
        const count = Math.max(1, parseInt(countEl.value) || 1);
        const style = styleEl.value;
        const startClassic = optStart.checked;
        const usePtags = optPtags.checked;
        const useBreaks = optBreaks.checked;

        let paragraphs;
        switch (mode) {
          case 'paragraphs': paragraphs = generateByParagraphs(count, style, startClassic); break;
          case 'words': paragraphs = generateByWords(count, style, startClassic); break;
          case 'sentences': paragraphs = generateBySentences(count, style, startClassic); break;
          case 'bytes': paragraphs = generateByBytes(count, style, startClassic); break;
          default: paragraphs = generateByParagraphs(count, style, startClassic);
        }

        let output;
        if (usePtags) {
          output = paragraphs.map(p => '<p>' + p + '</p>').join(useBreaks ? '\n\n' : '\n');
        } else {
          output = paragraphs.join(useBreaks ? '\n\n' : '\n');
        }

        outputEl.textContent = output;

        // Stats
        const plainText = paragraphs.join(' ');
        const wordCount = plainText.trim().split(/\s+/).filter(Boolean).length;
        const charCount = plainText.length;
        const byteCount = new TextEncoder().encode(output).length;
        statsEl.innerHTML = '<span>' + paragraphs.length + ' paragraphs</span><span>' + wordCount + ' words</span><span>' + charCount + ' characters</span><span>' + byteCount + ' bytes</span>';
      }

      btnGenerate.addEventListener('click', generate);

      btnCopy.addEventListener('click', () => {
        const text = outputEl.textContent;
        if (!text) return;
        navigator.clipboard.writeText(text).then(() => {
          const original = btnCopy.textContent;
          btnCopy.textContent = 'Copied!';
          setTimeout(() => { btnCopy.textContent = original; }, 1500);
        });
      });

      // Update max/defaults based on mode
      modeEl.addEventListener('change', () => {
        const mode = modeEl.value;
        switch (mode) {
          case 'paragraphs': countEl.value = 5; countEl.max = 100; break;
          case 'words': countEl.value = 200; countEl.max = 10000; break;
          case 'sentences': countEl.value = 20; countEl.max = 500; break;
          case 'bytes': countEl.value = 1000; countEl.max = 100000; break;
        }
      });

      // Generate on load
      generate();
    });
  </script>

