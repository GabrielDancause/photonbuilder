---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Academic Citation Styles Guide: APA, MLA, Chicago & More',
  description: 'Compare academic citation styles including APA 7th, MLA 9th, Chicago, Harvard, IEEE, and more. Learn formatting rules, in-text citations, and when to cite.',
  category: 'guide',
  published: '2026-05-15'
};

const SITE_ID = 'papyruspeople';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Papyrus People"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "When should I cite a source vs. paraphrasing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You must cite a source whenever you use an idea, data, or specific wording that is not your own. Paraphrasing also requires a citation because while the words are yours, the original idea belongs to another author."
        }
      },
      {
        "@type": "Question",
        "name": "What is the main difference between APA and MLA styles?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "APA style (American Psychological Association) is typically used in social sciences and emphasizes the date of publication. MLA style (Modern Language Association) is common in the humanities and emphasizes the author and page number."
        }
      },
      {
        "@type": "Question",
        "name": "How can I avoid accidental plagiarism?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To avoid accidental plagiarism, keep meticulous notes of your sources during research, use quotation marks for direct quotes, and always cite sources for both direct quotes and paraphrased ideas."
        }
      },
      {
        "@type": "Question",
        "name": "Are citation generators reliable?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Citation generators like Zotero and Mendeley are excellent tools for organizing and generating citations, but they are not perfect. You should always manually verify the generated citations against an official style guide."
        }
      },
      {
        "@type": "Question",
        "name": "Which citation style should I use for a legal paper?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Bluebook is the standard citation style for legal documents and academic legal writing in the United States."
        }
      }
    ]
  }
];

const citationStyles = [
  {
    name: "APA 7th Edition",
    discipline: "Social Sciences, Education, Psychology",
    inText: "(Author, Year)",
    bibFormat: "Author, A. A. (Year). Title of work. Publisher.",
    examples: [
      { type: "Book", text: "Miller, T. (2021). *The art of writing*. Academic Press." },
      { type: "Journal", text: "Smith, J., & Doe, R. (2022). Innovations in linguistics. *Journal of Textology*, 15(2), 45-60. https://doi.org/10.1001/jot.2022.15" },
      { type: "Website", text: "World Health Organization. (2023, March 12). *Global health trends*. https://www.who.int/reports/global-trends" }
    ]
  },
  {
    name: "MLA 9th Edition",
    discipline: "Humanities, Literature, Arts",
    inText: "(Author Page)",
    bibFormat: "Author, First Name. *Title of Work*. Publisher, Year.",
    examples: [
      { type: "Book", text: "Gaiman, Neil. *Stardust*. William Morrow, 1999." },
      { type: "Journal", text: "Brown, Linda. \"Symbolism in Modern Poetry.\" *Literary Review*, vol. 42, no. 3, 2020, pp. 210-225." },
      { type: "Website", text: "National Endowment for the Arts. \"The Importance of Reading.\" *NEA Resources*, 15 Jan. 2024, www.arts.gov/reading-importance." }
    ]
  },
  {
    name: "Chicago/Turabian (17th Ed.)",
    discipline: "History, Business, Fine Arts",
    inText: "Footnotes or (Author Year, Page)",
    bibFormat: "Author Last, First. *Title of Work*. City: Publisher, Year.",
    examples: [
      { type: "Book", text: "Pollan, Michael. *The Omnivore's Dilemma*. New York: Penguin Group, 2006." },
      { type: "Journal", text: "White, Sarah. \"The Economics of Publishing.\" *Business History Quarterly* 88, no. 4 (Winter 2014): 677-701." },
      { type: "Website", text: "Google. \"Privacy Policy.\" Last modified January 1, 2024. https://policies.google.com/privacy." }
    ]
  },
  {
    name: "Harvard",
    discipline: "Natural Sciences, Social Sciences (UK/Australia)",
    inText: "(Author, Year)",
    bibFormat: "Author, Initial. (Year) *Title of work*. Publisher.",
    examples: [
      { type: "Book", text: "Jones, P. (2018) *Environmental science*. London: Green Books." },
      { type: "Journal", text: "Watson, J. (2019) 'Climate change impacts', *Scientific American*, 12(4), pp. 88-102." },
      { type: "Website", text: "BBC News (2024) *World events update*. Available at: https://www.bbc.com/news (Accessed: 10 May 2024)." }
    ]
  },
  {
    name: "IEEE",
    discipline: "Engineering, Computer Science, IT",
    inText: "[Number]",
    bibFormat: "[Number] Author, *Title of Work*. Publisher, Year.",
    examples: [
      { type: "Book", text: "[1] K. Thompson, *Unix System Programming*. Prentice Hall, 1985." },
      { type: "Journal", text: "[2] M. S. Gupta, \"Power Amplifier Design,\" *IEEE Trans. Microwave Theory*, vol. 45, pp. 121-130, Jan. 2020." },
      { type: "Website", text: "[3] NASA. \"Mars Mission Details.\" nasa.gov. https://www.nasa.gov/mars (accessed Feb. 14, 2024)." }
    ]
  },
  {
    name: "AMA (11th Ed.)",
    discipline: "Medicine, Health, Biological Sciences",
    inText: "Superscript Number¹",
    bibFormat: "Author. Title of work. Publisher; Year.",
    examples: [
      { type: "Book", text: "1. Fauci AS, Braunwald E. *Harrison's Principles of Internal Medicine*. McGraw-Hill; 2008." },
      { type: "Journal", text: "2. Kesselheim AS. Drug development and FDA approval. *JAMA*. 2015;314(2):115-116. doi:10.1001/jama.2015.6534" },
      { type: "Website", text: "3. Centers for Disease Control and Prevention. Flu activity. Published October 10, 2023. Accessed March 1, 2024. https://www.cdc.gov/flu" }
    ]
  },
  {
    name: "Vancouver",
    discipline: "Medicine, Clinical Sciences",
    inText: "(Number) or [Number]",
    bibFormat: "Author. Title. Publisher; Year.",
    examples: [
      { type: "Book", text: "1. Rang HP, Dale MM. Pharmacology. Churchill Livingstone; 2007." },
      { type: "Journal", text: "2. Halpern SD. Solidarity and biomedical research. N Engl J Med. 2004 Sep 16;351(12):1214-22." },
      { type: "Website", text: "3. Diabetes Australia. Diabetes in Australia [Internet]. Canberra: Diabetes Australia; 2023 [cited 2024 May 12]. Available from: https://www.diabetesaustralia.com.au" }
    ]
  },
  {
    name: "Bluebook",
    discipline: "Law, Legal Studies",
    inText: "Footnotes",
    bibFormat: "Author, *Title* (Year).",
    examples: [
      { type: "Book", text: "Lawrence Lessig, *Free Culture* (2004)." },
      { type: "Journal", text: "Cass R. Sunstein, *Social Norms and Social Roles*, 96 Colum. L. Rev. 903 (1996)." },
      { type: "Website", text: "U.S. Dep't of Justice, *Identity Theft* (May 10, 2024), https://www.justice.gov/idtheft." }
    ]
  }
];
---

<SiteLayout
  site={SITE_ID}
  title={meta.title}
  description={meta.description}
  schema={JSON.stringify(schema)}
  canonical="https://papyruspeople.photonbuilder.com/citation-styles-guide"
>
  <div class="page-content">
    <div class="hero">
      <h1>Academic Citation Styles Guide</h1>
      <p>A master comparison of the most common citation formats used in academia and professional writing.</p>
    </div>

    <div class="content-section card">
      <h2>Why Proper Citation Matters</h2>
      <p>Citing your sources is the foundation of academic integrity. It gives credit to original authors, provides evidence for your arguments, and allows readers to locate your sources for further research.</p>

      <h3>Citing vs. Paraphrasing</h3>
      <p><strong>Citing</strong> involves using the exact words of an author within quotation marks. <strong>Paraphrasing</strong> is rewriting an idea in your own words. <strong>Both require a citation.</strong> Failing to cite a paraphrased idea is one of the most common forms of accidental plagiarism.</p>

      <h3>Avoiding Plagiarism</h3>
      <ul>
        <li>Keep track of every source you read during your research.</li>
        <li>Use quotation marks for any phrase longer than three words taken directly from a source.</li>
        <li>When in doubt, cite it. It is better to over-cite than to under-cite.</li>
        <li>Use plagiarism checkers to verify your work before submission.</li>
      </ul>
    </div>

    <div class="content-section card">
      <h2>Citation Style Comparison</h2>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Style</th>
              <th>Common Disciplines</th>
              <th>In-Text Format</th>
            </tr>
          </thead>
          <tbody>
            {citationStyles.map(style => (
              <tr>
                <td><strong>{style.name}</strong></td>
                <td>{style.discipline}</td>
                <td><code>{style.inText}</code></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {citationStyles.map(style => (
      <div class="content-section card">
        <h2>{style.name}</h2>
        <p><strong>Primary Discipline:</strong> {style.discipline}</p>
        <p><strong>Bibliography Format:</strong> <code>{style.bibFormat}</code></p>

        <div class="example-box">
          <h3>Examples:</h3>
          <ul>
            {style.examples.map(ex => (
              <li><strong>{ex.type}:</strong> <span set:html={ex.text.replace(/\*(.*?)\*/g, '<em>$1</em>')} /></li>
            ))}
          </ul>
        </div>
      </div>
    ))}

    <div class="content-section card">
      <h2>Citation Generators & Tools</h2>
      <p>Managing dozens of references manually is prone to error. Professional researchers use reference management software to automate the process.</p>

      <div class="tool-grid">
        <div class="tool-card">
          <h3>Zotero</h3>
          <p>A free, open-source tool that senses content in your web browser and allows you to add it to your library with a single click. Excellent for organizing research.</p>
        </div>
        <div class="tool-card">
          <h3>Mendeley</h3>
          <p>A free reference manager and academic social network that helps you organize your research, collaborate with others online, and discover the latest research.</p>
        </div>
        <div class="tool-card">
          <h3>EndNote</h3>
          <p>A premium industry-standard tool used by many universities and researchers for managing complex bibliographies and large-scale research projects.</p>
        </div>
      </div>
    </div>

    <div class="content-section card">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map((faq: any) => (
        <div class="faq-item">
          <h3>{faq.name}</h3>
          <p>{faq.acceptedAnswer.text}</p>
        </div>
      ))}
    </div>
  </div>

  <style>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; margin-bottom: 2.5rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color, #2a2418); border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }

    .content-section h2 { font-size: 1.75rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--accent-color); }
    .content-section h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; color: var(--text-primary); }
    .content-section p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 1rem; }

    ul { color: var(--text-secondary); line-height: 1.7; margin-bottom: 1rem; padding-left: 1.5rem; }
    li { margin-bottom: 0.5rem; }

    .example-box { background: rgba(0,0,0,0.2); border-radius: 8px; padding: 1.25rem; margin-top: 1rem; border: 1px dashed var(--border-color); }
    .example-box h3 { margin-top: 0; font-size: 1.1rem; }
    .example-box ul { margin-bottom: 0; list-style-type: none; padding-left: 0; }
    .example-box li { margin-bottom: 0.75rem; font-family: var(--font-ui); }
    .example-box li:last-child { margin-bottom: 0; }

    .tool-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }
    .tool-card { background: rgba(255,255,255,0.03); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border-color); }
    .tool-card h3 { margin-top: 0; color: var(--accent-color); }
    .tool-card p { margin-bottom: 0; font-size: 0.95rem; }

    .table-container { overflow-x: auto; margin: 1.5rem 0; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th, td { padding: 1rem; border-bottom: 1px solid var(--border-color); }
    th { color: var(--accent-color); font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; }
    td { color: var(--text-secondary); }

    code { font-family: var(--font-mono); background: rgba(212, 160, 23, 0.1); color: var(--accent-color); padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; }

    .faq-item { border-bottom: 1px solid var(--border-color, #2a2418); padding-bottom: 1.25rem; margin-bottom: 1.25rem; }
    .faq-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .faq-item h3 { margin-top: 0; color: var(--text-primary); }

    @media (max-width: 600px) {
      .page-content { padding: 1.5rem 1rem; }
      .hero h1 { font-size: 2rem; }
      .card { padding: 1.5rem; }
    }
  </style>
</SiteLayout>
