          return styleObj.prefix + text + styleObj.suffix;
        }

        // Handle character mapping
        const { chars, base, nums } = styleObj;
        const baseArr = Array.from(base || '');
        const charsArr = Array.from(chars || '');
        const map = new Map();

        for (let i = 0; i < baseArr.length; i++) {
          if (i < charsArr.length) {
            map.set(baseArr[i], charsArr[i]);
          }
        }

        if (nums) {
          const numsArr = Array.from(nums);
          for (let i = 0; i < numBase.length; i++) {
            if (i < numsArr.length) {
              map.set(numBase[i], numsArr[i]);
            }
          }
        }

        let result = '';
        for (const char of text) {
          result += map.get(char) || char;
        }

        if (styleObj.reverse) {
          result = Array.from(result).reverse().join('');
        }

        return result;
      }

      function generateZalgo(text) {
        const intensities = {
          mild: { above: 1, below: 1, maxMarks: 2 },
          medium: { above: 2, below: 2, maxMarks: 4 },
          extreme: { above: 4, below: 4, maxMarks: 8 }
        };

        const intensity = intensities[zalgoIntensity.current];
        let result = '';

        for (const char of text) {
          result += char;

          if (char.match(/[a-zA-Z]/)) {
            // Add above marks
            for (let i = 0; i < intensity.above; i++) {
              if (Math.random() > 0.5) {
                const mark = zalgoMarks.above[Math.floor(Math.random() * zalgoMarks.above.length)];
                result += mark;
              }
            }

            // Add below marks  
            for (let i = 0; i < intensity.below; i++) {
              if (Math.random() > 0.5) {
                const mark = zalgoMarks.below[Math.floor(Math.random() * zalgoMarks.below.length)];
                result += mark;
              }
            }
          }
        }

        return result;
      }

      function applyCombinings(text, marks) {
        let result = '';
        for (const char of text) {
          result += char;
          marks.forEach(mark => result += mark);
        }
        return result;
      }

      function updateResults() {
        const text = input.value || 'The quick brown fox jumps over the lazy dog';
        const len = Array.from(input.value).length;
        charCount.textContent = len + ' character' + (len !== 1 ? 's' : '');

        // Update all style categories
        updateStyleCategory('popular-results', styles.popular, text);
        updateStyleCategory('fancy-results', styles.fancy, text);
        updateStyleCategory('glitch-results', styles.glitch, text);
        updateStyleCategory('decorative-results', styles.decorative, text);
      }

      function updateStyleCategory(containerId, categoryStyles, text) {
        const container = document.getElementById(containerId);
        container.innerHTML = '';

        Object.entries(categoryStyles).forEach(([name, styleObj]) => {
          const converted = convertText(text, styleObj, name);

          const resultCard = document.createElement('div');
          resultCard.className = 'result-card';

          const header = document.createElement('div');
          header.className = 'result-header';

          const nameSpan = document.createElement('span');
          nameSpan.className = 'result-name';
          nameSpan.textContent = name;

          const copyBtn = document.createElement('button');
          copyBtn.className = 'copy-btn';
          copyBtn.setAttribute('data-text', converted);
          copyBtn.textContent = 'Copy';

          header.appendChild(nameSpan);
          header.appendChild(copyBtn);

          const textDiv = document.createElement('div');
          textDiv.className = 'result-text';
          textDiv.textContent = converted;

          resultCard.appendChild(header);
          resultCard.appendChild(textDiv);
          container.appendChild(resultCard);
        });
      }

      function handleCopy(btn, textToCopy) {
        navigator.clipboard.writeText(textToCopy).then(() => {
          const orig = btn.textContent;
          btn.textContent = 'Copied! ✓';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = orig;
            btn.classList.remove('copied');
          }, 2000);
        });
      }

      // Event listeners
      document.addEventListener('click', (e) => {
        if (e.target.classList.contains('copy-btn')) {
          handleCopy(e.target, e.target.getAttribute('data-text'));
        }
        
        if (e.target.classList.contains('intensity-btn')) {
          document.querySelectorAll('.intensity-btn').forEach(btn => btn.classList.remove('active'));
          e.target.classList.add('active');
          zalgoIntensity.current = e.target.dataset.intensity;
          updateResults();
        }
      });

      clearBtn.addEventListener('click', () => {
        input.value = '';
        updateResults();
        input.focus();
      });

      input.addEventListener('input', updateResults);

      // Initial render
      updateResults();
    });
  </script>

