          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        },
        'Sans-Serif Bold Italic': {
          chars: 'рқҳјрқҳҪрқҳҫрқҳҝрқҷҖрқҷҒрқҷӮрқҷғрқҷ„рқҷ…рқҷҶрқҷҮрқҷҲрқҷүрқҷҠрқҷӢрқҷҢрқҷҚрқҷҺрқҷҸрқҷҗрқҷ‘рқҷ’рқҷ“рқҷ”рқҷ•рқҷ–рқҷ—рқҷҳрқҷҷрқҷҡрқҷӣрқҷңрқҷқрқҷһрқҷҹрқҷ рқҷЎрқҷўрқҷЈрқҷӨрқҷҘрқҷҰрқҷ§рқҷЁрқҷ©рқҷӘрқҷ«рқҷ¬рқҷӯрқҷ®рқҷҜ',
