          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        },
        'Monospace': {
          chars: '𝙰𝙱𝙲𝙳𝙴𝙵𝙶𝙷𝙸𝙹𝙺𝙻𝙼𝙽𝙾𝙿𝚀𝚁𝚂𝚃𝚄𝚅𝚆𝚇𝚈𝚉𝚊𝚋𝚌𝚍𝚎𝚏𝚐𝚑𝚒𝚓𝚔𝚕𝚖𝚗𝚘𝚙𝚚𝚛𝚜𝚝𝚞𝚟𝚠𝚡𝚢𝚣',
          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        },
        'Double Struck': {
          chars: '𝔸𝔹ℂ𝔻𝔼𝔽𝔾ℍ𝕀𝕁𝕂𝕃𝕄ℕ𝕆ℙℚℝ𝕊𝕋𝕌𝕍𝕎𝕏𝕐ℤ𝕒𝕓𝕔𝕕𝕖𝕗𝕘𝕙𝕚𝕛𝕜𝕝𝕞𝕟𝕠𝕡𝕢𝕣𝕤𝕥𝕦𝕧𝕨𝕩𝕪𝕫',
          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        },
        'Circled': {
          chars: 'ⒶⒷⒸⒹⒺⒻⒼⒽⒾⒿⓀⓁⓂⓃⓄⓅⓆⓇⓈⓉⓊⓋⓌⓍⓎⓏⓐⓑⓒⓓⓔⓕⓖⓗⓘⓙⓚⓛⓜⓝⓞⓟⓠⓡⓢⓣⓤⓥⓦⓧⓨⓩ',
          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        },
        'Squared': {
          chars: '🄰🄱🄲🄳🄴🄵🄶🄷🄸🄹🄺🄻🄼🄽🄾🄿🅀🅁🅂🅃🅄🅅🅆🅇🅈🅉🄰🄱🄲🄳🄴🄵🄶🄷🄸🄹🄺🄻🄼🄽🄾🄿🅀🅁🅂🅃🅄🅅🅆🅇🅈🅉',
          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        },
        'Tiny': {
          chars: 'ᴀʙᴄᴅᴇғɢʜɪᴊᴋʟᴍɴᴏᴘǫʀsᴛᴜᴠᴡxʏᴢᴀʙᴄᴅᴇғɢʜɪᴊᴋʟᴍɴᴏᴘǫʀsᴛᴜᴠᴡxʏᴢ',
          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        },
        'Upside Down': {
          chars: '∀𐐒ƆᗡƎℲ⅁HIſʞ˥WNOԀΌᴚS⊥∩ΛMX⅄Zɐqɔpǝɟƃɥᴉɾʞlɯuodbɹsʇnʌʍxʎz',
          base:  'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'
        }
      };

      // Create a map string helper for unicode length
      function convertText(text, styleObj) {
        if (!text) return '';
        const { chars, base } = styleObj;

        // Build the char map
        // Due to surrogate pairs, simple split('') doesn't work for unicode
        const baseArr = Array.from(base);
        const charsArr = Array.from(chars);
        const map = new Map();

        for (let i = 0; i < baseArr.length; i++) {
          if (i < charsArr.length) {
            map.set(baseArr[i], charsArr[i]);
          }
        }

        let result = '';
        for (const char of text) {
          result += map.get(char) || char;
        }

        // Handle Upside Down logic (reverse text)
        if (styleObj.chars.startsWith('∀')) {
          result = Array.from(result).reverse().join('');
        }

        return result;
      }

      function updateResults() {
        const text = input.value || 'The quick brown fox jumps over the lazy dog';
        resultsContainer.innerHTML = '';

        Object.entries(styles).forEach(([name, styleObj]) => {
          const converted = convertText(text, styleObj);

          const resultCard = document.createElement('div');
          resultCard.className = 'result-card';

          const header = document.createElement('div');
          header.className = 'result-header';

          const nameSpan = document.createElement('span');
          nameSpan.className = 'result-name';
          nameSpan.textContent = name;

          const copyBtn = document.createElement('button');
          copyBtn.className = 'copy-btn';
          copyBtn.setAttribute('data-text', converted);
          copyBtn.textContent = 'Copy';

          header.appendChild(nameSpan);
          header.appendChild(copyBtn);

          const textDiv = document.createElement('div');
          textDiv.className = 'result-text';
          textDiv.textContent = converted;

          resultCard.appendChild(header);
          resultCard.appendChild(textDiv);

          resultsContainer.appendChild(resultCard);
        });
      }

      resultsContainer.addEventListener('click', (e) => {
        if (e.target.classList.contains('copy-btn')) {
          const textToCopy = e.target.getAttribute('data-text');
          navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = e.target.textContent;
            e.target.textContent = 'Copied!';
            e.target.classList.add('copied');
            setTimeout(() => {
              e.target.textContent = originalText;
              e.target.classList.remove('copied');
            }, 2000);
          });
        }
      });

      input.addEventListener('input', updateResults);

      // Initial render
      updateResults();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; margin-bottom: 2.5rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color, #2a2418); border-radius: 12px; padding: 2rem; }
    .input-group { margin-bottom: 2rem; }
    .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: var(--text-primary); }
    textarea { width: 100%; padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color, #2a2418); background: var(--bg-color, #0a0806); color: var(--text-primary); font-family: inherit; font-size: 1rem; resize: vertical; transition: border-color 0.2s; }
    textarea:focus { outline: none; border-color: var(--accent-color, #D4A574); }

    .results-grid { display: flex; flex-direction: column; gap: 1rem; }
    .result-card { background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 8px; padding: 1rem; transition: border-color 0.2s; }
    .result-card:hover { border-color: var(--accent-color, #D4A574); }
    .result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
    .result-name { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
    .copy-btn { background: var(--card-bg); border: 1px solid var(--border-color, #2a2418); color: var(--text-primary); padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover { background: var(--accent-color, #D4A574); color: #000; border-color: var(--accent-color, #D4A574); }
    .copy-btn.copied { background: #10B981; color: #fff; border-color: #10B981; }
    .result-text { font-size: 1.2rem; word-break: break-all; color: var(--text-primary); }
  </style>
</SiteLayout>
