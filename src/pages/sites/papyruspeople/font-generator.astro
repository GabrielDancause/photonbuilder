---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Fancy Font Generator',
  description: 'Convert normal text into fancy, cursive, bold, italic, and decorative font styles instantly. Copy and paste stylish Unicode fonts for social media and bios.',
  category: 'tool',
  published: '2026-03-24'
};

const SITE_ID = 'papyruspeople';

const schema = [{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Fancy Font Generator",
  "description": "Convert normal text into fancy, cursive, bold, and italic fonts instantly.",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All"
}];
---

<SiteLayout
  site={SITE_ID}
  title={meta.title}
  description={meta.description}
  schema={schema} canonical="https://papyruspeople.photonbuilder.com/font-generator"
>
  <div class="page-content">
    <div class="hero">
      <h1>Fancy Font Generator</h1>
      <p>Convert your text into fancy, cursive, bold, and italic styles.</p>
    </div>

    <div class="tool-container card">
      <div class="input-group">
        <label for="text-input">Your Text</label>
        <textarea id="text-input" placeholder="Type or paste your text here..." rows="3"></textarea>
      </div>

      <div id="results" class="results-grid"></div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('text-input');
      const resultsContainer = document.getElementById('results');

      const styles = {
