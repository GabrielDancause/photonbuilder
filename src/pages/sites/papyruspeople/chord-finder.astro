---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Chord Finder — Music Theory Reference & Chord Progression Builder',
  description: 'Interactive chord finder and music theory reference. Look up any chord — major, minor, 7th, diminished, augmented, sus — with piano keyboard visualization, guitar fretboard diagrams, and a chord progression builder.',
  category: 'tool',
  published: '2026-03-24'
};

const SITE_ID = 'papyruspeople';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Chord Finder — Music Theory Reference",
    "description": "Interactive music chord reference with piano and guitar visualizations. Look up chord notes, intervals, and build common chord progressions.",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "All",
    "url": "https://papyruspeople.photonbuilder.com/chord-finder"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What notes are in a C major chord?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A C major chord contains the notes C, E, and G. It is built using the major triad formula: root (C), major third (E, 4 semitones above the root), and perfect fifth (G, 7 semitones above the root). This is the most common starting chord for beginners learning piano or guitar."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between major and minor chords?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The difference lies in the third interval. A major chord uses a major third (4 semitones above the root), giving it a bright, happy sound. A minor chord uses a minor third (3 semitones above the root), creating a darker, more melancholic tone. Both share the same root and perfect fifth — only the third changes."
        }
      },
      {
        "@type": "Question",
        "name": "What are the most common chord progressions in popular music?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most common chord progressions include I-V-vi-IV (used in countless pop hits like 'Let It Be' and 'No Woman No Cry'), ii-V-I (the foundation of jazz harmony), I-IV-V (classic blues and rock), and vi-IV-I-V (the 'Axis of Awesome' progression). These Roman numeral patterns work in any key — just apply them to the major scale of your chosen root note."
        }
      },
      {
        "@type": "Question",
        "name": "What does 'sus' mean in a chord name like Csus4?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 'sus' stands for 'suspended.' In a sus chord, the third of the chord is replaced — a sus4 replaces it with the perfect fourth, and a sus2 replaces it with the major second. This creates an open, unresolved sound because the chord is neither major nor minor. Sus chords often resolve back to the major or minor chord of the same root."
        }
      },
      {
        "@type": "Question",
        "name": "How do I read a guitar chord diagram?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A guitar chord diagram shows the fretboard vertically. The six vertical lines represent the six strings (low E on the left to high E on the right). Horizontal lines are frets. Dots show where to press your fingers. An 'X' above a string means don't play it, and an 'O' means play it open (unfretted). Numbers on dots may indicate which finger to use. The top of the diagram represents the nut unless a fret number is shown."
        }
      }
    ]
  }
];

const relatedPages = [
  { url: '/sites/papyruspeople/metronome', title: 'Metronome', description: 'Keep perfect time with an online metronome' },
  { url: '/sites/papyruspeople/frequency-generator', title: 'Frequency Generator', description: 'Generate audio tones at any frequency' }
];
---

<SiteLayout
  site={SITE_ID}
  title={meta.title}
  description={meta.description}
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Chord Finder</h1>
      <p>Interactive music theory reference. Look up any chord with piano and guitar visualizations, then build progressions.</p>
    </div>

    <div class="tool-container card">
      <div class="options-row">
        <div class="option-group">
          <label for="root-note">Root Note</label>
          <select id="root-note">
            <option value="0">C</option>
            <option value="1">C# / Db</option>
            <option value="2">D</option>
            <option value="3">D# / Eb</option>
            <option value="4">E</option>
            <option value="5">F</option>
            <option value="6">F# / Gb</option>
            <option value="7">G</option>
            <option value="8">G# / Ab</option>
            <option value="9">A</option>
            <option value="10">A# / Bb</option>
            <option value="11">B</option>
          </select>
        </div>
        <div class="option-group">
          <label for="chord-type">Chord Type</label>
          <select id="chord-type">
            <option value="major">Major</option>
            <option value="minor">Minor</option>
            <option value="7">Dominant 7th</option>
            <option value="maj7">Major 7th</option>
            <option value="min7">Minor 7th</option>
            <option value="dim">Diminished</option>
            <option value="aug">Augmented</option>
            <option value="sus2">Sus2</option>
            <option value="sus4">Sus4</option>
            <option value="add9">Add9</option>
          </select>
        </div>
      </div>

      <div class="chord-info" id="chord-info">
        <div class="chord-name" id="chord-name">C Major</div>
        <div class="chord-details">
          <div class="detail-item"><span class="detail-label">Notes</span><span class="detail-value" id="chord-notes">C E G</span></div>
          <div class="detail-item"><span class="detail-label">Formula</span><span class="detail-value" id="chord-formula">1 3 5</span></div>
          <div class="detail-item"><span class="detail-label">Intervals</span><span class="detail-value" id="chord-intervals">R M3 P5</span></div>
        </div>
      </div>

      <div class="viz-section">
        <h3>Piano</h3>
        <div class="piano-wrapper">
          <div class="piano" id="piano"></div>
        </div>
      </div>

      <div class="viz-section">
        <h3>Guitar</h3>
        <div class="guitar-wrapper">
          <svg id="guitar-svg" viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg"></svg>
        </div>
      </div>
    </div>

    <div class="tool-container card" style="margin-top: 2rem;">
      <h2 class="section-title">Chord Progression Builder</h2>
      <div class="prog-controls">
        <div class="option-group">
          <label for="prog-key">Key</label>
          <select id="prog-key">
            <option value="0">C</option>
            <option value="1">C# / Db</option>
            <option value="2">D</option>
            <option value="3">D# / Eb</option>
            <option value="4">E</option>
            <option value="5">F</option>
            <option value="6">F# / Gb</option>
            <option value="7">G</option>
            <option value="8">G# / Ab</option>
            <option value="9">A</option>
            <option value="10">A# / Bb</option>
            <option value="11">B</option>
          </select>
        </div>
        <div class="option-group">
          <label for="prog-preset">Common Progressions</label>
          <select id="prog-preset">
            <option value="">— Select a preset —</option>
            <option value="I-V-vi-IV">I - V - vi - IV (Pop)</option>
            <option value="ii-V-I">ii - V - I (Jazz)</option>
            <option value="I-IV-V">I - IV - V (Blues/Rock)</option>
            <option value="vi-IV-I-V">vi - IV - I - V (Axis)</option>
            <option value="I-vi-IV-V">I - vi - IV - V (50s)</option>
            <option value="I-IV-vi-V">I - IV - vi - V (Alt Pop)</option>
            <option value="ii-V-I-vi">ii - V - I - vi (Jazz Turnaround)</option>
            <option value="I-V-vi-iii-IV-I-IV-V">I - V - vi - iii - IV - I - IV - V (Canon)</option>
          </select>
        </div>
      </div>
      <div class="prog-chords" id="prog-chords"></div>
      <div class="prog-builder">
        <div class="prog-slots" id="prog-slots"></div>
        <div class="prog-actions">
          <button id="btn-add-chord" class="btn-secondary">+ Add Chord</button>
          <button id="btn-clear-prog" class="btn-secondary">Clear</button>
        </div>
      </div>
    </div>

    <div class="content-section card">
      <h2>Understanding Chords and Music Theory</h2>
      <p>A <strong>chord</strong> is three or more notes played simultaneously. Chords are the harmonic foundation of virtually all Western music — from pop and rock to jazz and classical. This <strong>chord finder</strong> helps you look up any chord by root note and type, showing you the exact notes, interval structure, and fingerings for both piano and guitar.</p>
      <p>Chords are built by stacking intervals above a <strong>root note</strong>. The simplest chords are <strong>triads</strong> — three-note chords consisting of a root, third, and fifth. By altering these intervals, you create different chord qualities: major (bright), minor (dark), diminished (tense), and augmented (unstable).</p>

      <h3>Chord Types Explained</h3>
      <p><strong>Major and minor triads</strong> form the foundation of chord theory. <strong>Seventh chords</strong> add a fourth note — the seventh — to the triad, creating richer harmony used extensively in jazz and R&B. <strong>Suspended chords</strong> (sus2 and sus4) replace the third with the second or fourth, producing an open, unresolved quality. <strong>Add9 chords</strong> extend a triad with the ninth (same as the second, but an octave up), adding color without the full complexity of a ninth chord.</p>

      <h3>Using the Chord Progression Builder</h3>
      <p>Chord progressions are sequences of chords that form the harmonic backbone of a song. The <strong>progression builder</strong> lets you chain together chords in any key. Start with a common preset — like the ubiquitous <strong>I-V-vi-IV</strong> pop progression — or build your own from scratch. Roman numerals represent scale degrees, with uppercase for major chords and lowercase for minor chords.</p>
    </div>

    <div class="content-section card">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>What notes are in a C major chord?</h3>
        <p>A C major chord contains the notes C, E, and G. It is built using the major triad formula: root (C), major third (E, 4 semitones above the root), and perfect fifth (G, 7 semitones above the root). This is the most common starting chord for beginners learning piano or guitar.</p>
      </div>

      <div class="faq-item">
        <h3>What is the difference between major and minor chords?</h3>
        <p>The difference lies in the third interval. A major chord uses a major third (4 semitones above the root), giving it a bright, happy sound. A minor chord uses a minor third (3 semitones above the root), creating a darker, more melancholic tone. Both share the same root and perfect fifth — only the third changes.</p>
      </div>

      <div class="faq-item">
        <h3>What are the most common chord progressions in popular music?</h3>
        <p>The most common chord progressions include I-V-vi-IV (used in countless pop hits like "Let It Be" and "No Woman No Cry"), ii-V-I (the foundation of jazz harmony), I-IV-V (classic blues and rock), and vi-IV-I-V (the "Axis of Awesome" progression). These Roman numeral patterns work in any key — just apply them to the major scale of your chosen root note.</p>
      </div>

      <div class="faq-item">
        <h3>What does "sus" mean in a chord name like Csus4?</h3>
        <p>The "sus" stands for "suspended." In a sus chord, the third of the chord is replaced — a sus4 replaces it with the perfect fourth, and a sus2 replaces it with the major second. This creates an open, unresolved sound because the chord is neither major nor minor. Sus chords often resolve back to the major or minor chord of the same root.</p>
      </div>

      <div class="faq-item">
        <h3>How do I read a guitar chord diagram?</h3>
        <p>A guitar chord diagram shows the fretboard vertically. The six vertical lines represent the six strings (low E on the left to high E on the right). Horizontal lines are frets. Dots show where to press your fingers. An "X" above a string means don't play it, and an "O" means play it open (unfretted). Numbers on dots may indicate which finger to use. The top of the diagram represents the nut unless a fret number is shown.</p>
      </div>
    </div>

    <div class="content-section card">
      <h2>Related Tools</h2>
      <div class="related-grid">
        {relatedPages.map(page => (
          <a href={page.url} class="related-card">
            <h3>{page.title}</h3>
            <p>{page.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var rootEl = document.getElementById('root-note');
      var typeEl = document.getElementById('chord-type');
      var chordNameEl = document.getElementById('chord-name');
      var chordNotesEl = document.getElementById('chord-notes');
      var chordFormulaEl = document.getElementById('chord-formula');
      var chordIntervalsEl = document.getElementById('chord-intervals');
      var pianoEl = document.getElementById('piano');
      var guitarSvg = document.getElementById('guitar-svg');
      var progKeyEl = document.getElementById('prog-key');
      var progPresetEl = document.getElementById('prog-preset');
      var progChordsEl = document.getElementById('prog-chords');
      var progSlotsEl = document.getElementById('prog-slots');
      var btnAddChord = document.getElementById('btn-add-chord');
      var btnClearProg = document.getElementById('btn-clear-prog');

      var NOTE_NAMES_SHARP = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
      var NOTE_NAMES_FLAT = ['C','Db','D','Eb','E','F','Gb','G','Ab','A','Bb','B'];
      var NOTE_DISPLAY = ['C','C#/Db','D','D#/Eb','E','F','F#/Gb','G','G#/Ab','A','A#/Bb','B'];

      var CHORD_FORMULAS = {
        major:  { intervals: [0,4,7],     formula: '1 3 5',       names: ['R','M3','P5'] },
        minor:  { intervals: [0,3,7],     formula: '1 b3 5',      names: ['R','m3','P5'] },
        '7':    { intervals: [0,4,7,10],  formula: '1 3 5 b7',    names: ['R','M3','P5','m7'] },
        maj7:   { intervals: [0,4,7,11],  formula: '1 3 5 7',     names: ['R','M3','P5','M7'] },
        min7:   { intervals: [0,3,7,10],  formula: '1 b3 5 b7',   names: ['R','m3','P5','m7'] },
        dim:    { intervals: [0,3,6],     formula: '1 b3 b5',     names: ['R','m3','d5'] },
        aug:    { intervals: [0,4,8],     formula: '1 3 #5',      names: ['R','M3','A5'] },
        sus2:   { intervals: [0,2,7],     formula: '1 2 5',       names: ['R','M2','P5'] },
        sus4:   { intervals: [0,5,7],     formula: '1 4 5',       names: ['R','P4','P5'] },
        add9:   { intervals: [0,4,7,14],  formula: '1 3 5 9',     names: ['R','M3','P5','M9'] }
      };

      var TYPE_SUFFIX = {
        major: '', minor: 'm', '7': '7', maj7: 'maj7', min7: 'm7',
        dim: 'dim', aug: 'aug', sus2: 'sus2', sus4: 'sus4', add9: 'add9'
      };

      /* Guitar chord voicings: [lowE, A, D, G, B, highE] where -1 = muted, 0 = open */
      var GUITAR_VOICINGS = {
        '0_major':  [[-1,3,2,0,1,0]],
        '0_minor':  [[-1,3,1,0,1,0]],
        '0_7':      [[-1,3,2,3,1,0]],
        '0_maj7':   [[-1,3,2,0,0,0]],
        '0_min7':   [[-1,3,1,3,1,0]],
        '0_dim':    [[-1,3,1,0,1,-1]],
        '0_aug':    [[-1,3,2,1,1,0]],
        '0_sus2':   [[-1,3,0,0,1,0]],
        '0_sus4':   [[-1,3,3,0,1,0]],
        '0_add9':   [[-1,3,2,0,3,0]],
        '2_major':  [[-1,-1,0,2,3,2]],
        '2_minor':  [[-1,-1,0,2,3,1]],
        '2_7':      [[-1,-1,0,2,1,2]],
        '2_maj7':   [[-1,-1,0,2,2,2]],
        '2_min7':   [[-1,-1,0,2,1,1]],
        '2_dim':    [[-1,-1,0,1,3,1]],
        '2_aug':    [[-1,-1,0,3,3,2]],
        '2_sus2':   [[-1,-1,0,2,3,0]],
        '2_sus4':   [[-1,-1,0,2,3,3]],
        '2_add9':   [[-1,-1,0,2,3,0]],
        '4_major':  [[0,2,2,1,0,0]],
        '4_minor':  [[0,2,2,0,0,0]],
        '4_7':      [[0,2,0,1,0,0]],
        '4_maj7':   [[0,2,1,1,0,0]],
        '4_min7':   [[0,2,0,0,0,0]],
        '4_dim':    [[-1,-1,2,3,2,0]],
        '4_aug':    [[0,3,2,1,1,0]],
        '4_sus2':   [[0,2,4,1,0,0]],
        '4_sus4':   [[0,2,2,2,0,0]],
        '4_add9':   [[0,2,2,1,0,2]],
        '5_major':  [[1,3,3,2,1,1]],
        '5_minor':  [[1,3,3,1,1,1]],
        '5_7':      [[1,3,1,2,1,1]],
        '5_maj7':   [[1,3,2,2,1,1]],
        '5_min7':   [[1,3,1,1,1,1]],
        '5_dim':    [[-1,-1,3,1,0,1]],
        '5_aug':    [[-1,-1,3,2,2,1]],
        '5_sus2':   [[-1,-1,3,0,1,1]],
        '5_sus4':   [[1,3,3,3,1,1]],
        '5_add9':   [[1,3,3,2,1,3]],
        '7_major':  [[3,2,0,0,0,3]],
        '7_minor':  [[3,1,0,0,3,3]],
        '7_7':      [[3,2,0,0,0,1]],
        '7_maj7':   [[3,2,0,0,0,2]],
        '7_min7':   [[3,1,0,0,3,1]],
        '7_dim':    [[-1,-1,5,3,2,0]],
        '7_aug':    [[3,2,1,0,0,3]],
        '7_sus2':   [[3,0,0,0,3,3]],
        '7_sus4':   [[3,3,0,0,1,3]],
        '7_add9':   [[3,2,0,2,0,3]],
        '9_major':  [[-1,0,2,2,2,0]],
        '9_minor':  [[-1,0,2,2,1,0]],
        '9_7':      [[-1,0,2,0,2,0]],
        '9_maj7':   [[-1,0,2,1,2,0]],
        '9_min7':   [[-1,0,2,0,1,0]],
        '9_dim':    [[-1,0,1,2,1,0]],
        '9_aug':    [[-1,0,3,2,2,1]],
        '9_sus2':   [[-1,0,2,2,0,0]],
        '9_sus4':   [[-1,0,2,2,3,0]],
        '9_add9':   [[-1,0,2,4,2,0]]
      };

      function getChordNotes(root, type) {
        var formula = CHORD_FORMULAS[type];
        return formula.intervals.map(function(i) { return (root + i) % 12; });
      }

      function getNoteName(idx) {
        return NOTE_NAMES_SHARP[idx % 12];
      }

      function getChordDisplayName(root, type) {
        return NOTE_DISPLAY[root] + ' ' + (type === 'major' ? 'Major' : type === 'minor' ? 'Minor' : type === '7' ? '7' : type);
      }

      function updateChord() {
        var root = parseInt(rootEl.value);
        var type = typeEl.value;
        var formula = CHORD_FORMULAS[type];
        var notes = getChordNotes(root, type);

        chordNameEl.textContent = getChordDisplayName(root, type);
        chordNotesEl.textContent = notes.map(function(n) { return NOTE_NAMES_SHARP[n]; }).join('  ');
        chordFormulaEl.textContent = formula.formula;
        chordIntervalsEl.textContent = formula.names.join('  ');

        renderPiano(notes, root);
        renderGuitar(root, type);
      }

      function renderPiano(notes, root) {
        pianoEl.innerHTML = '';
        var startNote = 48; /* C3 */
        var totalKeys = 25; /* 2 octaves + 1 */
        var whiteKeys = [];
        var blackKeys = [];
        var whiteIndex = 0;

        for (var i = 0; i < totalKeys; i++) {
          var midi = startNote + i;
          var noteIdx = midi % 12;
          var isBlack = [1,3,6,8,10].indexOf(noteIdx) !== -1;
          var isActive = notes.indexOf(noteIdx) !== -1;
          var isRoot = noteIdx === root;

          if (isBlack) {
            blackKeys.push({ noteIdx: noteIdx, isActive: isActive, isRoot: isRoot, whiteIndex: whiteIndex });
          } else {
            whiteKeys.push({ noteIdx: noteIdx, isActive: isActive, isRoot: isRoot, index: whiteIndex });
            whiteIndex++;
          }
        }

        var whiteW = 100 / whiteKeys.length;

        whiteKeys.forEach(function(k) {
          var key = document.createElement('div');
          key.className = 'piano-key piano-white' + (k.isActive ? ' active' : '') + (k.isRoot ? ' root' : '');
          key.style.left = (k.index * whiteW) + '%';
          key.style.width = whiteW + '%';
          if (k.isActive) {
            var label = document.createElement('span');
            label.className = 'key-label';
            label.textContent = NOTE_NAMES_SHARP[k.noteIdx];
            key.appendChild(label);
          }
          pianoEl.appendChild(key);
        });

        blackKeys.forEach(function(k) {
          var key = document.createElement('div');
          key.className = 'piano-key piano-black' + (k.isActive ? ' active' : '') + (k.isRoot ? ' root' : '');
          key.style.left = ((k.whiteIndex - 0.35) * whiteW) + '%';
          key.style.width = (whiteW * 0.6) + '%';
          if (k.isActive) {
            var label = document.createElement('span');
            label.className = 'key-label';
            label.textContent = NOTE_NAMES_SHARP[k.noteIdx];
            key.appendChild(label);
          }
          pianoEl.appendChild(key);
        });
      }

      function renderGuitar(root, type) {
        var key = root + '_' + type;
        var voicing = GUITAR_VOICINGS[key];
        if (!voicing) {
          voicing = generateBarreVoicing(root, type);
        }
        var frets = voicing[0];

        var ns = 'http://www.w3.org/2000/svg';
        guitarSvg.innerHTML = '';

        var xStart = 40;
        var xEnd = 170;
        var yStart = 30;
        var yEnd = 160;
        var numFrets = 5;
        var numStrings = 6;
        var stringSpacing = (xEnd - xStart) / (numStrings - 1);
        var fretSpacing = (yEnd - yStart) / numFrets;

        var minFret = 99;
        var maxFret = 0;
        frets.forEach(function(f) {
          if (f > 0) {
            if (f < minFret) minFret = f;
            if (f > maxFret) maxFret = f;
          }
        });
        var startFret = 0;
        if (maxFret > 5) {
          startFret = minFret - 1;
        }

        /* Nut or fret marker */
        if (startFret === 0) {
          var nut = document.createElementNS(ns, 'rect');
          nut.setAttribute('x', xStart - 2);
          nut.setAttribute('y', yStart - 3);
          nut.setAttribute('width', xEnd - xStart + 4);
          nut.setAttribute('height', 4);
          nut.setAttribute('fill', 'var(--text-primary)');
          nut.setAttribute('rx', '1');
          guitarSvg.appendChild(nut);
        } else {
          var fretLabel = document.createElementNS(ns, 'text');
          fretLabel.setAttribute('x', xStart - 18);
          fretLabel.setAttribute('y', yStart + fretSpacing / 2 + 4);
          fretLabel.setAttribute('fill', 'var(--text-secondary)');
          fretLabel.setAttribute('font-size', '11');
          fretLabel.setAttribute('text-anchor', 'middle');
          fretLabel.textContent = startFret + 1;
          guitarSvg.appendChild(fretLabel);
        }

        /* Fret lines */
        for (var f = 0; f <= numFrets; f++) {
          var y = yStart + f * fretSpacing;
          var line = document.createElementNS(ns, 'line');
          line.setAttribute('x1', xStart);
          line.setAttribute('y1', y);
          line.setAttribute('x2', xEnd);
          line.setAttribute('y2', y);
          line.setAttribute('stroke', 'var(--border-color, #2a2418)');
          line.setAttribute('stroke-width', f === 0 ? '1' : '1');
          guitarSvg.appendChild(line);
        }

        /* String lines */
        for (var s = 0; s < numStrings; s++) {
          var x = xStart + s * stringSpacing;
          var sLine = document.createElementNS(ns, 'line');
          sLine.setAttribute('x1', x);
          sLine.setAttribute('y1', yStart);
          sLine.setAttribute('x2', x);
          sLine.setAttribute('y2', yEnd);
          sLine.setAttribute('stroke', 'var(--text-secondary)');
          sLine.setAttribute('stroke-width', 1.5 - s * 0.1);
          guitarSvg.appendChild(sLine);
        }

        /* String labels & dots */
        var stringNames = ['E','A','D','G','B','e'];
        for (var s = 0; s < numStrings; s++) {
          var x = xStart + s * stringSpacing;
          var fretVal = frets[s];

          if (fretVal === -1) {
            var xMark = document.createElementNS(ns, 'text');
            xMark.setAttribute('x', x);
            xMark.setAttribute('y', yStart - 10);
            xMark.setAttribute('fill', 'var(--text-secondary)');
            xMark.setAttribute('font-size', '12');
            xMark.setAttribute('text-anchor', 'middle');
            xMark.setAttribute('font-weight', '600');
            xMark.textContent = 'X';
            guitarSvg.appendChild(xMark);
          } else if (fretVal === 0) {
            var oMark = document.createElementNS(ns, 'circle');
            oMark.setAttribute('cx', x);
            oMark.setAttribute('cy', yStart - 10);
            oMark.setAttribute('r', '5');
            oMark.setAttribute('fill', 'none');
            oMark.setAttribute('stroke', 'var(--text-secondary)');
            oMark.setAttribute('stroke-width', '1.5');
            guitarSvg.appendChild(oMark);
          } else {
            var displayFret = fretVal - startFret;
            var dotY = yStart + (displayFret - 0.5) * fretSpacing;
            var dot = document.createElementNS(ns, 'circle');
            dot.setAttribute('cx', x);
            dot.setAttribute('cy', dotY);
            dot.setAttribute('r', '8');
            dot.setAttribute('fill', 'var(--accent-color, #D4A574)');
            guitarSvg.appendChild(dot);

            var dotLabel = document.createElementNS(ns, 'text');
            dotLabel.setAttribute('x', x);
            dotLabel.setAttribute('y', dotY + 4);
            dotLabel.setAttribute('fill', '#0a0806');
            dotLabel.setAttribute('font-size', '10');
            dotLabel.setAttribute('font-weight', '700');
            dotLabel.setAttribute('text-anchor', 'middle');
            dotLabel.textContent = fretVal;
            guitarSvg.appendChild(dotLabel);
          }
        }
      }

      function generateBarreVoicing(root, type) {
        /* Generate barre chord voicing based on E or A shape */
        var intervals = CHORD_FORMULAS[type].intervals;
        var barrePos = root;
        if (barrePos === 0) barrePos = 12;
        /* E-shape barre */
        var result = [barrePos, barrePos, -1, -1, -1, barrePos];
        /* Fill in middle strings based on chord type */
        if (intervals.indexOf(3) !== -1) {
          result[2] = barrePos + 2; result[3] = barrePos; result[4] = barrePos;
        } else if (intervals.indexOf(4) !== -1) {
          result[2] = barrePos + 2; result[3] = barrePos + 1; result[4] = barrePos;
        } else {
          result[2] = barrePos + 2; result[3] = barrePos; result[4] = barrePos;
        }
        return [result];
      }

      /* === Chord Progression Builder === */
      var SCALE_DEGREES = [0, 2, 4, 5, 7, 9, 11]; /* Major scale intervals */
      var DEGREE_TYPES = ['major','minor','minor','major','major','minor','dim'];
      var DEGREE_NAMES = ['I','ii','iii','IV','V','vi','vii°'];

      var progression = [];

      function getDegreeChord(key, degree) {
        var noteIdx = (key + SCALE_DEGREES[degree]) % 12;
        return { root: noteIdx, type: DEGREE_TYPES[degree], name: NOTE_NAMES_SHARP[noteIdx] + TYPE_SUFFIX[DEGREE_TYPES[degree]], numeral: DEGREE_NAMES[degree] };
      }

      function updateProgChords() {
        var key = parseInt(progKeyEl.value);
        progChordsEl.innerHTML = '';
        for (var d = 0; d < 7; d++) {
          var chord = getDegreeChord(key, d);
          var btn = document.createElement('button');
          btn.className = 'prog-chord-btn';
          btn.innerHTML = '<span class="numeral">' + chord.numeral + '</span><span class="cname">' + chord.name + '</span>';
          btn.setAttribute('data-degree', d);
          btn.addEventListener('click', function(e) {
            var deg = parseInt(this.getAttribute('data-degree'));
            addToProgression(deg);
          });
          progChordsEl.appendChild(btn);
        }
      }

      function addToProgression(degree) {
        if (progression.length >= 8) return;
        progression.push(degree);
        renderProgression();
      }

      function renderProgression() {
        var key = parseInt(progKeyEl.value);
        progSlotsEl.innerHTML = '';
        if (progression.length === 0) {
          progSlotsEl.innerHTML = '<div class="prog-empty">Click a chord above or select a preset to build your progression</div>';
          return;
        }
        progression.forEach(function(deg, idx) {
          var chord = getDegreeChord(key, deg);
          var slot = document.createElement('div');
          slot.className = 'prog-slot';
          slot.innerHTML = '<div class="slot-numeral">' + chord.numeral + '</div><div class="slot-name">' + chord.name + '</div><button class="slot-remove" data-idx="' + idx + '">×</button>';
          slot.querySelector('.slot-remove').addEventListener('click', function() {
            var i = parseInt(this.getAttribute('data-idx'));
            progression.splice(i, 1);
            renderProgression();
          });
          progSlotsEl.appendChild(slot);

          if (idx < progression.length - 1) {
            var arrow = document.createElement('div');
            arrow.className = 'prog-arrow';
            arrow.textContent = '\u2192';
            progSlotsEl.appendChild(arrow);
          }
        });
      }

      function parsePreset(preset) {
        var numeralMap = { 'I': 0, 'ii': 1, 'iii': 2, 'IV': 3, 'V': 4, 'vi': 5, 'vii': 6 };
        return preset.split('-').map(function(n) {
          var trimmed = n.trim().replace('°', '');
          return numeralMap[trimmed] !== undefined ? numeralMap[trimmed] : 0;
        });
      }

      progPresetEl.addEventListener('change', function() {
        if (!progPresetEl.value) return;
        progression = parsePreset(progPresetEl.value);
        renderProgression();
      });

      btnAddChord.addEventListener('click', function() {
        if (progression.length < 8) {
          addToProgression(0);
        }
      });

      btnClearProg.addEventListener('click', function() {
        progression = [];
        progPresetEl.value = '';
        renderProgression();
      });

      progKeyEl.addEventListener('change', function() {
        updateProgChords();
        renderProgression();
      });

      rootEl.addEventListener('change', updateChord);
      typeEl.addEventListener('change', updateChord);

      /* Init */
      updateChord();
      updateProgChords();
      renderProgression();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; margin-bottom: 2.5rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color, #2a2418); border-radius: 12px; padding: 2rem; }

    .options-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
    .option-group label { display: block; margin-bottom: 0.4rem; font-weight: 600; font-size: 0.9rem; color: var(--text-primary); }
    .option-group select { width: 100%; padding: 0.6rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-color, #2a2418); background: var(--bg-color, #0a0806); color: var(--text-primary); font-size: 0.95rem; box-sizing: border-box; }
    .option-group select:focus { outline: none; border-color: var(--accent-color, #D4A574); }

    .chord-info { text-align: center; margin-bottom: 2rem; padding: 1.5rem; background: var(--bg-color, #0a0806); border-radius: 10px; border: 1px solid var(--border-color, #2a2418); }
    .chord-name { font-size: 1.8rem; font-weight: 800; color: var(--accent-color, #D4A574); margin-bottom: 1rem; }
    .chord-details { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; }
    .detail-item { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; }
    .detail-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; }
    .detail-value { font-size: 1.05rem; color: var(--text-primary); font-weight: 600; font-family: monospace; }

    .viz-section { margin-bottom: 1.5rem; }
    .viz-section h3 { font-size: 1rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.8rem; }

    .piano-wrapper { overflow-x: auto; padding-bottom: 0.5rem; }
    .piano { position: relative; height: 140px; min-width: 450px; }
