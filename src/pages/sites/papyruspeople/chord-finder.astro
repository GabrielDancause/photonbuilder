    .piano-white { height: 100%; background: #f5f0eb; border: 1px solid var(--border-color, #2a2418); z-index: 1; }
    .piano-white.active { background: var(--accent-color, #D4A574); }
    .piano-white.root { background: var(--accent-color, #D4A574); box-shadow: 0 0 12px var(--accent-color, #D4A574); }
    .piano-black { height: 60%; background: #1a1510; border: 1px solid #0a0806; z-index: 2; }
    .piano-black.active { background: var(--accent-color, #D4A574); }
    .piano-black.root { background: var(--accent-color, #D4A574); box-shadow: 0 0 12px var(--accent-color, #D4A574); }
    .key-label { font-size: 0.65rem; font-weight: 700; color: #0a0806; pointer-events: none; }
    .piano-black .key-label { color: #0a0806; }

    .guitar-wrapper { display: flex; justify-content: center; }
    #guitar-svg { width: 100%; max-width: 360px; height: auto; }

    .section-title { font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.25rem; margin-top: 0; }

    .prog-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }

    .prog-chords { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
    .prog-chord-btn { display: flex; flex-direction: column; align-items: center; padding: 0.5rem 0.75rem; background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 8px; cursor: pointer; transition: all 0.2s; color: var(--text-primary); min-width: 60px; }
    .prog-chord-btn:hover { border-color: var(--accent-color, #D4A574); background: rgba(212,165,116,0.1); }
    .prog-chord-btn .numeral { font-size: 0.95rem; font-weight: 700; color: var(--accent-color, #D4A574); }
    .prog-chord-btn .cname { font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem; }

    .prog-builder { background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 10px; padding: 1.25rem; }
