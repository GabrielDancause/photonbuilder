    .btn-primary { background: var(--accent-color, #D4A574); color: #0a0806; border-color: var(--accent-color, #D4A574); }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { background: transparent; color: var(--text-primary); border-color: var(--border-color, #2a2418); }
    .btn-secondary:hover { border-color: var(--accent-color, #D4A574); color: var(--accent-color, #D4A574); }

    .content-section { margin-top: 2rem; }
    .content-section h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-primary); }
    .content-section h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .content-section p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.75rem; }

    .faq-item { border-bottom: 1px solid var(--border-color, #2a2418); padding-bottom: 1.25rem; margin-bottom: 1.25rem; }
    .faq-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .faq-item h3 { margin-top: 0; }

    .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
    .related-card { display: block; padding: 1.25rem; background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 8px; text-decoration: none; transition: border-color 0.2s; }
    .related-card:hover { border-color: var(--accent-color, #D4A574); }
    .related-card h3 { font-size: 1rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.4rem; }
    .related-card p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; line-height: 1.4; }

    @media (max-width: 600px) {
      .options-row { grid-template-columns: 1fr; }
      .prog-controls { grid-template-columns: 1fr; }
      .chord-details { gap: 1rem; }
      .prog-actions { flex-direction: column; }
      .btn-secondary { width: 100%; text-align: center; }
    }
  </style>
</SiteLayout>
