    .slot-remove { position: absolute; top: -6px; right: -6px; width: 18px; height: 18px; border-radius: 50%; background: var(--border-color, #2a2418); border: none; color: var(--text-primary); font-size: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; line-height: 1; padding: 0; }
    .slot-remove:hover { background: #c0392b; color: #fff; }
