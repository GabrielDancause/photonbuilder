---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Character Counter — Word Counter & Text Analysis Tool',
  description: 'Count characters, words, sentences, and paragraphs instantly. Check social media limits for Twitter, Instagram, and LinkedIn. Free online text analysis tool.',
  category: 'tool',
  published: '2026-03-24'
};

const SITE_ID = 'papyruspeople';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Character Counter",
    "description": "Count characters, words, sentences, and paragraphs. Check character limits for social media platforms and analyze keyword density.",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "All"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does the character counter work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The character counter analyzes your text in real time as you type or paste. It counts every character including letters, numbers, spaces, and punctuation marks. It also provides separate counts for characters with and without spaces, plus word, sentence, and paragraph totals."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between characters with spaces and without spaces?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Characters with spaces counts every single character in your text, including blank spaces between words. Characters without spaces excludes all space characters, giving you only the count of letters, numbers, and punctuation. Some platforms and assignments specify limits based on one or the other."
        }
      },
      {
        "@type": "Question",
        "name": "What is the character limit for Twitter/X posts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Twitter/X has a 280-character limit for standard posts. This includes all characters: letters, numbers, spaces, punctuation, and emojis. URLs are shortened to 23 characters regardless of their actual length. Twitter Blue subscribers can post up to 25,000 characters."
        }
      },
      {
        "@type": "Question",
        "name": "How is reading time calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Reading time is calculated based on the average adult reading speed of approximately 200-250 words per minute. Our tool uses 225 words per minute as the baseline, which is a widely accepted average for reading comprehension of online content."
        }
      },
      {
        "@type": "Question",
        "name": "What is keyword density and why does it matter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Keyword density is the percentage of times a specific word appears in your text relative to the total word count. It matters for SEO because search engines use it as one factor to understand what a page is about. A keyword density of 1-3% is generally considered optimal — too low and search engines may not associate your content with the keyword, too high and it may be flagged as keyword stuffing."
        }
      },
      {
        "@type": "Question",
        "name": "Does the character counter work with emojis and special characters?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! The character counter handles all Unicode characters including emojis, accented letters, and characters from non-Latin scripts. Each emoji is counted as a single character regardless of its underlying Unicode representation, matching how most social media platforms count them."
        }
      },
      {
        "@type": "Question",
        "name": "What are the character limits for popular social media platforms?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common character limits include: Twitter/X posts (280), Instagram bio (150), LinkedIn headline (120), SMS messages (160), Google title tag (60), and meta descriptions (160). Our tool shows real-time indicators for each of these limits so you can see at a glance whether your text fits."
        }
      }
    ]
  }
];

const relatedPages = [
  { url: '/fancy-text-generator', title: 'Fancy Text Generator', description: 'Generate cool text with 20+ Unicode styles for social media' },
  { url: '/font-generator', title: 'Font Generator', description: 'Generate text in serif, sans-serif, and decorative font styles' }
];
---

<SiteLayout
  site={SITE_ID}
  title={meta.title}
  description={meta.description}
  schema={schema} canonical="https://papyruspeople.photonbuilder.com/character-counter"
>
  <div class="page-content">
    <div class="hero">
      <h1>Character Counter</h1>
      <p>Count characters, words, sentences, and paragraphs. Analyze keyword density and check social media character limits — all in real time.</p>
    </div>

    <div class="tool-container card">
      <div class="input-group">
        <label for="text-input">Your Text</label>
        <textarea id="text-input" placeholder="Type or paste your text here to count characters, words, and more..." rows="8"></textarea>
      </div>

      <div class="stats-grid" id="stats-grid">
        <div class="stat-card">
          <span class="stat-value" id="stat-chars">0</span>
          <span class="stat-label">Characters</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-chars-no-space">0</span>
          <span class="stat-label">Without Spaces</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-words">0</span>
          <span class="stat-label">Words</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-sentences">0</span>
          <span class="stat-label">Sentences</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-paragraphs">0</span>
          <span class="stat-label">Paragraphs</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-unique">0</span>
          <span class="stat-label">Unique Words</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-avg-length">0</span>
          <span class="stat-label">Avg Word Length</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-reading">0s</span>
          <span class="stat-label">Reading Time</span>
        </div>
        <div class="stat-card">
          <span class="stat-value" id="stat-speaking">0s</span>
          <span class="stat-label">Speaking Time</span>
        </div>
      </div>
    </div>

    <div class="card section-card">
      <h2>Social Media Limits</h2>
      <div class="limits-grid" id="limits-grid"></div>
    </div>

    <div class="card section-card">
      <h2>Character Density</h2>
      <p class="section-desc">Top 10 most-used characters in your text</p>
      <div id="char-density" class="density-container">
        <p class="empty-state">Start typing to see character density</p>
      </div>
    </div>

    <div class="card section-card">
      <h2>Keyword Density</h2>
      <p class="section-desc">Top 10 most frequently used words</p>
      <div id="keyword-density" class="density-container">
        <p class="empty-state">Start typing to see keyword density</p>
      </div>
    </div>

    <div class="content-section card">
      <h2>How to Use the Character Counter</h2>
      <p>This free online <strong>character counter</strong> tool analyzes your text in real time. Simply type or paste your content into the text area above and all statistics update instantly — no buttons to click, no page reloads.</p>
      <p>The <strong>word counter</strong> splits your text on whitespace and counts each token, while the <strong>letter counter</strong> tallies every individual character. The tool also provides sentence and paragraph counts by detecting punctuation boundaries and line breaks.</p>

      <h3>Character Counts Explained</h3>
      <p><strong>Characters (with spaces)</strong> counts every character in your text including spaces, tabs, and newlines. <strong>Characters (without spaces)</strong> strips all whitespace first. Most social media platforms and writing assignments specify which counting method to use — Twitter uses total characters, while some academic assignments count characters without spaces.</p>

      <h3>Reading Time vs. Speaking Time</h3>
      <p>Reading time is calculated at 225 words per minute (the average silent reading speed for adults). Speaking time uses 150 words per minute, which is the typical pace for presentations and public speaking. These estimates help you plan content for blog posts, scripts, presentations, and podcasts.</p>

      <h3>Understanding Keyword Density</h3>
      <p>Keyword density shows how often each word appears as a percentage of total words. For SEO writing, aim for a primary keyword density of 1–3%. The keyword density section filters out common stop words (the, is, and, etc.) to surface meaningful content words. This helps you check whether your writing is balanced or over-relying on certain terms.</p>
    </div>

    <div class="content-section card">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>How does the character counter work?</h3>
        <p>The character counter analyzes your text in real time as you type or paste. It counts every character including letters, numbers, spaces, and punctuation marks. It also provides separate counts for characters with and without spaces, plus word, sentence, and paragraph totals.</p>
      </div>

      <div class="faq-item">
        <h3>What is the difference between characters with spaces and without spaces?</h3>
        <p>Characters with spaces counts every single character in your text, including blank spaces between words. Characters without spaces excludes all space characters, giving you only the count of letters, numbers, and punctuation. Some platforms and assignments specify limits based on one or the other.</p>
      </div>

      <div class="faq-item">
        <h3>What is the character limit for Twitter/X posts?</h3>
        <p>Twitter/X has a 280-character limit for standard posts. This includes all characters: letters, numbers, spaces, punctuation, and emojis. URLs are shortened to 23 characters regardless of their actual length. Twitter Blue subscribers can post up to 25,000 characters.</p>
      </div>

      <div class="faq-item">
        <h3>How is reading time calculated?</h3>
        <p>Reading time is calculated based on the average adult reading speed of approximately 200–250 words per minute. Our tool uses 225 words per minute as the baseline, which is a widely accepted average for reading comprehension of online content.</p>
      </div>

      <div class="faq-item">
        <h3>What is keyword density and why does it matter?</h3>
        <p>Keyword density is the percentage of times a specific word appears in your text relative to the total word count. It matters for SEO because search engines use it as one factor to understand what a page is about. A keyword density of 1–3% is generally considered optimal — too low and search engines may not associate your content with the keyword, too high and it may be flagged as keyword stuffing.</p>
      </div>

      <div class="faq-item">
        <h3>Does the character counter work with emojis and special characters?</h3>
        <p>Yes! The character counter handles all Unicode characters including emojis, accented letters, and characters from non-Latin scripts. Each emoji is counted as a single character regardless of its underlying Unicode representation, matching how most social media platforms count them.</p>
      </div>

      <div class="faq-item">
        <h3>What are the character limits for popular social media platforms?</h3>
        <p>Common character limits include: Twitter/X posts (280), Instagram bio (150), LinkedIn headline (120), SMS messages (160), Google title tag (60), and meta descriptions (160). Our tool shows real-time indicators for each of these limits so you can see at a glance whether your text fits.</p>
      </div>
    </div>

    <div class="content-section card">
      <h2>Related Tools</h2>
      <div class="related-grid">
        {relatedPages.map(page => (
          <a href={page.url} class="related-card">
            <h3>{page.title}</h3>
            <p>{page.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('text-input');
      const limitsGrid = document.getElementById('limits-grid');
      const charDensityEl = document.getElementById('char-density');
      const keywordDensityEl = document.getElementById('keyword-density');

      const LIMITS = [
        { name: 'Twitter/X Post', limit: 280, icon: '𝕏' },
        { name: 'Instagram Bio', limit: 150, icon: '📷' },
        { name: 'LinkedIn Headline', limit: 120, icon: '💼' },
        { name: 'SMS Message', limit: 160, icon: '💬' },
        { name: 'Google Title', limit: 60, icon: '🔍' },
        { name: 'Meta Description', limit: 160, icon: '📝' }
      ];

      const STOP_WORDS = new Set([
        'the','be','to','of','and','a','in','that','have','i','it','for','not','on','with',
        'he','as','you','do','at','this','but','his','by','from','they','we','say','her',
        'she','or','an','will','my','one','all','would','there','their','what','so','up',
        'out','if','about','who','get','which','go','me','when','make','can','like','time',
        'no','just','him','know','take','people','into','year','your','good','some','could',
        'them','see','other','than','then','now','look','only','come','its','over','think',
        'also','back','after','use','two','how','our','work','first','well','way','even',
        'new','want','because','any','these','give','day','most','us','is','are','was',
        'were','been','has','had','did','does','am','being','very','more','much','own',
        'such','here','should','may','each','where','those','must','before','through',
        'during','while','too','between','still','under','never','always','both','few'
      ]);

      function analyze(text) {
        const chars = Array.from(text).length;
        const charsNoSpace = text.replace(/\s/g, '').length;
        const words = text.trim() === '' ? [] : text.trim().split(/\s+/);
        const wordCount = words.length;
        const sentences = text.trim() === '' ? 0 : (text.match(/[.!?]+(?=\s|$)/g) || []).length || (text.trim().length > 0 ? 1 : 0);
        const paragraphs = text.trim() === '' ? 0 : text.split(/\n\s*\n/).filter(p => p.trim().length > 0).length || (text.trim().length > 0 ? 1 : 0);

        const uniqueWords = new Set(words.map(w => w.toLowerCase().replace(/[^a-z0-9'-]/g, '')).filter(Boolean));
        const avgLength = wordCount > 0
          ? (words.reduce((sum, w) => sum + w.replace(/[^a-zA-Z0-9]/g, '').length, 0) / wordCount).toFixed(1)
          : '0';

        const readingMin = wordCount / 225;
        const speakingMin = wordCount / 150;

        return {
          chars, charsNoSpace, wordCount, sentences, paragraphs,
          uniqueWords: uniqueWords.size, avgLength,
          readingTime: formatTime(readingMin),
          speakingTime: formatTime(speakingMin),
          words
        };
      }

      function formatTime(minutes) {
        if (minutes < 1/60) return '0s';
        if (minutes < 1) return Math.round(minutes * 60) + 's';
        const m = Math.floor(minutes);
        const s = Math.round((minutes - m) * 60);
        return s > 0 ? m + 'm ' + s + 's' : m + 'm';
      }

      function getCharDensity(text) {
        const clean = text.replace(/\s/g, '').toLowerCase();
        if (!clean) return [];
        const freq = {};
        for (const ch of Array.from(clean)) {
          freq[ch] = (freq[ch] || 0) + 1;
        }
        const total = Array.from(clean).length;
        return Object.entries(freq)
          .sort((a, b) => b[1] - a[1])
          .slice(0, 10)
          .map(([ch, count]) => ({ char: ch, count, pct: ((count / total) * 100).toFixed(1) }));
      }

      function getKeywordDensity(words) {
        if (!words.length) return [];
        const freq = {};
        const cleaned = words.map(w => w.toLowerCase().replace(/[^a-z0-9'-]/g, '')).filter(w => w.length > 1 && !STOP_WORDS.has(w));
        for (const w of cleaned) {
          freq[w] = (freq[w] || 0) + 1;
        }
        return Object.entries(freq)
          .sort((a, b) => b[1] - a[1])
          .slice(0, 10)
          .map(([word, count]) => ({ word, count, pct: ((count / words.length) * 100).toFixed(1) }));
      }

      function getLimitStatus(charCount, limit) {
        const ratio = charCount / limit;
        if (ratio <= 0.75) return 'green';
        if (ratio <= 1) return 'yellow';
        return 'red';
      }

      function renderLimits(charCount) {
        limitsGrid.innerHTML = LIMITS.map(l => {
          const status = charCount === 0 ? 'green' : getLimitStatus(charCount, l.limit);
          const remaining = l.limit - charCount;
          const pct = Math.min((charCount / l.limit) * 100, 100);
          return '<div class="limit-card limit-' + status + '">' +
            '<div class="limit-header">' +
              '<span class="limit-icon">' + l.icon + '</span>' +
              '<span class="limit-name">' + l.name + '</span>' +
            '</div>' +
            '<div class="limit-bar"><div class="limit-fill" style="width:' + pct + '%"></div></div>' +
            '<div class="limit-info">' +
              '<span>' + charCount + ' / ' + l.limit + '</span>' +
              '<span class="limit-remaining">' + (remaining >= 0 ? remaining + ' left' : Math.abs(remaining) + ' over') + '</span>' +
            '</div>' +
          '</div>';
        }).join('');
      }

      function renderDensityBar(items, labelKey) {
        if (!items.length) return '<p class="empty-state">Start typing to see ' + (labelKey === 'char' ? 'character' : 'keyword') + ' density</p>';
        const maxPct = parseFloat(items[0].pct);
        return '<div class="density-bars">' + items.map(item => {
          const label = labelKey === 'char' ? ('"' + item.char + '"') : item.word;
          const barWidth = maxPct > 0 ? ((parseFloat(item.pct) / maxPct) * 100) : 0;
          return '<div class="density-row">' +
            '<span class="density-label">' + label + '</span>' +
            '<div class="density-bar-track"><div class="density-bar-fill" style="width:' + barWidth + '%"></div></div>' +
            '<span class="density-count">' + item.count + ' (' + item.pct + '%)</span>' +
          '</div>';
        }).join('') + '</div>';
      }

      function update() {
        const text = input.value;
        const stats = analyze(text);

        document.getElementById('stat-chars').textContent = stats.chars;
        document.getElementById('stat-chars-no-space').textContent = stats.charsNoSpace;
        document.getElementById('stat-words').textContent = stats.wordCount;
        document.getElementById('stat-sentences').textContent = stats.sentences;
        document.getElementById('stat-paragraphs').textContent = stats.paragraphs;
        document.getElementById('stat-unique').textContent = stats.uniqueWords;
        document.getElementById('stat-avg-length').textContent = stats.avgLength;
        document.getElementById('stat-reading').textContent = stats.readingTime;
        document.getElementById('stat-speaking').textContent = stats.speakingTime;

        renderLimits(stats.chars);

        const charDensity = getCharDensity(text);
        charDensityEl.innerHTML = renderDensityBar(charDensity, 'char');

        const keywordDensity = getKeywordDensity(stats.words);
        keywordDensityEl.innerHTML = renderDensityBar(keywordDensity, 'word');
      }

      input.addEventListener('input', update);
      update();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; margin-bottom: 2.5rem; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color, #2a2418); border-radius: 12px; padding: 2rem; }
    .section-card { margin-top: 1.5rem; }
    .section-card h2 { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--text-primary); }
    .section-desc { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }

    .input-group { margin-bottom: 1.5rem; }
    .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: var(--text-primary); }
    textarea { width: 100%; padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color, #2a2418); background: var(--bg-color, #0a0806); color: var(--text-primary); font-family: inherit; font-size: 1rem; resize: vertical; transition: border-color 0.2s; box-sizing: border-box; }
    textarea:focus { outline: none; border-color: var(--accent-color, #D4A574); }

    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
    .stat-card { background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 8px; padding: 1rem; text-align: center; }
    .stat-value { display: block; font-size: 1.5rem; font-weight: 700; color: var(--accent-color, #D4A574); margin-bottom: 0.25rem; }
    .stat-label { font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }

    .limits-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
    .limit-card { background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 8px; padding: 1rem; }
    .limit-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
    .limit-icon { font-size: 1rem; }
    .limit-name { font-size: 0.85rem; font-weight: 600; color: var(--text-primary); }
    .limit-bar { height: 6px; background: var(--border-color, #2a2418); border-radius: 3px; overflow: hidden; margin-bottom: 0.4rem; }
    .limit-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
    .limit-green .limit-fill { background: #10B981; }
    .limit-yellow .limit-fill { background: #F59E0B; }
    .limit-red .limit-fill { background: #EF4444; }
    .limit-info { display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); }
    .limit-remaining { font-weight: 600; }
    .limit-green .limit-remaining { color: #10B981; }
    .limit-yellow .limit-remaining { color: #F59E0B; }
    .limit-red .limit-remaining { color: #EF4444; }

    .density-container { min-height: 2rem; }
    .empty-state { color: var(--text-secondary); font-size: 0.9rem; font-style: italic; margin: 0; }
    .density-bars { display: flex; flex-direction: column; gap: 0.5rem; }
    .density-row { display: flex; align-items: center; gap: 0.75rem; }
    .density-label { min-width: 5rem; font-size: 0.85rem; font-weight: 600; color: var(--text-primary); text-align: right; font-family: monospace; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .density-bar-track { flex: 1; height: 8px; background: var(--border-color, #2a2418); border-radius: 4px; overflow: hidden; }
    .density-bar-fill { height: 100%; background: var(--accent-color, #D4A574); border-radius: 4px; transition: width 0.3s; }
    .density-count { min-width: 5.5rem; font-size: 0.8rem; color: var(--text-secondary); text-align: right; white-space: nowrap; }

    .content-section { margin-top: 2rem; }
    .content-section h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-primary); }
    .content-section h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--text-primary); }
    .content-section p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 0.75rem; }

    .faq-item { border-bottom: 1px solid var(--border-color, #2a2418); padding-bottom: 1.25rem; margin-bottom: 1.25rem; }
    .faq-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .faq-item h3 { margin-top: 0; }

    .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
    .related-card { display: block; padding: 1.25rem; background: var(--bg-color, #0a0806); border: 1px solid var(--border-color, #2a2418); border-radius: 8px; text-decoration: none; transition: border-color 0.2s; }
    .related-card:hover { border-color: var(--accent-color, #D4A574); }
    .related-card h3 { font-size: 1rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.4rem; }
    .related-card p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; line-height: 1.4; }

    @media (max-width: 600px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .limits-grid { grid-template-columns: 1fr; }
      .density-label { min-width: 3.5rem; }
      .density-count { min-width: 4.5rem; }
    }
  </style>
</SiteLayout>
