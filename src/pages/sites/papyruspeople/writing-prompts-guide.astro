---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Best Writing Prompts Guide: 200 Ideas for Fiction, Non-Fiction & More',
  description: 'A comprehensive collection of 200 writing prompts spanning fiction, non-fiction, poetry, journaling, creative exercises, dialogue practice, and world-building. Plus tips on overcoming writer\'s block and building a daily habit.',
  category: 'list',
  published: '2026-03-24'
};

const SITE_ID = 'papyruspeople';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I overcome writer's block?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Overcoming writer's block often involves taking a break, changing your environment, or using writing prompts to jumpstart your creativity without the pressure of working on your main project."
        }
      },
      {
        "@type": "Question",
        "name": "What is a good daily writing habit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good daily writing habit involves setting a consistent time and place to write every day, even if it's just for 15 minutes or 500 words, focusing on progress rather than perfection."
        }
      },
      {
        "@type": "Question",
        "name": "How do I turn a prompt into a story?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To turn a prompt into a story, start by freewriting based on the prompt for 10 minutes. Then, identify the core conflict, develop the characters involved, and outline a beginning, middle, and end."
        }
      },
      {
        "@type": "Question",
        "name": "Are writing prompts only for beginners?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, writing prompts are useful for writers of all skill levels. They provide constraints that can spark new ideas, help writers break out of comfort zones, and warm up the creative muscles."
        }
      },
      {
        "@type": "Question",
        "name": "What are morning pages?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Morning pages are a daily habit of writing three pages of stream-of-consciousness thoughts first thing in the morning. They help clear your mind and unlock creativity for the day ahead."
        }
      }
    ]
  }
];
---

<SiteLayout
