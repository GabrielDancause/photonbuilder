---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const timeline = [
  {
    year: "Freshman/Sophomore",
    desc: "Focus on discovery programs, shadowing, and general skill building. Attend career fairs to network early."
  },
  {
    year: "Junior",
    desc: "The most critical year. Start applying in August/September for Summer internships. Top tech, finance, and consulting firms recruit in early fall."
  },
  {
    year: "Senior",
    desc: "Focus on full-time roles, but consider off-cycle internships or co-ops if you still need experience."
  }
];

const whereToFind = [
  {
    platform: "Handshake & Campus Portal",
    desc: "The highest conversion rate. Companies post here specifically looking for students from your school."
  },
  {
    platform: "LinkedIn & Indeed",
    desc: "High volume, but high competition. Use filters to find 'early career' or 'internship' tags."
  },
  {
    platform: "Company Careers Pages",
    desc: "Go directly to the source. Set up job alerts for companies you admire."
  },
  {
    platform: "Networking & Cold Emails",
    desc: "Reach out to alumni on LinkedIn. A referral drastically increases your chances."
  }
];

const appTips = [
  {
    tip: "Student Resume",
    desc: "Keep it to one page. Highlight coursework, projects, and extracurricular leadership if experience is light. Use the STAR method."
  },
  {
    tip: "Cover Letters",
    desc: "Only write one if required or if you have a non-traditional background. Keep it concise and focused on how you add value."
  },
  {
    tip: "Cold Emails",
    desc: "Keep them short. Introduce yourself, state your intent, and ask for a 15-minute informational chat, not a job outright."
  }
];

const interviewPrep = [
  {
    method: "Behavioral (STAR)",
    desc: "Situation, Task, Action, Result. Prepare 4-5 versatile stories that demonstrate leadership, problem-solving, and conflict resolution."
  },
  {
    method: "Technical Rounds",
    desc: "Practice LeetCode (for SWE), case studies (for consulting), or portfolio reviews (for design). Know the fundamentals cold."
  },
  {
    method: "Questions for Them",
    desc: "Always have questions prepared. Ask about the team culture, a typical day, or the return offer rate."
  }
];

const internshipSuccess = [
  {
    topic: "Getting the Return Offer",
    desc: "Treat the internship like a 10-week interview. Be proactive, ask for feedback, document your wins, and network with multiple teams."
  },
  {
    topic: "Virtual Internships",
    desc: "Over-communicate. Set up weekly 1-on-1s with your manager and virtually grab coffee with colleagues to stay visible."
  },
  {
    topic: "Paid vs. Unpaid",
    desc: "Whenever possible, prioritize paid internships. Unpaid internships should strictly offer high educational value or mentorship."
  }
];

const faqs = [
  {
    q: "When should I start applying for summer internships?",
    a: "For competitive industries like finance, tech, and consulting, recruiting starts as early as August the year prior. For most other industries, January to March is typical."
  },
  {
    q: "Do I need prior experience to get an internship?",
    a: "No, but you need to show potential. Use class projects, hackathons, volunteer work, or extracurricular leadership on your resume."
  },
  {
    q: "What is the STAR method?",
    a: "It stands for Situation, Task, Action, and Result. It's a structured way to answer behavioral interview questions clearly and concisely."
  },
  {
    q: "How important is my GPA?",
    a: "It depends on the industry. Finance and consulting often have strict cutoffs (e.g., 3.5+), while tech and creative fields care more about your portfolio and skills."
  },
  {
    q: "Should I accept an unpaid internship?",
    a: "Only as a last resort or if it offers exceptional mentorship and strictly adheres to legal labor standards for educational value."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Internship Tips for College Students",
    "description": "Complete internship guide. Cover: when to start applying, where to find internships, application tips, interview prep, getting the return offer, unpaid vs paid debate, virtual internship tips.",
    "author": {
      "@type": "Organization",
      "name": "Get The Bag"
    },
    "datePublished": "2026-05-10",
    "dateModified": "2026-05-10"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];
---

<SiteLayout
  site="getthebag"
  title="Best Internship Tips for College Students"
  description="Complete internship guide for college students: when to apply, where to find internships, application tips, interview prep, and how to land the return offer."
  canonical="https://getthebag.photonbuilder.com/internship-guide"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>The Ultimate College Internship Guide</h1>
      <p>From finding the right opportunities to crushing the interview and securing the return offer, here is everything you need to know about college internships.</p>
    </div>

    <section class="content-section">

      <h2>When to Start Applying (Timeline by Year)</h2>
      <div class="tips-grid">
        {timeline.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.year}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Where to Find Internships</h2>
      <div class="tips-grid">
        {whereToFind.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.platform}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Application Tips</h2>
      <div class="tips-grid">
        {appTips.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.tip}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Interview Prep</h2>
      <div class="tips-grid">
        {interviewPrep.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.method}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Internship Success & Advice</h2>
      <div class="tips-grid">
        {internshipSuccess.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.topic}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>

    </section>
  </div>

  <style>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1.2rem; margin-top: 2.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem; }

    /* Tips Grid */
    .tips-grid { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .tip-card { display: flex; gap: 1rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; align-items: flex-start; }
    .tip-number { background: var(--accent-color); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
    .tip-content h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .tip-content p { margin: 0; font-size: 0.95rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-container { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .faq-item h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin: 0; color: var(--text-secondary); }

    @media (max-width: 768px) {
      .hero h1 { font-size: 1.8rem; }
    }
  </style>
</SiteLayout>
