---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const sections = [
  {
    id: "rent-terms",
    title: "Lease Agreement Checklist",
    icon: "💰",
    items: [
      { id: "base-rent", label: "Base rent amount and payment schedule", lookFor: "Confirm the exact monthly amount, due date, and acceptable payment methods. Ensure the rate is quoted per rentable vs. usable square foot.", redFlag: "Vague language like 'market rate' without a fixed number, or rent due on receipt rather than a specific date.", tip: "Negotiate a few months of free or reduced rent (abatement) at the start of your lease to offset move-in costs." },
      { id: "rent-escalation", label: "Annual rent escalation clause", lookFor: "Check whether increases are fixed (e.g., 3% per year), tied to CPI, or at landlord's discretion.", redFlag: "Uncapped escalation clauses or language that lets the landlord adjust rent 'as deemed appropriate.'", tip: "Push for a fixed annual cap (2-3%) rather than CPI-based increases, which can spike unpredictably." },
      { id: "cam-charges", label: "Common Area Maintenance (CAM) charges", lookFor: "Get a full breakdown of CAM fees: janitorial, landscaping, security, property management, etc. Ask for historical CAM statements.", redFlag: "No cap on CAM charges, or 'gross-up' provisions that let the landlord bill as if the building is fully occupied.", tip: "Negotiate a CAM cap (typically 3-5% annual increase) and exclude capital expenditure pass-throughs." },
      { id: "percentage-rent", label: "Percentage rent (retail leases)", lookFor: "Understand the breakpoint above which percentage rent kicks in. Confirm whether it is a natural or artificial breakpoint.", redFlag: "Artificially low breakpoints that guarantee extra rent from day one, or inclusion of online sales in gross revenue calculations.", tip: "Negotiate exclusions for returns, employee discounts, and sales taxes from gross revenue calculations." },
      { id: "security-deposit", label: "Security deposit amount and return terms", lookFor: "Verify the deposit amount, conditions for return, timeline, and whether interest accrues in your favor.", redFlag: "Deposits exceeding 3 months' rent, or vague return conditions that give the landlord wide discretion to withhold.", tip: "Negotiate a decreasing deposit schedule — e.g., reduced by a third each year if you pay on time." },
      { id: "late-payment", label: "Late payment penalties and grace period", lookFor: "Confirm the grace period (typically 5-10 days) and the exact penalty amount or percentage.", redFlag: "No grace period, or compounding interest on late payments rather than a flat fee.", tip: "Negotiate at least a 5-day grace period and ensure penalties are capped at a reasonable flat fee (e.g., 5% of monthly rent)." }
    ]
  },
  {
    id: "space-details",
    title: "Space & Build-Out",
    icon: "📐",
    items: [
      { id: "square-footage", label: "Verify rentable vs. usable square footage", lookFor: "Get exact usable square footage measurements independently verified. Understand how rentable square footage is calculated (load factor).", redFlag: "A load factor above 15-20% for office space, or no distinction between rentable and usable footage in the lease.", tip: "Hire your own architect or space planner to measure usable square footage before signing." },
      { id: "common-area-factor", label: "Common area factor / load factor", lookFor: "The load factor is the ratio of rentable to usable space. Typical ranges: 10-15% for single-floor, 15-20% for multi-floor buildings.", redFlag: "Load factors above 20%, or the landlord refusing to disclose how common areas are measured.", tip: "Negotiate based on usable square footage rather than rentable, or push for a lower load factor." },
      { id: "build-out-allowance", label: "Tenant improvement (TI) allowance", lookFor: "Confirm the dollar-per-square-foot TI allowance, what it covers, disbursement schedule, and whether unused funds can be applied to rent.", redFlag: "TI allowance that is amortized into your rent at high interest rates, or restrictions that require using only the landlord's contractor.", tip: "Negotiate for a higher TI allowance or the right to choose your own contractors. Get unused TI applied as rent credit." },
      { id: "build-out-approval", label: "Build-out plans and approval process", lookFor: "Understand who approves plans, the timeline, and whether the landlord can reject designs. Confirm who owns improvements at lease end.", redFlag: "Clauses requiring you to restore the space to original condition at your expense when you leave.", tip: "Negotiate that improvements become the landlord's property at lease end so you avoid costly demolition." },
      { id: "move-in-condition", label: "Move-in condition and existing infrastructure", lookFor: "Document the current condition of HVAC, electrical, plumbing, internet, and structural elements before signing.", redFlag: "No warranty on building systems, or language shifting all repair liability to the tenant from day one.", tip: "Request a building condition report and negotiate landlord responsibility for pre-existing issues for at least the first year." }
    ]
  },
  {
    id: "lease-term",
    title: "Lease Term & Flexibility",
    icon: "📅",
    items: [
      { id: "lease-length", label: "Lease length and commencement date", lookFor: "Confirm the exact start date, whether it is tied to occupancy or a calendar date, and total term length.", redFlag: "Commencement dates tied to 'substantial completion' without a hard deadline or penalty for landlord delays.", tip: "Negotiate a 'drop-dead' date: if the space isn't ready by a certain date, you can walk away or receive rent abatement." },
      { id: "renewal-options", label: "Renewal options and terms", lookFor: "Check how many renewal options you have, the notice period required, and how renewal rent is determined.", redFlag: "Renewal at 'fair market value' without a cap, or very short notice windows (e.g., 6 months) for long-term leases.", tip: "Lock in renewal rates (e.g., 95% of market rate) and negotiate at least 9-12 months' notice period." },
      { id: "early-termination", label: "Early termination clause", lookFor: "Understand if you can terminate early, the required notice, and any penalties or fees.", redFlag: "No termination clause at all, or termination penalties that include all remaining rent through the original term.", tip: "Negotiate a termination option after year 2-3 with a reasonable penalty (e.g., 3-6 months' rent plus unamortized TI)." },
      { id: "expansion-rights", label: "Right of first offer / refusal on adjacent space", lookFor: "Confirm whether you have priority on nearby spaces if they become available, and the terms of that right.", redFlag: "Rights that expire quickly or require you to match any third-party offer within an unreasonably short period (e.g., 48 hours).", tip: "Negotiate a right of first offer (you get notified before it's listed) rather than right of first refusal (you match an existing offer)." },
      { id: "contraction-right", label: "Contraction / downsizing rights", lookFor: "Check if you can give back a portion of your space if your needs shrink, and under what conditions.", redFlag: "No contraction rights in a long-term lease, leaving you locked into more space than you may need.", tip: "Negotiate the right to contract by 20-30% of your space after a set period, with reasonable notice and a modest penalty." }
    ]
  },
  {
    id: "responsibilities",
    title: "Responsibilities & Operations",
    icon: "🔧",
    items: [
      { id: "maintenance-repair", label: "Maintenance and repair obligations", lookFor: "Clarify exactly what the landlord vs. tenant is responsible for: HVAC, plumbing, electrical, structural, roof, exterior walls.", redFlag: "Triple-net (NNN) language that shifts all maintenance to the tenant, including structural and roof repairs.", tip: "In NNN leases, negotiate a cap on your annual maintenance liability and exclude structural/roof from your obligations." },
      { id: "insurance-requirements", label: "Insurance requirements", lookFor: "Review required coverage types (general liability, property, business interruption), minimum limits, and whether the landlord must be named as additional insured.", redFlag: "Unreasonably high coverage requirements (e.g., $5M+ general liability for a small office), or requirements to insure the landlord's property.", tip: "Get insurance quotes before signing to confirm costs. Negotiate reasonable limits based on your business type and space size." },
      { id: "utilities-services", label: "Utilities and services included", lookFor: "Confirm which utilities are included in rent vs. billed separately: electricity, water, gas, internet, trash removal.", redFlag: "Sub-metering that adds a markup to utility costs, or the landlord controlling HVAC with no after-hours access.", tip: "Negotiate after-hours HVAC access at a reasonable rate, and confirm you can choose your own internet provider." },
      { id: "signage-rights", label: "Signage and branding rights", lookFor: "Understand what signage you are permitted: building directory, suite entrance, lobby, exterior. Review size and design approval process.", redFlag: "No signage rights, or approval processes that give the landlord unlimited veto power.", tip: "Negotiate specific signage rights in the lease (not just a promise) including dimensions, placement, and that approval won't be unreasonably withheld." },
      { id: "parking", label: "Parking allocation and costs", lookFor: "Confirm the number of reserved and unreserved spaces, location, and monthly cost per space.", redFlag: "Parking ratios below 3:1000 SF for office space, or rapidly escalating parking fees with no cap.", tip: "Lock in parking rates with the same escalation cap as your rent, and ensure adequate visitor parking." }
    ]
  },
  {
    id: "legal",
    title: "Legal Provisions",
    icon: "⚖️",
    items: [
      { id: "personal-guarantee", label: "Personal guarantee requirements", lookFor: "Determine if the landlord requires a personal guarantee, the scope, and whether it decreases over time.", redFlag: "Full personal guarantees for the entire lease term with no burn-off, or guarantees that extend to renewal periods.", tip: "Negotiate a 'good-guy guarantee' (you guarantee rent only until you vacate) or a burn-off schedule that reduces exposure over time." },
      { id: "subletting", label: "Subletting and assignment rights", lookFor: "Confirm whether you can sublet or assign, the landlord's approval process, and any profit-sharing requirements.", redFlag: "Blanket prohibitions on subletting, or the landlord keeping 100% of any sublet profits above your rent.", tip: "Negotiate that the landlord cannot unreasonably withhold consent, and that you keep at least 50% of sublet profits." },
      { id: "assignment", label: "Assignment clause (selling the business)", lookFor: "Ensure you can assign the lease if you sell your business, and that the terms transfer to the buyer.", redFlag: "Clauses that let the landlord recapture the space upon assignment, or that void favorable lease terms on transfer.", tip: "Negotiate that assignment in connection with a business sale does not trigger recapture or require landlord profit-sharing." },
      { id: "default-remedies", label: "Default and remedies provisions", lookFor: "Review what constitutes default, the cure period, and the landlord's available remedies (eviction, acceleration, etc.).", redFlag: "Short cure periods (under 10 days for monetary, under 30 days for non-monetary), or acceleration clauses for all remaining rent.", tip: "Negotiate at least 10 days for monetary default cure and 30 days for non-monetary, plus the right to cure before eviction." },
      { id: "dispute-resolution", label: "Dispute resolution mechanism", lookFor: "Check whether disputes go to arbitration, mediation, or litigation, and in what jurisdiction.", redFlag: "Mandatory arbitration with an arbitrator chosen solely by the landlord, or litigation required in a distant jurisdiction.", tip: "Negotiate for mediation first, then arbitration, with mutually agreed-upon arbitrators and a local venue." },
      { id: "force-majeure", label: "Force majeure clause", lookFor: "Confirm the lease addresses events beyond either party's control: natural disasters, pandemics, government orders.", redFlag: "No force majeure clause at all, or one that only protects the landlord but not the tenant.", tip: "Ensure force majeure covers rent abatement if the space becomes unusable due to events outside your control." }
    ]
  },
  {
    id: "hidden-costs",
    title: "Hidden Costs & Gotchas",
    icon: "🔍",
    items: [
      { id: "operating-expenses", label: "Operating expense pass-throughs", lookFor: "Review the base year for operating expenses and understand what costs can be passed through to tenants.", redFlag: "A base year with artificially low expenses (e.g., during a pandemic year), inflating future pass-throughs.", tip: "Negotiate a base year that reflects normalized operations, or set a cap on annual operating expense increases (3-5%)." },
      { id: "tax-escalation", label: "Property tax escalation exposure", lookFor: "Understand how property tax increases are allocated to tenants and whether recent reassessments are pending.", redFlag: "No cap on tax pass-throughs, especially in areas with pending reassessments or new development that could spike taxes.", tip: "Negotiate a tax escalation cap or ensure your proportionate share is based on actual occupancy, not full-building allocation." },
      { id: "hvac-after-hours", label: "After-hours HVAC costs", lookFor: "Get the exact hourly rate for after-hours heating and cooling, and confirm the standard operating hours.", redFlag: "HVAC rates above $75-100/hour, or standard hours that end at 5 PM with no weekend coverage.", tip: "Negotiate extended standard hours (e.g., 8 AM - 7 PM weekdays, half-day Saturday) and a capped after-hours rate." },
      { id: "restoration-costs", label: "End-of-lease restoration requirements", lookFor: "Check whether you must remove improvements and restore the space to its original condition at lease end.", redFlag: "Full restoration requirements for expensive build-outs, potentially costing tens of thousands of dollars.", tip: "Negotiate that the landlord accepts the space 'as-is' at lease end, or specify exactly which improvements must be removed." },
      { id: "relocation-clause", label: "Landlord's right to relocate tenant", lookFor: "Some leases allow the landlord to move you to a different space in the building. Check for this clause.", redFlag: "Any relocation clause, especially one without comparable space guarantees or moving cost coverage.", tip: "Strike the relocation clause entirely, or at minimum require comparable or better space, full moving cost reimbursement, and your approval." },
      { id: "holdover-provisions", label: "Holdover rent provisions", lookFor: "Understand the penalty rate if you stay beyond your lease term (typically 150-200% of the last month's rent).", redFlag: "Holdover rates above 200%, or holdover language that creates a new long-term tenancy rather than month-to-month.", tip: "Negotiate holdover at 125-150% of the then-current rent for the first 60 days, to give you breathing room if renewal talks run long." }
    ]
  }
];

const allItems = sections.flatMap(s => s.items);
const totalItems = allItems.length;

const faqs = [
  {
    q: "What is the most important thing to check in a commercial lease?",
    a: "The rent escalation clause and CAM charges are often the most impactful. A seemingly small 5% annual escalation on a 10-year lease can nearly double your rent. Always model out total occupancy cost over the full lease term, not just year-one rent."
  },
  {
    q: "Should I hire a lawyer to review my lease?",
    a: "Absolutely. A commercial lease is a legally binding contract typically worth hundreds of thousands of dollars over its term. A real estate attorney experienced in commercial leases will cost $1,500-$5,000 for a review but can save you many times that by catching unfavorable terms."
  },
  {
    q: "What is a triple-net (NNN) lease and should I be concerned?",
    a: "In a NNN lease, the tenant pays base rent plus property taxes, insurance, and maintenance costs. While the base rent is lower, your total costs can be unpredictable. Always negotiate caps on NNN expenses and get 3 years of historical expense data before signing."
  },
  {
    q: "How negotiable are commercial leases?",
    a: "Almost everything in a commercial lease is negotiable, especially in tenant-favorable markets. Common wins include free rent months, higher TI allowances, capped escalations, flexible termination rights, and reduced personal guarantees. The landlord's first offer is rarely their best."
  },
  {
    q: "What are the biggest hidden costs in a commercial lease?",
    a: "The most common hidden costs are uncapped CAM and operating expense pass-throughs, after-hours HVAC charges, end-of-lease restoration requirements, and property tax escalations. These can add 20-40% on top of your base rent if not properly negotiated."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Lease Agreement Checklist",
    "description": "Interactive checklist for reviewing commercial and office lease agreements before signing. Covers rent terms, space details, lease flexibility, responsibilities, legal provisions, and hidden costs.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Lease Agreement Checklist — Review Before You Sign",
  description: "Interactive checklist for reviewing commercial leases. Covers rent terms, CAM charges, build-out, termination clauses, and hidden costs with negotiation tips.",
  category: "tool",
  published: "2026-03-21"
};
---

<SiteLayout
  site="getthebag"
  title={meta.title}
  description={meta.description}
  canonical="https://getthebag.photonbuilder.com/lease-agreement-checklist"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Lease Agreement Checklist</h1>
      <p>Don't sign a commercial lease without checking every item. Review rent terms, space details, legal provisions, and hidden costs — with red flags and negotiation tips for each line item.</p>
    </div>

    <div class="progress-bar-container">
      <div class="progress-header">
        <span class="progress-label">Review Progress</span>
        <span class="progress-count" id="progress-count">0 / {totalItems} items checked</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
      </div>
      <div class="progress-pct" id="progress-pct">0% complete</div>
    </div>

    <div class="sections-container">
      {sections.map(section => (
        <section class="checklist-section" id={section.id}>
          <div class="section-header">
            <span class="section-icon">{section.icon}</span>
            <h2>{section.title}</h2>
            <span class="section-count" data-section={section.id}>0 / {section.items.length}</span>
          </div>
          <div class="checklist-items">
            {section.items.map(item => (
              <div class="checklist-item" data-item-id={item.id}>
                <label class="check-label">
                  <input type="checkbox" id={`check-${item.id}`} class="check-input" data-section={section.id} />
                  <span class="checkmark"></span>
                  <span class="item-label">{item.label}</span>
                </label>
                <div class="item-details">
                  <div class="detail-block look-for">
                    <strong>What to look for:</strong>
                    <p>{item.lookFor}</p>
                  </div>
                  <div class="detail-block red-flag">
                    <strong>Red flag:</strong>
                    <p>{item.redFlag}</p>
                  </div>
                  <div class="detail-block tip">
                    <strong>Negotiation tip:</strong>
                    <p>{item.tip}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <section class="content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var STORAGE_KEY = 'lease-checklist-state';
      var checkboxes = document.querySelectorAll('.check-input');
      var progressFill = document.getElementById('progress-fill');
      var progressCount = document.getElementById('progress-count');
      var progressPct = document.getElementById('progress-pct');
      var total = checkboxes.length;

      // Load saved state
      var saved = {};
      try { saved = JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch(e) { saved = {}; }

      checkboxes.forEach(function(cb) {
        var id = cb.id;
        if (saved[id]) {
          cb.checked = true;
          cb.closest('.checklist-item').classList.add('completed');
        }
        cb.addEventListener('change', function() {
          if (cb.checked) {
            saved[cb.id] = true;
            cb.closest('.checklist-item').classList.add('completed');
          } else {
            delete saved[cb.id];
            cb.closest('.checklist-item').classList.remove('completed');
          }
          try { localStorage.setItem(STORAGE_KEY, JSON.stringify(saved)); } catch(e) {}
          updateProgress();
        });
      });

      function updateProgress() {
        var checked = document.querySelectorAll('.check-input:checked').length;
        var pct = total > 0 ? Math.round((checked / total) * 100) : 0;
        progressFill.style.width = pct + '%';
        progressCount.textContent = checked + ' / ' + total + ' items checked';
        progressPct.textContent = pct + '% complete';

        // Update section counts
        var sections = document.querySelectorAll('.section-count');
        sections.forEach(function(el) {
          var sectionId = el.getAttribute('data-section');
          var sectionTotal = document.querySelectorAll('.check-input[data-section="' + sectionId + '"]').length;
          var sectionChecked = document.querySelectorAll('.check-input[data-section="' + sectionId + '"]:checked').length;
          el.textContent = sectionChecked + ' / ' + sectionTotal;
          if (sectionChecked === sectionTotal && sectionTotal > 0) {
            el.classList.add('complete');
          } else {
            el.classList.remove('complete');
          }
        });
      }

      updateProgress();

      // Toggle item details on click
      document.querySelectorAll('.checklist-item').forEach(function(item) {
        item.querySelector('.item-label').addEventListener('click', function(e) {
          item.classList.toggle('expanded');
        });
      });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    /* Progress Bar */
    .progress-bar-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; position: sticky; top: 0; z-index: 10; backdrop-filter: blur(12px); }
    .progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
    .progress-label { font-weight: 700; color: var(--text-primary); font-size: 0.95rem; }
    .progress-count { color: var(--text-secondary); font-size: 0.9rem; }
    .progress-track { width: 100%; height: 10px; background: rgba(255,255,255,0.08); border-radius: 5px; overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #22c55e, #16a34a); border-radius: 5px; transition: width 0.4s ease; }
    .progress-pct { text-align: right; font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.35rem; }

    /* Sections */
    .sections-container { display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 3rem; }
    .checklist-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; }
    .section-header { display: flex; align-items: center; gap: 0.75rem; padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-color); }
    .section-icon { font-size: 1.4rem; }
    .section-header h2 { margin: 0; font-size: 1.25rem; color: var(--text-primary); flex: 1; }
    .section-count { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); background: rgba(255,255,255,0.06); padding: 0.3rem 0.7rem; border-radius: 20px; }
    .section-count.complete { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

    /* Checklist Items */
    .checklist-items { display: flex; flex-direction: column; }
    .checklist-item { border-bottom: 1px solid var(--border-color); padding: 0; transition: background 0.2s; }
    .checklist-item:last-child { border-bottom: none; }
    .checklist-item.completed { background: rgba(34, 197, 94, 0.04); }

    /* Checkbox */
    .check-label { display: flex; align-items: center; gap: 0.75rem; padding: 1rem 1.5rem; cursor: pointer; }
    .check-input { display: none; }
    .checkmark { width: 22px; height: 22px; min-width: 22px; border: 2px solid var(--border-color); border-radius: 6px; display: flex; align-items: center; justify-content: center; transition: all 0.2s; background: transparent; }
    .check-input:checked + .checkmark { background: #22c55e; border-color: #22c55e; }
    .check-input:checked + .checkmark::after { content: '✓'; color: #fff; font-size: 14px; font-weight: 700; }
    .item-label { color: var(--text-primary); font-weight: 500; cursor: pointer; flex: 1; }
    .item-label:hover { text-decoration: underline; text-decoration-color: var(--text-secondary); text-underline-offset: 2px; }
    .checklist-item.completed .item-label { color: var(--text-secondary); text-decoration: line-through; text-decoration-color: var(--text-secondary); }

    /* Item Details (expandable) */
    .item-details { max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.35s ease; padding: 0 1.5rem 0 3.5rem; }
    .checklist-item.expanded .item-details { max-height: 600px; padding: 0 1.5rem 1.25rem 3.5rem; }
    .detail-block { margin-bottom: 0.75rem; }
    .detail-block:last-child { margin-bottom: 0; }
    .detail-block strong { font-size: 0.85rem; display: block; margin-bottom: 0.2rem; }
    .detail-block p { margin: 0; font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; }
    .detail-block.look-for strong { color: #3b82f6; }
    .detail-block.red-flag strong { color: #ef4444; }
    .detail-block.tip strong { color: #22c55e; }

    /* FAQ */
    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1.2rem; margin-top: 2.5rem; }
    .faq-container { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .faq-item h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin: 0; color: var(--text-secondary); line-height: 1.5; }

    @media (max-width: 768px) {
      .hero h1 { font-size: 1.8rem; }
      .section-header { padding: 1rem 1.25rem; }
      .check-label { padding: 0.85rem 1.25rem; }
      .checklist-item.expanded .item-details { padding: 0 1.25rem 1rem 2.75rem; }
      .progress-bar-container { position: static; }
    }
  </style>
</SiteLayout>
