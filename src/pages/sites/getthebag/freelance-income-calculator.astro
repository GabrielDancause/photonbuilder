---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const faqs = [
  {
    q: "How does the freelance income calculator work?",
    a: "Our calculator takes your hourly rate, billable hours, and work weeks to determine your gross income. Then, it subtracts your business expenses, self-employment taxes, and estimated income taxes to give you a clear picture of your real take-home pay."
  },
  {
    q: "What is the self-employment tax?",
    a: "The self-employment tax (usually 15.3% in the US) covers Medicare and Social Security taxes that are typically split between an employer and employee. As a freelancer, you are responsible for the full amount."
  },
  {
    q: "What are common freelance business expenses?",
    a: "Common expenses include software subscriptions, internet bills, hardware/equipment, home office costs, health insurance, and marketing."
  },
  {
    q: "Why is my effective hourly rate lower than my billed rate?",
    a: "Your effective hourly rate accounts for unbillable time (if you work fewer weeks or hours), business expenses, and taxes. This shows you how much you are actually taking home for every hour you bill."
  },
  {
    q: "How can I improve my freelance take-home pay?",
    a: "You can improve your take-home pay by increasing your hourly rate, reducing unnecessary business expenses, optimizing your tax deductions, and increasing your total billable hours."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Freelance Income Calculator",
    "url": "https://getthebag.photonbuilder.com/freelance-income-calculator",
    "description": "Calculate your real freelance take-home pay after taxes, expenses, and self-employment tax. Know your true hourly rate.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "All"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Freelance Income Calculator — Real Take-Home Pay",
  description: "Calculate your real freelance take-home pay after taxes, expenses, and self-employment tax. Know your true hourly rate.",
  category: "calculator",
  published: new Date().toISOString().split('T')[0]
};
---

<SiteLayout
  site="getthebag"
  title={meta.title}
  description={meta.description}
  canonical="https://getthebag.photonbuilder.com/freelance-income-calculator"
  schema={schema}
>
  <div class="calculator-container">
    <div class="header">
      <h1>Freelance Income Calculator</h1>
      <p>Estimate your real take-home pay and effective hourly rate.</p>
    </div>

    <div class="calc-grid">
      <!-- Inputs -->
      <div class="panel inputs-panel">
        <h2>Income Details</h2>
        <div class="input-group">
          <label for="hourlyRate">Hourly Rate ($)</label>
          <input type="number" id="hourlyRate" value="50" min="1" />
        </div>
        <div class="input-group">
          <label for="hoursPerWeek">Billable Hours per Week</label>
          <input type="number" id="hoursPerWeek" value="30" min="1" max="168" />
        </div>
        <div class="input-group">
          <label for="weeksPerYear">Weeks Worked per Year</label>
          <input type="number" id="weeksPerYear" value="48" min="1" max="52" />
        </div>

        <h2>Expenses & Taxes</h2>
        <div class="input-group">
          <label for="annualExpenses">Annual Expenses ($) (software, equipment, etc.)</label>
          <input type="number" id="annualExpenses" value="2000" min="0" />
        </div>
        <div class="input-group">
          <label for="seTaxRate">Self-Employment Tax Rate (%)</label>
          <input type="number" id="seTaxRate" value="15.3" step="0.1" min="0" />
        </div>
        <div class="input-group">
          <label for="incomeTaxRate">Income Tax Bracket (%)</label>
          <input type="number" id="incomeTaxRate" value="22" min="0" max="100" />
        </div>
      </div>

      <!-- Outputs -->
      <div class="panel outputs-panel">
        <h2>Your Results</h2>
        <div class="results-grid">
          <div class="result-card">
            <span>Gross Annual Income</span>
            <strong id="outGross">$0</strong>
          </div>
          <div class="result-card">
            <span>Total Expenses</span>
            <strong id="outExpenses">$0</strong>
          </div>
          <div class="result-card">
            <span>Self-Employment Tax</span>
            <strong id="outSETax">$0</strong>
          </div>
          <div class="result-card">
            <span>Income Tax</span>
            <strong id="outIncomeTax">$0</strong>
          </div>
          <div class="result-card highlight">
            <span>Net Take-Home Pay</span>
            <strong id="outNet">$0</strong>
          </div>
          <div class="result-card">
            <span>Effective Hourly Rate</span>
            <strong id="outEffectiveRate">$0/hr</strong>
          </div>
        </div>

        <div class="chart-container">
          <h3>Income Breakdown</h3>
          <div class="donut-chart" id="donutChart"></div>
          <div class="chart-legend">
            <div class="legend-item"><span class="color-box" style="background: var(--accent-color);"></span> Take-Home</div>
            <div class="legend-item"><span class="color-box" style="background: #ef4444;"></span> Income Tax</div>
            <div class="legend-item"><span class="color-box" style="background: #f59e0b;"></span> SE Tax</div>
            <div class="legend-item"><span class="color-box" style="background: #6b7280;"></span> Expenses</div>
          </div>
        </div>
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faqs">
        {faqs.map(faq => (
          <div class="faq">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    function calculate() {
      const hourlyRate = parseFloat(document.getElementById('hourlyRate').value) || 0;
      const hoursPerWeek = parseFloat(document.getElementById('hoursPerWeek').value) || 0;
      const weeksPerYear = parseFloat(document.getElementById('weeksPerYear').value) || 0;
      const annualExpenses = parseFloat(document.getElementById('annualExpenses').value) || 0;
      const seTaxRate = parseFloat(document.getElementById('seTaxRate').value) || 0;
      const incomeTaxRate = parseFloat(document.getElementById('incomeTaxRate').value) || 0;

      // Calculations
      const grossIncome = hourlyRate * hoursPerWeek * weeksPerYear;
      const taxableIncomeSE = Math.max(0, grossIncome - annualExpenses);

      const seTax = taxableIncomeSE * (seTaxRate / 100);

      const incomeTaxable = Math.max(0, taxableIncomeSE - (seTax / 2));
      const incomeTax = incomeTaxable * (incomeTaxRate / 100);

      const netIncome = grossIncome - annualExpenses - seTax - incomeTax;

      const totalHours = hoursPerWeek * weeksPerYear;
      const effectiveRate = totalHours > 0 ? netIncome / totalHours : 0;

      // Update UI
      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);

      document.getElementById('outGross').innerText = formatCurrency(grossIncome);
      document.getElementById('outExpenses').innerText = formatCurrency(annualExpenses);
      document.getElementById('outSETax').innerText = formatCurrency(seTax);
      document.getElementById('outIncomeTax').innerText = formatCurrency(incomeTax);
      document.getElementById('outNet').innerText = formatCurrency(netIncome);

      // Keep cents for hourly rate
      const formattedRate = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(effectiveRate);
      document.getElementById('outEffectiveRate').innerText = formattedRate + '/hr';

      // Update Chart
      const donutChart = document.getElementById('donutChart');
      if (grossIncome > 0) {
        const netPct = Math.max(0, (netIncome / grossIncome) * 100);
        const incTaxPct = Math.max(0, (incomeTax / grossIncome) * 100);
        const seTaxPct = Math.max(0, (seTax / grossIncome) * 100);
        const expPct = Math.max(0, (annualExpenses / grossIncome) * 100);

        donutChart.style.background = `conic-gradient(
          var(--accent-color) 0% ${netPct}%,
          #ef4444 ${netPct}% ${netPct + incTaxPct}%,
          #f59e0b ${netPct + incTaxPct}% ${netPct + incTaxPct + seTaxPct}%,
          #6b7280 ${netPct + incTaxPct + seTaxPct}% 100%
        )`;
      } else {
        donutChart.style.background = '#e5e7eb';
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const inputs = document.querySelectorAll('.inputs-panel input');
      inputs.forEach(input => input.addEventListener('input', calculate));
      calculate(); // Initial calculation
    });
  </script>

  <style is:inline>
    .calculator-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    .header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .header h1 {
      font-size: 2.2rem;
      margin-bottom: 0.5rem;
      color: var(--text-primary, inherit);
    }
    .header p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }
    .calc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }
    @media (max-width: 768px) {
      .calc-grid {
        grid-template-columns: 1fr;
      }
    }
    .panel {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .panel h2 {
      margin-top: 0;
      margin-bottom: 1.5rem;
      font-size: 1.4rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
      color: var(--text-primary, inherit);
    }
    .input-group {
      margin-bottom: 1rem;
    }
    .input-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: var(--text-secondary);
    }
    .input-group input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      background: var(--card-bg);
      color: inherit;
      font-size: 1rem;
      box-sizing: border-box;
    }
    .input-group input:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 2px rgba(100, 100, 100, 0.2);
    }
    .results-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .result-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      padding: 1rem;
      border-radius: 8px;
      display: flex;
      flex-direction: column;
    }
    .result-card span {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-bottom: 0.25rem;
    }
    .result-card strong {
      font-size: 1.25rem;
      color: var(--text-primary, inherit);
    }
    .result-card.highlight {
      border-color: var(--accent-color);
    }
    .result-card.highlight strong {
      color: var(--accent-color);
      font-size: 1.4rem;
    }
    .chart-container {
      text-align: center;
      margin-top: 2rem;
    }
    .chart-container h3 {
      margin-bottom: 1rem;
      font-size: 1.2rem;
      color: var(--text-primary, inherit);
    }
    .donut-chart {
      width: 200px;
      height: 200px;
      border-radius: 50%;
      background: #e5e7eb;
      margin: 0 auto 1.5rem;
      position: relative;
    }
    .donut-chart::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 120px;
      height: 120px;
      background: var(--card-bg);
      border-radius: 50%;
    }
    .chart-legend {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .color-box {
      width: 12px;
      height: 12px;
      border-radius: 3px;
      display: inline-block;
    }
    .faq-section {
      margin-top: 4rem;
    }
    .faq-section h2 {
      margin-bottom: 1.5rem;
      font-size: 1.8rem;
      color: var(--text-primary, inherit);
    }
    .faqs {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .faq {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      padding: 1.5rem;
      border-radius: 12px;
    }
    .faq h3 {
      margin-top: 0;
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
      color: var(--text-primary, inherit);
    }
    .faq p {
      margin: 0;
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>
</SiteLayout>
