---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const faqs = [
  {
    q: "How does the freelance income calculator work?",
    a: "Our calculator takes your hourly rate, billable hours, and work weeks to determine your gross income. Then, it subtracts your business expenses, self-employment taxes, and estimated income taxes to give you a clear picture of your real take-home pay."
  },
  {
    q: "What is the self-employment tax?",
    a: "The self-employment tax (usually 15.3% in the US) covers Medicare and Social Security taxes that are typically split between an employer and employee. As a freelancer, you are responsible for the full amount."
  },
  {
    q: "What are common freelance business expenses?",
    a: "Common expenses include software subscriptions, internet bills, hardware/equipment, home office costs, health insurance, and marketing."
  },
  {
    q: "Why is my effective hourly rate lower than my billed rate?",
    a: "Your effective hourly rate accounts for unbillable time (if you work fewer weeks or hours), business expenses, and taxes. This shows you how much you are actually taking home for every hour you bill."
  },
  {
    q: "How can I improve my freelance take-home pay?",
    a: "You can improve your take-home pay by increasing your hourly rate, reducing unnecessary business expenses, optimizing your tax deductions, and increasing your total billable hours."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Freelance Income Calculator",
    "url": "https://getthebag.photonbuilder.com/freelance-income-calculator",
    "description": "Calculate your real freelance take-home pay after taxes, expenses, and self-employment tax. Know your true hourly rate.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "All"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Freelance Income Calculator — Real Take-Home Pay",
  description: "Calculate your real freelance take-home pay after taxes, expenses, and self-employment tax. Know your true hourly rate.",
  category: "tool",
  published: new Date().toISOString().split('T')[0]
};
---

<SiteLayout
  site="getthebag"
  title={meta.title}
  description={meta.description}
  canonical="https://getthebag.photonbuilder.com/freelance-income-calculator"
  schema={schema}
>
  <div class="calculator-container">
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      💼 <strong style="color:#3B82F6;">The freelance economy grew 14% in 2026.</strong> More people are going independent than ever — but most underestimate taxes, insurance, and unbillable hours. Calculate your real take-home before making the leap. <a href="https://gab.ae/news/global-freelance-economy-record-growth-2026" style="color:#3B82F6;">The freelance boom →</a>
    </div>
    <div class="header">
      <h1>Freelance Income Calculator</h1>
      <p>Estimate your real take-home pay and effective hourly rate.</p>
    </div>

    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:1.5rem;">
      <span style="font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-secondary);line-height:32px;margin-right:4px;">Presets:</span>
      <button class="preset-pill" onclick="loadPreset(150,30,48,5000,15.3,32)">💻 Software Dev</button>
      <button class="preset-pill" onclick="loadPreset(100,28,48,3000,15.3,24)">🎨 Designer</button>
      <button class="preset-pill" onclick="loadPreset(75,25,46,2000,15.3,22)">✍️ Writer</button>
      <button class="preset-pill" onclick="loadPreset(200,25,46,4000,15.3,35)">📊 Consultant</button>
      <button class="preset-pill" onclick="loadPreset(60,30,48,1500,15.3,22)">📱 Social Media</button>
      <button class="preset-pill" onclick="loadPreset(125,28,46,3500,15.3,24)">📸 Photographer</button>
    </div>

    <div class="calc-grid">
      <!-- Inputs -->
      <div class="panel inputs-panel">
        <h2>Income Details</h2>
        <div class="input-group">
          <label for="hourlyRate">Hourly Rate ($)</label>
          <input type="number" id="hourlyRate" value="50" min="1" />
        </div>
        <div class="input-group">
          <label for="hoursPerWeek">Billable Hours per Week</label>
          <input type="number" id="hoursPerWeek" value="30" min="1" max="168" />
        </div>
        <div class="input-group">
          <label for="weeksPerYear">Weeks Worked per Year</label>
          <input type="number" id="weeksPerYear" value="48" min="1" max="52" />
        </div>

        <h2>Expenses & Taxes</h2>
        <div class="input-group">
          <label for="annualExpenses">Annual Expenses ($) (software, equipment, etc.)</label>
          <input type="number" id="annualExpenses" value="2000" min="0" />
        </div>
        <div class="input-group">
          <label for="seTaxRate">Self-Employment Tax Rate (%)</label>
          <input type="number" id="seTaxRate" value="15.3" step="0.1" min="0" />
        </div>
        <div class="input-group">
          <label for="incomeTaxRate">Income Tax Bracket (%)</label>
          <input type="number" id="incomeTaxRate" value="22" min="0" max="100" />
        </div>

        <h2>Insurance & Retirement</h2>
        <div class="input-group">
          <label for="healthInsurance">Annual Health Insurance ($)</label>
          <input type="number" id="healthInsurance" value="6000" min="0" />
        </div>
        <div class="input-group">
          <label for="retirementPct">Retirement Savings (% of net)</label>
          <input type="number" id="retirementPct" value="15" min="0" max="100" step="1" />
        </div>
      </div>

      <!-- Outputs -->
      <div class="panel outputs-panel">
        <h2>Your Results</h2>
        <div class="results-grid">
          <div class="result-card">
            <span>Gross Annual Income</span>
            <strong id="outGross">$0</strong>
          </div>
          <div class="result-card">
            <span>Total Expenses</span>
            <strong id="outExpenses">$0</strong>
          </div>
          <div class="result-card">
            <span>Self-Employment Tax</span>
            <strong id="outSETax">$0</strong>
          </div>
          <div class="result-card">
            <span>Income Tax</span>
            <strong id="outIncomeTax">$0</strong>
          </div>
          <div class="result-card">
            <span>Health Insurance</span>
            <strong id="outHealth">$0</strong>
          </div>
          <div class="result-card">
            <span>Retirement Savings</span>
            <strong id="outRetirement">$0</strong>
          </div>
          <div class="result-card highlight">
            <span>Net Take-Home Pay</span>
            <strong id="outNet">$0</strong>
          </div>
          <div class="result-card">
            <span>Effective Hourly Rate</span>
            <strong id="outEffectiveRate">$0/hr</strong>
          </div>
          <div class="result-card" style="grid-column: 1/-1; text-align:center; padding:1rem;">
            <span>Monthly Take-Home</span>
            <strong id="outMonthly" style="font-size:1.5rem;">$0</strong>
          </div>
        </div>

        <div class="chart-container">
          <h3>Income Breakdown</h3>
          <div class="donut-chart" id="donutChart"></div>
          <div class="chart-legend">
            <div class="legend-item"><span class="color-box" style="background: var(--accent-color);"></span> Take-Home</div>
            <div class="legend-item"><span class="color-box" style="background: #22c55e;"></span> Retirement</div>
            <div class="legend-item"><span class="color-box" style="background: #8b5cf6;"></span> Health Ins</div>
            <div class="legend-item"><span class="color-box" style="background: #ef4444;"></span> Income Tax</div>
            <div class="legend-item"><span class="color-box" style="background: #f59e0b;"></span> SE Tax</div>
            <div class="legend-item"><span class="color-box" style="background: #6b7280;"></span> Expenses</div>
          </div>
        </div>
      </div>
    </div>

    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faqs">
        {faqs.map(faq => (
          <div class="faq">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    function loadPreset(rate, hours, weeks, expenses, se, tax) {
      document.getElementById('hourlyRate').value = rate;
      document.getElementById('hoursPerWeek').value = hours;
      document.getElementById('weeksPerYear').value = weeks;
      document.getElementById('annualExpenses').value = expenses;
      document.getElementById('seTaxRate').value = se;
      document.getElementById('incomeTaxRate').value = tax;
      calculate();
    }

    function calculate() {
      var hourlyRate = parseFloat(document.getElementById('hourlyRate').value) || 0;
      var hoursPerWeek = parseFloat(document.getElementById('hoursPerWeek').value) || 0;
      var weeksPerYear = parseFloat(document.getElementById('weeksPerYear').value) || 0;
      var annualExpenses = parseFloat(document.getElementById('annualExpenses').value) || 0;
      var seTaxRate = parseFloat(document.getElementById('seTaxRate').value) || 0;
      var incomeTaxRate = parseFloat(document.getElementById('incomeTaxRate').value) || 0;
      var healthIns = parseFloat(document.getElementById('healthInsurance').value) || 0;
      var retirePct = parseFloat(document.getElementById('retirementPct').value) || 0;

      var grossIncome = hourlyRate * hoursPerWeek * weeksPerYear;
      var taxableIncomeSE = Math.max(0, grossIncome - annualExpenses);
      var seTax = taxableIncomeSE * (seTaxRate / 100);
      var incomeTaxable = Math.max(0, taxableIncomeSE - (seTax / 2));
      var incomeTax = incomeTaxable * (incomeTaxRate / 100);

      var afterTaxes = grossIncome - annualExpenses - seTax - incomeTax - healthIns;
      var retirementAmt = Math.max(0, afterTaxes * (retirePct / 100));
      var netIncome = afterTaxes - retirementAmt;

      var totalHours = hoursPerWeek * weeksPerYear;
      var effectiveRate = totalHours > 0 ? netIncome / totalHours : 0;

      var fmt = function(val) { return '$' + Math.round(val).toLocaleString(); };

      document.getElementById('outGross').innerText = fmt(grossIncome);
      document.getElementById('outExpenses').innerText = fmt(annualExpenses);
      document.getElementById('outSETax').innerText = fmt(seTax);
      document.getElementById('outIncomeTax').innerText = fmt(incomeTax);
      document.getElementById('outHealth').innerText = fmt(healthIns);
      document.getElementById('outRetirement').innerText = fmt(retirementAmt);
      document.getElementById('outNet').innerText = fmt(netIncome);
      document.getElementById('outMonthly').innerText = fmt(netIncome / 12);
      document.getElementById('outEffectiveRate').innerText = '$' + effectiveRate.toFixed(2) + '/hr';

      var donutChart = document.getElementById('donutChart');
      if (grossIncome > 0) {
        var netPct = Math.max(0, (netIncome / grossIncome) * 100);
        var retPct = Math.max(0, (retirementAmt / grossIncome) * 100);
        var hlthPct = Math.max(0, (healthIns / grossIncome) * 100);
        var incTaxPct = Math.max(0, (incomeTax / grossIncome) * 100);
        var seTaxPct = Math.max(0, (seTax / grossIncome) * 100);
        var expPct = Math.max(0, (annualExpenses / grossIncome) * 100);

        donutChart.style.background = 'conic-gradient(' +
          'var(--accent-color) 0% ' + netPct + '%,' +
          '#22c55e ' + netPct + '% ' + (netPct + retPct) + '%,' +
          '#8b5cf6 ' + (netPct + retPct) + '% ' + (netPct + retPct + hlthPct) + '%,' +
          '#ef4444 ' + (netPct + retPct + hlthPct) + '% ' + (netPct + retPct + hlthPct + incTaxPct) + '%,' +
          '#f59e0b ' + (netPct + retPct + hlthPct + incTaxPct) + '% ' + (netPct + retPct + hlthPct + incTaxPct + seTaxPct) + '%,' +
          '#6b7280 ' + (netPct + retPct + hlthPct + incTaxPct + seTaxPct) + '% 100%)';
      } else {
        donutChart.style.background = '#e5e7eb';
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      var inputs = document.querySelectorAll('.inputs-panel input');
      inputs.forEach(function(input) { input.addEventListener('input', calculate); });
      calculate();
    });
  </script>

  <style is:inline>
    .preset-pill { background: var(--card-bg); border: 1px solid var(--border-color); color: var(--text-secondary); padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all 0.2s; white-space: nowrap; }
    .preset-pill:hover { border-color: var(--accent-color); color: var(--text-primary, #fff); }
    .calculator-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    .header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .header h1 {
      font-size: 2.2rem;
      margin-bottom: 0.5rem;
      color: var(--text-primary, inherit);
    }
    .header p {
      color: var(--text-secondary);
      font-size: 1.1rem;
    }
    .calc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }
    @media (max-width: 768px) {
      .calc-grid {
        grid-template-columns: 1fr;
      }
    }
    .panel {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .panel h2 {
      margin-top: 0;
      margin-bottom: 1.5rem;
      font-size: 1.4rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
      color: var(--text-primary, inherit);
    }
    .input-group {
      margin-bottom: 1rem;
    }
    .input-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: var(--text-secondary);
    }
    .input-group input {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      background: var(--card-bg);
      color: inherit;
      font-size: 1rem;
      box-sizing: border-box;
    }
    .input-group input:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 2px rgba(100, 100, 100, 0.2);
    }
    .results-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .result-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      padding: 1rem;
      border-radius: 8px;
      display: flex;
      flex-direction: column;
    }
    .result-card span {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin-bottom: 0.25rem;
    }
    .result-card strong {
      font-size: 1.25rem;
      color: var(--text-primary, inherit);
    }
    .result-card.highlight {
      border-color: var(--accent-color);
    }
    .result-card.highlight strong {
      color: var(--accent-color);
      font-size: 1.4rem;
    }
    .chart-container {
      text-align: center;
      margin-top: 2rem;
    }
    .chart-container h3 {
      margin-bottom: 1rem;
      font-size: 1.2rem;
      color: var(--text-primary, inherit);
    }
    .donut-chart {
      width: 200px;
      height: 200px;
      border-radius: 50%;
      background: #e5e7eb;
      margin: 0 auto 1.5rem;
      position: relative;
    }
    .donut-chart::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 120px;
      height: 120px;
      background: var(--card-bg);
      border-radius: 50%;
    }
    .chart-legend {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .color-box {
      width: 12px;
      height: 12px;
      border-radius: 3px;
      display: inline-block;
    }
    .faq-section {
      margin-top: 4rem;
    }
    .faq-section h2 {
      margin-bottom: 1.5rem;
      font-size: 1.8rem;
      color: var(--text-primary, inherit);
    }
    .faqs {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .faq {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      padding: 1.5rem;
      border-radius: 12px;
    }
    .faq h3 {
      margin-top: 0;
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
      color: var(--text-primary, inherit);
    }
    .faq p {
      margin: 0;
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="https://firemaths.info/florida-paycheck-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Florida Paycheck Calculator: Accurate Net Pay Estimator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Calculate your exact Florida take-home pay. Are you losing more to taxes than you think? Our real-time calculator reveal...</p>
      </a>
      <a href="https://firemaths.info/income-tax-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Income Tax Calculator: Find Your True Take-Home Pay</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Stop guessing how much of your paycheck you actually keep. Calculate your true net income after federal, Social Security...</p>
      </a>
      <a href="https://firemaths.info/freelance-rate" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Freelance Rate Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Calculate your ideal hourly and project rates as a freelancer. Factor in desired salary, business expenses, taxes, and b...</p>
      </a>
    </div>
  </div>
</SiteLayout>
