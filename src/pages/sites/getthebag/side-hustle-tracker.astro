    .calc-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .card-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 0.5rem; }
    .card-header h2 { margin-bottom: 0; }

    .summary-card .summary-row { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0; border-bottom: 1px solid var(--border-color); }
    .summary-card .summary-row:last-of-type { border-bottom: none; }
    .summary-card .summary-row span { color: var(--text-secondary); }
    .summary-card .summary-row strong { color: var(--text-primary); font-size: 1.1rem; }
    .summary-card .total-row { border-top: 2px solid var(--border-color); border-bottom: none; margin-top: 0.5rem; padding-top: 1rem; }
    .summary-card .total-row strong { font-size: 1.3rem; color: var(--accent, #3b82f6); }

    /* Hustle tags */
    .hustle-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .hustle-tag { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.4rem 0.75rem; border-radius: 20px; border: 2px solid; background: transparent; font-size: 0.85rem; color: var(--text-primary); }
    .hustle-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
