    .form-input { padding: 0.6rem 0.75rem; border: 1px solid var(--border-color); border-radius: 8px; background: var(--input-bg, rgba(0,0,0,0.1)); color: var(--text-primary); font-size: 0.9rem; font-family: inherit; }
