    .tax-results { margin-top: 0.25rem; }
    .tax-row { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid var(--border-color); }
    .tax-row:last-child { border-bottom: none; }
    .tax-row span { color: var(--text-secondary); font-size: 0.9rem; }
    .tax-row strong { color: var(--text-primary); }
    .highlight-row { border-top: 2px solid var(--border-color); margin-top: 0.25rem; padding-top: 0.75rem; }
