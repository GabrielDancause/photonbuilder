    .content-section h2 { font-size: 1.5rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 0; }

    .calc-grid { display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem; margin-bottom: 2.5rem; }
