    /* Pie chart */
    #pie-chart { display: block; margin: 0 auto; max-width: 100%; }
    .legend-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.3rem 0; font-size: 0.85rem; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
