    .hustle-input:focus { outline: none; border-color: var(--accent, #3b82f6); }

    /* Buttons */
    .action-btn { padding: 0.6rem 1.2rem; border: 2px solid var(--accent, #3b82f6); border-radius: 8px; background: transparent; color: var(--accent, #3b82f6); cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: all 0.2s; white-space: nowrap; font-family: inherit; }
    .action-btn:hover { background: var(--accent, #3b82f6); color: #fff; }
