  { name: "Nashville, TN", country: "US", colIndex: 119, avgRent: 1700, stateTax: 0, salesTax: 9.25 },
  { name: "Atlanta, GA", country: "US", colIndex: 118, avgRent: 1750, stateTax: 5.49, salesTax: 8.9 },
  { name: "Philadelphia, PA", country: "US", colIndex: 133, avgRent: 1800, stateTax: 3.07, salesTax: 8.0 },
  { name: "Dallas, TX", country: "US", colIndex: 117, avgRent: 1600, stateTax: 0, salesTax: 8.25 },
  { name: "Houston, TX", country: "US", colIndex: 112, avgRent: 1450, stateTax: 0, salesTax: 8.25 },
  { name: "Phoenix, AZ", country: "US", colIndex: 111, avgRent: 1400, stateTax: 2.5, salesTax: 8.6 },
  { name: "Minneapolis, MN", country: "US", colIndex: 121, avgRent: 1550, stateTax: 9.85, salesTax: 8.025 },
  { name: "San Diego, CA", country: "US", colIndex: 160, avgRent: 2700, stateTax: 13.3, salesTax: 7.75 },
