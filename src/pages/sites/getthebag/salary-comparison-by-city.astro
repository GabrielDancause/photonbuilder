  { name: "Kansas City, MO", country: "US", colIndex: 100, avgRent: 1150, stateTax: 4.8, salesTax: 9.1 },
  { name: "Columbus, OH", country: "US", colIndex: 104, avgRent: 1250, stateTax: 3.5, salesTax: 7.5 },
  { name: "Indianapolis, IN", country: "US", colIndex: 99, avgRent: 1100, stateTax: 3.05, salesTax: 7.0 },
  { name: "Las Vegas, NV", country: "US", colIndex: 110, avgRent: 1450, stateTax: 0, salesTax: 8.375 },
  { name: "Tampa, FL", country: "US", colIndex: 113, avgRent: 1600, stateTax: 0, salesTax: 7.5 },
  { name: "Orlando, FL", country: "US", colIndex: 111, avgRent: 1550, stateTax: 0, salesTax: 6.5 },
  // International Cities
  { name: "London, UK", country: "UK", colIndex: 175, avgRent: 3100, stateTax: 45, salesTax: 20 },
  { name: "Toronto, Canada", country: "CA", colIndex: 142, avgRent: 2400, stateTax: 53.5, salesTax: 13 },
  { name: "Vancouver, Canada", country: "CA", colIndex: 148, avgRent: 2600, stateTax: 53.5, salesTax: 12 },
  { name: "Sydney, Australia", country: "AU", colIndex: 155, avgRent: 2700, stateTax: 45, salesTax: 10 },
  { name: "Melbourne, Australia", country: "AU", colIndex: 138, avgRent: 2100, stateTax: 45, salesTax: 10 },
  { name: "Berlin, Germany", country: "DE", colIndex: 120, avgRent: 1500, stateTax: 45, salesTax: 19 },
  { name: "Amsterdam, Netherlands", country: "NL", colIndex: 145, avgRent: 2300, stateTax: 49.5, salesTax: 21 },
  { name: "Dublin, Ireland", country: "IE", colIndex: 148, avgRent: 2500, stateTax: 40, salesTax: 23 },
  { name: "Singapore", country: "SG", colIndex: 152, avgRent: 2800, stateTax: 22, salesTax: 9 },
  { name: "Tokyo, Japan", country: "JP", colIndex: 140, avgRent: 1800, stateTax: 45, salesTax: 10 },
  { name: "Dubai, UAE", country: "AE", colIndex: 138, avgRent: 2400, stateTax: 0, salesTax: 5 },
  { name: "Zurich, Switzerland", country: "CH", colIndex: 195, avgRent: 3500, stateTax: 40, salesTax: 8.1 },
  { name: "Lisbon, Portugal", country: "PT", colIndex: 98, avgRent: 1200, stateTax: 48, salesTax: 23 },
  { name: "Mexico City, Mexico", country: "MX", colIndex: 62, avgRent: 800, stateTax: 35, salesTax: 16 },
  { name: "Bangkok, Thailand", country: "TH", colIndex: 55, avgRent: 650, stateTax: 35, salesTax: 7 },
];

const faqs = [
  {
    q: "How is the cost of living index calculated?",
    a: "The cost of living index uses a baseline of 100, representing the US national average. A city with an index of 150 means it costs 50% more than the average US city to maintain the same standard of living. The index factors in housing, groceries, transportation, healthcare, and utilities."
  },
  {
    q: "Does the salary comparison account for taxes?",
    a: "Yes, the tool factors in state and local income tax rates (or national tax rates for international cities) to show the approximate after-tax impact. Keep in mind that actual tax liability depends on many individual factors including filing status, deductions, and credits."
  },
  {
    q: "How accurate is the housing cost data?",
    a: "The housing costs shown represent average monthly rent for a 1-bedroom apartment in the city center as of early 2026. Actual costs vary significantly by neighborhood, apartment size, and market conditions. Use these figures as a relative comparison rather than exact amounts."
  },
  {
    q: "Should I base my relocation decision solely on this tool?",
    a: "No. While salary and cost of living are critical factors, you should also consider career growth opportunities, quality of life, proximity to family, climate preferences, healthcare access, and personal lifestyle priorities. This tool provides the financial picture to inform — not replace — your decision."
  },
  {
    q: "What does purchasing power mean in this context?",
    a: "Purchasing power represents how much your salary can actually buy in a given city after adjusting for the local cost of living. A higher purchasing power score means your dollar goes further. For example, a $100K salary in a city with index 80 gives you more purchasing power than the same salary in a city with index 150."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Salary Comparison by City Tool",
    "description": "Compare salaries adjusted for cost of living across 45+ major US and international cities. See equivalent salary, housing costs, tax impact, and purchasing power.",
    "url": "https://getthebag.photonbuilder.com/salary-comparison-by-city",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Salary Comparison by City — Cost of Living Calculator",
  description: "Compare salaries adjusted for cost of living across 45+ cities. See equivalent salary needed, housing costs, tax impact, and purchasing power.",
  category: "tool",
  published: "2026-03-21"
};
---

<SiteLayout
  site="getthebag"
  title={meta.title}
  description={meta.description}
  canonical="https://getthebag.photonbuilder.com/salary-comparison-by-city"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Salary Comparison by City</h1>
      <p>Enter your current salary and city, then pick target cities to see what you'd really need to earn — adjusted for cost of living, housing, and taxes.</p>
    </div>

    <section class="content-section">
      <div class="input-panel">
        <div class="input-row">
          <div class="input-group">
            <label for="salary-input">Your Current Annual Salary (USD)</label>
            <input type="number" id="salary-input" placeholder="e.g. 85000" min="0" step="1000" />
          </div>
          <div class="input-group">
            <label for="city-select">Your Current City</label>
            <select id="city-select">
              <option value="">Select your city...</option>
              {cities.map((c, i) => (
                <option value={i}>{c.name}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="input-group target-group">
          <label>Target Cities to Compare</label>
          <div class="target-controls">
            <button type="button" id="select-all-btn" class="btn-secondary">Select All US</button>
            <button type="button" id="select-intl-btn" class="btn-secondary">Select All International</button>
            <button type="button" id="clear-btn" class="btn-secondary">Clear All</button>
          </div>
          <div class="city-checkboxes" id="city-checkboxes">
            {cities.map((c, i) => (
              <label class="city-check">
                <input type="checkbox" name="target-city" value={i} />
                <span>{c.name}</span>
              </label>
            ))}
          </div>
        </div>
        <button type="button" id="compare-btn" class="btn-primary">Compare Salaries</button>
      </div>

      <div id="results-container" class="results-container" style="display:none;">
        <h2>Comparison Results</h2>
        <div class="summary-card" id="summary-card"></div>
        <h3>Purchasing Power Chart</h3>
        <div class="chart-container" id="chart-container"></div>
        <h3>Detailed City Breakdown</h3>
        <div id="city-cards"></div>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ cities }}>
    document.addEventListener('DOMContentLoaded', function() {
      const salaryInput = document.getElementById('salary-input');
      const citySelect = document.getElementById('city-select');
      const compareBtn = document.getElementById('compare-btn');
      const resultsContainer = document.getElementById('results-container');
      const summaryCard = document.getElementById('summary-card');
      const chartContainer = document.getElementById('chart-container');
      const cityCards = document.getElementById('city-cards');

      document.getElementById('select-all-btn').addEventListener('click', function() {
        document.querySelectorAll('input[name="target-city"]').forEach(cb => {
          if (cities[parseInt(cb.value)].country === 'US') cb.checked = true;
        });
      });
      document.getElementById('select-intl-btn').addEventListener('click', function() {
        document.querySelectorAll('input[name="target-city"]').forEach(cb => {
          if (cities[parseInt(cb.value)].country !== 'US') cb.checked = true;
        });
      });
      document.getElementById('clear-btn').addEventListener('click', function() {
        document.querySelectorAll('input[name="target-city"]').forEach(cb => { cb.checked = false; });
      });

      function formatMoney(n) {
        return '$' + Math.round(n).toLocaleString('en-US');
      }

      function getVerdict(purchasingPower, rentDiff, taxDiff) {
        // purchasingPower: ratio vs current city (>1 = better)
        // rentDiff: monthly $ diff (positive = more expensive)
        // taxDiff: percentage point diff
        let score = 0;
        if (purchasingPower >= 1.15) score += 3;
        else if (purchasingPower >= 1.05) score += 2;
        else if (purchasingPower >= 0.98) score += 1;
        else if (purchasingPower >= 0.90) score -= 1;
        else score -= 2;

        if (rentDiff < -500) score += 1;
        else if (rentDiff > 500) score -= 1;

        if (taxDiff < -3) score += 1;
        else if (taxDiff > 3) score -= 1;

        if (score >= 3) return { text: "Strongly Worth It", cls: "verdict-great", emoji: "strong-yes" };
        if (score >= 1) return { text: "Likely Worth It", cls: "verdict-good", emoji: "yes" };
        if (score >= 0) return { text: "It's a Wash", cls: "verdict-neutral", emoji: "neutral" };
        if (score >= -2) return { text: "Probably Not Worth It", cls: "verdict-bad", emoji: "no" };
        return { text: "Definitely Not Worth It", cls: "verdict-terrible", emoji: "strong-no" };
      }

      compareBtn.addEventListener('click', function() {
        const salary = parseFloat(salaryInput.value);
        const currentIdx = parseInt(citySelect.value);
        if (!salary || isNaN(currentIdx)) {
          alert('Please enter your salary and select your current city.');
          return;
        }

        const selectedIdxs = [];
        document.querySelectorAll('input[name="target-city"]:checked').forEach(cb => {
          const idx = parseInt(cb.value);
          if (idx !== currentIdx) selectedIdxs.push(idx);
        });

        if (selectedIdxs.length === 0) {
          alert('Please select at least one target city to compare.');
          return;
        }

        const current = cities[currentIdx];
        const currentPP = salary / current.colIndex * 100;

        const results = selectedIdxs.map(idx => {
          const target = cities[idx];
          const equivalentSalary = salary * (target.colIndex / current.colIndex);
          const purchasingPower = current.colIndex / target.colIndex;
          const rentDiff = target.avgRent - current.avgRent;
          const rentDiffAnnual = rentDiff * 12;
          const taxDiff = target.stateTax - current.stateTax;
          const verdict = getVerdict(purchasingPower, rentDiff, taxDiff);
          return {
            city: target,
            equivalentSalary,
            purchasingPower,
            purchasingPowerPct: purchasingPower * 100,
            rentDiff,
            rentDiffAnnual,
            taxDiff,
            verdict
          };
        }).sort((a, b) => b.purchasingPower - a.purchasingPower);

        // Summary
        const best = results[0];
        const worst = results[results.length - 1];
        summaryCard.innerHTML = `
          <div class="summary-grid">
            <div class="summary-stat">
              <span class="stat-label">Your Salary</span>
              <span class="stat-value">${formatMoney(salary)}</span>
              <span class="stat-sub">${current.name}</span>
            </div>
            <div class="summary-stat">
              <span class="stat-label">Best Purchasing Power</span>
              <span class="stat-value good">${best.city.name}</span>
              <span class="stat-sub">${best.purchasingPowerPct.toFixed(0)}% of current</span>
            </div>
            <div class="summary-stat">
              <span class="stat-label">Lowest Purchasing Power</span>
              <span class="stat-value bad">${worst.city.name}</span>
              <span class="stat-sub">${worst.purchasingPowerPct.toFixed(0)}% of current</span>
            </div>
            <div class="summary-stat">
              <span class="stat-label">Cities Compared</span>
              <span class="stat-value">${results.length}</span>
              <span class="stat-sub">vs. ${current.name}</span>
            </div>
          </div>
        `;

        // Chart
        const maxPP = Math.max(...results.map(r => r.purchasingPowerPct), 100);
        chartContainer.innerHTML = `<div class="bar-chart">
          <div class="bar-row baseline-row">
            <span class="bar-label">${current.name} (You)</span>
            <div class="bar-track"><div class="bar-fill baseline" style="width:${(100 / maxPP * 100).toFixed(1)}%"><span>100%</span></div></div>
          </div>
          ${results.map(r => {
            const w = (r.purchasingPowerPct / maxPP * 100).toFixed(1);
            const cls = r.purchasingPower >= 1 ? 'positive' : 'negative';
            return `<div class="bar-row">
              <span class="bar-label">${r.city.name}</span>
              <div class="bar-track"><div class="bar-fill ${cls}" style="width:${w}%"><span>${r.purchasingPowerPct.toFixed(0)}%</span></div></div>
            </div>`;
          }).join('')}
        </div>`;

        // City cards
        cityCards.innerHTML = results.map(r => `
          <div class="city-card">
            <div class="city-card-header">
              <h4>${r.city.name}</h4>
              <span class="verdict-badge ${r.verdict.cls}">${r.verdict.text}</span>
            </div>
            <div class="city-card-grid">
              <div class="metric">
                <span class="metric-label">Equivalent Salary Needed</span>
                <span class="metric-value">${formatMoney(r.equivalentSalary)}</span>
              </div>
              <div class="metric">
                <span class="metric-label">Cost of Living Index</span>
                <span class="metric-value">${r.city.colIndex}</span>
              </div>
              <div class="metric">
                <span class="metric-label">Purchasing Power</span>
                <span class="metric-value ${r.purchasingPower >= 1 ? 'good' : 'bad'}">${r.purchasingPowerPct.toFixed(1)}%</span>
              </div>
              <div class="metric">
                <span class="metric-label">Avg Rent (1BR)</span>
                <span class="metric-value">${formatMoney(r.city.avgRent)}/mo</span>
              </div>
              <div class="metric">
                <span class="metric-label">Housing Cost Diff</span>
                <span class="metric-value ${r.rentDiff <= 0 ? 'good' : 'bad'}">${r.rentDiff >= 0 ? '+' : ''}${formatMoney(r.rentDiff)}/mo</span>
              </div>
              <div class="metric">
                <span class="metric-label">Top Tax Rate</span>
                <span class="metric-value">${r.city.stateTax}%</span>
              </div>
              <div class="metric">
                <span class="metric-label">Tax Rate Diff</span>
                <span class="metric-value ${r.taxDiff <= 0 ? 'good' : 'bad'}">${r.taxDiff >= 0 ? '+' : ''}${r.taxDiff.toFixed(1)}pp</span>
              </div>
              <div class="metric">
                <span class="metric-label">Annual Housing Diff</span>
                <span class="metric-value ${r.rentDiffAnnual <= 0 ? 'good' : 'bad'}">${r.rentDiffAnnual >= 0 ? '+' : ''}${formatMoney(r.rentDiffAnnual)}/yr</span>
              </div>
            </div>
          </div>
        `).join('');

        resultsContainer.style.display = 'block';
        resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1.2rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.4rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem; }

    /* Input Panel */
    .input-panel { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group label { font-weight: 600; color: var(--text-primary); font-size: 0.95rem; }
    .input-group input, .input-group select { padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary, #0a0a0a); color: var(--text-primary); font-size: 1rem; }
    .input-group input:focus, .input-group select:focus { outline: none; border-color: var(--accent-primary, #3b82f6); box-shadow: 0 0 0 3px rgba(59,130,246,0.15); }

    .target-group { margin-bottom: 1.5rem; }
    .target-controls { display: flex; gap: 0.75rem; margin-bottom: 0.75rem; flex-wrap: wrap; }
    .btn-secondary { padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: transparent; color: var(--text-secondary); font-size: 0.85rem; cursor: pointer; transition: all 0.2s; }
    .btn-secondary:hover { border-color: var(--accent-primary, #3b82f6); color: var(--text-primary); }
    .city-checkboxes { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.4rem; max-height: 280px; overflow-y: auto; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 8px; background: var(--bg-primary, #0a0a0a); }
    .city-check { display: flex; align-items: center; gap: 0.4rem; font-size: 0.9rem; color: var(--text-secondary); cursor: pointer; padding: 0.25rem 0; }
    .city-check input { accent-color: var(--accent-primary, #3b82f6); }
    .city-check:hover span { color: var(--text-primary); }

    .btn-primary { width: 100%; padding: 0.9rem; border-radius: 8px; border: none; background: var(--accent-primary, #3b82f6); color: #fff; font-size: 1.05rem; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
    .btn-primary:hover { opacity: 0.9; }

    /* Results */
    .results-container { margin-bottom: 2rem; }
    .summary-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
    .summary-stat { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.25rem; }
    .stat-label { font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-value { font-size: 1.3rem; font-weight: 700; color: var(--text-primary); }
    .stat-value.good { color: #22c55e; }
    .stat-value.bad { color: #ef4444; }
    .stat-sub { font-size: 0.85rem; color: var(--text-secondary); }

    /* Bar Chart */
    .chart-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; overflow-x: auto; }
    .bar-chart { display: flex; flex-direction: column; gap: 0.5rem; min-width: 500px; }
    .bar-row { display: flex; align-items: center; gap: 0.75rem; }
    .bar-label { width: 180px; min-width: 180px; font-size: 0.85rem; color: var(--text-secondary); text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .bar-track { flex: 1; background: rgba(255,255,255,0.05); border-radius: 6px; height: 28px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 6px; display: flex; align-items: center; justify-content: flex-end; padding: 0 8px; font-size: 0.78rem; font-weight: 600; color: #fff; transition: width 0.5s ease; min-width: 40px; }
    .bar-fill.baseline { background: var(--accent-primary, #3b82f6); }
    .bar-fill.positive { background: #22c55e; }
    .bar-fill.negative { background: #ef4444; }
    .baseline-row .bar-label { font-weight: 700; color: var(--text-primary); }

    /* City Cards */
    .city-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 1rem; }
    .city-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
    .city-card-header h4 { margin: 0; font-size: 1.2rem; color: var(--text-primary); }
