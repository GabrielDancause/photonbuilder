---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    "q": "Do I have to pay taxes on my side hustle income?",
    "a": "Yes, generally any income earned from a side hustle is subject to income and self-employment taxes. It is crucial to track your earnings and expenses and consult a tax professional."
  },
  {
    "q": "How do I balance a side hustle with a full-time job?",
    "a": "Effective time management is key. Set specific hours for your side hustle, use time-blocking, prioritize high-impact tasks, and ensure you schedule time for rest to prevent burnout."
  },
  {
    "q": "How long does it take to make money from a side hustle?",
    "a": "It varies widely. Service-based hustles like tutoring or pet sitting can pay within days, while content creation or affiliate marketing may take months to generate your first dollar."
  },
  {
    "q": "Do I need to form an LLC for my side hustle?",
    "a": "Not immediately for most side hustles. Many start as sole proprietorships. As your business grows or if it involves significant liability, forming an LLC can protect your personal assets."
  },
  {
    "q": "What is the best side hustle for beginners?",
    "a": "The best beginner side hustle requires low upfront costs and utilizes your existing skills. Freelancing, pet sitting, and virtual assistance are great starting points with immediate income potential."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];
---

