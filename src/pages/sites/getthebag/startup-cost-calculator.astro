---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How much does it really cost to start a business?",
    a: "It varies enormously by type. A freelancing or consulting business can launch for under $500, while a restaurant may require $100,000–$500,000+. Use our calculator above to get a realistic estimate based on your specific business type and customize each line item to match your local market."
  },
  {
    q: "What's the difference between one-time and recurring costs?",
    a: "One-time costs are upfront expenses you pay once to launch (like legal registration, initial equipment, and buildout). Recurring costs are ongoing monthly expenses (like rent, insurance, software subscriptions, and payroll). Both matter for planning — one-time costs determine how much capital you need to start, while recurring costs determine your monthly burn rate."
  },
  {
    q: "How much runway should a new business have?",
    a: "Most financial advisors recommend having 6–12 months of operating expenses saved before launching. This gives you enough time to build revenue without running out of cash. The runway calculator above helps you see exactly how many months your savings will cover based on your projected costs."
  },
  {
    q: "What is a funding gap and how do I close it?",
    a: "A funding gap is the difference between what you need to launch and operate your business and the savings you have available. Common ways to close the gap include small business loans (SBA), business lines of credit, angel investors, crowdfunding, grants, or starting with a leaner version of your business plan."
  },
  {
    q: "Which business type has the lowest startup costs?",
    a: "Freelancing and consulting typically have the lowest startup costs since you're selling your existing skills with minimal overhead — often under $1,000 total. Online stores and SaaS businesses are next, usually ranging from $2,000–$15,000. Brick-and-mortar businesses like restaurants and retail stores are the most capital-intensive."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Startup Cost Calculator",
    "description": "Estimate startup costs by business type. Get realistic cost breakdowns for legal, equipment, inventory, marketing, rent, insurance, technology, and staffing.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Startup Cost Calculator — Estimate Business Launch Costs",
  description: "Estimate startup costs by business type. Get cost breakdowns for legal, equipment, inventory, marketing, rent, insurance, technology, and staffing with runway analysis.",
  category: "tool",
  published: "2026-03-21"
};
---

<SiteLayout
  site="getthebag"
  title={meta.title}
  description={meta.description}
  canonical="https://getthebag.photonbuilder.com/startup-cost-calculator"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      🚀 <strong style="color:#3B82F6;">82% of startups fail due to cash flow problems — not bad ideas.</strong> The average SaaS startup costs $12K–$50K to launch, while a food truck runs $50K–$200K. Know your burn rate before you quit your day job. <a href="https://gab.ae/news/global-freelance-economy-record-growth-2026" style="color:#3B82F6;">The freelance-to-founder pipeline is booming →</a>
    </div>
    <div class="hero">
      <h1>Startup Cost Calculator</h1>
      <p>Estimate realistic startup costs by business type. Choose a preset, customize each line item, and see your total investment, monthly burn rate, and how long your savings will last.</p>
    </div>

    <section class="content-section">
      <div class="calc-grid">
        <div class="calc-main">
          <div class="card">
            <h2>Business Type</h2>
