            { name: 'Digital Marketing/Ads', amount: 500 },
            { name: 'Payment Processing Fees', amount: 150 },
            { name: 'Shipping Supplies', amount: 200 },
            { name: 'Insurance', amount: 100 },
            { name: 'Accounting Software', amount: 30 }
          ]
        },
        'Restaurant': {
          onetime: [
            { name: 'Business Registration/Licenses', amount: 3000 },
            { name: 'Lease Deposit (3 months)', amount: 15000 },
            { name: 'Kitchen Equipment', amount: 50000 },
            { name: 'Furniture & Fixtures', amount: 25000 },
            { name: 'Interior Buildout', amount: 40000 },
            { name: 'Initial Food Inventory', amount: 5000 },
            { name: 'POS System', amount: 3000 },
            { name: 'Signage', amount: 2500 }
          ],
          recurring: [
            { name: 'Rent/Lease', amount: 5000 },
            { name: 'Payroll (Staff)', amount: 15000 },
            { name: 'Food & Beverage Costs', amount: 8000 },
            { name: 'Utilities', amount: 1200 },
            { name: 'Insurance', amount: 500 },
            { name: 'Marketing', amount: 800 },
            { name: 'Maintenance & Supplies', amount: 600 },
            { name: 'Accounting/Bookkeeping', amount: 300 }
          ]
        },
        'Food Truck': {
          onetime: [
            { name: 'Business Registration/Licenses', amount: 2000 },
            { name: 'Food Truck Purchase/Lease', amount: 50000 },
            { name: 'Kitchen Equipment', amount: 10000 },
            { name: 'Vehicle Wrap/Branding', amount: 3500 },
            { name: 'Initial Food Inventory', amount: 2000 },
            { name: 'POS System', amount: 1000 },
            { name: 'Health Permits', amount: 1000 }
          ],
          recurring: [
            { name: 'Commissary Kitchen Rent', amount: 1000 },
            { name: 'Food Costs', amount: 3000 },
            { name: 'Fuel', amount: 400 },
            { name: 'Payroll (1-2 Staff)', amount: 4000 },
            { name: 'Insurance', amount: 350 },
            { name: 'Parking/Event Fees', amount: 500 },
            { name: 'Marketing', amount: 300 },
            { name: 'Maintenance', amount: 200 }
          ]
        },
        'Consulting': {
          onetime: [
            { name: 'Business Registration/LLC', amount: 500 },
            { name: 'Professional Website', amount: 1500 },
            { name: 'Laptop/Computer', amount: 1500 },
            { name: 'Branding & Business Cards', amount: 300 },
            { name: 'Professional Certifications', amount: 1000 }
          ],
          recurring: [
            { name: 'Coworking Space/Office', amount: 300 },
            { name: 'Software Subscriptions', amount: 150 },
            { name: 'Marketing/Networking', amount: 200 },
            { name: 'Insurance (E&O)', amount: 200 },
            { name: 'Accounting Software', amount: 30 },
            { name: 'Phone/Internet', amount: 100 }
          ]
        },
        'SaaS': {
          onetime: [
            { name: 'Business Registration/LLC', amount: 500 },
            { name: 'MVP Development', amount: 15000 },
            { name: 'UI/UX Design', amount: 5000 },
            { name: 'Branding & Logo', amount: 1000 },
