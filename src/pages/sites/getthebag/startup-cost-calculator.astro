            <button class="add-btn" id="add-onetime">+ Add Custom Item</button>
            <div class="cost-subtotal">
              <span>Total One-Time Costs</span>
              <strong id="onetime-total">$0</strong>
            </div>
          </div>

          <div class="card">
            <h2>Monthly Recurring Costs</h2>
            <div id="recurring-costs"></div>
            <button class="add-btn" id="add-recurring">+ Add Custom Item</button>
            <div class="cost-subtotal">
              <span>Total Monthly Costs</span>
              <strong id="recurring-total">$0</strong>
            </div>
          </div>
        </div>

        <div class="calc-sidebar">
          <div class="card summary-card">
            <h2>Cost Summary</h2>
            <div class="summary-row">
              <span>One-Time Costs</span>
              <strong id="summary-onetime">$0</strong>
            </div>
            <div class="summary-row">
              <span>Monthly Recurring</span>
              <strong id="summary-recurring">$0</strong>
            </div>
            <div class="summary-row total-row">
              <span>First Year Total</span>
              <strong id="summary-first-year">$0</strong>
            </div>
          </div>

          <div class="card">
            <h2>Runway Calculator</h2>
            <label class="input-label" for="savings-input">Your Available Savings</label>
            <div class="input-prefix-wrap">
              <span class="input-prefix">$</span>
              <input type="number" id="savings-input" value="50000" min="0" step="1000">
            </div>
            <div class="runway-result" id="runway-result">
              <div class="runway-months">
                <span class="runway-number" id="runway-months">0</span>
                <span class="runway-label">months of runway</span>
              </div>
              <div class="runway-bar-container">
                <div class="runway-bar" id="runway-bar"></div>
              </div>
              <p class="runway-note" id="runway-note"></p>
            </div>
          </div>

          <div class="card">
            <h2>Funding Gap Analysis</h2>
            <div id="funding-gap-content">
              <div class="gap-row">
                <span>Total Capital Needed (12 mo)</span>
                <strong id="gap-needed">$0</strong>
              </div>
              <div class="gap-row">
                <span>Your Savings</span>
                <strong id="gap-savings">$0</strong>
              </div>
              <div class="gap-row gap-result" id="gap-result-row">
                <span id="gap-label">Funding Gap</span>
                <strong id="gap-amount">$0</strong>
              </div>
              <p class="gap-note" id="gap-note"></p>
            </div>
          </div>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var presets = {
        'Online Store': {
          onetime: [
            { name: 'Business Registration/LLC', amount: 500 },
            { name: 'Website/Platform Setup', amount: 2000 },
            { name: 'Initial Inventory', amount: 3000 },
            { name: 'Branding & Logo Design', amount: 800 },
            { name: 'Product Photography', amount: 500 },
            { name: 'Packaging Design', amount: 300 }
          ],
