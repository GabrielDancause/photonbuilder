          ]
        },
        'Freelancing': {
          onetime: [
            { name: 'Business Registration', amount: 200 },
            { name: 'Portfolio Website', amount: 500 },
            { name: 'Computer/Equipment', amount: 1200 },
            { name: 'Software Licenses', amount: 300 }
          ],
          recurring: [
            { name: 'Software Subscriptions', amount: 80 },
            { name: 'Internet', amount: 70 },
            { name: 'Marketing/Portfolio Hosting', amount: 30 },
            { name: 'Accounting Software', amount: 20 },
            { name: 'Insurance', amount: 100 }
          ]
        },
        'Retail Store': {
          onetime: [
            { name: 'Business Registration/Licenses', amount: 1500 },
            { name: 'Lease Deposit (3 months)', amount: 9000 },
            { name: 'Store Buildout/Renovation', amount: 20000 },
            { name: 'Fixtures & Displays', amount: 8000 },
            { name: 'Initial Inventory', amount: 25000 },
            { name: 'POS System', amount: 2000 },
            { name: 'Signage', amount: 2000 },
            { name: 'Security System', amount: 1500 }
          ],
          recurring: [
            { name: 'Rent/Lease', amount: 3000 },
            { name: 'Payroll (Staff)', amount: 6000 },
            { name: 'Inventory Replenishment', amount: 5000 },
            { name: 'Utilities', amount: 500 },
            { name: 'Insurance', amount: 300 },
            { name: 'Marketing', amount: 500 },
            { name: 'POS/Software Fees', amount: 100 },
            { name: 'Maintenance', amount: 200 }
          ]
        },
        'Salon / Barber': {
          onetime: [
            { name: 'Business Registration/Licenses', amount: 1000 },
            { name: 'Lease Deposit (3 months)', amount: 6000 },
            { name: 'Buildout & Plumbing', amount: 15000 },
            { name: 'Salon Chairs & Stations', amount: 8000 },
            { name: 'Initial Product Inventory', amount: 3000 },
            { name: 'Signage & Branding', amount: 1500 },
            { name: 'POS System', amount: 1000 }
          ],
          recurring: [
            { name: 'Rent/Lease', amount: 2000 },
            { name: 'Payroll (Stylists)', amount: 6000 },
            { name: 'Product Supplies', amount: 800 },
            { name: 'Utilities', amount: 400 },
            { name: 'Insurance', amount: 250 },
            { name: 'Marketing', amount: 300 },
            { name: 'Booking Software', amount: 50 },
            { name: 'Laundry/Cleaning', amount: 150 }
          ]
        }
      };

      var currentPreset = null;

      function fmt(n) {
        return '$' + Math.round(n).toLocaleString('en-US');
      }

      function renderPresets() {
        var grid = document.getElementById('preset-grid');
        grid.innerHTML = '';
        var icons = {
          'Online Store': '\uD83D\uDED2', 'Restaurant': '\uD83C\uDF7D\uFE0F', 'Food Truck': '\uD83D\uDE9A',
          'Consulting': '\uD83D\uDCBC', 'SaaS': '\uD83D\uDCBB', 'Freelancing': '\u270D\uFE0F',
          'Retail Store': '\uD83C\uDFEA', 'Salon / Barber': '\u2702\uFE0F'
        };
        Object.keys(presets).forEach(function(name) {
          var btn = document.createElement('button');
          btn.className = 'preset-btn' + (currentPreset === name ? ' active' : '');
          btn.innerHTML = '<span class="preset-icon">' + (icons[name] || '') + '</span><span class="preset-name">' + name + '</span>';
          btn.addEventListener('click', function() { selectPreset(name); });
          grid.appendChild(btn);
        });
      }

      function selectPreset(name) {
        currentPreset = name;
        var data = presets[name];
        renderCostList('onetime-costs', data.onetime, 'onetime');
        renderCostList('recurring-costs', data.recurring, 'recurring');
        renderPresets();
        recalculate();
      }

      function renderCostList(containerId, items, type) {
        var container = document.getElementById(containerId);
        container.innerHTML = '';
        items.forEach(function(item, idx) {
          var row = document.createElement('div');
          row.className = 'cost-row';
          row.setAttribute('data-type', type);
          row.setAttribute('data-index', idx);
          row.innerHTML =
            '<input type="text" class="cost-name" value="' + item.name + '" placeholder="Item name">' +
            '<div class="input-prefix-wrap compact"><span class="input-prefix">$</span>' +
            '<input type="number" class="cost-amount" value="' + item.amount + '" min="0" step="50"></div>' +
            '<button class="remove-btn" title="Remove">\u00D7</button>';
          row.querySelector('.cost-amount').addEventListener('input', recalculate);
          row.querySelector('.cost-name').addEventListener('input', function() { syncToPreset(); });
          row.querySelector('.remove-btn').addEventListener('click', function() {
            row.remove();
            syncToPreset();
            recalculate();
          });
          container.appendChild(row);
        });
      }

      function syncToPreset() {
        if (!currentPreset) return;
        presets[currentPreset].onetime = getItems('onetime-costs');
        presets[currentPreset].recurring = getItems('recurring-costs');
      }

      function getItems(containerId) {
        var rows = document.getElementById(containerId).querySelectorAll('.cost-row');
        var items = [];
        rows.forEach(function(row) {
          items.push({
            name: row.querySelector('.cost-name').value,
            amount: parseFloat(row.querySelector('.cost-amount').value) || 0
          });
        });
        return items;
      }

      function addItem(containerId, type) {
        var container = document.getElementById(containerId);
        var idx = container.querySelectorAll('.cost-row').length;
        var row = document.createElement('div');
        row.className = 'cost-row';
        row.setAttribute('data-type', type);
        row.setAttribute('data-index', idx);
        row.innerHTML =
          '<input type="text" class="cost-name" value="" placeholder="Custom item">' +
          '<div class="input-prefix-wrap compact"><span class="input-prefix">$</span>' +
          '<input type="number" class="cost-amount" value="0" min="0" step="50"></div>' +
          '<button class="remove-btn" title="Remove">\u00D7</button>';
        row.querySelector('.cost-amount').addEventListener('input', recalculate);
        row.querySelector('.cost-name').addEventListener('input', function() { syncToPreset(); });
        row.querySelector('.remove-btn').addEventListener('click', function() {
          row.remove();
          syncToPreset();
          recalculate();
        });
        container.appendChild(row);
        row.querySelector('.cost-name').focus();
        syncToPreset();
      }

      function recalculate() {
        syncToPreset();
        var onetimeItems = getItems('onetime-costs');
        var recurringItems = getItems('recurring-costs');

        var onetimeTotal = onetimeItems.reduce(function(s, i) { return s + i.amount; }, 0);
        var recurringTotal = recurringItems.reduce(function(s, i) { return s + i.amount; }, 0);
        var firstYear = onetimeTotal + (recurringTotal * 12);

        document.getElementById('onetime-total').textContent = fmt(onetimeTotal);
        document.getElementById('recurring-total').textContent = fmt(recurringTotal) + '/mo';
        document.getElementById('summary-onetime').textContent = fmt(onetimeTotal);
        document.getElementById('summary-recurring').textContent = fmt(recurringTotal) + '/mo';
        document.getElementById('summary-first-year').textContent = fmt(firstYear);

        // Runway
        var savings = parseFloat(document.getElementById('savings-input').value) || 0;
        var remaining = savings - onetimeTotal;
        var months = recurringTotal > 0 ? Math.max(0, Math.floor(remaining / recurringTotal)) : (remaining >= 0 ? 99 : 0);
        var displayMonths = Math.min(months, 99);

        document.getElementById('runway-months').textContent = displayMonths >= 99 ? '99+' : displayMonths;
        var barPct = Math.min(100, (displayMonths / 24) * 100);
        var bar = document.getElementById('runway-bar');
        bar.style.width = barPct + '%';
        bar.className = 'runway-bar' + (displayMonths < 6 ? ' danger' : displayMonths < 12 ? ' warning' : ' healthy');

        var note = document.getElementById('runway-note');
        if (remaining < 0) {
          note.textContent = 'Your savings don\u2019t cover the initial startup costs.';
          note.className = 'runway-note danger-text';
        } else if (displayMonths < 6) {
          note.textContent = 'Less than 6 months of runway. Consider additional funding.';
          note.className = 'runway-note danger-text';
        } else if (displayMonths < 12) {
          note.textContent = 'Moderate runway. Aim for 12+ months for safety.';
          note.className = 'runway-note warning-text';
        } else {
          note.textContent = 'Healthy runway of 12+ months. You\u2019re well positioned.';
          note.className = 'runway-note healthy-text';
        }

        // Funding gap
        document.getElementById('gap-needed').textContent = fmt(firstYear);
        document.getElementById('gap-savings').textContent = fmt(savings);
        var gap = firstYear - savings;
        var gapRow = document.getElementById('gap-result-row');
        var gapLabel = document.getElementById('gap-label');
        var gapAmount = document.getElementById('gap-amount');
        var gapNote = document.getElementById('gap-note');

        if (gap > 0) {
          gapLabel.textContent = 'Funding Gap';
          gapAmount.textContent = fmt(gap);
          gapRow.className = 'gap-row gap-result gap-negative';
          gapNote.textContent = 'You need ' + fmt(gap) + ' in additional funding to cover your first year.';
          gapNote.className = 'gap-note danger-text';
        } else {
          gapLabel.textContent = 'Surplus';
          gapAmount.textContent = fmt(Math.abs(gap));
          gapRow.className = 'gap-row gap-result gap-positive';
          gapNote.textContent = 'Your savings cover the first year with ' + fmt(Math.abs(gap)) + ' to spare.';
          gapNote.className = 'gap-note healthy-text';
        }
      }

      document.getElementById('add-onetime').addEventListener('click', function() { addItem('onetime-costs', 'onetime'); });
      document.getElementById('add-recurring').addEventListener('click', function() { addItem('recurring-costs', 'recurring'); });
      document.getElementById('savings-input').addEventListener('input', recalculate);

      renderPresets();
      selectPreset('Online Store');
    });
  </script>

  <style is:inline>
    .page-content { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.5rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 0; }

    .calc-grid { display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem; margin-bottom: 2.5rem; }
    .calc-main { display: flex; flex-direction: column; gap: 1.5rem; }
    .calc-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }

    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .summary-card .summary-row { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0; border-bottom: 1px solid var(--border-color); }
    .summary-card .summary-row:last-of-type { border-bottom: none; }
    .summary-card .summary-row span { color: var(--text-secondary); }
    .summary-card .summary-row strong { color: var(--text-primary); font-size: 1.1rem; }
    .summary-card .total-row { border-top: 2px solid var(--border-color); border-bottom: none; margin-top: 0.5rem; padding-top: 1rem; }
    .summary-card .total-row strong { font-size: 1.3rem; color: var(--accent, #3b82f6); }

    /* Presets */
    .preset-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; }
    .preset-btn { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; padding: 0.75rem 0.5rem; border-radius: 10px; border: 2px solid var(--border-color); background: transparent; color: var(--text-secondary); cursor: pointer; transition: all 0.2s; font-size: 0.8rem; font-family: inherit; }
    .preset-btn:hover { border-color: var(--accent, #3b82f6); color: var(--text-primary); }
    .preset-btn.active { border-color: var(--accent, #3b82f6); background: rgba(59, 130, 246, 0.1); color: var(--text-primary); }
    .preset-icon { font-size: 1.4rem; }
    .preset-name { font-weight: 600; text-align: center; line-height: 1.2; }

    /* Cost rows */
    .cost-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
    .cost-name { flex: 1; padding: 0.6rem 0.75rem; border: 1px solid var(--border-color); border-radius: 8px; background: var(--input-bg, rgba(0,0,0,0.1)); color: var(--text-primary); font-size: 0.9rem; font-family: inherit; }
    .cost-name:focus, .cost-amount:focus { outline: none; border-color: var(--accent, #3b82f6); }

    .input-prefix-wrap { position: relative; display: flex; align-items: center; }
    .input-prefix-wrap.compact { width: 130px; flex-shrink: 0; }
    .input-prefix { position: absolute; left: 0.75rem; color: var(--text-secondary); font-weight: 600; pointer-events: none; z-index: 1; }
    .input-prefix-wrap input { width: 100%; padding: 0.6rem 0.75rem 0.6rem 1.5rem; border: 1px solid var(--border-color); border-radius: 8px; background: var(--input-bg, rgba(0,0,0,0.1)); color: var(--text-primary); font-size: 0.9rem; font-family: inherit; }
