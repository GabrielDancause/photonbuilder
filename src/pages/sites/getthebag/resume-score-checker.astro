---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Resume Score Checker | Instant Free Feedback & ATS Scan',
  description: '75% of resumes are rejected by ATS before a human sees them. Paste your resume for an instant score on action verbs, quantified achievements, and ATS compatibility.',
  category: 'tool',
  keywords: ['resume score checker', 'ats score', 'resume feedback', 'resume scanner', 'power words suggester']
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Get The Bag" },
    "publisher": { "@type": "Organization", "name": "Get The Bag" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is the resume score calculated?",
        "acceptedAnswer": { "@type": "Answer", "text": "We analyze your resume across five key dimensions: use of strong action verbs, presence of quantified achievements (numbers/metrics), keyword density, optimal length, and ATS-friendly formatting." }
      },
      {
        "@type": "Question",
        "name": "What is an ATS compatibility score?",
        "acceptedAnswer": { "@type": "Answer", "text": "An Applicant Tracking System (ATS) score estimates how well software can parse your resume. It looks for standard headers, simple formatting without complex tables, and proper keyword usage." }
      },
      {
        "@type": "Question",
        "name": "Why are quantified achievements important?",
        "acceptedAnswer": { "@type": "Answer", "text": "Hiring managers want to see the impact of your work, not just your responsibilities. Saying 'Increased sales by 15%' is much stronger than simply stating 'Responsible for increasing sales'." }
      },
      {
        "@type": "Question",
        "name": "What are resume power words?",
        "acceptedAnswer": { "@type": "Answer", "text": "Power words are strong action verbs like 'Spearheaded', 'Optimized', and 'Engineered' that demonstrate leadership and initiative, replacing weak phrases like 'Helped with' or 'Responsible for'." }
      },
      {
        "@type": "Question",
        "name": "How long should a good resume be?",
        "acceptedAnswer": { "@type": "Answer", "text": "For most professionals, a 1-2 page resume is ideal. Entry-level candidates should stick to one page, while those with 10+ years of experience may need two pages to adequately detail their career progression." }
      }
    ]
  }
];
---

<SiteLayout site="getthebag" title={meta.title} description={meta.description} canonical="https://getthebag.photonbuilder.com/resume-score-checker" schema={JSON.stringify(schema)}>
  <!-- HERO -->
  <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
    📄 <strong style="color:#3B82F6;">Freelancers now outearn traditional employees in 42% of fields.</strong> But whether you go freelance or corporate, your resume is the gatekeeper. Get your score below — and make every application count. <a href="https://gab.ae/news/global-freelance-economy-record-growth-2026" style="color:#3B82F6;">The job market is shifting →</a>
  </div>
  <section class="resc-hero">
    <div class="resc-hero-badge">FREE INSTANT ANALYSIS</div>
    <h1>Is Your Resume Holding You Back?</h1>
    <p class="resc-hero-hook"><em>75% of resumes are rejected by ATS before a human sees them.</em> <br/>Paste your resume below for an instant score and actionable feedback.</p>
  </section>

  <!-- CALCULATOR -->
  <section class="resc-section">
    <div class="resc-calc-container">
      <div class="resc-calc-inputs">
        <div class="resc-input-group">
          <label for="input-resume">Paste your resume text</label>
          <textarea id="input-resume" placeholder="John Doe&#10;Software Engineer&#10;&#10;Experience&#10;Spearheaded the development of..." rows="12"></textarea>
        </div>
        <button id="analyze-btn" class="resc-btn">Analyze My Resume</button>
      </div>
    </div>
  </section>

  <!-- RESULTS (Hidden initially) -->
  <section id="results-section" class="resc-section" style="display:none;">
    <h2 class="resc-section-title">Your Resume Score</h2>

    <div class="resc-score-hero">
      <div class="resc-score-circle-wrap">
        <svg viewBox="0 0 120 120" class="resc-score-circle">
          <circle cx="60" cy="60" r="52" fill="none" stroke="var(--border-color, #152040)" stroke-width="8"/>
          <circle id="overall-score-ring" cx="60" cy="60" r="52" fill="none" stroke="var(--accent, #10b981)" stroke-width="8" stroke-linecap="round" stroke-dasharray="326.73" stroke-dashoffset="326.73" transform="rotate(-90 60 60)"/>
        </svg>
        <div class="resc-score-value">
          <span id="overall-score-num">0</span>
          <span class="resc-score-label">/ 100</span>
        </div>
      </div>
      <div class="resc-score-verdict" id="overall-verdict">Needs Work</div>
    </div>

    <!-- METRICS GRID -->
    <div class="resc-metrics-grid">
      <div class="resc-metric-card">
        <h3>Action Verbs</h3>
        <div class="resc-metric-bar"><div class="resc-metric-fill" id="fill-verbs"></div></div>
        <p id="feedback-verbs">Checking...</p>
      </div>
      <div class="resc-metric-card">
        <h3>Quantified Achievements</h3>
        <div class="resc-metric-bar"><div class="resc-metric-fill" id="fill-quant"></div></div>
        <p id="feedback-quant">Checking...</p>
      </div>
      <div class="resc-metric-card">
        <h3>Length & Density</h3>
        <div class="resc-metric-bar"><div class="resc-metric-fill" id="fill-length"></div></div>
        <p id="feedback-length">Checking...</p>
      </div>
      <div class="resc-metric-card">
        <h3>ATS Compatibility</h3>
        <div class="resc-metric-bar"><div class="resc-metric-fill" id="fill-ats"></div></div>
        <p id="feedback-ats">Checking...</p>
      </div>
    </div>

    <!-- POWER WORDS SUGGESTER -->
    <div class="resc-insight-box">
      <h3>Power Words Suggester</h3>
      <p>Upgrade weak words to power words to make your bullet points stand out.</p>
      <div id="power-words-list" class="resc-power-words"></div>
    </div>

    <!-- BEFORE / AFTER -->
    <div class="resc-insight-box">
      <h3>Before & After Example</h3>
      <div class="resc-ba-grid">
        <div class="resc-ba-card bad">
          <div class="resc-ba-badge">Weak</div>
          <p>"Responsible for managing the sales team and increasing revenue over the year."</p>
        </div>
        <div class="resc-ba-card good">
          <div class="resc-ba-badge">Strong</div>
          <p>"Spearheaded a 12-person sales team, driving a 24% YoY revenue increase to $1.2M."</p>
        </div>
      </div>
    </div>

    <!-- INDUSTRY TIPS -->
    <div class="resc-insight-box">
      <h3>Industry-Specific Tips</h3>
      <ul class="resc-tips-list">
        <li><strong>Tech:</strong> List your programming languages and frameworks immediately after your summary.</li>
        <li><strong>Sales/Marketing:</strong> Emphasize revenue numbers, ROI, and campaign scale in every bullet point.</li>
        <li><strong>Finance:</strong> Use precise financial modeling jargon and deal sizes.</li>
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="resc-section">
    <h2 class="resc-section-title">Frequently Asked Questions</h2>
    <div class="resc-faq">
      <details class="resc-faq-item">
        <summary>How is the resume score calculated?</summary>
        <p>We analyze your resume across five key dimensions: use of strong action verbs, presence of quantified achievements (numbers/metrics), keyword density, optimal length, and ATS-friendly formatting.</p>
      </details>
      <details class="resc-faq-item">
        <summary>What is an ATS compatibility score?</summary>
        <p>An Applicant Tracking System (ATS) score estimates how well software can parse your resume. It looks for standard headers, simple formatting without complex tables, and proper keyword usage.</p>
      </details>
      <details class="resc-faq-item">
        <summary>Why are quantified achievements important?</summary>
        <p>Hiring managers want to see the impact of your work, not just your responsibilities. Saying 'Increased sales by 15%' is much stronger than simply stating 'Responsible for increasing sales'.</p>
      </details>
      <details class="resc-faq-item">
        <summary>What are resume power words?</summary>
        <p>Power words are strong action verbs like 'Spearheaded', 'Optimized', and 'Engineered' that demonstrate leadership and initiative, replacing weak phrases like 'Helped with' or 'Responsible for'.</p>
      </details>
      <details class="resc-faq-item">
        <summary>How long should a good resume be?</summary>
        <p>For most professionals, a 1-2 page resume is ideal. Entry-level candidates should stick to one page, while those with 10+ years of experience may need two pages to adequately detail their career progression.</p>
      </details>
    </div>
  </section>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/ats-score-checker" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Resume ATS Score Checker</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Paste your resume and job description to get an instant ATS compatibility score. Analyze keyword matching, formatting is...</p>
      </a>
    </div>
  </div>
</SiteLayout>

