<script>
  const powerWords = [
    'Spearheaded', 'Optimized', 'Engineered', 'Streamlined', 'Pioneered',
    'Accelerated', 'Overhauled', 'Transformed', 'Generated', 'Executed',
    'Implemented', 'Negotiated', 'Maximized', 'Mentored', 'Revamped'
  ];

  const weakWords = ['Helped', 'Responsible for', 'Worked on', 'Assisted', 'Handled', 'Managed'];

  const analyzeBtn = document.getElementById('analyze-btn');
  const inputResume = document.getElementById('input-resume') as HTMLTextAreaElement;
  const resultsSection = document.getElementById('results-section');

  const ring = document.getElementById('overall-score-ring') as SVGCircleElement;
  const scoreNum = document.getElementById('overall-score-num');
  const verdict = document.getElementById('overall-verdict');
  const powerWordsList = document.getElementById('power-words-list');

  const metricFills = {
    verbs: document.getElementById('fill-verbs'),
    quant: document.getElementById('fill-quant'),
    length: document.getElementById('fill-length'),
    ats: document.getElementById('fill-ats')
  };

  const metricFeedback = {
    verbs: document.getElementById('feedback-verbs'),
    quant: document.getElementById('feedback-quant'),
    length: document.getElementById('feedback-length'),
    ats: document.getElementById('feedback-ats')
  };

  function animateScore(targetScore: number) {
    let currentScore = 0;
    const duration = 1500;
    const interval = 20;
    const step = (targetScore / duration) * interval;

    const circumference = 2 * Math.PI * 52; // r=52

    const timer = setInterval(() => {
      currentScore += step;
      if (currentScore >= targetScore) {
        currentScore = targetScore;
        clearInterval(timer);
      }
      if(scoreNum) scoreNum.textContent = Math.round(currentScore).toString();

      if(ring) {
        const offset = circumference - (currentScore / 100) * circumference;
        ring.style.strokeDashoffset = offset.toString();

        if (currentScore < 40) ring.style.stroke = '#ef4444';
        else if (currentScore < 70) ring.style.stroke = '#f59e0b';
        else ring.style.stroke = 'var(--accent, #10b981)';
      }

      if(verdict) {
        if (currentScore < 40) { verdict.textContent = "Needs Major Revision"; verdict.style.color = "#ef4444"; }
        else if (currentScore < 70) { verdict.textContent = "Good, but could be better"; verdict.style.color = "#f59e0b"; }
        else { verdict.textContent = "Excellent!"; verdict.style.color = "var(--accent, #10b981)"; }
      }
    }, interval);
  }

  function analyzeResume() {
    const text = inputResume.value.trim();
    if (!text) return alert("Please paste your resume text first.");

    if(resultsSection) resultsSection.style.display = 'block';
    resultsSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });

    // Reset fills
    Object.values(metricFills).forEach(fill => { if(fill) fill.style.width = '0%'; });
    if(ring) ring.style.strokeDashoffset = "326.73";

    setTimeout(() => {
      const lowerText = text.toLowerCase();

      // 1. Action Verbs (25 pts)
      let foundVerbs = 0;
      let usedPowerWords: string[] = [];
      let missedPowerWords: string[] = [];

      powerWords.forEach(word => {
        if (lowerText.includes(word.toLowerCase())) {
          foundVerbs++;
          usedPowerWords.push(word);
        } else {
          missedPowerWords.push(word);
        }
      });

      const verbsScore = Math.min(25, foundVerbs * 5);
      if(metricFills.verbs) metricFills.verbs.style.width = `${(verbsScore/25)*100}%`;
      if(metricFeedback.verbs) metricFeedback.verbs.textContent = `Found ${foundVerbs} power verbs. Aim for at least 5 to maximize impact.`;

      // 2. Quantified Achievements (25 pts)
      const numberMatches = text.match(/\b\d+(\.\d+)?%?|\b(one|two|three|four|five|six|seven|eight|nine|ten)\b/gi) || [];
      const dollarMatches = text.match(/\$\d+/g) || [];
      const quantCount = numberMatches.length + dollarMatches.length;

      const quantScore = Math.min(25, quantCount * 2);
      if(metricFills.quant) metricFills.quant.style.width = `${(quantScore/25)*100}%`;
      if(metricFeedback.quant) metricFeedback.quant.textContent = `Found ${quantCount} metrics/numbers. Quantifying achievements is crucial.`;

      // 3. Length & Density (25 pts)
      const wordCount = text.split(/\s+/).length;
      let lengthScore = 25;
      let lengthFeedback = "Perfect length. Your resume is dense and readable.";

      if (wordCount < 150) {
        lengthScore = 10;
        lengthFeedback = "Too short. Add more detail to your experience.";
      } else if (wordCount > 1000) {
        lengthScore = 15;
        lengthFeedback = "Too long. Consider trimming to keep it concise.";
      }

      if(metricFills.length) metricFills.length.style.width = `${(lengthScore/25)*100}%`;
      if(metricFeedback.length) metricFeedback.length.textContent = lengthFeedback;

      // 4. ATS Compatibility (25 pts)
      let atsScore = 25;
      const hasEducation = /education/i.test(lowerText);
      const hasExperience = /experience|history/i.test(lowerText);
      const hasSkills = /skills/i.test(lowerText);

      let missingHeaders = [];
      if (!hasEducation) missingHeaders.push("Education");
      if (!hasExperience) missingHeaders.push("Experience");
      if (!hasSkills) missingHeaders.push("Skills");

      let atsFeedback = "Standard sections found. Looks ATS friendly!";
      if (missingHeaders.length > 0) {
        atsScore -= missingHeaders.length * 5;
        atsFeedback = `Missing standard headers: ${missingHeaders.join(', ')}. ATS might fail to parse your sections.`;
      }

      if(metricFills.ats) metricFills.ats.style.width = `${(atsScore/25)*100}%`;
      if(metricFeedback.ats) metricFeedback.ats.textContent = atsFeedback;

      // OVERALL SCORE
      const totalScore = verbsScore + quantScore + lengthScore + atsScore;
      animateScore(totalScore);

      // Render Power Words
      if(powerWordsList) {
        powerWordsList.innerHTML = '';
        usedPowerWords.slice(0, 5).forEach(w => {
          powerWordsList.innerHTML += `<span class="resc-pw-chip">${w} ✓</span>`;
        });
        missedPowerWords.slice(0, 8).forEach(w => {
          powerWordsList.innerHTML += `<span class="resc-pw-chip missing">${w}</span>`;
        });
      }

    }, 100);
  }

  if (analyzeBtn) {
    analyzeBtn.addEventListener('click', analyzeResume);
  }
</script>
