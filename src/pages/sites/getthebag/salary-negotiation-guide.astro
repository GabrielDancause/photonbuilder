---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const steps = [
  {
    num: 1,
    title: "Research Your Market Value",
    desc: "Before any negotiation, you need data. Look up your exact role, location, experience level, and industry on multiple salary databases. You're building a range, not a single number.",
    actions: ["Search your title on Glassdoor, Levels.fyi, and LinkedIn Salary", "Filter by location, company size, and years of experience", "Talk to recruiters — they'll often share ranges if you ask", "Document the 25th, 50th, and 75th percentile for your role"],
    tip: "Collect at least 3 data points from different sources. One source can be skewed."
  },
  {
    num: 2,
    title: "Know Your Number",
    desc: "Pick a target salary and a walk-away number before the conversation starts. Your target should be the 75th percentile of your research — ambitious but defensible. Your walk-away is the minimum you'll accept.",
    actions: ["Set your target at 10-20% above what you'd happily accept", "Calculate your walk-away based on your actual expenses + savings goals", "Factor in total compensation: base, bonus, equity, benefits, PTO", "Write both numbers down — don't negotiate from memory"],
    tip: "Anchoring matters. The first number in a negotiation shapes the entire range. Aim high."
  },
  {
    num: 3,
    title: "Time It Right",
    desc: "When you negotiate matters almost as much as how. The best leverage comes after they've decided they want you — after the verbal offer but before you sign anything.",
    actions: ["Never discuss salary in the first interview if you can avoid it", "If asked for expectations early, deflect: 'I'd like to learn more about the role first'", "Wait for the written offer before countering", "For raises, time your ask after a big win or strong review cycle"],
    tip: "Thursday or Friday mornings tend to work best for salary conversations — people are in a better mood heading into the weekend."
  },
  {
    num: 4,
    title: "Script Your Conversation",
    desc: "Don't wing it. Write out exactly what you'll say, then practice until it sounds natural. The scripts below are battle-tested frameworks you can customize.",
    actions: ["Write your opening line and practice it 10+ times", "Prepare responses for the 3 most likely objections", "Practice with a friend who'll push back", "Record yourself — awkward but effective"],
    tip: "The goal is to sound confident and collaborative, not adversarial. You're solving a problem together."
  },
  {
    num: 5,
    title: "Make Your Counter-Offer",
    desc: "Present your counter with data, not emotions. Reference your research, highlight your unique value, and propose a specific number — not a range. Giving a range tells them to pick the bottom.",
    actions: ["Lead with enthusiasm: 'I'm excited about this role'", "Cite specific market data for your counter number", "Highlight 2-3 ways you'll deliver outsized value", "Ask for a specific number, not a range"],
    tip: "Always counter the first offer. Even a small counter signals you know your worth."
  },
  {
    num: 6,
    title: "Close the Deal",
    desc: "Once they meet your number (or you've reached a fair middle ground), lock it in. Get everything in writing before you celebrate. Verbal agreements mean nothing.",
    actions: ["Ask for the revised offer in writing within 24-48 hours", "Review every line item: base, bonus, equity, start date, PTO, remote policy", "If they can't move on salary, negotiate signing bonus, extra PTO, or equity", "Set a decision deadline for yourself and communicate it"],
    tip: "If they can't budge on base salary, a signing bonus is often easier to approve — it's a one-time expense, not a recurring line item."
  }
];

const scripts = [
  {
    title: "Responding to the Initial Offer",
    scenario: "You just received a verbal or written offer",
    script: `"Thank you so much for the offer — I'm really excited about the opportunity to join [Company] as [Role]. I've reviewed the details, and I'd love to discuss the compensation. Based on my research into market rates for this role and my [X years of experience / specific skill], I was expecting something closer to [$X]. Is there flexibility to move in that direction?"`,
    notes: "Start with genuine enthusiasm. Then pivot to your number backed by data. Ending with a question keeps the door open."
  },
  {
    title: "Counter-Offer Email Template",
    scenario: "You want to counter in writing (often better than phone)",
    script: `Subject: [Your Name] — Offer Discussion

Hi [Hiring Manager],

Thank you again for the offer to join [Company] as [Role]. I'm genuinely excited about the team and the work ahead.

After reviewing the offer and researching market compensation for this role, I'd like to propose a base salary of [$X]. This is based on:
• Market data from [Glassdoor/Levels.fyi/etc.] showing the range for [Role] in [Location] is [$Y-$Z]
• My [specific experience/skills] that directly apply to [key responsibility from JD]
• [Any other leverage: competing offer, specialized certification, etc.]

I'm confident I'll deliver strong results in this role, and I'd love to find a number that works for both of us. I'm happy to discuss this over a call if that's easier.

Best,
[Your Name]`,
    notes: "Email gives them time to process and consult internally. It also creates a paper trail. Always be specific with your number and reasoning."
  },
  {
    title: "Phone Negotiation Script",
    scenario: "HR or the hiring manager calls to discuss compensation",
    script: `"Hi [Name], thanks for taking the time to discuss this. I want to start by saying I'm really enthusiastic about this role — the work [specific detail] is exactly what I want to be doing.

That said, I've done some research and I think the compensation could better reflect the market rate and the value I'd bring. I've seen similar roles in [location] paying between [$X and $Y], and given my [experience/skill], I was hoping we could get to [$Z].

What's the flexibility on your end?"`,
    notes: "Pause after your ask. Silence is your friend. Let them respond — don't fill the gap by negotiating against yourself."
  },
  {
    title: "Leveraging a Competing Offer",
    scenario: "You have another offer and want to use it ethically",
    script: `"I want to be transparent with you — I've received another offer at [$X]. I'm not using this as a pressure tactic, because honestly [Company] is my first choice because of [specific reason]. But I want to make sure the compensation is competitive so I can make this decision confidently. Is there room to move closer to [$Y]?"`,
    notes: "Never bluff about competing offers — it can backfire badly. Only use this if you genuinely have one. Being honest about your preference builds trust."
  }
];

const tools = [
  {
    name: "Glassdoor",
    url: "glassdoor.com",
    best: "Company-specific salaries with employee-reported data",
    note: "Largest database but can be outdated. Filter by recency."
  },
  {
    name: "Levels.fyi",
    url: "levels.fyi",
    best: "Tech compensation with equity breakdowns",
    note: "Gold standard for tech. Includes base, stock, bonus splits."
  },
  {
    name: "LinkedIn Salary",
    url: "linkedin.com/salary",
    best: "Role-based ranges by location and industry",
    note: "Good for non-tech roles. Requires a LinkedIn account."
  },
  {
    name: "Payscale",
    url: "payscale.com",
    best: "Personalized salary reports based on your profile",
    note: "Takes into account skills, certifications, and education."
  },
  {
    name: "Salary.com",
    url: "salary.com",
    best: "HR-sourced data used by employers",
    note: "Shows what companies actually budget for roles — useful for benchmarking."
  },
  {
    name: "H1B Salary Database",
    url: "h1bdata.info",
    best: "Actual salaries from H1B visa filings (public record)",
    note: "Real numbers companies paid — not self-reported. US only."
  }
];

const mistakes = [
  {
    mistake: "Accepting the first offer without negotiating",
    fix: "Always counter. Even 'Is there any flexibility?' opens the door. Companies expect it — budgets almost always have room.",
    stat: "55% of people don't negotiate. Those who do earn $5,000-$10,000 more on average."
  },
  {
    mistake: "Giving a range instead of a specific number",
    fix: "Say '$95,000' not '$85,000 to $95,000.' A range tells them to anchor on the bottom number. Be precise.",
    stat: "Precise numbers (e.g., $92,500 vs $90,000) are perceived as more researched and harder to counter."
  },
  {
    mistake: "Negotiating based on personal need instead of market value",
    fix: "'I need more because my rent went up' is weak. 'Market data shows this role pays $X in our market' is strong. Lead with data, not bills.",
    stat: "Data-backed requests are 30% more likely to result in a higher offer."
  },
  {
    mistake: "Revealing your current salary",
    fix: "In many states, it's now illegal for employers to ask. Redirect: 'I'm focused on finding the right fit for this role's market rate.' Your past salary is irrelevant to your future value.",
    stat: "21 states + DC have banned salary history questions as of 2026."
  },
  {
    mistake: "Only negotiating base salary",
    fix: "Total compensation includes signing bonus, equity/RSUs, annual bonus, PTO, remote flexibility, professional development budget, and relocation. If base is capped, push on these.",
    stat: "Equity and bonuses can add 20-50% to total comp at mid-to-senior levels."
  },
  {
    mistake: "Being adversarial or giving ultimatums",
    fix: "Frame it as collaborative: 'I'd love to find a number that works for both of us.' Ultimatums burn bridges and can get offers rescinded.",
    stat: "Collaborative negotiators achieve 15% better outcomes than competitive ones."
  }
];

const scenarios = [
  {
    title: "First Job Out of College",
    tips: [
      "You have less leverage on salary — but more on signing bonus and start date",
      "Use internship offers or competing full-time offers as anchors",
      "Research entry-level ranges on Levels.fyi and Glassdoor by company",
      "Negotiate relocation assistance if applicable — companies expect it",
      "Don't undersell yourself. Even 5-10% on your first salary compounds over your career"
    ]
  },
  {
    title: "Internal Promotion or Raise",
    tips: [
      "Start building your case 3-6 months before your review",
      "Keep a 'brag document' of wins, metrics, and impact throughout the year",
      "Research external market rates — if you're underpaid, show the gap",
      "Frame it as retention: 'I want to grow here, and I want my comp to reflect my growth'",
      "Ask your manager what it would take to get to the next level, then deliver on it"
    ]
  },
  {
    title: "Remote Role",
    tips: [
      "Ask if salary is location-adjusted or location-agnostic — this matters a lot",
      "If location-adjusted, negotiate for a higher-cost-of-living band if possible",
      "Remote roles often save the company office costs — factor that into your value prop",
      "Negotiate for home office stipend ($1,000-$2,500 is common)",
      "Internet/phone reimbursement is a small ask that's usually easy to get"
    ]
  },
  {
    title: "Startup Equity Negotiation",
    tips: [
      "Ask for the total number of outstanding shares to calculate your actual percentage",
      "Understand the vesting schedule: standard is 4 years with a 1-year cliff",
      "Negotiate for accelerated vesting on acquisition (single or double trigger)",
      "Early-stage equity is high-risk — discount it 70-90% when comparing to cash comp",
      "Ask about the latest 409A valuation and the preferred share price from last funding round"
    ]
  }
];

const faqs = [
  {
    q: "When is the best time to negotiate salary?",
    a: "After you receive a written offer but before you sign. This is when you have maximum leverage — they've decided they want you and invested time in the hiring process. For internal raises, time your ask right after a major accomplishment or during annual review cycles."
  },
  {
    q: "Should I negotiate salary over email or phone?",
    a: "Email is generally better for your first counter because it gives the hiring manager time to process, consult with their team, and respond thoughtfully. It also creates a paper trail. However, if the back-and-forth stalls, switching to a phone call can help resolve things faster. Many people do an initial email counter followed by a phone discussion."
  },
  {
    q: "What if they rescind my offer for negotiating?",
    a: "This almost never happens at reputable companies — negotiation is expected and normal. If a company rescinds an offer because you politely asked for more money, that's a massive red flag about their culture. The exception: don't negotiate after you've already accepted. That can legitimately cause an offer to be pulled."
  },
  {
    q: "How much higher should I counter-offer?",
    a: "Counter 10-20% above the initial offer, depending on how far it is from market rate. If the offer is already competitive, a 5-10% counter is reasonable. If it's significantly below market, you can go 15-25% higher. Always back your number with market data — a researched counter is much harder to reject."
  },
  {
    q: "Can I negotiate salary at a startup?",
    a: "Absolutely. Startups often have more flexibility on equity, title, and non-traditional benefits even if cash is tighter. Ask about equity (and get specifics: number of shares, strike price, vesting schedule, total outstanding shares), signing bonuses, professional development budgets, and remote work flexibility."
  },
  {
    q: "What if they say the salary is non-negotiable?",
    a: "Pivot to other forms of compensation: signing bonus, annual bonus target, equity/RSUs, extra PTO days, remote work flexibility, professional development budget, or an accelerated review timeline (e.g., a guaranteed salary review at 6 months instead of 12). There's almost always something flexible."
  },
  {
    q: "Should I reveal my current salary during negotiation?",
    a: "No. Your current salary is irrelevant to the market value of the new role. In many states (21+ as of 2026), it's illegal for employers to ask. If pressed, redirect: 'I'm focused on finding the right compensation for this specific role based on market rates.' If they insist, share your target number instead."
  },
  {
    q: "How does negotiating salary affect lifetime earnings?",
    a: "Dramatically. A single successful negotiation of $5,000 can result in over $600,000 in additional lifetime earnings when you factor in compounding raises, bonuses calculated as a percentage of base, and retirement contributions. Every future raise is a percentage of your current salary — so starting higher has an exponential effect."
  },
  {
    q: "What if I have no competing offers to use as leverage?",
    a: "Competing offers are helpful but not necessary. Your primary leverage is market data and the value you bring. Research what the role pays at comparable companies, highlight your relevant skills and experience, and be prepared to articulate why you're worth your ask. The company has already invested time and money in hiring you — that's leverage in itself."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Salary Negotiation Guide 2026 — Scripts, Frameworks & Data",
    "description": "Step-by-step salary negotiation guide with word-for-word scripts, market research tools, and proven frameworks. Negotiate $5K-$25K more on your next offer.",
    "author": {
      "@type": "Organization",
      "name": "Get The Bag"
    },
    "datePublished": "2026-03-21",
    "dateModified": "2026-03-21"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Salary Negotiation Guide 2026 — Scripts, Frameworks & Data",
  description: "Step-by-step salary negotiation guide with word-for-word scripts, market research tools, and proven frameworks. Negotiate $5K-$25K more on your next offer.",
  category: "guide",
  published: "2026-03-21",
};
---

<SiteLayout
  site="getthebag"
  title="Salary Negotiation Guide 2026 — Scripts, Frameworks & Data"
  description="Step-by-step salary negotiation guide with word-for-word scripts, market research tools, and proven frameworks. Negotiate $5K-$25K more on your next offer."
  canonical="https://getthebag.photonbuilder.com/salary-negotiation-guide"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>How to Negotiate Your Salary (2026 Guide)</h1>
      <p>A step-by-step framework with word-for-word scripts, research tools, and data-backed strategies. Most people leave $5,000–$25,000 on the table by not negotiating.</p>
    </div>

    <section class="content-section">

      <!-- Stats Row -->
      <div class="stats-row">
        <div class="stat-card">
          <span class="stat-number">20%</span>
          <span class="stat-label">Average raise from negotiating</span>
          <span class="stat-source">Candidates who negotiate earn ~$5K-$10K more</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">55%</span>
          <span class="stat-label">Of workers never negotiate</span>
          <span class="stat-source">Over half accept the first offer on the table</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">$600K+</span>
          <span class="stat-label">Lifetime earnings impact</span>
          <span class="stat-source">From a single $5K negotiation compounding over 40 years</span>
        </div>
      </div>

      <p>Salary negotiation is the single highest-ROI skill in your career. A 30-minute conversation can be worth hundreds of thousands of dollars over your lifetime. Yet most people skip it because it feels uncomfortable.</p>
      <p>This guide gives you everything you need: a proven 6-step framework, word-for-word scripts you can use today, research tools to find your market rate, and strategies for every scenario from first job to startup equity.</p>

      <!-- Step-by-Step Framework -->
      <h2>The 6-Step Salary Negotiation Framework</h2>

      {steps.map(s => (
        <div class="step-card">
          <div class="step-header">
            <span class="step-num">Step {s.num}</span>
            <h3>{s.title}</h3>
          </div>
          <p>{s.desc}</p>
          <ul>
            {s.actions.map(a => <li>{a}</li>)}
          </ul>
          <div class="step-tip">
            <strong>Pro tip:</strong> {s.tip}
          </div>
        </div>
      ))}

      <!-- Word-for-Word Scripts -->
      <h2>Word-for-Word Negotiation Scripts</h2>
      <p>Don't improvise. Use these proven scripts as your starting point and customize them with your specific details.</p>

      {scripts.map(s => (
        <div class="script-card">
          <div class="script-header">
            <h3>{s.title}</h3>
            <span class="script-scenario">{s.scenario}</span>
          </div>
          <div class="script-body">
            <pre>{s.script}</pre>
          </div>
          <div class="script-note">
            <strong>Why this works:</strong> {s.notes}
          </div>
        </div>
      ))}

      <!-- Salary Research Tools -->
      <h2>Salary Research Tools</h2>
      <p>Use at least 3 of these to triangulate your market value. No single source is perfectly accurate.</p>

      <div class="tools-grid">
        {tools.map(t => (
          <div class="tool-card">
            <h3>{t.name}</h3>
            <span class="tool-url">{t.url}</span>
            <p class="tool-best"><strong>Best for:</strong> {t.best}</p>
            <p class="tool-note">{t.note}</p>
          </div>
        ))}
      </div>

      <!-- Common Mistakes -->
      <h2>6 Negotiation Mistakes (and How to Fix Them)</h2>

      {mistakes.map((m, i) => (
        <div class="mistake-card">
          <div class="mistake-header">
            <span class="mistake-num">#{i + 1}</span>
            <h3>{m.mistake}</h3>
          </div>
          <p class="mistake-fix"><strong>The fix:</strong> {m.fix}</p>
          <span class="mistake-stat">{m.stat}</span>
        </div>
      ))}

      <!-- Negotiation by Scenario -->
      <h2>Negotiation by Scenario</h2>
      <p>Different situations call for different strategies. Here's how to adapt the framework.</p>

      <div class="scenario-grid">
        {scenarios.map(s => (
          <div class="scenario-card">
            <h3>{s.title}</h3>
            <ul>
              {s.tips.map(t => <li>{t}</li>)}
            </ul>
          </div>
        ))}
      </div>

      <!-- Salary Comparison Calculator -->
      <h2>Salary Comparison Calculator</h2>
      <p>Enter your offer details to see how it compares and what negotiating could be worth over time.</p>

      <div class="calculator" id="salary-calculator">
        <div class="calc-inputs">
          <div class="calc-field">
            <label for="current-offer">Your offer ($)</label>
            <input type="number" id="current-offer" placeholder="85000" />
          </div>
          <div class="calc-field">
            <label for="market-low">Market range — low ($)</label>
            <input type="number" id="market-low" placeholder="80000" />
          </div>
          <div class="calc-field">
            <label for="market-high">Market range — high ($)</label>
            <input type="number" id="market-high" placeholder="110000" />
          </div>
          <div class="calc-field">
            <label for="annual-raise">Expected annual raise (%)</label>
            <input type="number" id="annual-raise" placeholder="3" />
          </div>
        </div>
        <button id="calc-btn" type="button">Calculate Impact</button>
        <div id="calc-results" class="calc-results" style="display:none;">
          <div class="result-row">
            <span class="result-label">Your offer vs market midpoint</span>
            <span class="result-value" id="r-vs-mid"></span>
          </div>
          <div class="result-row">
            <span class="result-label">Suggested counter-offer (75th percentile)</span>
            <span class="result-value" id="r-counter"></span>
          </div>
          <div class="result-row">
            <span class="result-label">Difference if negotiated</span>
            <span class="result-value" id="r-diff"></span>
          </div>
          <div class="result-row highlight">
            <span class="result-label">10-year compounded earnings difference</span>
            <span class="result-value" id="r-10yr"></span>
          </div>
          <div class="result-row highlight">
            <span class="result-label">30-year compounded earnings difference</span>
            <span class="result-value" id="r-30yr"></span>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

      <!-- Related Pages -->
      <h2>Related Pages</h2>
      <div class="related-grid">
        <a href="/" class="related-link">
          <strong>Get The Bag — Home</strong>
          <span>All career and money tools and guides</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
    (function() {
      var btn = document.getElementById('calc-btn');
      if (!btn) return;
      btn.addEventListener('click', function() {
        var offer = parseFloat(document.getElementById('current-offer').value);
        var low = parseFloat(document.getElementById('market-low').value);
        var high = parseFloat(document.getElementById('market-high').value);
        var raise = parseFloat(document.getElementById('annual-raise').value);
        if (!offer || !low || !high) return;
        if (!raise && raise !== 0) raise = 3;

        var mid = (low + high) / 2;
        var counter = low + (high - low) * 0.75;
        var diff = counter - offer;
        var r = raise / 100;

        var earn10 = 0;
        var earnOrig10 = 0;
        var earn30 = 0;
        var earnOrig30 = 0;
        for (var y = 0; y < 30; y++) {
          var factor = Math.pow(1 + r, y);
          earnOrig30 += offer * factor;
          earn30 += counter * factor;
          if (y < 10) {
            earnOrig10 += offer * factor;
            earn10 += counter * factor;
          }
        }

        var fmt = function(n) {
          return '$' + Math.round(n).toLocaleString('en-US');
        };

        var vsMid = offer - mid;
        document.getElementById('r-vs-mid').textContent = (vsMid >= 0 ? '+' : '') + fmt(vsMid) + ' (' + (vsMid >= 0 ? 'above' : 'below') + ' midpoint)';
        document.getElementById('r-vs-mid').className = 'result-value ' + (vsMid >= 0 ? 'positive' : 'negative');
        document.getElementById('r-counter').textContent = fmt(counter);
        document.getElementById('r-diff').textContent = (diff >= 0 ? '+' : '') + fmt(diff) + '/year';
        document.getElementById('r-diff').className = 'result-value ' + (diff >= 0 ? 'positive' : 'negative');
        document.getElementById('r-10yr').textContent = '+' + fmt(earn10 - earnOrig10);
        document.getElementById('r-30yr').textContent = '+' + fmt(earn30 - earnOrig30);
        document.getElementById('calc-results').style.display = 'flex';
      });
    })();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }

    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Stats Row */
    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1.5rem 0 2rem; }
    .stat-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; display: flex; flex-direction: column; gap: 0.3rem; }
    .stat-number { font-size: 2.2rem; font-weight: 800; color: var(--accent-color); line-height: 1; }
    .stat-label { font-size: 0.95rem; font-weight: 600; color: var(--text-primary); }
    .stat-source { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.3; }

    /* Step Cards */
    .step-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
