    .scenario-card ul { margin: 0; font-size: 0.9rem; }

    /* Calculator */
    .calculator { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .calc-inputs { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1rem; }
    .calc-field { display: flex; flex-direction: column; gap: 0.3rem; }
