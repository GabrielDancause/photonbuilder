---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const hustles = [
  // Online
  { name: "Freelance Writing", type: "Online", earningPotential: "$20-$100/hr", startupCost: "Low", timeCommitment: "Flexible", difficulty: "Medium", scalability: "Medium" },
  { name: "Dropshipping", type: "Online", earningPotential: "$500-$5k+/mo", startupCost: "Medium", timeCommitment: "High", difficulty: "High", scalability: "High" },
  { name: "Content Creation / YouTube", type: "Online", earningPotential: "Variable", startupCost: "Low", timeCommitment: "High", difficulty: "High", scalability: "High" },
  { name: "Online Tutoring", type: "Online", earningPotential: "$15-$50/hr", startupCost: "Low", timeCommitment: "Medium", difficulty: "Medium", scalability: "Low" },
  { name: "Survey Taking", type: "Online", earningPotential: "$1-$5/hr", startupCost: "None", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  { name: "Virtual Assistant", type: "Online", earningPotential: "$15-$35/hr", startupCost: "Low", timeCommitment: "Flexible", difficulty: "Low", scalability: "Medium" },
  { name: "Social Media Management", type: "Online", earningPotential: "$20-$50/hr", startupCost: "Low", timeCommitment: "Medium", difficulty: "Medium", scalability: "High" },
  { name: "Transcription", type: "Online", earningPotential: "$10-$20/hr", startupCost: "Low", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  { name: "Data Entry", type: "Online", earningPotential: "$12-$20/hr", startupCost: "Low", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  { name: "Voiceover Work", type: "Online", earningPotential: "$20-$100/hr", startupCost: "Medium", timeCommitment: "Flexible", difficulty: "Medium", scalability: "Medium" },
  // Gig Economy
  { name: "DoorDash Delivery", type: "Gig Economy", earningPotential: "$15-$25/hr", startupCost: "Medium", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  { name: "Uber / Lyft Driving", type: "Gig Economy", earningPotential: "$15-$30/hr", startupCost: "High", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  { name: "TaskRabbit", type: "Gig Economy", earningPotential: "$20-$50/hr", startupCost: "Low", timeCommitment: "Flexible", difficulty: "Medium", scalability: "Low" },
  { name: "Instacart Shopper", type: "Gig Economy", earningPotential: "$15-$25/hr", startupCost: "Medium", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  { name: "Rover Pet Sitting", type: "Gig Economy", earningPotential: "$15-$30/hr", startupCost: "Low", timeCommitment: "Flexible", difficulty: "Low", scalability: "Medium" },
  { name: "Amazon Flex", type: "Gig Economy", earningPotential: "$18-$25/hr", startupCost: "Medium", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  { name: "Plasma Donation", type: "Gig Economy", earningPotential: "$20-$50/visit", startupCost: "None", timeCommitment: "Low", difficulty: "Low", scalability: "None" },
  { name: "Mystery Shopping", type: "Gig Economy", earningPotential: "$10-$30/task", startupCost: "None", timeCommitment: "Flexible", difficulty: "Low", scalability: "Low" },
  // Skills-Based
  { name: "Photography", type: "Skills-Based", earningPotential: "$50-$200/hr", startupCost: "High", timeCommitment: "Medium", difficulty: "Medium", scalability: "Medium" },
  { name: "Web Development", type: "Skills-Based", earningPotential: "$30-$100/hr", startupCost: "Low", timeCommitment: "High", difficulty: "High", scalability: "High" },
  { name: "Graphic Design", type: "Skills-Based", earningPotential: "$25-$75/hr", startupCost: "Low", timeCommitment: "Medium", difficulty: "Medium", scalability: "Medium" },
  { name: "Bookkeeping", type: "Skills-Based", earningPotential: "$20-$50/hr", startupCost: "Low", timeCommitment: "Medium", difficulty: "Medium", scalability: "High" },
  { name: "Video Editing", type: "Skills-Based", earningPotential: "$25-$80/hr", startupCost: "Medium", timeCommitment: "Medium", difficulty: "Medium", scalability: "Medium" },
  { name: "Resume Writing", type: "Skills-Based", earningPotential: "$50-$200/resume", startupCost: "None", timeCommitment: "Flexible", difficulty: "Medium", scalability: "High" },
  { name: "SEO Consulting", type: "Skills-Based", earningPotential: "$50-$150/hr", startupCost: "Low", timeCommitment: "Medium", difficulty: "High", scalability: "High" },
  // Passive Income
  { name: "Dividend Investing", type: "Passive Income", earningPotential: "Variable", startupCost: "High", timeCommitment: "Low", difficulty: "Low", scalability: "Very High" },
  { name: "Rental Arbitrage", type: "Passive Income", earningPotential: "$500-$2k+/mo", startupCost: "High", timeCommitment: "Medium", difficulty: "High", scalability: "High" },
  { name: "Print on Demand", type: "Passive Income", earningPotential: "$100-$1k+/mo", startupCost: "Low", timeCommitment: "Medium", difficulty: "Medium", scalability: "High" },
  { name: "Affiliate Marketing", type: "Passive Income", earningPotential: "$100-$5k+/mo", startupCost: "Low", timeCommitment: "High", difficulty: "High", scalability: "Very High" },
  { name: "Selling Online Courses", type: "Passive Income", earningPotential: "$500-$10k+/mo", startupCost: "Medium", timeCommitment: "High", difficulty: "Medium", scalability: "Very High" }
];

const faqs = [
  {
    q: "What is the easiest side hustle to start right now?",
    a: "Gig economy jobs like DoorDash, Uber, and Instacart have the lowest barriers to entry. If you have a car and a clean driving record, you can often start earning within a few days."
  },
  {
    q: "Can I make a full-time income from a side hustle?",
    a: "Yes, many side hustles like freelance writing, web development, and affiliate marketing can scale into full-time businesses. However, it takes significant time and effort to build a client base or audience to reach that level."
  },
  {
    q: "Do I have to pay taxes on my side hustle income?",
    a: "Yes, you must report all side hustle income to the IRS. Once you earn over a certain threshold, you will need to file self-employment taxes. It's recommended to set aside 25-30% of your earnings for tax purposes."
  },
  {
    q: "What side hustles pay cash daily?",
    a: "Gig economy apps like Uber and DoorDash often offer instant payout options for a small fee. Waitressing, bartending, or local cash-in-hand tasks through TaskRabbit can also provide immediate cash."
  },
  {
    q: "How much time do I need to commit to a side hustle?",
    a: "It depends entirely on the hustle. Gig economy work and survey taking are highly flexible, whereas dropshipping, creating courses, or freelance web development require dedicated, consistent hours each week."
  },
  {
    q: "Are passive income side hustles really passive?",
    a: "No income is entirely passive at the start. Things like dividend investing, rental arbitrage, and selling online courses require a heavy upfront investment of either time or money before they start generating 'passive' returns."
  },
  {
    q: "How do I balance a side hustle with a full-time job?",
    a: "Time management is crucial. Dedicate specific blocks of time (like early mornings or weekends) strictly for your side hustle. Avoid burnout by starting small and setting realistic goals."
  },
  {
    q: "What is the best side hustle for introverts?",
    a: "Online-focused, independent work like freelance writing, transcription, data entry, and print-on-demand businesses are excellent options for those who prefer minimal direct customer interaction."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "30 Best Side Hustles for 2026",
  description: "Discover the 30 best side hustles for 2026 across online, gig economy, skills-based, and passive income categories. Compare earning potential, costs, and difficulty.",
  category: "list",
  published: "2026-03-22"
};
---

<SiteLayout
  site="getthebag"
  title={meta.title}
  description={meta.description}
  canonical="https://getthebag.photonbuilder.com/best-side-hustles"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>30 Best Side Hustles to Start in 2026</h1>
      <p>Whether you need fast cash or want to build a long-term passive income stream, explore the top 30 side hustles categorized by type, complete with earning potential and startup requirements.</p>
    </div>

    <section class="content-section">
      <h2>Side Hustles Comparison Matrix</h2>
      <p>Use the table below to compare our top 30 side hustle ideas. Click on any column header to sort.</p>

      <div class="table-container">
        <table id="hustles-table">
          <thead>
            <tr>
              <th data-sort="name">Side Hustle ↕</th>
              <th data-sort="type">Type ↕</th>
              <th data-sort="earning">Earning Potential ↕</th>
              <th data-sort="cost">Startup Cost ↕</th>
              <th data-sort="time">Time Commitment ↕</th>
              <th data-sort="difficulty">Difficulty ↕</th>
              <th data-sort="scalability">Scalability ↕</th>
            </tr>
          </thead>
          <tbody>
            {hustles.map(hustle => (
              <tr>
                <td data-value={hustle.name}><strong>{hustle.name}</strong></td>
                <td data-value={hustle.type} class="badge-cell"><span class={`badge type-${hustle.type.toLowerCase().replace(/\s+/g, '-')}`}>{hustle.type}</span></td>
                <td data-value={hustle.earningPotential}>{hustle.earningPotential}</td>
                <td data-value={hustle.startupCost} class="badge-cell"><span class={`badge cost-${hustle.startupCost.toLowerCase().replace(/[^a-z0-9]/g, '')}`}>{hustle.startupCost}</span></td>
                <td data-value={hustle.timeCommitment}>{hustle.timeCommitment}</td>
                <td data-value={hustle.difficulty} class="badge-cell"><span class={`badge diff-${hustle.difficulty.toLowerCase()}`}>{hustle.difficulty}</span></td>
                <td data-value={hustle.scalability} class="badge-cell"><span class={`badge scale-${hustle.scalability.toLowerCase().replace(/\s+/g, '-')}`}>{hustle.scalability}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const table = document.getElementById('hustles-table');
      if (!table) return;
      const headers = table.querySelectorAll('th[data-sort]');
      let currentSort = { column: '', direction: 'asc' };

      headers.forEach(header => {
        header.addEventListener('click', () => {
          const sortKey = header.getAttribute('data-sort');
          const tbody = table.querySelector('tbody');
          const rows = Array.from(tbody.querySelectorAll('tr'));

          // Determine sort direction
          if (currentSort.column === sortKey) {
            currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
          } else {
            currentSort.column = sortKey;
            currentSort.direction = 'asc';
          }

          // Custom sorting order dictionaries
          const sortOrder = {
            'cost': { 'none': 1, 'low': 2, 'medium': 3, 'high': 4 },
            'time': { 'low': 1, 'flexible': 2, 'medium': 3, 'high': 4 },
            'difficulty': { 'low': 1, 'medium': 2, 'high': 3 },
            'scalability': { 'none': 1, 'low': 2, 'medium': 3, 'high': 4, 'very high': 5 }
          };

          rows.sort((a, b) => {
            const getVal = row => {
              const cell = row.querySelector(`td:nth-child(${Array.from(header.parentNode.children).indexOf(header) + 1})`);
              return cell.getAttribute('data-value') ? cell.getAttribute('data-value').toLowerCase() : '';
            };

            const aVal = getVal(a);
            const bVal = getVal(b);

            let comparison = 0;

            if (['cost', 'time', 'difficulty', 'scalability'].includes(sortKey)) {
              // Extract base word for cost if it contains parens like "medium (car needed)"
              const cleanA = aVal.split(' ')[0].replace(/[^a-z]/g, '');
              const cleanB = bVal.split(' ')[0].replace(/[^a-z]/g, '');
              const aRank = sortOrder[sortKey][cleanA] || sortOrder[sortKey][aVal] || 0;
              const bRank = sortOrder[sortKey][cleanB] || sortOrder[sortKey][bVal] || 0;
              comparison = aRank - bRank;

              if (comparison === 0) {
                comparison = aVal.localeCompare(bVal);
              }
            } else if (sortKey === 'earning') {
                // extract numbers for earning potential
                const getNum = val => {
                    const match = val.match(/\$([0-9]+)/);
                    return match ? parseInt(match[1]) : 0;
                };
                comparison = getNum(aVal) - getNum(bVal);
                if (comparison === 0) {
                    comparison = aVal.localeCompare(bVal);
                }
            } else {
              comparison = aVal.localeCompare(bVal);
            }

            return currentSort.direction === 'asc' ? comparison : -comparison;
          });

          // Re-append sorted rows
          rows.forEach(row => tbody.appendChild(row));
        });
      });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1.2rem; margin-top: 2.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem; }

    strong { color: var(--text-primary); }

    /* Table Styles */
    .table-container { overflow-x: auto; margin-bottom: 2rem; border-radius: 12px; border: 1px solid var(--border-color); }
    table { width: 100%; border-collapse: collapse; text-align: left; background: var(--card-bg); }
    th { background: rgba(0,0,0,0.1); padding: 1rem; font-weight: 600; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    th[data-sort] { cursor: pointer; user-select: none; transition: background 0.2s; }
    th[data-sort]:hover { background: rgba(0,0,0,0.2); }
    td { padding: 1rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }

    /* Badges */
    .badge-cell { white-space: nowrap; }
    .badge { padding: 0.3rem 0.6rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600; white-space: nowrap; }

    .badge.type-online { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .badge.type-gig-economy { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
    .badge.type-skills-based { background: rgba(168, 85, 247, 0.15); color: #a855f7; }
    .badge.type-passive-income { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

    .badge.cost-none { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
    .badge.cost-low { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .badge.cost-medium { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
    .badge.cost-high { background: rgba(239, 68, 68, 0.15); color: #ef4444; }

    .badge.diff-low { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
    .badge.diff-medium { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
    .badge.diff-high { background: rgba(239, 68, 68, 0.15); color: #ef4444; }

    .badge.scale-none { background: rgba(107, 114, 128, 0.15); color: #9ca3af; }
    .badge.scale-low { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
    .badge.scale-medium { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
    .badge.scale-high { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .badge.scale-very-high { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

    /* FAQ */
    .faq-container { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .faq-item h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin: 0; color: var(--text-secondary); line-height: 1.5; }

    @media (max-width: 768px) {
      .hero h1 { font-size: 1.8rem; }
      td, th { padding: 0.75rem; }
    }
  </style>
</SiteLayout>
