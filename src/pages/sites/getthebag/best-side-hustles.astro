---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const methods = [
  // Online
  { name: "Freelancing", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Offer your skills online." },
  { name: "Dropshipping", incomePotential: "High", startupCost: "Medium", timeFlexibility: "High", desc: "Sell products without inventory." },
  { name: "Content Creation", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Create content for platforms like YouTube or TikTok." },
  { name: "Tutoring", incomePotential: "Medium", startupCost: "Low", timeFlexibility: "Medium", desc: "Teach students online." },
  { name: "Virtual Assistant", incomePotential: "Medium", startupCost: "Low", timeFlexibility: "High", desc: "Provide administrative help remotely." },
  { name: "Social Media Manager", incomePotential: "Medium", startupCost: "Low", timeFlexibility: "High", desc: "Manage social accounts for brands." },
  { name: "Transcription", incomePotential: "Low", startupCost: "Low", timeFlexibility: "High", desc: "Convert audio to text." },
  { name: "Data Entry", incomePotential: "Low", startupCost: "Low", timeFlexibility: "High", desc: "Input data into systems." },

  // Local
  { name: "Dog Walking", incomePotential: "Medium", startupCost: "Low", timeFlexibility: "Medium", desc: "Walk dogs for owners." },
  { name: "House Sitting", incomePotential: "Low", startupCost: "Low", timeFlexibility: "High", desc: "Watch houses while owners are away." },
  { name: "Photography", incomePotential: "High", startupCost: "High", timeFlexibility: "High", desc: "Take photos for events." },
  { name: "Rideshare Driving", incomePotential: "Medium", startupCost: "High", timeFlexibility: "High", desc: "Drive passengers using an app." },
  { name: "Food Delivery", incomePotential: "Low", startupCost: "Medium", timeFlexibility: "High", desc: "Deliver food from restaurants." },
  { name: "Handyman Services", incomePotential: "High", startupCost: "Medium", timeFlexibility: "High", desc: "Perform minor repairs." },
  { name: "Lawn Care", incomePotential: "Medium", startupCost: "Medium", timeFlexibility: "High", desc: "Mow lawns and maintain yards." },
  { name: "Cleaning Services", incomePotential: "Medium", startupCost: "Low", timeFlexibility: "High", desc: "Clean homes or offices." },

  // Skilled
  { name: "Web Dev", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Build websites for clients." },
  { name: "Graphic Design", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Create visual designs." },
  { name: "Bookkeeping", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Manage financial records." },
  { name: "SEO Consulting", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Optimize websites for search." },
  { name: "App Development", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Create mobile applications." },
  { name: "Video Editing", incomePotential: "High", startupCost: "Medium", timeFlexibility: "High", desc: "Edit videos for creators." },
  { name: "Copywriting", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Write persuasive text for businesses." },

  // Passive
  { name: "Print on Demand", incomePotential: "Medium", startupCost: "Low", timeFlexibility: "High", desc: "Sell custom products." },
  { name: "Digital Products", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Sell digital goods." },
  { name: "Affiliate Marketing", incomePotential: "High", startupCost: "Low", timeFlexibility: "High", desc: "Promote others' products." },
  { name: "Dividend Investing", incomePotential: "High", startupCost: "High", timeFlexibility: "High", desc: "Invest in dividend stocks." },
  { name: "Real Estate Crowdfunding", incomePotential: "Medium", startupCost: "Medium", timeFlexibility: "High", desc: "Invest in real estate." },
  { name: "Peer-to-Peer Lending", incomePotential: "Medium", startupCost: "Medium", timeFlexibility: "High", desc: "Lend money via platforms." },
  { name: "Vending Machines", incomePotential: "Medium", startupCost: "High", timeFlexibility: "Medium", desc: "Operate vending machines." }
];

const faqs = [
  { q: "Do I have to pay taxes on my side hustle income?", a: "Yes, side hustle income is taxable." },
  { q: "Should I form an LLC for my side hustle?", a: "It depends, consult a professional." },
  { q: "Can I write off expenses for my side hustle?", a: "Yes, you can deduct ordinary business expenses." },
  { q: "How much should I save for taxes from my side hustle?", a: "A good rule of thumb is 25-30%." },
  { q: "Do I need to pay estimated quarterly taxes?", a: "If you expect to owe $1,000 or more, yes." }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "30 Best Side Hustles 2026",
    "description": "30 best side hustles ranked by income potential, startup cost, time flexibility.",
    "author": {
      "@type": "Organization",
      "name": "Get The Bag"
    },
    "datePublished": "2026-01-01",
    "dateModified": "2026-01-01"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];
---

<SiteLayout
  site="getthebag"
  title="30 Best Side Hustles 2026"
  description="Explore 30 of the best side hustles for 2026, ranked by income potential, startup cost, and time flexibility. Find online, local, and skilled gigs."
  canonical="https://getthebag.photonbuilder.com/best-side-hustles"
  schema={JSON.stringify(schema)}
>
  <div class="page-content">
    <div class="hero">
      <h1>30 Best Side Hustles 2026</h1>
      <p>30 best side hustles ranked by income potential, startup cost, time flexibility.</p>
    </div>

    <section class="content-section">

      <h2>The 30 Methods</h2>
      <div class="tips-grid">
        {methods.map((method, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{method.name}</h3>
              <p><strong>Income Potential:</strong> {method.incomePotential}</p>
              <p><strong>Startup Cost:</strong> {method.startupCost}</p>
              <p><strong>Time Flexibility:</strong> {method.timeFlexibility}</p>
              <p><strong>Description:</strong> {method.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>

    </section>
  </div>

  <style>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1.2rem; margin-top: 2.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem; }

    /* Tips Grid */
    .tips-grid { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .tip-card { display: flex; gap: 1rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; align-items: flex-start; }
    .tip-number { background: var(--accent-color); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
    .tip-content h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .tip-content p { margin: 0; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.4; padding-bottom: 0.5rem; }

    /* FAQ */
    .faq-container { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .faq-item h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin: 0; color: var(--text-secondary); }

    @media (max-width: 768px) {
      .hero h1 { font-size: 1.8rem; }
    }
  </style>
</SiteLayout>
