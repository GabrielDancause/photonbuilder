---
import SiteLayout from "../../../layouts/SiteLayout.astro";


export const meta = {
  title: 'Best Freelance Portfolios and How to Build One',
  description: 'How to build a freelance portfolio that gets clients. Cover: what to include, platforms, writing case studies, pricing display, testimonials, SEO, 10 examples.',
  category: 'guide',
};

const whatToInclude = [
  {
    topic: "Detailed Case Studies",
    desc: "Don't just post screenshots of final designs. Explain the problem, the process, and the business results of your work."
  },
  {
    topic: "Clear Value Proposition",
    desc: "Your homepage should immediately state what you do and who you do it for (e.g., 'B2B SaaS Copywriter' or 'Shopify Developer for E-com Brands')."
  },
  {
    topic: "Services & Packages",
    desc: "Clearly list the specific services you offer to set expectations and filter out bad leads."
  },
  {
    topic: "Call to Action (CTA)",
    desc: "Make it painfully easy to contact you. Use clear 'Hire Me' or 'Book a Call' buttons leading to a simple form."
  }
];

const platforms = [
  {
    platform: "Personal Website (Custom)",
    desc: "The ultimate flex. Gives you total control over SEO, branding, and analytics. Use Webflow, Framer, or WordPress."
  },
  {
    platform: "Notion",
    desc: "Fast, free, and minimalist. Perfect for writers, strategists, and consultants who don't need heavily visual layouts."
  },
  {
    platform: "Behance & Dribbble",
    desc: "Great for visual designers and illustrators. Built-in audience, but hard to stand out and customize fully."
  },
  {
    platform: "Carrd & Linktree",
    desc: "Good for a temporary landing page if you are just starting, but transition to a full site as soon as possible."
  }
];

const writingCaseStudies = [
  {
    step: "The Problem (Context)",
    desc: "Start with the client's initial situation. What were they struggling with before they hired you?"
  },
  {
    step: "The Process (Execution)",
    desc: "Explain how you solved the problem. Show sketches, wireframes, early drafts, and explain your strategic thinking."
  },
  {
    step: "The Result (Impact)",
    desc: "The most important part. Use hard numbers if possible (e.g., 'Increased conversion by 20%' or 'Saved 10 hours of manual work')."
  }
];

const pricingDebate = [
  {
    stance: "Displaying Prices (Yes)",
    desc: "Filters out low-budget clients immediately. Sets clear expectations and saves time on discovery calls."
  },
  {
    stance: "Hiding Prices (No)",
    desc: "Allows you to value-price based on the client's budget and project complexity. Better for high-ticket custom services."
  }
];

const otherElements = [
  {
    element: "Testimonials & Social Proof",
    desc: "Sprinkle client quotes throughout your site, not just on one page. Video testimonials convert best."
  },
  {
    element: "About Me Section",
    desc: "Keep it professional but show personality. Clients hire humans. Mention your background and working style."
  },
  {
    element: "SEO for Your Portfolio",
    desc: "Optimize your title tags and headers for local or niche searches (e.g., 'Freelance UX Designer in Chicago' or 'Technical Writer for Fintech')."
  }
];

const examples = [
  { name: "Bruno Simon", industry: "Creative Developer", note: "Interactive 3D driving portfolio that went viral." },
  { name: "Tobias van Schneider", industry: "Product Designer", note: "Clean typography and massive, detailed case studies." },
  { name: "Gary Sheng", industry: "Software Engineer", note: "Great use of timeline structure for technical projects." },
  { name: "Kaleigh Moore", industry: "Freelance Writer", note: "Simple, copy-focused site with logos of major publications." },
  { name: "Devon Stank", industry: "Webflow Developer", note: "Clear service packages and strong video integration." },
  { name: "Edgar Perez", industry: "Photographer", note: "Minimal UI that lets the visual work speak for itself." },
  { name: "Robby Leonardi", industry: "Illustrator/Animator", note: "Famous interactive 'Mario-style' resume." },
  { name: "Ann Handley", industry: "Marketer/Writer", note: "Strong personal branding and clear newsletter CTA." },
  { name: "Jantana Hennard", industry: "UI/UX Designer", note: "Elegant layout with deep dives into design systems." },
  { name: "Matthew Smith", industry: "Art Director", note: "Bold, brutalist design that stands out in the creative space." }
];

const faqs = [
  {
    q: "Do I need a custom domain for my portfolio?",
    a: "Yes. Using a custom domain (yourname.com) looks infinitely more professional than a .notion.site or .wordpress.com address, and it costs less than $20 a year."
  },
  {
    q: "How many case studies should I include?",
    a: "Quality over quantity. 3 to 5 highly detailed, successful case studies are much better than 10 rushed, shallow projects."
  },
  {
    q: "What if I have no past clients?",
    a: "Create 'spec' work. Redesign a famous app, write sample copy for a brand you love, or build a personal project. Clearly label it as a concept."
  },
  {
    q: "Should I put my resume on my portfolio?",
    a: "Yes, offer a downloadable PDF version of your resume, but ensure the website itself tells a more compelling story than a standard resume document."
  },
  {
    q: "How often should I update my portfolio?",
    a: "Review it every 6 months. Add your best recent work and remove older projects that no longer represent your current skill level."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Freelance Portfolios and How to Build One",
    "description": "How to build a freelance portfolio that gets clients. Cover: what to include, platforms, writing case studies, pricing display, testimonials, SEO, 10 examples.",
    "author": {
      "@type": "Organization",
      "name": "Get The Bag"
    },
    "datePublished": "2026-05-10",
    "dateModified": "2026-05-10"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];
---

<SiteLayout
  site="getthebag"
  title="Best Freelance Portfolios and How to Build One"
  description="How to build a freelance portfolio that gets clients. Cover: what to include, platforms, writing case studies, pricing display, testimonials, SEO, 10 examples."
  canonical="https://getthebag.photonbuilder.com/freelance-portfolio-guide"
  schema={schema}
>
  <div class="page-content">
    <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      🎨 <strong style="color:#3B82F6;">Freelancers with case-study portfolios earn 2.4× more per project than those with just a skills list.</strong> Clients don't hire credentials — they hire proof. Three strong case studies with measurable results outperform 20 generic project screenshots every time. <a href="https://gab.ae/news/global-freelance-economy-record-growth-2026" style="color:#3B82F6;">The freelance economy is booming →</a>
    </div>
    <div class="hero">
      <h1>How to Build a Freelance Portfolio that Gets Clients</h1>
      <p>Your portfolio is your most powerful sales tool. Learn what to include, where to host it, and how to write case studies that prove your value.</p>
    </div>

    <section class="content-section">

      <h2>What to Include in Your Portfolio</h2>
      <div class="tips-grid">
        {whatToInclude.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.topic}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Best Portfolio Platforms</h2>
      <div class="tips-grid">
        {platforms.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.platform}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>How to Write a Case Study</h2>
      <div class="tips-grid">
        {writingCaseStudies.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.step}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Should You Display Your Prices?</h2>
      <div class="tips-grid">
        {pricingDebate.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.stance}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>Other Crucial Elements</h2>
      <div class="tips-grid">
        {otherElements.map((item, index) => (
          <div class="tip-card">
            <div class="tip-number">{index + 1}</div>
            <div class="tip-content">
              <h3>{item.element}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <h2>10 Examples of Great Portfolios by Industry</h2>
      <div class="examples-list">
        <ul>
          {examples.map(ex => (
            <li><strong>{ex.name}</strong> ({ex.industry}) – {ex.note}</li>
          ))}
        </ul>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>

    </section>
  </div>

  <style>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1.2rem; margin-top: 2.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.5rem; }

    /* Tips Grid */
    .tips-grid { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .tip-card { display: flex; gap: 1rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; align-items: flex-start; }
    .tip-number { background: var(--accent-color); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
    .tip-content h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .tip-content p { margin: 0; font-size: 0.95rem; color: var(--text-secondary); }

    /* Examples List */
    .examples-list { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
    .examples-list ul { margin: 0; padding-left: 1.5rem; color: var(--text-secondary); }
    .examples-list li { margin-bottom: 0.75rem; line-height: 1.5; }
    .examples-list strong { color: var(--text-primary); }

    /* FAQ */
    .faq-container { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .faq-item h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin: 0; color: var(--text-secondary); }

    @media (max-width: 768px) {
      .hero h1 { font-size: 1.8rem; }
    }
  </style>
</SiteLayout>
