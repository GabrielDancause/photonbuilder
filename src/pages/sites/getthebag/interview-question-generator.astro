---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const faqs = [
  {
    q: "How many questions should I prepare for an interview?",
    a: "You should prepare answers for at least 15-20 common questions spanning behavioral, technical, and situational categories. Focus on your specific job field and experience level. Practice your responses out loud, ideally with a timer, aiming for 1-3 minute answers."
  },
  {
    q: "What is the STAR method for answering behavioral questions?",
    a: "STAR stands for Situation, Task, Action, Result. You describe a specific Situation you faced, the Task you were responsible for, the Action you took, and the measurable Result you achieved. This framework keeps your answers structured, concise, and impactful."
  },
  {
    q: "How should I handle salary negotiation questions in an interview?",
    a: "Research market rates for your role and experience level before the interview. When asked, provide a range based on your research rather than a single number. Emphasize your value and total compensation expectations including benefits, equity, and growth opportunities."
  },
  {
    q: "What are the most common interview mistakes to avoid?",
    a: "The biggest mistakes include: not researching the company, giving vague answers without specific examples, speaking negatively about past employers, not asking thoughtful questions at the end, and failing to follow up with a thank-you note within 24 hours."
  },
  {
    q: "How long should I spend preparing for each interview question?",
    a: "Spend 5-10 minutes drafting each answer and 2-3 minutes practicing it aloud. For technical questions, allocate more time for problem-solving practice. In total, dedicate at least 3-5 hours to interview preparation for each company you apply to."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Interview Question Generator",
    "description": "Generate tailored interview questions by job field and experience level. Practice with 200+ questions across behavioral, technical, situational, culture fit, and salary negotiation categories.",
    "url": "https://getthebag.photonbuilder.com/interview-question-generator",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Interview Question Generator — Practice 200+ Questions by Field & Level",
  description: "Generate tailored interview questions by job field and experience level. Practice behavioral, technical, situational, culture fit, and salary negotiation questions with mock interview mode.",
  category: "tool",
  published: "2026-03-21"
};
---

<SiteLayout
  site="getthebag"
  title={meta.title}
  description={meta.description}
  canonical="https://getthebag.photonbuilder.com/interview-question-generator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Interview Question Generator</h1>
      <p>Select your job field and experience level to get tailored interview questions. Practice with 200+ questions across 5 categories, or launch mock interview mode for a timed 10-question session.</p>
    </div>

    <section class="content-section">
      <div class="controls-panel">
        <div class="control-group">
          <label for="field-select">Job Field</label>
          <select id="field-select">
            <option value="software-engineering">Software Engineering</option>
            <option value="marketing">Marketing</option>
            <option value="finance">Finance</option>
            <option value="sales">Sales</option>
            <option value="hr">Human Resources</option>
            <option value="design">Design</option>
            <option value="data-science">Data Science</option>
            <option value="management">Management</option>
            <option value="healthcare">Healthcare</option>
            <option value="education">Education</option>
          </select>
        </div>
        <div class="control-group">
          <label for="level-select">Experience Level</label>
          <select id="level-select">
            <option value="entry">Entry Level</option>
            <option value="mid">Mid Level</option>
            <option value="senior">Senior Level</option>
          </select>
        </div>
        <div class="control-group">
          <label for="category-select">Category</label>
          <select id="category-select">
            <option value="all">All Categories</option>
            <option value="behavioral">Behavioral (STAR)</option>
            <option value="technical">Technical</option>
            <option value="situational">Situational</option>
            <option value="culture-fit">Culture Fit</option>
            <option value="salary">Salary Negotiation</option>
          </select>
        </div>
        <div class="btn-group">
          <button id="generate-btn" class="btn btn-primary">Generate Questions</button>
          <button id="mock-btn" class="btn btn-secondary">Mock Interview Mode</button>
        </div>
      </div>

      <!-- Question List View -->
      <div id="questions-view">
        <div id="questions-list" class="questions-list"></div>
      </div>

      <!-- Mock Interview View -->
      <div id="mock-view" class="mock-view" style="display:none;">
        <div class="mock-header">
          <div class="mock-progress">
            <span id="mock-counter">Question 1 of 10</span>
            <div class="progress-bar"><div id="progress-fill" class="progress-fill"></div></div>
          </div>
          <div class="mock-timer">
            <span id="timer-display">2:00</span>
          </div>
        </div>
        <div id="mock-question-card" class="mock-question-card"></div>
        <div class="mock-actions">
          <button id="mock-reveal-btn" class="btn btn-secondary">Show Answer Framework</button>
          <button id="mock-next-btn" class="btn btn-primary">Next Question</button>
          <button id="mock-exit-btn" class="btn btn-outline">Exit Mock Interview</button>
        </div>
        <div id="mock-answer" class="mock-answer" style="display:none;"></div>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        {faqs.map(faq => (
          <div class="faq-item">
            <h3>{faq.q}</h3>
            <p>{faq.a}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

