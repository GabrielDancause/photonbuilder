        situational: [
          { q: "Your manager asks you to complete a project by Friday, but you know the timeline is unrealistic. What do you do?", framework: "Show honest communication: assess what's feasible, propose alternatives (scope reduction, deadline extension, additional resources), and document the conversation.", prepTime: 8, difficulty: "Medium", fields: ["all"], levels: ["all"] },
