          { q: "You join a team and notice significant technical debt. How do you approach addressing it?", framework: "Audit the scope, prioritize by risk and business impact, propose a plan that balances debt reduction with feature work, and get stakeholder buy-in.", prepTime: 10, difficulty: "Medium", fields: ["software-engineering", "data-science"], levels: ["mid", "senior"] },
          { q: "A vendor your team relies on suddenly doubles their pricing. What do you do?", framework: "Evaluate alternatives, negotiate with the vendor, assess build-vs-buy, present options with cost analysis to leadership, and plan the transition.", prepTime: 10, difficulty: "Hard", fields: ["all"], levels: ["mid", "senior"] },
          { q: "You're asked to lead a cross-functional project with people who don't report to you. How do you drive results?", framework: "Build relationships first, align on shared goals, establish clear roles (RACI), communicate consistently, and influence through expertise not authority.", prepTime: 10, difficulty: "Hard", fields: ["all"], levels: ["mid", "senior"] },
        ],
        "culture-fit": [
          { q: "Why do you want to work at this company?", framework: "Research the company's mission, products, and culture. Connect their values to your personal values and career goals. Be specific, not generic.", prepTime: 8, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "What kind of work environment do you thrive in?", framework: "Be honest but align with the company's culture. Give examples of environments where you've done your best work and why.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "How do you handle work-life balance?", framework: "Show you're productive and reliable while having healthy boundaries. Give examples of how you stay engaged without burning out.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "What motivates you in your career?", framework: "Connect intrinsic motivators (growth, impact, learning) to the role. Avoid generic answers; be specific about what drives your best work.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "How do you approach collaboration with teammates who have different working styles?", framework: "Demonstrate flexibility and emotional intelligence. Give examples of adapting your communication and work style for team effectiveness.", prepTime: 8, difficulty: "Medium", fields: ["all"], levels: ["all"] },
          { q: "Tell me about your ideal manager.", framework: "Describe qualities that help you grow (clear expectations, feedback, autonomy). Show self-awareness about what support you need to do your best work.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "What's a value you hold that you will not compromise on professionally?", framework: "Choose a value relevant to work (integrity, transparency, quality). Give a concrete example of upholding it under pressure.", prepTime: 8, difficulty: "Medium", fields: ["all"], levels: ["all"] },
          { q: "How do you contribute to a positive team culture?", framework: "Give specific examples: celebrating wins, helping others, giving constructive feedback, organizing team activities, or knowledge sharing.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "Where do you see yourself in 5 years?", framework: "Show ambition aligned with realistic growth at the company. Focus on skills you want to develop and impact you want to make.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "What do you do outside of work that influences your professional life?", framework: "Share relevant hobbies or activities that demonstrate transferable skills, curiosity, or well-roundedness. Keep it professional.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "How do you handle ambiguity in your role?", framework: "Show comfort with uncertainty. Describe how you seek clarity, make progress with incomplete information, and communicate proactively.", prepTime: 8, difficulty: "Medium", fields: ["all"], levels: ["mid", "senior"] },
          { q: "Describe a company culture you didn't fit into. What made it a bad fit?", framework: "Be diplomatic — focus on misaligned values or working styles, not blame. Show self-awareness about what you need to thrive.", prepTime: 8, difficulty: "Hard", fields: ["all"], levels: ["mid", "senior"] },
          { q: "How do you stay motivated during repetitive or mundane tasks?", framework: "Show discipline and perspective. Discuss finding meaning in routine, gamifying tasks, or connecting them to bigger goals.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["entry", "mid"] },
          { q: "What role do you typically take on in a team project?", framework: "Show flexibility. Describe your natural tendencies but demonstrate willingness to adapt to what the team needs.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "How do you celebrate team successes?", framework: "Give examples of recognizing contributions, sharing credit, and building team morale after wins.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "What's the most important thing you look for in a job?", framework: "Be genuine. Align your answer with what the role offers. Top answers include: growth, impact, team quality, and mission alignment.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "How do you handle feedback from someone you disagree with?", framework: "Show emotional maturity. Separate the message from the messenger, look for valid points, and respond professionally.", prepTime: 8, difficulty: "Medium", fields: ["all"], levels: ["all"] },
          { q: "What does professional development mean to you?", framework: "Discuss: continuous learning, mentorship (giving and receiving), skill expansion, and how you invest in your own growth.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
        ],
        salary: [
          { q: "What are your salary expectations for this role?", framework: "Provide a researched range based on market data (Glassdoor, Levels.fyi, Payscale). State your range confidently and ask about total compensation.", prepTime: 10, difficulty: "Hard", fields: ["all"], levels: ["all"] },
          { q: "What is your current compensation?", framework: "In many states, this question is illegal. You can redirect: 'I'd prefer to focus on the value I bring and the market rate for this role.' State your target range instead.", prepTime: 10, difficulty: "Hard", fields: ["all"], levels: ["all"] },
          { q: "We have a budget of $X for this role. Would you accept that?", framework: "Don't accept immediately. Ask about the full package (bonus, equity, benefits, PTO). If below your range, say: 'I appreciate the transparency. Based on my research and experience, I was targeting [range].'", prepTime: 10, difficulty: "Hard", fields: ["all"], levels: ["all"] },
          { q: "How do you evaluate a job offer beyond salary?", framework: "Discuss: equity/RSUs, signing bonus, annual bonus, benefits, PTO, remote flexibility, growth opportunities, team quality, and company trajectory.", prepTime: 8, difficulty: "Medium", fields: ["all"], levels: ["all"] },
          { q: "Are you interviewing with other companies?", framework: "Be honest but strategic: 'Yes, I'm exploring a few opportunities, but this role is a top choice because [specific reason].' This shows demand without being aggressive.", prepTime: 5, difficulty: "Medium", fields: ["all"], levels: ["all"] },
          { q: "If we gave you an offer today, would you accept?", framework: "Express enthusiasm without committing: 'I'm very excited about this opportunity. I'd want to review the full offer details and discuss with my family, which I can do within [timeframe].'", prepTime: 5, difficulty: "Medium", fields: ["all"], levels: ["all"] },
          { q: "What would it take for you to accept an offer today?", framework: "Name your priorities clearly: 'I'd need the compensation to be in the range of [X-Y], with [specific benefits]. I'm also looking for [growth opportunity or flexibility].'", prepTime: 10, difficulty: "Hard", fields: ["all"], levels: ["mid", "senior"] },
          { q: "We can't meet your salary request. What are your thoughts?", framework: "Explore alternatives: signing bonus, accelerated review cycle, additional equity, flexible work arrangements, or professional development budget.", prepTime: 10, difficulty: "Hard", fields: ["all"], levels: ["all"] },
          { q: "How soon can you start?", framework: "Be honest about notice periods. Standard is 2 weeks. For senior roles, 4 weeks is common. Express eagerness while being professional about current commitments.", prepTime: 5, difficulty: "Easy", fields: ["all"], levels: ["all"] },
          { q: "Do you have any competing offers?", framework: "If yes, mention it factually without ultimatums. If no, redirect to your interest level and market research. Never fabricate offers.", prepTime: 8, difficulty: "Hard", fields: ["all"], levels: ["mid", "senior"] },
        ]
      };

      const fieldSelect = document.getElementById('field-select');
      const levelSelect = document.getElementById('level-select');
      const categorySelect = document.getElementById('category-select');
      const generateBtn = document.getElementById('generate-btn');
      const mockBtn = document.getElementById('mock-btn');
      const questionsView = document.getElementById('questions-view');
      const questionsList = document.getElementById('questions-list');
      const mockView = document.getElementById('mock-view');
      const mockCounter = document.getElementById('mock-counter');
      const progressFill = document.getElementById('progress-fill');
      const timerDisplay = document.getElementById('timer-display');
      const mockQuestionCard = document.getElementById('mock-question-card');
      const mockRevealBtn = document.getElementById('mock-reveal-btn');
      const mockNextBtn = document.getElementById('mock-next-btn');
      const mockExitBtn = document.getElementById('mock-exit-btn');
      const mockAnswer = document.getElementById('mock-answer');

      let mockQuestions = [];
      let mockIndex = 0;
      let timerInterval = null;
      let timerSeconds = 120;

      const difficultyColors = {
        'Easy': { bg: 'rgba(34, 197, 94, 0.15)', color: '#22c55e' },
        'Medium': { bg: 'rgba(245, 158, 11, 0.15)', color: '#f59e0b' },
        'Hard': { bg: 'rgba(239, 68, 68, 0.15)', color: '#ef4444' }
      };

      const categoryColors = {
        'behavioral': { bg: 'rgba(59, 130, 246, 0.15)', color: '#3b82f6', label: 'Behavioral (STAR)' },
        'technical': { bg: 'rgba(168, 85, 247, 0.15)', color: '#a855f7', label: 'Technical' },
        'situational': { bg: 'rgba(245, 158, 11, 0.15)', color: '#f59e0b', label: 'Situational' },
        'culture-fit': { bg: 'rgba(34, 197, 94, 0.15)', color: '#22c55e', label: 'Culture Fit' },
        'salary': { bg: 'rgba(239, 68, 68, 0.15)', color: '#ef4444', label: 'Salary Negotiation' }
      };

      function getFilteredQuestions(field, level, category) {
        let questions = [];
        const categories = category === 'all' ? Object.keys(questionBank) : [category];

        categories.forEach(cat => {
          (questionBank[cat] || []).forEach(q => {
            const fieldMatch = q.fields.includes('all') || q.fields.includes(field);
            const levelMatch = q.levels.includes('all') || q.levels.includes(level);
            if (fieldMatch && levelMatch) {
              questions.push({ ...q, category: cat });
            }
          });
        });

        return questions;
      }

      function shuffleArray(arr) {
        const a = [...arr];
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
      }

      function renderQuestions(questions) {
        if (questions.length === 0) {
          questionsList.innerHTML = '<div class="empty-state">No questions found for this combination. Try broadening your filters.</div>';
          return;
        }

        const shuffled = shuffleArray(questions).slice(0, 15);
        questionsList.innerHTML = '<p class="results-count">Showing ' + shuffled.length + ' of ' + questions.length + ' available questions</p>' +
          shuffled.map((q, i) => {
            const catInfo = categoryColors[q.category];
            const diffInfo = difficultyColors[q.difficulty];
            return '<div class="question-card">' +
              '<div class="question-tags">' +
                '<span class="tag" style="background:' + catInfo.bg + ';color:' + catInfo.color + '">' + catInfo.label + '</span>' +
                '<span class="tag" style="background:' + diffInfo.bg + ';color:' + diffInfo.color + '">' + q.difficulty + '</span>' +
                '<span class="tag tag-time">' + q.prepTime + ' min prep</span>' +
              '</div>' +
              '<h3 class="question-text">' + q.q + '</h3>' +
              '<div class="answer-framework">' +
                '<strong>Answer Framework:</strong> ' + q.framework +
              '</div>' +
            '</div>';
          }).join('');
      }

      function startTimer() {
        clearInterval(timerInterval);
        timerSeconds = 120;
        updateTimerDisplay();
        timerInterval = setInterval(function() {
          timerSeconds--;
          updateTimerDisplay();
          if (timerSeconds <= 0) {
            clearInterval(timerInterval);
            timerDisplay.style.color = '#ef4444';
            timerDisplay.textContent = "Time's up!";
          }
        }, 1000);
      }

      function updateTimerDisplay() {
        const m = Math.floor(timerSeconds / 60);
        const s = timerSeconds % 60;
        timerDisplay.textContent = m + ':' + (s < 10 ? '0' : '') + s;
        timerDisplay.style.color = timerSeconds <= 30 ? '#ef4444' : timerSeconds <= 60 ? '#f59e0b' : 'var(--text-primary)';
      }

      function showMockQuestion() {
        if (mockIndex >= mockQuestions.length) {
          mockQuestionCard.innerHTML = '<div class="mock-complete"><h2>Mock Interview Complete!</h2><p>You answered all 10 questions. Great practice session!</p></div>';
          mockRevealBtn.style.display = 'none';
          mockNextBtn.style.display = 'none';
          mockAnswer.style.display = 'none';
          clearInterval(timerInterval);
          timerDisplay.textContent = 'Done';
          timerDisplay.style.color = '#22c55e';
          return;
        }

        const q = mockQuestions[mockIndex];
        const catInfo = categoryColors[q.category];
        const diffInfo = difficultyColors[q.difficulty];
        mockCounter.textContent = 'Question ' + (mockIndex + 1) + ' of 10';
        progressFill.style.width = ((mockIndex + 1) / 10 * 100) + '%';

        mockQuestionCard.innerHTML =
          '<div class="question-tags">' +
            '<span class="tag" style="background:' + catInfo.bg + ';color:' + catInfo.color + '">' + catInfo.label + '</span>' +
            '<span class="tag" style="background:' + diffInfo.bg + ';color:' + diffInfo.color + '">' + q.difficulty + '</span>' +
          '</div>' +
          '<h3 class="question-text">' + q.q + '</h3>';

        mockAnswer.innerHTML = '<strong>Suggested Framework:</strong> ' + q.framework;
        mockAnswer.style.display = 'none';
        mockRevealBtn.style.display = '';
        mockRevealBtn.textContent = 'Show Answer Framework';
        mockNextBtn.style.display = '';

        startTimer();
      }

      // Event listeners
      generateBtn.addEventListener('click', function() {
        mockView.style.display = 'none';
        questionsView.style.display = '';
        clearInterval(timerInterval);
        const questions = getFilteredQuestions(fieldSelect.value, levelSelect.value, categorySelect.value);
        renderQuestions(questions);
      });

      mockBtn.addEventListener('click', function() {
        const questions = getFilteredQuestions(fieldSelect.value, levelSelect.value, categorySelect.value);
        if (questions.length < 10) {
          mockQuestions = shuffleArray(questions);
        } else {
          mockQuestions = shuffleArray(questions).slice(0, 10);
        }

        if (mockQuestions.length === 0) {
          alert('No questions available for this combination. Try different filters.');
          return;
        }

        mockIndex = 0;
        questionsView.style.display = 'none';
        mockView.style.display = '';
        showMockQuestion();
      });

      mockRevealBtn.addEventListener('click', function() {
        if (mockAnswer.style.display === 'none') {
          mockAnswer.style.display = '';
          mockRevealBtn.textContent = 'Hide Answer Framework';
        } else {
          mockAnswer.style.display = 'none';
          mockRevealBtn.textContent = 'Show Answer Framework';
        }
      });

      mockNextBtn.addEventListener('click', function() {
        mockIndex++;
        showMockQuestion();
      });

      mockExitBtn.addEventListener('click', function() {
        mockView.style.display = 'none';
        questionsView.style.display = '';
        clearInterval(timerInterval);
      });

      // Initial render
      generateBtn.click();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 700px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1.2rem; margin-top: 2.5rem; }

    /* Controls */
    .controls-panel { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end; margin-bottom: 2rem; }
    .control-group { display: flex; flex-direction: column; gap: 0.4rem; flex: 1; min-width: 160px; }
    .control-group label { font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; }
    .control-group select { padding: 0.6rem 0.8rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-primary); color: var(--text-primary); font-size: 0.95rem; cursor: pointer; }
    .btn-group { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .btn { padding: 0.6rem 1.2rem; border-radius: 8px; border: none; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: opacity 0.2s, transform 0.1s; white-space: nowrap; }
    .btn:active { transform: scale(0.97); }
    .btn-primary { background: var(--accent-color, #3b82f6); color: #fff; }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { background: rgba(168, 85, 247, 0.15); color: #a855f7; }
    .btn-secondary:hover { background: rgba(168, 85, 247, 0.25); }
    .btn-outline { background: transparent; border: 1px solid var(--border-color); color: var(--text-secondary); }
    .btn-outline:hover { background: var(--card-bg); }

    /* Questions List */
    .results-count { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }
    .questions-list { display: flex; flex-direction: column; gap: 1rem; }
    .question-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .question-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
    .tag { padding: 0.25rem 0.6rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600; white-space: nowrap; }
    .tag-time { background: rgba(107, 114, 128, 0.15); color: #9ca3af; }
    .question-text { margin: 0 0 0.75rem 0; font-size: 1.1rem; color: var(--text-primary); line-height: 1.4; }
    .answer-framework { color: var(--text-secondary); line-height: 1.5; font-size: 0.95rem; }
    .answer-framework strong { color: var(--text-primary); }
    .empty-state { text-align: center; padding: 3rem; color: var(--text-secondary); }

    /* Mock Interview */
    .mock-view { margin-bottom: 2rem; }
    .mock-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; gap: 1rem; flex-wrap: wrap; }
    .mock-progress { flex: 1; min-width: 200px; }
    .mock-progress span { font-size: 0.9rem; font-weight: 600; color: var(--text-secondary); }
    .progress-bar { height: 6px; background: var(--border-color); border-radius: 3px; margin-top: 0.5rem; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--accent-color, #3b82f6); border-radius: 3px; transition: width 0.3s; width: 10%; }
    .mock-timer { font-size: 2rem; font-weight: 800; color: var(--text-primary); font-variant-numeric: tabular-nums; }
    .mock-question-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin-bottom: 1rem; min-height: 150px; }
    .mock-question-card .question-text { font-size: 1.3rem; margin-bottom: 0; }
    .mock-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .mock-answer { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; color: var(--text-secondary); line-height: 1.5; }
    .mock-answer strong { color: var(--text-primary); }
    .mock-complete { text-align: center; }
    .mock-complete h2 { color: var(--text-primary); margin-bottom: 0.5rem; }
    .mock-complete p { color: var(--text-secondary); }

    /* FAQ */
    .faq-container { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .faq-item h3 { margin: 0 0 0.5rem 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin: 0; color: var(--text-secondary); line-height: 1.5; }

    @media (max-width: 768px) {
      .hero h1 { font-size: 1.8rem; }
      .controls-panel { flex-direction: column; }
      .control-group { min-width: 100%; }
      .mock-timer { font-size: 1.5rem; }
      .mock-question-card .question-text { font-size: 1.1rem; }
    }
  </style>
</SiteLayout>
