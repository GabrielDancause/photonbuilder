    // Visualization Logic
    function renderVisualization() {
      const container = document.getElementById('domain-visualization');
      const hpv16 = e2Data.data.find(d => d.genotype === 'HPV-16');

      const totalLen = hpv16.e2Length;
      const tadPct = ((hpv16.tadEnd - hpv16.tadStart + 1) / totalLen) * 100;
      const hingePct = ((hpv16.hingeEnd - hpv16.hingeStart + 1) / totalLen) * 100;
      const dbdPct = ((hpv16.dbdEnd - hpv16.dbdStart + 1) / totalLen) * 100;

      container.innerHTML = `
        <div class="flex h-[60px] rounded-lg overflow-hidden mt-4 border border-[var(--border)]">
          <div class="flex items-center justify-center font-mono text-[0.8rem] font-semibold text-white bg-[rgba(16,185,129,0.2)] border-r border-[var(--border)]" style="width: ${tadPct}%;" title="Transactivation Domain (1-200)">
            TAD
          </div>
          <div class="flex items-center justify-center font-mono text-[0.8rem] font-semibold text-white bg-[rgba(16,185,129,0.05)] border-r border-[var(--border)]" style="width: ${hingePct}%;" title="Hinge Region (201-284)">
            Hinge
          </div>
          <div class="flex items-center justify-center font-mono text-[0.8rem] font-semibold text-white bg-[rgba(16,185,129,0.4)]" style="width: ${dbdPct}%;" title="DNA-Binding Domain (285-365)">
            DBD
          </div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:8px; font-size:0.75rem; color:var(--text-muted); font-family:'JetBrains Mono', monospace;">
          <span>1</span>
          <span>365</span>
        </div>
      `;
    }

    // Table Logic
    let currentData = [...e2Data.data];
    let sortCol = '';
    let sortAsc = true;

    function renderTable() {
      const tbody = document.getElementById('data-table-body');
      tbody.innerHTML = '';

      currentData.forEach(row => {
        const riskClass = row.riskLevel === 'high' ? 'bg-red-500/10 text-red-500' : 'bg-blue-500/10 text-blue-500';
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td class="p-4 border-b border-[var(--border)] font-mono text-[0.9rem]"><strong>${row.genotype}</strong></td>
          <td class="p-4 border-b border-[var(--border)] font-mono text-[0.9rem]"><span class="inline-block px-2 py-1 rounded text-[0.75rem] font-semibold uppercase ${riskClass}">${row.riskLevel}</span></td>
          <td class="p-4 border-b border-[var(--border)] font-mono text-[0.9rem]">${row.e2Length} aa</td>
          <td class="p-4 border-b border-[var(--border)] font-mono text-[0.9rem]">${row.tadStart}-${row.tadEnd}</td>
          <td class="p-4 border-b border-[var(--border)] font-mono text-[0.9rem]">${row.hingeStart}-${row.hingeEnd}</td>
          <td class="p-4 border-b border-[var(--border)] font-mono text-[0.9rem]">${row.dbdStart}-${row.dbdEnd}</td>
          <td class="p-4 border-b border-[var(--border)] font-mono text-[0.9rem]">${row.sequenceIdentityToHPV16}%</td>
        `;
`;
        tbody.appendChild(tr);
      });
    }

    function sortTable(column) {
      if (sortCol === column) {
        sortAsc = !sortAsc;
      } else {
        sortCol = column;
        sortAsc = true;
      }

      currentData.sort((a, b) => {
        let valA = a[column];
        let valB = b[column];

        if (typeof valA === 'string') valA = valA.toLowerCase();
        if (typeof valB === 'string') valB = valB.toLowerCase();

        // Natural sort for genotype strings like HPV-6 and HPV-16
        if (column === 'genotype') {
           const numA = parseInt(valA.replace('hpv-', ''));
           const numB = parseInt(valB.replace('hpv-', ''));
           return sortAsc ? numA - numB : numB - numA;
        }

        if (valA < valB) return sortAsc ? -1 : 1;
        if (valA > valB) return sortAsc ? 1 : -1;
        return 0;
      });
      renderTable();
    }

    document.getElementById('table-search').addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      currentData = e2Data.data.filter(row =>
        row.genotype.toLowerCase().includes(term) ||
        row.riskLevel.toLowerCase().includes(term)
      );
      renderTable();
    });

    // Init
    renderVisualization();
    renderTable();
  </script>
</SiteLayout>
