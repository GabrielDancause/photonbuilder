---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "E2 Protein Sequence Comparison Across HPV Genotypes",
      "description": "Comparative study of E2 protein sequences across characterized HPV genotypes, mapping conservation to known functional domains.",
      "author": {
        "@type": "Organization",
        "name": "HPV Research",
        "url": "https://hpv-research.org"
      },
      "publisher": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the E2 protein in HPV?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The E2 protein is a master regulator of the HPV lifecycle. It controls viral replication, transcription regulation, and genome maintenance."
          }
        },
        {
          "@type": "Question",
          "name": "Why compare E2 sequences across genotypes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Comparing sequences helps identify highly conserved regions that are common across multiple HPV types. These regions are potential targets for broad-spectrum antiviral drugs."
          }
        },
        {
          "@type": "Question",
          "name": "Which E2 domain is the most conserved?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Generally, the DNA-binding domain (DBD) and the transactivation domain (TAD) show higher conservation compared to the flexible hinge region, which is highly variable."
          }
        },
        {
          "@type": "Question",
          "name": "What is the reference sequence for this study?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "HPV16 E2 (UniProt ID: P03120) is used as the reference sequence for all pairwise alignments in this study."
          }
        },
        {
          "@type": "Question",
          "name": "How is sequence identity calculated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sequence identity is calculated using the Needleman-Wunsch algorithm for global pairwise alignment against the HPV16 reference."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="hpv-research"
  title="E2 Protein Sequence Comparison Across HPV Genotypes"
  description="A comprehensive analysis of E2 protein conservation across different Human Papillomavirus genotypes, identifying functional domains and therapeutic targets."
  canonical="https://photonbuilder.com/sites/hpv-research/e2-genotype-comparison" schema={schema}
>


<main class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-6 my-10">
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
            <div class="text-[2.5rem] font-extrabold text-[var(--accent-color)] font-mono mb-2" id="stat-genotypes">7</div>
            <div class="text-sm text-[var(--text-muted)] font-medium">Genotypes Analyzed</div>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
            <div class="text-[2.5rem] font-extrabold text-[var(--accent-color)] font-mono mb-2">HPV16</div>
            <div class="text-sm text-[var(--text-muted)] font-medium">Reference Sequence</div>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
            <div class="text-[2.5rem] font-extrabold text-[var(--accent-color)] font-mono mb-2">51.2%</div>
            <div class="text-sm text-[var(--text-muted)] font-medium">Avg DBD Identity</div>
        </div>
        <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 text-center">
            <div class="text-[2.5rem] font-extrabold text-[var(--accent-color)] font-mono mb-2">31.3%</div>
            <div class="text-sm text-[var(--text-muted)] font-medium">Avg Hinge Identity</div>
        </div>
    </div>

    <section class="my-[60px] bg-[var(--card-bg)] border border-[var(--border-color)] rounded-2xl p-10">
        <h2 class="text-[1.875rem] font-bold mb-6 text-white">HPV16 E2 Protein Domain Structure</h2>
        <p style="color: var(--text-muted)">The E2 protein consists of two highly conserved domains separated by a flexible, variable hinge region.</p>

        <div class="flex h-[60px] rounded-lg overflow-hidden mt-8 border border-[rgba(255,255,255,0.1)]">
            <div class="flex flex-col justify-center items-center text-white font-semibold text-sm transition-opacity duration-200 hover:opacity-90 flex-[201] bg-gradient-to-br from-blue-500 to-blue-600" title="Transactivation Domain (Amino Acids 1-201)">TAD</div>
            <div class="flex flex-col justify-center items-center text-white font-semibold text-xs transition-opacity duration-200 hover:opacity-90 flex-[84] bg-gradient-to-br from-slate-500 to-slate-600" title="Hinge Region (Amino Acids 202-285)">Hinge</div>
            <div class="flex flex-col justify-center items-center text-white font-semibold text-sm transition-opacity duration-200 hover:opacity-90 flex-[80] bg-gradient-to-br from-emerald-500 to-emerald-600" title="DNA-Binding Domain (Amino Acids 286-365)">DBD</div>
        </div>
        <div class="flex mt-3 text-[var(--text-muted)] text-sm">
            <div class="text-center flex-[201]">aa 1-201<br>Replication & Transcription</div>
            <div class="text-center flex-[84]">aa 202-285<br>Flexible Linker</div>
            <div class="text-center flex-[80]">aa 286-365<br>Dimerization & DNA Binding</div>
        </div>
    </section>

    <section>
        <h2 class="text-[1.875rem] font-bold mb-6 text-white">Genotype Comparison Data</h2>
        <div class="flex justify-between items-center mb-6 flex-wrap gap-4">
            <input type="text" id="searchInput" class="px-4 py-2.5 bg-[var(--bg-color)] border border-[var(--border-color)] rounded-lg text-white font-[var(--font-main)] w-[300px] text-sm focus:outline-none focus:border-[var(--accent-color)]" placeholder="Search genotypes (e.g., '16', 'high')...">
        </div>

        <div class="overflow-x-auto bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl mb-[60px]">
            <table id="dataTable" class="w-full border-collapse text-left">
                <thead>
                    <tr>
                        <th data-sort="genotype" class="px-5 py-4 border-b border-[var(--border-color)] bg-[rgba(255,255,255,0.02)] font-semibold text-xs uppercase tracking-[0.05em] text-[var(--text-muted)] cursor-pointer select-none hover:text-white">Genotype ↕</th>
                        <th data-sort="riskLevel" class="px-5 py-4 border-b border-[var(--border-color)] bg-[rgba(255,255,255,0.02)] font-semibold text-xs uppercase tracking-[0.05em] text-[var(--text-muted)] cursor-pointer select-none hover:text-white">Risk Level ↕</th>
                        <th data-sort="e2Length" class="px-5 py-4 border-b border-[var(--border-color)] bg-[rgba(255,255,255,0.02)] font-semibold text-xs uppercase tracking-[0.05em] text-[var(--text-muted)] cursor-pointer select-none hover:text-white">Length ↕</th>
                        <th data-sort="overallIdentityVsHPV16" class="px-5 py-4 border-b border-[var(--border-color)] bg-[rgba(255,255,255,0.02)] font-semibold text-xs uppercase tracking-[0.05em] text-[var(--text-muted)] cursor-pointer select-none hover:text-white">Overall ID vs HPV16 ↕</th>
                        <th data-sort="tadIdentity" class="px-5 py-4 border-b border-[var(--border-color)] bg-[rgba(255,255,255,0.02)] font-semibold text-xs uppercase tracking-[0.05em] text-[var(--text-muted)] cursor-pointer select-none hover:text-white">TAD ID ↕</th>
                        <th data-sort="hingeIdentity" class="px-5 py-4 border-b border-[var(--border-color)] bg-[rgba(255,255,255,0.02)] font-semibold text-xs uppercase tracking-[0.05em] text-[var(--text-muted)] cursor-pointer select-none hover:text-white">Hinge ID ↕</th>
                        <th data-sort="dbdIdentity" class="px-5 py-4 border-b border-[var(--border-color)] bg-[rgba(255,255,255,0.02)] font-semibold text-xs uppercase tracking-[0.05em] text-[var(--text-muted)] cursor-pointer select-none hover:text-white">DBD ID ↕</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <!-- Populated by JS -->
                </tbody>
            </table>
        </div>
    </section>

    <section class="my-[60px] pt-10 border-t border-[var(--border-color)]">
        <h2 class="text-[1.875rem] font-bold mb-6 text-white">Frequently Asked Questions</h2>

        <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
            <div class="font-semibold text-lg mb-3 text-white">What is the E2 protein in HPV?</div>
            <div class="text-[var(--text-muted)]">The E2 protein is a master regulator of the HPV lifecycle. It controls viral replication, transcription regulation, and genome maintenance. During integration of HPV into the host genome (which can lead to cancer), the E2 gene is often disrupted, leading to uncontrolled expression of oncogenes E6 and E7.</div>
        </div>

        <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
            <div class="font-semibold text-lg mb-3 text-white">Why compare E2 sequences across genotypes?</div>
            <div class="text-[var(--text-muted)]">Comparing sequences helps identify highly conserved regions that are common across multiple HPV types. These regions are potential targets for broad-spectrum antiviral drugs that could treat infections from various high-risk and low-risk HPV types, rather than just targeting a single genotype.</div>
        </div>

        <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
            <div class="font-semibold text-lg mb-3 text-white">Which E2 domain is the most conserved?</div>
            <div class="text-[var(--text-muted)]">Generally, the DNA-binding domain (DBD) and the transactivation domain (TAD) show higher conservation compared to the flexible hinge region. Our data shows the DBD often has the highest sequence identity across divergent genotypes, making it an attractive target for therapeutic intervention.</div>
        </div>

        <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
            <div class="font-semibold text-lg mb-3 text-white">What is the reference sequence for this study?</div>
            <div class="text-[var(--text-muted)]">HPV16 E2 (UniProt ID: P03120) is used as the reference sequence. HPV16 is the most prevalent high-risk genotype responsible for cervical and oropharyngeal cancers, making its E2 protein the most thoroughly characterized.</div>
        </div>

        <div class="mb-6 bg-[var(--card-bg)] border border-[var(--border-color)] p-6 rounded-xl">
            <div class="font-semibold text-lg mb-3 text-white">How is sequence identity calculated?</div>
            <div class="text-[var(--text-muted)]">Sequence identity is calculated using the Needleman-Wunsch algorithm for global pairwise alignment against the HPV16 reference. Identities are calculated separately for the full protein and its individual functional domains (TAD, Hinge, and DBD).</div>
        </div>
    </section>

    <section class="my-[60px] pt-10 border-t border-[var(--border-color)]">
        <h2 class="text-[1.875rem] font-bold mb-6 text-white">Methodology & Sources</h2>
        <div class="text-[var(--text-muted)] bg-[var(--card-bg)] p-8 rounded-xl border border-[var(--border-color)] [&>p]:mb-4 [&>ul]:ml-6 [&>ul]:mb-4 [&>ul>li]:mb-2">
            <p><strong>Data Collection:</strong> Protein sequences for E2 across various HPV genotypes were retrieved from the UniProt Knowledgebase (UniProtKB) via REST API. Papillomavirus Episteme (PAVE) nomenclature was used for genotype classification.</p>

            <p><strong>Alignment & Analysis:</strong></p>
            <ul>
                <li>Reference sequence: HPV16 E2 (UniProt P03120).</li>
                <li>Domain boundaries defined based on structural biology consensus for HPV16: TAD (aa 1-201), Hinge (aa 202-285), DBD (aa 286-365).</li>
                <li>Pairwise global alignment performed using the Needleman-Wunsch algorithm to calculate percent sequence identity.</li>
                <li>Risk level classifications are based on IARC monographs regarding the oncogenic potential of HPV types.</li>
            </ul>

            <div class="text-sm p-3 bg-[rgba(255,255,255,0.03)] border-l-3 border-[var(--accent-color)] mt-6">
                <strong>Primary Data Sources:</strong><br>
                1. UniProt Consortium. (2023). UniProt: the Universal Protein Knowledgebase in 2023. Nucleic Acids Research, 51(D1), D523-D531. DOI: 10.1093/nar/gkac1052<br>
                2. Van Doorslaer K, et al. (2017). The Papillomavirus Episteme: a major update to the PAVE database. Nucleic Acids Research, 45(D1), D499-D506. PMID: 27899637<br>
                3. McBride AA. (2013). The papillomavirus E2 proteins. Virology, 445(1-2), 57-79. PMID: 23931980
            </div>
        </div>
    </section>
</main>
  <script is:inline>
// Embedded Data from crawl script
const rawData = [
    {
      "genotype": "6",
      "riskLevel": "low",
      "e2Length": 368,
      "overallIdentityVsHPV16": 46.74,
      "tadIdentity": 48.8,
      "hingeIdentity": 34.07,
      "dbdIdentity": 52.38
    },
    {
      "genotype": "16",
      "riskLevel": "high",
      "e2Length": 365,
      "overallIdentityVsHPV16": 100,
      "tadIdentity": 100,
      "hingeIdentity": 100,
      "dbdIdentity": 100
    },
    {
      "genotype": "18",
      "riskLevel": "high",
      "e2Length": 365,
      "overallIdentityVsHPV16": 45.66,
      "tadIdentity": 46.67,
      "hingeIdentity": 29.81,
      "dbdIdentity": 54.12
    },
    {
      "genotype": "53",
      "riskLevel": "probable-high",
      "e2Length": 384,
      "overallIdentityVsHPV16": 46.55,
      "tadIdentity": 49.77,
      "hingeIdentity": 30.1,
      "dbdIdentity": 52.17
    },
    {
      "genotype": "54",
      "riskLevel": "low",
      "e2Length": 366,
      "overallIdentityVsHPV16": 46.92,
      "tadIdentity": 49.52,
      "hingeIdentity": 34.69,
      "dbdIdentity": 52.94
    },
    {
      "genotype": "61",
      "riskLevel": "low",
      "e2Length": 382,
      "overallIdentityVsHPV16": 44.8,
      "tadIdentity": 45.83,
      "hingeIdentity": 36.36,
      "dbdIdentity": 50
    },
    {
      "genotype": "70",
      "riskLevel": "low",
      "e2Length": 360,
      "overallIdentityVsHPV16": 48.34,
      "tadIdentity": 49.77,
      "hingeIdentity": 32.04,
      "dbdIdentity": 56.63
    }
];

let tableData = [...rawData];
let currentSort = { column: 'genotype', asc: true };

function renderTable(data) {
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = '';

    data.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'hover:bg-[rgba(255,255,255,0.02)] [&:last-child>td]:border-b-0';

        // Identity formatting with bars
        const formatId = (val) => `
            <div>
                <span class="font-mono text-sm">${val === null ? 'N/A' : val.toFixed(1) + '%'}</span>
                ${val !== null ? `<div class="w-full h-1.5 bg-[rgba(255,255,255,0.1)] rounded-[3px] mt-1.5 overflow-hidden"><div class="h-full bg-[var(--accent-color)] rounded-[3px]" style="width: ${val}%"></div></div>` : ''}
            </div>
        `;

        tr.innerHTML = `
            <td class="px-5 py-4 border-b border-[var(--border-color)] font-mono font-bold text-sm">HPV${row.genotype}</td>
            <td class="px-5 py-4 border-b border-[var(--border-color)]"><span class="inline-block px-2 py-1 rounded text-xs font-semibold uppercase ${row.riskLevel === 'high' ? 'bg-red-500/15 text-red-500' : row.riskLevel === 'probable-high' ? 'bg-amber-500/15 text-amber-500' : row.riskLevel === 'low' ? 'bg-emerald-500/15 text-emerald-500' : 'bg-slate-400/15 text-slate-400'}">${row.riskLevel}</span></td>
            <td class="px-5 py-4 border-b border-[var(--border-color)] font-mono text-sm">${row.e2Length} aa</td>
            <td class="px-5 py-4 border-b border-[var(--border-color)]">${formatId(row.overallIdentityVsHPV16)}</td>
            <td class="px-5 py-4 border-b border-[var(--border-color)]">${formatId(row.tadIdentity)}</td>
            <td class="px-5 py-4 border-b border-[var(--border-color)]">${formatId(row.hingeIdentity)}</td>
            <td class="px-5 py-4 border-b border-[var(--border-color)]">${formatId(row.dbdIdentity)}</td>
        `;
        tbody.appendChild(tr);
    });
}

function handleSort(column) {
    if (currentSort.column === column) {
        currentSort.asc = !currentSort.asc;
    } else {
        currentSort.column = column;
        currentSort.asc = true;
    }

    tableData.sort((a, b) => {
        let valA = a[column];
        let valB = b[column];

        if (column === 'genotype') {
            valA = parseInt(valA) || 0;
            valB = parseInt(valB) || 0;
        }

        if (valA === null) return 1;
        if (valB === null) return -1;

        if (valA < valB) return currentSort.asc ? -1 : 1;
        if (valA > valB) return currentSort.asc ? 1 : -1;
        return 0;
    });

    renderTable(tableData);
}

document.querySelectorAll('th[data-sort]').forEach(th => {
    th.addEventListener('click', () => handleSort(th.dataset.sort));
});

document.getElementById('searchInput').addEventListener('input', (e) => {
    const term = e.target.value.toLowerCase();
    tableData = rawData.filter(row =>
        row.genotype.toLowerCase().includes(term) ||
        row.riskLevel.toLowerCase().includes(term)
    );
    renderTable(tableData);
});

// Initial render
renderTable(tableData);
  </script>
</SiteLayout>
