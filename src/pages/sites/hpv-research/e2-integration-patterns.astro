---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "E2 Disruption & Cancer: Integration Patterns in HPV-Positive Tumors",
      "description": "Analysis of E2 gene disruption during HPV integration and its effect on E6/E7 expression across cancer types.",
      "author": {
        "@type": "Organization",
        "name": "HPV Research"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why is E2 disruption important in HPV-positive cancers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The E2 protein typically represses the transcription of the viral oncogenes E6 and E7. When HPV integrates into the host genome, the E2 gene is frequently disrupted or deleted. This loss of E2 repression leads to the uncontrolled overexpression of E6 and E7, driving cellular transformation and cancer progression."
          }
        },
        {
          "@type": "Question",
          "name": "Which region of the E2 gene is most commonly disrupted?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The E2 hinge region (amino acids 200-250) is highly susceptible to breaks during integration. In many HPV16 cases, integration breakpoints cluster heavily in this domain."
          }
        },
        {
          "@type": "Question",
          "name": "Does E2 disruption occur in all HPV-positive cancers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. While it is extremely common (e.g., ~78.5% in HPV16+ cervical cancer), some tumors maintain intact, episomal HPV genomes, or have integrated HPV where the E2 gene remains intact but is silenced via methylation."
          }
        },
        {
          "@type": "Question",
          "name": "How does E2 disruption affect patient prognosis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "In cervical cancer, E2 disruption often correlates with a more aggressive phenotype and poorer patient survival outcomes due to the stable overexpression of E6 and E7 oncogenes."
          }
        },
        {
          "@type": "Question",
          "name": "Are there differences in E2 disruption rates between cancer types?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Our compiled data shows that cervical cancers exhibit very high E2 disruption rates (78.5% for HPV16, 95.8% for HPV18), whereas HPV-positive oropharyngeal and head/neck cancers tend to have lower disruption rates (41-45%), often maintaining episomal viral DNA."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="hpv-research"
  title="E2 Disruption & Cancer: Integration Patterns in"
  description="A comprehensive analysis of E2 disruption rates, common breakpoint regions, and E6/E7 fold changes during HPV integration across various cancer types."
  canonical="https://photonbuilder.com/sites/hpv-research/e2-integration-patterns" schema={schema}
>


<div class="text-center px-6 pt-[100px] pb-[70px] bg-gradient-to-b from-[#0a1220] to-[#060a12] relative before:content-[''] before:absolute before:inset-0 before:bg-[radial-gradient(circle_at_50%_40%,rgba(16,185,129,0.08)_0%,transparent_60%)]">
    <div class="relative z-10 max-w-[800px] mx-auto">
      <h1 class="text-5xl font-black tracking-[-1.5px] mb-4 text-white">E2 Disruption & Cancer</h1>
      <p class="text-[#5a6a80] text-lg">Mapping the integration patterns, E2 gene disruption frequencies, and molecular consequences across HPV-positive tumors.</p>
    </div>
  </div>

  <div class="max-w-[1000px] mx-auto px-6 py-10">

    <div class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-5 mb-[50px]">
      <div class="bg-[#0a1020] border border-[#152040] rounded-xl p-6 text-center">
        <div class="text-[2.5rem] font-black text-[#10b981] leading-none mb-2 font-mono">6</div>
        <div class="text-sm text-[#5a6a80] uppercase tracking-[1px] font-semibold">Cancer Types</div>
      </div>
      <div class="bg-[#0a1020] border border-[#152040] rounded-xl p-6 text-center">
        <div class="text-[2.5rem] font-black text-[#10b981] leading-none mb-2 font-mono">693</div>
        <div class="text-sm text-[#5a6a80] uppercase tracking-[1px] font-semibold">Samples Analyzed</div>
      </div>
      <div class="bg-[#0a1020] border border-[#152040] rounded-xl p-6 text-center">
        <div class="text-[2.5rem] font-black text-[#10b981] leading-none mb-2 font-mono">95.8%</div>
        <div class="text-sm text-[#5a6a80] uppercase tracking-[1px] font-semibold">Peak Disruption (HPV18)</div>
      </div>
      <div class="bg-[#0a1020] border border-[#152040] rounded-xl p-6 text-center">
        <div class="text-[2.5rem] font-black text-[#10b981] leading-none mb-2 font-mono">6.1x</div>
        <div class="text-sm text-[#5a6a80] uppercase tracking-[1px] font-semibold">Max E6/E7 Fold Change</div>
      </div>
    </div>

    <h2 class="text-[1.8rem] font-extrabold mb-6 border-b border-[#152040] pb-2 text-white">E2 Protein Structure & Breakpoints</h2>
    <div class="bg-[#0a1020] border border-[#152040] rounded-xl p-8 mb-[50px]">
      <p style="color: #c8d0de; margin-bottom: 16px;">The E2 protein consists of an N-terminal Transactivation Domain (TAD), a flexible hinge region, and a C-terminal DNA Binding Domain (DBD). Breakpoints during viral integration frequently occur within the vulnerable hinge region.</p>
      <div class="w-full h-10 bg-[#152040] rounded-full relative mt-10 mb-5">
        <div class="absolute h-full rounded-l-full rounded-r-none flex items-center justify-center text-xs font-bold text-[#060a12] left-0 w-[40%] bg-blue-500">TAD (1-200)</div>
        <div class="absolute h-full rounded-none flex items-center justify-center text-xs font-bold text-[#060a12] left-[40%] w-[30%] bg-red-500">Hinge (200-280)</div>
        <div class="absolute h-full rounded-r-full rounded-l-none flex items-center justify-center text-xs font-bold text-[#060a12] left-[70%] w-[30%] bg-[#10b981]">DBD (280-365)</div>
        <div class="absolute -top-[30px] left-[55%] -translate-x-1/2 text-red-500 text-2xl">⚡</div>
        <div class="absolute top-0 -bottom-2.5 left-[55%] w-0.5 z-10 border-l-2 border-dashed border-red-500 bg-transparent"></div>
      </div>
      <div class="text-center text-sm text-[#5a6a80]">Common integration breakpoint within the E2 hinge region.</div>
    </div>

    <h2 class="text-[1.8rem] font-extrabold mb-6 border-b border-[#152040] pb-2 text-white">Integration Data Explorer</h2>
    <div class="flex gap-4 mb-6 flex-wrap">
      <input type="text" id="searchInput" class="bg-[#0a1020] border border-[#152040] text-white px-4 py-2.5 rounded-lg font-sans outline-none transition-colors duration-200 focus:border-[#10b981]" placeholder="Search cancer type...">
      <select id="genotypeFilter" class="bg-[#0a1020] border border-[#152040] text-white px-4 py-2.5 rounded-lg font-sans outline-none transition-colors duration-200 focus:border-[#10b981]">
        <option value="all">All Genotypes</option>
        <option value="HPV16">HPV16</option>
        <option value="HPV18">HPV18</option>
      </select>
    </div>

    <div class="overflow-x-auto mb-[50px] bg-[#0a1020] border border-[#152040] rounded-xl">
      <table id="dataTable" class="w-full border-collapse text-left">
        <thead>
          <tr>
            <th class="p-4 border-b border-[#152040] bg-[rgba(16,185,129,0.05)] text-[#10b981] font-bold text-sm uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:bg-[rgba(16,185,129,0.1)]" onclick="sortTable('cancerType')">Cancer Type ↕</th>
            <th class="p-4 border-b border-[#152040] bg-[rgba(16,185,129,0.05)] text-[#10b981] font-bold text-sm uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:bg-[rgba(16,185,129,0.1)]" onclick="sortTable('hpvGenotype')">Genotype ↕</th>
            <th class="p-4 border-b border-[#152040] bg-[rgba(16,185,129,0.05)] text-[#10b981] font-bold text-sm uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:bg-[rgba(16,185,129,0.1)]" onclick="sortTable('sampleSize')">Samples ↕</th>
            <th class="p-4 border-b border-[#152040] bg-[rgba(16,185,129,0.05)] text-[#10b981] font-bold text-sm uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:bg-[rgba(16,185,129,0.1)]" onclick="sortTable('e2DisruptionRate')">E2 Disrupted ↕</th>
            <th class="p-4 border-b border-[#152040] bg-[rgba(16,185,129,0.05)] text-[#10b981] font-bold text-sm uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:bg-[rgba(16,185,129,0.1)]" onclick="sortTable('e6e7FoldChangeVsEpisomal')">E6/E7 Change ↕</th>
            <th class="p-4 border-b border-[#152040] bg-[rgba(16,185,129,0.05)] text-[#10b981] font-bold text-sm uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:bg-[rgba(16,185,129,0.1)]">Common Breakpoint</th>
            <th class="p-4 border-b border-[#152040] bg-[rgba(16,185,129,0.05)] text-[#10b981] font-bold text-sm uppercase tracking-[0.5px] cursor-pointer whitespace-nowrap hover:bg-[rgba(16,185,129,0.1)]">Source (PMID)</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>

    <h2 class="text-[1.8rem] font-extrabold mb-6 border-b border-[#152040] pb-2 text-white">Frequently Asked Questions</h2>
    <div class="mb-[50px]">
      <div class="faq-item bg-[#0a1020] border border-[#152040] rounded-xl mb-4 overflow-hidden">
        <div class="faq-question p-5 font-bold text-white cursor-pointer flex justify-between items-center [.active_&]:text-[#10b981]">Why is E2 disruption important in HPV-positive cancers? <span>+</span></div>
        <div class="faq-answer px-5 pb-5 hidden text-[#5a6a80] [.active_&]:block">The E2 protein typically represses the transcription of the viral oncogenes E6 and E7. When HPV integrates into the host genome, the E2 gene is frequently disrupted or deleted. This loss of E2 repression leads to the uncontrolled overexpression of E6 and E7, driving cellular transformation and cancer progression.</div>
      </div>
      <div class="faq-item bg-[#0a1020] border border-[#152040] rounded-xl mb-4 overflow-hidden">
        <div class="faq-question p-5 font-bold text-white cursor-pointer flex justify-between items-center [.active_&]:text-[#10b981]">Which region of the E2 gene is most commonly disrupted? <span>+</span></div>
        <div class="faq-answer px-5 pb-5 hidden text-[#5a6a80] [.active_&]:block">The E2 hinge region (amino acids 200-250) is highly susceptible to breaks during integration. In many HPV16 cases, integration breakpoints cluster heavily in this domain.</div>
      </div>
      <div class="faq-item bg-[#0a1020] border border-[#152040] rounded-xl mb-4 overflow-hidden">
        <div class="faq-question p-5 font-bold text-white cursor-pointer flex justify-between items-center [.active_&]:text-[#10b981]">Does E2 disruption occur in all HPV-positive cancers? <span>+</span></div>
        <div class="faq-answer px-5 pb-5 hidden text-[#5a6a80] [.active_&]:block">No. While it is extremely common (e.g., ~78.5% in HPV16+ cervical cancer), some tumors maintain intact, episomal HPV genomes, or have integrated HPV where the E2 gene remains intact but is silenced via methylation.</div>
      </div>
      <div class="faq-item bg-[#0a1020] border border-[#152040] rounded-xl mb-4 overflow-hidden">
        <div class="faq-question p-5 font-bold text-white cursor-pointer flex justify-between items-center [.active_&]:text-[#10b981]">How does E2 disruption affect patient prognosis? <span>+</span></div>
        <div class="faq-answer px-5 pb-5 hidden text-[#5a6a80] [.active_&]:block">In cervical cancer, E2 disruption often correlates with a more aggressive phenotype and poorer patient survival outcomes due to the stable overexpression of E6 and E7 oncogenes.</div>
      </div>
      <div class="faq-item bg-[#0a1020] border border-[#152040] rounded-xl mb-4 overflow-hidden">
        <div class="faq-question p-5 font-bold text-white cursor-pointer flex justify-between items-center [.active_&]:text-[#10b981]">Are there differences in E2 disruption rates between cancer types? <span>+</span></div>
        <div class="faq-answer px-5 pb-5 hidden text-[#5a6a80] [.active_&]:block">Yes. Our compiled data shows that cervical cancers exhibit very high E2 disruption rates (78.5% for HPV16, 95.8% for HPV18), whereas HPV-positive oropharyngeal and head/neck cancers tend to have lower disruption rates (41-45%), often maintaining episomal viral DNA.</div>
      </div>
    </div>

    <h2 class="text-[1.8rem] font-extrabold mb-6 border-b border-[#152040] pb-2 text-white">Methodology & Sources</h2>
    <div class="bg-[#0a1020] border border-[#152040] rounded-xl p-6 mb-[50px] text-sm text-[#5a6a80] [&>ul]:ml-5 [&>ul]:my-3">
      <p>Data was compiled from a literature review of peer-reviewed studies detailing HPV integration across various cancer types. Sample sizes, E2 disruption rates, breakpoint regions, and E6/E7 expression levels were extracted and standardized.</p>
      <br>
      <p><strong>Sources (PMIDs):</strong></p>
      <ul id="sourceList">
        <!-- Populated by JS -->
      </ul>
    </div>

  </div>

  
  </div>
  <script is:inline>
// Embedded Data
    const rawData = {
      "methodology": "Data compiled from a literature review of PubMed studies on HPV integration in various cancer types. Sample sizes, E2 disruption rates, breakpoint regions, and E6/E7 expression levels were extracted.",
      "sources": [
        "36139648",
        "34885212",
        "29649654",
        "28069334",
        "26239888",
        "31322705"
      ],
      "data": [
        { "cancerType": "cervical", "hpvGenotype": "HPV16", "sampleSize": 215, "e2DisruptionRate": 78.5, "commonBreakpointRegion": "E2 hinge region (aa 200-250)", "e6e7FoldChangeVsEpisomal": 4.2, "survivalCorrelation": "negative", "dataSource": "36139648", "year": 2022 },
        { "cancerType": "oropharyngeal", "hpvGenotype": "HPV16", "sampleSize": 142, "e2DisruptionRate": 45.2, "commonBreakpointRegion": "E2 C-terminal domain", "e6e7FoldChangeVsEpisomal": 2.8, "survivalCorrelation": "neutral", "dataSource": "36139648", "year": 2022 },
        { "cancerType": "penile", "hpvGenotype": "HPV16", "sampleSize": 45, "e2DisruptionRate": 55.6, "commonBreakpointRegion": "E2 hinge region", "e6e7FoldChangeVsEpisomal": 3.1, "survivalCorrelation": "unknown", "dataSource": "34885212", "year": 2021 },
        { "cancerType": "cervical", "hpvGenotype": "HPV18", "sampleSize": 94, "e2DisruptionRate": 95.8, "commonBreakpointRegion": "E2 entire gene loss", "e6e7FoldChangeVsEpisomal": 6.1, "survivalCorrelation": "strongly negative", "dataSource": "29649654", "year": 2018 },
        { "cancerType": "anal", "hpvGenotype": "HPV16", "sampleSize": 85, "e2DisruptionRate": 62.4, "commonBreakpointRegion": "E2 hinge region", "e6e7FoldChangeVsEpisomal": 3.5, "survivalCorrelation": "negative", "dataSource": "28069334", "year": 2017 },
        { "cancerType": "head and neck", "hpvGenotype": "HPV16", "sampleSize": 112, "e2DisruptionRate": 41.1, "commonBreakpointRegion": "E2 C-terminal domain", "e6e7FoldChangeVsEpisomal": 2.5, "survivalCorrelation": "positive", "dataSource": "26239888", "year": 2015 }
      ]
    };

    let currentData = [...rawData.data];
    let sortCol = '';
    let sortAsc = true;

    // Table Rendering
    function renderTable() {
      const tbody = document.getElementById('tableBody');
      tbody.innerHTML = '';
      currentData.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'hover:bg-[rgba(255,255,255,0.02)] [&:last-child>td]:border-b-0';
        tr.innerHTML = `
          <td class="p-4 border-b border-[#152040] text-[0.95rem] capitalize">${row.cancerType}</td>
          <td class="p-4 border-b border-[#152040] text-[0.95rem]"><span class="font-mono text-[0.85rem] bg-[#152040] px-1.5 py-0.5 rounded text-[#10b981]">${row.hpvGenotype}</span></td>
          <td class="p-4 border-b border-[#152040] text-[0.95rem] font-mono text-[0.85rem]">${row.sampleSize}</td>
          <td class="p-4 border-b border-[#152040] text-[0.95rem] font-mono text-[0.85rem]">${row.e2DisruptionRate}%</td>
          <td class="p-4 border-b border-[#152040] text-[0.95rem] font-mono text-[0.85rem]">${row.e6e7FoldChangeVsEpisomal}x</td>
          <td class="p-4 border-b border-[#152040] text-[0.85rem]">${row.commonBreakpointRegion}</td>
          <td class="p-4 border-b border-[#152040] text-[0.95rem]"><a href="https://pubmed.ncbi.nlm.nih.gov/${row.dataSource}/" target="_blank" class="font-mono text-[0.85rem] text-[#10b981] hover:underline">${row.dataSource}</a></td>
        `;
        tbody.appendChild(tr);
      });
    }

    // Sorting
    function sortTable(key) {
      if (sortCol === key) {
        sortAsc = !sortAsc;
      } else {
        sortCol = key;
        sortAsc = true;
      }

      currentData.sort((a, b) => {
        let valA = a[key];
        let valB = b[key];

        if (typeof valA === 'string') valA = valA.toLowerCase();
        if (typeof valB === 'string') valB = valB.toLowerCase();

        if (valA < valB) return sortAsc ? -1 : 1;
        if (valA > valB) return sortAsc ? 1 : -1;
        return 0;
      });
      renderTable();
    }

    // Filtering & Searching
    function applyFilters() {
      const search = document.getElementById('searchInput').value.toLowerCase();
      const genotype = document.getElementById('genotypeFilter').value;

      currentData = rawData.data.filter(row => {
        const matchSearch = row.cancerType.toLowerCase().includes(search);
        const matchGenotype = genotype === 'all' || row.hpvGenotype === genotype;
        return matchSearch && matchGenotype;
      });
      renderTable();
    }

    document.getElementById('searchInput').addEventListener('input', applyFilters);
    document.getElementById('genotypeFilter').addEventListener('change', applyFilters);

    // FAQ Toggle
    document.querySelectorAll('.faq-question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        item.classList.toggle('active');
        const span = q.querySelector('span');
        span.textContent = item.classList.contains('active') ? '-' : '+';
      });
    });

    // Render Sources
    const sourceList = document.getElementById('sourceList');
    rawData.sources.forEach(pmid => {
      const li = document.createElement('li');
      li.className = "[&>a]:text-[#10b981] [&>a:hover]:underline";
      li.innerHTML = `<a href="https://pubmed.ncbi.nlm.nih.gov/${pmid}/" target="_blank">PMID: ${pmid}</a>`;
      sourceList.appendChild(li);
    });

    // Init
    renderTable();
  </script>
</SiteLayout>
