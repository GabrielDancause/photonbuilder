      {
        "@type": "Question",
        "name": "Why is the HPV vaccine important in Africa?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Africa bears the highest regional burden of cervical cancer in the world, with extremely high mortality rates due to a lack of routine screening and treatment infrastructure. The HPV vaccine is the most effective tool to prevent these deaths."
        }
      },
      {
        "@type": "Question",
        "name": "What role does Gavi play in Africa's HPV vaccination?",
        "acceptedAnswer": {
