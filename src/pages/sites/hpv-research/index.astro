---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "HPV Research — Human Papillomavirus Data & Analysis",
  "url": "https://hpvresearch.com/",
  "description": "Open-access research on Human Papillomavirus (HPV). E2 protein analysis, genotype data, epidemiology, and therapeutic targets."
};
---

<SiteLayout
  site="hpv-research"
  title="HPV Research — Human Papillomavirus Data & Analysis"
  description="Open-access research on Human Papillomavirus (HPV). E2 protein analysis, genotype data, epidemiology, and therapeutic targets."
  canonical="https://hpvresearch.com/"
  schema={schema}
>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Open-Access Virology Research</div>
      <h1>HPV Research</h1>
      <p>Data-driven analysis of Human Papillomavirus — protein structures, genotype classification, epidemiology, and therapeutic targets. Open access, no paywalls.</p>
    </div>
  </div>

  <!-- Studies -->
  <div class="section-container" id="studies">
    <div class="section-header">
      <span class="section-tag">RESEARCH</span>
      <h2 class="section-title">Studies</h2>
      <p class="section-sub">Original research and data compilation.</p>
    </div>
    <div class="studies-grid">
      <a class="study-card" href="/e2-protein-overview">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">9</span>
          <span class="stat-label">genotypes structurally analyzed</span>
        </div>
        <h3 class="study-title">HPV E2 Protein: Structure, Function &amp; Role in Viral Lifecycle</h3>
        <p class="study-subtitle">9 genotypes analyzed</p>
        <p class="study-desc">Comprehensive analysis of the E2 protein across HPV genotypes showing that in high-risk strains, disruption of E2 upon integration leads to unchecked oncogene expression driving carcinogenesis.</p>
      </a>
      <a class="study-card" href="/e2-genotype-comparison">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">14</span>
          <span class="stat-label">genotypes compared</span>
        </div>
        <h3 class="study-title">E2 Protein Sequence Comparison Across HPV Genotypes</h3>
        <p class="study-subtitle">Cross-strain structural analysis</p>
        <p class="study-desc">Side-by-side comparison of E2 protein sequences and structural features across high-risk and low-risk HPV genotypes, revealing conservation patterns linked to oncogenic potential.</p>
      </a>
      <a class="study-card" href="/e2-integration-patterns">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">70%</span>
          <span class="stat-label">of high-risk HPV cancers show E2 disruption</span>
        </div>
        <h3 class="study-title">E2 Disruption &amp; Cancer: Integration Patterns in HPV-Positive Tumors</h3>
        <p class="study-subtitle">Integration mechanisms mapped</p>
        <p class="study-desc">How HPV E2 disruption during viral genome integration into host DNA drives progression from infection to cervical cancer.</p>
      </a>
      <a class="study-card" href="/e2-therapeutic-targets">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">12</span>
          <span class="stat-label">therapeutic approaches analyzed</span>
        </div>
        <h3 class="study-title">E2 as Therapeutic Target: Drug Discovery &amp; Peptide Approaches</h3>
        <p class="study-subtitle">Therapeutic strategies reviewed</p>
        <p class="study-desc">Mapping therapeutic approaches that leverage E2 protein restoration to suppress HPV-driven oncogenesis, from small molecules to peptide vaccines.</p>
      </a>
    </div>
  </div>

  <!-- Disclaimer -->
  <div class="disclaimer">This site provides scientific data for educational and research purposes only. It is not medical advice. Consult a healthcare professional for any medical decisions.</div>
</SiteLayout>

<style>
  .hero { text-align:center; padding:100px 24px 70px; background:linear-gradient(180deg, #0a1220, #060a12); position:relative }
  .hero::before { content:""; position:absolute; inset:0; background:radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--accent-color) 8%, transparent) 0%, transparent 60%) }
  .hero-content { position:relative; z-index:1 }
  .hero .tagline { color:var(--accent-color); font-size:.85rem; font-weight:700; letter-spacing:3px; text-transform:uppercase; margin-bottom:16px }
  .hero h1 { font-size:3rem; font-weight:900; letter-spacing:-1.5px; margin-bottom:8px; color:#fff }
  .hero p { color:#5a6a80; font-size:1.05rem; max-width:560px; margin:0 auto; line-height:1.6 }

  .section-container { max-width:960px; margin:0 auto; padding:0 24px }
  .section-header { text-align:center; margin-bottom:32px; padding-top:20px }
  .section-tag { display:inline-block; background:#0d1a2e; color:var(--accent-color); font-size:.7rem; font-weight:800; padding:4px 14px; border-radius:20px; letter-spacing:1px; margin-bottom:12px }
  .section-title { font-size:1.8rem; font-weight:900; color:#fff; margin-bottom:6px }
  .section-sub { color:#4a5568; font-size:.9rem }

  .studies-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(290px, 1fr)); gap:18px; margin-bottom:60px }
  .study-card { background:linear-gradient(135deg, #0a1020, #0d1428); border:1px solid #152040; border-radius:16px; padding:28px 24px; text-decoration:none; color:inherit; display:block; transition:border-color .3s, transform .2s }
  .study-card:hover { border-color:var(--accent-color); transform:translateY(-2px) }
  .study-tag { display:inline-block; background:color-mix(in srgb, var(--accent-color) 10%, transparent); color:var(--accent-color); font-size:.58rem; font-weight:800; padding:3px 10px; border-radius:12px; letter-spacing:.8px; margin-bottom:14px }
  .stat-number { display:block; font-size:2.2rem; font-weight:900; color:var(--accent-color); line-height:1 }
  .stat-label { display:block; font-size:.78rem; color:#4a5568; margin-top:4px }
  .study-title { font-size:1.05rem; font-weight:800; color:#e0e8f0; margin-bottom:4px; margin-top:14px }
  .study-subtitle { font-size:.75rem; color:var(--accent-color); margin-bottom:10px; font-weight:600 }
  .study-desc { font-size:.82rem; color:#5a6a80; line-height:1.6 }

  .disclaimer { max-width:600px; margin:12px auto 0; color:#1e2a3a; font-size:.68rem; line-height:1.5; text-align:center; padding:50px 24px }

  @media (max-width: 600px) {
    .hero h1 { font-size:2.2rem }
    .studies-grid { grid-template-columns:1fr }
  }
</style>
