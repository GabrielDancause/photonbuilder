---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "HPV Research — Human Papillomavirus Data & Analysis",
  "url": "https://hpvresearch.com/",
  "description": "Open-access research on Human Papillomavirus (HPV). E2 protein analysis, genotype data, epidemiology, and therapeutic targets."
};
---

<SiteLayout
  site="hpv-research"
  title="HPV Research — Human Papillomavirus Data & Analysis"
  description="Open-access research on Human Papillomavirus (HPV). E2 protein analysis, genotype data, epidemiology, and therapeutic targets."
  canonical="https://hpvresearch.com/"
  schema={schema}
>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Open-Access Virology Research</div>
      <h1>HPV Research</h1>
      <p>Data-driven analysis of Human Papillomavirus — protein structures, genotype classification, epidemiology, and therapeutic targets. Open access, no paywalls.</p>
    </div>
  </div>

  <!-- Guides -->
  <div class="section-container" id="guides">
    <div class="section-header">
      <span class="section-tag">GUIDES</span>
      <h2 class="section-title">Comprehensive Guides</h2>
      <p class="section-sub">Evidence-based resources on HPV prevention.</p>
    </div>
    <div class="studies-grid">
      <a class="study-card" href="/sites/hpv-research/hpv-prevention-guide">
        <span class="study-tag">PILLAR GUIDE</span>
        <div>
          <span class="stat-number">200+</span>
          <span class="stat-label">HPV types explained</span>
        </div>
        <h3 class="study-title">The Comprehensive Guide to HPV Prevention</h3>
        <p class="study-subtitle">Transmission, Vaccination &amp; Screening</p>
        <p class="study-desc">An evidence-based pillar guide covering the virology of HPV, how it spreads, the effectiveness of the Gardasil 9 vaccine, and the path from infection to natural clearance.</p>
      </a>
    </div>
  </div>

  <!-- Tools -->
  <div class="section-container" id="tools">
    <div class="section-header">
      <span class="section-tag">TOOLS & REFERENCES</span>
      <h2 class="section-title">Interactive Resources</h2>
      <p class="section-sub">Assessments, data visualization, and specific topics.</p>
    </div>
    <div class="studies-grid">
      <a class="study-card" href="/sites/hpv-research/hpv-vaccine-guide">
        <span class="study-tag">CLINICAL DATA</span>
        <div>
          <span class="stat-number">9</span>
          <span class="stat-label">genotypes targeted</span>
        </div>
        <h3 class="study-title">HPV Vaccine Guide: Gardasil 9</h3>
        <p class="study-subtitle">Efficacy &amp; Safety Profile</p>
        <p class="study-desc">Deep dive into the 9-valent vaccine, covering dosing schedules by age, >90% efficacy data in preventing precancers, and the critical importance of male vaccination.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/hpv-screening-guide">
        <span class="study-tag">PROTOCOLS</span>
        <div>
          <span class="stat-number">ASCUS</span>
          <span class="stat-label">to HSIL explained</span>
        </div>
        <h3 class="study-title">HPV Screening &amp; Result Interpretation</h3>
        <p class="study-subtitle">Pap Smears vs HPV Tests</p>
        <p class="study-desc">Guide to cervical cancer screening protocols, understanding abnormal results, and an interactive tool for recommended screening intervals based on age.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/hpv-types-reference">
        <span class="study-tag">INTERACTIVE</span>
        <div>
          <span class="stat-number">16/18</span>
          <span class="stat-label">high-risk types highlighted</span>
        </div>
        <h3 class="study-title">HPV Types Reference Database</h3>
        <p class="study-subtitle">High-Risk vs. Low-Risk</p>
        <p class="study-desc">Browse HPV genotypes by oncogenic potential. Explore cancer associations for types 16, 18, 31, 33, 45, 52, 58 and low-risk types 6 and 11.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/hpv-and-cancer-guide">
        <span class="study-tag">PATHOLOGY</span>
        <div>
          <span class="stat-number">10-20</span>
          <span class="stat-label">years progression timeline</span>
        </div>
        <h3 class="study-title">HPV and Cancer Mechanisms</h3>
        <p class="study-subtitle">Cervical, Oropharyngeal, Anal</p>
        <p class="study-desc">Understanding how persistent high-risk HPV infections disrupt tumor suppressor proteins (p53/pRb) and the long timeline from infection to invasive malignancy.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/hpv-risk-assessment">
        <span class="study-tag">TOOL</span>
        <div>
          <span class="stat-number">Risk</span>
          <span class="stat-label">assessment profile</span>
        </div>
        <h3 class="study-title">Personalized HPV Risk Assessment</h3>
        <p class="study-subtitle">Interactive Questionnaire</p>
        <p class="study-desc">An anonymous tool to evaluate your general risk profile for HPV infection and related complications based on vaccination, screening history, and cofactors like smoking.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/hpv-natural-history">
        <span class="study-tag">VIROLOGY</span>
        <div>
          <span class="stat-number">90%</span>
          <span class="stat-label">clear within 2 years</span>
        </div>
        <h3 class="study-title">Natural History of HPV Infection</h3>
        <p class="study-subtitle">Viral Lifecycle &amp; Clearance</p>
        <p class="study-desc">Explore how HPV infects the basal epithelium, evades the immune system, and the critical difference between viral clearance and oncogenic persistence.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/hpv-global-statistics">
        <span class="study-tag">EPIDEMIOLOGY</span>
        <div>
          <span class="stat-number">90-70-90</span>
          <span class="stat-label">WHO elimination targets</span>
        </div>
        <h3 class="study-title">Global HPV Statistics &amp; Prevalence</h3>
        <p class="study-subtitle">Interactive Data Visualization</p>
        <p class="study-desc">Examine the stark global disparities in HPV prevalence, vaccination coverage rates, and the disproportionate burden of cervical cancer mortality in LMICs.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/hpv-for-men-guide">
        <span class="study-tag">DEMOGRAPHICS</span>
        <div>
          <span class="stat-number">4x</span>
          <span class="stat-label">higher risk of oropharyngeal cancer</span>
        </div>
        <h3 class="study-title">HPV in Men: The Rising Threat</h3>
        <p class="study-subtitle">Oropharyngeal Cancer &amp; Screening</p>
        <p class="study-desc">Why HPV matters for men. Explaining the rapid rise in head and neck cancers, the critical need for male vaccination, and the limitations of current screening.</p>
      </a>
    </div>
  </div>

  <!-- Studies -->
  <div class="section-container" id="studies">
    <div class="section-header">
      <span class="section-tag">RESEARCH</span>
      <h2 class="section-title">Studies</h2>
      <p class="section-sub">Original research and data compilation.</p>
    </div>
    <div class="studies-grid">
      <a class="study-card" href="/sites/hpv-research/e2-protein-overview">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">9</span>
          <span class="stat-label">genotypes structurally analyzed</span>
        </div>
        <h3 class="study-title">HPV E2 Protein: Structure, Function &amp; Role in Viral Lifecycle</h3>
        <p class="study-subtitle">9 genotypes analyzed</p>
        <p class="study-desc">Comprehensive analysis of the E2 protein across HPV genotypes showing that in high-risk strains, disruption of E2 upon integration leads to unchecked oncogene expression driving carcinogenesis.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/e2-genotype-comparison">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">14</span>
          <span class="stat-label">genotypes compared</span>
        </div>
        <h3 class="study-title">E2 Protein Sequence Comparison Across HPV Genotypes</h3>
        <p class="study-subtitle">Cross-strain structural analysis</p>
        <p class="study-desc">Side-by-side comparison of E2 protein sequences and structural features across high-risk and low-risk HPV genotypes, revealing conservation patterns linked to oncogenic potential.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/e2-integration-patterns">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">70%</span>
          <span class="stat-label">of high-risk HPV cancers show E2 disruption</span>
        </div>
        <h3 class="study-title">E2 Disruption &amp; Cancer: Integration Patterns in HPV-Positive Tumors</h3>
        <p class="study-subtitle">Integration mechanisms mapped</p>
        <p class="study-desc">How HPV E2 disruption during viral genome integration into host DNA drives progression from infection to cervical cancer.</p>
      </a>
      <a class="study-card" href="/sites/hpv-research/e2-therapeutic-targets">
        <span class="study-tag">ORIGINAL RESEARCH</span>
        <div>
          <span class="stat-number">12</span>
          <span class="stat-label">therapeutic approaches analyzed</span>
        </div>
        <h3 class="study-title">E2 as Therapeutic Target: Drug Discovery &amp; Peptide Approaches</h3>
        <p class="study-subtitle">Therapeutic strategies reviewed</p>
        <p class="study-desc">Mapping therapeutic approaches that leverage E2 protein restoration to suppress HPV-driven oncogenesis, from small molecules to peptide vaccines.</p>
      </a>
    </div>
  </div>

  <!-- Disclaimer -->
  <div class="disclaimer">This site provides scientific data for educational and research purposes only. It is not medical advice. Consult a healthcare professional for any medical decisions.</div>
</SiteLayout>

<style>
  .hero { text-align:center; padding:100px 24px 70px; background:linear-gradient(180deg, #0a1220, #060a12); position:relative }
  .hero::before { content:""; position:absolute; inset:0; background:radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--accent-color) 8%, transparent) 0%, transparent 60%) }
  .hero-content { position:relative; z-index:1 }
  .hero .tagline { color:var(--accent-color); font-size:.85rem; font-weight:700; letter-spacing:3px; text-transform:uppercase; margin-bottom:16px }
  .hero h1 { font-size:3rem; font-weight:900; letter-spacing:-1.5px; margin-bottom:8px; color:#fff }
  .hero p { color:#5a6a80; font-size:1.05rem; max-width:560px; margin:0 auto; line-height:1.6 }

  .section-container { max-width:960px; margin:0 auto; padding:0 24px }
  .section-header { text-align:center; margin-bottom:32px; padding-top:20px }
  .section-tag { display:inline-block; background:#0d1a2e; color:var(--accent-color); font-size:.7rem; font-weight:800; padding:4px 14px; border-radius:20px; letter-spacing:1px; margin-bottom:12px }
  .section-title { font-size:1.8rem; font-weight:900; color:#fff; margin-bottom:6px }
  .section-sub { color:#4a5568; font-size:.9rem }

  .studies-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(290px, 1fr)); gap:18px; margin-bottom:60px }
  .study-card { background:linear-gradient(135deg, #0a1020, #0d1428); border:1px solid #152040; border-radius:16px; padding:28px 24px; text-decoration:none; color:inherit; display:block; transition:border-color .3s, transform .2s }
  .study-card:hover { border-color:var(--accent-color); transform:translateY(-2px) }
  .study-tag { display:inline-block; background:color-mix(in srgb, var(--accent-color) 10%, transparent); color:var(--accent-color); font-size:.58rem; font-weight:800; padding:3px 10px; border-radius:12px; letter-spacing:.8px; margin-bottom:14px }
  .stat-number { display:block; font-size:2.2rem; font-weight:900; color:var(--accent-color); line-height:1 }
  .stat-label { display:block; font-size:.78rem; color:#4a5568; margin-top:4px }
  .study-title { font-size:1.05rem; font-weight:800; color:#e0e8f0; margin-bottom:4px; margin-top:14px }
  .study-subtitle { font-size:.75rem; color:var(--accent-color); margin-bottom:10px; font-weight:600 }
  .study-desc { font-size:.82rem; color:#5a6a80; line-height:1.6 }

  .disclaimer { max-width:600px; margin:12px auto 0; color:#1e2a3a; font-size:.68rem; line-height:1.5; text-align:center; padding:50px 24px }

  @media (max-width: 600px) {
    .hero h1 { font-size:2.2rem }
    .studies-grid { grid-template-columns:1fr }
  }
</style>
