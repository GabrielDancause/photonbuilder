---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Meal Prep Ideas for Weight Loss",
    "description": "A complete meal prep guide covering calorie counting, macro ratios, a 7-day meal plan, 20 high-protein recipes, and batch cooking strategies.",
    "url": "https://bodycount.photonbuilder.com/meal-prep-weight-loss",
    "author": {
      "@type": "Organization",
      "name": "BodyCount"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does meal prep stay good in the fridge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most cooked meals will stay safe and fresh in the fridge for 3-4 days when stored in airtight containers."
        }
      },
      {
        "@type": "Question",
        "name": "Is it better to freeze or refrigerate meal prep?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Refrigerate meals you plan to eat within 3-4 days. Freeze meals for longer-term storage (up to 3 months) to prevent spoilage."
        }
      },
      {
        "@type": "Question",
        "name": "How many calories should I eat to lose weight?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on your BMR and activity level. Generally, a deficit of 300-500 calories below your TDEE (Total Daily Energy Expenditure) is recommended for sustainable weight loss."
        }
      },
      {
        "@type": "Question",
        "name": "Do I have to track macros to lose weight?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, calories dictate weight loss. However, tracking macros ensures you get enough protein to preserve muscle and enough fats/carbs for energy and hormone health."
        }
      },
      {
        "@type": "Question",
        "name": "What are the best containers for meal prep?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Glass containers with snap-locking lids are best because they are microwave-safe, don't stain, and don't retain odors like plastic."
        }
      }
    ]
  }
];

const faqs = schema[1].mainEntity;

const recipes = [
  "Chicken Teriyaki with Cauliflower Rice (350 cal, 40g protein)",
  "Turkey Meatballs with Zucchini Noodles (320 cal, 35g protein)",
  "Salmon and Asparagus Foil Packets (400 cal, 35g protein)",
  "Greek Yogurt Chicken Salad (300 cal, 30g protein)",
  "Lean Beef and Broccoli Stir-fry (380 cal, 35g protein)",
  "Shrimp Tacos with Cabbage Slaw (350 cal, 30g protein)",
  "Egg White and Spinach Frittata (250 cal, 25g protein)",
  "Tuna Salad Lettuce Wraps (280 cal, 30g protein)",
  "Grilled Chicken and Quinoa Bowl (400 cal, 40g protein)",
  "Bison Chili (380 cal, 35g protein)",
  "Cottage Cheese and Berries Bowl (250 cal, 25g protein)",
  "Pork Tenderloin with Roasted Carrots (350 cal, 35g protein)",
  "Tofu and Vegetable Skewers (300 cal, 20g protein)",
  "Baked Cod with Sweet Potato Wedges (350 cal, 35g protein)",
  "Turkey Burger with Lettuce Bun (320 cal, 30g protein)",
  "Lentil Soup with Bone Broth (300 cal, 25g protein)",
  "Chicken Fajita Bowls (380 cal, 35g protein)",
  "Stuffed Bell Peppers with Lean Ground Turkey (350 cal, 30g protein)",
  "Overnight Oats with Protein Powder (300 cal, 25g protein)",
  "Edamame and Black Bean Salad (320 cal, 20g protein)"
];

const mealPlanTiers = [
  { name: "1500 Calories", desc: "Aggressive deficit for smaller individuals." },
  { name: "1800 Calories", desc: "Moderate deficit for average individuals or active smaller individuals." },
  { name: "2000 Calories", desc: "Slight deficit for larger or highly active individuals." }
];

---

<SiteLayout
  site="bodycount"
  title="Best Meal Prep Ideas for Weight Loss"
  description="A complete meal prep guide covering calorie counting, macro ratios, a 7-day meal plan, 20 high-protein recipes, and batch cooking strategies."
  canonical="https://bodycount.photonbuilder.com/meal-prep-weight-loss"
  schema={schema}
>
  <div class="page-wrapper">
    <div class="hero-section">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Best Meal Prep Ideas for Weight Loss</h1>
      <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
        Your ultimate guide to shedding fat efficiently with batch cooking, calorie counting, and high-protein recipes.
      </p>
    </div>

    <main class="container">
      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Calorie Counting Basics</h2>
        <div class="category-card" style="margin-bottom: 2rem;">
          <p class="cat-desc" style="font-size: 1rem;">To lose weight, you must be in a caloric deficit. This means consuming fewer calories than your body burns (TDEE). Start by calculating your TDEE using an online calculator, then subtract 300-500 calories. Use a food scale and tracking app like MyFitnessPal or MacroFactor to ensure accuracy.</p>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Macro Ratios for Fat Loss</h2>
        <div class="category-grid">
          <div class="category-card">
            <div class="cat-title">PROTEIN</div>
            <div class="cat-brand">40%</div>
            <div class="cat-desc">Preserves muscle mass and increases satiety.</div>
          </div>
          <div class="category-card">
            <div class="cat-title">FATS</div>
            <div class="cat-brand">30%</div>
            <div class="cat-desc">Essential for hormone regulation.</div>
          </div>
          <div class="category-card">
            <div class="cat-title">CARBS</div>
            <div class="cat-brand">30%</div>
            <div class="cat-desc">Provides energy for workouts.</div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">7-Day Meal Plan Tiers</h2>
        <div class="category-grid">
          {mealPlanTiers.map(tier => (
            <div class="category-card">
              <div class="cat-brand">{tier.name}</div>
              <div class="cat-desc">{tier.desc}</div>
            </div>
          ))}
        </div>
        <div class="category-card" style="margin-bottom: 2rem;">
          <p class="cat-desc" style="font-size: 1rem;">Each day consists of 3 meals and 1-2 snacks. Prioritize hitting your protein goal first, then fill the rest with veggies and healthy fats.</p>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">20 High-Protein Low-Calorie Recipes</h2>
        <div class="category-grid">
          {recipes.map(recipe => (
            <div class="category-card">
              <div class="cat-desc" style="font-size: 1rem; color: var(--text-primary);">{recipe}</div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Batch Cooking Strategy</h2>
        <div class="category-grid">
          <div class="category-card">
            <div class="cat-brand">Proteins</div>
            <div class="cat-desc">Grill or bake chicken breasts, lean beef, or tofu in large batches.</div>
          </div>
          <div class="category-card">
            <div class="cat-brand">Carbs</div>
            <div class="cat-desc">Use a rice cooker for large portions of rice or quinoa. Roast a large pan of potatoes.</div>
          </div>
          <div class="category-card">
            <div class="cat-brand">Veggies</div>
            <div class="cat-desc">Steam or roast vegetables on two baking sheets simultaneously.</div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Grocery List Template</h2>
        <div class="category-grid">
          <div class="category-card">
            <div class="cat-brand">Proteins</div>
            <div class="cat-desc">Chicken breast, ground turkey (93/7), eggs, Greek yogurt, canned tuna.</div>
          </div>
          <div class="category-card">
            <div class="cat-brand">Carbs</div>
            <div class="cat-desc">Oats, sweet potatoes, brown rice, quinoa, low-carb wraps.</div>
          </div>
          <div class="category-card">
            <div class="cat-brand">Fats</div>
            <div class="cat-desc">Olive oil, avocado, almonds, peanut butter.</div>
          </div>
          <div class="category-card">
            <div class="cat-brand">Produce</div>
            <div class="cat-desc">Spinach, broccoli, bell peppers, berries, bananas.</div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Storage and Reheating Tips</h2>
        <div class="category-card" style="margin-bottom: 2rem;">
          <p class="cat-desc" style="font-size: 1rem;">Use high-quality glass containers. Store meals in the fridge for up to 4 days, or freeze them if you're prepping for the whole week. When reheating, sprinkle a little water on rice or pasta to prevent it from drying out in the microwave.</p>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Avoiding Meal Prep Burnout</h2>
        <div class="category-card" style="margin-bottom: 2rem;">
          <p class="cat-desc" style="font-size: 1rem;">Eating the same thing every day gets boring. To avoid burnout, switch up your sauces and seasonings. A basic chicken and rice bowl can become Mexican, Asian, or Mediterranean just by changing the spices and low-calorie condiments.</p>
        </div>
      </section>

      <section class="faq-section">
        <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
        <div class="faq-list">
          {faqs.map((faq: any) => (
            <div class="faq-item">
              <div class="faq-q">{faq.name}</div>
              <div class="faq-a">{faq.acceptedAnswer.text}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>

  <style>
    .page-wrapper {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;

      background-color: var(--bg-color);
      color: var(--text-primary);
      min-height: 100vh;
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Category Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .category-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }

    .cat-title {
      font-size: 0.875rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .cat-brand {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .cat-desc {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
    }

    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>
</SiteLayout>