---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const faqList = [
  {
    question: "Do I need supplements to build muscle?",
    answer: "No, supplements are not strictly necessary. A calorie surplus, sufficient protein intake from whole foods, and progressive overload in your training are the fundamental drivers of muscle growth. Supplements simply offer convenience and a slight performance edge."
  },
  {
    question: "Is creatine safe for my kidneys?",
    answer: "Yes, extensive research shows that creatine monohydrate is safe for healthy individuals and does not cause kidney damage when taken at recommended dosages (3-5g per day)."
  },
  {
    question: "When is the best time to take whey protein?",
    answer: "Total daily protein intake is far more important than timing. However, consuming whey protein within a few hours before or after your workout can help ensure amino acids are available for muscle repair."
  },
  {
    question: "Are BCAAs worth buying?",
    answer: "For most people, no. If you are already consuming enough high-quality protein (like whey, meat, or dairy), you are naturally getting enough BCAAs. They are only potentially useful if training completely fasted or if your diet is severely protein deficient."
  },
  {
    question: "Do testosterone boosters actually work?",
    answer: "Over-the-counter testosterone boosters are generally a waste of money. Most rely on ingredients like Tribulus Terrestris or Fenugreek, which may slightly boost libido but do not increase testosterone levels enough to significantly impact muscle growth."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/best-muscle-supplements"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];

const tier1 = [
  { name: "Creatine Monohydrate", dosing: "3-5g daily", timing: "Anytime", evidence: "A+", sideEffects: "Possible mild bloating or water retention initially.", description: "The most researched and proven supplement for increasing strength, power output, and lean muscle mass." },
  { name: "Whey Protein", dosing: "20-40g per serving", timing: "Pre or Post-workout, or anytime to hit daily goals", evidence: "A+", sideEffects: "Digestive issues if lactose intolerant (isolate is better).", description: "A highly bioavailable and convenient source of high-quality protein to support muscle repair and growth." },
  { name: "Caffeine", dosing: "3-6mg per kg of bodyweight", timing: "30-60 mins pre-workout", evidence: "A", sideEffects: "Jitters, anxiety, insomnia if taken too late.", description: "A powerful stimulant that improves energy, focus, and overall workout performance, allowing you to train harder." }
];

const tier2 = [
  { name: "Beta-Alanine", dosing: "3-6g daily", timing: "Anytime", evidence: "B+", sideEffects: "Harmless tingling sensation (paresthesia).", description: "Buffers lactic acid, potentially improving performance in high-intensity exercise lasting 1-4 minutes." },
  { name: "Citrulline Malate", dosing: "6-8g", timing: "30-60 mins pre-workout", evidence: "B+", sideEffects: "Mild stomach upset in some.", description: "Increases nitric oxide production, improving blood flow, endurance, and 'pump' during workouts." },
  { name: "HMB", dosing: "3g daily", timing: "Pre-workout", evidence: "B-", sideEffects: "None known at recommended doses.", description: "May help prevent muscle breakdown (anti-catabolic), mostly beneficial for beginners or those training fasted." },
  { name: "Ashwagandha", dosing: "300-600mg daily", timing: "Anytime", evidence: "B", sideEffects: "Mild drowsiness, upset stomach.", description: "An adaptogen that may help lower cortisol (stress hormone) and modestly improve strength and testosterone levels." }
];

const tier3 = [
  { name: "BCAAs (Branched-Chain Amino Acids)", dosing: "5-10g", timing: "Intra-workout", evidence: "C", sideEffects: "None known.", description: "Largely unnecessary if overall daily protein intake is adequate. May help if training completely fasted." },
  { name: "Glutamine", dosing: "5g daily", timing: "Post-workout", evidence: "C", sideEffects: "None known.", description: "Often touted for muscle recovery, but oral glutamine is mostly absorbed by the gut and rarely reaches muscles in significant amounts." }
];

const wasteOfMoney = [
  { name: "Testosterone Boosters", description: "Most contain ingredients that do not significantly increase testosterone enough to affect muscle growth. Better off focusing on sleep, diet, and training." },
  { name: "Mass Gainers", description: "Usually just low-quality protein mixed with massive amounts of cheap sugar (maltodextrin). You are better off making your own high-calorie shakes with whole foods." },
  { name: "Fat Burners", description: "Often just expensive caffeine pills with underdosed 'proprietary blends'. A caloric deficit is the only true way to burn fat." }
];

const stacks = [
  { name: "The Essentials Stack", description: "Creatine Monohydrate + Whey Protein. The foundation for muscle growth and recovery. Highly effective and affordable." },
  { name: "The Pre-Workout Stack", description: "Caffeine + Citrulline Malate + Beta-Alanine. Formulate your own pre-workout for better pumps, endurance, and energy without proprietary blends." },
  { name: "The Recovery Stack", description: "Whey Protein + Tart Cherry Extract (optional for soreness). Focuses on supplying amino acids and reducing inflammation post-training." }
];
---

<SiteLayout
  site="bodycount"
  title="Best Supplements for Muscle Growth | BodyCount"
  description="An evidence-based guide to the best supplements for muscle growth. Discover what actually works (Tier 1) and what is a waste of money."
  canonical="https://bodycount.photonbuilder.com/best-muscle-supplements"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Best Supplements for Muscle Growth</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        An evidence-based guide to muscle-building supplements. Discover what is backed by science (Tier 1), what might offer a slight edge (Tier 2), and what is a complete waste of your money.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Tier 1: Highly Effective & Proven</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">These are the foundational supplements with decades of robust scientific evidence supporting their efficacy and safety.</div>
        <table>
          <thead>
            <tr>
              <th>Supplement</th>
              <th>Dosing & Timing</th>
              <th>Evidence</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            {tier1.map(item => (
              <tr>
                <td><strong>{item.name}</strong></td>
                <td>{item.dosing} ({item.timing})</td>
                <td><strong>{item.evidence}</strong></td>
                <td>{item.description} <em>Side effects: {item.sideEffects}</em></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Tier 2: Potentially Useful</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Supplements with decent evidence that may provide a minor performance edge, particularly for specific training scenarios.</div>
        <table>
          <thead>
            <tr>
              <th>Supplement</th>
              <th>Dosing & Timing</th>
              <th>Evidence</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            {tier2.map(item => (
              <tr>
                <td><strong>{item.name}</strong></td>
                <td>{item.dosing} ({item.timing})</td>
                <td><strong>{item.evidence}</strong></td>
                <td>{item.description} <em>Side effects: {item.sideEffects}</em></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Tier 3: Mostly Unnecessary</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Supplements that are generally not needed for the vast majority of people, though they aren't harmful.</div>
        <table>
          <thead>
            <tr>
              <th>Supplement</th>
              <th>Dosing & Timing</th>
              <th>Evidence</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            {tier3.map(item => (
              <tr>
                <td><strong>{item.name}</strong></td>
                <td>{item.dosing} ({item.timing})</td>
                <td><strong>{item.evidence}</strong></td>
                <td>{item.description} <em>Side effects: {item.sideEffects}</em></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Waste of Money</h2>
        <div class="highlight-box">
          <h4>Save Your Cash</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">The supplement industry is full of products that promise incredible results but fail to deliver. Avoid these common traps.</div>
          <ul style="margin-bottom: 0;">
            {wasteOfMoney.map(item => (
              <li><strong>{item.name}:</strong> {item.description}</li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <h2>Example Supplement Stacks</h2>
        <ul>
          {stacks.map(stack => (
            <li><strong>{stack.name}:</strong> {stack.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
