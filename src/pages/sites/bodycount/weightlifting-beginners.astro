---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const compoundVsIso = [
  { topic: "Compound Exercises", description: "Movements that use multiple muscle groups and joints at the same time. Examples: Squat, deadlift, bench press. These are the most efficient for building overall strength and size, as they allow you to move the most weight and stimulate the most muscle mass." },
  { topic: "Isolation Exercises", description: "Movements that target a single muscle group and involve only one joint. Examples: Bicep curl, leg extension. These are useful for targeting specific weak points or for extra volume after your heavy compound lifts, but shouldn't be the primary focus for a beginner." }
];

const bigFive = [
  { lift: "The Squat", cues: "Place the barbell across your upper back (traps). Keep your chest up, brace your core. Sit back and down as if sitting in a chair. Keep your knees tracking over your toes. Drive through your mid-foot to stand back up. Often called the 'king of exercises' for leg development." },
  { lift: "The Deadlift", cues: "Stand with feet hip-width apart, barbell over your mid-foot. Hinge at the hips and grab the bar just outside your legs. Keep a flat back, chest up. Drive through your legs and extend your hips to stand up straight. Crucial for the posterior chain (hamstrings, glutes, back)." },
  { lift: "The Bench Press", cues: "Lie flat on the bench, feet firmly on the floor. Grip the bar slightly wider than shoulder-width. Lower the bar to your mid-chest with elbows tucked at a 45-degree angle. Press the bar back up in a slight arc toward your upper chest/shoulders. The primary builder for chest, front shoulders, and triceps." },
  { lift: "The Overhead Press (OHP)", cues: "Stand with the barbell resting on your front delts, grip just outside shoulder-width. Brace your core and glutes. Press the bar straight up, moving your head slightly out of the way, then push your head back through at the top. Essential for overall shoulder strength and stability." },
  { lift: "The Barbell Row", cues: "Hinge forward at the hips until your torso is nearly parallel to the floor, maintaining a flat back. Grip the bar and pull it towards your lower chest/belly button, driving your elbows back. Control the weight back down. Vital for back thickness and balancing out pushing movements." }
];

const progressiveOverload = [
  { principle: "What it is", detail: "The foundational rule of muscle growth and strength gains. To keep making progress, you must continually challenge your muscles with more stress than they are used to." },
  { principle: "How to do it", detail: "The most common way is adding weight to the bar (e.g., adding 5 lbs to your squat each week). Other methods include doing more reps with the same weight, doing more sets, or decreasing rest time between sets." },
  { principle: "When to add weight", detail: "A common approach is 'linear progression'. If a program calls for 3 sets of 5 reps, and you complete all 15 reps with good form, you add a small amount of weight (usually 2.5-5 lbs) the next time you perform that exercise." }
];

const programs = [
  { name: "3-Day Full Body", explanation: "Ideal for true beginners. You train 3 days a week (e.g., Monday, Wednesday, Friday). Every session covers the whole body, usually centering around 3-4 of the 'Big 5' compound lifts per day. This maximizes the frequency at which a beginner practices the movements and stimulates growth." },
  { name: "PPL (Push/Pull/Legs)", explanation: "A split that divides the body into movement patterns. 'Push' days (chest, shoulders, triceps), 'Pull' days (back, biceps), and 'Legs' (quads, hamstrings, calves). It can be run 3 days a week, but is often run 6 days a week (PPLPPL Rest) by intermediate lifters. As a beginner, stick to a 3-day full body routine first before moving to PPL to ensure adequate recovery and form practice." }
];

const trainingVariables = [
  { variable: "Rest Periods", advice: "For heavy compound lifts (squats, deadlifts, bench), rest 2-5 minutes between sets. You want your nervous system and muscles fully recovered to handle the heavy weight. For isolation exercises, 60-90 seconds is usually sufficient." },
  { variable: "Warm-up Sets", advice: "Never jump straight into your working weight. Start with the empty bar, then do a few sets gradually increasing the weight until you reach your target for the day. E.g., if squatting 135 lbs: Empty bar x 10, 95 lbs x 5, 115 lbs x 3, then working sets at 135 lbs. Warm-up sets should not cause fatigue." }
];

const etiquette = [
  { rule: "Re-rack your weights", description: "Always put dumbbells back in their proper spot and strip the plates off your barbells and machines when you are finished." },
  { rule: "Wipe down equipment", description: "Use the gym's provided wipes or spray to clean benches and machines after you've sweat on them." },
  { rule: "Don't curl in the squat rack", description: "Squat racks are limited. Reserve them for exercises that actually require them (squats, overhead press). Do your bicep curls elsewhere." },
  { rule: "Personal Space", description: "Don't walk directly in front of someone while they are mid-set, especially if they are looking in the mirror to check their form." }
];

const equipment = [
  { item: "Weightlifting Belt", purpose: "Increases intra-abdominal pressure, stabilizing the spine during heavy squats and deadlifts. Not necessary for beginners until you've built a baseline of core strength and are moving significant weight." },
  { item: "Proper Shoes", purpose: "Squishy running shoes are terrible for lifting. You need a hard, flat sole to transfer force effectively and maintain stability. Converse, Vans, or specialized lifting shoes (with a raised heel for squats) are best. Even bare feet (if allowed) are better than running shoes." },
  { item: "Lifting Straps", purpose: "Help you hold onto the bar when your grip strength gives out before your target muscles do (often on deadlifts or rows). Use them sparingly as a beginner to allow your natural grip strength to develop." },
  { item: "Wrist Wraps", purpose: "Provide support to the wrist joint during heavy pressing movements (bench press, overhead press). Helpful if you experience wrist pain, but ensure you are gripping the bar correctly first (bar low in the palm)." }
];

const faqList = [
  {
    question: "Do I need to take supplements?",
    answer: "No. Supplements are just that—supplementary. Focus on eating a balanced diet with enough protein, carbs, and fats, getting adequate sleep, and following a consistent training program first. Protein powder and creatine can be helpful later, but are not required."
  },
  {
    question: "Will lifting weights make me bulky?",
    answer: "No, especially for women. Building significant muscle mass takes years of dedicated, intense training and a caloric surplus. Lifting weights will make you stronger, build lean muscle, and improve your body composition."
  },
  {
    question: "How long should my workouts last?",
    answer: "A typical beginner workout focusing on compound lifts should take between 45 to 75 minutes. If it's taking much longer, you may be resting too long, doing too many exercises, or socializing too much."
  },
  {
    question: "Is it normal to be sore?",
    answer: "Yes, Delayed Onset Muscle Soreness (DOMS) is very common when you first start or introduce a new exercise. It typically peaks 24-48 hours after the workout. It will significantly decrease as your body adapts to the routine."
  },
  {
    question: "Should I do cardio before or after lifting?",
    answer: "If your main goal is getting stronger or building muscle, do cardio after you lift weights or on separate days. Doing intense cardio first will deplete your energy, compromising your form and strength during your lifts."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/weightlifting-beginners"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<SiteLayout
  site="bodycount"
  title="Complete Beginner Weight Training Guide | BodyCount"
  description="A comprehensive guide for beginners starting weightlifting. Learn about compound exercises, the Big 5 lifts, progressive overload, programs, and gym etiquette."
  canonical="https://bodycount.photonbuilder.com/weightlifting-beginners"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Weightlifting for Beginners</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        Everything you need to know to start your strength training journey. Master the basics, understand proper form, and learn how to progress safely and effectively.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Compound vs. Isolation Exercises</h2>
        <ul>
          {compoundVsIso.map(item => (
            <li><strong>{item.topic}:</strong> {item.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>The Big 5 Lifts</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">
          These five compound barbell movements form the foundation of almost every successful strength training program.
        </div>
        <ul>
          {bigFive.map(item => (
            <li><strong>{item.lift}:</strong> {item.cues}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>The Principle of Progressive Overload</h2>
        <ul>
          {progressiveOverload.map(item => (
            <li><strong>{item.principle}:</strong> {item.detail}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Beginner Programs Explained</h2>
        <table>
          <thead>
            <tr>
              <th>Program</th>
              <th>Explanation</th>
            </tr>
          </thead>
          <tbody>
            {programs.map(item => (
              <tr>
                <td><strong>{item.name}</strong></td>
                <td>{item.explanation}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Training Variables: Rest & Warm-ups</h2>
        <div class="highlight-box">
          <h4>Key Factors</h4>
          <ul style="margin-bottom: 0;">
            {trainingVariables.map(item => (
              <li><strong>{item.variable}:</strong> {item.advice}</li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <h2>Gym Etiquette 101</h2>
        <ul>
          {etiquette.map(item => (
            <li><strong>{item.rule}:</strong> {item.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Equipment Guide</h2>
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th>Purpose & When to Use</th>
            </tr>
          </thead>
          <tbody>
            {equipment.map(item => (
              <tr>
                <td><strong>{item.item}</strong></td>
                <td>{item.purpose}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
