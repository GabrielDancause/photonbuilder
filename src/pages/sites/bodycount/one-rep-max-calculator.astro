            <div class="radio-group">
              <label class="radio-label"><input type="radio" name="gender" value="male" checked> Male</label>
              <label class="radio-label"><input type="radio" name="gender" value="female"> Female</label>
            </div>
          </div>
        </div>
      </div>

      <button class="calculate-btn" id="calculateBtn" type="button">Calculate 1RM</button>
    </div>

    <div class="results" id="results">
      <!-- Average 1RM -->
      <div class="card">
        <div class="section-title">Estimated One Rep Max</div>
        <div class="result-box" style="border:1px solid var(--accent-color);">
          <div>
            <div class="result-title">Average 1RM</div>
            <div class="result-subtitle" id="rangeText">Range across 5 formulas</div>
          </div>
          <div class="result-value" id="avg1rm">—</div>
        </div>

        <div class="range-bar">
          <div class="range-label">Low</div>
          <div class="range-track">
            <div class="range-fill" id="rangeFill" style="width:0%"></div>
          </div>
          <div class="range-label" style="text-align:right;">High</div>
          <div class="range-values"><span id="rangeMin">—</span> – <span id="rangeMax">—</span></div>
        </div>

        <div class="section-subtitle">Individual Formula Results</div>
        <div class="formulas-grid" id="formulasGrid"></div>

        <div id="strengthLevel" style="display:none;">
          <div class="result-box" style="border-left:3px solid var(--accent-color);" id="strengthBox">
            <div>
              <div class="result-title" id="strengthExercise">Bench Press</div>
              <div class="result-subtitle">Your strength level</div>
            </div>
            <div class="strength-badge" id="strengthBadge">—</div>
          </div>
        </div>
      </div>

      <!-- Percentage Chart -->
      <div class="card">
        <div class="section-title">Percentage-Based Training Chart</div>
        <div class="section-subtitle">Weights and recommended rep ranges based on your estimated 1RM</div>
        <div style="overflow-x:auto;">
          <table class="data-table">
            <thead>
              <tr>
                <th>% of 1RM</th>
