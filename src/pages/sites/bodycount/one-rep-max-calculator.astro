              <option value="13">13 reps</option>
              <option value="14">14 reps</option>
              <option value="15">15 reps</option>
            </select>
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-col">
          <div class="form-group">
            <label for="bodyweight">Body Weight <span id="bwUnitLabel">(lbs)</span> <span style="color:var(--text-secondary);font-weight:400;">— for strength standards</span></label>
