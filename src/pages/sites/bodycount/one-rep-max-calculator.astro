                <th>Reps</th>
                <th>Training Goal</th>
              </tr>
            </thead>
            <tbody id="pctBody"></tbody>
          </table>
        </div>
      </div>

      <!-- Strength Standards -->
      <div class="card" id="standardsCard">
        <div class="section-title">Strength Standards — <span id="stdExerciseName">Bench Press</span></div>
        <div class="section-subtitle" id="stdSubtitle">Body weight ratio benchmarks</div>

        <div class="exercise-btns" id="stdExerciseBtns">
          <button class="exercise-btn active" data-std="bench" type="button">Bench Press</button>
          <button class="exercise-btn" data-std="squat" type="button">Squat</button>
          <button class="exercise-btn" data-std="deadlift" type="button">Deadlift</button>
          <button class="exercise-btn" data-std="ohp" type="button">OHP</button>
        </div>

        <div class="std-gender-toggle">
          <button class="std-gender-btn active" data-stdgender="male" type="button">Male</button>
          <button class="std-gender-btn" data-stdgender="female" type="button">Female</button>
        </div>

        <div style="overflow-x:auto;" id="stdTableWrap"></div>
      </div>

      <!-- FAQ -->
      <div class="card">
        <h2>Frequently Asked Questions</h2>
        <div id="faqContainer"></div>
      </div>

      <!-- Related Tools -->
      <div class="card">
        <h2>Related Tools</h2>
        <div class="related-tools">
          <a href="/macro-calculator" class="related-tool">
            <div class="related-tool-name">Macro Calculator</div>
            <div class="related-tool-desc">Calculate daily macros and TDEE for your training goals</div>
          </a>
          <a href="/body-fat-calculator" class="related-tool">
            <div class="related-tool-name">Body Fat Calculator</div>
            <div class="related-tool-desc">Estimate body fat percentage using multiple methods</div>
          </a>
        </div>
      </div>

      <div class="disclaimer">
        <strong>Disclaimer:</strong> This calculator provides estimates for informational purposes only. Attempting a true one rep max carries injury risk. Always use proper form, a spotter, and safety equipment. Consult a healthcare professional before starting any exercise program.
      </div>
    </div>
  </div>

  <script is:inline>
(function() {
  var currentUnit = 'lbs';
  var selectedExercise = 'bench';
  var stdExercise = 'bench';
  var stdGender = 'male';

  var exerciseNames = { bench: 'Bench Press', squat: 'Squat', deadlift: 'Deadlift', ohp: 'Overhead Press' };

  // 1RM formulas
  function epley(w, r) { return r === 1 ? w : w * (1 + r / 30); }
  function brzycki(w, r) { return r === 1 ? w : w * (36 / (37 - r)); }
  function lombardi(w, r) { return r === 1 ? w : w * Math.pow(r, 0.10); }
  function mayhew(w, r) { return r === 1 ? w : (100 * w) / (52.2 + 41.9 * Math.exp(-0.055 * r)); }
  function oconner(w, r) { return r === 1 ? w : w * (1 + r * 0.025); }

  var formulaList = [
    { key: 'epley',    fn: epley,    name: 'Epley',    eq: 'w \u00d7 (1 + r/30)' },
    { key: 'brzycki',  fn: brzycki,  name: 'Brzycki',  eq: 'w \u00d7 36/(37 \u2212 r)' },
    { key: 'lombardi', fn: lombardi, name: 'Lombardi', eq: 'w \u00d7 r^0.10' },
    { key: 'mayhew',   fn: mayhew,   name: 'Mayhew',   eq: '100w / (52.2 + 41.9e^(\u22120.055r))' },
    { key: 'oconner',  fn: oconner,  name: "O'Conner", eq: 'w \u00d7 (1 + r\u00d70.025)' }
  ];

  var percentages = [
    { pct: 100, reps: '1',      goal: 'Max Strength' },
    { pct: 95,  reps: '1\u20132',    goal: 'Strength / Peaking' },
    { pct: 90,  reps: '2\u20133',    goal: 'Strength' },
    { pct: 85,  reps: '3\u20135',    goal: 'Strength' },
    { pct: 80,  reps: '4\u20136',    goal: 'Strength / Hypertrophy' },
    { pct: 75,  reps: '6\u20138',    goal: 'Hypertrophy' },
    { pct: 70,  reps: '8\u201310',   goal: 'Hypertrophy' },
    { pct: 65,  reps: '10\u201312',  goal: 'Hypertrophy / Endurance' },
    { pct: 60,  reps: '12\u201315',  goal: 'Muscular Endurance' },
    { pct: 55,  reps: '15\u201320',  goal: 'Endurance' },
    { pct: 50,  reps: '20+',    goal: 'Endurance / Warm-up' }
  ];

  // Strength standards: body weight multipliers [beginner, intermediate, advanced, elite]
  var standards = {
    bench:    { male: [0.50, 1.00, 1.50, 2.00], female: [0.25, 0.50, 0.75, 1.15] },
    squat:    { male: [0.75, 1.25, 1.75, 2.50], female: [0.50, 0.75, 1.25, 1.75] },
    deadlift: { male: [1.00, 1.50, 2.00, 2.75], female: [0.50, 1.00, 1.50, 2.00] },
    ohp:      { male: [0.35, 0.65, 1.00, 1.40], female: [0.20, 0.35, 0.55, 0.80] }
  };

  var levelNames = ['Beginner', 'Intermediate', 'Advanced', 'Elite'];
  var levelColors = ['#888888', '#3b82f6', '#f59e0b', '#ef4444'];

  var stdBWLbs = [120, 140, 150, 160, 170, 180, 190, 200, 220, 240, 260];
  var stdBWKg  = [55, 60, 65, 70, 75, 80, 85, 90, 100, 110, 120];

  function roundStep(n) {
    return currentUnit === 'kg' ? Math.round(n / 2.5) * 2.5 : Math.round(n / 5) * 5;
  }

  // Unit toggle
  document.getElementById('btnLbs').addEventListener('click', function() { setUnit('lbs'); });
  document.getElementById('btnKg').addEventListener('click', function() { setUnit('kg'); });

  function setUnit(u) {
    currentUnit = u;
    document.getElementById('btnLbs').classList.toggle('active', u === 'lbs');
    document.getElementById('btnKg').classList.toggle('active', u === 'kg');
    document.getElementById('unitLabel').textContent = '(' + u + ')';
    document.getElementById('bwUnitLabel').textContent = '(' + u + ')';
  }

  // Exercise buttons
  document.getElementById('exerciseBtns').addEventListener('click', function(e) {
    var btn = e.target.closest('.exercise-btn');
    if (!btn) return;
    document.querySelectorAll('#exerciseBtns .exercise-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    selectedExercise = btn.dataset.exercise;
  });

  // Standards exercise buttons
  document.getElementById('stdExerciseBtns').addEventListener('click', function(e) {
    var btn = e.target.closest('.exercise-btn');
    if (!btn) return;
    document.querySelectorAll('#stdExerciseBtns .exercise-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    stdExercise = btn.dataset.std;
    renderStandards();
  });

  // Standards gender toggle
  document.querySelectorAll('.std-gender-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.std-gender-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      stdGender = btn.dataset.stdgender;
      renderStandards();
    });
  });

  // FAQ
  var faqData = [
    { q: "What is a one rep max (1RM)?", a: "A one rep max (1RM) is the maximum amount of weight you can lift for a single repetition with proper form. It\u2019s the gold standard for measuring absolute strength and is used to program training intensity. Rather than testing it directly (which carries injury risk), most lifters estimate their 1RM using submaximal loads and rep-based formulas." },
    { q: "How accurate are 1RM formulas?", a: "1RM formulas are most accurate when using sets of 1\u20136 reps and become less reliable above 10 reps. The Epley and Brzycki formulas are considered the most accurate for most lifters. This calculator averages five formulas to give you a more reliable estimate. For the most precise result, use a weight you can lift for 3\u20135 reps with good form." },
    { q: "What is the difference between Epley and Brzycki formulas?", a: "The Epley formula (1RM = weight \u00d7 (1 + reps/30)) tends to give slightly higher estimates at higher rep ranges. The Brzycki formula (1RM = weight \u00d7 36/(37 - reps)) is considered more accurate for lower rep ranges (1\u20136 reps). Both are widely used in strength training." },
    { q: "How should I use my 1RM to program training?", a: "Most strength programs prescribe weights as a percentage of your 1RM. For strength (1\u20135 reps), work at 85\u2013100% of 1RM. For hypertrophy (6\u201312 reps), use 65\u201385%. For endurance (12+ reps), use 50\u201365%. The percentage chart in this calculator shows exact weights for each percentage along with recommended rep ranges." },
    { q: "How often should I test or recalculate my 1RM?", a: "Recalculate your estimated 1RM every 4\u20138 weeks, or at the start of a new training cycle. Avoid testing a true 1RM more than once every 3\u20134 months, as maximal attempts are taxing on the nervous system." },
    { q: "What are strength standards and how are they determined?", a: "Strength standards classify your lifts as beginner, intermediate, advanced, or elite based on your body weight and gender. They\u2019re derived from competitive powerlifting data and large-scale gym surveys. A beginner standard represents someone with less than 6 months of training, while elite represents competitive-level strength." },
    { q: "Why does my 1RM vary between exercises?", a: "Different exercises use different muscle groups and movement patterns. Deadlifts typically have the highest 1RM because they recruit the most total muscle mass. Squats are next, followed by bench press, then overhead press. A common benchmark ratio is 1:0.8:0.6:0.4 for deadlift:squat:bench:OHP." },
    { q: "Is it safe to attempt a true one rep max?", a: "Testing a true 1RM carries higher injury risk than regular training. If you do attempt it, warm up thoroughly, use a spotter, have safety bars/pins set up, and only attempt it when well-rested. For most training purposes, estimating your 1RM from submaximal sets is safer and nearly as accurate." }
  ];

  var faqContainer = document.getElementById('faqContainer');
  faqData.forEach(function(item) {
    var div = document.createElement('div');
    div.className = 'faq-item';
    div.innerHTML = '<button class="faq-question" type="button">' + item.q + '</button><div class="faq-answer">' + item.a + '</div>';
    div.querySelector('.faq-question').addEventListener('click', function() { div.classList.toggle('open'); });
    faqContainer.appendChild(div);
  });

  // Render strength standards table
  function renderStandards() {
    var ex = stdExercise;
    var gender = stdGender;
    var std = standards[ex][gender];
    var bwRows = currentUnit === 'kg' ? stdBWKg : stdBWLbs;
    var userBW = parseFloat(document.getElementById('bodyweight').value) || 0;

    document.getElementById('stdExerciseName').textContent = exerciseNames[ex];
    document.getElementById('stdSubtitle').textContent = (gender === 'male' ? 'Male' : 'Female') + ' strength standards for ' + exerciseNames[ex].toLowerCase() + ' (' + currentUnit + ')';

    var html = '<table class="data-table"><thead><tr><th>Body Weight</th>';
    levelNames.forEach(function(n) { html += '<th>' + n + '</th>'; });
    html += '</tr></thead><tbody>';

    bwRows.forEach(function(bw) {
      var isUser = userBW > 0 && Math.abs(bw - userBW) < (currentUnit === 'kg' ? 6 : 11);
      html += '<tr' + (isUser ? ' class="user-row"' : '') + '>';
      html += '<td class="col-bw"' + (isUser ? ' style="color:var(--accent-color)"' : '') + '>' + bw + ' ' + currentUnit + '</td>';
      std.forEach(function(m) {
        var val = roundStep(bw * m);
        html += '<td class="col-std">' + val + '</td>';
      });
      html += '</tr>';
    });

    html += '</tbody></table>';
    document.getElementById('stdTableWrap').innerHTML = html;
  }

  // Calculate
  document.getElementById('calculateBtn').addEventListener('click', calculate);

  function calculate() {
    var w = parseFloat(document.getElementById('weight').value);
    var r = parseInt(document.getElementById('reps').value);
    if (!w || w <= 0) { document.getElementById('weight').focus(); return; }

    var results = [];
    var min = Infinity, max = -Infinity;

    formulaList.forEach(function(f) {
      var val = f.fn(w, r);
      var rounded = roundStep(val);
      results.push({ name: f.name, eq: f.eq, raw: val, rounded: rounded });
      if (val < min) min = val;
      if (val > max) max = val;
    });

    var avgRaw = results.reduce(function(s, r) { return s + r.raw; }, 0) / results.length;
    var avg = roundStep(avgRaw);
    var minR = roundStep(min);
    var maxR = roundStep(max);

    // Display
    document.getElementById('avg1rm').textContent = avg + ' ' + currentUnit;
    document.getElementById('rangeText').textContent = 'Range: ' + minR + ' \u2013 ' + maxR + ' ' + currentUnit;
    document.getElementById('rangeMin').textContent = minR;
    document.getElementById('rangeMax').textContent = maxR;

    // Range fill
    var spread = maxR - minR;
    var trackRange = avg * 0.2;
    var pctWidth = trackRange > 0 ? Math.min((spread / trackRange) * 100, 100) : 10;
    var fill = document.getElementById('rangeFill');
    fill.style.width = pctWidth + '%';
    fill.style.marginLeft = ((100 - pctWidth) / 2) + '%';

    // Formula grid
    var grid = document.getElementById('formulasGrid');
    grid.innerHTML = '';
    results.forEach(function(r) {
      var card = document.createElement('div');
      card.className = 'formula-card';
      card.innerHTML = '<div><div class="formula-name">' + r.name + '</div><div class="formula-equation">' + r.eq + '</div></div><div class="formula-value">' + r.rounded + ' ' + currentUnit + '</div>';
      grid.appendChild(card);
    });

    // Percentage table
    var pctBody = document.getElementById('pctBody');
    pctBody.innerHTML = '';
    percentages.forEach(function(row) {
      var wt = roundStep(avg * row.pct / 100);
      var tr = document.createElement('tr');
      tr.innerHTML = '<td class="col-pct">' + row.pct + '%</td><td class="col-weight">' + wt + ' ' + currentUnit + '</td><td class="col-reps">' + row.reps + '</td><td class="col-reps">' + row.goal + '</td>';
      pctBody.appendChild(tr);
    });

    // Strength level badge
    var bw = parseFloat(document.getElementById('bodyweight').value);
    var gender = document.querySelector('input[name="gender"]:checked').value;
    var strengthSection = document.getElementById('strengthLevel');

    if (bw && bw > 0) {
      var ratio = avgRaw / bw;
      var std = standards[selectedExercise][gender];
      var levelIdx = 0;
      for (var i = std.length - 1; i >= 0; i--) {
        if (ratio >= std[i]) { levelIdx = i; break; }
      }

      document.getElementById('strengthExercise').textContent = exerciseNames[selectedExercise] + ' @ ' + bw + ' ' + currentUnit + ' BW';
      var badge = document.getElementById('strengthBadge');
      badge.textContent = levelNames[levelIdx];
      badge.style.backgroundColor = levelColors[levelIdx] + '22';
      badge.style.color = levelColors[levelIdx];
      document.getElementById('strengthBox').style.borderLeftColor = levelColors[levelIdx];
      strengthSection.style.display = 'block';
    } else {
      strengthSection.style.display = 'none';
    }

    // Sync standards table exercise and gender
    stdExercise = selectedExercise;
    stdGender = gender;
    document.querySelectorAll('#stdExerciseBtns .exercise-btn').forEach(function(b) {
      b.classList.toggle('active', b.dataset.std === selectedExercise);
    });
    document.querySelectorAll('.std-gender-btn').forEach(function(b) {
      b.classList.toggle('active', b.dataset.stdgender === gender);
    });
    renderStandards();

    document.getElementById('results').classList.add('active');
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Initialize standards table
  renderStandards();
})();
  </script>
</SiteLayout>
