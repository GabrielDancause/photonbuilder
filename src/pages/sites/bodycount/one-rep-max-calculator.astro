---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "One Rep Max Calculator",
  "url": "https://bodycount.photonbuilder.com/one-rep-max-calculator.html",
  "description": "Calculate your one rep max (1RM) using 5 proven formulas — Epley, Brzycki, Lombardi, Mayhew, O'Conner. View percentage charts, strength standards by body weight and gender.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a one rep max (1RM)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A one rep max (1RM) is the maximum amount of weight you can lift for a single repetition with proper form. It's the gold standard for measuring absolute strength and is used to program training intensity. Rather than testing it directly (which carries injury risk), most lifters estimate their 1RM using submaximal loads and rep-based formulas."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate are 1RM formulas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "1RM formulas are most accurate when using sets of 1–6 reps and become less reliable above 10 reps. The Epley and Brzycki formulas are considered the most accurate for most lifters. This calculator averages five formulas to give you a more reliable estimate. For the most precise result, use a weight you can lift for 3–5 reps with good form."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between Epley and Brzycki formulas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Epley formula (1RM = weight × (1 + reps/30)) tends to give slightly higher estimates at higher rep ranges. The Brzycki formula (1RM = weight × 36/(37 - reps)) is considered more accurate for lower rep ranges (1–6 reps). Both are widely used in strength training. This calculator uses both plus three additional formulas to provide a range."
      }
    },
    {
      "@type": "Question",
      "name": "How should I use my 1RM to program training?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most strength programs prescribe weights as a percentage of your 1RM. For strength (1–5 reps), work at 85–100% of 1RM. For hypertrophy (6–12 reps), use 65–85%. For endurance (12+ reps), use 50–65%. The percentage chart in this calculator shows exact weights for each percentage along with recommended rep ranges."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I test or recalculate my 1RM?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Recalculate your estimated 1RM every 4–8 weeks, or at the start of a new training cycle. Avoid testing a true 1RM more than once every 3–4 months, as maximal attempts are taxing on the nervous system. Using submaximal estimates (like this calculator) lets you track progress frequently without the fatigue and injury risk of actual max attempts."
      }
    },
    {
      "@type": "Question",
      "name": "What are strength standards and how are they determined?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Strength standards classify your lifts as beginner, intermediate, advanced, or elite based on your body weight and gender. They're derived from competitive powerlifting data and large-scale gym surveys. A beginner standard represents someone with less than 6 months of training, while elite represents competitive-level strength (top 1–2% of trained lifters)."
      }
    },
    {
      "@type": "Question",
      "name": "Why does my 1RM vary between exercises?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Different exercises use different muscle groups and movement patterns. Deadlifts typically have the highest 1RM because they recruit the most total muscle mass. Squats are next, followed by bench press, then overhead press. The ratio between lifts varies by individual, but a common benchmark is a 1:0.8:0.6:0.4 ratio for deadlift:squat:bench:overhead press."
      }
    },
    {
      "@type": "Question",
      "name": "Is it safe to attempt a true one rep max?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Testing a true 1RM carries higher injury risk than regular training. If you do attempt it, warm up thoroughly, use a spotter, have safety bars/pins set up, and only attempt it when well-rested. For most training purposes, estimating your 1RM from submaximal sets (as this calculator does) is safer and nearly as accurate."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="One Rep Max Calculator — 1RM Estimator for Bench, Squat & Deadlift"
  description="Calculate your one rep max (1RM) using 5 proven formulas. Bench press calculator, squat max, deadlift 1RM with percentage chart and strength standards by body weight and gender."
  canonical="https://bodycount.photonbuilder.com/one-rep-max-calculator" schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <style>
