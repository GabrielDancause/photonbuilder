---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "8 Best Yoga Mats of 2026",
    "description": "Compare the best yoga mats. Ranked for thickness, grip, material, weight, eco-friendliness, durability, and price. Find the perfect mat for your practice.",
    "url": "https://bodycount.photonbuilder.com/best-yoga-mats"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the best material for a yoga mat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Natural rubber offers the best combination of grip and eco-friendliness. PVC is highly durable but less environmentally friendly. Polyurethane (PU) tops provide excellent wet grip, while TPE and cork are great lightweight alternatives."
        }
      },
      {
        "@type": "Question",
        "name": "How thick should my yoga mat be?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A standard mat is about 4mm to 5mm thick, offering a balance of cushioning and stability. If you need joint support, opt for a thicker mat (6mm+). For travel or better ground connection, a thinner mat (1.5mm to 3mm) is ideal."
        }
      },
      {
        "@type": "Question",
        "name": "Are expensive yoga mats worth it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, premium mats from brands like Manduka and Liforme are often worth the investment. They are more durable, provide vastly superior grip (especially when sweaty), and offer better joint protection compared to cheap entry-level mats."
        }
      },
      {
        "@type": "Question",
        "name": "How do I clean my yoga mat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wipe it down after practice with a damp cloth and mild soap or a specialized mat cleaner. Avoid harsh chemicals, and let it air dry completely before rolling. Do not leave natural rubber mats in direct sunlight."
        }
      },
      {
        "@type": "Question",
        "name": "Which mat is best for hot yoga?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For hot yoga, you need a mat that maintains grip when wet. Mats with a polyurethane (PU) top layer, like the Liforme, or specialized sweat-absorbing mats are best. Alternatively, use a high-quality yoga towel over a standard mat."
        }
      }
    ]
  }
];

const categories = [
  { name: 'Best Overall', brand: 'Manduka PRO', desc: 'Legendary durability, unmatched support, and a lifetime guarantee.' },
  { name: 'Best for Hot Yoga', brand: 'Liforme', desc: 'Unbeatable wet grip and alignment markers.' },
  { name: 'Best for Beginners', brand: 'Gaiam Sol', desc: 'Affordable, great grip, and comfortable thickness.' },
  { name: 'Best for Travel', brand: 'JadeYoga Voyager', desc: 'Incredibly lightweight and folds up easily.' },
  { name: 'Best for Joint Support', brand: 'B Yoga (B MAT Strong)', desc: 'Exceptional cushioning and a super grippy texture.' },
];

const mats = [
  { brand: 'Manduka PRO', material: 'PVC', thickness: 6, weight: 7.5, grip: 'Excellent', eco: 'Fair', durability: 'Lifetime', price: 138 },
  { brand: 'Liforme', material: 'Natural Rubber / PU', thickness: 4.2, weight: 5.5, grip: 'Exceptional', eco: 'Good', durability: 'High', price: 150 },
  { brand: 'Jade Harmony', material: 'Natural Rubber', thickness: 4.8, weight: 4.5, grip: 'Excellent', eco: 'Excellent', durability: 'Medium', price: 85 },
  { brand: 'Lululemon Reversible', material: 'Natural Rubber / PU', thickness: 5, weight: 5.2, grip: 'Excellent', eco: 'Good', durability: 'High', price: 88 },
  { brand: 'Gaiam Sol', material: 'Dry-Grip PU', thickness: 5, weight: 4.0, grip: 'Great', eco: 'Fair', durability: 'Medium', price: 60 },
  { brand: 'JadeYoga Voyager', material: 'Natural Rubber', thickness: 1.6, weight: 1.5, grip: 'Excellent', eco: 'Excellent', durability: 'Medium', price: 44 },
  { brand: 'B Yoga B MAT Strong', material: 'Natural Rubber', thickness: 6, weight: 5.0, grip: 'Exceptional', eco: 'Good', durability: 'High', price: 104 },
  { brand: 'prAna E.C.O.', material: 'TPE', thickness: 5, weight: 2.2, grip: 'Good', eco: 'Good', durability: 'Medium', price: 55 },
];
---

<SiteLayout
  site="bodycount"
  title="8 Best Yoga Mats 2026 - BodyCount"
  description="Compare the top yoga mats for your practice. Discover our top picks for hot yoga, travel, beginners, and joint support."
  canonical="https://bodycount.photonbuilder.com/best-yoga-mats"
  schema={schema}
>
  <style>
    .page-wrapper {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;
      background-color: var(--bg-color);
      color: var(--text-primary);
      min-height: 100vh;
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .hero-title {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
      letter-spacing: -0.025em;
    }

    @media (min-width: 768px) {
      .hero-title {
        font-size: 3rem;
      }
    }

    .hero-desc {
      font-size: 1.25rem;
      color: var(--text-secondary);
      max-width: 42rem;
      margin: 0 auto;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .section-title {
      font-size: 1.875rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .section-desc {
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
      text-align: left;
    }

    /* Category Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .category-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }

    .cat-title {
      font-size: 0.875rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .cat-brand {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .cat-desc {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
    }

    /* Table Styles */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 4rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background: var(--chart-header);
      padding: 1rem 1.5rem;
      font-weight: 600;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color);
      white-space: nowrap;
    }

    td {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--table-hover);
    }

    .material-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-secondary);
    }

    .td-brand { font-weight: 500; }
    .td-thick { font-weight: 700; color: var(--accent-color); }
    .td-price { font-family: monospace; font-size: 0.875rem; }

    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <div class="page-wrapper">
    <div class="hero-section">
      <h1 class="hero-title">8 Best Yoga Mats</h1>
      <p class="hero-desc">
        Compare the top yoga mats based on thickness, grip, material, and price. Find the perfect foundation for your practice.
      </p>
    </div>

    <main class="container">
      <section>
        <h2 class="section-title">Top Category Winners</h2>
        <div class="category-grid">
          {categories.map(cat => (
            <div class="category-card">
              <div class="cat-title">{cat.name}</div>
              <div class="cat-brand">{cat.brand}</div>
              <div class="cat-desc">{cat.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-title" style="text-align: left;">Compare All Yoga Mats</h2>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Brand</th>
                <th>Material</th>
                <th>Thickness (mm)</th>
                <th>Weight (lbs)</th>
                <th>Grip (Wet/Dry)</th>
                <th>Eco-Friendly</th>
                <th>Durability</th>
                <th>Price ($)</th>
              </tr>
            </thead>
            <tbody>
              {mats.map(mat => (
                <tr>
                  <td class="td-brand">{mat.brand}</td>
                  <td><span class="material-badge">{mat.material}</span></td>
                  <td class="td-thick">{mat.thickness}mm</td>
                  <td>{mat.weight.toFixed(1)}</td>
                  <td>{mat.grip}</td>
                  <td>{mat.eco}</td>
                  <td>{mat.durability}</td>
                  <td class="td-price">${mat.price.toFixed(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          {schema[1].mainEntity.map((faq: any) => (
            <div class="faq-item">
              <div class="faq-q">{faq.name}</div>
              <div class="faq-a">{faq.acceptedAnswer.text}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
