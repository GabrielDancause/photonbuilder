---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "5 Best Yoga Mats (Manduka, Liforme, Lululemon, Jade, Gaiam)",
    "description": "Compare the 5 best yoga mats including Manduka PRO, Liforme, Jade, Lululemon, and Gaiam based on thickness, material, grip, weight, eco-friendliness, and price.",
    "author": {
      "@type": "Organization",
      "name": "BodyCount"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What thickness of yoga mat is best?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A standard yoga mat is about 1/8 inch (3-4mm) thick. A thicker mat (1/4 inch or 5-6mm) provides more cushioning for your joints but can make balancing poses harder. Thinner mats (1/16 inch or 1-2mm) are usually travel mats."
        }
      },
      {
        "@type": "Question",
        "name": "What material is best for a yoga mat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "PVC is the most durable and common material, but it's not eco-friendly. Natural rubber, polyurethane (PU), and cork are great eco-friendly alternatives that offer excellent grip, even when sweaty."
        }
      },
      {
        "@type": "Question",
        "name": "How do I clean my yoga mat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most mats can be wiped down with a mixture of equal parts water and white vinegar, plus a few drops of tea tree oil. Avoid soaking open-cell mats (like natural rubber) and always check the manufacturer's instructions."
        }
      },
      {
        "@type": "Question",
        "name": "Why are some yoga mats so expensive?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Premium mats use high-quality, durable materials (like dense PVC or natural rubber) that won't flake or peel over time. They also invest in proprietary textures for superior grip and joint support, often lasting years or even a lifetime."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a towel for hot yoga?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you use a closed-cell mat (like the Manduka PRO), you will likely need a yoga towel to absorb sweat and prevent slipping. Open-cell mats (like Liforme or Jade) absorb sweat and retain grip better, but can still benefit from a towel for hygiene."
        }
      }
    ]
  }
];

const categories = [
  { name: 'Best Overall', brand: 'Liforme Original', desc: 'Unbeatable grip, helpful alignment lines, and eco-friendly materials.' },
  { name: 'Best for Durability', brand: 'Manduka PRO', desc: 'Ultra-dense cushioning and guaranteed to last a lifetime.' },
  { name: 'Best for Hot Yoga', brand: 'Lululemon The Reversible Mat', desc: 'Absorbs sweat perfectly, providing grip when things get slippery.' },
  { name: 'Best Eco-Friendly', brand: 'Jade Harmony', desc: 'Made from natural rubber for excellent traction and sustainability.' },
  { name: 'Best Budget', brand: 'Gaiam Premium', desc: 'Affordable, lightweight, and comes in many beautiful designs.' },
];

const mats = [
  { brand: 'Manduka PRO', thickness: 6, material: 'PVC', grip: 'Medium (Needs break-in)', weight: 7.5, eco: 'No (Oeko-Tex certified)', price: 138 },
  { brand: 'Liforme Original', thickness: 4.2, material: 'PU / Natural Rubber', grip: 'Excellent', weight: 5.5, eco: 'Yes', price: 140 },
  { brand: 'Jade Harmony', thickness: 4.7, material: 'Natural Rubber', grip: 'Excellent', weight: 4.5, eco: 'Yes', price: 85 },
  { brand: 'Lululemon The Reversible Mat', thickness: 5, material: 'PU / Natural Rubber', grip: 'Excellent', weight: 5.2, eco: 'Yes', price: 88 },
  { brand: 'Gaiam Premium', thickness: 6, material: 'PVC', grip: 'Good', weight: 3.0, eco: 'No', price: 30 },
];
---

<SiteLayout
  site="bodycount"
  title="5 Best Yoga Mats (Manduka, Liforme, Jade) - BodyCount"
  description="Compare the 5 best yoga mats for every practice. We compare Manduka PRO, Liforme, Jade, Lululemon, and Gaiam on thickness, grip, material, and price."
  canonical="https://bodycount.photonbuilder.com/best-yoga-mats"
  schema={schema}
>
  <style is:global>
    :root {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Category Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .category-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }

    .cat-title {
      font-size: 0.875rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .cat-brand {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .cat-desc {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
    }

    /* Table Styles */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 4rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background: var(--chart-header);
      padding: 1rem 1.5rem;
      font-weight: 600;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
      transition: color 0.2s;
    }

    th:hover {
      color: var(--text-primary);
    }

    td {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--table-hover);
    }

    .type-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-secondary);
    }

    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <div class="hero-section">
    <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">5 Best Yoga Mats</h1>
    <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
      Compare the top yoga mats based on thickness, grip, material, weight, and price to find the perfect one for your practice.
    </p>
  </div>

  <main class="container">
    <section>
      <h2 class="text-3xl font-bold mb-6 text-center">Top Category Winners</h2>
      <div class="category-grid">
        {categories.map(cat => (
          <div class="category-card">
            <div class="cat-title">{cat.name}</div>
            <div class="cat-brand">{cat.brand}</div>
            <div class="cat-desc">{cat.desc}</div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Compare Yoga Mats</h2>
      <p class="text-[var(--text-secondary)] mb-6 text-sm">Click column headers to sort.</p>

      <div class="table-container">
        <table id="matTable">
          <thead>
            <tr>
              <th data-sort="brand">Brand ↕</th>
              <th data-sort="thickness">Thickness (mm) ↕</th>
              <th data-sort="material">Material ↕</th>
              <th data-sort="grip">Grip ↕</th>
              <th data-sort="weight">Weight (lbs) ↕</th>
              <th data-sort="eco">Eco-Friendly ↕</th>
              <th data-sort="price">Price ($) ↕</th>
            </tr>
          </thead>
          <tbody id="matTbody">
            {mats.map(mat => (
              <tr>
                <td class="font-medium">{mat.brand}</td>
                <td class="font-bold text-[var(--accent-color)]" data-val={mat.thickness}>{mat.thickness}mm</td>
                <td><span class="type-badge">{mat.material}</span></td>
                <td>{mat.grip}</td>
                <td data-val={mat.weight}>{mat.weight} lbs</td>
                <td>{mat.eco}</td>
                <td class="font-mono text-sm" data-val={mat.price}>${mat.price.toFixed(2)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="faq-list">
        {schema[1].mainEntity.map((faq: any) => (
          <div class="faq-item">
            <div class="faq-q">{faq.name}</div>
            <div class="faq-a">{faq.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    const tbody = document.getElementById('matTbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    let currentSort = { col: null, asc: true };

    function applySort() {
      rows.sort((a, b) => {
        let valA, valB;
        if (['brand', 'material', 'grip', 'eco'].includes(currentSort.col)) {
          const idx = currentSort.col === 'brand' ? 1 : (currentSort.col === 'material' ? 3 : (currentSort.col === 'grip' ? 4 : 6));
          valA = a.querySelector(`td:nth-child(${idx})`).textContent.trim();
          valB = b.querySelector(`td:nth-child(${idx})`).textContent.trim();
          return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else {
          const idx = currentSort.col === 'thickness' ? 2 : (currentSort.col === 'weight' ? 5 : 7);
          valA = parseFloat(a.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          valB = parseFloat(b.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          return currentSort.asc ? valA - valB : valB - valA;
        }
      });

      tbody.innerHTML = '';
      rows.forEach(r => tbody.appendChild(r));
    }

    function handleSortClick(e) {
      if (e.target.tagName !== 'TH' || !e.target.dataset.sort) return;

      const col = e.target.dataset.sort;
      if (currentSort.col === col) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.col = col;
        currentSort.asc = true;
      }

      applySort();
    }

    document.querySelector('thead').addEventListener('click', handleSortClick);
  </script>
</SiteLayout>
