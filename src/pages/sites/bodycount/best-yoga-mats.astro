---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best Yoga Mats 2026: Manduka, Liforme, Jade & More",
  "description": "Compare the top yoga mats of 2026. Discover the best options for hot yoga, travel, and beginners, featuring Manduka PRO, Liforme, Jade, Lululemon, and Gaiam.",
  "author": {
    "@type": "Organization",
    "name": "BodyCount"
  },
  "publisher": {
    "@type": "Organization",
    "name": "BodyCount",
    "logo": {
      "@type": "ImageObject",
      "url": "https://bodycount.photonbuilder.com/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://bodycount.photonbuilder.com/best-yoga-mats"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which yoga mat is best for hot yoga?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For hot yoga, you need a mat with excellent grip even when wet. The Liforme Yoga Mat and Lululemon The Reversible Mat are top choices due to their highly absorbent and grippy top layers."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best thickness for a yoga mat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A standard yoga mat is about 4mm to 5mm thick, offering a good balance of cushioning and stability. Beginners might prefer a thicker mat (6mm) for extra joint protection, while travel mats are usually 1mm to 2mm thick."
      }
    },
    {
      "@type": "Question",
      "name": "Are eco-friendly yoga mats worth it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, eco-friendly mats made from natural rubber, cork, or recycled materials, like the Jade Harmony, are great for the environment and typically offer excellent grip and durability without toxic chemicals."
      }
    },
    {
      "@type": "Question",
      "name": "How do I clean my yoga mat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cleaning methods vary by material. Closed-cell mats (like Manduka PRO) can be wiped with a damp cloth and mild soap. Open-cell mats (like Liforme) absorb moisture and should be cleaned with specialized mat sprays or a very diluted vinegar/water solution."
      }
    },
    {
      "@type": "Question",
      "name": "Which is the best yoga mat for beginners?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Gaiam Premium Print Yoga Mat is excellent for beginners. It's affordable, provides decent cushioning at 6mm thick, and offers enough grip for basic poses while you learn the practice."
      }
    }
  ]
};

const schema = [articleSchema, faqSchema];

const categories = [
  { name: 'Best Overall & Durability', brand: 'Manduka PRO', desc: 'Incredibly dense cushioning and a lifetime guarantee. A heavy-duty favorite for serious practitioners.' },
  { name: 'Best Grip & Alignment', brand: 'Liforme Yoga Mat', desc: 'Unmatched grip even in sweaty conditions, featuring helpful alignment markers.' },
  { name: 'Best Eco-Friendly', brand: 'Jade Harmony', desc: 'Made from natural rubber for excellent traction and sustainable practice.' },
  { name: 'Best for Hot Yoga', brand: 'Lululemon The Reversible Mat', desc: 'Polyurethane top layer absorbs moisture, providing incredible grip during sweaty sessions.' },
  { name: 'Best for Beginners', brand: 'Gaiam Premium', desc: 'Affordable, thick cushioning, and lightweight. Perfect for starting your yoga journey.' },
];

const mats = [
  { brand: 'Manduka PRO', thickness: '6.0', material: 'PVC (Closed-Cell)', grip: 'Moderate', weight: '7.5', eco: 'No (Lifetime durable)', price: 138 },
  { brand: 'Liforme Yoga Mat', thickness: '4.2', material: 'Natural Rubber + PU', grip: 'High', weight: '5.5', eco: 'Yes', price: 149 },
  { brand: 'Jade Harmony', thickness: '4.7', material: 'Natural Rubber', grip: 'High', weight: '4.3', eco: 'Yes', price: 85 },
  { brand: 'Lululemon Reversible', thickness: '5.0', material: 'Natural Rubber + PU', grip: 'High', weight: '5.2', eco: 'Partial', price: 88 },
  { brand: 'Gaiam Premium', thickness: '6.0', material: 'PVC', grip: 'Moderate', weight: '3.0', eco: 'No', price: 30 },
  { brand: 'Manduka eKO Lite', thickness: '4.0', material: 'Natural Rubber', grip: 'High', weight: '4.5', eco: 'Yes', price: 78 },
  { brand: 'B Yoga B MAT Strong', thickness: '6.0', material: 'Natural Rubber', grip: 'Very High', weight: '5.0', eco: 'Yes', price: 104 },
  { brand: 'Alo Yoga Warrior Mat', thickness: '4.2', material: 'Natural Rubber + PU', grip: 'High', weight: '6.0', eco: 'Partial', price: 128 },
  { brand: 'Jade Voyager (Travel)', thickness: '1.6', material: 'Natural Rubber', grip: 'High', weight: '1.5', eco: 'Yes', price: 45 },
  { brand: 'Manduka PROlite', thickness: '4.7', material: 'PVC (Closed-Cell)', grip: 'Moderate', weight: '4.0', eco: 'No', price: 99 },
];
---

<SiteLayout
  site="bodycount"
  title="Best Yoga Mats 2026: Manduka, Liforme, Jade - BodyCount"
  description="Compare the top yoga mats for hot yoga, travel, and beginners. Detailed comparison of Manduka PRO, Liforme, Jade, Lululemon, and Gaiam."
  canonical="https://bodycount.photonbuilder.com/best-yoga-mats"
  schema={schema}
>
  <style is:global>
    :root {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Category Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .category-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }

    .cat-title {
      font-size: 0.875rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .cat-brand {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .cat-desc {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
    }

    /* Table Styles */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 4rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background: var(--chart-header);
      padding: 1rem 1.5rem;
      font-weight: 600;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
      transition: color 0.2s;
    }

    th:hover {
      color: var(--text-primary);
    }

    td {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--table-hover);
    }

    .type-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-secondary);
    }

    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <div class="hero-section">
    <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Best Yoga Mats of 2026</h1>
    <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
      Find the perfect foundation for your practice. Compare top mats for hot yoga, travel, beginners, and overall performance.
    </p>
  </div>

  <main class="container">
    <section>
      <h2 class="text-3xl font-bold mb-6 text-center">Top Category Winners</h2>
      <div class="category-grid">
        {categories.map(cat => (
          <div class="category-card">
            <div class="cat-title">{cat.name}</div>
            <div class="cat-brand">{cat.brand}</div>
            <div class="cat-desc">{cat.desc}</div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Compare All Yoga Mats</h2>
      <p class="text-[var(--text-secondary)] mb-6 text-sm">Click column headers to sort.</p>

      <div class="table-container">
        <table id="matsTable">
          <thead>
            <tr>
              <th data-sort="brand">Brand ↕</th>
              <th data-sort="thickness">Thickness (mm) ↕</th>
              <th data-sort="material">Material ↕</th>
              <th data-sort="grip">Grip ↕</th>
              <th data-sort="weight">Weight (lbs) ↕</th>
              <th data-sort="eco">Eco-Friendly ↕</th>
              <th data-sort="price">Price ($) ↕</th>
            </tr>
          </thead>
          <tbody id="matsTbody">
            {mats.map(mat => (
              <tr>
                <td class="font-medium">{mat.brand}</td>
                <td class="font-bold text-[var(--accent-color)]" data-val={mat.thickness}>{mat.thickness}mm</td>
                <td><span class="type-badge">{mat.material}</span></td>
                <td>{mat.grip}</td>
                <td data-val={mat.weight}>{mat.weight}</td>
                <td>{mat.eco}</td>
                <td class="font-mono text-sm" data-val={mat.price}>${mat.price.toFixed(2)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqSchema.mainEntity.map((faq: any) => (
          <div class="faq-item">
            <div class="faq-q">{faq.name}</div>
            <div class="faq-a">{faq.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    const tbody = document.getElementById('matsTbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    let currentSort = { col: null, asc: true };

    function applySort() {
      rows.sort((a, b) => {
        let valA, valB;
        if (currentSort.col === 'brand' || currentSort.col === 'material' || currentSort.col === 'grip' || currentSort.col === 'eco') {
            const idx = currentSort.col === 'brand' ? 1 : (currentSort.col === 'material' ? 3 : (currentSort.col === 'grip' ? 4 : 6));
            valA = a.querySelector(`td:nth-child(${idx})`).textContent.trim();
            valB = b.querySelector(`td:nth-child(${idx})`).textContent.trim();
            return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else {
          const idx = currentSort.col === 'thickness' ? 2 : (currentSort.col === 'weight' ? 5 : 7);
          valA = parseFloat(a.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          valB = parseFloat(b.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          return currentSort.asc ? valA - valB : valB - valA;
        }
      });

      tbody.innerHTML = '';
      rows.forEach(r => tbody.appendChild(r));
    }

    function handleSortClick(e) {
      if (e.target.tagName !== 'TH' || !e.target.dataset.sort) return;

      const col = e.target.dataset.sort;
      if (currentSort.col === col) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.col = col;
        currentSort.asc = true;
      }

      applySort();
    }

    document.querySelector('thead').addEventListener('click', handleSortClick);
  </script>
</SiteLayout>
