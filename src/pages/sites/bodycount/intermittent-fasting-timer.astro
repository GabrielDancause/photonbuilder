---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Intermittent Fasting Timer",
      "url": "https://bodycount.photonbuilder.com/intermittent-fasting-timer",
      "description": "Free intermittent fasting timer with live countdown, circular progress ring, fasting stage tracking, and fast history log. Supports 16:8, 18:6, 20:4, OMAD, and 5:2 protocols.",
      "applicationCategory": "HealthAndFitnessApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Article",
      "headline": "Intermittent Fasting Timer — Track Your Fast with Live Countdown",
      "description": "Start and track your intermittent fast with a live countdown timer, progress ring, fasting stage indicators, and history log. Supports all popular IF protocols.",
      "author": { "@type": "Organization", "name": "ijustwantto.live" },
      "publisher": { "@type": "Organization", "name": "ijustwantto.live" },
      "datePublished": "2026-03-21",
      "dateModified": "2026-03-21",
      "mainEntityOfPage": "https://bodycount.photonbuilder.com/intermittent-fasting-timer"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is 16:8 intermittent fasting?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "16:8 intermittent fasting means you fast for 16 hours and eat within an 8-hour window each day. For example, if you eat your last meal at 8 PM, you wouldn't eat again until 12 PM the next day. It's the most popular IF protocol because it's sustainable — most of the fasting happens while you sleep."
          }
        },
        {
          "@type": "Question",
          "name": "What can I drink while fasting?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "During your fasting window you can drink water, black coffee (no sugar, no cream), plain tea, and sparkling water. These have zero or negligible calories and won't break your fast. Avoid diet sodas with artificial sweeteners as some may trigger an insulin response, though research is mixed."
          }
        },
        {
          "@type": "Question",
          "name": "How long does it take to enter ketosis while fasting?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most people begin producing ketones after 12–18 hours of fasting. By 18–24 hours, you're typically in a deeper state of ketosis where your body is primarily burning fat for fuel. The exact timing depends on your glycogen stores, activity level, and what you ate before starting the fast."
          }
        },
        {
          "@type": "Question",
          "name": "Will intermittent fasting slow my metabolism?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Short-term fasting (up to 24–48 hours) does not slow your metabolism. In fact, studies show fasting periods under 72 hours can slightly increase metabolic rate due to norepinephrine release. Metabolic slowdown is associated with prolonged caloric restriction over weeks, not daily time-restricted eating."
          }
        },
        {
          "@type": "Question",
          "name": "Is it okay to exercise while fasting?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, moderate exercise during a fast is generally safe and may enhance fat burning. Light cardio, yoga, and walking are well-tolerated. For intense strength training, some people prefer to train near the end of their fast or during the eating window to have fuel for recovery. Stay hydrated and listen to your body."
          }
        },
        {
          "@type": "Question",
          "name": "What is OMAD (One Meal a Day)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "OMAD stands for One Meal a Day — a 23:1 fasting protocol where you eat all your daily calories in a single meal within a 1-hour window. It's an advanced form of intermittent fasting that maximizes time in ketosis and autophagy. OMAD is not recommended for beginners; start with 16:8 and work up gradually."
          }
        },
        {
          "@type": "Question",
          "name": "What are the stages of fasting?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Fasting progresses through stages: Fed state (0–4 hours) where your body digests food; Early fasting (4–8 hours) when blood sugar drops and insulin decreases; Fat burning (8–12 hours) as glycogen depletes and fat oxidation increases; Ketosis (12–18 hours) when the liver produces ketone bodies; and Deep ketosis (18–24+ hours) with peak fat burning and autophagy (cellular cleanup)."
          }
        },
        {
          "@type": "Question",
          "name": "How do I break a fast properly?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Break your fast with easily digestible foods. Start with something small like bone broth, a handful of nuts, or some avocado. Avoid immediately eating a large, heavy meal — this can cause bloating and digestive discomfort. Wait 15–30 minutes after your first small snack before eating a full meal."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Intermittent Fasting Timer — Free IF Tracker & Countdown | ijustwantto.live"
  description="Free intermittent fasting timer with live countdown, progress ring, and fasting stage tracking. Supports 16:8, 18:6, 20:4, OMAD, and 5:2 protocols."
  canonical="https://bodycount.photonbuilder.com/intermittent-fasting-timer" schema={schema}
>
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        /* Protocol Selector */
        .protocol-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .protocol-btn {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 0.75rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            font-family: var(--font-ui);
            color: var(--text-primary);
        }

        .protocol-btn:hover {
            border-color: var(--accent-color);
        }

        .protocol-btn.active {
            border-color: var(--accent-color);
            background-color: rgba(45, 184, 154, 0.08);
        }

        .protocol-name {
            font-size: 1.25rem;
            font-weight: 700;
            color: #ffffff;
            font-family: var(--font-mono);
        }

        .protocol-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.125rem;
        }

        /* Start Time */
        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        input[type="datetime-local"] {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s;
            color-scheme: dark;
        }

        input[type="datetime-local"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .btn-row {
            display: flex;
            gap: 0.75rem;
        }

        button.start-btn {
            flex: 1;
            background-color: var(--accent-color);
            color: #000000;
            border: none;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            font-family: var(--font-ui);
        }

        button.start-btn:hover {
            background-color: var(--accent-hover);
        }

        button.stop-btn {
            flex: 1;
            background-color: transparent;
            color: #ef4444;
            border: 1px solid #ef4444;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: var(--font-ui);
            display: none;
        }

        button.stop-btn:hover {
            background-color: rgba(239, 68, 68, 0.1);
        }

        .info-note {
            margin-top: 0.75rem;
            font-size: 0.8125rem;
            color: var(--text-secondary);
            display: none;
        }

        /* Timer Display */
        .timer-section {
            display: none;
            text-align: center;
            margin-bottom: 2rem;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .timer-section.active {
            display: block;
        }

        .progress-ring-container {
            position: relative;
            width: 280px;
            height: 280px;
            margin: 0 auto 1.5rem;
        }

        .progress-ring-container svg {
            transform: rotate(-90deg);
        }

        .progress-ring-bg {
            fill: none;
            stroke: var(--border-color);
            stroke-width: 8;
        }

        .progress-ring-fill {
            fill: none;
            stroke: var(--accent-color);
            stroke-width: 8;
            stroke-linecap: round;
            transition: stroke-dashoffset 1s linear;
        }

        .timer-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .timer-countdown {
            font-family: var(--font-mono);
            font-size: 2.5rem;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: 0.05em;
        }

        .timer-label {
            font-size: 0.8125rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .timer-percent {
            font-size: 1rem;
            font-weight: 600;
            color: var(--accent-color);
            margin-top: 0.25rem;
        }

        .timer-times {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 1.5rem;
        }

        .timer-time-block {
            text-align: center;
        }

        .timer-time-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .timer-time-value {
            font-family: var(--font-mono);
            font-size: 1.125rem;
            font-weight: 600;
            color: #ffffff;
        }

        /* Fasting Stages */
        .stages-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            display: none;
        }

        .stages-card.active {
            display: block;
        }

        .stages-title {
            font-size: 1.125rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 1rem;
        }

        .stage-item {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            padding: 0.75rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
            transition: all 0.3s;
            background-color: transparent;
            border: 1px solid transparent;
        }

        .stage-item.current {
            background-color: rgba(45, 184, 154, 0.08);
            border-color: var(--accent-color);
        }

        .stage-item.completed {
            opacity: 0.5;
        }

        .stage-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
        }

        .stage-item.current .stage-icon {
            border-color: var(--accent-color);
            background-color: rgba(45, 184, 154, 0.15);
        }

        .stage-info {
            flex: 1;
        }

        .stage-name {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .stage-item.current .stage-name {
            color: #ffffff;
        }

        .stage-range {
            font-size: 0.75rem;
            color: var(--text-secondary);
            font-family: var(--font-mono);
        }

        .stage-desc {
            font-size: 0.8125rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
            line-height: 1.4;
        }

        .stage-badge {
            display: inline-block;
            font-size: 0.6875rem;
            font-weight: 600;
            padding: 0.125rem 0.5rem;
            border-radius: 4px;
            margin-left: 0.5rem;
        }

        .stage-item.current .stage-badge {
            background-color: rgba(45, 184, 154, 0.15);
            color: var(--accent-color);
        }

        /* Notification toggle */
        .notify-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border-color);
        }

        .notify-label {
            font-size: 0.875rem;
            color: var(--text-primary);
        }

        .notify-sub {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .toggle-switch {
            position: relative;
            width: 44px;
            height: 24px;
            cursor: pointer;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: var(--border-color);
            border-radius: 12px;
            transition: background-color 0.2s;
        }

        .toggle-slider::before {
            content: '';
            position: absolute;
            width: 18px;
            height: 18px;
            left: 3px;
            bottom: 3px;
            background-color: var(--text-primary);
            border-radius: 50%;
            transition: transform 0.2s;
        }

        .toggle-switch input:checked + .toggle-slider {
            background-color: var(--accent-color);
        }

        .toggle-switch input:checked + .toggle-slider::before {
            transform: translateX(20px);
        }

        /* History */
        .history-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .history-title {
            font-size: 1.125rem;
            font-weight: 700;
            color: #ffffff;
        }

        .history-clear {
            background: none;
            border: none;
            color: var(--text-secondary);
            font-size: 0.8125rem;
            cursor: pointer;
            font-family: var(--font-ui);
            transition: color 0.2s;
        }

        .history-clear:hover {
            color: #ef4444;
        }

        .history-empty {
            text-align: center;
            padding: 2rem 0;
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        .history-list {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 0.75rem 1rem;
        }

        .history-item-left {
            display: flex;
            flex-direction: column;
        }

        .history-protocol {
            font-family: var(--font-mono);
            font-size: 0.875rem;
            font-weight: 600;
            color: #ffffff;
        }

        .history-date {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .history-item-right {
            text-align: right;
        }

        .history-duration {
            font-family: var(--font-mono);
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--accent-color);
        }

        .history-status {
            font-size: 0.6875rem;
            font-weight: 600;
            padding: 0.125rem 0.5rem;
            border-radius: 4px;
        }

        .history-status.completed {
            background-color: rgba(45, 184, 154, 0.15);
            color: var(--accent-color);
        }

        .history-status.ended-early {
            background-color: rgba(239, 68, 68, 0.15);
            color: #ef4444;
        }

        /* SEO Content */
        .seo-content {
            margin-top: 3rem;
        }

        .seo-content h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .seo-content h3 {
            font-size: 1.125rem;
            font-weight: 600;
            margin-top: 2rem;
            margin-bottom: 0.75rem;
            color: #ffffff;
        }

        .seo-content p {
            margin-bottom: 1.25rem;
            color: var(--text-secondary);
        }

        .seo-content ul, .seo-content ol {
            margin-bottom: 1.25rem;
            padding-left: 1.5rem;
            color: var(--text-secondary);
        }

        .seo-content li {
            margin-bottom: 0.5rem;
        }

        .seo-content strong {
            color: var(--text-primary);
        }

        /* FAQ */
        .faq-section {
            margin-top: 3rem;
        }

        .faq-section h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: #ffffff;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1.25rem 0;
        }

        .faq-item:first-of-type {
            border-top: 1px solid var(--border-color);
        }

        .faq-q {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-primary);
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .faq-q::after {
            content: '+';
            font-size: 1.25rem;
            color: var(--accent-color);
            flex-shrink: 0;
            transition: transform 0.2s;
        }

        .faq-item.open .faq-q::after {
            content: '\2212';
        }

        .faq-a {
            display: none;
            margin-top: 0.75rem;
            font-size: 0.875rem;
            color: var(--text-secondary);
            line-height: 1.7;
        }

        .faq-item.open .faq-a {
            display: block;
        }

        /* Related Tools */
        .related-tools {
            margin-top: 3rem;
        }

        .related-tools h2 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .related-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        @media (min-width: 640px) {
            .related-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .related-link {
            display: block;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
            text-decoration: none;
            transition: all 0.2s;
        }

        .related-link:hover {
            border-color: var(--accent-color);
            transform: translateY(-1px);
        }

        .related-link h3 {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0.25rem;
        }

        .related-link p {
            font-size: 0.8125rem;
            color: var(--text-secondary);
        }
  </style>

<div class="container">
    <header>
        <h1>Intermittent Fasting Timer</h1>
        <p class="subtitle">Track your fast with a live countdown, progress ring, and fasting stage indicators</p>
    </header>

    <main>
        <!-- Protocol Selection & Start -->
        <div class="card" id="setupCard">
            <label>Select Fasting Protocol</label>
            <div class="protocol-grid">
                <button type="button" class="protocol-btn active" data-protocol="16:8" data-fast="16" data-eat="8" onclick="selectProtocol(this)">
                    <div class="protocol-name">16:8</div>
                    <div class="protocol-label">16h fast / 8h eat</div>
                </button>
                <button type="button" class="protocol-btn" data-protocol="18:6" data-fast="18" data-eat="6" onclick="selectProtocol(this)">
                    <div class="protocol-name">18:6</div>
                    <div class="protocol-label">18h fast / 6h eat</div>
                </button>
                <button type="button" class="protocol-btn" data-protocol="20:4" data-fast="20" data-eat="4" onclick="selectProtocol(this)">
                    <div class="protocol-name">20:4</div>
                    <div class="protocol-label">20h fast / 4h eat</div>
                </button>
                <button type="button" class="protocol-btn" data-protocol="23:1" data-fast="23" data-eat="1" onclick="selectProtocol(this)">
                    <div class="protocol-name">OMAD</div>
                    <div class="protocol-label">23h fast / 1h eat</div>
                </button>
                <button type="button" class="protocol-btn" data-protocol="5:2" data-fast="0" data-eat="0" onclick="selectProtocol(this)">
                    <div class="protocol-name">5:2</div>
                    <div class="protocol-label">5 days eat / 2 days restrict</div>
                </button>
            </div>

            <div id="timerSetup">
                <div class="form-group">
                    <label for="startTime">Fast Start Time</label>
                    <input type="datetime-local" id="startTime">
                </div>

                <div class="btn-row">
                    <button type="button" class="start-btn" id="startBtn" onclick="startFast()">Start Fast</button>
                    <button type="button" class="stop-btn" id="stopBtn" onclick="endFast()">End Fast</button>
                </div>

                <div class="notify-row">
                    <div>
                        <div class="notify-label">Notify when fast ends</div>
                        <div class="notify-sub">Browser notification when your fast is complete</div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" id="notifyToggle" onchange="toggleNotifications()">
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <div id="fivetwonote" class="info-note">
                <strong>5:2 Protocol:</strong> Eat normally for 5 days per week and restrict calories to 500–600 on 2 non-consecutive days. This protocol doesn't use a timed fast — track your restrict days manually.
            </div>
        </div>

        <!-- Timer Display -->
        <div class="timer-section" id="timerSection">
            <div class="card">
                <div class="progress-ring-container">
                    <svg width="280" height="280" viewBox="0 0 280 280">
                        <circle class="progress-ring-bg" cx="140" cy="140" r="124"/>
                        <circle class="progress-ring-fill" id="progressRing" cx="140" cy="140" r="124"
                            stroke-dasharray="779.42" stroke-dashoffset="779.42"/>
                    </svg>
                    <div class="timer-overlay">
                        <div class="timer-countdown" id="countdown">00:00:00</div>
                        <div class="timer-label" id="timerLabel">remaining</div>
                        <div class="timer-percent" id="timerPercent">0% complete</div>
                    </div>
                </div>

                <div class="timer-times">
                    <div class="timer-time-block">
                        <div class="timer-time-label">Started</div>
                        <div class="timer-time-value" id="startedAt">--:--</div>
                    </div>
                    <div class="timer-time-block">
                        <div class="timer-time-label">Protocol</div>
                        <div class="timer-time-value" id="protocolDisplay">--</div>
                    </div>
                    <div class="timer-time-block">
                        <div class="timer-time-label">Ends At</div>
                        <div class="timer-time-value" id="endsAt">--:--</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fasting Stages -->
        <div class="stages-card" id="stagesCard">
            <div class="stages-title">Fasting Stages</div>

            <div class="stage-item" id="stage-fed" data-start="0" data-end="4">
                <div class="stage-icon">1</div>
                <div class="stage-info">
                    <div class="stage-name">Fed State<span class="stage-badge"></span></div>
                    <div class="stage-range">0 – 4 hours</div>
                    <div class="stage-desc">Body digests and absorbs food. Insulin levels are elevated, storing energy.</div>
                </div>
            </div>

            <div class="stage-item" id="stage-early" data-start="4" data-end="8">
                <div class="stage-icon">2</div>
                <div class="stage-info">
                    <div class="stage-name">Early Fasting<span class="stage-badge"></span></div>
                    <div class="stage-range">4 – 8 hours</div>
                    <div class="stage-desc">Blood sugar drops, insulin decreases. Body starts using stored glycogen for fuel.</div>
                </div>
            </div>

            <div class="stage-item" id="stage-fat" data-start="8" data-end="12">
                <div class="stage-icon">3</div>
                <div class="stage-info">
                    <div class="stage-name">Fat Burning<span class="stage-badge"></span></div>
                    <div class="stage-range">8 – 12 hours</div>
                    <div class="stage-desc">Glycogen depleted. Fat oxidation increases as the body shifts to burning stored fat.</div>
                </div>
            </div>

            <div class="stage-item" id="stage-ketosis" data-start="12" data-end="18">
                <div class="stage-icon">4</div>
                <div class="stage-info">
                    <div class="stage-name">Ketosis<span class="stage-badge"></span></div>
                    <div class="stage-range">12 – 18 hours</div>
                    <div class="stage-desc">Liver produces ketone bodies. Brain begins using ketones for fuel alongside glucose.</div>
                </div>
            </div>

            <div class="stage-item" id="stage-deep" data-start="18" data-end="24">
                <div class="stage-icon">5</div>
                <div class="stage-info">
                    <div class="stage-name">Deep Ketosis<span class="stage-badge"></span></div>
                    <div class="stage-range">18 – 24 hours</div>
                    <div class="stage-desc">Peak fat burning and autophagy — cellular cleanup and repair processes accelerate.</div>
                </div>
            </div>
        </div>

        <!-- Fast History -->
        <div class="history-card">
            <div class="history-header">
                <div class="history-title">Fast History</div>
                <button type="button" class="history-clear" id="clearHistoryBtn" onclick="clearHistory()">Clear All</button>
            </div>
            <div id="historyContainer">
                <div class="history-empty">No fasts recorded yet. Start your first fast above.</div>
            </div>
        </div>

        <!-- SEO Content -->
        <div class="seo-content">
            <h2>How the Intermittent Fasting Timer Works</h2>
            <p>This free <strong>intermittent fasting timer</strong> helps you track your fasting window with a live countdown, visual progress ring, and real-time fasting stage indicators. Choose your protocol, set your start time, and let the timer guide you through your fast.</p>

            <h3>What is intermittent fasting?</h3>
            <p>Intermittent fasting (IF) is an eating pattern that cycles between periods of fasting and eating. Unlike traditional diets, IF doesn't restrict <em>what</em> you eat — it restricts <em>when</em> you eat. The most popular method is <strong>16:8 fasting</strong>, where you fast for 16 hours and eat within an 8-hour window each day.</p>

            <h3>Popular intermittent fasting protocols</h3>
            <ul>
                <li><strong>16:8 (Leangains):</strong> Fast 16 hours, eat within 8 hours. The most popular and sustainable protocol for beginners. Most of the fast happens while you sleep.</li>
                <li><strong>18:6:</strong> Fast 18 hours, eat within 6 hours. A step up from 16:8 that increases time in fat-burning and early ketosis states.</li>
                <li><strong>20:4 (Warrior Diet):</strong> Fast 20 hours, eat within a 4-hour window. Reaches deeper ketosis. Best for experienced fasters.</li>
                <li><strong>OMAD (23:1):</strong> One Meal a Day — fast for 23 hours and eat everything in a single meal. Maximum autophagy and ketosis benefits.</li>
                <li><strong>5:2:</strong> Eat normally 5 days per week, restrict to 500–600 calories on 2 non-consecutive days. Flexible and doesn't require daily time-restricted eating.</li>
            </ul>

            <h3>The five stages of fasting</h3>
            <p>As your fast progresses, your body moves through distinct metabolic stages. During the <strong>fed state</strong> (0–4 hours), your body digests food and insulin is elevated. In <strong>early fasting</strong> (4–8 hours), blood sugar drops and your body taps glycogen stores. <strong>Fat burning</strong> kicks in at 8–12 hours as glycogen depletes. Around 12–18 hours, you enter <strong>ketosis</strong> where the liver produces ketone bodies. Beyond 18 hours, <strong>deep ketosis</strong> and autophagy — your body's cellular cleanup process — are in full effect.</p>

            <h3>Tips for successful intermittent fasting</h3>
            <ul>
                <li>Start with 16:8 and gradually increase your fasting window over weeks</li>
                <li>Stay hydrated — drink water, black coffee, and plain tea during fasts</li>
                <li>Break your fast with easily digestible foods, not a heavy meal</li>
                <li>Keep busy during fasting hours — hunger often comes in waves and passes</li>
                <li>Be consistent with your eating window to help your body adapt</li>
                <li>Track your fasts to build accountability and see your progress</li>
            </ul>
        </div>

        <!-- FAQ Section -->
        <div class="faq-section">
            <h2>Frequently Asked Questions</h2>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">What is 16:8 intermittent fasting?</div>
                <div class="faq-a">16:8 intermittent fasting means you fast for 16 hours and eat within an 8-hour window each day. For example, if you eat your last meal at 8 PM, you wouldn't eat again until 12 PM the next day. It's the most popular IF protocol because it's sustainable — most of the fasting happens while you sleep.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">What can I drink while fasting?</div>
                <div class="faq-a">During your fasting window you can drink water, black coffee (no sugar, no cream), plain tea, and sparkling water. These have zero or negligible calories and won't break your fast. Avoid diet sodas with artificial sweeteners as some may trigger an insulin response, though research is mixed.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">How long does it take to enter ketosis while fasting?</div>
                <div class="faq-a">Most people begin producing ketones after 12–18 hours of fasting. By 18–24 hours, you're typically in a deeper state of ketosis where your body is primarily burning fat for fuel. The exact timing depends on your glycogen stores, activity level, and what you ate before starting the fast.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">Will intermittent fasting slow my metabolism?</div>
                <div class="faq-a">Short-term fasting (up to 24–48 hours) does not slow your metabolism. In fact, studies show fasting periods under 72 hours can slightly increase metabolic rate due to norepinephrine release. Metabolic slowdown is associated with prolonged caloric restriction over weeks, not daily time-restricted eating.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">Is it okay to exercise while fasting?</div>
                <div class="faq-a">Yes, moderate exercise during a fast is generally safe and may enhance fat burning. Light cardio, yoga, and walking are well-tolerated. For intense strength training, some people prefer to train near the end of their fast or during the eating window to have fuel for recovery. Stay hydrated and listen to your body.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">What is OMAD (One Meal a Day)?</div>
                <div class="faq-a">OMAD stands for One Meal a Day — a 23:1 fasting protocol where you eat all your daily calories in a single meal within a 1-hour window. It's an advanced form of intermittent fasting that maximizes time in ketosis and autophagy. OMAD is not recommended for beginners; start with 16:8 and work up gradually.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">What are the stages of fasting?</div>
                <div class="faq-a">Fasting progresses through stages: Fed state (0–4 hours) where your body digests food; Early fasting (4–8 hours) when blood sugar drops and insulin decreases; Fat burning (8–12 hours) as glycogen depletes and fat oxidation increases; Ketosis (12–18 hours) when the liver produces ketone bodies; and Deep ketosis (18–24+ hours) with peak fat burning and autophagy (cellular cleanup).</div>
            </div>

            <div class="faq-item">
                <div class="faq-q" onclick="toggleFaq(this)">How do I break a fast properly?</div>
                <div class="faq-a">Break your fast with easily digestible foods. Start with something small like bone broth, a handful of nuts, or some avocado. Avoid immediately eating a large, heavy meal — this can cause bloating and digestive discomfort. Wait 15–30 minutes after your first small snack before eating a full meal.</div>
            </div>
        </div>

        <!-- Related Tools -->
        <div class="related-tools">
            <h2>Related Tools</h2>
            <div class="related-grid">
                <a href="/calorie-calculator" class="related-link">
                    <h3>Calorie Calculator</h3>
                    <p>Calculate your daily calorie needs based on your activity level and goals.</p>
                </a>
                <a href="/macro-calculator" class="related-link">
                    <h3>Macro Calculator</h3>
                    <p>Find your ideal macronutrient split for protein, carbs, and fat.</p>
                </a>
            </div>
        </div>

    </main>
</div>

  <script is:inline>
// State
let fastState = null;
let timerInterval = null;
let notificationsEnabled = false;

// Elements
const startBtn = document.getElementById('startBtn');
const stopBtn = document.getElementById('stopBtn');
const timerSection = document.getElementById('timerSection');
const stagesCard = document.getElementById('stagesCard');
const progressRing = document.getElementById('progressRing');
const countdown = document.getElementById('countdown');
const timerLabel = document.getElementById('timerLabel');
const timerPercent = document.getElementById('timerPercent');
const startedAt = document.getElementById('startedAt');
const protocolDisplay = document.getElementById('protocolDisplay');
const endsAt = document.getElementById('endsAt');
const fivetwonote = document.getElementById('fivetwonote');
const timerSetup = document.getElementById('timerSetup');

const CIRCUMFERENCE = 2 * Math.PI * 124;

// Init
(function init() {
    setDefaultStartTime();
    loadActiveFast();
    renderHistory();
})();

function setDefaultStartTime() {
    const now = new Date();
    const offset = now.getTimezoneOffset();
    const local = new Date(now.getTime() - offset * 60000);
    document.getElementById('startTime').value = local.toISOString().slice(0, 16);
}

function selectProtocol(btn) {
    document.querySelectorAll('.protocol-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');

    var protocol = btn.dataset.protocol;
    if (protocol === '5:2') {
        fivetwonote.style.display = 'block';
        timerSetup.style.display = 'none';
    } else {
        fivetwonote.style.display = 'none';
        timerSetup.style.display = 'block';
    }
}

function getSelectedProtocol() {
    var active = document.querySelector('.protocol-btn.active');
    return {
        protocol: active.dataset.protocol,
        fastHours: parseInt(active.dataset.fast),
        eatHours: parseInt(active.dataset.eat)
    };
}

function startFast() {
    var sel = getSelectedProtocol();
    if (sel.fastHours === 0) return;

    var startInput = document.getElementById('startTime').value;
    if (!startInput) return;

    var startTime = new Date(startInput).getTime();
    var endTime = startTime + (sel.fastHours * 60 * 60 * 1000);

    fastState = { protocol: sel.protocol, fastHours: sel.fastHours, startTime: startTime, endTime: endTime };
    localStorage.setItem('if_active_fast', JSON.stringify(fastState));

    activateTimer();
}

function loadActiveFast() {
    var saved = localStorage.getItem('if_active_fast');
    if (!saved) return;

    fastState = JSON.parse(saved);
    var now = Date.now();

    if (now >= fastState.endTime) {
        completeFast(true);
        return;
    }

    document.querySelectorAll('.protocol-btn').forEach(function(b) {
        b.classList.toggle('active', b.dataset.protocol === fastState.protocol);
    });

    activateTimer();
}

function activateTimer() {
    startBtn.style.display = 'none';
    stopBtn.style.display = 'block';
    timerSection.classList.add('active');
    stagesCard.classList.add('active');

    startedAt.textContent = formatTime12(new Date(fastState.startTime));
    protocolDisplay.textContent = fastState.protocol;
    endsAt.textContent = formatTime12(new Date(fastState.endTime));

    updateTimer();
    timerInterval = setInterval(updateTimer, 1000);
}

function updateTimer() {
    var now = Date.now();
    var elapsed = now - fastState.startTime;
    var total = fastState.endTime - fastState.startTime;
    var remaining = Math.max(0, fastState.endTime - now);

    var progress = Math.min(elapsed / total, 1);
    var offset = CIRCUMFERENCE * (1 - progress);
    progressRing.style.strokeDashoffset = offset;

    var pct = Math.round(progress * 100);
    timerPercent.textContent = pct + '% complete';

    if (remaining <= 0) {
        countdown.textContent = '00:00:00';
        timerLabel.textContent = 'Fast complete!';
        completeFast(false);
        return;
    }

    var h = Math.floor(remaining / 3600000);
    var m = Math.floor((remaining % 3600000) / 60000);
    var s = Math.floor((remaining % 60000) / 1000);
    countdown.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
    timerLabel.textContent = 'remaining';

    var elapsedHours = elapsed / 3600000;
    updateStages(elapsedHours);
}

function updateStages(elapsedHours) {
    var stages = document.querySelectorAll('.stage-item');
    stages.forEach(function(stage) {
        var start = parseFloat(stage.dataset.start);
        var end = parseFloat(stage.dataset.end);
        var badge = stage.querySelector('.stage-badge');

        stage.classList.remove('current', 'completed');

        if (elapsedHours >= end) {
            stage.classList.add('completed');
            badge.textContent = 'Completed';
        } else if (elapsedHours >= start) {
            stage.classList.add('current');
            badge.textContent = 'Current';
        } else {
            badge.textContent = '';
        }
    });
}

function endFast() {
    if (!fastState) return;
    var elapsed = Date.now() - fastState.startTime;
    var totalMs = fastState.endTime - fastState.startTime;
    var completed = elapsed >= totalMs;

    saveToHistory(fastState, elapsed, completed);
    cleanupFast();
}

function completeFast(wasBackground) {
    if (!fastState) return;
    var totalMs = fastState.endTime - fastState.startTime;
    saveToHistory(fastState, totalMs, true);

    if (!wasBackground && notificationsEnabled && 'Notification' in window && Notification.permission === 'granted') {
        new Notification('Fast Complete!', {
            body: 'Your ' + fastState.protocol + ' fast is done. Time to eat!'
        });
    }

    cleanupFast();
}

function cleanupFast() {
    clearInterval(timerInterval);
    timerInterval = null;
    fastState = null;
    localStorage.removeItem('if_active_fast');

    startBtn.style.display = 'block';
    stopBtn.style.display = 'none';
    timerSection.classList.remove('active');
    stagesCard.classList.remove('active');

    progressRing.style.strokeDashoffset = CIRCUMFERENCE;
    countdown.textContent = '00:00:00';
    timerPercent.textContent = '0% complete';

    document.querySelectorAll('.stage-item').forEach(function(s) {
        s.classList.remove('current', 'completed');
        s.querySelector('.stage-badge').textContent = '';
    });

    setDefaultStartTime();
    renderHistory();
}

// History
function saveToHistory(fast, elapsedMs, completed) {
    var history = getHistory();
    history.unshift({
        protocol: fast.protocol,
        startTime: fast.startTime,
        durationMs: elapsedMs,
        targetMs: fast.endTime - fast.startTime,
        completed: completed,
        date: new Date(fast.startTime).toISOString()
    });

    if (history.length > 50) history.length = 50;
    localStorage.setItem('if_history', JSON.stringify(history));
}

function getHistory() {
    try {
        return JSON.parse(localStorage.getItem('if_history') || '[]');
    } catch(e) { return []; }
}

function renderHistory() {
    var container = document.getElementById('historyContainer');
    var history = getHistory();
    var clearBtn = document.getElementById('clearHistoryBtn');

    if (history.length === 0) {
        container.innerHTML = '<div class="history-empty">No fasts recorded yet. Start your first fast above.</div>';
        clearBtn.style.display = 'none';
        return;
    }

    clearBtn.style.display = 'block';
    var html = '<div class="history-list">';

    history.slice(0, 10).forEach(function(item) {
        var durH = Math.floor(item.durationMs / 3600000);
        var durM = Math.floor((item.durationMs % 3600000) / 60000);
        var dateStr = new Date(item.startTime).toLocaleDateString('en-US', {
            month: 'short', day: 'numeric', year: 'numeric'
        });
        var timeStr = formatTime12(new Date(item.startTime));
        var statusClass = item.completed ? 'completed' : 'ended-early';
        var statusText = item.completed ? 'Completed' : 'Ended Early';

        html += '<div class="history-item">' +
            '<div class="history-item-left">' +
                '<div class="history-protocol">' + item.protocol + '</div>' +
                '<div class="history-date">' + dateStr + ' at ' + timeStr + '</div>' +
            '</div>' +
            '<div class="history-item-right">' +
                '<div class="history-duration">' + durH + 'h ' + durM + 'm</div>' +
                '<div class="history-status ' + statusClass + '">' + statusText + '</div>' +
            '</div>' +
        '</div>';
    });

    html += '</div>';
    container.innerHTML = html;
}

function clearHistory() {
    localStorage.removeItem('if_history');
    renderHistory();
}

// Notifications
function toggleNotifications() {
    var toggle = document.getElementById('notifyToggle');
    if (toggle.checked) {
        if ('Notification' in window) {
            Notification.requestPermission().then(function(perm) {
                notificationsEnabled = perm === 'granted';
                toggle.checked = notificationsEnabled;
            });
        } else {
            toggle.checked = false;
        }
    } else {
        notificationsEnabled = false;
    }
}

// Helpers
function formatTime12(date) {
    var h = date.getHours();
    var m = date.getMinutes();
    var ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    return h + ':' + pad(m) + ' ' + ampm;
}

function pad(n) {
    return n.toString().padStart(2, '0');
}

function toggleFaq(el) {
    el.parentElement.classList.toggle('open');
}
  </script>
</SiteLayout>
