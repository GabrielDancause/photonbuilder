---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const faqList = [
  {
    question: "How long does it take to recover from sleep debt?",
    answer: "Sleep debt cannot be fully repaid in a single weekend. It takes multiple days of consistent, adequate sleep to recover from chronic sleep deprivation. A general rule is it takes up to four days to recover from one hour of lost sleep."
  },
  {
    question: "What is the optimal room temperature for sleep?",
    answer: "The optimal room temperature for sleep is typically between 60 to 67 degrees Fahrenheit (15.6 to 19.4 degrees Celsius). A cooler room mimics the body's natural drop in core temperature during sleep."
  },
  {
    question: "Do blue light blocking glasses actually work?",
    answer: "Yes, amber or red-tinted blue light blocking glasses can be effective if worn 2-3 hours before bed. They prevent blue light from suppressing melatonin production, helping your body prepare for sleep."
  },
  {
    question: "How much melatonin should I take for sleep?",
    answer: "For most people, a very low dose of 0.3mg to 1mg is more effective than higher doses (like 5mg or 10mg) which can cause grogginess and disrupt natural production. Melatonin is a sleep timing hormone, not a sleep initiator."
  },
  {
    question: "When should I stop drinking caffeine before bed?",
    answer: "Caffeine has a half-life of 5-7 hours. To minimize sleep disruption, it is recommended to stop consuming caffeine at least 8-10 hours before your intended bedtime."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Evidence-Based Sleep Science Guide",
    "description": "An evidence-based sleep optimization guide covering sleep architecture, circadian rhythms, room conditions, supplements, and more.",
    "author": {
      "@type": "Organization",
      "name": "BodyCount"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/sleep-science-guide"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];

const sleepStages = [
  { name: "NREM Stage 1", description: "The transition phase between wakefulness and sleep. Lasts only a few minutes. Brain waves begin to slow down." },
  { name: "NREM Stage 2", description: "Light sleep where heart rate and breathing stabilize, and body temperature drops. Represents about 50% of total sleep time." },
  { name: "NREM Stage 3 (Deep Sleep)", description: "Crucial for physical restoration, tissue repair, and immune system strengthening. Hardest to wake up from." },
  { name: "REM (Rapid Eye Movement)", description: "Essential for cognitive functions, memory consolidation, and emotional regulation. Dreams primarily occur here." }
];

const chronotypes = [
  { name: "Lion", description: "Early risers who are most productive in the morning and tire by early evening (approx. 15-20% of population)." },
  { name: "Bear", description: "Follow the sun's schedule. Energy peaks mid-morning and dips mid-afternoon (approx. 50% of population)." },
  { name: "Wolf", description: "Night owls who have a hard time waking early and are most productive later in the day (approx. 15-20% of population)." },
  { name: "Dolphin", description: "Light sleepers who often struggle with insomnia and have irregular sleep routines (approx. 10% of population)." }
];

const supplements = [
  { name: "Magnesium Glycinate", details: "Highly bioavailable form of magnesium that promotes relaxation and helps calm the nervous system without causing gastrointestinal distress." },
  { name: "L-Theanine", details: "An amino acid found in tea leaves that increases GABA levels, promoting relaxation and reducing pre-sleep anxiety." },
  { name: "Apigenin", details: "A flavonoid found in chamomile that binds to benzodiazepine receptors in the brain, aiding in sleep initiation." },
  { name: "Melatonin", details: "Best used for shifting circadian rhythms (jet lag, shift work) rather than general insomnia. Keep doses extremely low (0.3mg - 1mg)." }
];
---

<SiteLayout
  site="bodycount"
  title="Evidence-Based Sleep Science Guide | BodyCount"
  description="An evidence-based sleep optimization guide covering sleep architecture, circadian rhythms, room conditions, supplements, and more."
  canonical="https://bodycount.photonbuilder.com/sleep-science-guide"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;
      background-color: var(--bg-color);
      color: var(--text-primary);
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Evidence-Based Sleep Science Guide</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        Optimize your recovery with this comprehensive guide covering sleep architecture, circadian biology, optimal environments, and evidence-based protocols.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Sleep Architecture</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Sleep is not a uniform state but a cycle of distinct stages, each serving critical functions for physical and mental restoration.</div>
        <ul>
          {sleepStages.map(stage => (
            <li><strong>{stage.name}:</strong> {stage.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Circadian Rhythm & Chronotypes</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Your internal 24-hour clock dictates your natural sleep-wake cycle. Understanding your chronotype helps align your schedule for maximum energy.</div>
        <table>
          <thead>
            <tr>
              <th>Chronotype</th>
              <th>Characteristics</th>
            </tr>
          </thead>
          <tbody>
            {chronotypes.map(type => (
              <tr>
                <td><strong>{type.name}</strong></td>
                <td>{type.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Optimal Room Conditions</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Creating a sleep sanctuary is critical for reducing sleep latency and maximizing deep sleep phases.</div>
        <ol>
          <li><strong>Temperature:</strong> Keep the room between 60-67°F (15-19°C). A drop in core body temperature is required to initiate sleep.</li>
          <li><strong>Darkness:</strong> Make the room pitch black. Use blackout curtains or a sleep mask. Any light exposure can suppress melatonin.</li>
          <li><strong>Noise:</strong> Ensure a quiet environment. Use earplugs or a white noise machine to mask disruptive background sounds.</li>
        </ol>
      </section>

      <section>
        <h2>Blue Light & Melatonin</h2>
        <div class="highlight-box">
          <h4>The Light-Dark Cycle</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">Light exposure is the strongest signal for our circadian rhythm.</div>
          <ul style="margin-bottom: 0;">
            <li><strong>Morning Light:</strong> Get 10-30 minutes of natural sunlight outdoors within an hour of waking to set your circadian clock and boost cortisol.</li>
            <li><strong>Evening Light:</strong> Avoid bright overhead lights and screens 1-2 hours before bed. Blue light suppresses natural melatonin release.</li>
          </ul>
        </div>
      </section>

      <section>
        <h2>Evidence-Based Sleep Supplements</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">While behavior change is paramount, targeted supplementation can aid in relaxation and sleep quality.</div>
        <ul>
          {supplements.map(item => (
            <li><strong>{item.name}:</strong> {item.details}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Protocols & Methodologies</h2>
        <ul>
          <li><strong>CBT-I for Insomnia:</strong> Cognitive Behavioral Therapy for Insomnia is the gold-standard treatment, focusing on stimulus control, sleep restriction, and cognitive restructuring.</li>
          <li><strong>Sleep Trackers:</strong> Wearables (Oura, Whoop, Apple Watch) are decent at tracking total sleep time and resting heart rate, but often inaccurate at classifying specific sleep stages (REM vs. Deep).</li>
          <li><strong>Napping Protocol:</strong> Keep naps to 20-30 minutes to avoid sleep inertia (waking up groggy from deep sleep) or opt for a full 90-minute cycle. Avoid napping late in the afternoon.</li>
          <li><strong>Jet Lag Recovery:</strong> Shift your schedule towards the destination time zone before traveling. Fasting during travel and eating at the destination's normal meal times helps reset the circadian rhythm.</li>
          <li><strong>Caffeine Cutoff:</strong> Due to a half-life of 5-7 hours, stop consuming caffeine 8-10 hours before bed to ensure adenosine receptors are not blocked when trying to sleep.</li>
          <li><strong>Sleep Debt Myth:</strong> You cannot effectively "catch up" on severe chronic sleep deprivation by simply sleeping in on the weekends. Consistency is required.</li>
        </ul>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>