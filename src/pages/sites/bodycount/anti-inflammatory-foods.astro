---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const inflammationTypes = [
  { type: "Acute Inflammation", description: "A short-term, natural immune response to injury or illness. Symptoms include redness, heat, swelling, and pain. It resolves once the threat is gone." },
  { type: "Chronic Inflammation", description: "A prolonged, low-grade inflammatory state that persists for months or years. It can silently damage tissues and is linked to numerous chronic diseases." }
];

const inflammatoryMarkers = [
  { marker: "C-Reactive Protein (CRP)", details: "A protein produced by the liver. High levels in the blood indicate inflammation in the body." },
  { marker: "Interleukin-6 (IL-6)", details: "A cytokine that plays a major role in the immune response and inflammation. Elevated levels are associated with chronic conditions." }
];

const topFoods = [
  { food: "Berries", benefits: "Packed with anthocyanins, antioxidants that reduce inflammation and boost immunity." },
  { food: "Fatty Fish", benefits: "Rich in EPA and DHA omega-3 fatty acids, which reduce inflammation that can lead to metabolic syndrome, heart disease, and diabetes." },
  { food: "Turmeric", benefits: "Contains curcumin, a powerful anti-inflammatory compound that is most effective when consumed with black pepper." },
  { food: "Ginger", benefits: "Contains gingerol, which has potent anti-inflammatory and antioxidant properties." },
  { food: "Leafy Greens", benefits: "Spinach, kale, and collards are rich in vitamin K and antioxidants that combat cellular damage." },
  { food: "Extra Virgin Olive Oil", benefits: "Rich in oleocanthal, an antioxidant with properties similar to ibuprofen." },
  { food: "Nuts", benefits: "Almonds and walnuts are excellent sources of anti-inflammatory monounsaturated fats and vitamin E." },
  { food: "Dark Chocolate", benefits: "Contains flavanols that reduce inflammation and keep endothelial cells lining the arteries healthy." },
  { food: "Tomatoes", benefits: "Loaded with vitamin C, potassium, and lycopene, an antioxidant with impressive anti-inflammatory properties." },
  { food: "Avocados", benefits: "Packed with potassium, magnesium, fiber, and heart-healthy monounsaturated fats." },
  { food: "Green Tea", benefits: "High in EGCG, a catechin that reduces inflammation and protects cells from damage." },
  { food: "Peppers", benefits: "Bell peppers and chili peppers are loaded with vitamin C and antioxidants like quercetin and sinapic acid." },
  { food: "Mushrooms", benefits: "Varieties like truffles, portobello, and shiitake contain phenols and other antioxidants." },
  { food: "Grapes", benefits: "Contain anthocyanins and resveratrol, compounds that may protect the heart against inflammation." },
  { food: "Cherries", benefits: "Rich in antioxidants, such as anthocyanins and catechins, which fight inflammation." },
  { food: "Garlic", benefits: "Contains diallyl disulfide, an anti-inflammatory compound that limits the effects of pro-inflammatory cytokines." },
  { food: "Onions", benefits: "A great source of quercetin, which inhibits inflammation-causing leukotrienes, prostaglandins, and histamines." },
  { food: "Beets", benefits: "Rich in betalains, known for their potent antioxidant and anti-inflammatory properties." },
  { food: "Chia Seeds", benefits: "Offer an excellent plant-based source of omega-3 fatty acids, fiber, and protein." },
  { food: "Flaxseeds", benefits: "High in lignans and ALA (alpha-linolenic acid), which help lower inflammatory markers." }
];

const inflammatoryFoods = [
  { food: "Added Sugar", details: "Excess intake triggers the release of inflammatory messengers called cytokines." },
  { food: "Refined Carbohydrates", details: "White bread, pastries, and other refined carbs cause rapid blood sugar spikes, promoting inflammation." },
  { food: "Seed Oils (Debated)", details: "High consumption of omega-6 fatty acids from industrial seed oils may promote inflammation if not balanced with omega-3s." },
  { food: "Alcohol", details: "Heavy drinking weakens the intestinal barrier, allowing toxins to leak into the blood and drive inflammation." }
];

const mediterraneanFramework = [
  { principle: "Plant-Centric Base", description: "Emphasize vegetables, fruits, whole grains, legumes, and nuts as the foundation of every meal." },
  { principle: "Healthy Fats", description: "Use extra virgin olive oil as the primary source of added fat, replacing butter and margarines." },
  { principle: "Quality Protein", description: "Prioritize fish and poultry. Consume red meat rarely and in small portions." },
  { principle: "Herbs and Spices", description: "Use generously to flavor foods and boost antioxidant intake while reducing salt." }
];

const mealPlan = [
  { day: "Day 1", meals: "Breakfast: Oatmeal with berries and walnuts. Lunch: Spinach salad with grilled salmon. Dinner: Turmeric chicken with roasted vegetables." },
  { day: "Day 2", meals: "Breakfast: Chia seed pudding. Lunch: Lentil soup with a side of mixed greens. Dinner: Baked cod with quinoa and asparagus." },
  { day: "Day 3", meals: "Breakfast: Green smoothie with spinach and ginger. Lunch: Quinoa salad with chickpeas and tomatoes. Dinner: Stir-fried tofu with broccoli." },
  { day: "Day 4", meals: "Breakfast: Scrambled eggs with bell peppers. Lunch: Mediterranean tuna salad. Dinner: Grilled mackerel with sweet potato." },
  { day: "Day 5", meals: "Breakfast: Greek yogurt with flaxseeds and cherries. Lunch: Kale salad with avocado and pumpkin seeds. Dinner: Veggie chili." },
  { day: "Day 6", meals: "Breakfast: Whole grain toast with mashed avocado. Lunch: Black bean and corn salad. Dinner: Sautéed shrimp with zucchini noodles." },
  { day: "Day 7", meals: "Breakfast: Porridge with cinnamon and apple slices. Lunch: Roasted beet and walnut salad. Dinner: Baked salmon with a kale and quinoa pilaf." }
];

const supplements = [
  { nutrient: "Omega-3 Fatty Acids", details: "Look for high-quality fish oil or algal oil. A common therapeutic dose ranges from 1,000 to 2,000 mg of combined EPA and DHA per day." },
  { nutrient: "Curcumin", details: "The active compound in turmeric. It has poor bioavailability on its own, so ensure your supplement contains piperine (black pepper extract) or uses liposomal delivery to enhance absorption." }
];

const faqList = [
  {
    question: "How quickly does an anti-inflammatory diet work?",
    answer: "Some people notice improved energy and reduced joint stiffness within a few weeks, though measurable changes in blood markers like CRP may take a few months of consistent dietary habits."
  },
  {
    question: "Can I eat meat on an anti-inflammatory diet?",
    answer: "Yes, but focus on lean proteins like poultry and emphasize fatty fish. Red meat and processed meats should be consumed rarely, as they contain pro-inflammatory compounds."
  },
  {
    question: "Are nightshade vegetables inflammatory?",
    answer: "For most people, nightshades (like tomatoes, eggplants, and peppers) are highly anti-inflammatory due to their antioxidants. However, a small percentage of people with certain autoimmune conditions may have a sensitivity to them."
  },
  {
    question: "Is coffee anti-inflammatory?",
    answer: "Yes, coffee contains polyphenols and other anti-inflammatory compounds. Just be mindful of added sugars or high-calorie creamers, which can negate these benefits."
  },
  {
    question: "What is the best cooking oil to use?",
    answer: "Extra virgin olive oil is considered the gold standard for an anti-inflammatory diet due to its high monounsaturated fat content and potent antioxidants like oleocanthal."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/anti-inflammatory-foods"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<SiteLayout
  site="bodycount"
  title="Anti-Inflammatory Foods Guide | BodyCount"
  description="Science-backed anti-inflammatory diet guide covering foods, meal plans, and supplements."
  canonical="https://bodycount.photonbuilder.com/anti-inflammatory-foods"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Anti-Inflammatory Foods Guide</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        A science-backed guide to understanding inflammation. Learn about acute vs. chronic inflammation, the top anti-inflammatory foods, Mediterranean diet framework, and effective supplementation.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Understanding Inflammation</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">
          Inflammation is your body's way of protecting itself from infection, illness, or injury. However, not all inflammation is the same.
        </div>
        <ul>
          {inflammationTypes.map(item => (
            <li><strong>{item.type}:</strong> {item.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Common Inflammatory Markers</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Healthcare providers often measure these markers in the blood to assess levels of inflammation in the body.</div>
        <ul>
          {inflammatoryMarkers.map(item => (
            <li><strong>{item.marker}:</strong> {item.details}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Top 20 Anti-Inflammatory Foods</h2>
        <table>
          <thead>
            <tr>
              <th>Food</th>
              <th>Benefits</th>
            </tr>
          </thead>
          <tbody>
            {topFoods.map(item => (
              <tr>
                <td><strong>{item.food}</strong></td>
                <td>{item.benefits}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Foods That Cause Inflammation</h2>
        <div class="highlight-box">
          <h4>Dietary Triggers</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">Limit or avoid these foods, as they can promote chronic inflammation and contribute to various health issues.</div>
          <ul style="margin-bottom: 0;">
            {inflammatoryFoods.map(item => (
              <li><strong>{item.food}:</strong> {item.details}</li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <h2>The Mediterranean Diet Framework</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">
          The Mediterranean diet is consistently ranked as one of the best eating patterns for reducing inflammation and promoting longevity.
        </div>
        <ol>
          {mediterraneanFramework.map(item => (
            <li><strong>{item.principle}:</strong> {item.description}</li>
          ))}
        </ol>
      </section>

      <section>
        <h2>7-Day Anti-Inflammatory Meal Plan</h2>
        <table>
          <thead>
            <tr>
              <th>Day</th>
              <th>Meals</th>
            </tr>
          </thead>
          <tbody>
            {mealPlan.map(item => (
              <tr>
                <td><strong>{item.day}</strong></td>
                <td>{item.meals}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Anti-Inflammatory Supplements</h2>
        <ul>
          {supplements.map(item => (
            <li><strong>{item.nutrient}:</strong> {item.details}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
