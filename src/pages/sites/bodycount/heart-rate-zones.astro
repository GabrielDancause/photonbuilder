---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Heart Rate Zone Calculator",
      "url": "https://bodycount.photonbuilder.com/heart-rate-zones.html",
      "description": "Calculate your heart rate zones instantly. Enter your age and optional resting heart rate for personalized training zones using both standard and Karvonen methods. Color-coded zone chart with fat burning, aerobic, and anaerobic ranges.",
      "applicationCategory": "HealthAndFitnessApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are heart rate zones?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Heart rate zones are ranges of heartbeats per minute (bpm) that correspond to different exercise intensities. There are five standard zones, from Zone 1 (light warm-up at 50-60% of max heart rate) to Zone 5 (maximum effort at 90-100% of max heart rate). Training in different zones produces different physiological adaptations — lower zones build aerobic endurance and burn fat, while higher zones improve speed, power, and VO2 max."
          }
        },
        {
          "@type": "Question",
          "name": "How do I calculate my maximum heart rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The most common formula is 220 minus your age. For example, a 30-year-old would have an estimated max heart rate of 190 bpm. While this formula provides a useful estimate, actual max heart rate varies between individuals and can only be precisely determined through a maximal exercise test supervised by a healthcare professional."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Karvonen method?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Karvonen method (also called Heart Rate Reserve method) calculates training zones using your resting heart rate in addition to your max heart rate. The formula is: Target HR = ((Max HR - Resting HR) × intensity%) + Resting HR. This method is considered more accurate because it accounts for individual fitness levels — a lower resting heart rate typically indicates better cardiovascular fitness."
          }
        },
        {
          "@type": "Question",
          "name": "What is the fat burning zone?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The fat burning zone is typically Zone 2, at 60-70% of your maximum heart rate. At this intensity, your body uses a higher percentage of fat as fuel compared to carbohydrates. However, higher-intensity exercise burns more total calories and more total fat per session. The fat burning zone is ideal for longer, steady-state cardio sessions and building aerobic base fitness."
          }
        },
        {
          "@type": "Question",
          "name": "How long should I train in each heart rate zone?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Training distribution depends on your goals. A common approach is the 80/20 rule: 80% of training time in Zones 1-2 (easy effort) and 20% in Zones 3-5 (moderate to hard effort). For general fitness, aim for 150 minutes per week in Zone 2-3. For weight loss, mix Zone 2 sessions (30-60 minutes) with shorter Zone 4-5 intervals. For performance, follow a structured plan that periodizes time across all five zones."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my resting heart rate important?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Resting heart rate (RHR) is a key indicator of cardiovascular fitness. A normal adult RHR ranges from 60-100 bpm, while well-trained athletes may have RHRs of 40-60 bpm. A lower RHR generally indicates a stronger, more efficient heart. Tracking your RHR over time can show improvements in fitness. To measure accurately, check your pulse first thing in the morning before getting out of bed."
          }
        },
        {
          "@type": "Question",
          "name": "Is the 220 minus age formula accurate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 220-minus-age formula provides a rough estimate with a standard deviation of about 10-12 bpm. This means your actual max heart rate could be 10-12 bpm higher or lower than the estimate. The formula tends to overestimate max HR in younger people and underestimate it in older adults. For more precise zones, consider a graded exercise test or use the Karvonen method with your resting heart rate for better personalization."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Heart Rate Zone Calculator — Find Your Target Heart Rate | ijustwantto.live"
  description="Calculate your 5 heart rate training zones instantly. Enter your age for personalized zones using standard or Karvonen method. Color-coded chart with fat burning, aerobic, and anaerobic zone ranges."
  canonical="https://bodycount.photonbuilder.com/heart-rate-zones" schema={schema}
>
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --zone1: #3b82f6;
            --zone2: #10b981;
            --zone3: #f59e0b;
            --zone4: #f97316;
            --zone5: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .form-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .form-col {
            flex: 1;
            min-width: 140px;
        }

        input[type="number"] {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s;
            appearance: none;
        }

        input[type="number"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .method-toggle {
            display: flex;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            overflow: hidden;
            margin-bottom: 1rem;
        }

        .method-btn {
            flex: 1;
            padding: 0.75rem;
            background: none;
            border: none;
            color: var(--text-secondary);
            font-family: var(--font-ui);
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .method-btn.active {
            background-color: var(--accent-color);
            color: #000000;
        }

        .resting-hr-group {
            display: none;
        }

        .resting-hr-group.visible {
            display: block;
        }

        .helper-text {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.35rem;
        }

        button.calculate-btn {
            width: 100%;
            background-color: var(--accent-color);
            color: #000000;
            border: none;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 1rem;
            font-family: var(--font-ui);
        }

        button.calculate-btn:hover {
            background-color: var(--accent-hover);
        }

        .results {
            display: none;
            margin-top: 2rem;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .results.active {
            display: block;
        }

        .max-hr-display {
            text-align: center;
            padding: 1.25rem;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }

        .max-hr-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-bottom: 0.25rem;
        }

        .max-hr-value {
            font-family: var(--font-mono);
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--accent-color);
        }

        .max-hr-unit {
            font-size: 1rem;
            color: var(--text-secondary);
            margin-left: 0.25rem;
        }

        .method-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        /* Zone chart */
        .zone-chart {
            margin: 1.5rem 0;
        }

        .zone-bar {
            display: flex;
            align-items: center;
            margin-bottom: 0.5rem;
            gap: 0.75rem;
        }

        .zone-label-col {
            width: 60px;
            flex-shrink: 0;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .zone-bar-track {
            flex: 1;
            height: 36px;
            background-color: var(--bg-color);
            border-radius: 6px;
            position: relative;
            overflow: hidden;
        }

        .zone-bar-fill {
            height: 100%;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 600;
            color: #000000;
            transition: width 0.5s ease-out;
            min-width: 80px;
        }

        .zone-range-col {
            width: 100px;
            flex-shrink: 0;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-align: right;
        }

        .zone1-fill { background-color: var(--zone1); }
        .zone2-fill { background-color: var(--zone2); }
        .zone3-fill { background-color: var(--zone3); }
        .zone4-fill { background-color: var(--zone4); }
        .zone5-fill { background-color: var(--zone5); }

        /* Zone details */
        .zone-details {
            margin-top: 1.5rem;
        }

        .zone-detail-card {
            display: flex;
            gap: 1rem;
            padding: 1rem;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            margin-bottom: 0.75rem;
            border-left: 4px solid var(--text-secondary);
        }

        .zone-detail-card .zone-num {
            font-family: var(--font-mono);
            font-size: 1.25rem;
            font-weight: 700;
            flex-shrink: 0;
            width: 30px;
            text-align: center;
        }

        .zone-detail-card .zone-info {
            flex: 1;
        }

        .zone-detail-card .zone-name {
            font-weight: 600;
            color: #ffffff;
            font-size: 0.95rem;
            margin-bottom: 0.25rem;
        }

        .zone-detail-card .zone-desc {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 0.35rem;
        }

        .zone-detail-card .zone-activities {
            font-size: 0.8rem;
            color: var(--text-secondary);
            font-style: italic;
        }

        .zone-detail-card .zone-hr-range {
            font-family: var(--font-mono);
            font-size: 0.85rem;
            font-weight: 600;
            flex-shrink: 0;
            text-align: right;
            align-self: center;
        }

        /* Tables */
        .table-container {
            overflow-x: auto;
            margin-bottom: 1rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        th, td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            font-weight: 600;
            color: var(--text-primary);
            background-color: var(--bg-color);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        td {
            color: var(--text-secondary);
        }

        .zone-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 0.5rem;
        }

        /* SEO content */
        .seo-content {
            margin-top: 4rem;
        }

        .seo-content h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .seo-content h3 {
            font-size: 1.125rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
            color: #ffffff;
            margin-top: 2rem;
        }

        .seo-content p {
            margin-bottom: 1.5rem;
            color: var(--text-secondary);
        }

        .seo-content ul, .seo-content ol {
            margin-bottom: 1.5rem;
            padding-left: 1.5rem;
            color: var(--text-secondary);
        }

        .seo-content li {
            margin-bottom: 0.5rem;
        }

        .disclaimer {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-left: 4px solid #f59e0b;
            border-radius: 8px;
            padding: 1.25rem;
            margin: 2rem 0;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .disclaimer strong {
            color: #f59e0b;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1.25rem 0;
        }

        .faq-item:last-child {
            border-bottom: none;
        }

        .faq-q {
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .faq-a {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        footer {
            margin-top: 4rem;
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        footer a {
            color: var(--accent-color);
            text-decoration: none;
        }

        footer a:hover {
            text-decoration: underline;
        }
  </style>

<div class="container">
    <header>
        <h1>Heart Rate Zone Calculator</h1>
        <p class="subtitle">Enter your age to calculate your 5 target heart rate training zones</p>
    </header>

    <main>
        <!-- Calculator -->
        <div class="card">
            <div class="method-toggle">
                <button type="button" class="method-btn active" id="methodStd" onclick="setMethod('standard')">Standard (% Max HR)</button>
                <button type="button" class="method-btn" id="methodKarv" onclick="setMethod('karvonen')">Karvonen (HR Reserve)</button>
            </div>

            <form id="hrForm">
                <div class="form-row">
                    <div class="form-group form-col">
                        <label for="age">Age (years)</label>
                        <input type="number" id="age" name="age" required min="10" max="100" step="1" placeholder="e.g. 30">
                    </div>
                    <div class="form-group form-col resting-hr-group" id="restingGroup">
                        <label for="restingHr">Resting Heart Rate (bpm)</label>
                        <input type="number" id="restingHr" name="restingHr" min="30" max="120" step="1" placeholder="e.g. 65">
                        <div class="helper-text">Measure first thing in the morning</div>
                    </div>
                </div>
                <button type="submit" class="calculate-btn">Calculate Zones</button>
            </form>

            <div id="results" class="results">
                <div class="max-hr-display">
                    <div class="max-hr-label">Estimated Maximum Heart Rate</div>
                    <span class="max-hr-value" id="maxHrValue">190</span>
                    <span class="max-hr-unit">bpm</span>
                    <div class="method-label" id="methodLabel">220 &minus; age formula</div>
                </div>

                <!-- Zone chart bars -->
                <div class="zone-chart" id="zoneChart">
                    <div class="zone-bar">
                        <div class="zone-label-col" style="color:var(--zone5)">Zone 5</div>
                        <div class="zone-bar-track"><div class="zone-bar-fill zone5-fill" id="bar5" style="width:0%"></div></div>
                        <div class="zone-range-col" id="range5">--</div>
                    </div>
                    <div class="zone-bar">
                        <div class="zone-label-col" style="color:var(--zone4)">Zone 4</div>
                        <div class="zone-bar-track"><div class="zone-bar-fill zone4-fill" id="bar4" style="width:0%"></div></div>
                        <div class="zone-range-col" id="range4">--</div>
                    </div>
                    <div class="zone-bar">
                        <div class="zone-label-col" style="color:var(--zone3)">Zone 3</div>
                        <div class="zone-bar-track"><div class="zone-bar-fill zone3-fill" id="bar3" style="width:0%"></div></div>
                        <div class="zone-range-col" id="range3">--</div>
                    </div>
                    <div class="zone-bar">
                        <div class="zone-label-col" style="color:var(--zone2)">Zone 2</div>
                        <div class="zone-bar-track"><div class="zone-bar-fill zone2-fill" id="bar2" style="width:0%"></div></div>
                        <div class="zone-range-col" id="range2">--</div>
                    </div>
                    <div class="zone-bar">
                        <div class="zone-label-col" style="color:var(--zone1)">Zone 1</div>
                        <div class="zone-bar-track"><div class="zone-bar-fill zone1-fill" id="bar1" style="width:0%"></div></div>
                        <div class="zone-range-col" id="range1">--</div>
                    </div>
                </div>

                <!-- Zone detail cards -->
                <div class="zone-details" id="zoneDetails"></div>
            </div>
        </div>

        <!-- Zone Reference Table -->
        <div class="card">
            <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:1rem;">Heart Rate Zone Reference</h2>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Zone</th>
                            <th>Intensity</th>
                            <th>% of Max HR</th>
                            <th>Primary Benefit</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone1)"></span>Zone 1</td>
                            <td>Very Light</td>
                            <td>50 – 60%</td>
                            <td>Recovery, warm-up</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone2)"></span>Zone 2</td>
                            <td>Light</td>
                            <td>60 – 70%</td>
                            <td>Fat burning, endurance</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone3)"></span>Zone 3</td>
                            <td>Moderate</td>
                            <td>70 – 80%</td>
                            <td>Aerobic fitness</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone4)"></span>Zone 4</td>
                            <td>Hard</td>
                            <td>80 – 90%</td>
                            <td>Anaerobic threshold</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone5)"></span>Zone 5</td>
                            <td>Maximum</td>
                            <td>90 – 100%</td>
                            <td>VO2 max, peak power</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Max HR by Age Table -->
        <div class="card">
            <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:1rem;">Maximum Heart Rate by Age</h2>
            <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:1rem;">Estimated max heart rate using the 220 &minus; age formula. Individual results vary by &plusmn;10–12 bpm.</p>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Age</th>
                            <th>Max HR (bpm)</th>
                            <th>Zone 2 Range</th>
                            <th>Zone 4 Range</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>20</td><td>200</td><td>120 – 140</td><td>160 – 180</td></tr>
                        <tr><td>25</td><td>195</td><td>117 – 137</td><td>156 – 176</td></tr>
                        <tr><td>30</td><td>190</td><td>114 – 133</td><td>152 – 171</td></tr>
                        <tr><td>35</td><td>185</td><td>111 – 130</td><td>148 – 167</td></tr>
                        <tr><td>40</td><td>180</td><td>108 – 126</td><td>144 – 162</td></tr>
                        <tr><td>45</td><td>175</td><td>105 – 123</td><td>140 – 158</td></tr>
                        <tr><td>50</td><td>170</td><td>102 – 119</td><td>136 – 153</td></tr>
                        <tr><td>55</td><td>165</td><td>99 – 116</td><td>132 – 149</td></tr>
                        <tr><td>60</td><td>160</td><td>96 – 112</td><td>128 – 144</td></tr>
                        <tr><td>65</td><td>155</td><td>93 – 109</td><td>124 – 140</td></tr>
                        <tr><td>70</td><td>150</td><td>90 – 105</td><td>120 – 135</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- SEO Content -->
        <div class="seo-content">
            <h2>Understanding Heart Rate Zones</h2>
            <p>Heart rate zones are specific ranges of heartbeats per minute that correspond to different levels of exercise intensity. By training in the right zone, you can target specific fitness goals — whether that's burning fat, building aerobic endurance, or pushing your anaerobic limits. Heart rate zone training is used by everyone from casual joggers to elite athletes to optimize their workouts and avoid overtraining.</p>
            <p>Your target heart rate zones are calculated from your maximum heart rate (max HR), which represents the fastest your heart can beat during all-out exertion. The standard estimate is <strong>220 minus your age</strong>, though individual variation means your actual max HR could be 10–12 bpm higher or lower.</p>

            <h2>The 5 Heart Rate Training Zones</h2>

            <h3>Zone 1: Warm-Up (50–60% Max HR)</h3>
            <p>Zone 1 is the lightest intensity. Your breathing is easy and conversational. This zone is ideal for warm-ups, cool-downs, and active recovery between hard training days. It promotes blood flow to muscles without adding training stress. Example activities: easy walking, gentle stretching, light yoga.</p>

            <h3>Zone 2: Fat Burning (60–70% Max HR)</h3>
            <p>Zone 2 is where your body primarily burns fat for fuel. At this comfortable, sustainable pace, you can exercise for extended periods. This zone builds your aerobic base — the foundation of all endurance fitness. Most of your weekly training time should be spent here. Example activities: brisk walking, easy jogging, casual cycling, swimming at a relaxed pace.</p>

            <h3>Zone 3: Aerobic (70–80% Max HR)</h3>
            <p>Zone 3 improves cardiovascular efficiency and aerobic capacity. Breathing becomes heavier but still manageable. You can speak in short sentences but not hold a full conversation. This zone strengthens your heart muscle and improves your body's ability to transport and use oxygen. Example activities: steady-state running, moderate cycling, rowing, group fitness classes.</p>

            <h3>Zone 4: Anaerobic (80–90% Max HR)</h3>
            <p>Zone 4 pushes you past your anaerobic threshold — the point where your body can no longer clear lactic acid as fast as it produces it. Training here improves your lactate threshold, speed, and power. You can only sustain this effort for 10–30 minutes. Example activities: tempo runs, hill repeats, interval training, competitive cycling.</p>

            <h3>Zone 5: VO2 Max (90–100% Max HR)</h3>
            <p>Zone 5 is maximum effort. Your heart and lungs are working at full capacity. Training here improves your VO2 max — the maximum amount of oxygen your body can use during exercise. This zone can only be sustained for short bursts of 1–5 minutes. Example activities: all-out sprints, high-intensity intervals, race finishes, Tabata-style workouts.</p>

            <h2>Standard Method vs. Karvonen Method</h2>
            <p>There are two main approaches to calculating your heart rate zones:</p>
            <ul>
                <li><strong>Standard method (% of Max HR):</strong> Simply multiplies your max heart rate by the zone percentages. Quick and easy, but doesn't account for individual fitness levels.</li>
                <li><strong>Karvonen method (Heart Rate Reserve):</strong> Uses both your max HR and resting HR to calculate zones. The formula is: Target HR = ((Max HR &minus; Resting HR) &times; intensity%) + Resting HR. This method produces more personalized zones because a lower resting heart rate (indicating better fitness) shifts your zones higher.</li>
            </ul>
            <p>The Karvonen method is generally considered more accurate for trained individuals. If you know your resting heart rate, toggle to the Karvonen method above for more personalized results.</p>

            <h3>How to Measure Your Resting Heart Rate</h3>
            <p>For the most accurate resting heart rate measurement:</p>
            <ol>
                <li>Measure first thing in the morning before getting out of bed</li>
                <li>Place two fingers on your wrist (radial pulse) or neck (carotid pulse)</li>
                <li>Count beats for 60 seconds, or count for 15 seconds and multiply by 4</li>
                <li>Measure on 3 consecutive mornings and take the average</li>
                <li>Avoid measuring after caffeine, alcohol, or a stressful night's sleep</li>
            </ol>

            <h3>Tips for Heart Rate Zone Training</h3>
            <ul>
                <li><strong>Use the 80/20 rule:</strong> Spend about 80% of training time in Zones 1–2 and 20% in Zones 3–5 for optimal adaptation without overtraining</li>
                <li><strong>Wear a chest strap or optical HR monitor:</strong> Wrist-based monitors can lag during intervals — chest straps provide the most accurate real-time data</li>
                <li><strong>Don't ignore Zone 2:</strong> Easy training builds the aerobic engine that supports all other zones. Many athletes train too hard too often</li>
                <li><strong>Recalculate periodically:</strong> As your fitness improves, your resting heart rate may drop, shifting your Karvonen-based zones</li>
                <li><strong>Account for conditions:</strong> Heat, humidity, altitude, caffeine, and sleep quality all affect heart rate. Don't chase numbers on tough days</li>
            </ul>

            <div class="disclaimer">
                <strong>Health Disclaimer:</strong> This calculator provides estimated heart rate zones for general fitness purposes only. It is not medical advice. The 220-minus-age formula is an estimate with individual variation of &plusmn;10–12 bpm. If you have a heart condition, take medications that affect heart rate (such as beta-blockers), or are new to exercise, consult your doctor before beginning a heart-rate-based training program. Stop exercising immediately if you feel chest pain, dizziness, or unusual shortness of breath.
            </div>

            <h2>Frequently Asked Questions</h2>

            <div class="faq-item">
                <div class="faq-q">What are heart rate zones?</div>
                <div class="faq-a">Heart rate zones are ranges of heartbeats per minute (bpm) that correspond to different exercise intensities. There are five standard zones, from Zone 1 (light warm-up at 50–60% of max heart rate) to Zone 5 (maximum effort at 90–100% of max heart rate). Training in different zones produces different physiological adaptations — lower zones build aerobic endurance and burn fat, while higher zones improve speed, power, and VO2 max.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">How do I calculate my maximum heart rate?</div>
                <div class="faq-a">The most common formula is 220 minus your age. For example, a 30-year-old would have an estimated max heart rate of 190 bpm. While this formula provides a useful estimate, actual max heart rate varies between individuals and can only be precisely determined through a maximal exercise test supervised by a healthcare professional.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">What is the Karvonen method?</div>
                <div class="faq-a">The Karvonen method (also called Heart Rate Reserve method) calculates training zones using your resting heart rate in addition to your max heart rate. The formula is: Target HR = ((Max HR &minus; Resting HR) &times; intensity%) + Resting HR. This method is considered more accurate because it accounts for individual fitness levels — a lower resting heart rate typically indicates better cardiovascular fitness.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">What is the fat burning zone?</div>
                <div class="faq-a">The fat burning zone is typically Zone 2, at 60–70% of your maximum heart rate. At this intensity, your body uses a higher percentage of fat as fuel compared to carbohydrates. However, higher-intensity exercise burns more total calories and more total fat per session. The fat burning zone is ideal for longer, steady-state cardio sessions and building aerobic base fitness.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">How long should I train in each heart rate zone?</div>
                <div class="faq-a">Training distribution depends on your goals. A common approach is the 80/20 rule: 80% of training time in Zones 1–2 (easy effort) and 20% in Zones 3–5 (moderate to hard effort). For general fitness, aim for 150 minutes per week in Zone 2–3. For weight loss, mix Zone 2 sessions (30–60 minutes) with shorter Zone 4–5 intervals. For performance, follow a structured plan that periodizes time across all five zones.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">Why is my resting heart rate important?</div>
                <div class="faq-a">Resting heart rate (RHR) is a key indicator of cardiovascular fitness. A normal adult RHR ranges from 60–100 bpm, while well-trained athletes may have RHRs of 40–60 bpm. A lower RHR generally indicates a stronger, more efficient heart. Tracking your RHR over time can show improvements in fitness. To measure accurately, check your pulse first thing in the morning before getting out of bed.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">Is the 220 minus age formula accurate?</div>
                <div class="faq-a">The 220-minus-age formula provides a rough estimate with a standard deviation of about 10–12 bpm. This means your actual max heart rate could be 10–12 bpm higher or lower than the estimate. The formula tends to overestimate max HR in younger people and underestimate it in older adults. For more precise zones, consider a graded exercise test or use the Karvonen method with your resting heart rate for better personalization.</div>
            </div>
        </div>
    </main>
</div>

<script is:inline>
var ZONES = [
    { num: 1, name: 'Warm-Up', low: 0.50, high: 0.60, color: 'var(--zone1)', desc: 'Very light effort. Easy breathing, comfortable pace. Ideal for warming up, cooling down, and active recovery days.', activities: 'Walking, light stretching, gentle yoga' },
    { num: 2, name: 'Fat Burning', low: 0.60, high: 0.70, color: 'var(--zone2)', desc: 'Light effort. You can hold a full conversation. Your body primarily uses fat for fuel at this intensity. Builds aerobic base.', activities: 'Brisk walking, easy jogging, casual cycling' },
    { num: 3, name: 'Aerobic', low: 0.70, high: 0.80, color: 'var(--zone3)', desc: 'Moderate effort. Breathing is heavier \u2014 short sentences only. Strengthens cardiovascular system and improves aerobic capacity.', activities: 'Steady running, moderate cycling, swimming, rowing' },
    { num: 4, name: 'Anaerobic', low: 0.80, high: 0.90, color: 'var(--zone4)', desc: 'Hard effort. Breathing is heavy, speaking is difficult. Pushes past lactate threshold. Improves speed and power.', activities: 'Tempo runs, hill repeats, interval training' },
    { num: 5, name: 'VO2 Max', low: 0.90, high: 1.00, color: 'var(--zone5)', desc: 'Maximum effort. Cannot speak. Heart and lungs at full capacity. Only sustainable for 1\u20135 minutes. Boosts VO2 max.', activities: 'All-out sprints, high-intensity intervals, race finishes' }
];

var currentMethod = 'standard';

function setMethod(method) {
    currentMethod = method;
    document.getElementById('methodStd').classList.toggle('active', method === 'standard');
    document.getElementById('methodKarv').classList.toggle('active', method === 'karvonen');
    var group = document.getElementById('restingGroup');
    group.classList.toggle('visible', method === 'karvonen');
    if (method === 'karvonen') {
        document.getElementById('restingHr').setAttribute('required', '');
    } else {
        document.getElementById('restingHr').removeAttribute('required');
    }
}

function calcZones(maxHr, restingHr, method) {
    return ZONES.map(function(z) {
        var low, high;
        if (method === 'karvonen' && restingHr) {
            var reserve = maxHr - restingHr;
            low = Math.round(reserve * z.low + restingHr);
            high = Math.round(reserve * z.high + restingHr);
        } else {
            low = Math.round(maxHr * z.low);
            high = Math.round(maxHr * z.high);
        }
        return { num: z.num, name: z.name, low: z.low, high: z.high, color: z.color, desc: z.desc, activities: z.activities, bpmLow: low, bpmHigh: high };
    });
}

document.getElementById('hrForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var age = parseInt(document.getElementById('age').value);
    if (isNaN(age)) return;

    var maxHr = 220 - age;
    var restingHr = parseInt(document.getElementById('restingHr').value) || 0;

    document.getElementById('maxHrValue').textContent = maxHr;
    if (currentMethod === 'karvonen' && restingHr) {
        document.getElementById('methodLabel').textContent = 'Karvonen method (HR Reserve: ' + (maxHr - restingHr) + ' bpm)';
    } else {
        document.getElementById('methodLabel').textContent = '220 \u2212 age formula';
    }

    var zones = calcZones(maxHr, restingHr, currentMethod);

    // Update bar chart
    zones.forEach(function(z) {
        var barEl = document.getElementById('bar' + z.num);
        var rangeEl = document.getElementById('range' + z.num);
        var widthPct = Math.round((z.bpmHigh / maxHr) * 100);
        barEl.style.width = widthPct + '%';
        barEl.textContent = z.bpmLow + '\u2013' + z.bpmHigh;
        rangeEl.textContent = z.bpmLow + '\u2013' + z.bpmHigh + ' bpm';
    });

    // Update detail cards
    var detailsHtml = '';
    zones.forEach(function(z) {
        detailsHtml += '<div class="zone-detail-card" style="border-left-color:' + z.color + '">' +
            '<div class="zone-num" style="color:' + z.color + '">' + z.num + '</div>' +
            '<div class="zone-info">' +
                '<div class="zone-name">' + z.name + ' (' + Math.round(z.low * 100) + '\u2013' + Math.round(z.high * 100) + '% Max HR)</div>' +
                '<div class="zone-desc">' + z.desc + '</div>' +
                '<div class="zone-activities">Activities: ' + z.activities + '</div>' +
            '</div>' +
            '<div class="zone-hr-range" style="color:' + z.color + '">' + z.bpmLow + '\u2013' + z.bpmHigh + '<br>bpm</div>' +
        '</div>';
    });
    document.getElementById('zoneDetails').innerHTML = detailsHtml;

    document.getElementById('results').classList.add('active');
});
</script>

