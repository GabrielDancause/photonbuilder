---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Heart Rate Zone Calculator",
  "url": "https://photonbuilder.com/health/heart-rate-zones.html",
  "description": "Calculate your heart rate training zones using the standard % of max HR or Karvonen method. Find your fat burning zone, aerobic zone, and target heart rate for every workout.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are heart rate zones?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Heart rate zones are ranges of heartbeats per minute that correspond to different exercise intensities. There are typically 5 zones, from Zone 1 (very light warm-up) to Zone 5 (maximum effort). Training in different zones produces different physiological adaptations — lower zones build endurance and burn fat, while higher zones improve speed and anaerobic capacity."
      }
    },
    {
      "@type": "Question",
      "name": "What is the fat burning zone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The fat burning zone is Zone 2, typically 60-70% of your maximum heart rate. At this intensity, your body uses a higher percentage of fat as fuel compared to carbohydrates. However, higher-intensity exercise burns more total calories and more total fat per session. Zone 2 training is ideal for long, easy sessions and building aerobic base fitness."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my maximum heart rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common formula is 220 minus your age. For example, a 30-year-old would have an estimated max heart rate of 190 bpm. This is a rough estimate — actual max heart rate varies between individuals. A more accurate method is a supervised max heart rate test, but the 220-age formula works well for most people setting training zones."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Karvonen method?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Karvonen method (also called Heart Rate Reserve method) calculates training zones using your resting heart rate in addition to your max heart rate. The formula is: Target HR = ((Max HR − Resting HR) × % Intensity) + Resting HR. This method is considered more accurate because it accounts for your fitness level through your resting heart rate."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good resting heart rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A normal resting heart rate for adults is between 60 and 100 bpm. Well-trained athletes can have resting heart rates as low as 40 bpm. A lower resting heart rate generally indicates better cardiovascular fitness. To measure yours, check your pulse first thing in the morning before getting out of bed, for the most accurate reading."
      }
    },
    {
      "@type": "Question",
      "name": "Which heart rate zone should I train in?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on your goal. For general fitness and fat loss, spend most of your time in Zones 2-3 (60-80% of max HR). For improving race performance, include intervals in Zones 4-5. Most endurance training programs recommend an 80/20 split: 80% of training time in Zones 1-2, and 20% in Zones 4-5. Zone 3 is sometimes called the 'gray zone' and should be used sparingly."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate is the 220-minus-age formula?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 220-minus-age formula has a standard deviation of about 10-12 bpm, meaning your actual max heart rate could be 10-12 beats higher or lower. It tends to overestimate max HR in younger people and underestimate it in older adults. For more accuracy, use the Karvonen method with your resting heart rate, or perform a field test to find your true max HR."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use heart rate zones for weight loss?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. While Zone 2 is called the 'fat burning zone,' the best zone for weight loss depends on your overall training plan. Higher-intensity zones burn more total calories per minute. A mix of Zone 2 sessions (longer, easier workouts) and Zone 4-5 intervals (shorter, intense workouts) is the most effective approach for fat loss and overall fitness improvement."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Heart Rate Zone Calculator — Target Heart Rate Zones | bodycount"
  description="Calculate your heart rate training zones using % of max HR or the Karvonen method. Find your fat burning zone, aerobic zone, and target heart rate for every workout intensity."
  canonical="https://photonbuilder.com/health/heart-rate-zones" schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --zone1-color: #3b82f6;
            --zone2-color: #22c55e;
            --zone3-color: #f59e0b;
            --zone4-color: #f97316;
            --zone5-color: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .form-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .form-col {
            flex: 1;
            min-width: 140px;
        }

        input[type="number"] {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s;
            appearance: none;
        }

        input[type="number"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .helper-text {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .method-toggle-container {
            display: flex;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .method-toggle {
            display: flex;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
        }

        .method-btn {
            background: none;
            border: none;
            color: var(--text-secondary);
            padding: 0.5rem 1.5rem;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: var(--font-ui);
        }

        .method-btn.active {
            background-color: var(--accent-color);
            color: #000000;
        }

        .rhr-input {
            display: none;
        }

        .rhr-input.active {
            display: block;
        }

        button.calculate-btn {
            width: 100%;
            background-color: var(--accent-color);
            color: #000000;
            border: none;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 1rem;
            font-family: var(--font-ui);
        }

        button.calculate-btn:hover {
            background-color: var(--accent-hover);
        }

        .results {
            display: none;
            margin-top: 2rem;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .results.active {
            display: block;
        }

        .summary-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .summary-card {
            flex: 1;
            min-width: 120px;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.25rem;
            text-align: center;
        }

        .summary-card-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .summary-card-value {
            font-family: var(--font-mono);
            font-size: 1.5rem;
            font-weight: 700;
        }

        .summary-card-detail {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .zone-chart {
            margin-bottom: 2rem;
        }

        .zone-bar-wrapper {
            display: flex;
            width: 100%;
            height: 48px;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 1rem;
        }

        .zone-bar-segment {
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            font-weight: 600;
            color: #000;
            transition: width 0.5s ease;
            min-width: 0;
        }

        .zone-table-container {
            overflow-x: auto;
        }

        table.zone-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        table.zone-table th,
        table.zone-table td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        table.zone-table th {
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        table.zone-table td {
            color: var(--text-primary);
        }

        table.zone-table td.zone-name {
            font-weight: 600;
        }

        table.zone-table td.zone-bpm {
            font-family: var(--font-mono);
            font-weight: 600;
        }

        .zone-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 0.5rem;
            vertical-align: middle;
        }

        .training-guide {
            margin-top: 1.5rem;
        }

        .guide-item {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin-bottom: 0.75rem;
        }

        .guide-item-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .guide-item-zone {
            font-weight: 700;
            font-size: 0.9rem;
        }

        .guide-item-intensity {
            font-size: 0.75rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .guide-item-desc {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .guide-item-examples {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 0.5rem;
            font-style: italic;
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 1rem;
            margin-top: 1rem;
        }

        .faq-section {
            margin-top: 2rem;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 0;
        }

        .faq-question {
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-primary);
        }

        .faq-question::after {
            content: '+';
            font-size: 1.25rem;
            color: var(--accent-color);
            transition: transform 0.2s;
        }

        .faq-item.open .faq-question::after {
            content: '−';
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.7;
        }

        .faq-item.open .faq-answer {
            max-height: 500px;
            padding-top: 0.75rem;
        }

        .related-links {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2rem;
        }

        .related-link {
            flex: 1;
            min-width: 200px;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            text-decoration: none;
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }

        .related-link:hover {
            border-color: var(--accent-color);
        }

        .related-link span {
            display: block;
            font-size: 0.75rem;
            color: var(--text-secondary);
            font-weight: 400;
            margin-top: 0.25rem;
        }

        .method-note {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 1rem;
            padding: 0.75rem;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 6px;
        }

        @media (max-width: 640px) {
            h1 { font-size: 1.5rem; }
            .summary-row { flex-direction: column; }
            .zone-bar-segment { font-size: 0.6rem; }
        }
  </style>

  <div class="container">
    <h1>Heart Rate Zone Calculator</h1>
    <p class="subtitle">Find your target heart rate zones for training. Calculate BPM ranges for fat burning, aerobic fitness, and peak performance.</p>

    <div class="card" style="margin-top: 2rem;">
      <div class="method-toggle-container">
        <div class="method-toggle">
          <button class="method-btn active" data-method="standard">% of Max HR</button>
          <button class="method-btn" data-method="karvonen">Karvonen Method</button>
        </div>
      </div>

      <div class="form-row">
        <div class="form-col">
          <div class="form-group">
            <label for="age">Age</label>
            <input type="number" id="age" min="10" max="100" value="30" />
            <div class="helper-text">Max HR = 220 − age</div>
          </div>
        </div>
        <div class="form-col rhr-input" id="rhrGroup">
          <div class="form-group">
            <label for="rhr">Resting Heart Rate (bpm)</label>
            <input type="number" id="rhr" min="30" max="120" value="65" />
            <div class="helper-text">Measure first thing in the morning</div>
          </div>
        </div>
      </div>

      <button class="calculate-btn" id="calculateBtn">Calculate Heart Rate Zones</button>
    </div>

    <div class="results" id="results">
      <div class="card">
        <h2 class="section-title">Your Heart Rate Zones</h2>

        <div class="summary-row">
          <div class="summary-card">
            <div class="summary-card-label">Max Heart Rate</div>
            <div class="summary-card-value" id="maxHrValue" style="color: var(--zone5-color);">—</div>
            <div class="summary-card-detail">bpm</div>
          </div>
          <div class="summary-card" id="rhrCard" style="display:none;">
            <div class="summary-card-label">Resting HR</div>
            <div class="summary-card-value" id="rhrValue" style="color: var(--zone1-color);">—</div>
            <div class="summary-card-detail">bpm</div>
          </div>
          <div class="summary-card" id="hrrCard" style="display:none;">
            <div class="summary-card-label">HR Reserve</div>
            <div class="summary-card-value" id="hrrValue" style="color: var(--accent-color);">—</div>
            <div class="summary-card-detail">bpm</div>
          </div>
          <div class="summary-card">
            <div class="summary-card-label">Fat Burn Zone</div>
            <div class="summary-card-value" id="fatBurnValue" style="color: var(--zone2-color);">—</div>
            <div class="summary-card-detail" id="fatBurnDetail">bpm</div>
          </div>
        </div>

        <div class="method-note" id="methodNote"></div>

        <div class="zone-chart">
          <div class="zone-bar-wrapper" id="zoneBar"></div>
        </div>

        <div class="zone-table-container">
          <table class="zone-table">
            <thead>
              <tr>
                <th>Zone</th>
                <th>Intensity</th>
                <th>BPM Range</th>
                <th>Purpose</th>
              </tr>
            </thead>
            <tbody id="zoneTableBody"></tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <h2 class="section-title">Training Guide</h2>
        <div class="training-guide" id="trainingGuide"></div>
      </div>

      <div class="card faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-item">
          <div class="faq-question">What are heart rate zones?</div>
          <div class="faq-answer">Heart rate zones are ranges of heartbeats per minute that correspond to different exercise intensities. There are typically 5 zones, from Zone 1 (very light warm-up) to Zone 5 (maximum effort). Training in different zones produces different physiological adaptations — lower zones build endurance and burn fat, while higher zones improve speed and anaerobic capacity.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">What is the fat burning zone?</div>
          <div class="faq-answer">The fat burning zone is Zone 2, typically 60-70% of your maximum heart rate. At this intensity, your body uses a higher percentage of fat as fuel compared to carbohydrates. However, higher-intensity exercise burns more total calories and more total fat per session. Zone 2 training is ideal for long, easy sessions and building aerobic base fitness.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">How do I calculate my maximum heart rate?</div>
          <div class="faq-answer">The most common formula is 220 minus your age. For example, a 30-year-old would have an estimated max heart rate of 190 bpm. This is a rough estimate — actual max heart rate varies between individuals. A more accurate method is a supervised max heart rate test, but the 220-age formula works well for most people setting training zones.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">What is the Karvonen method?</div>
          <div class="faq-answer">The Karvonen method (also called Heart Rate Reserve method) calculates training zones using your resting heart rate in addition to your max heart rate. The formula is: Target HR = ((Max HR − Resting HR) × % Intensity) + Resting HR. This method is considered more accurate because it accounts for your fitness level through your resting heart rate.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">What is a good resting heart rate?</div>
          <div class="faq-answer">A normal resting heart rate for adults is between 60 and 100 bpm. Well-trained athletes can have resting heart rates as low as 40 bpm. A lower resting heart rate generally indicates better cardiovascular fitness. To measure yours, check your pulse first thing in the morning before getting out of bed, for the most accurate reading.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Which heart rate zone should I train in?</div>
          <div class="faq-answer">It depends on your goal. For general fitness and fat loss, spend most of your time in Zones 2-3 (60-80% of max HR). For improving race performance, include intervals in Zones 4-5. Most endurance training programs recommend an 80/20 split: 80% of training time in Zones 1-2, and 20% in Zones 4-5. Zone 3 is sometimes called the "gray zone" and should be used sparingly.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">How accurate is the 220-minus-age formula?</div>
          <div class="faq-answer">The 220-minus-age formula has a standard deviation of about 10-12 bpm, meaning your actual max heart rate could be 10-12 beats higher or lower. It tends to overestimate max HR in younger people and underestimate it in older adults. For more accuracy, use the Karvonen method with your resting heart rate, or perform a field test to find your true max HR.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Can I use heart rate zones for weight loss?</div>
          <div class="faq-answer">Yes. While Zone 2 is called the "fat burning zone," the best zone for weight loss depends on your overall training plan. Higher-intensity zones burn more total calories per minute. A mix of Zone 2 sessions (longer, easier workouts) and Zone 4-5 intervals (shorter, intense workouts) is the most effective approach for fat loss and overall fitness improvement.</div>
        </div>
      </div>

      <div class="related-links">
        <a class="related-link" href="/sites/bodycount/calorie-calculator">
          Calorie Calculator
          <span>Calculate daily calorie intake for your goals</span>
        </a>
        <a class="related-link" href="/sites/bodycount/bmi-calculator">
          BMI Calculator
          <span>Check your body mass index</span>
        </a>
      </div>
    </div>
  </div>

  <script type="text/javascript" is:inline>
    const zones = [
      { num: 1, name: 'Zone 1 — Warm Up', low: 0.50, high: 0.60, color: '#3b82f6', purpose: 'Recovery & warm-up', desc: 'Very light activity to warm up or cool down. Improves overall health, aids recovery, and prepares your body for harder sessions.', examples: 'Walking, light stretching, easy cycling' },
      { num: 2, name: 'Zone 2 — Fat Burn', low: 0.60, high: 0.70, color: '#22c55e', purpose: 'Fat burning & endurance', desc: 'Comfortable pace you can sustain for long periods. Maximizes fat oxidation, builds aerobic base, and improves metabolic efficiency. The foundation of endurance training.', examples: 'Easy jogging, brisk walking, light swimming' },
      { num: 3, name: 'Zone 3 — Aerobic', low: 0.70, high: 0.80, color: '#f59e0b', purpose: 'Aerobic fitness', desc: 'Moderate effort where you can still hold a conversation but it feels challenging. Strengthens the heart, improves circulation, and increases aerobic capacity.', examples: 'Steady-state running, moderate cycling, swimming laps' },
      { num: 4, name: 'Zone 4 — Anaerobic', low: 0.80, high: 0.90, color: '#f97316', purpose: 'Speed & power', desc: 'Hard effort where talking becomes difficult. Increases lactate threshold, improves speed endurance, and trains your body to clear lactic acid faster.', examples: 'Tempo runs, interval training, hill repeats' },
      { num: 5, name: 'Zone 5 — Max Effort', low: 0.90, high: 1.00, color: '#ef4444', purpose: 'Maximum performance', desc: 'All-out effort sustainable for only short bursts. Develops maximum speed, power, and neuromuscular capacity. Use sparingly — high injury risk if overdone.', examples: 'Sprints, HIIT intervals, race finishing kicks' }
    ];

    let method = 'standard';

    document.querySelectorAll('.method-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.method-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        method = btn.dataset.method;
        const rhrGroup = document.getElementById('rhrGroup');
        if (method === 'karvonen') {
          rhrGroup.classList.add('active');
        } else {
          rhrGroup.classList.remove('active');
        }
      });
    });

    document.getElementById('calculateBtn').addEventListener('click', calculate);

    function calculate() {
      const age = parseInt(document.getElementById('age').value);
      if (!age || age < 10 || age > 100) return;

      const maxHR = 220 - age;
      const rhr = parseInt(document.getElementById('rhr').value) || 65;
      const hrr = maxHR - rhr;
      const useKarvonen = method === 'karvonen';

      document.getElementById('maxHrValue').textContent = maxHR;

      if (useKarvonen) {
        document.getElementById('rhrCard').style.display = '';
        document.getElementById('hrrCard').style.display = '';
        document.getElementById('rhrValue').textContent = rhr;
        document.getElementById('hrrValue').textContent = hrr;
        document.getElementById('methodNote').textContent = 'Using the Karvonen method: Target HR = ((Max HR \u2212 Resting HR) \u00d7 % Intensity) + Resting HR. This accounts for your fitness level through resting heart rate.';
      } else {
        document.getElementById('rhrCard').style.display = 'none';
        document.getElementById('hrrCard').style.display = 'none';
        document.getElementById('methodNote').textContent = 'Using standard % of Max HR method: Target HR = Max HR \u00d7 % Intensity. For more personalized zones, try the Karvonen method with your resting heart rate.';
      }

      function getBPM(pct) {
        if (useKarvonen) return Math.round(hrr * pct + rhr);
        return Math.round(maxHR * pct);
      }

      const fatLow = getBPM(0.60);
      const fatHigh = getBPM(0.70);
      document.getElementById('fatBurnValue').textContent = fatLow + '\u2013' + fatHigh;
      document.getElementById('fatBurnDetail').textContent = 'bpm (Zone 2)';

      // Zone bar
      const zoneBar = document.getElementById('zoneBar');
      zoneBar.innerHTML = '';
      const totalRange = getBPM(1.0) - getBPM(0.50);
      zones.forEach(z => {
        const low = getBPM(z.low);
        const high = getBPM(z.high);
        const width = ((high - low) / totalRange) * 100;
        const seg = document.createElement('div');
        seg.className = 'zone-bar-segment';
        seg.style.width = width + '%';
        seg.style.backgroundColor = z.color;
        seg.textContent = low + '\u2013' + high;
        zoneBar.appendChild(seg);
      });

      // Zone table
      const tbody = document.getElementById('zoneTableBody');
      tbody.innerHTML = '';
      zones.forEach(z => {
        const low = getBPM(z.low);
        const high = getBPM(z.high);
        const pctLow = Math.round(z.low * 100);
        const pctHigh = Math.round(z.high * 100);
        const tr = document.createElement('tr');
        tr.innerHTML =
          '<td class="zone-name"><span class="zone-dot" style="background-color:' + z.color + '"></span>Zone ' + z.num + '</td>' +
          '<td>' + pctLow + '\u2013' + pctHigh + '%</td>' +
          '<td class="zone-bpm" style="color:' + z.color + '">' + low + '\u2013' + high + ' bpm</td>' +
          '<td>' + z.purpose + '</td>';
        tbody.appendChild(tr);
      });

      // Training guide
      const guide = document.getElementById('trainingGuide');
      guide.innerHTML = '';
      zones.forEach(z => {
        const low = getBPM(z.low);
        const high = getBPM(z.high);
        const item = document.createElement('div');
        item.className = 'guide-item';
        item.innerHTML =
          '<div class="guide-item-header">' +
            '<span class="zone-dot" style="background-color:' + z.color + '"></span>' +
            '<span class="guide-item-zone" style="color:' + z.color + '">' + z.name + '</span>' +
            '<span class="guide-item-intensity">' + low + '\u2013' + high + ' bpm</span>' +
          '</div>' +
          '<div class="guide-item-desc">' + z.desc + '</div>' +
          '<div class="guide-item-examples">Examples: ' + z.examples + '</div>';
        guide.appendChild(item);
      });

      document.getElementById('results').classList.add('active');
      document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // FAQ toggle
    document.querySelectorAll('.faq-question').forEach(q => {
      q.addEventListener('click', () => {
        q.parentElement.classList.toggle('open');
      });
    });

    // Auto-calculate on load
    calculate();
  </script>
</SiteLayout>
