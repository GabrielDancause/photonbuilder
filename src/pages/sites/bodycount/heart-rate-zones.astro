<script is:inline>
const zones = [
    { num: 1, name: 'Zone 1 — Warm-Up', low: 0.50, high: 0.60, benefit: 'Recovery, warm-up, active rest', activities: 'Easy walking, light stretching, gentle cycling', duration: '20–60 min', color: 'var(--zone1)' },
    { num: 2, name: 'Zone 2 — Fat Burn', low: 0.60, high: 0.70, benefit: 'Fat oxidation, aerobic base, endurance', activities: 'Easy jogging, moderate cycling, brisk walking', duration: '30–90 min', color: 'var(--zone2)' },
    { num: 3, name: 'Zone 3 — Cardio', low: 0.70, high: 0.80, benefit: 'Aerobic capacity, cardiovascular fitness', activities: 'Tempo running, steady cycling, group fitness', duration: '20–40 min', color: 'var(--zone3)' },
    { num: 4, name: 'Zone 4 — Threshold', low: 0.80, high: 0.90, benefit: 'Lactate threshold, speed, power', activities: 'Interval training, hill repeats, race pace', duration: '2–8 min intervals', color: 'var(--zone4)' },
    { num: 5, name: 'Zone 5 — Max', low: 0.90, high: 1.00, benefit: 'VO2max, neuromuscular power, sprint speed', activities: 'Sprints, short hill sprints, all-out intervals', duration: '30s–2 min intervals', color: 'var(--zone5)' }
];

let currentMethod = 'standard';

document.getElementById('btnStandard').addEventListener('click', function() {
    currentMethod = 'standard';
    this.classList.add('active');
    document.getElementById('btnKarvonen').classList.remove('active');
});

document.getElementById('btnKarvonen').addEventListener('click', function() {
    currentMethod = 'karvonen';
    this.classList.add('active');
    document.getElementById('btnStandard').classList.remove('active');
});

document.getElementById('hrForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const age = parseInt(document.getElementById('age').value);
    if (isNaN(age) || age < 10 || age > 100) return;

    const restingHR = parseInt(document.getElementById('restingHR').value);
    const hasResting = !isNaN(restingHR) && restingHR >= 30 && restingHR <= 120;

    // Use Tanaka formula as primary: 208 - 0.7 * age
    const maxHR = Math.round(208 - (0.7 * age));
    const maxHR220 = 220 - age;

    // If Karvonen selected but no resting HR, fall back to standard
    let method = currentMethod;
    if (method === 'karvonen' && !hasResting) {
        method = 'standard';
    }

    document.getElementById('maxHRValue').textContent = maxHR;
    document.getElementById('methodLabel').textContent = method === 'karvonen' ? 'Karvonen Method (HR Reserve)' : 'Standard Method (% Max HR)';

    // Formula comparison
    document.getElementById('formula220').innerHTML = maxHR220 + ' <span>bpm</span>';
    document.getElementById('formulaTanaka').innerHTML = maxHR + ' <span>bpm</span>';

    // Calculate zones
    const hrr = hasResting ? maxHR - restingHR : 0;
    const cardsHTML = zones.map(function(z) {
        let lowBPM, highBPM;
        if (method === 'karvonen') {
            lowBPM = Math.round((hrr * z.low) + restingHR);
            highBPM = Math.round((hrr * z.high) + restingHR);
        } else {
            lowBPM = Math.round(maxHR * z.low);
            highBPM = Math.round(maxHR * z.high);
        }

        return '<div class="zone-card">' +
            '<div class="zone-color-bar" style="background:' + z.color + '"></div>' +
            '<div class="zone-content">' +
                '<div class="zone-header">' +
                    '<span class="zone-name">' + z.name + '</span>' +
                    '<span class="zone-bpm">' + lowBPM + ' – ' + highBPM + ' bpm</span>' +
                '</div>' +
                '<div class="zone-percent">' + Math.round(z.low * 100) + '–' + Math.round(z.high * 100) + '% of max HR</div>' +
                '<div class="zone-details">' +
                    '<div><div class="zone-detail-label">Training Benefit</div><div class="zone-detail-value">' + z.benefit + '</div></div>' +
                    '<div><div class="zone-detail-label">Example Activities</div><div class="zone-detail-value">' + z.activities + '</div></div>' +
                    '<div><div class="zone-detail-label">Recommended Duration</div><div class="zone-detail-value">' + z.duration + '</div></div>' +
                '</div>' +
            '</div>' +
        '</div>';
    }).join('');

    document.getElementById('zoneCards').innerHTML = cardsHTML;
    document.getElementById('results').classList.add('active');
});
</script>
