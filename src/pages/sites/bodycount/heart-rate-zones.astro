---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Heart Rate Zone Calculator",
      "url": "https://photonbuilder.com/health/heart-rate-zones",
      "description": "Calculate your heart rate training zones using standard percentage or Karvonen method. See target BPM ranges for all 5 zones with personalized results based on your age and resting heart rate.",
      "applicationCategory": "HealthAndFitnessApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are heart rate zones?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Heart rate zones are ranges of heartbeats per minute that correspond to different exercise intensities. There are five zones, from Zone 1 (light warm-up at 50-60% of max heart rate) to Zone 5 (maximum effort at 90-100%). Training in different zones produces different physiological adaptations — lower zones build aerobic base and burn fat, while higher zones improve speed, power, and VO2max."
          }
        },
        {
          "@type": "Question",
          "name": "How do I calculate my maximum heart rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The most common formula is 220 minus your age. A more accurate formula developed by Tanaka et al. is 208 - (0.7 × age). For example, a 30-year-old would have an estimated max HR of 190 bpm (220-age) or 187 bpm (Tanaka). The only way to determine your true max HR is through a supervised maximal exercise test."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Karvonen method?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Karvonen method (also called Heart Rate Reserve method) uses your resting heart rate to calculate more personalized training zones. The formula is: Target HR = ((Max HR - Resting HR) × % intensity) + Resting HR. It produces higher zone thresholds than the standard method because it accounts for your fitness level through resting heart rate."
          }
        },
        {
          "@type": "Question",
          "name": "Which heart rate zone burns the most fat?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Zone 2 (60-70% of max HR) is commonly called the 'fat-burning zone' because the highest percentage of calories burned comes from fat at this intensity. However, higher-intensity zones burn more total calories per minute. For overall fat loss, a mix of Zone 2 endurance work and higher-intensity intervals is most effective."
          }
        },
        {
          "@type": "Question",
          "name": "How long should I train in each heart rate zone?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "General guidelines: Zone 1 for warm-up and cool-down (5-10 minutes). Zone 2 should make up 70-80% of your training volume — long steady sessions of 30-90 minutes. Zone 3 for tempo runs of 20-40 minutes. Zone 4 intervals of 2-8 minutes with equal rest. Zone 5 short bursts of 30 seconds to 2 minutes with full recovery. Most endurance athletes follow an 80/20 rule: 80% low intensity, 20% high intensity."
          }
        },
        {
          "@type": "Question",
          "name": "What is a good resting heart rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A normal resting heart rate for adults ranges from 60 to 100 bpm. Well-trained athletes may have resting heart rates as low as 40 bpm. Generally, a lower resting heart rate indicates better cardiovascular fitness. Factors that affect resting HR include fitness level, age, body size, medications, stress, and temperature."
          }
        },
        {
          "@type": "Question",
          "name": "Is the 220-minus-age formula accurate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 220-minus-age formula provides a rough estimate but has a standard deviation of about 10-12 bpm, meaning your actual max HR could be significantly higher or lower. The Tanaka formula (208 - 0.7 × age) is considered slightly more accurate based on a meta-analysis of 351 studies. For precise zones, a lab-based maximal exercise test is recommended."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Heart Rate Zone Calculator — Find Your Training Zones | ijustwantto.live"
  description="Calculate your 5 heart rate training zones instantly. Uses standard and Karvonen methods with your age and resting heart rate. See target BPM ranges, training benefits, and recommended activities for each zone."
  canonical="https://photonbuilder.com/health/heart-rate-zones" schema={schema}
>
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --zone1: #3b82f6;
            --zone2: #22c55e;
            --zone3: #eab308;
            --zone4: #f97316;
            --zone5: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .form-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .form-col {
            flex: 1;
            min-width: 140px;
        }

        input[type="number"] {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s;
            appearance: none;
        }

        input[type="number"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .optional-label {
            font-weight: 400;
            color: var(--text-secondary);
            font-size: 0.75rem;
        }

        .method-toggle {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .method-btn {
            flex: 1;
            padding: 0.625rem;
            border: 1px solid var(--border-color);
            background: var(--bg-color);
            color: var(--text-secondary);
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }

        .method-btn.active {
            border-color: var(--accent-color);
            color: var(--accent-color);
            background: rgba(45, 184, 154, 0.08);
        }

        .method-btn:hover:not(.active) {
            border-color: var(--text-secondary);
        }

        button.calculate-btn {
            width: 100%;
            background-color: var(--accent-color);
            color: #000000;
            border: none;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 1rem;
            font-family: var(--font-ui);
        }

        button.calculate-btn:hover {
            background-color: var(--accent-hover);
        }

        .results {
            display: none;
            margin-top: 2rem;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .results.active {
            display: block;
        }

        .max-hr-display {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .max-hr-value {
            font-family: var(--font-mono);
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--accent-color);
        }

        .max-hr-unit {
            font-size: 1rem;
            color: var(--text-secondary);
            margin-left: 0.25rem;
        }

        .max-hr-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .method-label {
            display: inline-block;
            font-size: 0.7rem;
            font-weight: 600;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            background: rgba(45, 184, 154, 0.15);
            color: var(--accent-color);
            margin-top: 0.5rem;
        }

        /* Zone chart */
        .zone-chart {
            margin: 1.5rem 0;
        }

        .zone-bar-container {
            display: flex;
            height: 32px;
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 0.75rem;
        }

        .zone-bar-segment {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
            color: rgba(0,0,0,0.7);
            transition: flex 0.4s ease;
        }

        .zone-bar-1 { background: var(--zone1); flex: 1; }
        .zone-bar-2 { background: var(--zone2); flex: 1; }
        .zone-bar-3 { background: var(--zone3); flex: 1; }
        .zone-bar-4 { background: var(--zone4); flex: 1; }
        .zone-bar-5 { background: var(--zone5); flex: 1; }

        .zone-card {
            display: flex;
            align-items: stretch;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 0.75rem;
            transition: border-color 0.2s;
        }

        .zone-card:hover {
            border-color: var(--text-secondary);
        }

        .zone-color-bar {
            width: 5px;
            flex-shrink: 0;
        }

        .zone-content {
            flex: 1;
            padding: 1rem 1.25rem;
        }

        .zone-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 0.5rem;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .zone-name {
            font-weight: 700;
            font-size: 1rem;
            color: #ffffff;
        }

        .zone-bpm {
            font-family: var(--font-mono);
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--accent-color);
        }

        .zone-percent {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        .zone-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
            font-size: 0.8rem;
        }

        .zone-detail-label {
            color: var(--text-secondary);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.15rem;
        }

        .zone-detail-value {
            color: var(--text-primary);
        }

        @media (max-width: 480px) {
            .zone-details {
                grid-template-columns: 1fr;
            }
        }

        /* Formula comparison */
        .formula-comparison {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1rem;
        }

        .formula-box {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
            text-align: center;
        }

        .formula-name {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .formula-expr {
            font-family: var(--font-mono);
            font-size: 0.85rem;
            color: var(--text-primary);
            margin-bottom: 0.5rem;
        }

        .formula-result {
            font-family: var(--font-mono);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent-color);
        }

        .formula-result span {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 400;
        }

        @media (max-width: 480px) {
            .formula-comparison {
                grid-template-columns: 1fr;
            }
        }

        /* Tables */
        .table-container {
            overflow-x: auto;
            margin-bottom: 1rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        th, td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            font-weight: 600;
            color: var(--text-primary);
            background-color: var(--bg-color);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        td {
            color: var(--text-secondary);
        }

        .zone-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 0.5rem;
        }

        /* SEO content */
        .seo-content {
            margin-top: 4rem;
        }

        .seo-content h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .seo-content h3 {
            font-size: 1.125rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
            color: #ffffff;
            margin-top: 2rem;
        }

        .seo-content p {
            margin-bottom: 1.5rem;
            color: var(--text-secondary);
        }

        .seo-content ul, .seo-content ol {
            margin-bottom: 1.5rem;
            padding-left: 1.5rem;
            color: var(--text-secondary);
        }

        .seo-content li {
            margin-bottom: 0.5rem;
        }

        .disclaimer {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-left: 4px solid #f59e0b;
            border-radius: 8px;
            padding: 1.25rem;
            margin: 2rem 0;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .disclaimer strong {
            color: #f59e0b;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1.25rem 0;
        }

        .faq-item:last-child {
            border-bottom: none;
        }

        .faq-q {
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .faq-a {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        footer {
            margin-top: 4rem;
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        footer a {
            color: var(--accent-color);
            text-decoration: none;
        }

        footer a:hover {
            text-decoration: underline;
        }
  </style>

<div class="container">
    <header>
        <h1>Heart Rate Zone Calculator</h1>
        <p class="subtitle">Enter your age to calculate your 5 training heart rate zones. Add resting heart rate for Karvonen method.</p>
    </header>

    <main>
        <!-- Calculator -->
        <div class="card">
            <form id="hrForm">
                <div class="form-row">
                    <div class="form-group form-col">
                        <label for="age">Age (years)</label>
                        <input type="number" id="age" name="age" required min="10" max="100" step="1" placeholder="e.g. 30">
                    </div>
                    <div class="form-group form-col">
                        <label for="restingHR">Resting Heart Rate <span class="optional-label">(optional, for Karvonen)</span></label>
                        <input type="number" id="restingHR" name="restingHR" min="30" max="120" step="1" placeholder="e.g. 65">
                    </div>
                </div>

                <label style="margin-bottom:0.5rem;">Calculation Method</label>
                <div class="method-toggle">
                    <button type="button" class="method-btn active" data-method="standard" id="btnStandard">Standard (% of Max HR)</button>
                    <button type="button" class="method-btn" data-method="karvonen" id="btnKarvonen">Karvonen (HR Reserve)</button>
                </div>

                <button type="submit" class="calculate-btn">Calculate Zones</button>
            </form>

            <div id="results" class="results">
                <div class="max-hr-display">
                    <div><span class="max-hr-value" id="maxHRValue">190</span><span class="max-hr-unit">bpm</span></div>
                    <div class="max-hr-label">Estimated Max Heart Rate</div>
                    <div class="method-label" id="methodLabel">Standard Method</div>
                </div>

                <!-- Visual zone bar -->
                <div class="zone-chart">
                    <div class="zone-bar-container">
                        <div class="zone-bar-segment zone-bar-1" id="bar1">Z1</div>
                        <div class="zone-bar-segment zone-bar-2" id="bar2">Z2</div>
                        <div class="zone-bar-segment zone-bar-3" id="bar3">Z3</div>
                        <div class="zone-bar-segment zone-bar-4" id="bar4">Z4</div>
                        <div class="zone-bar-segment zone-bar-5" id="bar5">Z5</div>
                    </div>
                </div>

                <!-- Zone cards -->
                <div id="zoneCards"></div>

                <!-- Formula comparison -->
                <div style="margin-top:1.5rem;">
                    <div style="font-size:0.875rem;font-weight:600;color:#fff;margin-bottom:0.75rem;">Max Heart Rate Formula Comparison</div>
                    <div class="formula-comparison">
                        <div class="formula-box">
                            <div class="formula-name">Traditional</div>
                            <div class="formula-expr">220 − age</div>
                            <div class="formula-result" id="formula220"><span>bpm</span></div>
                        </div>
                        <div class="formula-box">
                            <div class="formula-name">Tanaka (2001)</div>
                            <div class="formula-expr">208 − (0.7 × age)</div>
                            <div class="formula-result" id="formulaTanaka"><span>bpm</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Zone reference table -->
        <div class="card">
            <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:1rem;">Heart Rate Zone Overview</h2>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Zone</th>
                            <th>Intensity</th>
                            <th>% of Max HR</th>
                            <th>Primary Benefit</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone1)"></span>Zone 1</td>
                            <td>Very Light</td>
                            <td>50 – 60%</td>
                            <td>Recovery &amp; warm-up</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone2)"></span>Zone 2</td>
                            <td>Light</td>
                            <td>60 – 70%</td>
                            <td>Fat burn &amp; endurance base</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone3)"></span>Zone 3</td>
                            <td>Moderate</td>
                            <td>70 – 80%</td>
                            <td>Aerobic fitness</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone4)"></span>Zone 4</td>
                            <td>Hard</td>
                            <td>80 – 90%</td>
                            <td>Lactate threshold</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone5)"></span>Zone 5</td>
                            <td>Maximum</td>
                            <td>90 – 100%</td>
                            <td>VO2max &amp; speed</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Zone benefits table -->
        <div class="card">
            <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:1rem;">Zone Benefits: What Each Zone Trains</h2>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Zone</th>
                            <th>Trains</th>
                            <th>Fuel Source</th>
                            <th>RPE</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone1)"></span>Zone 1</td>
                            <td>Active recovery, warm-up/cool-down</td>
                            <td>Mostly fat</td>
                            <td>2–3 / 10</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone2)"></span>Zone 2</td>
                            <td>Aerobic base, fat oxidation, endurance</td>
                            <td>Fat &amp; some carbs</td>
                            <td>4–5 / 10</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone3)"></span>Zone 3</td>
                            <td>Aerobic fitness, cardiovascular stamina</td>
                            <td>Mixed fat &amp; carbs</td>
                            <td>5–6 / 10</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone4)"></span>Zone 4</td>
                            <td>Lactate threshold, speed endurance</td>
                            <td>Mostly carbs</td>
                            <td>7–8 / 10</td>
                        </tr>
                        <tr>
                            <td><span class="zone-dot" style="background:var(--zone5)"></span>Zone 5</td>
                            <td>VO2max, anaerobic power, sprint speed</td>
                            <td>Almost all carbs</td>
                            <td>9–10 / 10</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Age-based max HR table -->
        <div class="card">
            <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:1rem;">Estimated Max Heart Rate by Age</h2>
            <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:1rem;">Max HR estimates using 220−age formula. Individual variation of ±10–12 bpm is normal.</p>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Age</th>
                            <th>Max HR (220−age)</th>
                            <th>Zone 2 Range</th>
                            <th>Zone 4 Range</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>20</td><td>200 bpm</td><td>120 – 140</td><td>160 – 180</td></tr>
                        <tr><td>25</td><td>195 bpm</td><td>117 – 137</td><td>156 – 176</td></tr>
                        <tr><td>30</td><td>190 bpm</td><td>114 – 133</td><td>152 – 171</td></tr>
                        <tr><td>35</td><td>185 bpm</td><td>111 – 130</td><td>148 – 167</td></tr>
                        <tr><td>40</td><td>180 bpm</td><td>108 – 126</td><td>144 – 162</td></tr>
                        <tr><td>45</td><td>175 bpm</td><td>105 – 123</td><td>140 – 158</td></tr>
                        <tr><td>50</td><td>170 bpm</td><td>102 – 119</td><td>136 – 153</td></tr>
