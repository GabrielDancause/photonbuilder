---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Complete TDEE Guide: Total Daily Energy Expenditure Explained",
  "description": "Everything you need to know about Total Daily Energy Expenditure (TDEE). Understand BMR formulas, activity multipliers, how to calculate macros, and adjust for cutting or bulking.",
  "author": {
    "@type": "Organization",
    "name": "BodyCount"
  },
  "publisher": {
    "@type": "Organization",
    "name": "BodyCount",
    "logo": {
      "@type": "ImageObject",
      "url": "https://bodycount.photonbuilder.com/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://bodycount.photonbuilder.com/tdee-guide"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What exactly is TDEE?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Total Daily Energy Expenditure (TDEE) is the total number of calories your body burns in a 24-hour period. It consists of your Basal Metabolic Rate (BMR), Non-Exercise Activity Thermogenesis (NEAT), the Thermic Effect of Food (TEF), and Exercise Activity Thermogenesis (EAT)."
      }
    },
    {
      "@type": "Question",
      "name": "Which BMR formula should I use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Mifflin-St Jeor equation is generally considered the most accurate for the average population. However, if you know your exact body fat percentage and have a significant amount of muscle mass, the Katch-McArdle formula is typically the most precise as it accounts for lean body mass."
      }
    },
    {
      "@type": "Question",
      "name": "What is adaptive thermogenesis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Adaptive thermogenesis (often called metabolic adaptation) is your body's response to a calorie deficit. When you eat less and lose weight, your body burns fewer calories than expected to conserve energy. This is why weight loss often slows down and why diet breaks or reverse dieting can be beneficial."
      }
    },
    {
      "@type": "Question",
      "name": "How large should my calorie deficit or surplus be?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For sustainable weight loss (cutting), a deficit of 300 to 500 calories per day is recommended, aiming for 0.5 to 1 lb of fat loss per week. For muscle gain (bulking), a modest surplus of 200 to 300 calories is usually sufficient to maximize muscle growth while minimizing excess fat gain."
      }
    },
    {
      "@type": "Question",
      "name": "What is NEAT and why is it important?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "NEAT stands for Non-Exercise Activity Thermogenesis. It represents all the calories you burn doing things other than sleeping, eating, or purposeful exercise. This includes walking around the house, fidgeting, typing, and maintaining posture. NEAT can account for a massive variation in daily calorie burn between individuals and is often the first thing to drop when you diet."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Complete TDEE Guide | Total Daily Energy Expenditure"
  description="Complete guide to Total Daily Energy Expenditure (TDEE). Learn BMR formulas, activity multipliers, macros, cutting vs bulking, NEAT, and TEF."
  canonical="https://bodycount.photonbuilder.com/tdee-guide"
  schema={articleSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="page-wrapper">
    <div class="container">
      <header class="hero-section">
        <h1>Complete Guide to TDEE</h1>
        <p class="subtitle">Master your metabolism. Understand exactly how your body burns energy and how to calculate your nutritional needs for any goal.</p>
      </header>

      <section class="content-section">
        <h2>What is TDEE?</h2>
        <p><strong>Total Daily Energy Expenditure (TDEE)</strong> is the holy grail of nutrition. It is the total number of calories your body burns in a given 24-hour period. Whether you want to lose fat, build muscle, or simply maintain your current physique, your TDEE is the baseline number you must know.</p>

        <p>Your TDEE isn't a single, static number. It's dynamic and fluctuates based on several components:</p>

        <div class="component-grid">
          <div class="component-card">
            <h3>1. BMR (70%)</h3>
            <p><strong>Basal Metabolic Rate:</strong> The energy required just to keep you alive at complete rest (breathing, brain function, cell turnover).</p>
          </div>
          <div class="component-card">
            <h3>2. NEAT (15%)</h3>
            <p><strong>Non-Exercise Activity:</strong> Fidgeting, walking to the fridge, standing, and all daily unconscious movement.</p>
          </div>
          <div class="component-card">
            <h3>3. TEF (10%)</h3>
            <p><strong>Thermic Effect of Food:</strong> The calories your body burns simply breaking down and digesting the food you eat.</p>
          </div>
          <div class="component-card">
            <h3>4. EAT (5%)</h3>
            <p><strong>Exercise Activity:</strong> The actual calories burned during deliberate, planned workouts (lifting, running, etc.).</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Calculating BMR: The Formulas</h2>
        <p>Because BMR makes up the vast majority of your TDEE, getting an accurate estimate is crucial. Over the years, scientists have developed several formulas. Here are the three most common:</p>

        <div class="formula-box">
          <h3>Mifflin-St Jeor Equation (Most Popular)</h3>
          <p>Considered the gold standard for the modern, general population. It relies on age, height, and weight.</p>
          <ul>
            <li><strong>Men:</strong> (10 × weight in kg) + (6.25 × height in cm) - (5 × age in years) + 5</li>
            <li><strong>Women:</strong> (10 × weight in kg) + (6.25 × height in cm) - (5 × age in years) - 161</li>
          </ul>
        </div>

        <div class="formula-box">
          <h3>Harris-Benedict Equation (The Original)</h3>
          <p>Created in 1919 and revised in 1984. It tends to slightly overestimate calorie needs for modern, more sedentary populations compared to Mifflin-St Jeor.</p>
          <ul>
            <li><strong>Men:</strong> 88.362 + (13.397 × weight in kg) + (4.799 × height in cm) - (5.677 × age in years)</li>
            <li><strong>Women:</strong> 447.593 + (9.247 × weight in kg) + (3.098 × height in cm) - (4.330 × age in years)</li>
          </ul>
        </div>

        <div class="formula-box">
          <h3>Katch-McArdle Formula (Most Accurate)</h3>
          <p>Unlike the others, this formula doesn't care about your gender, age, or total body weight. It only cares about your <strong>Lean Body Mass (LBM)</strong>. Muscle tissue burns more calories at rest than fat tissue. If you know your body fat percentage, this is the formula to use.</p>
          <ul>
            <li><strong>Formula:</strong> 370 + (21.6 × Lean Body Mass in kg)</li>
          </ul>
        </div>
      </section>

      <section class="content-section">
        <h2>Activity Multipliers Explained</h2>
        <p>Once you have your BMR, you must multiply it by an "Activity Factor" to find your TDEE. This is where most people make mistakes—usually by overestimating how active they are.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Activity Level</th>
                <th>Multiplier</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Sedentary</strong></td>
                <td>BMR × 1.2</td>
                <td>Office job, little to no exercise. (Most modern workers)</td>
              </tr>
              <tr>
                <td><strong>Lightly Active</strong></td>
                <td>BMR × 1.375</td>
                <td>Light exercise or sports 1-3 days a week.</td>
              </tr>
              <tr>
                <td><strong>Moderately Active</strong></td>
                <td>BMR × 1.55</td>
                <td>Moderate exercise or sports 3-5 days a week.</td>
              </tr>
              <tr>
                <td><strong>Very Active</strong></td>
                <td>BMR × 1.725</td>
                <td>Hard exercise or sports 6-7 days a week.</td>
              </tr>
              <tr>
                <td><strong>Extra Active</strong></td>
                <td>BMR × 1.9</td>
                <td>Very hard exercise/physical job or 2x training.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Adjusting for Goals: Cutting vs. Bulking</h2>
        <p>Your TDEE is your maintenance number. Eating this exact amount means your weight will stay the same. To change your body composition, you must manipulate your intake relative to your TDEE.</p>

        <div class="goal-grid">
          <div class="goal-card cutting">
            <h3>Cutting (Fat Loss)</h3>
            <p>To lose fat, you must eat less than your TDEE (a calorie deficit).</p>
            <ul>
              <li><strong>Moderate Cut:</strong> TDEE - 500 calories (Yields ~1lb loss per week)</li>
              <li><strong>Aggressive Cut:</strong> TDEE - 750 to 1000 calories (Risk of muscle loss)</li>
            </ul>
            <p class="note">Never drop your calories below your BMR for extended periods.</p>
          </div>

          <div class="goal-card bulking">
            <h3>Bulking (Muscle Gain)</h3>
            <p>To build muscle optimally, you must eat more than your TDEE (a calorie surplus).</p>
            <ul>
              <li><strong>Lean Bulk:</strong> TDEE + 200 to 300 calories (Maximizes muscle, limits fat)</li>
              <li><strong>Dirty Bulk:</strong> TDEE + 500+ calories (Faster weight gain, but mostly fat)</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Calculating Macros from TDEE</h2>
        <p>Once you have your target daily calorie intake (TDEE ± your goal adjustment), you need to break those calories down into macronutrients: Protein, Fat, and Carbohydrates.</p>

        <div class="macro-steps">
          <div class="step">
            <span class="step-num">1</span>
            <div>
              <h4>Set Protein</h4>
              <p>Aim for 0.8g to 1g of protein per pound of body weight. (Protein has 4 calories per gram).</p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <div>
              <h4>Set Fats</h4>
              <p>Aim for 0.3g to 0.4g of fat per pound of body weight. Do not drop fats too low, as they are essential for hormone production. (Fat has 9 calories per gram).</p>
            </div>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <div>
              <h4>Fill the rest with Carbs</h4>
              <p>Subtract the calories of your protein and fats from your daily target. Divide the remaining calories by 4. That is your daily carbohydrate target in grams.</p>
            </div>
          </div>
        </div>

        <div class="example-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 2rem;">
          <div class="example-box" style="margin-top: 0;">
            <h4>Example 1: The Average Male (Maintenance)</h4>
            <p><strong>Subject:</strong> 180lb Male. <strong>Target:</strong> 2,600 calories</p>
            <ul>
              <li><strong>Protein (1g/lb):</strong> 180g (720 cal)</li>
              <li><strong>Fats (0.4g/lb):</strong> 72g (648 cal)</li>
              <li><strong>Remaining Carbs:</strong> 1,232 cal ÷ 4 = 308g</li>
            </ul>
            <p><strong>Macros:</strong> 180P / 72F / 308C</p>
          </div>

          <div class="example-box" style="margin-top: 0;">
            <h4>Example 2: Petite Female (Cutting)</h4>
            <p><strong>Subject:</strong> 130lb Female. <strong>Target:</strong> 1,500 calories</p>
            <ul>
              <li><strong>Protein (1g/lb):</strong> 130g (520 cal)</li>
              <li><strong>Fats (0.35g/lb):</strong> 45g (405 cal)</li>
              <li><strong>Remaining Carbs:</strong> 575 cal ÷ 4 = 143g</li>
            </ul>
            <p><strong>Macros:</strong> 130P / 45F / 143C</p>
          </div>

          <div class="example-box" style="margin-top: 0;">
            <h4>Example 3: Heavyweight (Bulking)</h4>
            <p><strong>Subject:</strong> 210lb Male. <strong>Target:</strong> 3,400 calories</p>
            <ul>
              <li><strong>Protein (0.8g/lb):</strong> 168g (672 cal)</li>
              <li><strong>Fats (0.4g/lb):</strong> 84g (756 cal)</li>
              <li><strong>Remaining Carbs:</strong> 1,972 cal ÷ 4 = 493g</li>
            </ul>
            <p><strong>Macros:</strong> 168P / 84F / 493C</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Common Roadblocks: Adaptive Thermogenesis</h2>
        <p>If you have been eating in a calorie deficit for months and the scale has stopped moving, your TDEE has likely dropped. This is known as <strong>Adaptive Thermogenesis</strong> or metabolic adaptation.</p>
        <p>As you lose weight, you become a smaller organism, which requires less energy to survive (lower BMR). Furthermore, your body subconsciously reduces your NEAT (you fidget less, you take the elevator instead of stairs) to conserve energy.</p>
        <p><strong>The Solution:</strong> You cannot stay in a deficit forever. Implement structured "diet breaks" where you eat at maintenance (your new TDEE) for 1-2 weeks, or utilize a "reverse diet" to slowly build your metabolic capacity back up before cutting again.</p>
      </section>

    </div>
  </div>

  <style>
    .page-wrapper {
      background-color: var(--bg-color, #060c0a);
      color: var(--text-primary, #c8e0d8);
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    .hero-section {
      text-align: center;
      margin-bottom: 4rem;
    }

    .hero-section h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .subtitle {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .content-section {
      margin-bottom: 4rem;
    }

    h2 {
      font-size: 1.8rem;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    h3 {
      color: var(--text-primary);
      margin-bottom: 1rem;
    }

    p {
      margin-bottom: 1.2rem;
      color: var(--text-secondary);
    }

    strong {
      color: var(--text-primary);
    }

    /* Grid Layouts */
    .component-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .component-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      padding: 1.5rem;
      border-radius: 8px;
    }

    .component-card h3 {
      color: var(--accent-color);
      margin-top: 0;
      font-size: 1.2rem;
    }

    /* Formula Boxes */
    .formula-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      border-radius: 0 8px 8px 0;
    }

    .formula-box ul {
      list-style-type: none;
      padding-left: 0;
      margin: 1rem 0 0 0;
    }

    .formula-box li {
      margin-bottom: 0.5rem;
      color: var(--text-secondary);
    }

    /* Tables */
    .table-container {
      overflow-x: auto;
      margin: 2rem 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: rgba(45, 184, 154, 0.1);
      color: var(--accent-color);
    }

    td {
      color: var(--text-secondary);
    }

    /* Goals */
    .goal-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .goal-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      padding: 1.5rem;
      border-radius: 8px;
    }

    .goal-card.cutting { border-top: 4px solid #ef4444; }
    .goal-card.bulking { border-top: 4px solid #3b82f6; }

    .goal-card ul {
      padding-left: 1.2rem;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .goal-card li { margin-bottom: 0.5rem; }

    .note {
      font-size: 0.9rem;
      font-style: italic;
      margin-bottom: 0;
    }

    /* Steps */
    .macro-steps {
      margin: 2rem 0;
    }

    .step {
      display: flex;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
      background: var(--card-bg);
      padding: 1.5rem;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .step-num {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: var(--accent-color);
      color: #000;
      font-weight: bold;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .step h4 {
      margin: 0 0 0.5rem 0;
      color: var(--text-primary);
    }

    .step p { margin: 0; }

    /* Example Box */
    .example-box {
      background: rgba(45, 184, 154, 0.05);
      border: 1px dashed var(--accent-color);
      padding: 1.5rem;
      border-radius: 8px;
      margin-top: 2rem;
    }

    .example-box h4 {
      color: var(--accent-color);
      margin-top: 0;
    }

    .example-box ul {
      color: var(--text-secondary);
      padding-left: 1.2rem;
    }

    @media (max-width: 600px) {
      .hero-section h1 { font-size: 2rem; }
      .step { flex-direction: column; gap: 1rem; }
    }
  </style>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/tdee-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Tdee Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Tdee Calculator</p>
      </a>
    </div>
  </div>
</SiteLayout>
