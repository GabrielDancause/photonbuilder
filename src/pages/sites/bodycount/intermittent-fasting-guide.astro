---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const faqList = [
  {
    question: "Does coffee break a fast?",
    answer: "Black coffee does not break a fast as it contains practically zero calories and does not spike insulin. Adding milk, sugar, or creamer will break it."
  },
  {
    question: "Can I exercise while fasting?",
    answer: "Yes, many people exercise safely while fasted. It may even increase fat oxidation. However, for intense workouts, you might need to adjust your eating window or consume electrolytes."
  },
  {
    question: "What is the best intermittent fasting schedule?",
    answer: "The 16:8 protocol is the most popular and sustainable for beginners, but the 'best' schedule is the one that fits your lifestyle consistently."
  },
  {
    question: "Do I need to track calories while intermittent fasting?",
    answer: "While IF naturally helps restrict calories by limiting your eating window, you still need to be in a caloric deficit to lose weight. Tracking calories can help ensure you aren't overeating during your feeding window."
  },
  {
    question: "Can I take supplements while fasting?",
    answer: "Most vitamins and minerals won't break a fast. However, fat-soluble vitamins (A, D, E, K) are better absorbed with food, and gummy vitamins containing sugar will break a fast."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/intermittent-fasting-guide"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];

const protocols = [
  { name: "16:8", description: "Fast for 16 hours, eat during an 8-hour window. Most popular and sustainable." },
  { name: "18:6", description: "Fast for 18 hours, eat during a 6-hour window. Good for breaking plateaus." },
  { name: "20:4", description: "Fast for 20 hours, eat during a 4-hour window. Often called the Warrior Diet." },
  { name: "OMAD", description: "One Meal A Day. Fasting for ~23 hours. Convenient but can make it hard to hit protein goals." },
  { name: "5:2", description: "Eat normally 5 days a week, restrict calories to 500-600 on 2 non-consecutive days." },
  { name: "Alternate Day", description: "Fast completely every other day. Not recommended for beginners." }
];

const starterPlan = [
  { day: "Days 1-3", protocol: "12:12", focus: "Get used to not eating after dinner. Hydrate well in the morning." },
  { day: "Days 4-7", protocol: "14:10", focus: "Push breakfast back by 2 hours. Start introducing black coffee or tea." },
  { day: "Days 8-10", protocol: "15:9", focus: "Adjust your meals to fit the slightly smaller window." },
  { day: "Days 11-14", protocol: "16:8", focus: "Settle into the standard routine. Monitor energy levels." }
];
---

<SiteLayout
  site="bodycount"
  title="Complete Guide to Intermittent Fasting | BodyCount"
  description="An evidence-based guide to intermittent fasting covering protocols, benefits, what breaks a fast, and a starter plan."
  canonical="https://bodycount.photonbuilder.com/intermittent-fasting-guide"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Complete Guide to Intermittent Fasting</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        An evidence-based guide to intermittent fasting covering protocols, benefits, what breaks a fast, and a starter plan.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Common Fasting Protocols</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Find the schedule that works best for your lifestyle.</div>
        <table>
          <thead>
            <tr>
              <th>Protocol</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            {protocols.map(protocol => (
              <tr>
                <td><strong>{protocol.name}</strong></td>
                <td>{protocol.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>What Breaks a Fast?</h2>
        <div class="highlight-box">
          <h4>The Technical Answer vs The Practical Answer</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">Technically, any calories break a fast. Practically, very small amounts of calories (under 50) won't significantly impact insulin or stop autophagy.</div>
          <ul style="margin-bottom: 0;">
            <li><strong>Safe during a fast:</strong> Black coffee, plain tea, water, sparkling water.</li>
            <li><strong>Usually safe (Grey Area):</strong> Zero-calorie sweeteners, a splash of milk (under 50 calories), bone broth (depending on your fasting goals).</li>
            <li><strong>Breaks a fast:</strong> Sugar, cream, milk, protein powder, BCAA supplements, gummy vitamins, food.</li>
          </ul>
        </div>
      </section>

      <section>
        <h2>Key Benefits of Intermittent Fasting</h2>
        <ul>
          <li><strong>Weight Loss & Fat Loss:</strong> IF naturally restricts your eating window, often leading to a caloric deficit. It also lowers insulin levels, facilitating fat burning.</li>
          <li><strong>Autophagy:</strong> A cellular "cleanup" process where the body removes damaged cells and proteins. Usually begins around 16-18 hours of fasting.</li>
          <li><strong>Insulin Sensitivity:</strong> Fasting periods give your pancreas a break, helping to lower blood sugar and improve insulin resistance.</li>
        </ul>
      </section>

      <section>
        <h2>Who Should NOT Fast?</h2>
        <ul>
          <li><strong>Pregnant or Breastfeeding Women:</strong> High nutrient demands make fasting inappropriate.</li>
          <li><strong>Individuals who are Underweight:</strong> Fasting can exacerbate low body weight.</li>
          <li><strong>History of Eating Disorders:</strong> Restrictive eating windows can trigger unhealthy behaviors or relapses.</li>
          <li><strong>Type 1 Diabetics (or Type 2 on certain meds):</strong> Fasting can cause dangerous drops in blood sugar. Always consult a doctor first.</li>
        </ul>
      </section>

      <section>
        <h2>Workout Timing & Electrolytes</h2>
        <ul>
          <li><strong>Working Out Fasted:</strong> Safe and effective for fat loss, but you may lack top-end energy for high-intensity or very heavy lifting sessions.</li>
          <li><strong>Working Out Fed:</strong> Better for maximizing muscle growth and peak performance. You can schedule your workouts during your eating window.</li>
          <li><strong>Electrolytes:</strong> During a fast, insulin levels drop, causing your kidneys to excrete more sodium, potassium, and magnesium. This can lead to headaches or fatigue. Supplement with unflavored electrolytes (salt, potassium chloride) in your water during long fasts.</li>
        </ul>
      </section>

      <section>
        <h2>Common Fasting Mistakes</h2>
        <ul>
          <li><strong>Bingeing During the Eating Window:</strong> Overeating to compensate for the fast will negate weight loss benefits.</li>
          <li><strong>Not Drinking Enough Water:</strong> You get a lot of water from food. When you stop eating, you need to actively drink more water.</li>
          <li><strong>Starting Too Fast:</strong> Jumping straight into a 20-hour fast or OMAD can cause extreme hunger and lead to failure. Start slow.</li>
          <li><strong>Obsessing Over the Clock:</strong> If you're intensely hungry at hour 15, it's okay to break the fast early. Consistency matters more than perfection.</li>
        </ul>
      </section>

      <section>
        <h2>2-Week Starter Plan</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">A gradual approach to easing into a 16:8 fasting schedule.</div>
        <table>
          <thead>
            <tr>
              <th>Timeline</th>
              <th>Protocol</th>
              <th>Focus</th>
            </tr>
          </thead>
          <tbody>
            {starterPlan.map(plan => (
              <tr>
                <td><strong>{plan.day}</strong></td>
                <td>{plan.protocol}</td>
                <td>{plan.focus}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/intermittent-fasting-timer" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Intermittent Fasting Timer</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Intermittent Fasting Timer</p>
      </a>
    </div>
  </div>
</SiteLayout>