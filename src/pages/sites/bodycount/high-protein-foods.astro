const top10 = [...foods].sort((a, b) => parseFloat(b.ratio) - parseFloat(a.ratio)).slice(0, 10);
const allCategories = [...new Set(foods.map(f => f.cat))].sort();
---

<SiteLayout
  site="bodycount"
  title="High Protein Foods Chart | Sortable Reference Guide"
  description="Comprehensive high protein foods chart with 60+ foods sorted by category, diet type, and protein-to-calorie ratio. Calculate your daily protein needs."
  canonical="https://bodycount.photonbuilder.com/high-protein-foods"
  schema={schema}
>
  <style is:global>
    :root {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .container {
      max-width: 1152px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .calculator-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 1rem;
      padding: 2rem;
      margin: -2rem auto 3rem;
      max-width: 800px;
      box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
      position: relative;
    }

    .calc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group label {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-secondary);
    }

    .input-field {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-size: 1rem;
      width: 100%;
    }

    .input-field:focus {
      outline: none;
      border-color: var(--accent-color);
    }

    .calc-btn {
      background: var(--accent-color);
      color: #000;
      font-weight: 700;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      border: none;
      cursor: pointer;
      transition: background 0.2s;
      width: 100%;
    }

    .calc-btn:hover {
      background: var(--accent-hover);
    }

    .calc-result {
      margin-top: 1.5rem;
      padding: 1.5rem;
      background: rgba(74, 222, 128, 0.1);
      border: 1px solid rgba(74, 222, 128, 0.2);
      border-radius: 0.5rem;
      text-align: center;
      display: none;
    }

    .calc-result.active {
      display: block;
    }

    .result-value {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent-color);
      line-height: 1;
      margin: 0.5rem 0;
    }

    .top-10-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .food-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .food-card .rank {
      color: var(--accent-color);
      font-weight: 800;
      font-size: 1.25rem;
    }

    .food-card .name {
      font-weight: 600;
      font-size: 1.1rem;
    }

    .food-card .stats {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    .food-card .ratio {
      margin-top: auto;
      background: var(--bg-color);
      padding: 0.5rem;
      border-radius: 0.25rem;
      font-family: monospace;
      font-size: 0.9rem;
      text-align: center;
      border: 1px solid var(--border-color);
    }

    .controls-bar {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.5rem;
      background: var(--card-bg);
      padding: 1rem;
      border-radius: 0.75rem;
      border: 1px solid var(--border-color);
      align-items: center;
    }

    .table-container {
      overflow-x: auto;
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 0.75rem;
      margin-bottom: 3rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background: var(--chart-header);
      padding: 1rem;
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
      border-bottom: 1px solid var(--border-color);
    }

    th:hover {
      color: var(--text-primary);
    }

    td {
      padding: 1rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--table-hover);
    }

    .badge {
      display: inline-block;
      padding: 0.25rem 0.5rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      margin-right: 0.25rem;
      margin-top: 0.25rem;
    }

    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      border-bottom: 1px solid var(--border-color);
      padding: 1.5rem 0;
    }

    .faq-q {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--accent-color);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <section class="hero-section">
    <div class="container">
      <h1 class="text-4xl md:text-5xl font-black mb-4">High Protein Foods Chart</h1>
      <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
        Discover the ultimate guide to protein sources. Calculate your daily needs and sort 60+ foods by protein-to-calorie ratio, category, and diet type.
      </p>
    </div>
  </section>

  <main class="container">
    <!-- Calculator Section -->
    <div class="calculator-card">
      <h2 class="text-2xl font-bold mb-6 text-center">Daily Protein Needs Calculator</h2>
      <form id="proteinCalc">
        <div class="calc-grid">
          <div class="form-group">
            <label>Weight (lbs)</label>
            <input type="number" id="weight" class="input-field" placeholder="e.g. 170" required min="50" max="500">
          </div>
          <div class="form-group">
            <label>Activity Level</label>
            <select id="activity" class="input-field" required>
              <option value="sedentary">Sedentary (Little to no exercise)</option>
              <option value="light">Light Activity (1-3 days/week)</option>
              <option value="moderate" selected>Moderate Activity (3-5 days/week)</option>
              <option value="active">Very Active (6-7 days/week)</option>
              <option value="athlete">Athlete (2x training/day)</option>
            </select>
          </div>
          <div class="form-group">
            <label>Primary Goal</label>
            <select id="goal" class="input-field" required>
              <option value="maintenance">Maintain Weight / General Health</option>
              <option value="muscle" selected>Build Muscle (Hypertrophy)</option>
              <option value="fatloss">Lose Fat (Preserve Muscle)</option>
            </select>
          </div>
        </div>
        <button type="submit" class="calc-btn">Calculate Protein Target</button>
      </form>

      <div id="calcResult" class="calc-result">
        <div class="text-[var(--text-secondary)] font-semibold uppercase tracking-wider text-sm">Your Daily Target</div>
        <div id="resultValue" class="result-value">-- g</div>
        <div id="resultDesc" class="text-sm mt-2 text-[var(--text-secondary)]"></div>
      </div>
    </div>

    <!-- Top 10 Section -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">Top 10 Highest Protein per Calorie</h2>
      <div class="top-10-grid">
        {top10.map((food, index) => (
          <div class="food-card">
            <div class="flex items-center gap-3">
              <span class="rank">#{index + 1}</span>
              <span class="name">{food.name}</span>
            </div>
            <div class="stats">
              {food.protein}g protein | {food.calories} cal
              <br/>({food.serving})
            </div>
            <div class="ratio">
              <span class="text-[var(--text-secondary)]">Ratio:</span> <span class="text-white font-bold">{food.ratio}</span> <span class="text-xs">g/cal</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Comprehensive Table Section -->
    <section>
      <h2 class="text-3xl font-bold mb-6">Comprehensive Protein Chart</h2>

      <div class="controls-bar">
        <div class="flex items-center gap-2">
          <label class="font-semibold text-sm">Category:</label>
          <select id="filterCategory" class="input-field py-1 px-2 text-sm w-auto">
            <option value="all">All Categories</option>
            {allCategories.map(cat => (
              <option value={cat}>{cat}</option>
            ))}
          </select>
        </div>

        <div class="flex items-center gap-2">
          <label class="font-semibold text-sm">Diet:</label>
          <select id="filterDiet" class="input-field py-1 px-2 text-sm w-auto">
            <option value="all">Any Diet</option>
            <option value="Vegetarian">Vegetarian Friendly</option>
            <option value="Vegan">Vegan Friendly</option>
            <option value="Keto">Keto Friendly</option>
          </select>
        </div>

        <div class="flex items-center gap-2 ml-auto">
          <input type="text" id="searchFood" class="input-field py-1 px-3 text-sm" placeholder="Search foods...">
        </div>
      </div>

      <div class="table-container">
        <table id="foodTable">
          <thead>
            <tr>
              <th data-sort="name">Food Source ↕</th>
              <th data-sort="cat">Category ↕</th>
              <th>Serving Size</th>
              <th data-sort="protein">Protein (g) ↕</th>
              <th data-sort="calories">Calories ↕</th>
              <th data-sort="ratio">Protein/Cal Ratio ↕</th>
              <th>Diet Types</th>
            </tr>
          </thead>
          <tbody id="foodTbody">
            {foods.map(food => (
              <tr data-cat={food.cat} data-types={food.types.join(',')} data-name={food.name.toLowerCase()}>
                <td class="font-medium">{food.name}</td>
                <td class="text-[var(--text-secondary)]">{food.cat}</td>
                <td class="text-[var(--text-secondary)]">{food.serving}</td>
                <td class="font-bold text-[var(--accent-color)]" data-val={food.protein}>{food.protein}g</td>
                <td data-val={food.calories}>{food.calories}</td>
                <td class="font-mono text-sm" data-val={food.ratio}>{food.ratio}</td>
                <td>
                  {food.types.map(t => (
                    <span class="badge">{t}</span>
                  ))}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="faq-list">
        {schema[1].mainEntity.map((faq: any) => (
          <div class="faq-item">
            <div class="faq-q">{faq.name}</div>
            <div class="faq-a">{faq.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    // Calculator Logic
    document.getElementById('proteinCalc').addEventListener('submit', function(e) {
      e.preventDefault();
      const weightLbs = parseFloat(document.getElementById('weight').value);
      const activity = document.getElementById('activity').value;
      const goal = document.getElementById('goal').value;

      if (isNaN(weightLbs) || weightLbs <= 0) return;

      const weightKg = weightLbs / 2.20462;
      let multiplier = 0.8; // base RDA

      // Activity modifier
      if (activity === 'light') multiplier = 1.2;
      else if (activity === 'moderate') multiplier = 1.4;
      else if (activity === 'active') multiplier = 1.6;
      else if (activity === 'athlete') multiplier = 1.8;

      // Goal modifier
      if (goal === 'muscle') {
        multiplier += 0.4;
      } else if (goal === 'fatloss') {
        // Higher protein needed to preserve muscle in deficit
        multiplier = Math.max(multiplier + 0.5, 2.0);
      }

      // Cap at 2.5g/kg for extreme cases
      multiplier = Math.min(multiplier, 2.5);

      const targetGrams = Math.round(weightKg * multiplier);
      const targetLbs = (targetGrams / weightLbs).toFixed(2);

      document.getElementById('resultValue').textContent = `${targetGrams}g - ${targetGrams + 20}g`;
      document.getElementById('resultDesc').textContent = `Based on your profile, target ${targetLbs}g to ${(targetGrams/weightLbs + 0.1).toFixed(2)}g of protein per pound of bodyweight.`;
      document.getElementById('calcResult').classList.add('active');
    });

    // Table Filtering and Sorting Logic
    const filterCat = document.getElementById('filterCategory');
    const filterDiet = document.getElementById('filterDiet');
    const searchInput = document.getElementById('searchFood');
    const tbody = document.getElementById('foodTbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    let currentSort = { col: 'ratio', asc: false };

    function applyFilters() {
      const catVal = filterCat.value;
      const dietVal = filterDiet.value;
      const searchVal = searchInput.value.toLowerCase();

      rows.forEach(row => {
        const rCat = row.getAttribute('data-cat');
        const rTypes = row.getAttribute('data-types');
        const rName = row.getAttribute('data-name');

        const matchCat = catVal === 'all' || rCat === catVal;
        const matchDiet = dietVal === 'all' || rTypes.includes(dietVal);
        const matchSearch = searchVal === '' || rName.includes(searchVal);

        row.style.display = (matchCat && matchDiet && matchSearch) ? '' : 'none';
      });
    }

    function applySort() {
      const visibleRows = rows.filter(r => r.style.display !== 'none');
      const hiddenRows = rows.filter(r => r.style.display === 'none');

      visibleRows.sort((a, b) => {
        let valA, valB;
        if (currentSort.col === 'name' || currentSort.col === 'cat') {
          // String sort based on text content
          valA = a.querySelector(`td:nth-child(${currentSort.col === 'name' ? 1 : 2})`).textContent.trim();
          valB = b.querySelector(`td:nth-child(${currentSort.col === 'name' ? 1 : 2})`).textContent.trim();
          return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else {
          // Numeric sort
          const idx = currentSort.col === 'protein' ? 4 : (currentSort.col === 'calories' ? 5 : 6);
          valA = parseFloat(a.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          valB = parseFloat(b.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          return currentSort.asc ? valA - valB : valB - valA;
        }
      });

      tbody.innerHTML = '';
      visibleRows.forEach(r => tbody.appendChild(r));
      hiddenRows.forEach(r => tbody.appendChild(r));
    }

    function handleSortClick(e) {
      if (e.target.tagName !== 'TH' || !e.target.dataset.sort) return;

      const col = e.target.dataset.sort;
      if (currentSort.col === col) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.col = col;
        currentSort.asc = false;
      }

      applySort();
    }

    // Event Listeners
    filterCat.addEventListener('change', () => { applyFilters(); applySort(); });
    filterDiet.addEventListener('change', () => { applyFilters(); applySort(); });
    searchInput.addEventListener('input', () => { applyFilters(); applySort(); });
    document.querySelector('thead').addEventListener('click', handleSortClick);

    // Initial Sort
    applySort();
  </script>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/protein-intake-calculator" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Protein Intake Calculator</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Protein Intake Calculator</p>
      </a>
    </div>
