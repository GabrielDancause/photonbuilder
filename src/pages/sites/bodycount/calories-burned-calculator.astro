  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let currentUnit = 'metric';

      // All activities with MET values
      const activities = [
        { name: 'Running (4 mph / jogging)', met: 6.0, cat: 'Running' },
        { name: 'Running (5 mph)', met: 8.3, cat: 'Running' },
        { name: 'Running (6 mph)', met: 9.8, cat: 'Running' },
        { name: 'Running (7 mph)', met: 11.0, cat: 'Running' },
        { name: 'Running (8 mph)', met: 11.8, cat: 'Running' },
        { name: 'Running (9 mph)', met: 12.8, cat: 'Running' },
        { name: 'Running (10 mph)', met: 14.5, cat: 'Running' },
        { name: 'Trail Running (easy)', met: 5.0, cat: 'Running' },
        { name: 'Trail Running (hard)', met: 10.0, cat: 'Running' },
        { name: 'Cycling (leisure, < 10 mph)', met: 4.0, cat: 'Cycling' },
        { name: 'Cycling (moderate, 12-14 mph)', met: 6.8, cat: 'Cycling' },
        { name: 'Cycling (vigorous, 14-16 mph)', met: 8.0, cat: 'Cycling' },
        { name: 'Cycling (racing, 16-19 mph)', met: 10.0, cat: 'Cycling' },
        { name: 'Cycling (racing, > 20 mph)', met: 12.0, cat: 'Cycling' },
        { name: 'Mountain Biking', met: 8.5, cat: 'Cycling' },
        { name: 'Spinning / Indoor Cycling', met: 6.8, cat: 'Cycling' },
        { name: 'Swimming (moderate)', met: 6.0, cat: 'Swimming' },
        { name: 'Swimming (vigorous laps)', met: 8.3, cat: 'Swimming' },
        { name: 'Swimming (butterfly)', met: 10.0, cat: 'Swimming' },
        { name: 'Treading Water (moderate)', met: 3.5, cat: 'Swimming' },
        { name: 'Water Polo', met: 7.0, cat: 'Swimming' },
        { name: 'Weight Lifting (light)', met: 3.5, cat: 'Gym' },
        { name: 'Weight Lifting (moderate)', met: 5.0, cat: 'Gym' },
        { name: 'Weight Lifting (vigorous)', met: 6.0, cat: 'Gym' },
        { name: 'Circuit Training / CrossFit', met: 8.0, cat: 'Gym' },
        { name: 'Kettlebell Training', met: 6.0, cat: 'Gym' },
        { name: 'Resistance Bands', met: 3.8, cat: 'Gym' },
        { name: 'Jump Rope (fast)', met: 12.3, cat: 'Cardio' },
        { name: 'Jump Rope (moderate)', met: 8.8, cat: 'Cardio' },
        { name: 'HIIT / Interval Training', met: 8.0, cat: 'Cardio' },
        { name: 'Burpees', met: 9.0, cat: 'Cardio' },
        { name: 'Stair Climbing (fast)', met: 8.0, cat: 'Cardio' },
        { name: 'Stair Climbing (slow)', met: 4.0, cat: 'Cardio' },
        { name: 'Elliptical Trainer', met: 5.0, cat: 'Cardio' },
        { name: 'Rowing Machine (moderate)', met: 7.0, cat: 'Cardio' },
        { name: 'Rowing Machine (vigorous)', met: 8.5, cat: 'Cardio' },
        { name: 'Step Aerobics', met: 6.5, cat: 'Cardio' },
        { name: 'Basketball (game)', met: 6.5, cat: 'Sports' },
        { name: 'Soccer (game)', met: 7.0, cat: 'Sports' },
        { name: 'Tennis (singles)', met: 7.3, cat: 'Sports' },
        { name: 'Tennis (doubles)', met: 5.0, cat: 'Sports' },
        { name: 'Badminton', met: 6.0, cat: 'Sports' },
        { name: 'Volleyball', met: 4.0, cat: 'Sports' },
        { name: 'Boxing (sparring)', met: 12.0, cat: 'Sports' },
        { name: 'Boxing (bag work)', met: 5.5, cat: 'Sports' },
        { name: 'Martial Arts (judo, karate)', met: 10.3, cat: 'Sports' },
        { name: 'Golf (walking, carrying clubs)', met: 5.5, cat: 'Sports' },
        { name: 'Rock Climbing', met: 7.8, cat: 'Sports' },
        { name: 'Ice Skating (moderate)', met: 6.0, cat: 'Sports' },
        { name: 'Skiing (downhill, moderate)', met: 7.0, cat: 'Sports' },
        { name: 'Cross-Country Skiing', met: 8.0, cat: 'Sports' },
        { name: 'Walking (2 mph, slow)', met: 2.8, cat: 'Walking' },
        { name: 'Walking (3 mph, moderate)', met: 3.5, cat: 'Walking' },
        { name: 'Walking (3.5 mph, brisk)', met: 4.3, cat: 'Walking' },
        { name: 'Walking (4.5 mph, very fast)', met: 5.0, cat: 'Walking' },
        { name: 'Hiking (moderate terrain)', met: 6.0, cat: 'Walking' },
        { name: 'Hiking (steep, with pack)', met: 8.3, cat: 'Walking' },
        { name: 'Yoga (hatha, light)', met: 2.5, cat: 'Mind-Body' },
        { name: 'Yoga (power / vinyasa)', met: 4.0, cat: 'Mind-Body' },
        { name: 'Pilates', met: 3.0, cat: 'Mind-Body' },
        { name: 'Stretching', met: 2.3, cat: 'Mind-Body' },
        { name: 'Tai Chi', met: 2.5, cat: 'Mind-Body' },
        { name: 'Gardening', met: 3.5, cat: 'Daily' },
        { name: 'Housework (general)', met: 3.3, cat: 'Daily' },
        { name: 'Shoveling Snow', met: 5.0, cat: 'Daily' },
        { name: 'Moving Furniture', met: 6.0, cat: 'Daily' },
        { name: 'Playing with Kids (moderate)', met: 2.5, cat: 'Daily' },
        { name: 'Dancing (aerobic)', met: 6.5, cat: 'Daily' },
        { name: 'Dancing (slow, ballroom)', met: 3.0, cat: 'Daily' }
      ];

      // Unit toggle
      document.querySelectorAll('.unit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentUnit = btn.dataset.unit;
          document.querySelectorAll('.metric-inputs').forEach(el => el.style.display = currentUnit === 'metric' ? '' : 'none');
          document.querySelectorAll('.imperial-inputs').forEach(el => el.style.display = currentUnit === 'imperial' ? '' : 'none');
        });
      });

      // FAQ toggle
      document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => {
          q.parentElement.classList.toggle('open');
        });
      });

      // Populate comparison selects
      const compareIds = ['compare1', 'compare2', 'compare3'];
      const defaultCompare = ['Running (6 mph)', 'Cycling (vigorous, 14-16 mph)', 'Swimming (vigorous laps)'];
      compareIds.forEach((id, idx) => {
        const sel = document.getElementById(id);
        activities.forEach(a => {
          const opt = document.createElement('option');
          opt.value = a.met;
          opt.textContent = a.name;
          opt.dataset.name = a.name;
          if (a.name === defaultCompare[idx]) opt.selected = true;
          sel.appendChild(opt);
        });
        sel.addEventListener('change', updateChart);
      });

      function getWeightKg() {
        if (currentUnit === 'metric') {
          return parseFloat(document.getElementById('weight-kg').value);
        }
        return parseFloat(document.getElementById('weight-lbs').value) * 0.453592;
      }

      function calcCalories(met, weightKg, durationMin) {
        return met * weightKg * (durationMin / 60);
      }

      function updateChart() {
        const weightKg = getWeightKg();
        if (!weightKg) return;

        const container = document.getElementById('chartContainer');
        const bars = [];
        const colors = ['bar1', 'bar2', 'bar3'];

        compareIds.forEach((id, idx) => {
          const sel = document.getElementById(id);
          const opt = sel.options[sel.selectedIndex];
          const met = parseFloat(sel.value);
          const name = opt.dataset.name;
          const calPerHour = Math.round(calcCalories(met, weightKg, 60));
          bars.push({ name, calPerHour, color: colors[idx] });
        });

        const maxCal = Math.max(...bars.map(b => b.calPerHour)) * 1.15;

        container.innerHTML = bars.map(b => `
          <div class="chart-bar-row">
            <div class="chart-label">${b.name}</div>
            <div class="chart-bar-wrapper">
              <div class="chart-bar ${b.color}" style="width: ${(b.calPerHour / maxCal) * 100}%">${b.calPerHour} cal/hr</div>
            </div>
          </div>
        `).join('');
      }

      function calculate() {
        const weightKg = getWeightKg();
        const duration = parseFloat(document.getElementById('duration').value);
        if (!weightKg || !duration) return;

        const exerciseSelect = document.getElementById('exercise');
        const selectedOption = exerciseSelect.options[exerciseSelect.selectedIndex];
        const met = parseFloat(exerciseSelect.value);
        const exerciseName = selectedOption.dataset.name;

        const totalCals = Math.round(calcCalories(met, weightKg, duration));
        const calPerMin = (totalCals / duration).toFixed(1);
        const calPerHour = Math.round(calcCalories(met, weightKg, 60));

        // Main result
        document.getElementById('burnLabel').textContent = `${exerciseName} \u2014 ${duration} min`;
        document.getElementById('burnValue').textContent = totalCals.toLocaleString();

        // Stats
        document.getElementById('calPerMin').textContent = calPerMin;
        document.getElementById('calPerHour').textContent = calPerHour.toLocaleString();
        document.getElementById('metValue').textContent = met;

        // Food equivalents
        document.getElementById('foodPizza').textContent = (totalCals / 285).toFixed(1);
        document.getElementById('foodBeer').textContent = (totalCals / 150).toFixed(1);
        document.getElementById('foodChocolate').textContent = (totalCals / 230).toFixed(1);

        // Update comparison chart
        updateChart();

        // Top 20 table
        const sorted = [...activities].sort((a, b) => b.met - a.met).slice(0, 20);
        const tbody = document.getElementById('topTableBody');
        tbody.innerHTML = '';
        sorted.forEach((a, i) => {
          const cph = Math.round(calcCalories(a.met, weightKg, 60));
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td class="rank-col">${i + 1}</td>
            <td>${a.name}</td>
            <td class="met-col">${a.met}</td>
            <td class="highlight">${cph.toLocaleString()}</td>
          `;
          tbody.appendChild(tr);
        });

        // Show results
        document.getElementById('results').classList.add('active');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      document.getElementById('calculateBtn').addEventListener('click', calculate);
      calculate();
    });
  </script>
</SiteLayout>
