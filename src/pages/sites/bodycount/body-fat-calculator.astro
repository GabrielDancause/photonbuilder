                        </div>
                    </div>

                    <!-- Body Fat Range Indicator -->
                    <div class="bf-bar-container">
                        <div class="bf-bar-title">Body Fat Range</div>
                        <div class="bf-bar">
                            <div class="bf-segment seg-essential"></div>
                            <div class="bf-segment seg-athlete"></div>
                            <div class="bf-segment seg-fitness"></div>
                            <div class="bf-segment seg-average"></div>
                            <div class="bf-segment seg-obese"></div>
                            <div class="bf-marker" id="bfMarker"></div>
                        </div>
                        <div class="bf-labels" id="bfLabels">
                            <span>2%</span>
                            <span>6%</span>
                            <span>14%</span>
                            <span>18%</span>
                            <span>25%</span>
                            <span>40%+</span>
                        </div>
                        <div class="bf-legend">
                            <div class="legend-item"><div class="legend-color color-essential"></div> Essential</div>
                            <div class="legend-item"><div class="legend-color color-athlete"></div> Athlete</div>
                            <div class="legend-item"><div class="legend-color color-fitness"></div> Fitness</div>
                            <div class="legend-item"><div class="legend-color color-average"></div> Average</div>
                            <div class="legend-item"><div class="legend-color color-obese"></div> Obese</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Body Fat Categories Table -->
            <div class="seo-content">
                <h2>Body Fat Percentage Categories</h2>
                <p>Body fat categories differ between men and women due to essential fat differences. Women naturally carry more body fat for reproductive and hormonal health.</p>

                <h3>Men</h3>
                <table class="data-table">
                    <thead>
                        <tr><th>Category</th><th>Body Fat %</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Essential Fat</td><td>2–5%</td></tr>
                        <tr><td>Athlete</td><td>6–13%</td></tr>
                        <tr><td>Fitness</td><td>14–17%</td></tr>
                        <tr><td>Average</td><td>18–24%</td></tr>
                        <tr><td>Obese</td><td>25%+</td></tr>
                    </tbody>
                </table>

                <h3>Women</h3>
                <table class="data-table">
                    <thead>
                        <tr><th>Category</th><th>Body Fat %</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Essential Fat</td><td>10–13%</td></tr>
                        <tr><td>Athlete</td><td>14–20%</td></tr>
                        <tr><td>Fitness</td><td>21–24%</td></tr>
                        <tr><td>Average</td><td>25–31%</td></tr>
                        <tr><td>Obese</td><td>32%+</td></tr>
                    </tbody>
                </table>

                <h2>Healthy Body Fat Ranges by Age</h2>
                <p>Acceptable body fat increases slightly with age as metabolism slows and body composition shifts.</p>

                <h3>Men</h3>
                <table class="data-table">
                    <thead>
                        <tr><th>Age</th><th>Healthy Range</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>20–29</td><td>7–17%</td></tr>
                        <tr><td>30–39</td><td>12–21%</td></tr>
                        <tr><td>40–49</td><td>14–23%</td></tr>
                        <tr><td>50–59</td><td>16–24%</td></tr>
                        <tr><td>60+</td><td>17–25%</td></tr>
                    </tbody>
                </table>

                <h3>Women</h3>
                <table class="data-table">
                    <thead>
                        <tr><th>Age</th><th>Healthy Range</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>20–29</td><td>16–24%</td></tr>
                        <tr><td>30–39</td><td>17–25%</td></tr>
                        <tr><td>40–49</td><td>19–28%</td></tr>
                        <tr><td>50–59</td><td>22–31%</td></tr>
                        <tr><td>60+</td><td>22–33%</td></tr>
                    </tbody>
                </table>

                <h2>How to Measure for the US Navy Method</h2>
                <p>The US Navy body fat formula uses circumference measurements to estimate body fat percentage. For accurate results:</p>
                <ul>
                    <li><strong>Neck:</strong> Measure just below the larynx (Adam's apple), with the tape sloping slightly downward at the front.</li>
                    <li><strong>Waist (men):</strong> Measure at navel level, at the narrowest point of your abdomen.</li>
                    <li><strong>Waist (women):</strong> Measure at the narrowest part of the waist.</li>
                    <li><strong>Hips (women only):</strong> Measure at the widest point of the buttocks/hips.</li>
                </ul>
                <p>Take each measurement twice and use the average. Keep the tape snug but not compressing the skin. Measure on bare skin when possible.</p>

                <h2>How Skinfold Measurements Work</h2>
                <p>The Jackson-Pollock 3-site skinfold method uses caliper measurements at specific body locations. The sum of the three skinfolds, combined with your age, is used in a formula to calculate body density, which is then converted to body fat percentage using the Siri equation.</p>
                <ul>
                    <li><strong>Men — chest:</strong> A diagonal fold taken between the armpit and nipple.</li>
                    <li><strong>Men — abdomen:</strong> A vertical fold taken 2 cm to the right of the navel.</li>
                    <li><strong>Men — thigh:</strong> A vertical fold taken on the front of the thigh, midway between hip and knee.</li>
                    <li><strong>Women — tricep:</strong> A vertical fold taken on the back of the upper arm, midway between shoulder and elbow.</li>
                    <li><strong>Women — suprailiac:</strong> A diagonal fold taken just above the hip bone.</li>
                    <li><strong>Women — thigh:</strong> Same as men, a vertical fold on the front of the thigh.</li>
                </ul>

                <h2>Tips to Reduce Body Fat</h2>
                <ol>
                    <li><strong>Create a moderate calorie deficit</strong> — aim for 300–500 calories below your maintenance level. Extreme restriction leads to muscle loss.</li>
                    <li><strong>Prioritize protein</strong> — consume 0.7–1g of protein per pound of bodyweight to maintain muscle while losing fat.</li>
                    <li><strong>Lift weights regularly</strong> — resistance training 3–4 times per week signals your body to keep muscle tissue.</li>
                    <li><strong>Add cardio strategically</strong> — 2–3 sessions of moderate cardio per week supports fat loss without overtraining.</li>
                    <li><strong>Sleep 7–9 hours</strong> — poor sleep raises cortisol and ghrelin, promoting fat storage and increasing appetite.</li>
                    <li><strong>Manage stress</strong> — chronic stress elevates cortisol, which is linked to increased abdominal fat storage.</li>
                    <li><strong>Stay hydrated</strong> — drinking water supports metabolism and helps control appetite.</li>
                    <li><strong>Be patient and consistent</strong> — aim to lose 0.5–1% of bodyweight per week for sustainable fat loss with minimal muscle loss.</li>
                </ol>

                <div class="disclaimer">
                    <strong>Medical Disclaimer:</strong> This body fat calculator provides estimates for educational and informational purposes only. Results are not a substitute for professional medical advice, diagnosis, or treatment. Body fat estimation methods used here (US Navy and skinfold) have inherent margins of error (±3–4%). For precise body composition analysis, consult a healthcare professional and consider clinical methods such as DEXA scanning, hydrostatic weighing, or air displacement plethysmography. Always consult your physician before making changes to your diet or exercise program.
                </div>

                <h2>Frequently Asked Questions</h2>
                <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" onclick="toggleFaq(this)">What is a healthy body fat percentage?</button>
                        <div class="faq-answer">Healthy body fat ranges vary by gender and age. For men, 14–24% is generally considered healthy. For women, 21–31% is considered healthy. Athletes typically have lower body fat: 6–13% for men and 14–20% for women.</div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="toggleFaq(this)">How accurate is the US Navy body fat method?</button>
                        <div class="faq-answer">The US Navy method has an accuracy of about ±3–4% compared to more precise methods like DEXA scans. It uses circumference measurements of the neck, waist, and hips (for women) along with height to estimate body fat percentage.</div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="toggleFaq(this)">What is the difference between body fat percentage and BMI?</button>
                        <div class="faq-answer">BMI (Body Mass Index) only considers height and weight, so it cannot distinguish between muscle and fat. Body fat percentage directly measures how much of your body weight is fat tissue, making it a more accurate indicator of body composition and health risk.</div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="toggleFaq(this)">How do skinfold measurements work?</button>
                        <div class="faq-answer">Skinfold measurements use calipers to pinch and measure subcutaneous fat at specific body sites. The Jackson-Pollock 3-site method measures chest, abdomen, and thigh for men, and tricep, suprailiac, and thigh for women. These measurements are combined with age in a formula to estimate total body fat percentage.</div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="toggleFaq(this)">How often should I measure my body fat?</button>
                        <div class="faq-answer">Measure body fat every 2–4 weeks for tracking progress. Always measure at the same time of day (morning is best), under similar conditions, and using the same method for consistent comparisons. Avoid measuring after exercise, eating, or drinking large amounts of fluid.</div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" onclick="toggleFaq(this)">Can I reduce body fat without losing muscle?</button>
                        <div class="faq-answer">Yes. To lose fat while preserving muscle, maintain a moderate caloric deficit (300–500 calories below maintenance), eat adequate protein (0.7–1g per pound of bodyweight), perform resistance training 3–4 times per week, and get sufficient sleep. Avoid extreme caloric restriction, which promotes muscle loss.</div>
                    </div>
                </div>
            </div>
        </main>

    </div>

  <script is:inline>
let currentUnit = 'metric';
let currentMethod = 'navy';

function setUnitSystem(unit) {
    currentUnit = unit;
    document.getElementById('btnMetric').classList.toggle('active', unit === 'metric');
    document.getElementById('btnImperial').classList.toggle('active', unit === 'imperial');
    document.querySelectorAll('.metric-inputs').forEach(el => el.style.display = unit === 'metric' ? 'flex' : 'none');
    document.querySelectorAll('.imperial-inputs').forEach(el => el.style.display = unit === 'imperial' ? 'flex' : 'none');
    document.getElementById('results').classList.remove('active');
}

function setMethod(method) {
    currentMethod = method;
    document.getElementById('btnNavy').classList.toggle('active', method === 'navy');
    document.getElementById('btnSkinfold').classList.toggle('active', method === 'skinfold');
    document.getElementById('navyInputs').classList.toggle('active', method === 'navy');
    document.getElementById('skinfoldInputs').classList.toggle('active', method === 'skinfold');
    document.getElementById('results').classList.remove('active');
}

function updateGenderFields() {
    const gender = document.querySelector('input[name="gender"]:checked').value;
    const isFemale = gender === 'female';

    // Hip field for Navy method
    document.getElementById('hipField').style.display = isFemale ? 'flex' : 'none';

    // Skinfold fields
    document.getElementById('maleSfFields').style.display = isFemale ? 'none' : 'block';
    document.getElementById('femaleSfFields').style.display = isFemale ? 'block' : 'none';

    // Update bar labels for gender
    updateBarLabels(gender);

    document.getElementById('results').classList.remove('active');
}

function updateBarLabels(gender) {
    const labels = document.getElementById('bfLabels');
    if (gender === 'male') {
        labels.innerHTML = '<span>2%</span><span>6%</span><span>14%</span><span>18%</span><span>25%</span><span>40%+</span>';
    } else {
        labels.innerHTML = '<span>10%</span><span>14%</span><span>21%</span><span>25%</span><span>32%</span><span>45%+</span>';
    }
}

function getCategory(bf, gender) {
    if (gender === 'male') {
        if (bf <= 5) return { name: 'Essential Fat', color: 'var(--bf-essential)' };
        if (bf <= 13) return { name: 'Athlete', color: 'var(--bf-athlete)' };
        if (bf <= 17) return { name: 'Fitness', color: 'var(--bf-fitness)' };
        if (bf <= 24) return { name: 'Average', color: 'var(--bf-average)' };
        return { name: 'Obese', color: 'var(--bf-obese)' };
    } else {
        if (bf <= 13) return { name: 'Essential Fat', color: 'var(--bf-essential)' };
        if (bf <= 20) return { name: 'Athlete', color: 'var(--bf-athlete)' };
        if (bf <= 24) return { name: 'Fitness', color: 'var(--bf-fitness)' };
        if (bf <= 31) return { name: 'Average', color: 'var(--bf-average)' };
        return { name: 'Obese', color: 'var(--bf-obese)' };
    }
}

function getMarkerPos(bf, gender) {
    // Segments: essential(12%), athlete(18%), fitness(25%), average(25%), obese(20%)
    let ranges;
    if (gender === 'male') {
        ranges = [
            { min: 2, max: 5, start: 0, width: 12 },
            { min: 6, max: 13, start: 12, width: 18 },
            { min: 14, max: 17, start: 30, width: 25 },
            { min: 18, max: 24, start: 55, width: 25 },
            { min: 25, max: 40, start: 80, width: 20 }
        ];
    } else {
        ranges = [
            { min: 10, max: 13, start: 0, width: 12 },
            { min: 14, max: 20, start: 12, width: 18 },
            { min: 21, max: 24, start: 30, width: 25 },
            { min: 25, max: 31, start: 55, width: 25 },
            { min: 32, max: 45, start: 80, width: 20 }
        ];
    }

    for (const r of ranges) {
        if (bf <= r.max) {
            const clampedBf = Math.max(r.min, bf);
            const pct = (clampedBf - r.min) / (r.max - r.min);
            return r.start + pct * r.width;
        }
    }
    return 100;
}

document.getElementById('bfForm').addEventListener('submit', function(e) {
    e.preventDefault();

    const gender = document.querySelector('input[name="gender"]:checked').value;
    let bodyFat = 0;
    let weightKg = 0;

    if (currentMethod === 'navy') {
        // Get height in cm
        let heightCm;
        if (currentUnit === 'metric') {
            heightCm = parseFloat(document.getElementById('heightCm').value);
        } else {
            const ft = parseFloat(document.getElementById('heightFt').value) || 0;
            const inch = parseFloat(document.getElementById('heightIn').value) || 0;
            heightCm = (ft * 12 + inch) * 2.54;
        }

        // Get circumferences in cm
        let neckCm, waistCm, hipCm;
        if (currentUnit === 'metric') {
            neckCm = parseFloat(document.getElementById('neckCm').value);
            waistCm = parseFloat(document.getElementById('waistCm').value);
            hipCm = gender === 'female' ? parseFloat(document.getElementById('hipCm').value) : 0;
            weightKg = parseFloat(document.getElementById('weightKg').value);
        } else {
            neckCm = parseFloat(document.getElementById('neckIn').value) * 2.54;
            waistCm = parseFloat(document.getElementById('waistIn').value) * 2.54;
            hipCm = gender === 'female' ? parseFloat(document.getElementById('hipIn').value) * 2.54 : 0;
            weightKg = parseFloat(document.getElementById('weightLbs').value) * 0.453592;
        }

        if (isNaN(heightCm) || isNaN(neckCm) || isNaN(waistCm) || isNaN(weightKg)) return;
        if (gender === 'female' && isNaN(hipCm)) return;

        // US Navy formula
        if (gender === 'male') {
            bodyFat = 86.010 * Math.log10(waistCm - neckCm) - 70.041 * Math.log10(heightCm) + 36.76;
        } else {
            bodyFat = 163.205 * Math.log10(waistCm + hipCm - neckCm) - 97.684 * Math.log10(heightCm) - 78.387;
        }
    } else {
        // Skinfold method (Jackson-Pollock 3-site)
        const age = parseFloat(document.getElementById('sfAge').value);
        if (isNaN(age)) return;

        if (currentUnit === 'metric') {
            weightKg = parseFloat(document.getElementById('sfWeightKg').value);
        } else {
            weightKg = parseFloat(document.getElementById('sfWeightLbs').value) * 0.453592;
        }
        if (isNaN(weightKg)) return;

        let sumSf, bodyDensity;
        if (gender === 'male') {
            const chest = parseFloat(document.getElementById('sfChest').value);
            const abdomen = parseFloat(document.getElementById('sfAbdomen').value);
            const thigh = parseFloat(document.getElementById('sfThighM').value);
            if (isNaN(chest) || isNaN(abdomen) || isNaN(thigh)) return;
            sumSf = chest + abdomen + thigh;
            bodyDensity = 1.10938 - (0.0008267 * sumSf) + (0.0000016 * sumSf * sumSf) - (0.0002574 * age);
        } else {
            const tricep = parseFloat(document.getElementById('sfTricep').value);
            const suprailiac = parseFloat(document.getElementById('sfSuprailiac').value);
            const thigh = parseFloat(document.getElementById('sfThighF').value);
            if (isNaN(tricep) || isNaN(suprailiac) || isNaN(thigh)) return;
            sumSf = tricep + suprailiac + thigh;
            bodyDensity = 1.0994921 - (0.0009929 * sumSf) + (0.0000023 * sumSf * sumSf) - (0.0001392 * age);
        }

        // Siri equation
        bodyFat = (495 / bodyDensity) - 450;
    }

    // Clamp body fat to reasonable range
    bodyFat = Math.max(1, Math.min(60, bodyFat));

    const fatMassKg = weightKg * (bodyFat / 100);
    const leanMassKg = weightKg - fatMassKg;

    const category = getCategory(bodyFat, gender);

    // Update UI
    document.getElementById('bfPercent').textContent = bodyFat.toFixed(1) + '%';

    if (currentUnit === 'metric') {
        document.getElementById('fatMass').textContent = fatMassKg.toFixed(1) + ' kg';
        document.getElementById('leanMass').textContent = leanMassKg.toFixed(1) + ' kg';
    } else {
        document.getElementById('fatMass').textContent = (fatMassKg / 0.453592).toFixed(1) + ' lbs';
        document.getElementById('leanMass').textContent = (leanMassKg / 0.453592).toFixed(1) + ' lbs';
    }

    document.getElementById('bfCategoryText').textContent = category.name;
    document.getElementById('bfCategoryText').style.color = category.color;
    document.getElementById('categoryBox').style.borderLeftColor = category.color;

    // Position marker
    const markerPos = Math.max(0, Math.min(100, getMarkerPos(bodyFat, gender)));
    document.getElementById('bfMarker').style.left = markerPos + '%';

    document.getElementById('results').classList.add('active');
});

function toggleFaq(btn) {
    const item = btn.parentElement;
    item.classList.toggle('open');
}

// Initialize
setUnitSystem('metric');
updateGenderFields();
  </script>

