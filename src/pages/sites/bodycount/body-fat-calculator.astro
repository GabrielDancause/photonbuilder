                            <div class="result-val" id="bfPercent">0.0%</div>
                        </div>
                        <div class="result-card">
                            <div class="result-title">Fat Mass</div>
                            <div class="result-val" id="fatMass">0.0</div>
                        </div>
                        <div class="result-card">
