---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Best Meal Replacement Shakes 2026",
    "url": "https://bodycount.photonbuilder.com/best-meal-replacement-shakes",
    "description": "Compare the best meal replacement shakes of 2026. Review Huel, Soylent, Ka Chava, and more for calories, protein, macros, and dietary options."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are meal replacement shakes healthy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, high-quality meal replacement shakes can be healthy. They are designed to provide a balanced mix of proteins, carbohydrates, fats, and essential vitamins and minerals similar to a whole food meal."
        }
      },
      {
        "@type": "Question",
        "name": "Can I lose weight using meal replacement shakes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Meal replacement shakes can aid in weight loss by providing portion control and a known calorie count, which helps in maintaining a caloric deficit."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between protein powder and a meal replacement shake?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Protein powders are primarily designed to supplement protein intake, while meal replacement shakes include a balance of protein, carbs, fats, fiber, and micronutrients to mimic a complete meal."
        }
      },
      {
        "@type": "Question",
        "name": "Are there vegan meal replacement shakes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, many brands offer vegan options using plant-based proteins like pea, rice, or soy, such as Huel, Soylent, and Ka Chava."
        }
      },
      {
        "@type": "Question",
        "name": "How many meal replacement shakes can I drink a day?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most people consume 1-2 shakes a day as convenient meal substitutes. It's generally recommended to still eat whole foods for at least one or two meals daily to ensure dietary variety."
        }
      }
    ]
  }
];

const categories = [
  { name: 'Best Overall', brand: 'Huel Black Edition', desc: 'High protein, nutritionally complete, and great value with low carbs.' },
  { name: 'Best Budget', brand: 'Soylent', desc: 'The original pioneer. Smooth texture, affordable, and fully plant-based.' },
  { name: 'Best Whole Food', brand: 'Ka Chava', desc: 'Premium ingredients with superfoods, probiotics, and adaptogens.' },
  { name: 'Best Keto', brand: 'Ample K', desc: 'Specially formulated for ketogenic diets with high healthy fats.' },
  { name: 'Best Taste', brand: 'Orgain Organic', desc: 'Delicious flavor profiles with clean, organic ingredients.' },
];

const shakes = [
  { brand: 'Huel Black Edition', diet: 'Vegan, GF', calories: 400, protein: 40, carbs: 17, fat: 18, price: 2.50 },
  { brand: 'Soylent', diet: 'Vegan', calories: 400, protein: 20, carbs: 36, fat: 21, price: 1.80 },
  { brand: 'Ka Chava', diet: 'Vegan, GF', calories: 240, protein: 25, carbs: 24, fat: 7, price: 4.65 },
  { brand: 'Ample K', diet: 'Keto, GF', calories: 400, protein: 13, carbs: 3, fat: 34, price: 5.50 },
  { brand: 'Garden of Life Raw Organic', diet: 'Vegan, GF', calories: 130, protein: 20, carbs: 13, fat: 2.5, price: 2.10 },
  { brand: 'Orgain Organic', diet: 'Vegan, GF', calories: 230, protein: 20, carbs: 25, fat: 7, price: 2.20 },
  { brand: 'Premier Protein', diet: 'GF', calories: 160, protein: 30, carbs: 5, fat: 3, price: 1.50 },
  { brand: 'Ensure Max Protein', diet: 'GF', calories: 150, protein: 30, carbs: 6, fat: 1.5, price: 2.00 },
];
---

<SiteLayout
  site="bodycount"
  title="8 Best Meal Replacement Shakes 2026 - BodyCount"
  description="Compare the top meal replacement shakes including Huel, Soylent, Ka Chava, and more. See calories, macros, and dietary options."
  canonical="https://bodycount.photonbuilder.com/best-meal-replacement-shakes"
  schema={schema}
>
  <div class="page-wrapper">
    <div class="hero-section">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">8 Best Meal Replacement Shakes 2026</h1>
      <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
        Compare the top meal replacement shakes based on nutrition, macros, dietary options, and value.
      </p>
    </div>

    <main class="container">
      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Top Category Winners</h2>
        <div class="category-grid">
          {categories.map(cat => (
            <div class="category-card">
              <div class="cat-title">{cat.name}</div>
              <div class="cat-brand">{cat.brand}</div>
              <div class="cat-desc">{cat.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6">Compare All Shakes</h2>
        <p class="text-[var(--text-secondary)] mb-6 text-sm">Click column headers to sort.</p>

        <div class="table-container">
          <table id="shakeTable">
            <thead>
              <tr>
                <th data-sort="brand">Brand ↕</th>
                <th data-sort="diet">Diet ↕</th>
                <th data-sort="calories">Calories ↕</th>
                <th data-sort="protein">Protein (g) ↕</th>
                <th data-sort="carbs">Carbs (g) ↕</th>
                <th data-sort="fat">Fat (g) ↕</th>
                <th data-sort="price">Price / Serving ($) ↕</th>
              </tr>
            </thead>
            <tbody id="shakeTbody">
              {shakes.map(shake => (
                <tr>
                  <td class="font-medium">{shake.brand}</td>
                  <td><span class="diet-badge">{shake.diet}</span></td>
                  <td data-val={shake.calories}>{shake.calories}</td>
                  <td class="font-bold text-[var(--accent-color)]" data-val={shake.protein}>{shake.protein}g</td>
                  <td data-val={shake.carbs}>{shake.carbs}g</td>
                  <td data-val={shake.fat}>{shake.fat}g</td>
                  <td class="font-mono text-sm" data-val={shake.price}>${shake.price.toFixed(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="faq-section">
        <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
        <div class="faq-list">
          {schema[1].mainEntity.map((faq: any) => (
            <div class="faq-item">
              <div class="faq-q">{faq.name}</div>
              <div class="faq-a">{faq.acceptedAnswer.text}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>

  <style>
    .page-wrapper {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;

      background-color: var(--bg-color);
      color: var(--text-primary);
      min-height: 100vh;
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Category Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .category-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }

    .cat-title {
      font-size: 0.875rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .cat-brand {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .cat-desc {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
    }

    /* Table Styles */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 4rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background: var(--chart-header);
      padding: 1rem 1.5rem;
      font-weight: 600;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
      transition: color 0.2s;
    }

    th:hover {
      color: var(--text-primary);
    }

    td {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--table-hover);
    }

    .diet-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-secondary);
    }

    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <script is:inline>
    const tbody = document.getElementById('shakeTbody');
    if (tbody) {
      const rows = Array.from(tbody.querySelectorAll('tr'));
      let currentSort = { col: null, asc: true };

      function applySort() {
        rows.sort((a, b) => {
          let valA, valB;
          if (currentSort.col === 'brand' || currentSort.col === 'diet') {
            valA = a.querySelector(`td:nth-child(${currentSort.col === 'brand' ? 1 : 2})`).textContent.trim();
            valB = b.querySelector(`td:nth-child(${currentSort.col === 'brand' ? 1 : 2})`).textContent.trim();
            return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
          } else {
            const idx = currentSort.col === 'calories' ? 3 :
                        (currentSort.col === 'protein' ? 4 :
                        (currentSort.col === 'carbs' ? 5 :
                        (currentSort.col === 'fat' ? 6 : 7)));
            valA = parseFloat(a.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
            valB = parseFloat(b.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
            return currentSort.asc ? valA - valB : valB - valA;
          }
        });

        tbody.innerHTML = '';
        rows.forEach(r => tbody.appendChild(r));
      }

      function handleSortClick(e) {
        if (e.target.tagName !== 'TH' || !e.target.dataset.sort) return;

        const col = e.target.dataset.sort;
        if (currentSort.col === col) {
          currentSort.asc = !currentSort.asc;
        } else {
          currentSort.col = col;
          currentSort.asc = true;
        }

        applySort();
      }

      const thead = document.querySelector('thead');
      if (thead) {
        thead.addEventListener('click', handleSortClick);
      }
    }
  </script>
</SiteLayout>
