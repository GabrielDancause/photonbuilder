  <script is:inline>
let currentUnit = 'kg';

function setUnit(unit) {
    currentUnit = unit;
    document.getElementById('btnKg').classList.toggle('active', unit === 'kg');
    document.getElementById('btnLbs').classList.toggle('active', unit === 'lbs');
    document.getElementById('weightKgGroup').style.display = unit === 'kg' ? 'block' : 'none';
    document.getElementById('weightLbsGroup').style.display = unit === 'lbs' ? 'block' : 'none';
    document.getElementById('weightKg').required = unit === 'kg';
    document.getElementById('weightLbs').required = unit === 'lbs';
    document.getElementById('results').classList.remove('active');
}

document.getElementById('waterForm').addEventListener('submit', function(e) {
    e.preventDefault();

    let weightKg;
    if (currentUnit === 'kg') {
        weightKg = parseFloat(document.getElementById('weightKg').value);
    } else {
        const lbs = parseFloat(document.getElementById('weightLbs').value);
        if (isNaN(lbs)) return;
        weightKg = lbs * 0.453592;
    }
    if (isNaN(weightKg) || weightKg <= 0) return;

    const activityMultiplier = parseFloat(document.getElementById('activity').value);
    const climateMultiplier = parseFloat(document.getElementById('climate').value);
    const special = document.querySelector('input[name="special"]:checked').value;

    // Base: 35 ml per kg of body weight
    let waterMl = weightKg * 35;

    // Apply multipliers
    waterMl *= activityMultiplier;
    waterMl *= climateMultiplier;

    // Special conditions
    if (special === 'pregnant') {
        waterMl += 300; // ~10 oz extra
    } else if (special === 'breastfeeding') {
        waterMl += 700; // ~24 oz extra
    }

    // Convert
    const waterOz = waterMl / 29.5735;
    const waterCups = waterOz / 8;
    const waterLiters = waterMl / 1000;

    // Update results
    document.getElementById('resultOz').textContent = Math.round(waterOz) + ' oz';
    document.getElementById('resultMl').textContent = Math.round(waterMl) + ' ml';
    document.getElementById('resultCups').textContent = waterCups.toFixed(1) + ' cups';
    document.getElementById('resultLiters').textContent = waterLiters.toFixed(1) + ' L';

    // Update bottle
    // Scale: 0% at 0 oz, 100% at a reasonable max (~150 oz)
    const fillPct = Math.min(100, Math.max(5, (waterOz / 150) * 100));
    document.getElementById('bottleWater').style.height = fillPct + '%';
    document.getElementById('bottleLabel').textContent = Math.round(waterOz) + ' oz / ' + waterLiters.toFixed(1) + ' L';
    document.getElementById('bottleSublabel').textContent = Math.round(waterCups) + ' cups per day';

    // Build hourly schedule (16 waking hours, 7 AM - 11 PM)
    const wakingHours = 16;
    const perHourMl = waterMl / wakingHours;
    const perHourOz = waterOz / wakingHours;

    const scheduleBody = document.getElementById('scheduleBody');
    scheduleBody.innerHTML = '';

    const timeSlots = [
        { time: '7:00 AM', label: 'Wake up — drink first' },
        { time: '8:00 AM', label: 'With breakfast' },
        { time: '9:00 AM', label: 'Mid-morning' },
        { time: '10:00 AM', label: 'Mid-morning' },
        { time: '11:00 AM', label: 'Before lunch' },
        { time: '12:00 PM', label: 'With lunch' },
        { time: '1:00 PM', label: 'After lunch' },
        { time: '2:00 PM', label: 'Afternoon' },
        { time: '3:00 PM', label: 'Afternoon' },
        { time: '4:00 PM', label: 'Late afternoon' },
        { time: '5:00 PM', label: 'Before dinner' },
        { time: '6:00 PM', label: 'With dinner' },
        { time: '7:00 PM', label: 'Evening' },
        { time: '8:00 PM', label: 'Evening' },
        { time: '9:00 PM', label: 'Wind down' },
        { time: '10:00 PM', label: 'Last glass' },
    ];

    timeSlots.forEach(slot => {
        const tr = document.createElement('tr');
        tr.innerHTML = '<td class="time-col">' + slot.time + '</td>' +
            '<td>' + slot.label + '</td>' +
            '<td class="amount-col">' + Math.round(perHourOz) + ' oz / ' + Math.round(perHourMl) + ' ml</td>';
        scheduleBody.appendChild(tr);
    });

    document.getElementById('results').classList.add('active');
});

function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    item.classList.toggle('open');
}

// Initialize
setUnit('kg');
  </script>
</SiteLayout>
