---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const postureProblems = [
  {
    issue: "Forward Head Posture",
    causes: "Staring at screens, poor sleeping positions, weak neck muscles.",
    assessment: "Stand against a wall with your heels, buttocks, and shoulders touching it. If your head doesn't naturally touch the wall, you may have forward head posture.",
    exercises: "Chin Tucks: Gently pull your chin straight back as if making a double chin. Hold for 5 seconds. Repeat 10 times.",
    routine: "Perform Chin Tucks 3 times a day. Stretch the upper trapezius by gently pulling your ear to your shoulder and holding for 30 seconds per side."
  },
  {
    issue: "Rounded Shoulders",
    causes: "Prolonged sitting, hunching over keyboards, imbalanced chest/back training.",
    assessment: "Stand naturally. If your thumbs point toward each other rather than forward, your shoulders are likely rounded internally.",
    exercises: "Doorway Stretch: Place your forearms on a doorframe at 90 degrees and lean forward to stretch the chest. Band Pull-Aparts: Squeeze shoulder blades together while pulling a resistance band apart.",
    routine: "Do the Doorway Stretch for 30 seconds, 3 times daily. Perform 2 sets of 15 Band Pull-Aparts every evening."
  },
  {
    issue: "Anterior Pelvic Tilt",
    causes: "Sitting for long hours, weak glutes and hamstrings, tight hip flexors.",
    assessment: "The Thomas Test: Lie on your back on a table, pull one knee to your chest, and let the other leg hang. If the hanging leg's thigh lifts off the table, your hip flexors are tight.",
    exercises: "Glute Bridges: Lie on your back, knees bent, and lift your hips by squeezing your glutes. Plank: Core strengthening to stabilize the pelvis.",
    routine: "Hold a Kneeling Hip Flexor Stretch for 45 seconds per side daily. Do 3 sets of 15 Glute Bridges every other day."
  },
  {
    issue: "Desk Worker Syndrome",
    causes: "A combination of forward head posture, rounded shoulders, and anterior pelvic tilt from prolonged sedentary desk work.",
    assessment: "Check for persistent neck/back ache after working, and a visible hunching posture when unaware.",
    exercises: "Thoracic Extensions: Lie back over a foam roller placed at your mid-back. Y-T-W Raises: Lie face down and raise your arms in Y, T, and W shapes to strengthen the upper back.",
    routine: "Take a 5-minute movement break every hour to walk and perform a quick chest stretch and thoracic extension."
  }
];

const ergonomicTips = [
  { item: "Monitor Height", tip: "The top of your screen should be at or slightly below eye level to prevent looking down." },
  { item: "Chair Height", tip: "Your feet should be flat on the floor with your knees at a 90-degree angle." },
  { item: "Keyboard Position", tip: "Keep your elbows close to your body and bent at 90 degrees when typing." },
  { item: "Lumbar Support", tip: "Use a chair with built-in lower back support or a lumbar cushion to maintain the natural curve of your spine." }
];

const standingDeskTips = [
  { tip: "Don't Stand All Day", description: "Alternate between sitting and standing every 30-60 minutes." },
  { tip: "Use an Anti-Fatigue Mat", description: "Reduces pressure on your feet and lower back while standing." },
  { tip: "Wear Supportive Shoes", description: "Avoid standing barefoot or in unsupportive footwear for long periods." }
];

const reminderApps = [
  { name: "Posture Reminder Apps", description: "Apps like PostureMinder or Stand Up! send notifications at set intervals to check your posture." },
  { name: "Wearable Trackers", description: "Devices like Upright GO attach to your back and vibrate when you slouch." }
];

const faqList = [
  {
    question: "How long does it take to fix bad posture?",
    answer: "Consistency is key. Minor postural issues can start improving within a few weeks of daily stretching and strengthening. However, deeply ingrained habits or structural issues may take several months to a year of dedicated effort to correct fully."
  },
  {
    question: "Is it ever too late to correct my posture?",
    answer: "It's rarely too late to improve your posture. While structural changes from aging (like arthritis) can limit flexibility, strengthening the supporting muscles and improving mobility can still significantly reduce pain and improve alignment at any age."
  },
  {
    question: "Do posture correctors actually work?",
    answer: "Posture correctors can be a helpful temporary reminder to keep your shoulders back, but they shouldn't be relied upon long-term. Overuse can actually weaken your postural muscles because the device is doing the work instead of your body."
  },
  {
    question: "Can bad posture cause headaches?",
    answer: "Yes. Forward head posture places excessive strain on the muscles of the neck and upper back, which can lead to tension headaches and cervicogenic headaches originating from the neck."
  },
  {
    question: "How often should I do these corrective exercises?",
    answer: "For best results, aim to do the stretches daily and the strengthening exercises 3-4 times a week. Frequent, short sessions are more effective for postural correction than infrequent, long sessions."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/posture-correction-guide"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<SiteLayout
  site="bodycount"
  title="Posture Correction Guide | BodyCount"
  description="Fix common posture problems like forward head posture and rounded shoulders. Discover causes, self-assessments, corrective exercises, and daily routines."
  canonical="https://bodycount.photonbuilder.com/posture-correction-guide"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Posture Correction Guide</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        Fix common posture problems like forward head posture, rounded shoulders, and anterior pelvic tilt. Discover causes, self-assessments, corrective exercises, and daily routines.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Common Posture Problems</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Identify and address the most prevalent postural deviations affecting modern lifestyles.</div>
        <table>
          <thead>
            <tr>
              <th>Issue</th>
              <th>Causes</th>
              <th>Self-Assessment</th>
              <th>Corrective Exercises</th>
              <th>Daily Routine</th>
            </tr>
          </thead>
          <tbody>
            {postureProblems.map(item => (
              <tr>
                <td><strong>{item.issue}</strong></td>
                <td>{item.causes}</td>
                <td>{item.assessment}</td>
                <td>{item.exercises}</td>
                <td><em>{item.routine}</em></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Ergonomic Desk Setup</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Optimize your workspace to minimize strain and naturally encourage better posture.</div>
        <ul>
          {ergonomicTips.map(item => (
            <li><strong>{item.item}:</strong> {item.tip}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Standing Desk Tips</h2>
        <ul>
          {standingDeskTips.map(item => (
            <li><strong>{item.tip}:</strong> {item.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Posture Reminder Apps & Tools</h2>
        <div class="highlight-box">
          <h4>Stay Mindful Throughout the Day</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">Technology can be part of the solution by keeping you accountable.</div>
          <ul style="margin-bottom: 0;">
            {reminderApps.map(item => (
              <li><strong>{item.name}:</strong> {item.description}</li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
