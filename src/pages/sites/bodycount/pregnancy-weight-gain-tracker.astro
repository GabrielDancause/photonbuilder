  <script is:inline>
    // IOM Guidelines: { totalLow, totalHigh, weeklyLow, weeklyHigh } (in lbs, for 2nd/3rd tri)
    const IOM = {
      underweight: { totalLow: 28, totalHigh: 40, weeklyLow: 1.0, weeklyHigh: 1.3, tri1Low: 1, tri1High: 5 },
      normal:      { totalLow: 25, totalHigh: 35, weeklyLow: 0.8, weeklyHigh: 1.0, tri1Low: 1, tri1High: 5 },
      overweight:  { totalLow: 15, totalHigh: 25, weeklyLow: 0.5, weeklyHigh: 0.7, tri1Low: 1, tri1High: 5 },
      obese:       { totalLow: 11, totalHigh: 20, weeklyLow: 0.4, weeklyHigh: 0.6, tri1Low: 1, tri1High: 5 }
    };

    let isMetric = false;
    let weightLog = JSON.parse(localStorage.getItem('pregnancyWeightLog') || '[]');
    let calcState = null;

    // Unit toggle
    document.querySelectorAll('.unit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        isMetric = btn.dataset.unit === 'metric';
        document.getElementById('heightGroup').style.display = isMetric ? 'none' : '';
        document.getElementById('heightCmGroup').style.display = isMetric ? '' : 'none';
        document.getElementById('preWeight').placeholder = isMetric ? '68 kg' : '150 lbs';
        document.getElementById('currentWeight').placeholder = isMetric ? '70 kg' : '155 lbs';
        document.getElementById('logWeight').placeholder = isMetric ? 'kg' : 'lbs';
        document.getElementById('results').classList.remove('active');
      });
    });

    function getBmiCategory(bmi) {
      if (bmi < 18.5) return 'underweight';
      if (bmi < 25) return 'normal';
      if (bmi < 30) return 'overweight';
      return 'obese';
    }

    function getBmiLabel(cat) {
      return cat.charAt(0).toUpperCase() + cat.slice(1);
    }

    function lbsToKg(lbs) { return lbs * 0.453592; }
    function kgToLbs(kg) { return kg / 0.453592; }

    function getExpectedGainAtWeek(week, guideline) {
      if (week <= 0) return { low: 0, high: 0 };
      if (week <= 13) {
        const frac = week / 13;
        return { low: guideline.tri1Low * frac, high: guideline.tri1High * frac };
      }
      const weeksAfterTri1 = week - 13;
      return {
        low: guideline.tri1Low + guideline.weeklyLow * weeksAfterTri1,
        high: guideline.tri1High + guideline.weeklyHigh * weeksAfterTri1
      };
    }

    function drawChart() {
      const canvas = document.getElementById('gainChart');
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);

      const W = rect.width;
      const H = rect.height;
      const pad = { top: 20, right: 20, bottom: 40, left: 50 };
      const cw = W - pad.left - pad.right;
      const ch = H - pad.top - pad.bottom;

      if (!calcState) return;
      const { guideline, preWeightLbs, currentWeekNum } = calcState;

      const maxGain = getExpectedGainAtWeek(42, guideline).high;
      const yMax = Math.ceil(maxGain / 5) * 5 + 5;

      function xPos(week) { return pad.left + (week / 42) * cw; }
      function yPos(gain) { return pad.top + ch - (gain / yMax) * ch; }

      // Background
      ctx.fillStyle = '#060c0a';
      ctx.fillRect(0, 0, W, H);

      // Grid lines
      ctx.strokeStyle = '#1a2a24';
      ctx.lineWidth = 0.5;
      for (let g = 0; g <= yMax; g += 5) {
        ctx.beginPath();
        ctx.moveTo(pad.left, yPos(g));
        ctx.lineTo(W - pad.right, yPos(g));
        ctx.stroke();
        ctx.fillStyle = '#888888';
        ctx.font = '10px JetBrains Mono, monospace';
        ctx.textAlign = 'right';
        const label = isMetric ? (g * 0.453592).toFixed(0) + ' kg' : g + ' lbs';
        ctx.fillText(label, pad.left - 8, yPos(g) + 3);
      }

      // X-axis labels
      ctx.textAlign = 'center';
      for (let w = 0; w <= 40; w += 5) {
        ctx.fillStyle = '#888888';
        ctx.fillText('W' + w, xPos(w), H - pad.bottom + 20);
        ctx.strokeStyle = '#1a2a24';
        ctx.beginPath();
        ctx.moveTo(xPos(w), pad.top);
        ctx.lineTo(xPos(w), H - pad.bottom);
        ctx.stroke();
      }

      // Trimester shading
      ctx.globalAlpha = 0.06;
      ctx.fillStyle = '#8b5cf6';
      ctx.fillRect(xPos(0), pad.top, xPos(13) - xPos(0), ch);
      ctx.fillStyle = '#f59e0b';
      ctx.fillRect(xPos(13), pad.top, xPos(27) - xPos(13), ch);
      ctx.fillStyle = '#ef4444';
      ctx.fillRect(xPos(27), pad.top, xPos(40) - xPos(27), ch);
      ctx.globalAlpha = 1;

      // Recommended range (filled area)
      ctx.beginPath();
      for (let w = 0; w <= 42; w++) {
        const g = getExpectedGainAtWeek(w, guideline);
        const x = xPos(w), y = yPos(g.high);
        w === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      for (let w = 42; w >= 0; w--) {
        const g = getExpectedGainAtWeek(w, guideline);
        ctx.lineTo(xPos(w), yPos(g.low));
      }
      ctx.closePath();
      ctx.fillStyle = 'rgba(45, 184, 154, 0.15)';
      ctx.fill();

      // Upper bound line
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(45, 184, 154, 0.5)';
      ctx.lineWidth = 1.5;
      ctx.setLineDash([4, 4]);
      for (let w = 0; w <= 42; w++) {
        const g = getExpectedGainAtWeek(w, guideline);
        const x = xPos(w), y = yPos(g.high);
        w === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();

      // Lower bound line
      ctx.beginPath();
      for (let w = 0; w <= 42; w++) {
        const g = getExpectedGainAtWeek(w, guideline);
        const x = xPos(w), y = yPos(g.low);
        w === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.setLineDash([]);

      // Plot weight log entries
      const sortedLog = [...weightLog].sort((a, b) => a.week - b.week);
      if (sortedLog.length > 0) {
        ctx.beginPath();
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 2;
        sortedLog.forEach((entry, i) => {
          const gain = (isMetric ? kgToLbs(entry.weight) : entry.weight) - preWeightLbs;
          const x = xPos(entry.week), y = yPos(gain);
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        });
        ctx.stroke();

        sortedLog.forEach(entry => {
          const gain = (isMetric ? kgToLbs(entry.weight) : entry.weight) - preWeightLbs;
          const x = xPos(entry.week), y = yPos(gain);
          const expected = getExpectedGainAtWeek(entry.week, guideline);
          const inRange = gain >= expected.low && gain <= expected.high;

          ctx.beginPath();
          ctx.arc(x, y, 4, 0, Math.PI * 2);
          ctx.fillStyle = inRange ? '#34d399' : '#f87171';
          ctx.fill();
          ctx.strokeStyle = '#ffffff';
          ctx.lineWidth = 1.5;
          ctx.stroke();
        });
      }

      // Current weight marker
      if (calcState.currentWeightLbs) {
        const gain = calcState.currentWeightLbs - preWeightLbs;
        const x = xPos(currentWeekNum);
        const y = yPos(gain);
        ctx.beginPath();
        ctx.arc(x, y, 6, 0, Math.PI * 2);
        ctx.fillStyle = '#2DB89A';
        ctx.fill();
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 2;
        ctx.stroke();
      }

      // Legend
      ctx.font = '10px Inter, sans-serif';
      const legendY = H - 8;
      ctx.fillStyle = 'rgba(45, 184, 154, 0.4)';
      ctx.fillRect(pad.left, legendY - 6, 12, 3);
      ctx.fillStyle = '#888888';
      ctx.textAlign = 'left';
      ctx.fillText('Recommended range', pad.left + 16, legendY);

      if (sortedLog.length > 0 || calcState.currentWeightLbs) {
        const lx = pad.left + 140;
        ctx.beginPath();
        ctx.arc(lx + 4, legendY - 4, 3, 0, Math.PI * 2);
        ctx.fillStyle = '#2DB89A';
        ctx.fill();
        ctx.fillStyle = '#888888';
        ctx.fillText('Your weight', lx + 12, legendY);
      }
    }

    document.getElementById('calcForm').addEventListener('submit', function(e) {
      e.preventDefault();

      let preWeightLbs, heightInches;

      if (isMetric) {
        const preKg = parseFloat(document.getElementById('preWeight').value);
        const heightCm = parseFloat(document.getElementById('heightCm').value);
        if (!preKg || !heightCm) return;
        preWeightLbs = kgToLbs(preKg);
        heightInches = heightCm / 2.54;
      } else {
        preWeightLbs = parseFloat(document.getElementById('preWeight').value);
        const ft = parseInt(document.getElementById('heightFt').value);
        const inches = parseInt(document.getElementById('heightIn').value) || 0;
        if (!preWeightLbs || !ft) return;
        heightInches = ft * 12 + inches;
      }

      const currentWeekNum = parseInt(document.getElementById('currentWeek').value);
      const currentWeightVal = parseFloat(document.getElementById('currentWeight').value);
      let currentWeightLbs = null;
      if (currentWeightVal) {
        currentWeightLbs = isMetric ? kgToLbs(currentWeightVal) : currentWeightVal;
      }

      // BMI: (weight in lbs * 703) / (height in inches)^2
      const bmi = (preWeightLbs * 703) / (heightInches * heightInches);
      const bmiCat = getBmiCategory(bmi);
      const guideline = IOM[bmiCat];

      calcState = { guideline, preWeightLbs, currentWeekNum, currentWeightLbs, bmi, bmiCat };

      // Update hero
      const displayUnit = isMetric ? 'kg' : 'lbs';
      const low = isMetric ? (guideline.totalLow * 0.453592).toFixed(1) : guideline.totalLow;
      const high = isMetric ? (guideline.totalHigh * 0.453592).toFixed(1) : guideline.totalHigh;
      document.getElementById('totalGain').textContent = low + '\u2013' + high + ' ' + displayUnit;

      if (currentWeightLbs) {
        const actualGain = currentWeightLbs - preWeightLbs;
        const expected = getExpectedGainAtWeek(currentWeekNum, guideline);
        const dispGain = isMetric ? (actualGain * 0.453592).toFixed(1) : actualGain.toFixed(1);
        const inRange = actualGain >= expected.low && actualGain <= expected.high;
        document.getElementById('gainSub').textContent = 'Current gain: ' + dispGain + ' ' + displayUnit + ' at week ' + currentWeekNum + ' \u2014 ' + (inRange ? 'within recommended range' : 'outside recommended range');
        document.getElementById('gainSub').style.color = inRange ? '#34d399' : '#f87171';
      } else {
        document.getElementById('gainSub').textContent = 'Based on your BMI category: ' + getBmiLabel(bmiCat);
        document.getElementById('gainSub').style.color = '';
      }

      // Stats
      document.getElementById('bmiValue').textContent = bmi.toFixed(1);
      const catEl = document.getElementById('bmiCategory');
      catEl.textContent = getBmiLabel(bmiCat);
      catEl.className = 'stat-value ' + bmiCat;

      const wkLow = isMetric ? (guideline.weeklyLow * 0.453592).toFixed(2) : guideline.weeklyLow;
      const wkHigh = isMetric ? (guideline.weeklyHigh * 0.453592).toFixed(2) : guideline.weeklyHigh;
      document.getElementById('weeklyRate').textContent = wkLow + '\u2013' + wkHigh + ' ' + displayUnit + '/wk';

      const targetLow = isMetric ? ((preWeightLbs + guideline.totalLow) * 0.453592).toFixed(1) : (preWeightLbs + guideline.totalLow).toFixed(1);
      const targetHigh = isMetric ? ((preWeightLbs + guideline.totalHigh) * 0.453592).toFixed(1) : (preWeightLbs + guideline.totalHigh).toFixed(1);
      document.getElementById('targetWeight').textContent = targetLow + '\u2013' + targetHigh + ' ' + displayUnit;

      // Trimester breakdown
      const tri1 = getExpectedGainAtWeek(13, guideline);
      const tri2End = getExpectedGainAtWeek(27, guideline);
      const tri3End = getExpectedGainAtWeek(40, guideline);

      function fmtRange(lo, hi) {
        if (isMetric) return (lo * 0.453592).toFixed(1) + '\u2013' + (hi * 0.453592).toFixed(1) + ' kg';
        return lo.toFixed(1) + '\u2013' + hi.toFixed(1) + ' lbs';
      }

      document.getElementById('tri1Gain').textContent = fmtRange(tri1.low, tri1.high);
      document.getElementById('tri2Gain').textContent = fmtRange(tri2End.low - tri1.low, tri2End.high - tri1.high);
      document.getElementById('tri3Gain').textContent = fmtRange(tri3End.low - tri2End.low, tri3End.high - tri2End.high);

      // Highlight matching row in recommendations table
      document.querySelectorAll('#recTableBody tr').forEach(tr => tr.classList.remove('highlight'));
      const rowIndex = { underweight: 0, normal: 1, overweight: 2, obese: 3 }[bmiCat];
      document.querySelectorAll('#recTableBody tr')[rowIndex].classList.add('highlight');

      // Set log week default
      document.getElementById('logWeek').value = currentWeekNum;

      document.getElementById('results').classList.add('active');

      renderLog();
      setTimeout(drawChart, 50);
    });

    // Weight log
    function saveLog() {
      localStorage.setItem('pregnancyWeightLog', JSON.stringify(weightLog));
    }

    function renderLog() {
      const container = document.getElementById('logEntries');
      const actions = document.getElementById('logActions');

      if (weightLog.length === 0) {
        container.innerHTML = '<div class="log-empty">No entries yet. Add your weekly weigh-ins above to track progress.</div>';
        actions.style.display = 'none';
        return;
      }

      actions.style.display = '';
      const sorted = [...weightLog].sort((a, b) => a.week - b.week);
      container.innerHTML = sorted.map(function(entry) {
        const origIdx = weightLog.indexOf(entry);
        const gain = (isMetric ? kgToLbs(entry.weight) : entry.weight) - (calcState ? calcState.preWeightLbs : 0);
        const displayWeight = isMetric ? entry.weight.toFixed(1) + ' kg' : entry.weight.toFixed(1) + ' lbs';
        const displayGain = isMetric ? (gain * 0.453592).toFixed(1) + ' kg' : gain.toFixed(1) + ' lbs';

        var rangeClass = '';
        if (calcState) {
          const expected = getExpectedGainAtWeek(entry.week, calcState.guideline);
          rangeClass = (gain >= expected.low && gain <= expected.high) ? 'in-range' : 'out-range';
        }

        return '<div class="log-entry">' +
          '<div class="log-entry-info">' +
            '<span class="log-week">Wk ' + entry.week + '</span>' +
            '<span class="log-weight">' + displayWeight + '</span>' +
            '<span class="log-gain ' + rangeClass + '">' + (gain >= 0 ? '+' : '') + displayGain + '</span>' +
          '</div>' +
          '<button class="log-delete" onclick="deleteLog(' + origIdx + ')" title="Remove">&times;</button>' +
        '</div>';
      }).join('');
    }

    window.deleteLog = function(idx) {
      weightLog.splice(idx, 1);
      saveLog();
      renderLog();
      drawChart();
    };

    document.getElementById('addLogBtn').addEventListener('click', function() {
      const week = parseInt(document.getElementById('logWeek').value);
      const weight = parseFloat(document.getElementById('logWeight').value);
      if (!week || !weight) return;

      weightLog = weightLog.filter(function(e) { return e.week !== week; });
      weightLog.push({ week: week, weight: weight });
      saveLog();
      renderLog();
      drawChart();
      document.getElementById('logWeight').value = '';
    });

    document.getElementById('clearLogBtn').addEventListener('click', function() {
      if (confirm('Clear all weight log entries?')) {
        weightLog = [];
        saveLog();
        renderLog();
        drawChart();
      }
    });

    window.addEventListener('resize', function() {
      if (calcState) drawChart();
    });
  </script>
</SiteLayout>
