    </main>
  </div>

  <script is:inline>
    // IOM Guidelines
    const IOM_SINGLE = {
      underweight: { min: 28, max: 40, weeklyMin: 1.0, weeklyMax: 1.3, label: 'Underweight', bmiRange: 'BMI < 18.5' },
      normal:      { min: 25, max: 35, weeklyMin: 0.8, weeklyMax: 1.0, label: 'Normal Weight', bmiRange: 'BMI 18.5–24.9' },
      overweight:  { min: 15, max: 25, weeklyMin: 0.5, weeklyMax: 0.7, label: 'Overweight', bmiRange: 'BMI 25–29.9' },
      obese:       { min: 11, max: 20, weeklyMin: 0.4, weeklyMax: 0.6, label: 'Obese', bmiRange: 'BMI ≥ 30' }
    };

    const IOM_TWINS = {
      underweight: { min: 50, max: 62, weeklyMin: 1.5, weeklyMax: 1.7, label: 'Underweight', bmiRange: 'BMI < 18.5' },
      normal:      { min: 37, max: 54, weeklyMin: 1.3, weeklyMax: 1.5, label: 'Normal Weight', bmiRange: 'BMI 18.5–24.9' },
      overweight:  { min: 31, max: 50, weeklyMin: 1.0, weeklyMax: 1.3, label: 'Overweight', bmiRange: 'BMI 25–29.9' },
      obese:       { min: 25, max: 42, weeklyMin: 0.8, weeklyMax: 1.1, label: 'Obese', bmiRange: 'BMI ≥ 30' }
    };

    const FIRST_TRI_GAIN = { min: 1.1, max: 4.4 }; // lbs total in first 13 weeks

    let currentUnit = 'imperial';
    let trackedWeights = [];
    let chartInstance = null;
    let lastCalcData = null;

    // Unit toggle
    document.querySelectorAll('.unit-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentUnit = btn.dataset.unit;
        const imperial = currentUnit === 'imperial';
        document.getElementById('imperialHeight').style.display = imperial ? 'flex' : 'none';
        document.getElementById('metricHeight').style.display = imperial ? 'none' : 'block';
        document.getElementById('weightUnitLabel').textContent = imperial ? 'Weight unit: lbs' : 'Weight unit: kg';
      });
    });

    function getHeightInches() {
      if (currentUnit === 'imperial') {
        const ft = parseFloat(document.getElementById('heightFeet').value) || 0;
        const inc = parseFloat(document.getElementById('heightInches').value) || 0;
        return ft * 12 + inc;
      } else {
        const cm = parseFloat(document.getElementById('heightCm').value) || 0;
        return cm / 2.54;
      }
    }

    function getWeightLbs(val) {
      if (currentUnit === 'metric') return val * 2.20462;
      return val;
    }

    function lbsToDisplay(lbs) {
      if (currentUnit === 'metric') return (lbs / 2.20462).toFixed(1) + ' kg';
      return lbs.toFixed(1) + ' lbs';
    }

    function getBMICategory(bmi) {
      if (bmi < 18.5) return 'underweight';
      if (bmi < 25) return 'normal';
      if (bmi < 30) return 'overweight';
      return 'obese';
    }

    function calcBMI(weightLbs, heightInches) {
      return (weightLbs / (heightInches * heightInches)) * 703;
    }

    // Generate expected gain curve (lbs gained from pre-pregnancy weight)
    function getExpectedCurve(guidelines) {
      const lowCurve = [];
      const highCurve = [];
      const firstTriWeeklyMin = FIRST_TRI_GAIN.min / 13;
      const firstTriWeeklyMax = FIRST_TRI_GAIN.max / 13;

      for (let w = 0; w <= 40; w++) {
        if (w <= 13) {
          lowCurve.push(firstTriWeeklyMin * w);
          highCurve.push(firstTriWeeklyMax * w);
        } else {
          const weeksAfterFirst = w - 13;
          lowCurve.push(FIRST_TRI_GAIN.min + guidelines.weeklyMin * weeksAfterFirst);
          highCurve.push(FIRST_TRI_GAIN.max + guidelines.weeklyMax * weeksAfterFirst);
        }
      }
      return { lowCurve, highCurve };
    }

    // Draw chart using canvas
    function drawChart(lowCurve, highCurve, currentWeek, trackedData) {
      const canvas = document.getElementById('gainChart');
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);
      const W = rect.width;
      const H = rect.height;

      ctx.clearRect(0, 0, W, H);

      const pad = { top: 20, right: 20, bottom: 40, left: 50 };
      const plotW = W - pad.left - pad.right;
      const plotH = H - pad.top - pad.bottom;

      // Find Y range
      let maxY = Math.max(...highCurve, ...trackedData.map(d => d.gain));
      maxY = Math.ceil(maxY / 5) * 5 + 5;
      const minY = Math.min(0, ...trackedData.map(d => d.gain));

      function xPos(week) { return pad.left + (week / 40) * plotW; }
      function yPos(val) { return pad.top + plotH - ((val - minY) / (maxY - minY)) * plotH; }

      // Grid
      ctx.strokeStyle = '#1a2a24';
      ctx.lineWidth = 1;
      const ySteps = 5;
      for (let i = 0; i <= ySteps; i++) {
        const val = minY + (maxY - minY) * (i / ySteps);
        const y = yPos(val);
        ctx.beginPath();
        ctx.moveTo(pad.left, y);
        ctx.lineTo(W - pad.right, y);
        ctx.stroke();
        ctx.fillStyle = '#888888';
        ctx.font = '11px Inter, sans-serif';
        ctx.textAlign = 'right';
        ctx.fillText(val.toFixed(0), pad.left - 8, y + 4);
      }

      // X labels
      ctx.textAlign = 'center';
      for (let w = 0; w <= 40; w += 8) {
        const x = xPos(w);
        ctx.fillStyle = '#888888';
        ctx.fillText('W' + w, x, H - pad.bottom + 20);
        ctx.beginPath();
        ctx.moveTo(x, pad.top);
        ctx.lineTo(x, pad.top + plotH);
        ctx.stroke();
      }

      // Y axis label
      ctx.save();
      ctx.translate(12, pad.top + plotH / 2);
      ctx.rotate(-Math.PI / 2);
      ctx.fillStyle = '#888888';
      ctx.font = '11px Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(currentUnit === 'metric' ? 'kg gained' : 'lbs gained', 0, 0);
      ctx.restore();

      // Recommended range (shaded area)
      ctx.beginPath();
      for (let w = 0; w <= 40; w++) {
        const x = xPos(w);
        const y = yPos(currentUnit === 'metric' ? lowCurve[w] / 2.20462 : lowCurve[w]);
        if (w === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      for (let w = 40; w >= 0; w--) {
        const x = xPos(w);
        const y = yPos(currentUnit === 'metric' ? highCurve[w] / 2.20462 : highCurve[w]);
        ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.fillStyle = 'rgba(45,184,154,0.15)';
      ctx.fill();

      // Low curve line
      ctx.beginPath();
      ctx.strokeStyle = 'rgba(45,184,154,0.5)';
      ctx.lineWidth = 2;
      ctx.setLineDash([5, 5]);
      for (let w = 0; w <= 40; w++) {
        const x = xPos(w);
        const y = yPos(currentUnit === 'metric' ? lowCurve[w] / 2.20462 : lowCurve[w]);
        if (w === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();

      // High curve line
      ctx.beginPath();
      for (let w = 0; w <= 40; w++) {
        const x = xPos(w);
        const y = yPos(currentUnit === 'metric' ? highCurve[w] / 2.20462 : highCurve[w]);
        if (w === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
      ctx.setLineDash([]);

      // Tracked data points
      if (trackedData.length > 0) {
        const sorted = [...trackedData].sort((a, b) => a.week - b.week);

        // Line
        ctx.beginPath();
        ctx.strokeStyle = '#8b5cf6';
        ctx.lineWidth = 2.5;
        sorted.forEach((d, i) => {
          const x = xPos(d.week);
          const displayGain = currentUnit === 'metric' ? d.gain / 2.20462 : d.gain;
          const y = yPos(displayGain);
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        });
        ctx.stroke();

        // Dots
        sorted.forEach(d => {
          const x = xPos(d.week);
          const displayGain = currentUnit === 'metric' ? d.gain / 2.20462 : d.gain;
          const y = yPos(displayGain);
          ctx.beginPath();
          ctx.arc(x, y, 5, 0, Math.PI * 2);
          ctx.fillStyle = '#8b5cf6';
          ctx.fill();
          ctx.strokeStyle = '#0c1410';
          ctx.lineWidth = 2;
          ctx.stroke();
        });
      }

      // Current week marker
      if (currentWeek > 0) {
        const x = xPos(currentWeek);
        ctx.beginPath();
        ctx.strokeStyle = 'rgba(255,255,255,0.3)';
        ctx.lineWidth = 1;
        ctx.setLineDash([3, 3]);
        ctx.moveTo(x, pad.top);
        ctx.lineTo(x, pad.top + plotH);
        ctx.stroke();
        ctx.setLineDash([]);

        ctx.fillStyle = '#ffffff';
        ctx.font = 'bold 10px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('W' + currentWeek, x, pad.top - 5);
      }

      // Legend
      const legendY = H - 8;
      ctx.font = '10px Inter, sans-serif';

      ctx.fillStyle = 'rgba(45,184,154,0.4)';
      ctx.fillRect(pad.left, legendY - 8, 20, 10);
      ctx.fillStyle = '#888888';
      ctx.textAlign = 'left';
      ctx.fillText('Recommended range', pad.left + 24, legendY);

      if (trackedData.length > 0) {
        ctx.fillStyle = '#8b5cf6';
        ctx.beginPath();
        ctx.arc(pad.left + 160, legendY - 3, 4, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#888888';
        ctx.fillText('Your weight', pad.left + 168, legendY);
      }
    }

    function buildMilestoneTable(lowCurve, highCurve, currentWeek) {
      const body = document.getElementById('milestoneBody');
      body.innerHTML = '';
      const weeks = [4, 8, 12, 16, 20, 24, 28, 32, 36, 40];
      weeks.forEach(w => {
        const tr = document.createElement('tr');
        if (w === Math.min(...weeks.filter(wk => wk >= currentWeek))) {
          tr.classList.add('current-row');
        }
        const trimester = w <= 12 ? '1st' : w <= 27 ? '2nd' : '3rd';
        const trimColor = w <= 12 ? 'var(--trim1)' : w <= 27 ? 'var(--trim2)' : 'var(--trim3)';
        tr.innerHTML = `
          <td><span class="week-badge">W${w}</span></td>
          <td>${lbsToDisplay(lowCurve[w])}</td>
          <td>${lbsToDisplay(highCurve[w])}</td>
          <td style="color:${trimColor};font-weight:600;font-size:0.8125rem;">${trimester}</td>
        `;
        body.appendChild(tr);
      });
    }

    function updateBreakdown() {
      // Static breakdown in lbs — update display units
      const items = [
        { lbs: 7.5 }, { lbs: 1.5 }, { lbs: 2 }, { lbs: 4 },
        { lbs: 2 }, { lbs: 2 }, { lbs: 4 }, { lbs: 7 }
      ];
      const grid = document.getElementById('breakdownGrid');
      const values = grid.querySelectorAll('.breakdown-value');
      items.forEach((item, i) => {
        if (values[i]) values[i].textContent = lbsToDisplay(item.lbs);
      });
    }

    function renderTrackedEntries() {
      const container = document.getElementById('trackedEntries');
      container.innerHTML = '';
      const sorted = [...trackedWeights].sort((a, b) => a.week - b.week);
      sorted.forEach((entry, idx) => {
        const div = document.createElement('div');
        div.className = 'track-entry';
        const displayWeight = currentUnit === 'metric'
          ? (entry.weightLbs / 2.20462).toFixed(1) + ' kg'
          : entry.weightLbs.toFixed(1) + ' lbs';
        div.innerHTML = `
          <div class="track-entry-info">
            <span class="track-entry-week">Week ${entry.week}</span>
            <span class="track-entry-weight">${displayWeight}</span>
          </div>
          <button class="track-entry-delete" data-idx="${idx}" title="Remove">&times;</button>
        `;
        container.appendChild(div);
      });

      container.querySelectorAll('.track-entry-delete').forEach(btn => {
        btn.addEventListener('click', () => {
          const i = parseInt(btn.dataset.idx);
          trackedWeights.splice(i, 1);
          renderTrackedEntries();
          if (lastCalcData) redrawChart();
        });
      });
    }

    function redrawChart() {
      if (!lastCalcData) return;
      const { lowCurve, highCurve, currentWeek, preWeightLbs } = lastCalcData;
      const trackedData = trackedWeights.map(e => ({
        week: e.week,
        gain: e.weightLbs - preWeightLbs
      }));
      drawChart(lowCurve, highCurve, currentWeek, trackedData);
    }

    // Main calculation
    document.getElementById('weightForm').addEventListener('submit', (e) => {
      e.preventDefault();

      const preWeightRaw = parseFloat(document.getElementById('preWeight').value);
      const currentWeightRaw = parseFloat(document.getElementById('currentWeight').value);
      const currentWeek = parseInt(document.getElementById('currentWeek').value);
      const numBabies = parseInt(document.getElementById('numBabies').value);
      const heightIn = getHeightInches();

      if (!preWeightRaw || !heightIn) return;

      const preWeightLbs = getWeightLbs(preWeightRaw);
      const bmi = calcBMI(preWeightLbs, heightIn);
      const category = getBMICategory(bmi);
      const guidelines = numBabies === 2 ? IOM_TWINS[category] : IOM_SINGLE[category];
      const { lowCurve, highCurve } = getExpectedCurve(guidelines);

      lastCalcData = { lowCurve, highCurve, currentWeek, preWeightLbs };

      // Display results
      document.getElementById('gainRange').textContent = lbsToDisplay(guidelines.min) + ' – ' + lbsToDisplay(guidelines.max);
      document.getElementById('bmiCategory').textContent = guidelines.label + ' (' + guidelines.bmiRange + ')';
      document.getElementById('bmiValue').textContent = bmi.toFixed(1);
      document.getElementById('targetWeight').textContent = lbsToDisplay(preWeightLbs + (guidelines.min + guidelines.max) / 2);

      // Current gain
      if (currentWeightRaw) {
        const currentWeightLbs = getWeightLbs(currentWeightRaw);
        const gain = currentWeightLbs - preWeightLbs;
        document.getElementById('currentGain').textContent = lbsToDisplay(gain);

        const expectedLow = lowCurve[currentWeek] || 0;
        const expectedHigh = highCurve[currentWeek] || 0;
        const statusEl = document.getElementById('gainStatus');

        if (gain < expectedLow) {
          statusEl.textContent = 'Below Range';
          statusEl.className = 'stat-value under';
        } else if (gain > expectedHigh) {
          statusEl.textContent = 'Above Range';
          statusEl.className = 'stat-value over';
        } else {
          statusEl.textContent = 'On Track';
          statusEl.className = 'stat-value on-track';
        }

        // Auto-add current weight to tracked
        const existingIdx = trackedWeights.findIndex(t => t.week === currentWeek);
        if (existingIdx >= 0) {
          trackedWeights[existingIdx].weightLbs = currentWeightLbs;
        } else {
          trackedWeights.push({ week: currentWeek, weightLbs: currentWeightLbs });
        }
      } else {
        document.getElementById('currentGain').textContent = '—';
        document.getElementById('gainStatus').textContent = '—';
        document.getElementById('gainStatus').className = 'stat-value';
      }

      // Set track week default
      document.getElementById('trackWeek').value = currentWeek;

      // Build milestone table
      buildMilestoneTable(lowCurve, highCurve, currentWeek);

      // Update breakdown units
      updateBreakdown();

      // Render tracked entries
      renderTrackedEntries();

      // Draw chart
      const trackedData = trackedWeights.map(e => ({
        week: e.week,
        gain: e.weightLbs - preWeightLbs
      }));
      drawChart(lowCurve, highCurve, currentWeek, trackedData);

      // Show results
      document.getElementById('results').classList.add('active');
      document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Add tracking entry
    document.getElementById('addTrackBtn').addEventListener('click', () => {
      const week = parseInt(document.getElementById('trackWeek').value);
      const weightRaw = parseFloat(document.getElementById('trackWeight').value);
      if (!weightRaw || !lastCalcData) return;

      const weightLbs = getWeightLbs(weightRaw);
      const existingIdx = trackedWeights.findIndex(t => t.week === week);
      if (existingIdx >= 0) {
        trackedWeights[existingIdx].weightLbs = weightLbs;
      } else {
        trackedWeights.push({ week, weightLbs });
      }

      document.getElementById('trackWeight').value = '';
      renderTrackedEntries();
      redrawChart();
    });

    // FAQ toggle
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => {
        q.parentElement.classList.toggle('open');
      });
    });

    // Resize chart
    window.addEventListener('resize', () => {
      if (lastCalcData) redrawChart();
    });
  </script>
</SiteLayout>
