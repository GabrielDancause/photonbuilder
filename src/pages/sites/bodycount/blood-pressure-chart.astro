---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Blood Pressure Chart & Calculator",
      "url": "https://bodycount.photonbuilder.com/blood-pressure-chart.html",
      "description": "Check your blood pressure category instantly. Interactive blood pressure chart with ranges for Normal, Elevated, Stage 1 & 2 Hypertension, and Hypertensive Crisis. Includes age-based reference tables and history tracking.",
      "applicationCategory": "HealthAndFitnessApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is normal blood pressure?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Normal blood pressure is defined as a systolic reading below 120 mmHg and a diastolic reading below 80 mmHg (written as less than 120/80 mmHg). This range indicates your heart and blood vessels are working efficiently without placing excess strain on artery walls."
          }
        },
        {
          "@type": "Question",
          "name": "What do the two blood pressure numbers mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The top number (systolic) measures the pressure in your arteries when your heart beats and pumps blood out. The bottom number (diastolic) measures the pressure in your arteries between heartbeats when the heart is resting and refilling with blood. Both numbers are important for assessing cardiovascular health."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I check my blood pressure?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The American Heart Association recommends adults with normal blood pressure get checked at least once a year during regular health visits. If you have elevated blood pressure or hypertension, your doctor may recommend checking it more frequently — daily home monitoring is common for those managing hypertension."
          }
        },
        {
          "@type": "Question",
          "name": "Does blood pressure change with age?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, blood pressure generally increases with age due to stiffening of arteries (arteriosclerosis) and plaque buildup. Systolic pressure tends to rise steadily after age 30, while diastolic pressure may plateau or even decrease after age 60. This is why regular monitoring becomes more important as you age."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between Stage 1 and Stage 2 hypertension?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Stage 1 hypertension is defined as systolic 130-139 mmHg or diastolic 80-89 mmHg. Stage 2 hypertension is systolic 140 mmHg or higher, or diastolic 90 mmHg or higher. Stage 2 is more severe and typically requires medication along with lifestyle changes, while Stage 1 may initially be managed with lifestyle modifications alone."
          }
        },
        {
          "@type": "Question",
          "name": "Can I lower my blood pressure naturally without medication?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, many people can lower blood pressure through lifestyle changes including reducing sodium intake (under 2,300 mg/day), exercising regularly (150 minutes per week), maintaining a healthy weight, limiting alcohol, managing stress, eating a DASH diet rich in fruits, vegetables, and whole grains, and quitting smoking. These changes can lower systolic blood pressure by 5-15 mmHg."
          }
        },
        {
          "@type": "Question",
          "name": "When is high blood pressure a medical emergency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A hypertensive crisis occurs when blood pressure exceeds 180/120 mmHg. If you get a reading this high, wait 5 minutes and test again. If it's still above 180/120 and you have symptoms like chest pain, shortness of breath, back pain, numbness, vision changes, or difficulty speaking, call emergency services immediately — this is a hypertensive emergency that can cause organ damage."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Blood Pressure Chart — Check Your BP Category | ijustwantto.live"
  description="Check your blood pressure category instantly. Interactive blood pressure chart with color-coded ranges, age-based reference tables, and history tracking. Normal, Elevated, Stage 1 & 2 Hypertension ranges."
  canonical="https://bodycount.photonbuilder.com/blood-pressure-chart" schema={schema}
>
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --bp-normal: #10b981;
            --bp-elevated: #f59e0b;
            --bp-stage1: #f97316;
            --bp-stage2: #ef4444;
            --bp-crisis: #dc2626;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .form-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .form-col {
            flex: 1;
            min-width: 140px;
        }

        input[type="number"] {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s;
            appearance: none;
        }

        input[type="number"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        button.calculate-btn {
            width: 100%;
            background-color: var(--accent-color);
            color: #000000;
            border: none;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 1rem;
            font-family: var(--font-ui);
        }

        button.calculate-btn:hover {
            background-color: var(--accent-hover);
        }

        .results {
            display: none;
            margin-top: 2rem;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .results.active {
            display: block;
        }

        .category-box {
            text-align: center;
            padding: 1.5rem;
            border-radius: 8px;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            margin-bottom: 1.5rem;
            border-left: 4px solid var(--accent-color);
        }

        .category-label {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        .category-name {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .category-desc {
            margin-top: 0.5rem;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .reading-display {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .reading-value {
            font-family: var(--font-mono);
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--accent-color);
        }

        .reading-unit {
            font-size: 1rem;
            color: var(--text-secondary);
            margin-left: 0.25rem;
        }

        /* Gauge */
        .gauge-container {
            margin: 1.5rem 0;
        }

        .gauge-title {
            font-size: 0.875rem;
            color: var(--text-secondary);
            margin-bottom: 1rem;
            text-align: center;
            font-weight: 500;
        }

        .gauge-bar {
            height: 24px;
            border-radius: 12px;
            display: flex;
            overflow: hidden;
            position: relative;
            margin-bottom: 0.5rem;
        }

        .gauge-segment {
            height: 100%;
        }

        .seg-normal { width: 25%; background-color: var(--bp-normal); }
        .seg-elevated { width: 15%; background-color: var(--bp-elevated); }
        .seg-stage1 { width: 15%; background-color: var(--bp-stage1); }
        .seg-stage2 { width: 25%; background-color: var(--bp-stage2); }
        .seg-crisis { width: 20%; background-color: var(--bp-crisis); }

        .gauge-marker {
            position: absolute;
            top: -6px;
            bottom: -6px;
            width: 4px;
            background-color: #ffffff;
            border-radius: 2px;
            box-shadow: 0 0 4px rgba(0,0,0,0.5);
            transition: left 0.5s ease-out;
            left: 0%;
            z-index: 10;
        }

        .gauge-marker::before {
            content: '';
            position: absolute;
            top: -8px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 6px 6px 0;
            border-style: solid;
            border-color: #ffffff transparent transparent transparent;
        }

        .gauge-labels {
            display: flex;
            justify-content: space-between;
            font-size: 0.7rem;
            color: var(--text-secondary);
            font-family: var(--font-mono);
        }

        .gauge-legend {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 1rem;
            justify-content: center;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.7rem;
            color: var(--text-secondary);
        }

        .legend-color {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* Tables */
        .table-container {
            overflow-x: auto;
            margin-bottom: 1rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        th, td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            font-weight: 600;
            color: var(--text-primary);
            background-color: var(--bg-color);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        td {
            color: var(--text-secondary);
        }

        .bp-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 0.5rem;
        }

        /* History */
        .history-section {
            margin-top: 1rem;
        }

        .history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .history-header h3 {
            font-size: 1rem;
            font-weight: 600;
            color: #ffffff;
        }

        .clear-btn {
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 0.4rem 0.75rem;
            border-radius: 6px;
            font-size: 0.75rem;
            cursor: pointer;
            font-family: var(--font-ui);
            transition: all 0.2s;
        }

        .clear-btn:hover {
            border-color: #ef4444;
            color: #ef4444;
        }

        .save-btn {
            background-color: transparent;
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            padding: 0.75rem;
            border-radius: 6px;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            margin-top: 0.75rem;
            font-family: var(--font-ui);
            transition: all 0.2s;
        }

        .save-btn:hover {
            background-color: rgba(45, 184, 154, 0.1);
        }

        .history-empty {
            text-align: center;
            padding: 2rem;
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        .history-entry {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            margin-bottom: 0.5rem;
        }

        .history-reading {
            font-family: var(--font-mono);
            font-weight: 600;
            color: var(--text-primary);
        }

        .history-cat {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
        }

        .history-date {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .history-del {
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            padding: 0.25rem;
            font-size: 1rem;
            line-height: 1;
            transition: color 0.2s;
        }

        .history-del:hover {
            color: #ef4444;
        }

        .trend-indicator {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            margin-bottom: 1rem;
            font-size: 0.875rem;
        }

        .trend-arrow {
            font-size: 1.25rem;
        }

        /* SEO content */
        .seo-content {
            margin-top: 4rem;
        }

        .seo-content h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .seo-content h3 {
            font-size: 1.125rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
            color: #ffffff;
            margin-top: 2rem;
        }

        .seo-content p {
            margin-bottom: 1.5rem;
            color: var(--text-secondary);
        }

        .seo-content ul, .seo-content ol {
            margin-bottom: 1.5rem;
            padding-left: 1.5rem;
            color: var(--text-secondary);
        }

        .seo-content li {
            margin-bottom: 0.5rem;
        }

        .disclaimer {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-left: 4px solid #f59e0b;
            border-radius: 8px;
            padding: 1.25rem;
            margin: 2rem 0;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .disclaimer strong {
            color: #f59e0b;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1.25rem 0;
        }

        .faq-item:last-child {
            border-bottom: none;
        }

        .faq-q {
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .faq-a {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        footer {
            margin-top: 4rem;
            text-align: center;
            padding: 2rem 0;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        footer a {
            color: var(--accent-color);
            text-decoration: none;
        }

        footer a:hover {
            text-decoration: underline;
        }
  </style>

<div class="container">
    <header>
        <h1>Blood Pressure Chart</h1>
        <p class="subtitle">Enter your systolic and diastolic readings to see your blood pressure category instantly</p>
    </header>

    <main>
        <!-- Calculator -->
        <div class="card">
            <form id="bpForm">
                <div class="form-row">
                    <div class="form-group form-col">
                        <label for="systolic">Systolic (top number) mmHg</label>
                        <input type="number" id="systolic" name="systolic" required min="60" max="250" step="1" placeholder="e.g. 120">
                    </div>
                    <div class="form-group form-col">
                        <label for="diastolic">Diastolic (bottom number) mmHg</label>
                        <input type="number" id="diastolic" name="diastolic" required min="30" max="160" step="1" placeholder="e.g. 80">
                    </div>
                </div>
                <button type="submit" class="calculate-btn">Check Blood Pressure</button>
            </form>

            <div id="results" class="results">
                <div class="reading-display">
                    <span class="reading-value" id="readingValue">120/80</span>
                    <span class="reading-unit">mmHg</span>
                </div>

                <div class="category-box" id="categoryBox">
                    <div class="category-label">Your Blood Pressure Category</div>
                    <div class="category-name" id="categoryText">Normal</div>
                    <div class="category-desc" id="categoryDesc"></div>
                </div>

                <div class="gauge-container">
                    <div class="gauge-title">Where your systolic reading falls</div>
                    <div class="gauge-bar">
                        <div class="gauge-segment seg-normal"></div>
                        <div class="gauge-segment seg-elevated"></div>
                        <div class="gauge-segment seg-stage1"></div>
                        <div class="gauge-segment seg-stage2"></div>
                        <div class="gauge-segment seg-crisis"></div>
                        <div class="gauge-marker" id="gaugeMarker"></div>
                    </div>
                    <div class="gauge-labels">
                        <span>&lt;120</span>
                        <span>120</span>
                        <span>130</span>
                        <span>140</span>
                        <span>180+</span>
                    </div>
                    <div class="gauge-legend">
                        <div class="legend-item"><div class="legend-color" style="background:var(--bp-normal)"></div> Normal</div>
                        <div class="legend-item"><div class="legend-color" style="background:var(--bp-elevated)"></div> Elevated</div>
                        <div class="legend-item"><div class="legend-color" style="background:var(--bp-stage1)"></div> Stage 1</div>
                        <div class="legend-item"><div class="legend-color" style="background:var(--bp-stage2)"></div> Stage 2</div>
                        <div class="legend-item"><div class="legend-color" style="background:var(--bp-crisis)"></div> Crisis</div>
                    </div>
                </div>

                <button type="button" class="save-btn" id="saveBtn" onclick="saveReading()">Save This Reading</button>
            </div>
        </div>

        <!-- BP Categories Table -->
        <div class="card">
            <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:1rem;">Blood Pressure Categories</h2>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Systolic (mmHg)</th>
                            <th></th>
                            <th>Diastolic (mmHg)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="bp-dot" style="background:var(--bp-normal)"></span>Normal</td>
                            <td>Less than 120</td>
                            <td style="color:var(--text-secondary);text-align:center;">and</td>
                            <td>Less than 80</td>
                        </tr>
                        <tr>
                            <td><span class="bp-dot" style="background:var(--bp-elevated)"></span>Elevated</td>
                            <td>120 – 129</td>
                            <td style="color:var(--text-secondary);text-align:center;">and</td>
                            <td>Less than 80</td>
                        </tr>
                        <tr>
                            <td><span class="bp-dot" style="background:var(--bp-stage1)"></span>Stage 1 Hypertension</td>
                            <td>130 – 139</td>
                            <td style="color:var(--text-secondary);text-align:center;">or</td>
                            <td>80 – 89</td>
                        </tr>
                        <tr>
                            <td><span class="bp-dot" style="background:var(--bp-stage2)"></span>Stage 2 Hypertension</td>
                            <td>140 or higher</td>
                            <td style="color:var(--text-secondary);text-align:center;">or</td>
                            <td>90 or higher</td>
                        </tr>
                        <tr>
                            <td><span class="bp-dot" style="background:var(--bp-crisis)"></span>Hypertensive Crisis</td>
                            <td>Higher than 180</td>
                            <td style="color:var(--text-secondary);text-align:center;">and/or</td>
                            <td>Higher than 120</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Age-Based Reference -->
        <div class="card">
            <h2 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:1rem;">Normal Blood Pressure by Age</h2>
            <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:1rem;">Average blood pressure readings (mmHg) by age group and sex. These are typical averages — individual targets may differ.</p>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Age Group</th>
                            <th>Male Average</th>
                            <th>Female Average</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>18 – 29</td><td>119 / 70</td><td>110 / 68</td></tr>
                        <tr><td>30 – 39</td><td>122 / 75</td><td>116 / 72</td></tr>
                        <tr><td>40 – 49</td><td>126 / 78</td><td>122 / 76</td></tr>
                        <tr><td>50 – 59</td><td>131 / 80</td><td>128 / 79</td></tr>
                        <tr><td>60 – 69</td><td>135 / 76</td><td>134 / 74</td></tr>
                        <tr><td>65+</td><td>138 / 73</td><td>137 / 71</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- History Log -->
        <div class="card">
            <div class="history-header">
                <h3>Reading History</h3>
                <button type="button" class="clear-btn" id="clearBtn" onclick="clearHistory()">Clear All</button>
            </div>
            <div id="trendIndicator" class="trend-indicator" style="display:none;">
                <span class="trend-arrow" id="trendArrow"></span>
                <span id="trendText"></span>
            </div>
            <div id="historyList">
                <div class="history-empty">No readings saved yet. Check your blood pressure above and save it to start tracking.</div>
            </div>
        </div>

        <!-- SEO Content -->
        <div class="seo-content">
            <h2>Understanding Your Blood Pressure Numbers</h2>
            <p>Blood pressure is one of the most important indicators of cardiovascular health. It measures the force of blood pushing against the walls of your arteries as your heart pumps. A blood pressure reading consists of two numbers: systolic pressure (the top number) recorded when the heart beats, and diastolic pressure (the bottom number) measured between beats.</p>
            <p>High blood pressure (hypertension) is often called the "silent killer" because it typically has no symptoms but can lead to serious health problems including heart attack, stroke, kidney disease, and vision loss. According to the CDC, nearly half of U.S. adults have hypertension, and many don't know it.</p>

            <h2>Blood Pressure Ranges Explained</h2>
            <p>The American Heart Association (AHA) recognizes five blood pressure categories based on 2017 guidelines:</p>
            <ul>
                <li><strong>Normal (less than 120/80 mmHg):</strong> Your blood pressure is in the healthy range. Maintain a heart-healthy lifestyle to keep it there — regular exercise, balanced diet, and stress management all help.</li>
                <li><strong>Elevated (120-129 / less than 80 mmHg):</strong> Your systolic pressure is creeping up, but diastolic remains healthy. Without lifestyle changes, elevated blood pressure is likely to progress to full hypertension over time.</li>
                <li><strong>Stage 1 Hypertension (130-139 / 80-89 mmHg):</strong> Your doctor will likely recommend lifestyle changes and may consider medication depending on your overall cardiovascular risk, including factors like a history of heart disease or stroke.</li>
                <li><strong>Stage 2 Hypertension (140+ / 90+ mmHg):</strong> At this stage, doctors typically prescribe a combination of blood pressure medications along with lifestyle changes. Consistent Stage 2 readings require medical attention.</li>
                <li><strong>Hypertensive Crisis (higher than 180 / higher than 120 mmHg):</strong> This is a medical emergency. If you get a reading this high, wait 5 minutes and test again. If still elevated, seek immediate medical help — especially if you experience chest pain, shortness of breath, back pain, numbness, weakness, or vision changes.</li>
            </ul>

            <h3>Tips for Lowering Blood Pressure Naturally</h3>
            <p>Research-backed lifestyle changes can meaningfully reduce blood pressure, sometimes by as much as medication:</p>
            <ol>
                <li><strong>Reduce sodium intake:</strong> Aim for less than 2,300 mg per day (ideally 1,500 mg). Read food labels — processed foods are the biggest source of hidden sodium.</li>
                <li><strong>Exercise regularly:</strong> Get at least 150 minutes of moderate aerobic activity per week. Walking, cycling, and swimming are all effective. Consistent exercise can lower systolic BP by 5–8 mmHg.</li>
                <li><strong>Follow the DASH diet:</strong> The Dietary Approaches to Stop Hypertension diet emphasizes fruits, vegetables, whole grains, lean protein, and low-fat dairy while limiting saturated fat and sweets.</li>
                <li><strong>Maintain a healthy weight:</strong> Losing even 5–10 pounds can lower blood pressure. Each kilogram of weight loss reduces systolic BP by about 1 mmHg.</li>
                <li><strong>Limit alcohol:</strong> No more than one drink per day for women, two for men. Excessive alcohol raises blood pressure and reduces the effectiveness of BP medications.</li>
                <li><strong>Manage stress:</strong> Chronic stress contributes to sustained high blood pressure. Techniques like deep breathing, meditation, regular exercise, and adequate sleep all help.</li>
                <li><strong>Quit smoking:</strong> Each cigarette temporarily raises blood pressure. Quitting improves heart health and allows blood pressure medications to work more effectively.</li>
                <li><strong>Increase potassium intake:</strong> Foods rich in potassium (bananas, potatoes, spinach, beans) help balance sodium and relax blood vessel walls.</li>
            </ol>

            <h3>When to See a Doctor</h3>
            <p>Schedule a doctor's appointment if:</p>
            <ul>
                <li>Your readings are consistently above 130/80 mmHg on multiple occasions</li>
                <li>You experience headaches, dizziness, or nosebleeds alongside high readings</li>
                <li>You have a family history of heart disease or stroke</li>
                <li>You're pregnant and notice elevated blood pressure readings</li>
                <li>Your blood pressure doesn't respond to lifestyle changes after 3–6 months</li>
                <li>You experience side effects from current blood pressure medication</li>
            </ul>
            <p><strong>Call emergency services immediately</strong> if your blood pressure exceeds 180/120 mmHg and you have symptoms like chest pain, shortness of breath, back pain, numbness/weakness, vision changes, or difficulty speaking.</p>

            <div class="disclaimer">
                <strong>Medical Disclaimer:</strong> This tool is for informational and educational purposes only. It is not a substitute for professional medical advice, diagnosis, or treatment. Blood pressure readings can vary based on time of day, activity level, stress, caffeine, and measurement technique. Always consult a qualified healthcare provider for medical decisions. If you believe you are experiencing a medical emergency, call your local emergency number immediately.
            </div>

            <h2>Frequently Asked Questions</h2>

            <div class="faq-item">
                <div class="faq-q">What is normal blood pressure?</div>
                <div class="faq-a">Normal blood pressure is defined as a systolic reading below 120 mmHg and a diastolic reading below 80 mmHg (written as less than 120/80 mmHg). This range indicates your heart and blood vessels are working efficiently without placing excess strain on artery walls.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">What do the two blood pressure numbers mean?</div>
                <div class="faq-a">The top number (systolic) measures the pressure in your arteries when your heart beats and pumps blood out. The bottom number (diastolic) measures the pressure in your arteries between heartbeats when the heart is resting and refilling with blood. Both numbers are important for assessing cardiovascular health.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">How often should I check my blood pressure?</div>
                <div class="faq-a">The American Heart Association recommends adults with normal blood pressure get checked at least once a year during regular health visits. If you have elevated blood pressure or hypertension, your doctor may recommend checking it more frequently — daily home monitoring is common for those managing hypertension.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">Does blood pressure change with age?</div>
                <div class="faq-a">Yes, blood pressure generally increases with age due to stiffening of arteries (arteriosclerosis) and plaque buildup. Systolic pressure tends to rise steadily after age 30, while diastolic pressure may plateau or even decrease after age 60. This is why regular monitoring becomes more important as you age.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">What is the difference between Stage 1 and Stage 2 hypertension?</div>
                <div class="faq-a">Stage 1 hypertension is defined as systolic 130–139 mmHg or diastolic 80–89 mmHg. Stage 2 hypertension is systolic 140 mmHg or higher, or diastolic 90 mmHg or higher. Stage 2 is more severe and typically requires medication along with lifestyle changes, while Stage 1 may initially be managed with lifestyle modifications alone.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">Can I lower my blood pressure naturally without medication?</div>
                <div class="faq-a">Yes, many people can lower blood pressure through lifestyle changes including reducing sodium intake (under 2,300 mg/day), exercising regularly (150 minutes per week), maintaining a healthy weight, limiting alcohol, managing stress, eating a DASH diet rich in fruits, vegetables, and whole grains, and quitting smoking. These changes can lower systolic blood pressure by 5–15 mmHg.</div>
            </div>

            <div class="faq-item">
                <div class="faq-q">When is high blood pressure a medical emergency?</div>
                <div class="faq-a">A hypertensive crisis occurs when blood pressure exceeds 180/120 mmHg. If you get a reading this high, wait 5 minutes and test again. If it's still above 180/120 and you have symptoms like chest pain, shortness of breath, back pain, numbness, vision changes, or difficulty speaking, call emergency services immediately — this is a hypertensive emergency that can cause organ damage.</div>
            </div>
        </div>
    </main>
</div>

<script is:inline>
// BP Category logic per AHA 2017 guidelines
function getCategory(sys, dia) {
    if (sys > 180 || dia > 120) return { name: 'Hypertensive Crisis', color: 'var(--bp-crisis)', desc: 'Seek immediate medical attention. Wait 5 minutes and re-test. If still this high, call emergency services.' };
    if (sys >= 140 || dia >= 90) return { name: 'Stage 2 Hypertension', color: 'var(--bp-stage2)', desc: 'Likely requires medication plus lifestyle changes. See your doctor.' };
    if (sys >= 130 || dia >= 80) return { name: 'Stage 1 Hypertension', color: 'var(--bp-stage1)', desc: 'Lifestyle changes recommended. Medication may be considered based on cardiovascular risk.' };
    if (sys >= 120 && dia < 80) return { name: 'Elevated', color: 'var(--bp-elevated)', desc: 'At risk of developing hypertension without lifestyle changes.' };
    return { name: 'Normal', color: 'var(--bp-normal)', desc: 'Your blood pressure is in the healthy range. Keep it up!' };
}

// Gauge position based on systolic value
function getGaugePos(sys) {
    // Segments: Normal(<120)=25%, Elevated(120-129)=15%, Stage1(130-139)=15%, Stage2(140-180)=25%, Crisis(180+)=20%
    if (sys < 120) {
        // Map 60-120 to 0-25%
        const clamped = Math.max(60, sys);
        return ((clamped - 60) / 60) * 25;
    } else if (sys < 130) {
        // Map 120-130 to 25-40%
        return 25 + ((sys - 120) / 10) * 15;
    } else if (sys < 140) {
        // Map 130-140 to 40-55%
        return 40 + ((sys - 130) / 10) * 15;
    } else if (sys <= 180) {
        // Map 140-180 to 55-80%
        return 55 + ((sys - 140) / 40) * 25;
    } else {
        // Map 180-220 to 80-100%
        const clamped = Math.min(220, sys);
        return 80 + ((clamped - 180) / 40) * 20;
    }
}

let lastSys = 0, lastDia = 0;

document.getElementById('bpForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const sys = parseInt(document.getElementById('systolic').value);
    const dia = parseInt(document.getElementById('diastolic').value);
    if (isNaN(sys) || isNaN(dia)) return;

    lastSys = sys;
    lastDia = dia;

    const cat = getCategory(sys, dia);

    document.getElementById('readingValue').textContent = sys + '/' + dia;
    document.getElementById('categoryText').textContent = cat.name;
    document.getElementById('categoryText').style.color = cat.color;
    document.getElementById('categoryBox').style.borderLeftColor = cat.color;
    document.getElementById('categoryDesc').textContent = cat.desc;
    document.getElementById('readingValue').style.color = cat.color;

    const pos = Math.max(0, Math.min(100, getGaugePos(sys)));
    document.getElementById('gaugeMarker').style.left = pos + '%';

    document.getElementById('results').classList.add('active');
});

// History management using localStorage
const STORAGE_KEY = 'bp_history';

function getHistory() {
    try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
    } catch { return []; }
}

function saveHistory(data) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
}

function saveReading() {
    if (!lastSys || !lastDia) return;
    const history = getHistory();
    history.unshift({
        sys: lastSys,
        dia: lastDia,
        cat: getCategory(lastSys, lastDia).name,
        date: new Date().toISOString()
    });
    // Keep max 50 readings
    if (history.length > 50) history.length = 50;
    saveHistory(history);
    renderHistory();

    const btn = document.getElementById('saveBtn');
    btn.textContent = 'Saved!';
    btn.style.borderColor = 'var(--bp-normal)';
    btn.style.color = 'var(--bp-normal)';
    setTimeout(() => {
        btn.textContent = 'Save This Reading';
        btn.style.borderColor = 'var(--accent-color)';
        btn.style.color = 'var(--accent-color)';
    }, 1500);
}

function deleteReading(index) {
    const history = getHistory();
    history.splice(index, 1);
    saveHistory(history);
    renderHistory();
}

function clearHistory() {
    if (!confirm('Clear all saved readings?')) return;
    localStorage.removeItem(STORAGE_KEY);
    renderHistory();
}

function getCatColor(catName) {
    const map = { 'Normal': 'var(--bp-normal)', 'Elevated': 'var(--bp-elevated)', 'Stage 1 Hypertension': 'var(--bp-stage1)', 'Stage 2 Hypertension': 'var(--bp-stage2)', 'Hypertensive Crisis': 'var(--bp-crisis)' };
    return map[catName] || 'var(--text-secondary)';
}

function renderHistory() {
    const history = getHistory();
    const container = document.getElementById('historyList');
    const trendEl = document.getElementById('trendIndicator');

    if (history.length === 0) {
        container.innerHTML = '<div class="history-empty">No readings saved yet. Check your blood pressure above and save it to start tracking.</div>';
        trendEl.style.display = 'none';
        return;
    }

    // Trend calculation (compare last 3 vs previous 3)
    if (history.length >= 4) {
        const recent = history.slice(0, Math.min(3, history.length));
        const older = history.slice(Math.min(3, history.length), Math.min(6, history.length));
        if (older.length > 0) {
            const avgRecent = recent.reduce((s, r) => s + r.sys, 0) / recent.length;
            const avgOlder = older.reduce((s, r) => s + r.sys, 0) / older.length;
            const diff = avgRecent - avgOlder;
            trendEl.style.display = 'flex';
            if (Math.abs(diff) < 3) {
                document.getElementById('trendArrow').textContent = '→';
                document.getElementById('trendText').textContent = 'Systolic trend: stable';
                document.getElementById('trendText').style.color = 'var(--bp-normal)';
            } else if (diff > 0) {
                document.getElementById('trendArrow').textContent = '↑';
                document.getElementById('trendText').textContent = 'Systolic trend: increasing (+' + Math.round(diff) + ' mmHg avg)';
                document.getElementById('trendText').style.color = 'var(--bp-stage1)';
            } else {
                document.getElementById('trendArrow').textContent = '↓';
                document.getElementById('trendText').textContent = 'Systolic trend: decreasing (' + Math.round(diff) + ' mmHg avg)';
                document.getElementById('trendText').style.color = 'var(--bp-normal)';
            }
        }
    } else {
        trendEl.style.display = 'none';
    }

    let html = '';
    history.forEach((r, i) => {
        const d = new Date(r.date);
        const dateStr = d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) + ' ' + d.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
        const color = getCatColor(r.cat);
        const shortCat = r.cat.replace('Hypertension', 'HTN').replace('Hypertensive ', '');
        html += '<div class="history-entry">' +
            '<div><div class="history-reading" style="color:' + color + '">' + r.sys + '/' + r.dia + '</div>' +
            '<div class="history-date">' + dateStr + '</div></div>' +
            '<div style="display:flex;align-items:center;gap:0.75rem;">' +
            '<span class="history-cat" style="color:' + color + ';background:' + color + '15;border:1px solid ' + color + '30">' + shortCat + '</span>' +
            '<button class="history-del" onclick="deleteReading(' + i + ')" title="Delete">&times;</button>' +
            '</div></div>';
    });
    container.innerHTML = html;
}

// Initialize history on load
renderHistory();
</script>

