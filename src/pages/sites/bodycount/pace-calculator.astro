<script is:inline>
// ========== STATE ==========
var currentMode = 'calcPace';
var calcData = { distanceM: 0, timeS: 0 };

var events = {
    '1500m': 1500,
    '1mi': 1609.344,
    '3k': 3000,
    '5k': 5000,
    '10k': 10000,
    '15k': 15000,
    '10mi': 16093.44,
    'half': 21097.5,
    'marathon': 42195,
    '50k': 50000
};

// ========== DOM ==========
var form = document.getElementById('paceForm');
var tabs = document.querySelectorAll('.tab-btn');
var sectionDistance = document.getElementById('sectionDistance');
var sectionTime = document.getElementById('sectionTime');
var sectionPace = document.getElementById('sectionPace');
var submitBtn = document.getElementById('submitBtn');
var eventSelect = document.getElementById('eventSelect');
var distanceValEl = document.getElementById('distanceVal');
var distanceUnitEl = document.getElementById('distanceUnit');

// ========== TAB SWITCHING ==========
tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        currentMode = tab.dataset.target;

        sectionDistance.classList.remove('active');
        sectionTime.classList.remove('active');
        sectionPace.classList.remove('active');

        if (currentMode === 'calcPace') {
            sectionDistance.classList.add('active');
            sectionTime.classList.add('active');
            submitBtn.textContent = 'Calculate Pace';
        } else if (currentMode === 'calcTime') {
            sectionDistance.classList.add('active');
            sectionPace.classList.add('active');
            submitBtn.textContent = 'Calculate Time';
        } else if (currentMode === 'calcDistance') {
            sectionTime.classList.add('active');
            sectionPace.classList.add('active');
            submitBtn.textContent = 'Calculate Distance';
        }
    });
});

// ========== EVENT DROPDOWN ==========
eventSelect.addEventListener('change', function(e) {
    var val = e.target.value;
    if (val && events[val]) {
        var meters = events[val];
        if (distanceUnitEl.value === 'km') {
            distanceValEl.value = (meters / 1000).toFixed(3);
        } else if (distanceUnitEl.value === 'mi') {
            distanceValEl.value = (meters / 1609.344).toFixed(3);
        } else {
            distanceValEl.value = meters.toFixed(0);
        }
    } else {
        distanceValEl.value = '';
    }
});

distanceValEl.addEventListener('input', function() { eventSelect.value = ''; });
distanceUnitEl.addEventListener('change', function() { eventSelect.value = ''; });

// ========== HELPERS ==========
function getSeconds(h, m, s) {
    return (parseInt(h) || 0) * 3600 + (parseInt(m) || 0) * 60 + (parseInt(s) || 0);
}

function fmtTime(totalSeconds) {
    if (!isFinite(totalSeconds) || totalSeconds < 0) return "00:00:00";
    var h = Math.floor(totalSeconds / 3600);
    var m = Math.floor((totalSeconds % 3600) / 60);
    var s = Math.round(totalSeconds % 60);
    if (s === 60) { m++; s = 0; }
    if (m === 60) { h++; m = 0; }
    if (h > 0) {
        return h.toString().padStart(2, '0') + ':' + m.toString().padStart(2, '0') + ':' + s.toString().padStart(2, '0');
    }
    return m.toString().padStart(2, '0') + ':' + s.toString().padStart(2, '0');
}

function fmtPace(secPerUnit) {
    if (!isFinite(secPerUnit) || secPerUnit <= 0) return "00:00";
    var m = Math.floor(secPerUnit / 60);
    var s = Math.round(secPerUnit % 60);
    if (s === 60) { m++; s = 0; }
    return m.toString().padStart(2, '0') + ':' + s.toString().padStart(2, '0');
}

// ========== MAIN FORM ==========
form.addEventListener('submit', function(e) {
    e.preventDefault();

    var distanceM = 0;
    var timeS = 0;
    var paceSecPerKm = 0;

    if (currentMode === 'calcPace' || currentMode === 'calcTime') {
        var dVal = parseFloat(distanceValEl.value) || 0;
        var dUnit = distanceUnitEl.value;
        if (dUnit === 'km') distanceM = dVal * 1000;
        else if (dUnit === 'mi') distanceM = dVal * 1609.344;
        else distanceM = dVal;
        if (distanceM <= 0) return alert('Please enter a valid distance.');
    }

    if (currentMode === 'calcPace' || currentMode === 'calcDistance') {
        timeS = getSeconds(
            document.getElementById('timeH').value,
            document.getElementById('timeM').value,
            document.getElementById('timeS').value
        );
        if (timeS <= 0) return alert('Please enter a valid time.');
    }

    if (currentMode === 'calcTime' || currentMode === 'calcDistance') {
        var pM = parseInt(document.getElementById('paceM').value) || 0;
        var pS = parseInt(document.getElementById('paceS').value) || 0;
        var pUnit = document.getElementById('paceUnit').value;
        var paceSec = pM * 60 + pS;
        if (paceSec <= 0) return alert('Please enter a valid pace.');
        if (pUnit === 'km') paceSecPerKm = paceSec;
        else paceSecPerKm = paceSec / 1.609344;
    }

    if (currentMode === 'calcPace') {
        paceSecPerKm = timeS / (distanceM / 1000);
    } else if (currentMode === 'calcTime') {
        timeS = paceSecPerKm * (distanceM / 1000);
    } else if (currentMode === 'calcDistance') {
        distanceM = (timeS / paceSecPerKm) * 1000;
    }

    calcData.distanceM = distanceM;
    calcData.timeS = timeS;

    updateResultsUI(distanceM, timeS, paceSecPerKm);
    renderSplits('km');
    renderPredictions(timeS, distanceM);

    document.getElementById('results').classList.add('active');
});

function updateResultsUI(distanceM, timeS, paceSecPerKm) {
    var distanceKm = distanceM / 1000;
    var distanceMi = distanceM / 1609.344;
    var paceSecPerMi = paceSecPerKm * 1.609344;
    var speedKmH = distanceKm / (timeS / 3600);
    var speedMph = distanceMi / (timeS / 3600);

    var mainTitle = document.getElementById('mainResultTitle');
    var mainValue = document.getElementById('mainResultValue');
    var mainSub = document.getElementById('mainResultSub');

    if (currentMode === 'calcPace') {
        mainTitle.textContent = 'Your Pace';
        mainValue.textContent = fmtPace(paceSecPerKm);
        mainSub.textContent = '/km';
    } else if (currentMode === 'calcTime') {
        mainTitle.textContent = 'Your Finish Time';
        mainValue.textContent = fmtTime(timeS);
        mainSub.textContent = '';
    } else if (currentMode === 'calcDistance') {
        mainTitle.textContent = 'Your Distance';
        mainValue.textContent = distanceKm.toFixed(2);
        mainSub.textContent = 'km';
    }

    document.getElementById('resDistance').textContent = distanceKm.toFixed(2) + ' km';
    document.getElementById('resDistanceSub').textContent = distanceMi.toFixed(2) + ' mi';
    document.getElementById('resTime').textContent = fmtTime(timeS);
    document.getElementById('resPace').textContent = fmtPace(paceSecPerKm) + ' /km';
    document.getElementById('resPaceSub').textContent = fmtPace(paceSecPerMi) + ' /mi';
    document.getElementById('resSpeed').textContent = speedKmH.toFixed(2) + ' km/h';
    document.getElementById('resSpeedSub').textContent = speedMph.toFixed(2) + ' mph';
}

// ========== SPLITS ==========
function renderSplits(unit) {
    document.getElementById('splitKmBtn').classList.toggle('active', unit === 'km');
    document.getElementById('splitMiBtn').classList.toggle('active', unit === 'mi');

    var tbody = document.getElementById('splitsBody');
    tbody.innerHTML = '';

    var distanceTotal = calcData.distanceM;
    var timeTotal = calcData.timeS;
    if (distanceTotal <= 0) return;

    var splitDistanceM = unit === 'km' ? 1000 : 1609.344;
    var numFullSplits = Math.floor(distanceTotal / splitDistanceM);
    var remainderM = distanceTotal % splitDistanceM;
    var secPerSplit = (timeTotal / distanceTotal) * splitDistanceM;
    var cumulativeTime = 0;

    for (var i = 1; i <= numFullSplits; i++) {
        cumulativeTime += secPerSplit;
        var tr = document.createElement('tr');
        tr.innerHTML = '<td>' + i + ' ' + unit + '</td><td>' + fmtTime(secPerSplit) + '</td><td>' + fmtTime(cumulativeTime) + '</td>';
        tbody.appendChild(tr);
    }

    if (remainderM > 1) {
        var remainderSec = (timeTotal / distanceTotal) * remainderM;
        cumulativeTime += remainderSec;
        var tr2 = document.createElement('tr');
        var label = unit === 'km' ? (remainderM / 1000).toFixed(2) : (remainderM / 1609.344).toFixed(2);
        tr2.classList.add('split-highlight');
        tr2.innerHTML = '<td>+ ' + label + ' ' + unit + '</td><td>' + fmtTime(remainderSec) + '</td><td>' + fmtTime(cumulativeTime) + '</td>';
        tbody.appendChild(tr2);
    }
}

// ========== RACE PREDICTIONS ==========
function renderPredictions(timeS, distanceM) {
    var tbody = document.getElementById('predictionsBody');
    tbody.innerHTML = '';
    if (distanceM <= 0) return;

    var predEvents = [
        { name: '5K', dist: 5000 },
        { name: '10K', dist: 10000 },
        { name: 'Half Marathon', dist: 21097.5 },
        { name: 'Marathon', dist: 42195 }
    ];

    predEvents.forEach(function(ev) {
        var predTimeS = timeS * Math.pow((ev.dist / distanceM), 1.06);
        var predPaceKm = predTimeS / (ev.dist / 1000);
        var predPaceMi = predPaceKm * 1.609344;
        var isSame = Math.abs(ev.dist - distanceM) < 50;

        var tr = document.createElement('tr');
        if (isSame) tr.classList.add('split-highlight');
        tr.innerHTML = '<td>' + ev.name + '</td><td>' + fmtTime(predTimeS) + '</td><td>' + fmtPace(predPaceKm) + '</td><td>' + fmtPace(predPaceMi) + '</td>';
        tbody.appendChild(tr);
    });
}

// ========== NEGATIVE SPLIT CALCULATOR ==========
document.getElementById('negSplitForm').addEventListener('submit', function(e) {
    e.preventDefault();

    var evKey = document.getElementById('nsEvent').value;
    var totalDistM = events[evKey] || 21097.5;
    var totalDistKm = totalDistM / 1000;
    var halfDistKm = totalDistKm / 2;

    var targetTimeS = getSeconds(
        document.getElementById('nsTargetH').value,
        document.getElementById('nsTargetM').value,
        document.getElementById('nsTargetS').value
    );
    if (targetTimeS <= 0) return alert('Please enter a valid target time.');

    var splitPct = parseFloat(document.getElementById('nsSplitPct').value) / 100;

    // first_half_time + second_half_time = total
    // second_half_time = first_half_time * (1 - splitPct)
    // first_half_time * (2 - splitPct) = total
    var firstHalfTime = targetTimeS / (2 - splitPct);
    var secondHalfTime = targetTimeS - firstHalfTime;

    var firstHalfPace = firstHalfTime / halfDistKm;
    var secondHalfPace = secondHalfTime / halfDistKm;

    document.getElementById('nsFirstHalfTime').textContent = fmtTime(firstHalfTime);
    document.getElementById('nsFirstHalfPace').textContent = fmtPace(firstHalfPace) + ' /km';
    document.getElementById('nsSecondHalfTime').textContent = fmtTime(secondHalfTime);
    document.getElementById('nsSecondHalfPace').textContent = fmtPace(secondHalfPace) + ' /km';

    // Build per-km split table
    var tbody = document.getElementById('negSplitBody');
    tbody.innerHTML = '';
    var numFullKm = Math.floor(totalDistKm);
    var remainderKm = totalDistKm - numFullKm;
    var cumulative = 0;

    for (var i = 1; i <= numFullKm; i++) {
        var inFirstHalf = i <= Math.ceil(halfDistKm);
        var pace = inFirstHalf ? firstHalfPace : secondHalfPace;
        cumulative += pace;
        var tr = document.createElement('tr');
        if (!inFirstHalf) tr.style.color = 'var(--accent-color)';
        tr.innerHTML = '<td>' + i + '</td><td>' + fmtPace(pace) + '</td><td>' + fmtTime(pace) + '</td><td>' + fmtTime(cumulative) + '</td>';
        tbody.appendChild(tr);
    }

    if (remainderKm > 0.01) {
        var inFirst = false;
        var pace2 = secondHalfPace;
        var lapTime = pace2 * remainderKm;
        cumulative += lapTime;
        var tr2 = document.createElement('tr');
        tr2.classList.add('split-highlight');
        tr2.innerHTML = '<td>+ ' + remainderKm.toFixed(2) + '</td><td>' + fmtPace(pace2) + '</td><td>' + fmtTime(lapTime) + '</td><td>' + fmtTime(cumulative) + '</td>';
        tbody.appendChild(tr2);
    }

    document.getElementById('negSplitResults').classList.add('active');
});

// ========== COPY ==========
function copyText(elementId) {
    var text = document.getElementById(elementId).textContent;
    if (elementId === 'mainResultValue') {
        var sub = document.getElementById('mainResultSub').textContent;
        text = text + ' ' + sub;
    }
    navigator.clipboard.writeText(text.trim()).then(function() {
        // brief visual feedback could go here
    }).catch(function(err) {
        console.error('Copy failed:', err);
    });
}
