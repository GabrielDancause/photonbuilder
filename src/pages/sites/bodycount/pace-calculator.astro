        <!-- Common Pace Reference -->
        <div class="card">
            <h2 class="card-title">Common Race Pace Reference</h2>
            <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:1rem;">Target paces for popular finish times. Find the min per km pace you need.</p>
            <div class="table-container" style="margin-top:0;">
                <table>
                    <thead>
                        <tr>
                            <th>Goal</th>
                            <th>Pace /km</th>
                            <th>Pace /mi</th>
                            <th>Speed</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Sub-20 5K</td><td>3:59</td><td>6:26</td><td>15.0 km/h</td></tr>
                        <tr><td>Sub-25 5K</td><td>4:59</td><td>8:02</td><td>12.0 km/h</td></tr>
                        <tr><td>Sub-30 5K</td><td>5:59</td><td>9:38</td><td>10.0 km/h</td></tr>
                        <tr><td>Sub-50 10K</td><td>4:59</td><td>8:02</td><td>12.0 km/h</td></tr>
                        <tr><td>Sub-60 10K</td><td>5:59</td><td>9:38</td><td>10.0 km/h</td></tr>
                        <tr><td>Sub-1:45 Half</td><td>4:58</td><td>8:00</td><td>12.1 km/h</td></tr>
