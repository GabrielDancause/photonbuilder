---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Protein-Rich Meal Planner",
  "url": "https://bodycount.photonbuilder.com/protein-meal-planner",
  "description": "Plan high-protein meals to hit your daily protein goals. Generate meal plans for breakfast, lunch, dinner, and snacks with 80+ protein-rich foods across omnivore, vegetarian, vegan, and pescatarian diets.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much protein do I need per day for muscle building?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For muscle building, research recommends 1.6–2.2 grams of protein per kilogram of body weight per day. For a 80 kg (176 lb) person, that's 128–176g of protein daily. Spreading this across 3–5 meals with 25–40g per meal optimizes muscle protein synthesis. This planner helps you distribute protein evenly across your meals."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get enough protein on a vegan diet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, you can meet high protein targets on a vegan diet by combining foods like tofu, tempeh, seitan, lentils, chickpeas, edamame, hemp seeds, and pea protein. The key is variety — combining different plant proteins throughout the day ensures you get all essential amino acids. This planner includes 20+ vegan protein sources to help you plan balanced meals."
      }
    },
    {
      "@type": "Question",
      "name": "What are the best high-protein foods per calorie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most protein-dense foods per calorie include chicken breast (31g protein per 165 cal), egg whites (11g per 52 cal), shrimp (24g per 99 cal), turkey breast (29g per 135 cal), and cottage cheese (14g per 98 cal). The reference table in this planner ranks the top 20 protein sources by their protein-to-calorie ratio."
      }
    },
    {
      "@type": "Question",
      "name": "How should I distribute protein across meals?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Research shows that distributing protein evenly across meals (20–40g per meal) maximizes muscle protein synthesis better than eating most protein in one meal. Aim for at least 20g of protein at breakfast, which most people under-eat. This planner automatically distributes your target protein across your chosen number of meals."
      }
    },
    {
      "@type": "Question",
      "name": "Is it better to eat 3 or 5 meals for protein intake?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For protein intake above 120g per day, eating 4–5 meals makes it easier to hit your target without feeling overly full at each meal. Each meal can deliver 25–35g of protein, which is the optimal range for muscle protein synthesis per sitting. However, 3 meals can work fine if you're comfortable with 40g+ protein portions."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Protein-Rich Meal Planner — High-Protein Meal Plans | bodycount"
  description="Plan high-protein meals to hit your daily protein goals. Generate meal plans with 80+ protein-rich foods for omnivore, vegetarian, vegan, and pescatarian diets."
  canonical="https://bodycount.photonbuilder.com/protein-meal-planner" schema={schema}
