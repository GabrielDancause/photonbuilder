        }
  </style>

<div class="container">
    <main>
        <div class="card">
            <form id="plannerForm">
                <div class="form-row" style="margin-bottom: 1rem;">
                    <div class="form-group form-col">
                        <label for="proteinTarget">Daily Protein Target (g)</label>
                        <input type="number" id="proteinTarget" name="proteinTarget" required min="30" max="400" step="1" placeholder="e.g. 150">
                    </div>
                    <div class="form-group form-col">
                        <label for="mealCount">Number of Meals</label>
                        <select id="mealCount" name="mealCount" required>
                            <option value="3">3 meals</option>
                            <option value="4" selected>4 meals (3 + snack)</option>
                            <option value="5">5 meals (3 + 2 snacks)</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="diet">Dietary Preference</label>
                    <select id="diet" name="diet" required>
                        <option value="omnivore" selected>Omnivore</option>
                        <option value="pescatarian">Pescatarian</option>
                        <option value="vegetarian">Vegetarian</option>
                        <option value="vegan">Vegan</option>
                    </select>
                </div>

                <button type="submit" class="calculate-btn">Generate Meal Plan</button>
            </form>

            <div id="results" class="results">
                <div class="progress-bar-container">
                    <div class="progress-info">
