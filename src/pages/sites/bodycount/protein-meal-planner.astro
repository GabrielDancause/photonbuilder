var currentPlan = [];
var currentDiet = 'omnivore';
var currentTarget = 0;
var currentMealCount = 4;

function shuffle(arr) {
    for (var i = arr.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;
    }
    return arr;
}

function getMealLabels(count) {
    if (count === 3) return ['breakfast', 'lunch', 'dinner'];
    if (count === 4) return ['breakfast', 'lunch', 'snack', 'dinner'];
    return ['breakfast', 'lunch', 'snack', 'dinner', 'snack'];
}

function getMealDisplayNames(count) {
    if (count === 3) return ['Breakfast', 'Lunch', 'Dinner'];
    if (count === 4) return ['Breakfast', 'Lunch', 'Snack', 'Dinner'];
    return ['Breakfast', 'Lunch', 'Snack 1', 'Dinner', 'Snack 2'];
}

function getMealRatios(count) {
    if (count === 3) return [0.30, 0.35, 0.35];
    if (count === 4) return [0.25, 0.30, 0.15, 0.30];
    return [0.25, 0.28, 0.12, 0.25, 0.10];
}

function generateMealPlan(target, mealCount, diet) {
    var foods = foodDatabase[diet] || foodDatabase.omnivore;
    var labels = getMealLabels(mealCount);
    var ratios = getMealRatios(mealCount);
    var plan = [];

    for (var m = 0; m < mealCount; m++) {
        var mealType = labels[m];
        var mealTarget = Math.round(target * ratios[m]);
        var mealFoods = [];
        var mealProtein = 0;

        var available = foods.filter(function(f) { return f.meal.indexOf(mealType) !== -1; });
        available = shuffle(available.slice());

        for (var i = 0; i < available.length && mealProtein < mealTarget; i++) {
            var food = available[i];
            var isDuplicate = false;
            for (var d = 0; d < mealFoods.length; d++) {
                if (mealFoods[d].name === food.name) { isDuplicate = true; break; }
            }
            if (isDuplicate) continue;

            mealFoods.push({ name: food.name, serving: food.serving, protein: food.protein, calories: food.calories });
            mealProtein += food.protein;

            if (mealFoods.length >= 3 && mealProtein >= mealTarget * 0.7) break;
        }

        if (mealFoods.length === 0 && available.length > 0) {
            var fallback = available[0];
            mealFoods.push({ name: fallback.name, serving: fallback.serving, protein: fallback.protein, calories: fallback.calories });
        }

        plan.push({
            label: mealType,
            displayName: getMealDisplayNames(mealCount)[m],
            targetProtein: mealTarget,
            foods: mealFoods
        });
    }

    return plan;
}

function getTotalProtein(plan) {
    var total = 0;
    for (var m = 0; m < plan.length; m++) {
        for (var f = 0; f < plan[m].foods.length; f++) {
            total += plan[m].foods[f].protein;
        }
    }
    return total;
}

function getMealProtein(meal) {
    var total = 0;
    for (var f = 0; f < meal.foods.length; f++) {
        total += meal.foods[f].protein;
    }
    return total;
}

function renderPlan() {
    var container = document.getElementById('mealPlanContainer');
    var html = '';

    for (var m = 0; m < currentPlan.length; m++) {
        var meal = currentPlan[m];
        var mealP = getMealProtein(meal);
        html += '<div class="meal-block">';
        html += '<div class="meal-header"><span class="meal-name">' + meal.displayName + '</span><span class="meal-protein-total">' + mealP + 'g protein</span></div>';

        for (var f = 0; f < meal.foods.length; f++) {
            var food = meal.foods[f];
            html += '<div class="meal-food-item">';
            html += '<div class="food-info"><span class="food-name">' + food.name + '</span><span class="food-serving">' + food.serving + '</span></div>';
            html += '<div class="food-actions"><span class="food-protein">' + food.protein + 'g &middot; ' + food.calories + ' cal</span>';
            html += '<button type="button" class="swap-btn" onclick="swapFood(' + m + ',' + f + ')">Swap</button></div>';
            html += '</div>';
        }

        html += '</div>';
    }

    container.innerHTML = html;
    updateSummary();
    updateBreakdown();
}

function updateSummary() {
    var totalP = getTotalProtein(currentPlan);
    var pct = Math.min(Math.round((totalP / currentTarget) * 100), 100);

    document.getElementById('progressText').textContent = totalP + 'g / ' + currentTarget + 'g';
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('summaryTarget').textContent = currentTarget + 'g';
    document.getElementById('summaryPlanned').textContent = totalP + 'g';
    document.getElementById('summaryPerMeal').textContent = Math.round(totalP / currentPlan.length) + 'g';
}

function updateBreakdown() {
    var counts = {};
    for (var m = 0; m < currentPlan.length; m++) {
        for (var f = 0; f < currentPlan[m].foods.length; f++) {
            var food = currentPlan[m].foods[f];
            if (!counts[food.name]) {
                counts[food.name] = { servings: 0, protein: 0 };
            }
            counts[food.name].servings++;
            counts[food.name].protein += food.protein;
        }
    }

    var sorted = Object.keys(counts).sort(function(a, b) { return counts[b].protein - counts[a].protein; });
    var tbody = document.getElementById('breakdownBody');
    var html = '';

    for (var i = 0; i < sorted.length; i++) {
        var name = sorted[i];
        html += '<tr><td>' + name + '</td><td>' + counts[name].servings + '</td><td>' + counts[name].protein + 'g</td></tr>';
    }

    tbody.innerHTML = html;
}

function swapFood(mealIndex, foodIndex) {
    var meal = currentPlan[mealIndex];
    var oldFood = meal.foods[foodIndex];
    var foods = foodDatabase[currentDiet] || foodDatabase.omnivore;

    var available = foods.filter(function(f) {
        if (f.name === oldFood.name) return false;
        if (f.meal.indexOf(meal.label) === -1) return false;
        for (var e = 0; e < meal.foods.length; e++) {
            if (meal.foods[e].name === f.name) return false;
        }
        return true;
    });

    available.sort(function(a, b) {
        return Math.abs(a.protein - oldFood.protein) - Math.abs(b.protein - oldFood.protein);
    });

    if (available.length === 0) return;

    var topCandidates = available.slice(0, Math.min(5, available.length));
    var pick = topCandidates[Math.floor(Math.random() * topCandidates.length)];

    meal.foods[foodIndex] = { name: pick.name, serving: pick.serving, protein: pick.protein, calories: pick.calories };
    renderPlan();
}

function regeneratePlan() {
    currentPlan = generateMealPlan(currentTarget, currentMealCount, currentDiet);
    renderPlan();
}

function renderRefTable(diet) {
    var foods = foodDatabase[diet] || foodDatabase.omnivore;
    var unique = {};
    for (var i = 0; i < foods.length; i++) {
        var f = foods[i];
        if (!unique[f.name] || (f.protein / f.calories) > (unique[f.name].protein / unique[f.name].calories)) {
            unique[f.name] = f;
        }
    }

    var arr = Object.keys(unique).map(function(k) { return unique[k]; });
    arr.sort(function(a, b) { return (b.protein / b.calories) - (a.protein / a.calories); });

    var top20 = arr.slice(0, 20);
    var tbody = document.getElementById('refBody');
    var html = '';

    for (var j = 0; j < top20.length; j++) {
        var food = top20[j];
        var ratio = ((food.protein / food.calories) * 100).toFixed(1);
        html += '<tr><td class="ref-rank">' + (j + 1) + '</td><td>' + food.name + '</td><td>' + food.protein + 'g</td><td>' + food.calories + '</td><td class="ref-ratio">' + ratio + 'g</td></tr>';
    }

    tbody.innerHTML = html;
}

function toggleFaq(btn) {
    var item = btn.parentElement;
    item.classList.toggle('open');
}

document.getElementById('plannerForm').addEventListener('submit', function(e) {
    e.preventDefault();

    currentTarget = parseInt(document.getElementById('proteinTarget').value);
    currentMealCount = parseInt(document.getElementById('mealCount').value);
    currentDiet = document.getElementById('diet').value;

    if (isNaN(currentTarget) || currentTarget < 30) return;

    currentPlan = generateMealPlan(currentTarget, currentMealCount, currentDiet);
    renderPlan();
    renderRefTable(currentDiet);
    document.getElementById('results').classList.add('active');
});
</script>

