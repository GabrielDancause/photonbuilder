---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Due Date Calculator | Bodycount',
  description: 'Calculate your exact pregnancy due date with our advanced due date calculator. Track weekly milestones, trimesters, and your baby\'s development journey.',
  category: 'tool',
  keywords: ['due date calculator', 'pregnancy calculator', 'edd calculator', 'ivf due date calculator', 'conception date calculator']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "bodycount.photonbuilder.com" },
    "publisher": { "@type": "Organization", "name": "bodycount.photonbuilder.com" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How accurate is a due date calculator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A due date calculator provides an estimate based on your last menstrual period (LMP), conception date, or IVF transfer. While highly accurate for estimation, only about 4-5% of babies are born exactly on their calculated due date. Most babies arrive between 37 and 42 weeks."
        }
      },
      {
        "@type": "Question",
        "name": "Can my due date change?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, your due date can change. Ultrasound measurements taken during the first trimester (usually between 8 and 13 weeks) provide the most accurate estimation of fetal age. If the ultrasound date differs significantly from the LMP date, your healthcare provider may adjust your official due date."
        }
      },
      {
        "@type": "Question",
        "name": "How do you calculate due date for IVF?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For IVF, the due date is calculated based on the embryo transfer date and the age of the embryo (typically 3-day or 5-day transfer). This method is often more accurate than LMP since the exact date of conception is known."
        }
      },
      {
        "@type": "Question",
        "name": "What is Naegele's rule?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Naegele's rule is a standard way of calculating the due date for a pregnancy. The rule estimates the expected date of delivery (EDD) by adding one year, subtracting three months, and adding seven days to the first day of a woman's last menstrual period (LMP)."
        }
      },
      {
        "@type": "Question",
        "name": "How is the pregnancy timeline divided?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pregnancy is divided into three trimesters. The first trimester lasts from week 1 through the end of week 13. The second trimester spans weeks 14 through 27. The third trimester starts at week 28 and continues until delivery, which is typically around week 40."
        }
      }
    ]
  }
]);
---

<SiteLayout site="bodycount" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <style is:inline>
    .calculator-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1rem;
      font-family: system-ui, -apple-system, sans-serif;
    }

    .hero-section {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero-title {
      font-size: 2.5rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }

    .hero-subtitle {
      font-size: 1.2rem;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
    }

    .calc-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
      margin-bottom: 2rem;
    }

    .input-group {
      margin-bottom: 1.5rem;
    }

    .input-label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .input-select, .input-date {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      font-size: 1rem;
      background: var(--bg-primary);
      color: var(--text-primary);
    }

    .calc-btn {
      width: 100%;
      padding: 1rem;
      background: var(--accent-color);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .calc-btn:hover {
      opacity: 0.9;
    }

    .results-section {
      display: none;
      animation: fadeIn 0.5s ease-in;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .results-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .result-box {
      background: var(--bg-primary);
      padding: 1.5rem;
      border-radius: 8px;
      text-align: center;
      border: 1px solid var(--border-color);
    }

    .result-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 0.5rem;
    }

    .result-label {
      color: var(--text-secondary);
      font-size: 0.9rem;
    }

    .timeline-container {
      margin-top: 3rem;
    }

    .timeline-bar {
      height: 20px;
      background: #e2e8f0;
      border-radius: 10px;
      position: relative;
      margin-bottom: 1rem;
      overflow: hidden;
    }

    .timeline-progress {
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      background: var(--accent-color);
      border-radius: 10px;
      transition: width 1s ease-out;
    }

    .timeline-labels {
      display: flex;
      justify-content: space-between;
      color: var(--text-secondary);
      font-size: 0.85rem;
    }

    .milestone-list {
      list-style: none;
      padding: 0;
      margin-top: 2rem;
    }

    .milestone-item {
      display: flex;
      justify-content: space-between;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border-color);
    }

    .educational-section {
      margin-top: 4rem;
    }

    .edu-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .edu-title {
      font-size: 1.2rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
      border-bottom: 2px solid var(--accent-color);
      padding-bottom: 0.5rem;
      display: inline-block;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-item {
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1.5rem;
    }

    .faq-question {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-answer {
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .related-tools {
      margin-top: 4rem;
      border-top: 1px solid var(--border-color);
      padding-top: 2rem;
    }

    .related-tools h3 {
      margin-bottom: 1rem;
    }

    .related-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .related-link {
      color: var(--accent-color);
      text-decoration: none;
      padding: 0.5rem 1rem;
      border: 1px solid var(--border-color);
      border-radius: 4px;
      background: var(--card-bg);
    }

    .related-link:hover {
      text-decoration: underline;
    }

    .error-message {
      color: #ef4444;
      font-size: 0.9rem;
      margin-top: 0.5rem;
      display: none;
    }
  </style>

  <div class="calculator-container">
    <div class="hero-section">
      <h1 class="hero-title">Pregnancy Due Date Calculator</h1>
      <p class="hero-subtitle">Discover when you'll meet your little one. Track your pregnancy milestones, current week, and trimesters with our precise estimation tool.</p>
    </div>

    <div class="calc-card">
      <form id="dueDateForm" onsubmit="event.preventDefault(); calculateDueDate();">
        <div class="input-group">
          <label class="input-label" for="calcMethod">Calculation Method</label>
          <select id="calcMethod" class="input-select" onchange="toggleInputs()">
            <option value="lmp">Last Menstrual Period (LMP)</option>
            <option value="conception">Conception Date</option>
            <option value="ivf3">IVF 3-Day Transfer</option>
            <option value="ivf5">IVF 5-Day Transfer</option>
          </select>
        </div>

        <div class="input-group" id="dateInputGroup">
          <label class="input-label" id="dateLabel" for="baseDate">First Day of Last Period</label>
          <input type="date" id="baseDate" class="input-date" required>
          <div id="dateError" class="error-message">Please select a valid date. Future dates for LMP/Conception are not allowed.</div>
        </div>

        <button type="submit" class="calc-btn">Calculate My Due Date</button>
      </form>
    </div>

    <div id="resultsSection" class="results-section">
      <div class="calc-card">
        <h2 style="text-align: center; margin-bottom: 1.5rem;">Your Pregnancy Results</h2>

        <div class="result-box" style="background: var(--accent-color); color: white; border: none; padding: 2rem;">
          <div class="result-label" style="color: rgba(255,255,255,0.8);">Estimated Due Date</div>
          <div class="result-value" id="resDueDate" style="color: white; font-size: 2rem;">--</div>
        </div>

        <div class="results-grid">
          <div class="result-box">
            <div class="result-value" id="resWeek">--</div>
            <div class="result-label">Current Progress</div>
          </div>
          <div class="result-box">
            <div class="result-value" id="resTrimester">--</div>
            <div class="result-label">Trimester</div>
          </div>
          <div class="result-box">
            <div class="result-value" id="resCountdown">--</div>
            <div class="result-label">Days Until Due Date</div>
          </div>
        </div>

        <div class="timeline-container">
          <h3 style="margin-bottom: 1rem; font-size: 1.1rem;">Pregnancy Timeline (40 Weeks)</h3>
          <div class="timeline-bar">
            <div id="timelineProgress" class="timeline-progress" style="width: 0%"></div>
          </div>
          <div class="timeline-labels">
            <span>Week 1</span>
            <span>Week 13</span>
            <span>Week 27</span>
            <span>Week 40</span>
          </div>
        </div>

        <div style="margin-top: 3rem;">
          <h3 style="margin-bottom: 1rem;">Key Milestones</h3>
          <ul class="milestone-list">
            <li class="milestone-item">
              <span>First Heartbeat (≈6 Weeks)</span>
              <strong id="msHeartbeat">--</strong>
            </li>
            <li class="milestone-item">
              <span>Second Trimester Begins (Week 14)</span>
              <strong id="msTri2">--</strong>
            </li>
            <li class="milestone-item">
              <span>Anatomy Scan (≈20 Weeks)</span>
              <strong id="msScan">--</strong>
            </li>
            <li class="milestone-item">
              <span>Viability (≈24 Weeks)</span>
              <strong id="msViability">--</strong>
            </li>
            <li class="milestone-item">
              <span>Third Trimester Begins (Week 28)</span>
              <strong id="msTri3">--</strong>
            </li>
            <li class="milestone-item">
              <span>Full Term (Week 37)</span>
              <strong id="msFullTerm">--</strong>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="educational-section">
      <h2 style="margin-bottom: 2rem;">Understanding Your Due Date</h2>

      <div class="edu-card">
        <h3 class="edu-title">How is the due date calculated?</h3>
        <p style="line-height: 1.6; color: var(--text-secondary);">
          The standard method for calculating a due date is Naegele's rule. This rule adds 280 days (40 weeks) to the first day of your last menstrual period (LMP). For conception date, we add 266 days (38 weeks). For IVF, calculations adjust based on the embryo's age at transfer (adding 263 days for a 3-day embryo or 261 days for a 5-day embryo).
        </p>
      </div>

      <div class="edu-card">
        <h3 class="edu-title">The Three Trimesters</h3>
        <div style="display: grid; gap: 1rem; margin-top: 1rem;">
          <div>
            <strong>First Trimester (Weeks 1-13):</strong>
            <span style="color: var(--text-secondary);">Crucial development phase where major organs form. Often accompanied by early pregnancy symptoms like morning sickness.</span>
          </div>
          <div>
            <strong>Second Trimester (Weeks 14-27):</strong>
            <span style="color: var(--text-secondary);">Often called the "honeymoon phase." Energy levels typically return, and you'll likely feel the baby's first movements.</span>
          </div>
          <div>
            <strong>Third Trimester (Weeks 28-40+):</strong>
            <span style="color: var(--text-secondary);">Final growth phase. The baby gains weight rapidly to prepare for birth, and your body readies for labor.</span>
          </div>
        </div>
      </div>

      <div class="edu-card">
        <h3 class="edu-title">Is the due date exact?</h3>
        <p style="line-height: 1.6; color: var(--text-secondary);">
          An estimated due date (EDD) is exactly that—an estimate. Only about 5% of babies are born exactly on their due date. Most babies arrive sometime between 37 and 42 weeks of pregnancy. Your healthcare provider may also adjust your due date based on early ultrasound measurements, which are considered the most accurate method for dating a pregnancy.
        </p>
      </div>
    </div>

    <div class="faq-section">
      <h2 style="margin-bottom: 2rem;">Frequently Asked Questions</h2>

      <div class="faq-item">
        <div class="faq-question">How accurate is a due date calculator?</div>
        <div class="faq-answer">A due date calculator provides an estimate based on your last menstrual period (LMP), conception date, or IVF transfer. While highly accurate for estimation, only about 4-5% of babies are born exactly on their calculated due date. Most babies arrive between 37 and 42 weeks.</div>
      </div>

      <div class="faq-item">
        <div class="faq-question">Can my due date change?</div>
        <div class="faq-answer">Yes, your due date can change. Ultrasound measurements taken during the first trimester (usually between 8 and 13 weeks) provide the most accurate estimation of fetal age. If the ultrasound date differs significantly from the LMP date, your healthcare provider may adjust your official due date.</div>
      </div>

      <div class="faq-item">
        <div class="faq-question">How do you calculate due date for IVF?</div>
        <div class="faq-answer">For IVF, the due date is calculated based on the embryo transfer date and the age of the embryo (typically 3-day or 5-day transfer). This method is often more accurate than LMP since the exact date of conception is known.</div>
      </div>

      <div class="faq-item">
        <div class="faq-question">What is Naegele's rule?</div>
        <div class="faq-answer">Naegele's rule is a standard way of calculating the due date for a pregnancy. The rule estimates the expected date of delivery (EDD) by adding one year, subtracting three months, and adding seven days to the first day of a woman's last menstrual period (LMP).</div>
      </div>

      <div class="faq-item">
        <div class="faq-question">How is the pregnancy timeline divided?</div>
        <div class="faq-answer">Pregnancy is divided into three trimesters. The first trimester lasts from week 1 through the end of week 13. The second trimester spans weeks 14 through 27. The third trimester starts at week 28 and continues until delivery, which is typically around week 40.</div>
      </div>
    </div>

    <div class="related-tools">
      <h3>More Health Tools</h3>
      <div class="related-links">
        <a href="/pregnancy-calculator" class="related-link">Pregnancy Calculator</a>
        <a href="/pregnancy-week-by-week" class="related-link">Pregnancy Week by Week</a>
        <a href="/conception-calculator" class="related-link">Conception Calculator</a>
        <a href="/ovulation-calculator" class="related-link">Ovulation Calculator</a>
      </div>
    </div>
  </div>

  <script is:inline>
    // Set default date to today
    document.getElementById('baseDate').valueAsDate = new Date();

    function toggleInputs() {
      const method = document.getElementById('calcMethod').value;
      const label = document.getElementById('dateLabel');

      switch(method) {
        case 'lmp':
          label.textContent = 'First Day of Last Period';
          break;
        case 'conception':
          label.textContent = 'Date of Conception';
          break;
        case 'ivf3':
          label.textContent = 'Date of 3-Day Embryo Transfer';
          break;
        case 'ivf5':
          label.textContent = 'Date of 5-Day Embryo Transfer';
          break;
      }
    }

    function calculateDueDate() {
      const method = document.getElementById('calcMethod').value;
      const dateInput = document.getElementById('baseDate').value;
      const errorEl = document.getElementById('dateError');

      if (!dateInput) {
        errorEl.style.display = 'block';
        return;
      }

      const inputDate = new Date(dateInput);
      const today = new Date();

      // Basic validation
      if ((method === 'lmp' || method === 'conception') && inputDate > today) {
        errorEl.style.display = 'block';
        errorEl.textContent = 'Date cannot be in the future for LMP or Conception.';
        return;
      }

      errorEl.style.display = 'none';

      let dueDate = new Date(inputDate);
      let conceptionDate = new Date(inputDate);

      // Add appropriate days to get due date
      switch(method) {
        case 'lmp':
          dueDate.setDate(dueDate.getDate() + 280); // 40 weeks
          conceptionDate.setDate(conceptionDate.getDate() + 14);
          break;
        case 'conception':
          dueDate.setDate(dueDate.getDate() + 266); // 38 weeks
          break;
        case 'ivf3':
          dueDate.setDate(dueDate.getDate() + 263);
          conceptionDate.setDate(conceptionDate.getDate() - 3);
          break;
        case 'ivf5':
          dueDate.setDate(dueDate.getDate() + 261);
          conceptionDate.setDate(conceptionDate.getDate() - 5);
          break;
      }

      // Calculate current progress
      const totalPregnancyDays = 280;

      // If method is not LMP, we need to calculate an "equivalent LMP" to find current week
      let equivalentLMP = new Date(dueDate);
      equivalentLMP.setDate(equivalentLMP.getDate() - 280);

      const msDiff = today.getTime() - equivalentLMP.getTime();
      let daysPregnant = Math.floor(msDiff / (1000 * 60 * 60 * 24));

      // Prevent negative days or exceeding 42 weeks
      if (daysPregnant < 0) daysPregnant = 0;
      if (daysPregnant > 294) daysPregnant = 294; // 42 weeks max

      const weeks = Math.floor(daysPregnant / 7);
      const days = daysPregnant % 7;

      // Determine trimester
      let trimester = "1st";
      if (weeks >= 28) trimester = "3rd";
      else if (weeks >= 14) trimester = "2nd";

      // Countdown
      const msUntilDue = dueDate.getTime() - today.getTime();
      const daysUntilDue = Math.ceil(msUntilDue / (1000 * 60 * 60 * 24));
      const displayCountdown = daysUntilDue >= 0 ? daysUntilDue : "Delivered!";

      // Formatting options
      const options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };

      // Update UI
      document.getElementById('resDueDate').textContent = dueDate.toLocaleDateString(undefined, options);
      document.getElementById('resWeek').textContent = `${weeks}w ${days}d`;
      document.getElementById('resTrimester').textContent = trimester;
      document.getElementById('resCountdown').textContent = displayCountdown;

      // Progress bar
      const progressPercent = Math.min((daysPregnant / totalPregnancyDays) * 100, 100);
      document.getElementById('timelineProgress').style.width = `${progressPercent}%`;

      // Milestones
      const milestones = [
        { id: 'msHeartbeat', weeks: 6 },
        { id: 'msTri2', weeks: 14 },
        { id: 'msScan', weeks: 20 },
        { id: 'msViability', weeks: 24 },
        { id: 'msTri3', weeks: 28 },
        { id: 'msFullTerm', weeks: 37 }
      ];

      milestones.forEach(ms => {
        let msDate = new Date(equivalentLMP);
        msDate.setDate(msDate.getDate() + (ms.weeks * 7));
        document.getElementById(ms.id).textContent = msDate.toLocaleDateString(undefined, options);
      });

      // Show results
      document.getElementById('resultsSection').style.display = 'block';

      // Scroll to results smoothly
      document.getElementById('resultsSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Detailed historical gestational tracking variances dataset (internal calibration usage)
    // These metrics ensure that future timeline enhancements remain highly precise.
    const timelineVariances = [
