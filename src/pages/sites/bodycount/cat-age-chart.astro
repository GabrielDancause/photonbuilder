---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Cat Age Calculator",
      "url": "https://bodycount.photonbuilder.com/cat-age-chart",
      "description": "Convert cat years to human years with our interactive calculator and chart. See life stages, breed lifespans, and care tips for every age.",
      "applicationCategory": "HealthAndFitnessApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How old is my cat in human years?",
          "acceptedAnswer": { "@type": "Answer", "text": "A 1-year-old cat is roughly 15 in human years. At 2, they're about 24. After that, each cat year equals approximately 4 human years. So a 5-year-old cat is about 36 in human years." }
        },
        {
          "@type": "Question",
          "name": "Do indoor cats live longer than outdoor cats?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, significantly. Indoor cats typically live 12–18 years, while outdoor-only cats average just 2–5 years due to traffic, predators, disease, and weather exposure." }
        },
        {
          "@type": "Question",
          "name": "What is the oldest cat ever recorded?",
          "acceptedAnswer": { "@type": "Answer", "text": "The oldest verified cat was Creme Puff from Austin, Texas, who lived to 38 years and 3 days (1967–2005), equivalent to roughly 168 human years." }
        },
        {
          "@type": "Question",
          "name": "At what age is a cat considered senior?",
          "acceptedAnswer": { "@type": "Answer", "text": "Cats are generally considered senior at 11 years old (about 60 in human years). Cats 15 and older are sometimes called 'super seniors' or 'geriatric cats.'" }
        },
        {
          "@type": "Question",
          "name": "Why do cats age faster in their first two years?",
          "acceptedAnswer": { "@type": "Answer", "text": "Cats mature rapidly — reaching sexual maturity by 6–9 months and full physical maturity by age 2. This compressed development means the first two years account for roughly 24 human years of growth and change." }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Cat Age Chart: Cat Years to Human Years Calculator",
  description: "Convert cat years to human years with our interactive calculator and chart. See life stages, breed lifespans, and care tips for every age.",
  category: "tool",
  published: "2026-03-29"
};
---

<SiteLayout
  site="bodycount"
  title="Cat Age Chart: Cat Years to Human Years Calculator"
  description="Convert cat years to human years with our interactive calculator and chart. See life stages, breed lifespans, and care tips for every age."
  canonical="https://bodycount.photonbuilder.com/cat-age-chart"
  schema={schema}
>
  <h1>Cat Age Chart: Cat Years to Human Years Calculator</h1>

  <style is:inline>
    :root {
      --bg-color: #0a0a10;
      --card-bg: #12121c;
      --border-color: #252535;
      --accent-color: #c084fc;
      --accent-hover: #a855f7;
      --accent-soft: rgba(192,132,252,0.12);
      --text-primary: #e0dce8;
      --text-secondary: #8a8898;
      --font-ui: 'Inter', system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --kitten: #f472b6;
      --junior: #fb923c;
      --prime: #34d399;
      --mature: #60a5fa;
      --senior: #a78bfa;
      --super-senior: #f87171;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-ui); background: var(--bg-color); color: var(--text-primary); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    .container { max-width: 860px; margin: 0 auto; padding: 2rem 1rem; }
    h1 { font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 0.5rem; text-align: center; }
    p.subtitle { color: var(--text-secondary); text-align: center; font-size: 1.05rem; margin-bottom: 2rem; }
    h2 { font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 1rem; }
    h3 { font-size: 1.1rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem; }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }

    /* Converter */
    .converter-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: center; }
    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group label { font-size: 0.85rem; color: var(--text-secondary); font-weight: 500; }
    .input-group input[type="range"] { width: 100%; accent-color: var(--accent-color); }
    .input-row { display: flex; gap: 0.75rem; }
    .input-row .field { flex: 1; }
    .input-row .field input { width: 100%; padding: 0.6rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-color); color: var(--text-primary); font-size: 1rem; font-family: var(--font-mono); text-align: center; }
    .input-row .field input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px var(--accent-soft); }
    .result-display { text-align: center; padding: 1.5rem; background: var(--accent-soft); border-radius: 12px; border: 1px solid rgba(192,132,252,0.2); }
    .result-display .cat-visual { font-size: 3rem; margin-bottom: 0.5rem; }
    .result-display .human-age { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); font-family: var(--font-mono); }
    .result-display .human-label { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem; }
    .stage-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600; margin-top: 0.5rem; }
    .slider-value { font-family: var(--font-mono); font-size: 1.1rem; color: var(--accent-color); font-weight: 600; text-align: center; }

    /* Chart */
    .chart-container { position: relative; width: 100%; height: 320px; margin: 1rem 0; }
    .chart-canvas { width: 100%; height: 100%; }
    .chart-legend { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; margin-top: 0.75rem; }
    .chart-legend span { font-size: 0.78rem; display: flex; align-items: center; gap: 0.35rem; color: var(--text-secondary); }
    .chart-legend span::before { content: ''; width: 10px; height: 10px; border-radius: 3px; display: inline-block; }

    /* Life stages */
    .stages-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .stage-card { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.25rem; border-left: 3px solid; }
    .stage-card .stage-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; }
    .stage-card .stage-header .emoji { font-size: 1.5rem; }
    .stage-card .stage-header .stage-name { font-weight: 700; color: #fff; }
    .stage-card .stage-header .age-range { font-size: 0.8rem; color: var(--text-secondary); font-family: var(--font-mono); }
    .stage-card .detail { margin-bottom: 0.5rem; }
    .stage-card .detail-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); font-weight: 600; margin-bottom: 0.15rem; }
    .stage-card .detail-text { font-size: 0.88rem; color: var(--text-primary); }

    /* Breed table */
    .table-controls { display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .table-controls input { flex: 1; min-width: 200px; padding: 0.5rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-color); color: var(--text-primary); font-size: 0.9rem; }
    .table-controls input:focus { outline: none; border-color: var(--accent-color); }
    .table-controls select { padding: 0.5rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-color); color: var(--text-primary); font-size: 0.9rem; }
    .breed-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .breed-table th { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; user-select: none; white-space: nowrap; }
    .breed-table th:hover { color: var(--accent-color); }
    .breed-table th .sort-arrow { margin-left: 0.25rem; font-size: 0.7rem; }
    .breed-table td { padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--border-color); }
    .breed-table tr:hover td { background: var(--accent-soft); }
    .lifespan-bar { height: 6px; border-radius: 3px; background: var(--accent-color); display: block; min-width: 4px; }

    /* Indoor vs outdoor */
    .comparison-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .compare-card { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.25rem; text-align: center; }
    .compare-card .compare-emoji { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .compare-card .compare-title { font-weight: 700; color: #fff; font-size: 1.1rem; margin-bottom: 0.5rem; }
    .compare-card .compare-years { font-size: 2rem; font-weight: 800; font-family: var(--font-mono); margin-bottom: 0.25rem; }
    .compare-card .compare-label { font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 0.75rem; }
    .compare-bar { height: 10px; border-radius: 5px; margin: 0.75rem 0; }
    .indoor-color { color: var(--prime); }
    .outdoor-color { color: var(--super-senior); }
    .compare-list { text-align: left; list-style: none; padding: 0; }
    .compare-list li { font-size: 0.85rem; padding: 0.3rem 0; color: var(--text-primary); }
    .compare-list li::before { content: '•'; margin-right: 0.5rem; }

    /* FAQ */
    .faq-item { border-bottom: 1px solid var(--border-color); }
    .faq-item:last-child { border-bottom: none; }
    .faq-q { padding: 1rem 0; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-weight: 600; color: #fff; font-size: 1rem; }
    .faq-q:hover { color: var(--accent-color); }
    .faq-q .arrow { transition: transform 0.2s; font-size: 0.8rem; color: var(--text-secondary); }
    .faq-q.open .arrow { transform: rotate(180deg); }
    .faq-a { padding: 0 0 1rem; font-size: 0.92rem; color: var(--text-secondary); display: none; line-height: 1.7; }
    .faq-a.open { display: block; }

    /* Content prose */
    .prose { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.7; }
    .prose p { margin-bottom: 1rem; }
    .prose h2 { color: #fff; margin-top: 2rem; }

    @media (max-width: 640px) {
      .converter-grid, .stages-grid, .comparison-grid { grid-template-columns: 1fr; }
      h1 { font-size: 1.5rem; }
      .result-display .human-age { font-size: 2rem; }
      .chart-container { height: 260px; }
      .breed-table { font-size: 0.82rem; }
      .breed-table th, .breed-table td { padding: 0.45rem 0.5rem; }
    }
  </style>

  <div class="container">
    <p class="subtitle">Convert your cat's age to human years and learn what to expect at every life stage</p>

    <!-- Age Converter -->
    <div class="card">
      <h2>Cat Age Calculator</h2>
      <div class="converter-grid">
        <div>
          <div class="input-group">
            <label>Cat's Age (Years)</label>
            <input type="range" id="catYears" min="0" max="25" value="3" step="1">
            <div class="slider-value" id="yearsVal">3 years</div>
          </div>
          <div class="input-group" style="margin-top:1rem;">
            <label>Months (fine-tune)</label>
            <input type="range" id="catMonths" min="0" max="11" value="0" step="1">
            <div class="slider-value" id="monthsVal">0 months</div>
          </div>
          <div class="input-row" style="margin-top:1rem;">
            <div class="field">
              <label style="font-size:0.78rem;color:var(--text-secondary);">Or enter directly</label>
              <input type="number" id="directYears" min="0" max="30" placeholder="Years" value="3">
            </div>
            <div class="field">
              <label style="font-size:0.78rem;color:var(--text-secondary);">&nbsp;</label>
              <input type="number" id="directMonths" min="0" max="11" placeholder="Months" value="0">
            </div>
          </div>
        </div>
        <div class="result-display">
          <div class="cat-visual" id="catEmoji">🐱</div>
          <div class="human-age" id="humanAge">28</div>
          <div class="human-label">human years equivalent</div>
          <div class="stage-badge" id="stageBadge" style="background:var(--prime);color:#000;">Prime</div>
        </div>
      </div>
    </div>

    <!-- Age Chart -->
    <div class="card">
      <h2>Cat-to-Human Age Curve</h2>
      <p style="color:var(--text-secondary);font-size:0.9rem;margin-bottom:1rem;">The curve flattens after age 2 — each additional cat year equals about 4 human years.</p>
      <div class="chart-container">
        <canvas id="ageChart" class="chart-canvas"></canvas>
      </div>
      <div class="chart-legend">
        <span style="--c:var(--kitten);">Kitten</span>
        <span style="--c:var(--junior);">Junior</span>
        <span style="--c:var(--prime);">Prime</span>
        <span style="--c:var(--mature);">Mature</span>
        <span style="--c:var(--senior);">Senior</span>
        <span style="--c:var(--super-senior);">Super Senior</span>
      </div>
    </div>

    <!-- Life Stage Guide -->
    <div class="card">
      <h2>Life Stage Guide</h2>
      <div class="stages-grid">
        <div class="stage-card" style="border-left-color:var(--kitten);">
          <div class="stage-header">
            <span class="emoji">🐾</span>
            <div><div class="stage-name">Kitten</div><div class="age-range">0–6 months (0–10 human yrs)</div></div>
          </div>
          <div class="detail"><div class="detail-label">Behaviors</div><div class="detail-text">Boundless energy, play-hunting, rapid learning, socialization with humans and other pets.</div></div>
          <div class="detail"><div class="detail-label">Health</div><div class="detail-text">Vaccinations, deworming, spay/neuter planning. Monitor growth milestones closely.</div></div>
          <div class="detail"><div class="detail-label">Care Tips</div><div class="detail-text">Kitten-specific food for growth. Provide safe toys, scratching posts, and litter training.</div></div>
        </div>
        <div class="stage-card" style="border-left-color:var(--junior);">
          <div class="stage-header">
            <span class="emoji">😺</span>
            <div><div class="stage-name">Junior</div><div class="age-range">7 months–2 yrs (12–24 human yrs)</div></div>
          </div>
          <div class="detail"><div class="detail-label">Behaviors</div><div class="detail-text">Reaching full size, testing boundaries, establishing territory. Still very playful.</div></div>
          <div class="detail"><div class="detail-label">Health</div><div class="detail-text">Complete vaccination series. Spay/neuter if not done. Dental check baseline.</div></div>
          <div class="detail"><div class="detail-label">Care Tips</div><div class="detail-text">Transition to adult food around 12 months. Interactive play to burn energy and bond.</div></div>
        </div>
        <div class="stage-card" style="border-left-color:var(--prime);">
          <div class="stage-header">
            <span class="emoji">🐱</span>
            <div><div class="stage-name">Prime</div><div class="age-range">3–6 yrs (28–40 human yrs)</div></div>
          </div>
          <div class="detail"><div class="detail-label">Behaviors</div><div class="detail-text">Peak physical condition. Settled personality, established routines, confident and active.</div></div>
          <div class="detail"><div class="detail-label">Health</div><div class="detail-text">Annual vet visits. Watch weight — obesity risks begin. Dental cleanings recommended.</div></div>
          <div class="detail"><div class="detail-label">Care Tips</div><div class="detail-text">Maintain play routines. Portion-controlled feeding. Keep vaccinations current.</div></div>
        </div>
        <div class="stage-card" style="border-left-color:var(--mature);">
          <div class="stage-header">
            <span class="emoji">😼</span>
            <div><div class="stage-name">Mature</div><div class="age-range">7–10 yrs (44–56 human yrs)</div></div>
          </div>
          <div class="detail"><div class="detail-label">Behaviors</div><div class="detail-text">Calmer, more routine-oriented. May gain weight. Less intense play sessions.</div></div>
          <div class="detail"><div class="detail-label">Health</div><div class="detail-text">Bi-annual vet visits. Blood work for kidney/thyroid. Watch for diabetes signs.</div></div>
          <div class="detail"><div class="detail-label">Care Tips</div><div class="detail-text">Adjust diet for metabolism changes. Provide steps to favorite spots. Dental monitoring.</div></div>
        </div>
        <div class="stage-card" style="border-left-color:var(--senior);">
          <div class="stage-header">
            <span class="emoji">😿</span>
            <div><div class="stage-name">Senior</div><div class="age-range">11–14 yrs (60–72 human yrs)</div></div>
          </div>
          <div class="detail"><div class="detail-label">Behaviors</div><div class="detail-text">Sleeping more, reduced activity. May vocalize more. Comfort-seeking behavior increases.</div></div>
          <div class="detail"><div class="detail-label">Health</div><div class="detail-text">Arthritis, kidney disease, hyperthyroidism common. Quarterly vet checks recommended.</div></div>
          <div class="detail"><div class="detail-label">Care Tips</div><div class="detail-text">Senior diet formula. Low-entry litter boxes. Heated beds. Gentle, regular grooming.</div></div>
        </div>
        <div class="stage-card" style="border-left-color:var(--super-senior);">
          <div class="stage-header">
            <span class="emoji">🐈</span>
            <div><div class="stage-name">Super Senior</div><div class="age-range">15+ yrs (76+ human yrs)</div></div>
          </div>
          <div class="detail"><div class="detail-label">Behaviors</div><div class="detail-text">Significant slowing. Possible cognitive changes, disorientation, altered sleep cycles.</div></div>
          <div class="detail"><div class="detail-label">Health</div><div class="detail-text">Close monitoring of all systems. Pain management for arthritis. Hydration support.</div></div>
          <div class="detail"><div class="detail-label">Care Tips</div><div class="detail-text">Easy access to food, water, litter. Minimize stress and routine changes. Extra warmth and affection.</div></div>
        </div>
      </div>
    </div>

    <!-- Breed Lifespan Table -->
    <div class="card">
      <h2>Cat Breed Lifespan Table</h2>
      <div class="table-controls">
        <input type="text" id="breedSearch" placeholder="Search breeds...">
        <select id="breedSort">
          <option value="name-asc">Name A–Z</option>
          <option value="name-desc">Name Z–A</option>
          <option value="max-desc">Longest lifespan</option>
          <option value="min-asc">Shortest lifespan</option>
        </select>
      </div>
      <div style="overflow-x:auto;">
        <table class="breed-table" id="breedTable">
          <thead>
            <tr>
              <th data-sort="name">Breed <span class="sort-arrow">▲</span></th>
              <th data-sort="min">Min (yrs) <span class="sort-arrow"></span></th>
              <th data-sort="max">Max (yrs) <span class="sort-arrow"></span></th>
              <th data-sort="avg">Avg <span class="sort-arrow"></span></th>
              <th style="min-width:100px;">Lifespan</th>
            </tr>
          </thead>
          <tbody id="breedBody"></tbody>
        </table>
      </div>
    </div>

    <!-- Indoor vs Outdoor -->
    <div class="card">
      <h2>Indoor vs. Outdoor Lifespan</h2>
      <div class="comparison-grid">
        <div class="compare-card">
          <div class="compare-emoji">🏠</div>
          <div class="compare-title">Indoor Cat</div>
          <div class="compare-years indoor-color">12–18 yrs</div>
          <div class="compare-label">average lifespan</div>
          <div class="compare-bar" style="background:linear-gradient(90deg,var(--prime) 0%,var(--prime) 100%);width:100%;"></div>
          <ul class="compare-list">
            <li>Protected from traffic and predators</li>
            <li>Lower disease and parasite exposure</li>
            <li>Consistent nutrition and vet care</li>
            <li>Climate-controlled environment</li>
            <li>May need enrichment to prevent boredom</li>
          </ul>
        </div>
        <div class="compare-card">
          <div class="compare-emoji">🌲</div>
          <div class="compare-title">Outdoor Cat</div>
          <div class="compare-years outdoor-color">2–5 yrs</div>
          <div class="compare-label">average lifespan</div>
          <div class="compare-bar" style="background:linear-gradient(90deg,var(--super-senior) 0%,var(--super-senior) 100%);width:28%;"></div>
          <ul class="compare-list">
            <li>Traffic accidents are the #1 risk</li>
            <li>Exposure to FIV, FeLV, parasites</li>
            <li>Predation by coyotes, dogs, birds of prey</li>
            <li>Territorial fights cause injuries</li>
            <li>Weather extremes and toxic substances</li>
          </ul>
        </div>
      </div>
      <p style="color:var(--text-secondary);font-size:0.85rem;margin-top:1rem;text-align:center;">
        <strong style="color:#fff;">Compromise:</strong> A supervised outdoor enclosure ("catio") gives fresh air and enrichment while keeping cats safe. Indoor cats with catios can live just as long as fully indoor cats.
      </p>
    </div>

    <!-- FAQ -->
    <div class="card">
      <h2>Frequently Asked Questions</h2>
      <div id="faqContainer">
        <div class="faq-item">
          <div class="faq-q" onclick="toggleFaq(this)">How old is my cat in human years? <span class="arrow">▼</span></div>
          <div class="faq-a">A 1-year-old cat is roughly 15 in human years. At 2, they're about 24. After that, each cat year equals approximately 4 human years. So a 5-year-old cat is about 36 in human years. Use the calculator above for a precise conversion including months.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q" onclick="toggleFaq(this)">Do indoor cats live longer than outdoor cats? <span class="arrow">▼</span></div>
          <div class="faq-a">Yes, significantly. Indoor cats typically live 12–18 years, while outdoor-only cats average just 2–5 years due to traffic, predators, disease, and weather exposure. Indoor/outdoor cats (with supervised outdoor time) fall somewhere in between.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q" onclick="toggleFaq(this)">What is the oldest cat ever recorded? <span class="arrow">▼</span></div>
          <div class="faq-a">The oldest verified cat was Creme Puff from Austin, Texas, who lived to 38 years and 3 days (1967–2005), equivalent to roughly 168 human years. Her owner also had another cat, Granpa Rex Allen, who lived to 34.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q" onclick="toggleFaq(this)">At what age is a cat considered senior? <span class="arrow">▼</span></div>
          <div class="faq-a">Cats are generally considered senior at 11 years old (about 60 in human years). Cats 15 and older are sometimes called "super seniors" or "geriatric cats." Senior cats benefit from more frequent vet visits and adjusted nutrition.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q" onclick="toggleFaq(this)">Why do cats age faster in their first two years? <span class="arrow">▼</span></div>
          <div class="faq-a">Cats mature rapidly — reaching sexual maturity by 6–9 months and full physical maturity by age 2. This compressed development means the first two years account for roughly 24 human years of growth and change. After that, aging slows to about 4 human years per cat year.</div>
        </div>
      </div>
    </div>

    <!-- Prose content for SEO -->
    <div class="card prose">
      <h2>Understanding Cat Years</h2>
      <p>The old myth that one cat year equals seven human years is inaccurate. Cats develop much more rapidly in their first two years of life, reaching the equivalent of a 24-year-old human by their second birthday. After that initial burst of development, aging becomes more linear at roughly four human years for every one cat year.</p>
      <p>This non-linear aging curve means that a 5-year-old cat is roughly equivalent to a 36-year-old person — firmly in their prime. Meanwhile, a 15-year-old cat is comparable to a 76-year-old human, which is why veterinarians recommend increased health monitoring for cats entering their senior years.</p>
      <h2>Factors That Affect Cat Lifespan</h2>
      <p>Genetics play a major role — some breeds are predisposed to longer lives. Mixed-breed cats often benefit from hybrid vigor and can live well into their late teens. Beyond genetics, diet quality, regular veterinary care, weight management, dental health, and mental stimulation all contribute to longevity. Indoor cats consistently outlive outdoor cats, primarily due to reduced exposure to accidents, disease, and predation.</p>
      <p>The single most impactful thing you can do for your cat's lifespan is to keep them at a healthy weight. Obesity in cats leads to diabetes, joint problems, and organ stress — all of which shorten life expectancy significantly.</p>
    </div>
  </div>

  <script is:inline>
    // Breed data
    const breeds = [
      { name: 'Siamese', min: 15, max: 20 },
      { name: 'Persian', min: 12, max: 17 },
      { name: 'Maine Coon', min: 12, max: 15 },
      { name: 'Ragdoll', min: 12, max: 17 },
      { name: 'British Shorthair', min: 12, max: 17 },
      { name: 'Abyssinian', min: 14, max: 17 },
      { name: 'Bengal', min: 12, max: 16 },
      { name: 'Sphynx', min: 12, max: 14 },
      { name: 'Russian Blue', min: 15, max: 20 },
      { name: 'Scottish Fold', min: 11, max: 14 },
      { name: 'Burmese', min: 16, max: 18 },
      { name: 'Norwegian Forest', min: 14, max: 16 },
      { name: 'Devon Rex', min: 12, max: 15 },
      { name: 'Birman', min: 12, max: 16 },
      { name: 'American Shorthair', min: 15, max: 20 },
      { name: 'Oriental', min: 12, max: 15 },
      { name: 'Tonkinese', min: 15, max: 18 },
      { name: 'Cornish Rex', min: 12, max: 15 },
      { name: 'Himalayan', min: 9, max: 15 },
      { name: 'Exotic Shorthair', min: 12, max: 15 },
      { name: 'Turkish Angora', min: 12, max: 18 },
      { name: 'Manx', min: 8, max: 14 },
      { name: 'Somali', min: 11, max: 16 },
      { name: 'Siberian', min: 11, max: 15 },
      { name: 'Balinese', min: 18, max: 22 },
      { name: 'Bombay', min: 12, max: 16 },
      { name: 'Chartreux', min: 12, max: 15 },
      { name: 'Havana Brown', min: 12, max: 15 },
      { name: 'Japanese Bobtail', min: 14, max: 16 },
      { name: 'Korat', min: 15, max: 20 },
      { name: 'Ragamuffin', min: 12, max: 16 },
      { name: 'Singapura', min: 11, max: 15 },
      { name: 'Turkish Van', min: 12, max: 17 },
      { name: 'Domestic Shorthair (mixed)', min: 12, max: 20 },
    ];
    const maxLife = 22;

    function catToHuman(years, months) {
      const totalMonths = years * 12 + months;
      if (totalMonths <= 12) return (totalMonths / 12) * 15;
      if (totalMonths <= 24) return 15 + ((totalMonths - 12) / 12) * 9;
      return 24 + ((totalMonths - 24) / 12) * 4;
    }

    function getStage(years, months) {
      const totalMonths = years * 12 + months;
      if (totalMonths <= 6) return { name: 'Kitten', color: 'var(--kitten)', emoji: '🐾' };
      if (totalMonths <= 24) return { name: 'Junior', color: 'var(--junior)', emoji: '😺' };
      if (years <= 6) return { name: 'Prime', color: 'var(--prime)', emoji: '🐱' };
      if (years <= 10) return { name: 'Mature', color: 'var(--mature)', emoji: '😼' };
      if (years <= 14) return { name: 'Senior', color: 'var(--senior)', emoji: '😿' };
      return { name: 'Super Senior', color: 'var(--super-senior)', emoji: '🐈' };
    }

    function getStageColor(catYear) {
      if (catYear < 0.5) return getComputedStyle(document.documentElement).getPropertyValue('--kitten').trim();
      if (catYear <= 2) return getComputedStyle(document.documentElement).getPropertyValue('--junior').trim();
      if (catYear <= 6) return getComputedStyle(document.documentElement).getPropertyValue('--prime').trim();
      if (catYear <= 10) return getComputedStyle(document.documentElement).getPropertyValue('--mature').trim();
      if (catYear <= 14) return getComputedStyle(document.documentElement).getPropertyValue('--senior').trim();
      return getComputedStyle(document.documentElement).getPropertyValue('--super-senior').trim();
    }

    // Calculator
    const sliderYears = document.getElementById('catYears');
    const sliderMonths = document.getElementById('catMonths');
    const directYears = document.getElementById('directYears');
    const directMonths = document.getElementById('directMonths');
    const yearsVal = document.getElementById('yearsVal');
    const monthsVal = document.getElementById('monthsVal');
    const humanAgeEl = document.getElementById('humanAge');
    const catEmojiEl = document.getElementById('catEmoji');
    const stageBadgeEl = document.getElementById('stageBadge');

    function updateCalc() {
      const y = parseInt(sliderYears.value);
      const m = parseInt(sliderMonths.value);
      yearsVal.textContent = y + (y === 1 ? ' year' : ' years');
      monthsVal.textContent = m + (m === 1 ? ' month' : ' months');
      directYears.value = y;
      directMonths.value = m;
      const human = catToHuman(y, m);
      humanAgeEl.textContent = Math.round(human);
      const stage = getStage(y, m);
      catEmojiEl.textContent = stage.emoji;
      stageBadgeEl.textContent = stage.name;
      stageBadgeEl.style.background = stage.color;
      stageBadgeEl.style.color = stage.name === 'Kitten' || stage.name === 'Junior' || stage.name === 'Prime' ? '#000' : '#fff';
      drawChart(y + m / 12);
    }

    sliderYears.addEventListener('input', updateCalc);
    sliderMonths.addEventListener('input', updateCalc);
    directYears.addEventListener('input', function() {
      let v = Math.max(0, Math.min(25, parseInt(this.value) || 0));
      sliderYears.value = v;
      updateCalc();
    });
    directMonths.addEventListener('input', function() {
      let v = Math.max(0, Math.min(11, parseInt(this.value) || 0));
      sliderMonths.value = v;
      updateCalc();
    });

    // Chart
    const canvas = document.getElementById('ageChart');
    const ctx = canvas.getContext('2d');

    function drawChart(highlight) {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      ctx.scale(dpr, dpr);
      const W = rect.width;
      const H = rect.height;
      const pad = { top: 20, right: 20, bottom: 40, left: 50 };
      const cW = W - pad.left - pad.right;
      const cH = H - pad.top - pad.bottom;
      const maxCat = 25;
      const maxHuman = 120;

      ctx.clearRect(0, 0, W, H);

      // Grid
      ctx.strokeStyle = 'rgba(255,255,255,0.06)';
      ctx.lineWidth = 1;
      for (let i = 0; i <= 5; i++) {
        const y = pad.top + (cH / 5) * i;
        ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(W - pad.right, y); ctx.stroke();
      }
      for (let i = 0; i <= 5; i++) {
        const x = pad.left + (cW / 5) * i;
        ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, H - pad.bottom); ctx.stroke();
      }

      // Axis labels
      ctx.fillStyle = '#888';
      ctx.font = '11px Inter, system-ui, sans-serif';
      ctx.textAlign = 'center';
      for (let i = 0; i <= 5; i++) {
        const catVal = (maxCat / 5) * i;
        const x = pad.left + (cW / 5) * i;
        ctx.fillText(catVal, x, H - pad.bottom + 18);
      }
      ctx.textAlign = 'right';
      for (let i = 0; i <= 5; i++) {
        const humanVal = Math.round((maxHuman / 5) * (5 - i));
        const y = pad.top + (cH / 5) * i;
        ctx.fillText(humanVal, pad.left - 8, y + 4);
      }
      ctx.textAlign = 'center';
      ctx.fillText('Cat Years', W / 2, H - 4);
      ctx.save();
      ctx.translate(14, pad.top + cH / 2);
      ctx.rotate(-Math.PI / 2);
      ctx.fillText('Human Years', 0, 0);
      ctx.restore();

      // Life stage background bands
      const stageRanges = [
        { start: 0, end: 0.5, color: 'var(--kitten)' },
        { start: 0.5, end: 2, color: 'var(--junior)' },
        { start: 2, end: 6, color: 'var(--prime)' },
        { start: 6, end: 10, color: 'var(--mature)' },
        { start: 10, end: 14, color: 'var(--senior)' },
        { start: 14, end: 25, color: 'var(--super-senior)' },
      ];
      stageRanges.forEach(s => {
        const x1 = pad.left + (s.start / maxCat) * cW;
        const x2 = pad.left + (s.end / maxCat) * cW;
        ctx.fillStyle = getStageColor(s.start + 0.1).replace(')', ',0.07)').replace('rgb', 'rgba');
        ctx.fillRect(x1, pad.top, x2 - x1, cH);
      });

      // Curve
      ctx.beginPath();
      const points = [];
      for (let c = 0; c <= maxCat; c += 0.1) {
        const h = catToHuman(Math.floor(c), Math.round((c % 1) * 12));
        const x = pad.left + (c / maxCat) * cW;
        const y = pad.top + cH - (h / maxHuman) * cH;
        points.push({ x, y, c, h });
        if (c === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.strokeStyle = '#c084fc';
      ctx.lineWidth = 2.5;
      ctx.stroke();

      // Fill under curve
      const lastPt = points[points.length - 1];
      ctx.lineTo(lastPt.x, pad.top + cH);
      ctx.lineTo(pad.left, pad.top + cH);
      ctx.closePath();
      const grad = ctx.createLinearGradient(0, pad.top, 0, pad.top + cH);
      grad.addColorStop(0, 'rgba(192,132,252,0.18)');
      grad.addColorStop(1, 'rgba(192,132,252,0.01)');
      ctx.fillStyle = grad;
      ctx.fill();

      // Highlight point
      if (highlight !== undefined && highlight >= 0 && highlight <= maxCat) {
        const hAge = catToHuman(Math.floor(highlight), Math.round((highlight % 1) * 12));
        const hx = pad.left + (highlight / maxCat) * cW;
        const hy = pad.top + cH - (hAge / maxHuman) * cH;
        // Crosshair
        ctx.strokeStyle = 'rgba(192,132,252,0.3)';
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 4]);
        ctx.beginPath(); ctx.moveTo(hx, pad.top); ctx.lineTo(hx, pad.top + cH); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(pad.left, hy); ctx.lineTo(W - pad.right, hy); ctx.stroke();
        ctx.setLineDash([]);
        // Dot
        ctx.beginPath();
        ctx.arc(hx, hy, 6, 0, Math.PI * 2);
        ctx.fillStyle = '#c084fc';
        ctx.fill();
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 2;
        ctx.stroke();
        // Label
        ctx.fillStyle = '#fff';
        ctx.font = 'bold 12px Inter, system-ui, sans-serif';
        const label = Math.round(hAge) + ' human yrs';
        const lx = hx + (hx > W / 2 ? -10 : 10);
        ctx.textAlign = hx > W / 2 ? 'right' : 'left';
        ctx.fillText(label, lx, hy - 12);
      }
    }

    // Breed table
    function renderBreeds(data) {
      const body = document.getElementById('breedBody');
      body.innerHTML = data.map(b => {
        const avg = ((b.min + b.max) / 2).toFixed(1);
        const barW = ((b.max / maxLife) * 100).toFixed(1);
        return `<tr>
          <td style="font-weight:500;">${b.name}</td>
          <td style="font-family:var(--font-mono);">${b.min}</td>
          <td style="font-family:var(--font-mono);">${b.max}</td>
          <td style="font-family:var(--font-mono);">${avg}</td>
          <td><span class="lifespan-bar" style="width:${barW}%;"></span></td>
        </tr>`;
      }).join('');
    }

    function sortBreeds() {
      const val = document.getElementById('breedSort').value;
      const search = document.getElementById('breedSearch').value.toLowerCase();
      let data = breeds.filter(b => b.name.toLowerCase().includes(search));
      switch (val) {
        case 'name-asc': data.sort((a, b) => a.name.localeCompare(b.name)); break;
        case 'name-desc': data.sort((a, b) => b.name.localeCompare(a.name)); break;
        case 'max-desc': data.sort((a, b) => b.max - a.max || b.min - a.min); break;
        case 'min-asc': data.sort((a, b) => a.min - b.min || a.max - b.max); break;
      }
      renderBreeds(data);
    }

    document.getElementById('breedSort').addEventListener('change', sortBreeds);
    document.getElementById('breedSearch').addEventListener('input', sortBreeds);

    // Column header sort
    document.querySelectorAll('.breed-table th[data-sort]').forEach(th => {
      th.addEventListener('click', function() {
        const key = this.dataset.sort;
        const sel = document.getElementById('breedSort');
        if (key === 'name') sel.value = sel.value === 'name-asc' ? 'name-desc' : 'name-asc';
        else if (key === 'max') sel.value = 'max-desc';
        else if (key === 'min') sel.value = 'min-asc';
        else if (key === 'avg') sel.value = 'max-desc';
        sortBreeds();
      });
    });

    // FAQ
    function toggleFaq(el) {
      const answer = el.nextElementSibling;
      const isOpen = answer.classList.contains('open');
      document.querySelectorAll('.faq-a').forEach(a => a.classList.remove('open'));
      document.querySelectorAll('.faq-q').forEach(q => q.classList.remove('open'));
      if (!isOpen) {
        answer.classList.add('open');
        el.classList.add('open');
      }
    }

    // Chart legend colors
    document.querySelectorAll('.chart-legend span').forEach(s => {
      const c = s.style.getPropertyValue('--c');
      s.style.setProperty('--c', c);
      s.querySelector('::before') // styled via CSS
    });

    // init
    sortBreeds();
    updateCalc();
    window.addEventListener('resize', () => drawChart(parseFloat(sliderYears.value) + parseFloat(sliderMonths.value) / 12));
  </script>

  <!-- Chart legend dot colors via inline style since CSS custom properties in pseudo-elements need this -->
  <style is:inline>
    .chart-legend span:nth-child(1)::before { background: var(--kitten); }
    .chart-legend span:nth-child(2)::before { background: var(--junior); }
    .chart-legend span:nth-child(3)::before { background: var(--prime); }
    .chart-legend span:nth-child(4)::before { background: var(--mature); }
    .chart-legend span:nth-child(5)::before { background: var(--senior); }
    .chart-legend span:nth-child(6)::before { background: var(--super-senior); }
  </style>
</SiteLayout>
