---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Peptide Reconstitution Calculator - Accurate Dosing & Safety Guide",
  description: "Professional peptide calculator for BPC-157, TB-500, semaglutide, tirzepatide. Calculate reconstitution, dosing, syringe units with safety protocols.",
  category: "tool",
  published: "2026-03-28",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "BodyCount",
      "url": "https://bodycount.photonbuilder.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "BodyCount",
      "logo": {
        "@type": "ImageObject",
        "url": "https://bodycount.photonbuilder.com/logo.png"
      }
    },
    "datePublished": meta.published,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/peptide-calculator"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I reconstitute peptides?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Remove vial cap, swab with alcohol, draw bacteriostatic water into syringe, inject water slowly down side of vial (don't spray directly on powder), gently swirl (never shake), then calculate concentration using peptide mg ÷ water mL = mg/mL."
        }
      },
      {
        "@type": "Question",
        "name": "How many units is 250mcg of BPC-157?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For a 5mg BPC-157 vial reconstituted with 2mL bacteriostatic water, 250mcg equals 10 units on a 100-unit insulin syringe. The calculation: 5mg = 5000mcg, 5000mcg ÷ 2mL = 2500mcg/mL, 250mcg ÷ 2500mcg/mL = 0.1mL = 10 units."
        }
      },
      {
        "@type": "Question",
        "name": "How much bacteriostatic water should I use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common ratios are 1-3mL bacteriostatic water per 5mg peptide vial. More water makes easier measurement but takes more storage space. Less water means higher concentration but smaller syringe measurements."
        }
      },
      {
        "@type": "Question",
        "name": "How long do reconstituted peptides last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Reconstituted peptides last 3-4 weeks when stored refrigerated (36-46°F) away from light. Never freeze reconstituted peptides. Lyophilized powder can be stored at room temperature before reconstitution."
        }
      },
      {
        "@type": "Question",
        "name": "What size syringe should I use for peptides?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Use insulin syringes: 0.3mL (30 units) for small doses, 0.5mL (50 units) for medium doses, 1mL (100 units) for larger doses. All use the same needle gauge (typically 29-31G) for comfortable subcutaneous injection."
        }
      },
      {
        "@type": "Question",
        "name": "What is the correct semaglutide dosing schedule?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standard semaglutide escalation: 0.25mg (weeks 1-4) → 0.5mg (weeks 5-8) → 1mg (weeks 9-12) → 1.7mg → 2.4mg weekly. Always start low and titrate up gradually to minimize side effects."
        }
      }
    ]
  }
];
---

<SiteLayout site="bodycount" title={meta.title} description={meta.description} canonical="https://bodycount.photonbuilder.com/peptide-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Peptide Reconstitution Calculator</h1>
      <p class="subtitle">Professional dosing calculator for research peptides with safety protocols</p>
    </div>

    <!-- Popular Peptide Presets -->
    <div class="presets-section">
      <h2>Popular Peptide Quick-Select</h2>
      <div class="preset-grid">
        <button class="preset-btn" data-preset='{"vial": 5, "water": 2, "dose": 250, "name": "BPC-157 (250mcg)"}'>
          <strong>BPC-157</strong>
          <span>5mg vial • 250mcg dose</span>
        </button>
        <button class="preset-btn" data-preset='{"vial": 5, "water": 2, "dose": 500, "name": "BPC-157 (500mcg)"}'>
          <strong>BPC-157</strong>
          <span>5mg vial • 500mcg dose</span>
        </button>
        <button class="preset-btn" data-preset='{"vial": 5, "water": 2, "dose": 2000, "name": "TB-500"}'>
          <strong>TB-500</strong>
          <span>5mg vial • 2mg dose</span>
        </button>
        <button class="preset-btn" data-preset='{"vial": 5, "water": 2, "dose": 250, "name": "Semaglutide"}'>
          <strong>Semaglutide</strong>
          <span>5mg vial • 0.25mg dose</span>
        </button>
        <button class="preset-btn" data-preset='{"vial": 10, "water": 4, "dose": 2500, "name": "Tirzepatide"}'>
          <strong>Tirzepatide</strong>
          <span>10mg vial • 2.5mg dose</span>
        </button>
        <button class="preset-btn" data-preset='{"vial": 2, "water": 2, "dose": 200, "name": "CJC-1295"}'>
          <strong>CJC-1295</strong>
          <span>2mg vial • 200mcg dose</span>
        </button>
        <button class="preset-btn" data-preset='{"vial": 50, "water": 5, "dose": 2000, "name": "GHK-Cu"}'>
          <strong>GHK-Cu</strong>
          <span>50mg vial • 2mg dose</span>
        </button>
        <button class="preset-btn" data-preset='{"vial": 10, "water": 2, "dose": 1000, "name": "PT-141"}'>
          <strong>PT-141</strong>
          <span>10mg vial • 1mg dose</span>
        </button>
      </div>
    </div>

    <!-- Calculator -->
    <div class="calculator-container">
      <h2>Reconstitution Calculator</h2>
      
      <div class="input-row">
        <div class="input-group">
          <label for="vial-size">Peptide Amount in Vial (mg)</label>
          <input type="number" id="vial-size" min="1" max="100" value="5" step="0.5" placeholder="e.g. 5">
          <span class="error-msg" id="vial-error">Enter a valid amount (1-100 mg)</span>
        </div>
        <div class="input-group">
          <label for="water-volume">Bacteriostatic Water Added (mL)</label>
          <input type="number" id="water-volume" min="0.5" max="10" value="2" step="0.1" placeholder="e.g. 2">
          <span class="error-msg" id="water-error">Enter a valid volume (0.5-10 mL)</span>
        </div>
      </div>

      <div class="input-row">
        <div class="input-group">
          <label for="dose-amount">Desired Dose per Injection (mcg)</label>
          <input type="number" id="dose-amount" min="1" max="50000" value="250" step="10" placeholder="e.g. 250">
          <span class="error-msg" id="dose-error">Enter a valid dose (1-50000 mcg)</span>
        </div>
        <div class="input-group">
          <label for="vial-cost">Vial Cost (optional)</label>
          <input type="number" id="vial-cost" min="0" max="1000" value="" step="0.01" placeholder="e.g. 45.00">
        </div>
      </div>

      <!-- Results -->
      <div class="results-section">
        <div class="main-result">
          <h3>Draw to this mark on insulin syringe:</h3>
          <div class="result-value">
            <span id="units-result">10</span>
            <span class="unit-label">Units</span>
          </div>
          <p class="volume-display">Volume: <span id="volume-result">0.1</span> mL</p>
        </div>

        <!-- Syringe Visual -->
        <div class="syringe-visual">
          <div class="syringe-container">
            <div class="syringe-barrel">
              <div class="syringe-plunger" id="syringe-plunger"></div>
              <div class="syringe-markings">
                <div class="marking" data-units="0">0</div>
                <div class="marking" data-units="10">10</div>
                <div class="marking" data-units="20">20</div>
                <div class="marking" data-units="30">30</div>
                <div class="marking" data-units="40">40</div>
                <div class="marking" data-units="50">50</div>
                <div class="marking" data-units="60">60</div>
                <div class="marking" data-units="70">70</div>
                <div class="marking" data-units="80">80</div>
                <div class="marking" data-units="90">90</div>
                <div class="marking" data-units="100">100</div>
              </div>
              <div class="syringe-liquid" id="syringe-liquid"></div>
            </div>
          </div>
          <p class="syringe-label">100-unit insulin syringe</p>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <h4>Concentration</h4>
            <span id="concentration-result">2,500</span>
            <small>mcg/mL</small>
          </div>
          <div class="stat-card">
            <h4>Doses per Vial</h4>
            <span id="doses-result">20</span>
            <small>doses</small>
          </div>
          <div class="stat-card">
            <h4>Cost per Dose</h4>
            <span id="cost-result">--</span>
            <small>if vial cost entered</small>
          </div>
        </div>
      </div>
    </div>

    <!-- How Peptide Reconstitution Works -->
    <section class="content-section">
      <h2>How Peptide Reconstitution Works</h2>
      <p>Peptide reconstitution transforms lyophilized (freeze-dried) powder into an injectable solution through a precise process that preserves peptide integrity while enabling accurate dosing.</p>
      
      <h3>Step-by-Step Reconstitution Process</h3>
      <ol>
        <li><strong>Prepare your workspace:</strong> Clean surface, alcohol swabs, sterile technique</li>
        <li><strong>Remove vial cap:</strong> Pop off the plastic cap and swab the rubber stopper with alcohol</li>
        <li><strong>Draw bacteriostatic water:</strong> Use a fresh insulin syringe to draw the calculated amount</li>
        <li><strong>Inject water slowly:</strong> Insert needle and inject water down the side of the vial—never spray directly onto the powder</li>
        <li><strong>Gentle mixing:</strong> Swirl the vial gently (never shake) until powder fully dissolves</li>
        <li><strong>Calculate concentration:</strong> Peptide mg ÷ water mL = mg/mL, then multiply by 1000 for mcg/mL</li>
        <li><strong>Store properly:</strong> Refrigerate immediately at 36-46°F, away from light</li>
      </ol>

      <div class="calculation-example">
        <h4>Example Calculation</h4>
        <p><strong>Scenario:</strong> 5mg BPC-157 vial + 2mL bacteriostatic water, targeting 250mcg dose</p>
        <ul>
          <li>Total peptide: 5mg × 1000 = 5,000mcg</li>
          <li>Concentration: 5,000mcg ÷ 2mL = 2,500mcg/mL</li>
          <li>Dose volume: 250mcg ÷ 2,500mcg/mL = 0.1mL</li>
          <li>Syringe units: 0.1mL × 100 = <strong>10 units</strong></li>
        </ul>
      </div>
    </section>

    <!-- Dosing Safety Guide -->
    <section class="content-section safety-section">
      <h2>Dosing Safety Guide</h2>
      <div class="safety-grid">
        <div class="safety-card">
          <h3>⚠️ Start Low, Titrate Up</h3>
          <p>Begin with the lowest effective dose and gradually increase. This minimizes side effects and allows your body to adapt. Monitor your response for at least one week before adjusting.</p>
        </div>
        <div class="safety-card">
          <h3>💉 Injection Technique</h3>
          <p><strong>Subcutaneous:</strong> Most peptides (belly, thigh, arm). <strong>Intramuscular:</strong> Rare cases only. Rotate injection sites to prevent lipodystrophy. Use 29-31G needles for comfort.</p>
        </div>
        <div class="safety-card">
          <h3>❄️ Storage Requirements</h3>
          <p>Reconstituted peptides last 3-4 weeks refrigerated (36-46°F). Never freeze liquid peptides. Store in original vial with rubber stopper. Protect from direct light.</p>
        </div>
        <div class="safety-card">
          <h3>🧼 Sterile Technique</h3>
          <p>Never reuse needles or syringes. Alcohol swab injection sites and vial tops. Use bacteriostatic water, not regular saline. Wash hands thoroughly before handling.</p>
        </div>
      </div>
      
      <div class="disclaimer">
        <p><strong>Research Disclaimer:</strong> This information is for research purposes only. Peptides discussed are research chemicals not approved for human consumption. Consult with a qualified healthcare provider before using any research peptides.</p>
      </div>
    </section>

    <!-- GLP-1 Dosing Chart -->
    <section class="content-section">
      <h2>GLP-1 Dosing Schedules</h2>
      <p>GLP-1 receptor agonists like semaglutide and tirzepatide require gradual dose escalation to minimize gastrointestinal side effects. Follow these evidence-based protocols:</p>
      
      <div class="dosing-charts">
        <div class="chart-card">
          <h3>Semaglutide Weekly Schedule</h3>
          <table class="dosing-table">
            <thead>
              <tr>
                <th>Weeks</th>
                <th>Dose</th>
                <th>Units (5mg/2mL)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>1-4</td>
                <td>0.25mg</td>
                <td>10 units</td>
              </tr>
              <tr>
                <td>5-8</td>
                <td>0.5mg</td>
                <td>20 units</td>
              </tr>
              <tr>
                <td>9-12</td>
                <td>1.0mg</td>
                <td>40 units</td>
              </tr>
              <tr>
                <td>13+</td>
                <td>1.7mg</td>
                <td>68 units</td>
              </tr>
              <tr>
                <td>Max</td>
                <td>2.4mg</td>
                <td>96 units</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="chart-card">
          <h3>Tirzepatide Weekly Schedule</h3>
          <table class="dosing-table">
            <thead>
              <tr>
                <th>Weeks</th>
                <th>Dose</th>
                <th>Units (10mg/4mL)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>1-4</td>
                <td>2.5mg</td>
                <td>100 units</td>
              </tr>
              <tr>
                <td>5-8</td>
                <td>5.0mg</td>
                <td>200 units (2 inj)</td>
              </tr>
              <tr>
                <td>9-12</td>
                <td>7.5mg</td>
                <td>300 units (3 inj)</td>
              </tr>
              <tr>
                <td>13-16</td>
                <td>10mg</td>
                <td>400 units (4 inj)</td>
              </tr>
              <tr>
                <td>17+</td>
                <td>12.5mg</td>
                <td>500 units (5 inj)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Unit Conversion Reference -->
    <section class="content-section">
      <h2>Unit Conversion Reference</h2>
      <div class="conversion-grid">
        <div class="conversion-card">
          <h3>Weight Conversions</h3>
          <ul>
            <li>1 mg = 1,000 mcg</li>
            <li>1 gram = 1,000 mg</li>
            <li>5 mg = 5,000 mcg</li>
            <li>10 mg = 10,000 mcg</li>
          </ul>
        </div>
        <div class="conversion-card">
          <h3>Volume Conversions</h3>
          <ul>
            <li>1 mL = 100 units (insulin syringe)</li>
            <li>0.1 mL = 10 units</li>
            <li>0.5 mL = 50 units</li>
            <li>1 mL = 1 cc</li>
          </ul>
        </div>
        <div class="conversion-card">
          <h3>Common Syringe Sizes</h3>
          <ul>
            <li>0.3 mL = 30 units max</li>
            <li>0.5 mL = 50 units max</li>
            <li>1.0 mL = 100 units max</li>
            <li>All use same needle gauge</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="content-section">
      <h2>Related Body Composition Tools</h2>
      <div class="tools-grid">
        <a href="/body-fat-calculator" class="tool-card">
          <h3>Body Fat Calculator</h3>
          <p>Accurate body composition analysis using multiple measurement methods</p>
        </a>
        <a href="/bmi-calculator" class="tool-card">
          <h3>BMI Calculator</h3>
          <p>Body mass index calculation with health risk assessment</p>
        </a>
        <a href="/calorie-calculator" class="tool-card">
          <h3>Daily Calorie Calculator</h3>
          <p>Determine your total daily energy expenditure and calorie needs</p>
        </a>
        <a href="/macro-calculator" class="tool-card">
          <h3>Macronutrient Calculator</h3>
          <p>Optimize protein, carbohydrate, and fat intake for your goals</p>
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>How do I reconstitute peptides?</summary>
        <p>Remove vial cap, swab with alcohol, draw bacteriostatic water into syringe, inject water slowly down side of vial (don't spray directly on powder), gently swirl (never shake), then calculate concentration using peptide mg ÷ water mL = mg/mL.</p>
      </details>

      <details>
        <summary>How many units is 250mcg of BPC-157?</summary>
        <p>For a 5mg BPC-157 vial reconstituted with 2mL bacteriostatic water, 250mcg equals 10 units on a 100-unit insulin syringe. The calculation: 5mg = 5000mcg, 5000mcg ÷ 2mL = 2500mcg/mL, 250mcg ÷ 2500mcg/mL = 0.1mL = 10 units.</p>
      </details>

      <details>
        <summary>How much bacteriostatic water should I use?</summary>
        <p>Common ratios are 1-3mL bacteriostatic water per 5mg peptide vial. More water makes easier measurement but takes more storage space. Less water means higher concentration but smaller syringe measurements.</p>
      </details>

      <details>
        <summary>How long do reconstituted peptides last?</summary>
        <p>Reconstituted peptides last 3-4 weeks when stored refrigerated (36-46°F) away from light. Never freeze reconstituted peptides. Lyophilized powder can be stored at room temperature before reconstitution.</p>
      </details>

      <details>
        <summary>What size syringe should I use for peptides?</summary>
        <p>Use insulin syringes: 0.3mL (30 units) for small doses, 0.5mL (50 units) for medium doses, 1mL (100 units) for larger doses. All use the same needle gauge (typically 29-31G) for comfortable subcutaneous injection.</p>
      </details>

      <details>
        <summary>What is the correct semaglutide dosing schedule?</summary>
        <p>Standard semaglutide escalation: 0.25mg (weeks 1-4) → 0.5mg (weeks 5-8) → 1mg (weeks 9-12) → 1.7mg → 2.4mg weekly. Always start low and titrate up gradually to minimize side effects.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = {
        vial: document.getElementById('vial-size'),
        water: document.getElementById('water-volume'),
        dose: document.getElementById('dose-amount'),
        cost: document.getElementById('vial-cost')
      };

      const errors = {
        vial: document.getElementById('vial-error'),
        water: document.getElementById('water-error'),
        dose: document.getElementById('dose-error')
      };

      const outputs = {
        units: document.getElementById('units-result'),
        volume: document.getElementById('volume-result'),
        concentration: document.getElementById('concentration-result'),
        doses: document.getElementById('doses-result'),
        cost: document.getElementById('cost-result')
      };

      const syringeElements = {
        plunger: document.getElementById('syringe-plunger'),
        liquid: document.getElementById('syringe-liquid')
      };

      // Preset button functionality
      document.querySelectorAll('.preset-btn').forEach(button => {
        button.addEventListener('click', () => {
          const preset = JSON.parse(button.dataset.preset);
          inputs.vial.value = preset.vial;
          inputs.water.value = preset.water;
          inputs.dose.value = preset.dose;
          inputs.cost.value = ''; // Clear cost on preset
          calculate();
          
          // Visual feedback
          document.querySelectorAll('.preset-btn').forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');
          setTimeout(() => button.classList.remove('active'), 200);
        });
      });

      function validateInputs() {
        let isValid = true;

        const vialVal = parseFloat(inputs.vial.value);
        if (isNaN(vialVal) || vialVal < 1 || vialVal > 100) {
          inputs.vial.classList.add('invalid');
          errors.vial.style.display = 'block';
          isValid = false;
        } else {
          inputs.vial.classList.remove('invalid');
          errors.vial.style.display = 'none';
        }

        const waterVal = parseFloat(inputs.water.value);
        if (isNaN(waterVal) || waterVal < 0.5 || waterVal > 10) {
          inputs.water.classList.add('invalid');
          errors.water.style.display = 'block';
          isValid = false;
        } else {
          inputs.water.classList.remove('invalid');
          errors.water.style.display = 'none';
        }

        const doseVal = parseFloat(inputs.dose.value);
        if (isNaN(doseVal) || doseVal < 1 || doseVal > 50000) {
          inputs.dose.classList.add('invalid');
          errors.dose.style.display = 'block';
          isValid = false;
        } else {
          inputs.dose.classList.remove('invalid');
          errors.dose.style.display = 'none';
        }

        return isValid;
      }

      function updateSyringeVisual(units) {
        if (units > 100) {
          syringeElements.liquid.style.height = '0%';
          syringeElements.plunger.style.bottom = '100%';
          return;
        }

        const percentage = Math.min(units / 100 * 100, 100);
        syringeElements.liquid.style.height = percentage + '%';
        syringeElements.plunger.style.bottom = (100 - percentage) + '%';
      }

      function calculate() {
        if (!validateInputs()) {
          outputs.units.textContent = '--';
          outputs.volume.textContent = '--';
          outputs.concentration.textContent = '--';
          outputs.doses.textContent = '--';
          outputs.cost.textContent = '--';
          updateSyringeVisual(0);
          return;
        }

        const vialMg = parseFloat(inputs.vial.value);
        const waterMl = parseFloat(inputs.water.value);
        const doseMcg = parseFloat(inputs.dose.value);
        const costValue = parseFloat(inputs.cost.value);

        // Convert mg to mcg
        const totalMcg = vialMg * 1000;

        // Concentration mcg per mL
        const concentration = totalMcg / waterMl;

        // Volume needed for desired dose
        const drawVolume = doseMcg / concentration;

        // Convert to insulin units (1mL = 100 units)
        const units = drawVolume * 100;

        // Total doses per vial
        const dosesPerVial = Math.floor(totalMcg / doseMcg);

        // Cost per dose
        let costPerDose = '--';
        if (!isNaN(costValue) && costValue > 0) {
          costPerDose = '$' + (costValue / dosesPerVial).toFixed(2);
        }

        const formatNum = (num, decimals = 1) => {
          if (Number.isInteger(num)) {
            return num.toLocaleString('en-US');
          }
          return num.toLocaleString('en-US', { maximumFractionDigits: decimals, minimumFractionDigits: decimals });
        };

        // Update outputs
        if (units > 100) {
          outputs.units.textContent = 'ERROR';
          outputs.units.style.color = '#E05A5A';
        } else {
          outputs.units.textContent = formatNum(units, 1);
          outputs.units.style.color = '#E05A5A';
        }

        outputs.volume.textContent = formatNum(drawVolume, 3);
        outputs.concentration.textContent = formatNum(concentration, 0);
        outputs.doses.textContent = dosesPerVial;
        outputs.cost.textContent = costPerDose;

        // Update syringe visual
        updateSyringeVisual(units);
      }

      // Attach event listeners
      Object.values(inputs).forEach(input => {
        input.addEventListener('input', calculate);
        input.addEventListener('change', calculate);
      });

      // Initial calculation
      calculate();
    });
  </script>

  <style>
    * { box-sizing: border-box; }
    
    .page-content { 
      max-width: 1000px; 
      margin: 0 auto; 
      padding: 2rem 1.5rem; 
      background: #060a12;
      color: #ffffff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .hero { 
      text-align: center; 
      padding: 3rem 0 2rem; 
    }
    .hero h1 { 
      font-size: 2.5rem; 
      font-weight: 800; 
      margin-bottom: 0.5rem;
      color: #ffffff;
    }
    .subtitle { 
      color: #a0a8b8; 
