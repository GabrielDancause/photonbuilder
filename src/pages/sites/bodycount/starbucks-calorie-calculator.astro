---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Starbucks Calorie Calculator | Custom Drink Nutrition",
  description: "Find out exactly how many calories are in your custom Starbucks order. Calculate the impact of extra pumps, different milks, and toppings before you sip.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How accurate is this Starbucks calorie calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This calculator is based on official Starbucks nutritional information and standard recipe guidelines. However, since each drink is handcrafted by a barista, actual calories may vary slightly depending on the exact pour and preparation."
          }
        },
        {
          "@type": "Question",
          "name": "How many calories are in one pump of Starbucks syrup?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most standard Starbucks syrups (like Vanilla, Caramel, Classic) contain approximately 20 calories and 5 grams of sugar per pump. Sugar-free syrups contain 0 calories per pump. Sauces like Mocha and White Mocha are higher, ranging from 35 to 60 calories per pump."
          }
        },
        {
          "@type": "Question",
          "name": "What is the lowest calorie milk at Starbucks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Almond milk is currently the lowest calorie milk option at Starbucks, with approximately 60 calories per cup (8 fl oz). Nonfat (skim) milk is the next lowest, followed by soy milk and oat milk."
          }
        },
        {
          "@type": "Question",
          "name": "How many calories does sweet cream cold foam add?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A standard serving of Vanilla Sweet Cream Cold Foam adds approximately 110 calories, largely from heavy cream and vanilla syrup. Modifying the foam or requesting a lighter amount will change the caloric impact."
          }
        },
        {
          "@type": "Question",
          "name": "Are there hidden calories in Starbucks iced coffees and teas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, many standard iced coffee and iced tea orders at Starbucks are sweetened by default with 'Classic' syrup. Unless you specify 'unsweetened' or 'no classic', a standard Grande iced coffee includes 4 pumps of syrup (about 80 calories)."
          }
        }
      ]
    },
    {
      "@type": "SoftwareApplication",
      "name": "Starbucks Calorie Calculator",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Any",
      "description": "Calculate calories for custom Starbucks drinks based on milk choice, syrups, and toppings."
    },
    {
      "@type": "Article",
      "headline": "Starbucks Calorie Calculator & Nutritional Guide",
      "description": "Find out exactly how many calories are in your custom Starbucks order. Calculate the impact of extra pumps, different milks, and toppings before you sip.",
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      }
    }
  ]
};
---

<SiteLayout site="bodycount" title={meta.title} description={meta.description} canonical="https://bodycount.photonbuilder.com/starbucks-calorie-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Starbucks Calorie Calculator</h1>
      <p class="subtitle">Customize your drink and calculate the exact nutritional breakdown before you order.</p>
    </div>

    <div class="calculator-container">
      <div class="form-grid">
        <div class="input-group">
          <label for="baseDrink">Base Drink Category</label>
          <select id="baseDrink">
            <option value="coffee">Brewed Coffee / Americano (5 cal)</option>
            <option value="latte">Latte / Macchiato / Cappuccino (base 0 cal, add milk)</option>
            <option value="coldbrew">Cold Brew / Iced Coffee (base 5 cal)</option>
            <option value="frappuccino">Frappuccino (base ~120 cal, add milk/syrup)</option>
            <option value="tea">Iced / Hot Tea (0 cal)</option>
            <option value="refresher">Refreshers (base 50 cal)</option>
          </select>
        </div>
        <div class="input-group">
          <label for="size">Drink Size</label>
          <select id="size">
            <option value="short">Short (8 oz)</option>
            <option value="tall">Tall (12 oz)</option>
            <option value="grande" selected>Grande (16 oz)</option>
            <option value="venti_hot">Venti Hot (20 oz)</option>
            <option value="venti_iced">Venti Iced (24 oz)</option>
            <option value="trenta">Trenta (30 oz - Iced Only)</option>
          </select>
        </div>

        <div class="input-group">
          <label for="milkType">Milk Selection</label>
          <select id="milkType">
            <option value="none">No Milk</option>
            <option value="splash">Splash of Milk (~1-2 oz)</option>
            <option value="nonfat">Nonfat (Skim) Milk</option>
            <option value="twoPercent" selected>2% Milk (Default)</option>
            <option value="whole">Whole Milk</option>
            <option value="breve">Breve (Half & Half)</option>
            <option value="heavyCream">Heavy Cream</option>
            <option value="almond">Almond Milk</option>
            <option value="soy">Soy Milk</option>
            <option value="oat">Oat Milk</option>
            <option value="coconut">Coconut Milk</option>
          </select>
        </div>
        <div class="input-group">
          <label for="syrupStandard">Standard Syrups (Pumps)</label>
          <div class="input-wrapper">
            <input type="number" id="syrupStandard" min="0" max="20" value="0">
            <span class="suffix">pumps</span>
          </div>
          <small style="color:var(--text-secondary); font-size:0.8rem;">Vanilla, Caramel, Classic, Hazelnut, etc. (20 cal/pump)</small>
        </div>

        <div class="input-group">
          <label for="syrupSauce">Thick Sauces (Pumps)</label>
          <div class="input-wrapper">
            <input type="number" id="syrupSauce" min="0" max="20" value="0">
            <span class="suffix">pumps</span>
          </div>
          <small style="color:var(--text-secondary); font-size:0.8rem;">Mocha, White Mocha, Pumpkin, Pistachio (50-60 cal/pump)</small>
        </div>
        <div class="input-group">
          <label for="syrupSF">Sugar-Free Syrups (Pumps)</label>
          <div class="input-wrapper">
            <input type="number" id="syrupSF" min="0" max="20" value="0">
            <span class="suffix">pumps</span>
          </div>
          <small style="color:var(--text-secondary); font-size:0.8rem;">SF Vanilla (0 cal/pump)</small>
        </div>

        <div class="input-group">
          <label for="coldFoam">Cold Foam / Toppings</label>
          <select id="coldFoam">
            <option value="none">None</option>
            <option value="vsccf">Vanilla Sweet Cream Cold Foam</option>
            <option value="cf_nonfat">Regular Cold Foam (Nonfat)</option>
            <option value="whip">Whipped Cream</option>
            <option value="drizzle">Caramel/Mocha Drizzle</option>
            <option value="matcha">Matcha Powder (per scoop)</option>
            <option value="fruit">Fruit Inclusions (Refreshers)</option>
          </select>
        </div>
        <div class="input-group" id="scoopContainer" style="display: none;">
          <label for="scoops">Scoops / Extra Drizzle</label>
          <div class="input-wrapper">
            <input type="number" id="scoops" min="1" max="10" value="1">
            <span class="suffix">qty</span>
          </div>
        </div>
      </div>

      <div class="results-panel">
        <div class="total-label">Estimated Total Calories</div>
        <div class="total-calories" id="resultTotalCalories">0</div>

        <div class="macros-grid">
          <div class="macro-card">
            <div class="macro-label">Carbs / Sugar</div>
            <div class="macro-value" id="resultCarbs">0g</div>
          </div>
          <div class="macro-card">
            <div class="macro-label">Fat</div>
            <div class="macro-value" id="resultFat">0g</div>
          </div>
          <div class="macro-card">
            <div class="macro-label">Protein</div>
            <div class="macro-value" id="resultProtein">0g</div>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>How the Starbucks Calorie Calculator Works</h2>
      <p>Starbucks menus often display a calorie range or standard formulation, but customizing a drink—whether it's swapping milk, adding extra pumps of syrup, or topping it with cold foam—drastically changes the nutritional profile. This calculator uses standardized nutritional data derived from Starbucks' official nutrition disclosures to dynamically calculate the macro and caloric impact of your specific customizations.</p>

      <h3>The Core Components of a Drink</h3>
      <p>Calculating the calories of a custom Starbucks beverage involves breaking the drink down into its fundamental building blocks: the base, the milk volume, the sweeteners, and the toppings. Each component carries a specific nutritional weight that must be added together.</p>

      <ul>
        <li><strong>Base Liquid:</strong> Black coffee, Americanos, and plain teas contribute negligible calories (typically 0-5 calories). However, bases like Frappuccino roast, Refresher bases, and Lemonade contain intrinsic sugars and calories that scale with cup size.</li>
        <li><strong>Milk Volume:</strong> In milk-based drinks (lattes, cappuccinos, macchiatos), milk constitutes the vast majority of the volume. We calculate the required milk volume by subtracting espresso shot volume (approx. 1 oz per shot) and syrup volume from the total cup size.</li>
        <li><strong>Sweeteners (Pumps):</strong> Starbucks utilizes standard syrup pumps and sauce pumps. A standard flavor syrup pump (e.g., Vanilla, Caramel) adds roughly 20 calories. A thick sauce pump (e.g., Mocha, White Mocha) adds roughly 50-60 calories.</li>
        <li><strong>Toppings & Add-ins:</strong> Whipped cream and cold foams add significant calories. A standard dollop of whipped cream on a Grande drink adds 80-110 calories. Vanilla Sweet Cream Cold Foam adds roughly 110 calories.</li>
      </ul>

      <h3>Methodology & Mathematical Formulas</h3>
      <p>The total caloric value is calculated using a dynamic summation equation where each variable is scaled according to the selected cup size and requested quantities.</p>
      <p>The primary formula is: <br>
      <code>Total Calories = Base Calories + (Milk Cal/Oz &times; Milk Volume Oz) + (Syrup Cal/Pump &times; Pumps) + Topping Calories</code></p>

      <h4>Estimating Milk Volume</h4>
      <p>To accurately calculate calories from milk, we must estimate the fluid ounces of milk in the cup. This is derived from the total cup capacity minus other ingredients:</p>
      <ul>
        <li><strong>Short:</strong> 8 oz capacity. Approx. 6 oz milk.</li>
        <li><strong>Tall:</strong> 12 oz capacity. Approx. 9 oz milk.</li>
        <li><strong>Grande:</strong> 16 oz capacity. Approx. 13 oz milk.</li>
        <li><strong>Venti (Hot):</strong> 20 oz capacity. Approx. 16 oz milk.</li>
        <li><strong>Venti (Iced):</strong> 24 oz capacity (accounts for ice). Approx. 14 oz milk.</li>
        <li><strong>Trenta:</strong> 30 oz capacity. Only available for iced teas, coffees, and refreshers.</li>
      </ul>
      <p>If the user selects "Splash of Milk", the calculator assumes a standardized 1.5 oz addition regardless of cup size.</p>

      <h4>Milk Nutritional Density (per Fluid Ounce)</h4>
      <p>The calculator applies the following standard caloric densities per fluid ounce of milk:</p>
      <ul>
        <li><strong>Nonfat (Skim) Milk:</strong> ~11 cal/oz | 1.5g carbs | 0g fat | 1g protein</li>
        <li><strong>2% Milk (Standard):</strong> ~16.25 cal/oz | 1.5g carbs | 0.6g fat | 1g protein</li>
        <li><strong>Whole Milk:</strong> ~19 cal/oz | 1.5g carbs | 1g fat | 1g protein</li>
        <li><strong>Breve (Half & Half):</strong> ~39 cal/oz | 1g carbs | 3.5g fat | 1g protein</li>
        <li><strong>Heavy Cream:</strong> ~100 cal/oz | 1g carbs | 11g fat | 1g protein</li>
        <li><strong>Almond Milk:</strong> ~7.5 cal/oz | 0.5g carbs | 0.5g fat | 0.2g protein</li>
        <li><strong>Soy Milk:</strong> ~16.25 cal/oz | 1.5g carbs | 0.5g fat | 0.8g protein</li>
        <li><strong>Oat Milk:</strong> ~17.5 cal/oz | 2g carbs | 0.8g fat | 0.2g protein</li>
        <li><strong>Coconut Milk:</strong> ~10 cal/oz | 1g carbs | 1g fat | 0.1g protein</li>
      </ul>

      <h4>Syrups and Sauces</h4>
      <p>Starbucks syrups are dispensed via pumps. The volume of a pump varies slightly between hot and iced bars, but for nutritional calculation, standard averages are used:</p>
      <ul>
        <li><strong>Standard Syrups:</strong> 20 calories, 5g sugar, 0g fat, 0g protein per pump. (Includes Vanilla, Caramel, Hazelnut, Classic, Peppermint, Toffeenut, Cinnamon Dolce, Brown Sugar).</li>
        <li><strong>Thick Sauces:</strong> 50-60 calories, 6-7g sugar, 1-2g fat per pump. (Includes Mocha, White Chocolate Mocha, Pumpkin Spice, Pistachio, Caramel Brulee).</li>
        <li><strong>Sugar-Free Syrups:</strong> 0 calories. (Presently only Sugar-Free Vanilla is universally available).</li>
      </ul>

      <h3>Handling Frappuccinos and Complex Drinks</h3>
      <p>Frappuccinos introduce a distinct challenge due to the 'Frappuccino Roast' base and the 'Creme/Coffee Syrup Base' required for blending. A Grande Frappuccino inherently contains about 120 calories just from the base syrups before adding milk, flavor syrups, or whipped cream. The calculator adds this baseline automatically when the Frappuccino category is selected.</p>
      <p>Similarly, Starbucks Refreshers contain a base made with fruit juice and green coffee extract. A Grande Refresher base (made with water) is roughly 50 calories. If made with Lemonade or Coconut milk (Pink Drink), those respective volumes and caloric densities are added to the baseline.</p>

      <h3>The Impact of Ice and Temperature</h3>
      <p>One of the most significant yet frequently overlooked factors in Starbucks beverage nutrition is the temperature of the drink. Hot beverages generally have a higher caloric density for the same cup size because the entire volume is filled with milk, water, or base liquid. In contrast, iced beverages feature a large volume of ice, which displaces the liquid and therefore reduces the total calories—assuming you do not ask for "light ice." When you request light ice, the barista typically fills the remaining space with extra milk or base, which can inadvertently increase the total calories of your drink by up to 20% depending on the milk chosen.</p>

      <h3>Understanding Espresso Variations</h3>
      <p>While espresso shots themselves contribute very few calories (roughly 5 calories per standard shot), the way the shot is pulled can affect the overall drink profile, especially if you modify the milk to compensate. Starbucks offers standard shots, ristretto shots (shorter, sweeter, less volume), and long shots (larger volume, more bitter). Because a ristretto shot has less liquid volume, a milk-based drink made with ristretto shots will require marginally more milk to fill the cup to the brim, theoretically increasing the calorie count by a fraction, though this difference is often negligible for standard tracking.</p>

      <h3>Seasonal Syrups and Limited-Time Offerings</h3>
      <p>Throughout the year, Starbucks releases seasonal syrups and sauces—such as Pumpkin Spice in the fall or Peppermint Mocha and Caramel Brulée in the winter. These specialty sauces are often denser and richer than standard year-round syrups. A pump of Pumpkin Spice sauce, for example, can contain up to 50 calories and significant sugar and dairy, unlike the clear, standard syrups. When tracking seasonal drinks, it is crucial to use the 'Thick Sauces' input in this calculator to ensure you are capturing the correct nutritional density.</p>

      <h3>The Reality of Sugar-Free Options</h3>
      <p>Starbucks currently offers limited sugar-free options, primarily Sugar-Free Vanilla syrup. While this syrup contributes zero calories and zero grams of sugar, it is sweetened with sucralose. For those tracking macros strictly for medical reasons or deep ketosis, it is important to remember that zero calories do not always mean zero metabolic impact. Additionally, many customers mistakenly believe that 'Skinny' drinks or those made with sugar-free syrup are entirely calorie-free. However, if that drink is made with milk—even nonfat or almond milk—the milk itself will still contribute carbohydrates and calories to the final profile.</p>

      <h3>Milk Alternatives and Calorie Traps</h3>
      <p>As dairy-free lifestyles become more popular, Starbucks has expanded its alternative milk roster to include almond, soy, oat, and coconut milk. While almond milk remains the lowest-calorie option, oat milk has surged in popularity due to its creamy texture, which closely mimics dairy. However, oat milk is significantly more calorically dense than almond milk and contains more carbohydrates. Furthermore, many customers do not realize that Starbucks' soy milk is sweetened with vanilla flavor, adding hidden sugars to an otherwise savory or plain beverage. Understanding these nuances is critical for accurate macro tracking.</p>

      <p><em>Disclaimer: This tool provides estimations based on public nutritional data. Starbucks beverages are handcrafted and exact calorie counts will vary based on ice volume, pour precision, and local market ingredient sourcing.</em></p>

      <div class="cross-link-box" style="margin-top: 3rem; padding: 1.5rem; background: var(--card-bg); border-left: 4px solid var(--accent-color); border-radius: 4px;">
        <h4 style="margin-top: 0; color: var(--text-primary);">Planning a major life event?</h4>
        <p style="margin-bottom: 0;">If you're balancing your macros to look your best for your big day, don't forget to balance your finances too. Consider using an interactive wedding budget planner to intelligently allocate your wedding expenses.</p>
      </div>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How accurate is this Starbucks calorie calculator?</summary>
        <p>This calculator is based on official Starbucks nutritional information and standard recipe guidelines. However, since each drink is handcrafted by a barista, actual calories may vary slightly depending on the exact pour, the amount of ice used, and the specific pumps. It provides a highly accurate estimate rather than an exact laboratory measurement.</p>
      </details>
      <details>
        <summary>How many calories are in one pump of Starbucks syrup?</summary>
        <p>Most standard Starbucks syrups (like Vanilla, Caramel, Classic, and Brown Sugar) contain approximately 20 calories and 5 grams of sugar per pump. Sugar-free syrups contain 0 calories per pump. Sauces like Mocha and White Mocha are much higher, ranging from 35 to 60 calories per pump depending on the specific sauce.</p>
      </details>
      <details>
        <summary>What is the lowest calorie milk at Starbucks?</summary>
        <p>Almond milk is currently the lowest calorie milk option at Starbucks, with approximately 60 calories per cup (8 fl oz), which translates to about 7.5 calories per ounce. Nonfat (skim) milk and Coconut milk are the next lowest, followed by soy milk and oat milk. Heavy cream and Breve (half and half) are the highest calorie options.</p>
      </details>
      <details>
        <summary>How many calories does sweet cream cold foam add?</summary>
        <p>A standard serving of Vanilla Sweet Cream Cold Foam adds approximately 110-120 calories, largely from the heavy cream and vanilla syrup used to make it. Modifying the foam (such as asking for nonfat cold foam) or requesting a lighter amount will change the caloric impact.</p>
      </details>
      <details>
        <summary>Are there hidden calories in Starbucks iced coffees and teas?</summary>
        <p>Yes, many standard iced coffee and iced tea orders at Starbucks are sweetened by default with 'Classic' syrup or Liquid Cane Sugar. Unless you specify 'unsweetened', a standard Grande iced coffee includes 4 pumps of syrup, adding roughly 80 calories to a drink you might expect to be zero calories.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = {
        baseDrink: document.getElementById('baseDrink'),
        size: document.getElementById('size'),
        milkType: document.getElementById('milkType'),
        syrupStandard: document.getElementById('syrupStandard'),
        syrupSauce: document.getElementById('syrupSauce'),
        syrupSF: document.getElementById('syrupSF'),
        coldFoam: document.getElementById('coldFoam'),
        scoops: document.getElementById('scoops')
      };

      const scoopContainer = document.getElementById('scoopContainer');

      // Nutritional densities per oz for milks
      const milkNutrition = {
        none: { cal: 0, carbs: 0, fat: 0, protein: 0 },
        nonfat: { cal: 11, carbs: 1.5, fat: 0, protein: 1 },
        twoPercent: { cal: 16.25, carbs: 1.5, fat: 0.6, protein: 1 },
        whole: { cal: 19, carbs: 1.5, fat: 1, protein: 1 },
        breve: { cal: 39, carbs: 1, fat: 3.5, protein: 1 },
        heavyCream: { cal: 100, carbs: 1, fat: 11, protein: 1 },
        almond: { cal: 7.5, carbs: 0.5, fat: 0.5, protein: 0.2 },
        soy: { cal: 16.25, carbs: 1.5, fat: 0.5, protein: 0.8 },
        oat: { cal: 17.5, carbs: 2, fat: 0.8, protein: 0.2 },
        coconut: { cal: 10, carbs: 1, fat: 1, protein: 0.1 }
      };

      // Milk volume estimation based on drink size
      const milkVolumes = {
        short: 6,
        tall: 9,
        grande: 13,
        venti_hot: 16,
        venti_iced: 14,
        trenta: 18 // Limited to iced drinks
      };

      // Base drink inherent calories (before milk/custom syrup)
      const baseNutrition = {
        coffee: { short: 5, tall: 5, grande: 5, venti_hot: 5, venti_iced: 5, trenta: 5 },
        latte: { short: 0, tall: 0, grande: 0, venti_hot: 0, venti_iced: 0, trenta: 0 },
        coldbrew: { short: 5, tall: 5, grande: 5, venti_hot: 5, venti_iced: 5, trenta: 5 },
        frappuccino: { short: 90, tall: 90, grande: 120, venti_hot: 150, venti_iced: 150, trenta: 150 }, // Base frappe roast/syrup
        tea: { short: 0, tall: 0, grande: 0, venti_hot: 0, venti_iced: 0, trenta: 0 },
        refresher: { short: 40, tall: 40, grande: 50, venti_hot: 70, venti_iced: 70, trenta: 90 }
      };

      // Topping/Foam nutrition per serving
      const toppingNutrition = {
        none: { cal: 0, carbs: 0, fat: 0, protein: 0 },
        vsccf: { cal: 110, carbs: 10, fat: 7, protein: 1 },
        cf_nonfat: { cal: 35, carbs: 5, fat: 0, protein: 3 },
        whip: { cal: 110, carbs: 2, fat: 11, protein: 1 },
        drizzle: { cal: 15, carbs: 3, fat: 0, protein: 0 }, // per scoop/pump equivalent
        matcha: { cal: 25, carbs: 6, fat: 0, protein: 0 }, // per scoop
        fruit: { cal: 10, carbs: 2, fat: 0, protein: 0 } // per scoop
      };

      function calculateNutrition() {
        const base = inputs.baseDrink.value;
        const size = inputs.size.value;
        const milkType = inputs.milkType.value;

        // Input validation and error states
        let hasError = false;
        const validateInput = (inputEl) => {
          const val = parseInt(inputEl.value);
          if (val < 0) {
            inputEl.style.borderColor = 'red';
            hasError = true;
            return 0;
          } else {
            inputEl.style.borderColor = 'var(--border-color)';
            return isNaN(val) ? 0 : val;
          }
        };

        const standardPumps = validateInput(inputs.syrupStandard);
        const saucePumps = validateInput(inputs.syrupSauce);
        const sfPumps = validateInput(inputs.syrupSF);
        const toppingQty = validateInput(inputs.scoops);

        const errorMsgEl = document.getElementById('calc-error-msg');
        if (hasError) {
          if (!errorMsgEl) {
            const msg = document.createElement('div');
            msg.id = 'calc-error-msg';
            msg.style.color = 'red';
            msg.style.fontSize = '0.9rem';
            msg.style.marginTop = '1rem';
            msg.textContent = 'Please enter valid non-negative numbers.';
            document.querySelector('.form-grid').appendChild(msg);
          }
        } else if (errorMsgEl) {
          errorMsgEl.remove();
        }

        const topping = inputs.coldFoam.value;

        let totalCal = 0;
        let totalCarbs = 0;
        let totalFat = 0;
        let totalProtein = 0;

        // 1. Add Base
        const baseCals = baseNutrition[base][size] || 0;
        totalCal += baseCals;
        totalCarbs += (base === 'frappuccino' || base === 'refresher') ? (baseCals / 4) : 0; // rough estimate for sugary bases

        // 2. Add Milk
        if (milkType !== 'none') {
          let oz = milkVolumes[size] || 13;

          if (milkType === 'splash') {
            oz = 1.5; // Standard splash
            const defaultMilk = milkNutrition['twoPercent']; // Assume splash of 2% default
            totalCal += defaultMilk.cal * oz;
            totalCarbs += defaultMilk.carbs * oz;
            totalFat += defaultMilk.fat * oz;
            totalProtein += defaultMilk.protein * oz;
          } else if (milkNutrition[milkType]) {
            // Adjust volume down slightly if base is coffee/coldbrew/tea and milk is added,
            // as it typically displaces base. For lattes, milk is the bulk.
            if (base === 'coffee' || base === 'coldbrew' || base === 'tea' || base === 'refresher') {
               // if they selected a specific milk for a coffee, they usually mean replacing water/base with milk, or making it a latte.
               // For this calc, we assume a latte build if they select milk for a coffee base.
               // To keep it simple, we use full milk volume.
            }

            const milk = milkNutrition[milkType];
            totalCal += milk.cal * oz;
            totalCarbs += milk.carbs * oz;
            totalFat += milk.fat * oz;
            totalProtein += milk.protein * oz;
          }
        }

        // 3. Add Syrups
        // Standard (20 cal, 5g sugar)
        totalCal += standardPumps * 20;
        totalCarbs += standardPumps * 5;

        // Sauce (55 cal, 7g sugar, 1.5g fat)
        totalCal += saucePumps * 55;
        totalCarbs += saucePumps * 7;
        totalFat += saucePumps * 1.5;

        // SF (0 cal, 0g sugar, some carbs from sugar alcohols but we simplify to 0 for standard tracking)
        // 0 cal added

        // 4. Add Toppings
        if (topping !== 'none' && toppingNutrition[topping]) {
          const topStats = toppingNutrition[topping];
          let multiplier = 1;

          // Multiply drizzle, matcha, fruit by scoop input
          if (topping === 'drizzle' || topping === 'matcha' || topping === 'fruit') {
            multiplier = toppingQty;
          }

          totalCal += topStats.cal * multiplier;
          totalCarbs += topStats.carbs * multiplier;
          totalFat += topStats.fat * multiplier;
          totalProtein += topStats.protein * multiplier;
        }

        // Update UI
        document.getElementById('resultTotalCalories').textContent = Math.round(totalCal);
        document.getElementById('resultCarbs').textContent = Math.round(totalCarbs) + 'g';
        document.getElementById('resultFat').textContent = Math.round(totalFat) + 'g';
        document.getElementById('resultProtein').textContent = Math.round(totalProtein) + 'g';
      }

      function handleToppingChange() {
        const topping = inputs.coldFoam.value;
        if (topping === 'drizzle' || topping === 'matcha' || topping === 'fruit') {
          scoopContainer.style.display = 'block';
        } else {
          scoopContainer.style.display = 'none';
          inputs.scoops.value = 1;
        }
        calculateNutrition();
      }

      // Add event listeners
      Object.values(inputs).forEach(input => {
        if(input) input.addEventListener('input', calculateNutrition);
      });

      inputs.coldFoam.addEventListener('change', handleToppingChange);

      // Initial calculation
      calculateNutrition();
    });
  </script>

