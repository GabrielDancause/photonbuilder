---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Chipotle Nutrition Calculator: Build Your Custom Bowl",
  description: "Want to hit your exact macro targets? Use our interactive Chipotle nutrition calculator to instantly count calories, protein, carbs, and fats for your...",
  category: "tool",
  published: "2025-08-16"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How accurate is this Chipotle nutrition calculator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This calculator uses the standard nutritional data published by Chipotle for standard portion sizes. However, actual portions may vary slightly depending on the person serving you."
        }
      },
      {
        "@type": "Question",
        "name": "Does adding double meat double the calories?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, selecting double portions for protein or rice will multiply the standard serving calories, protein, carbs, and fats by two."
        }
      },
      {
        "@type": "Question",
        "name": "What is the highest calorie item at Chipotle?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The flour tortilla used for burritos is one of the highest calorie single items, coming in at 320 calories and 50g of carbs before any fillings are added."
        }
      },
      {
        "@type": "Question",
        "name": "Can I calculate macronutrients for a keto diet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. By selecting a bowl and avoiding high-carb ingredients like rice, beans, and tortillas, you can use our calculator to ensure your meal fits your exact keto macros."
        }
      },
      {
        "@type": "Question",
        "name": "Why do some ingredients have 0 calories?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ingredients like lettuce or certain light salsas contain negligible calories per standard serving size, making them excellent choices for low-calorie volume eating."
        }
      }
    ]
  }
];
---
<SiteLayout site="bodycount" title={meta.title} description={meta.description} canonical="https://bodycount.photonbuilder.com/chipotle-nutrition-calculator" schema={schema}>
