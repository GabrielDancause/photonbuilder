---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const waterNeeds = [
  { fact: "The 8 Glasses Myth", description: "The advice to drink eight 8-ounce glasses of water a day is a simplified rule of thumb, not a rigid scientific mandate. Your actual needs depend on body size, activity level, climate, and diet." },
  { fact: "Individual Needs", description: "A better baseline is to drink half your body weight in ounces daily, but adjust upward significantly for exercise and heat." }
];

const sweatRate = [
  { step: "Step 1: Weigh Yourself", description: "Weigh yourself without clothes right before a workout." },
  { step: "Step 2: Exercise", description: "Perform exactly one hour of exercise at your typical intensity. Keep track of how much fluid (in ounces) you drink during this time." },
  { step: "Step 3: Weigh Again", description: "Weigh yourself again after the workout, without clothes, and after toweling off any sweat." },
  { step: "Step 4: Calculate", description: "Subtract your post-workout weight from your pre-workout weight. Convert the pounds lost to ounces (1 lb = 16 oz). Add the fluid ounces you drank during the workout. This total is your hourly sweat rate." }
];

const electrolytes = [
  { nutrient: "Sodium", role: "The primary electrolyte lost in sweat. Crucial for fluid balance, nerve signaling, and muscle contraction. Prevents hyponatremia." },
  { nutrient: "Potassium", role: "Works with sodium to maintain cellular fluid balance. Essential for muscle function and preventing cramps." },
  { nutrient: "Magnesium", role: "Supports muscle relaxation and energy production. Helps prevent muscle cramps and spasms." }
];

const drinkComparison = [
  { type: "Water", pros: "Perfect for everyday hydration and light exercise under 60 minutes. Zero calories or additives.", cons: "Lacks electrolytes, making it insufficient for heavy sweaters or prolonged endurance exercise." },
  { type: "Sports Drinks (e.g., Gatorade)", pros: "Provides quick carbohydrates for energy and basic electrolytes.", cons: "Often high in added sugars and artificial colors. Sometimes lacks adequate sodium for heavy sweaters." },
  { type: "Electrolyte Tablets/Powders", pros: "High, customizable electrolyte content with minimal or no sugar. Great for tailored hydration plans.", cons: "Can be expensive. Doesn't provide carbohydrates for energy during long workouts." }
];

const sportsHydration = [
  { sport: "Endurance (Running/Cycling)", focus: "High fluid and sodium turnover. Requires consistent fluid intake and carbohydrate-electrolyte solutions for sessions over 60-90 minutes." },
  { sport: "Strength Training", focus: "Moderate fluid needs. Water is usually sufficient, but electrolytes can help if training in a hot environment or for prolonged sessions." },
  { sport: "Team Sports (Soccer/Basketball)", focus: "Variable intensity with limited drinking opportunities. Pre-hydration is critical, followed by taking advantage of breaks to replenish." }
];

const hydrationSigns = [
  { state: "Dehydration", symptoms: "Thirst, dark yellow urine, dry mouth, headache, fatigue, muscle cramps, dizziness." },
  { state: "Overhydration (Hyponatremia)", symptoms: "Clear urine, nausea, vomiting, headache, confusion, muscle weakness, seizures in severe cases." }
];

const caffeineAlcohol = [
  { topic: "Caffeine Myth", details: "While caffeine has a mild diuretic effect, caffeinated beverages like coffee and tea still contribute to your daily fluid intake. Moderate consumption does not lead to dehydration." },
  { topic: "Alcohol Dehydration", details: "Alcohol is a strong diuretic that suppresses the antidiuretic hormone (ADH), leading to increased urination and significant fluid loss. It is heavily dehydrating." }
];

const supplements = [
  { brand: "LMNT", features: "High sodium (1000mg per packet), zero sugar, great for low-carb diets and heavy sweaters." },
  { brand: "Liquid I.V.", features: "Uses Cellular Transport Technology (sugar and sodium) to accelerate water absorption. Contains 500mg sodium and added vitamins." },
  { brand: "Nuun", features: "Effervescent tablets with a lighter flavor profile and moderate electrolytes (300mg sodium). Very convenient for on-the-go." }
];

const protocol = [
  { phase: "Pre-Workout", strategy: "Drink 16-24 oz of fluid with some sodium 2 hours before exercise. Check urine color to ensure it's pale yellow." },
  { phase: "During Workout", strategy: "Drink 4-8 oz every 15-20 minutes. If exercising over 60 minutes or heavily sweating, include electrolytes and potentially carbohydrates." },
  { phase: "Post-Workout", strategy: "Drink 16-24 oz of fluid for every pound of body weight lost during the workout. Include electrolytes and protein for recovery." }
];

const faqList = [
  {
    question: "Is drinking a gallon of water a day healthy?",
    answer: "It depends on the individual. For active people or those in hot climates, a gallon can be appropriate. However, for sedentary individuals, it might be excessive and could potentially disrupt electrolyte balance if not careful."
  },
  {
    question: "Does coffee dehydrate you?",
    answer: "No. While caffeine is a mild diuretic, the water in a cup of coffee more than makes up for any fluid lost. Coffee contributes to your overall daily hydration."
  },
  {
    question: "How do I know if I'm hydrated?",
    answer: "The easiest way is to check the color of your urine. It should be pale yellow, like lemonade. If it's dark like apple juice, you need to drink more."
  },
  {
    question: "Do I need electrolytes for every workout?",
    answer: "Not necessarily. For light workouts under an hour, water is usually fine. Electrolytes become crucial for intense workouts, sessions over an hour, or if you sweat heavily."
  },
  {
    question: "Can I drink too much water?",
    answer: "Yes. Drinking excessive amounts of water in a short period without replacing electrolytes can lead to a dangerous condition called hyponatremia, where blood sodium levels drop too low."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/hydration-guide"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<SiteLayout
  site="bodycount"
  title="Hydration Guide for Athletes | BodyCount"
  description="The science of hydration, covering sweat rates, electrolytes, debunking myths, and actionable protocols for athletes."
  canonical="https://bodycount.photonbuilder.com/hydration-guide"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Hydration Guide for Athletes</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        The science of hydration. Learn how much water you actually need, calculate your sweat rate, understand electrolytes, and dial in your protocol for peak performance.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>How Much Water Do You Actually Need?</h2>
        <ul>
          {waterNeeds.map(item => (
            <li><strong>{item.fact}:</strong> {item.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Sweat Rate Calculation</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">
          Knowing your sweat rate allows you to customize your hydration protocol precisely to your body's needs.
        </div>
        <ol>
          {sweatRate.map(item => (
            <li><strong>{item.step}:</strong> {item.description}</li>
          ))}
        </ol>
      </section>

      <section>
        <h2>Electrolytes Explained</h2>
        <ul>
          {electrolytes.map(item => (
            <li><strong>{item.nutrient}:</strong> {item.role}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Drink Comparison: What to Choose?</h2>
        <table>
          <thead>
            <tr>
              <th>Type</th>
              <th>Pros</th>
              <th>Cons</th>
            </tr>
          </thead>
          <tbody>
            {drinkComparison.map(item => (
              <tr>
                <td><strong>{item.type}</strong></td>
                <td>{item.pros}</td>
                <td>{item.cons}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Hydration for Different Sports</h2>
        <ul>
          {sportsHydration.map(item => (
            <li><strong>{item.sport}:</strong> {item.focus}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Signs of Dehydration vs. Overhydration</h2>
        <table>
          <thead>
            <tr>
              <th>State</th>
              <th>Symptoms</th>
            </tr>
          </thead>
          <tbody>
            {hydrationSigns.map(item => (
              <tr>
                <td><strong>{item.state}</strong></td>
                <td>{item.symptoms}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Caffeine and Alcohol: The Myths and Realities</h2>
        <div class="highlight-box">
          <h4>Substance Effects</h4>
          <ul style="margin-bottom: 0;">
            {caffeineAlcohol.map(item => (
              <li><strong>{item.topic}:</strong> {item.details}</li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <h2>Best Hydration Supplements</h2>
        <ul>
          {supplements.map(item => (
            <li><strong>{item.brand}:</strong> {item.features}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Pre/During/Post Workout Hydration Protocol</h2>
        <table>
          <thead>
            <tr>
              <th>Phase</th>
              <th>Strategy</th>
            </tr>
          </thead>
          <tbody>
            {protocol.map(item => (
              <tr>
                <td><strong>{item.phase}</strong></td>
                <td>{item.strategy}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
