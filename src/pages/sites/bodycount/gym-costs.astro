    const tbody = document.getElementById('tableBody');
    const searchInput = document.getElementById('searchInput');
    let currentSort = { column: 'price', direction: 'asc' };

    function formatCurrency(val) {
      if (val === null || val === undefined) return 'Varies';
      return '$' + parseFloat(val).toFixed(2).replace(/\.00$/, '');
    }

    function renderTable(data) {
      tbody.innerHTML = '';
      data.forEach(gym => {
        const tr = document.createElement('tr');

        const ams = gym.amenities.map(a => `<span class="amenity-tag">${a}</span>`).join('');

        tr.innerHTML = `
          <td>
            <div class="gym-name">${gym.gym}</div>
            <div class="locations">${gym.locations.toLocaleString()} locations</div>
          </td>
          <td>
            <div class="price">${formatCurrency(gym.monthlyBase)}/mo</div>
            <div class="price-range">Up to ${formatCurrency(gym.monthlyPremium)}</div>
          </td>
          <td class="hide-mobile">
            <div class="price">${formatCurrency(gym.initFee)}</div>
          </td>
          <td class="hide-mobile" style="color: var(--text-secondary); font-size: 0.875rem;">
            ${gym.contractLength}
          </td>
          <td class="hide-mobile">
            <div class="amenities">${ams}</div>
          </td>
        `;
        tbody.appendChild(tr);
      });
    }

    function sortData(data, column, direction) {
      return [...data].sort((a, b) => {
        let valA, valB;
        if (column === 'gym') {
          valA = a.gym.toLowerCase();
          valB = b.gym.toLowerCase();
          return direction === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else if (column === 'price') {
          valA = a.monthlyBase === null ? 999999 : a.monthlyBase;
          valB = b.monthlyBase === null ? 999999 : b.monthlyBase;
        } else if (column === 'init') {
          valA = a.initFee === null ? 999999 : a.initFee;
          valB = b.initFee === null ? 999999 : b.initFee;
        }

        return direction === 'asc' ? valA - valB : valB - valA;
      });
    }

    function filterData(query) {
      const lowerQuery = query.toLowerCase();
      return gymData.filter(gym => {
        return gym.gym.toLowerCase().includes(lowerQuery) ||
               gym.amenities.some(a => a.toLowerCase().includes(lowerQuery));
      });
    }

    function updateTable() {
      const query = searchInput.value;
      const filtered = filterData(query);
      const sorted = sortData(filtered, currentSort.column, currentSort.direction);
      renderTable(sorted);
    }

    // Event Listeners
    searchInput.addEventListener('input', updateTable);

    document.querySelectorAll('th[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const column = th.dataset.sort;
        if (currentSort.column === column) {
          currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
        } else {
          currentSort.column = column;
          currentSort.direction = 'asc';
        }

        document.querySelectorAll('th').forEach(el => {
          el.classList.remove('asc', 'desc');
        });
        th.classList.add(currentSort.direction);

        updateTable();
      });
    });

    // FAQ Accordion
    document.querySelectorAll('.faq-question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        item.classList.toggle('active');
      });
    });

    // Initial render
    document.querySelector('th[data-sort="price"]').classList.add('asc');
    updateTable();
  </script>

