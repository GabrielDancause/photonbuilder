      margin-left: 6px;
      opacity: 0.3;
    }
    th.asc .sort-icon::after { content: '↑'; opacity: 1; color: var(--accent); }
    th.desc .sort-icon::after { content: '↓'; opacity: 1; color: var(--accent); }

