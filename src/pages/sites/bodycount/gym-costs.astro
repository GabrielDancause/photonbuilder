    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 80px;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 800;
      margin-bottom: 32px;
      text-align: center;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      margin-bottom: 16px;
      overflow: hidden;
    }

    .faq-question {
      padding: 20px 24px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .faq-question::after {
      content: '+';
      color: var(--accent);
      font-size: 1.5rem;
      transition: transform 0.2s;
    }

    .faq-item.active .faq-question::after {
      transform: rotate(45deg);
    }

    .faq-answer {
      padding: 0 24px;
      max-height: 0;
      overflow: hidden;
      transition: all 0.3s ease;
      color: var(--text-secondary);
    }

    .faq-item.active .faq-answer {
      padding: 0 24px 24px;
      max-height: 500px;
    }

