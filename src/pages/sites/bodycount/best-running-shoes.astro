---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Running Shoes 2026",
    "description": "Top running shoes by category: daily trainers, speed/racing, trail, stability, max cushion, budget.",
    "url": "https://bodycount.photonbuilder.com/best-running-shoes"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How often should I replace my running shoes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most running shoes last between 300 and 500 miles. Replace them when you notice significant wear on the outsole or when the cushioning feels flat and less supportive."
        }
      },
      {
        "@type": "Question",
        "name": "What is heel-to-toe drop?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Heel-to-toe drop is the difference in height between the heel and the forefoot of the shoe, usually measured in millimeters. A higher drop (8-12mm) favors heel strikers, while a lower drop (0-6mm) is often preferred by midfoot or forefoot strikers."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need stability shoes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Stability shoes are designed for runners who overpronate (their feet roll inward excessively). If you have a neutral gait or underpronate (supinate), a neutral shoe is usually better."
        }
      },
      {
        "@type": "Question",
        "name": "Are carbon-plated shoes worth it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For racing and speed workouts, carbon-plated shoes can improve running economy and speed. However, they are expensive, less durable, and may alter your biomechanics, so they shouldn't be used for everyday training."
        }
      },
      {
        "@type": "Question",
        "name": "How much should I spend on running shoes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good pair of daily trainers typically costs between $120 and $160. Budget options exist around $100, while premium racing shoes can cost $250 or more."
        }
      }
    ]
  }
];

const categories = [
  { name: 'Best Daily Trainer', brand: 'Brooks Ghost 15', desc: 'Reliable, comfortable, and perfect for everyday miles.' },
  { name: 'Best Speed/Racing', brand: 'Nike Vaporfly 3', desc: 'Carbon-plated speed for your next PR.' },
  { name: 'Best Trail', brand: 'Hoka Speedgoat 5', desc: 'Unmatched grip and cushioning for technical terrain.' },
  { name: 'Best Stability', brand: 'ASICS Gel-Kayano 30', desc: 'Maximum support for overpronators without feeling clunky.' },
  { name: 'Best Max Cushion', brand: 'New Balance Fresh Foam X 1080v13', desc: 'Plush, soft, and protective for long, easy runs.' },
  { name: 'Best Budget', brand: 'Saucony Axon 3', desc: 'Incredible value with a fast, rockered geometry.' }
];

const shoes = [
  { brand: 'Brooks Ghost 15', category: 'Daily Trainer', weight: '9.8 oz', drop: '12mm', cushion: 'Medium', durability: '400-500', terrain: 'Road', price: 140 },
  { brand: 'Nike Vaporfly 3', category: 'Speed/Racing', weight: '6.5 oz', drop: '8mm', cushion: 'High', durability: '200-250', terrain: 'Road', price: 260 },
  { brand: 'Hoka Speedgoat 5', category: 'Trail', weight: '10.3 oz', drop: '4mm', cushion: 'High', durability: '350-400', terrain: 'Trail', price: 155 },
  { brand: 'ASICS Gel-Kayano 30', category: 'Stability', weight: '10.7 oz', drop: '10mm', cushion: 'High', durability: '400-500', terrain: 'Road', price: 160 },
  { brand: 'New Balance 1080v13', category: 'Max Cushion', weight: '9.2 oz', drop: '6mm', cushion: 'Max', durability: '350-450', terrain: 'Road', price: 165 },
  { brand: 'Saucony Axon 3', category: 'Budget', weight: '8.5 oz', drop: '4mm', cushion: 'High', durability: '300-400', terrain: 'Road', price: 100 },
  { brand: 'Adidas Adizero Boston 12', category: 'Speed/Racing', weight: '9.4 oz', drop: '7mm', cushion: 'Medium', durability: '350-400', terrain: 'Road', price: 160 }
];
---

<SiteLayout
  site="bodycount"
  title="Best Running Shoes 2026 - BodyCount"
  description="Top running shoes by category: daily trainers, speed/racing, trail, stability, max cushion, budget. Find the perfect shoe for your gait and mileage."
  canonical="https://bodycount.photonbuilder.com/best-running-shoes"
>
  <div class="page-wrapper">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style>
      .page-wrapper {
        --bg-color: #0f1115;
        --card-bg: #1a1d24;
        --border-color: #2a2f3a;
        --accent-color: #4ade80;
        --accent-hover: #22c55e;
        --text-primary: #f8fafc;
        --text-secondary: #94a3b8;
        --chart-header: #212530;
        --table-hover: #262b36;

        background-color: var(--bg-color);
        color: var(--text-primary);
        min-height: 100vh;
        font-family: system-ui, -apple-system, sans-serif;
      }

      .hero-section {
        background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
        padding: 4rem 1.5rem 3rem;
        text-align: center;
        border-bottom: 1px solid var(--border-color);
      }

      .hero-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        letter-spacing: -0.025em;
        margin-top: 0;
      }

      .hero-subtitle {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 42rem;
        margin: 0 auto;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      /* Category Grid */
      .section-title {
        font-size: 1.875rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        text-align: center;
        margin-top: 0;
      }

      .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
      }

      .category-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        transition: transform 0.2s, border-color 0.2s;
      }

      .category-card:hover {
        transform: translateY(-2px);
        border-color: var(--accent-color);
      }

      .cat-title {
        font-size: 0.875rem;
        color: var(--accent-color);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        margin-bottom: 0.5rem;
      }

      .cat-brand {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
      }

      .cat-desc {
        color: var(--text-secondary);
        font-size: 0.875rem;
        line-height: 1.5;
      }

      /* Gait Guide Section */
      .gait-guide {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 4rem;
      }

      .gait-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
      }

      @media (max-width: 768px) {
        .gait-grid {
          grid-template-columns: 1fr;
        }
      }

      .gait-type h3 {
        color: var(--accent-color);
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        margin-top: 0;
      }

      .gait-type p {
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
      }

      /* Table Styles */
      .table-container {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow-x: auto;
        margin-bottom: 4rem;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
      }

      th {
        background: var(--chart-header);
        padding: 1rem 1.5rem;
        font-weight: 600;
        color: var(--text-secondary);
        border-bottom: 2px solid var(--border-color);
        white-space: nowrap;
      }

      td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-primary);
      }

      tr:last-child td {
        border-bottom: none;
      }

      tr:hover td {
        background: var(--table-hover);
      }

      .type-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        background: rgba(148, 163, 184, 0.1);
        color: var(--text-secondary);
      }

      .val-price {
        font-family: monospace;
        font-size: 0.875rem;
      }

      /* FAQ Section */
      .faq-section {
        max-width: 800px;
        margin: 0 auto 4rem;
      }

      .faq-item {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1rem;
      }

      .faq-q {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
      }

      .faq-a {
        color: var(--text-secondary);
        line-height: 1.6;
      }
    </style>

    <div class="hero-section">
      <h1 class="hero-title">Best Running Shoes 2026</h1>
      <p class="hero-subtitle">
        Compare the top daily trainers, speed shoes, and trail runners.
      </p>
    </div>

    <main class="container">
      <section>
        <h2 class="section-title">Top Category Winners</h2>
        <div class="category-grid">
          {categories.map(cat => (
            <div class="category-card">
              <div class="cat-title">{cat.name}</div>
              <div class="cat-brand">{cat.brand}</div>
              <div class="cat-desc">{cat.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-title">Gait Type Guide</h2>
        <div class="gait-guide">
          <div class="gait-grid">
            <div class="gait-type">
              <h3>Neutral Gait</h3>
              <p>Your foot rolls inward naturally to absorb shock. Neutral runners typically have a normal or high arch and do best in neutral shoes that offer cushioning without added structural support.</p>
            </div>
            <div class="gait-type">
              <h3>Overpronation</h3>
              <p>Your foot rolls inward excessively, often associated with flat feet or low arches. Overpronators benefit from stability shoes, which have features like guide rails or medial posts to provide support and keep the foot aligned.</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title" style="text-align: left;">Compare Running Shoes</h2>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Brand & Model</th>
                <th>Category</th>
                <th>Weight</th>
                <th>Drop</th>
                <th>Cushion</th>
                <th>Durability (mi)</th>
                <th>Terrain</th>
                <th>Price</th>
              </tr>
            </thead>
            <tbody>
              {shoes.map(shoe => (
                <tr>
                  <td style="font-weight: 500;">{shoe.brand}</td>
                  <td><span class="type-badge">{shoe.category}</span></td>
                  <td>{shoe.weight}</td>
                  <td>{shoe.drop}</td>
                  <td>{shoe.cushion}</td>
                  <td>{shoe.durability}</td>
                  <td>{shoe.terrain}</td>
                  <td class="val-price">${shoe.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          {schema[1].mainEntity.map((faq: any) => (
            <div class="faq-item">
              <div class="faq-q">{faq.name}</div>
              <div class="faq-a">{faq.acceptedAnswer.text}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
