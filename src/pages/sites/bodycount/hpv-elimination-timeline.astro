    "publisher": {
      "@type": "Organization",
      "name": "HPV Research"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does cervical cancer elimination mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The World Health Organization defines the elimination of cervical cancer as a public health problem as reducing the incidence rate to fewer than 4 cases per 100,000 women globally."
        }
      },
      {
        "@type": "Question",
        "name": "What are the WHO 90-70-90 targets?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The targets, to be achieved by 2030, are: 90% of girls fully vaccinated by age 15; 70% of women screened with a high-performance test by ages 35 and 45; and 90% of women identified with cervical disease receiving treatment."
        }
      },
      {
        "@type": "Question",
        "name": "When will cervical cancer be eliminated?",
