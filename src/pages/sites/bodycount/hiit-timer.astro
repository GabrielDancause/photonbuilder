---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "HIIT Workout Timer",
  "url": "https://bodycount.photonbuilder.com/hiit-timer",
  "description": "Customizable HIIT interval timer with work/rest intervals, round tracking, audio cues, and calorie burn estimates. Includes Tabata, Classic, Sprint, and Beginner presets.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is HIIT and how does it work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "HIIT (High-Intensity Interval Training) alternates between short bursts of intense exercise and brief rest periods. A typical session lasts 10-30 minutes. During work intervals you push to 80-95% of your max heart rate, then recover during rest intervals. This approach burns more calories per minute than steady-state cardio and creates an afterburn effect (EPOC) that keeps your metabolism elevated for hours after the workout."
      }
    },
    {
      "@type": "Question",
      "name": "What is Tabata training?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tabata is a specific HIIT protocol created by Dr. Izumi Tabata in 1996. It consists of 8 rounds of 20 seconds all-out work followed by 10 seconds rest, totaling just 4 minutes. Despite its short duration, studies show Tabata improves both aerobic and anaerobic fitness. It's one of the most time-efficient workout formats ever studied."
      }
    },
    {
      "@type": "Question",
      "name": "How many calories does HIIT burn?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "HIIT burns approximately 10-16 calories per minute depending on body weight, intensity, and exercise selection. A 150 lb person can burn 200-350 calories in a 20-minute HIIT session. Additionally, HIIT creates an afterburn effect (EPOC) that can increase calorie burn by 6-15% for several hours post-workout, making the total calorie expenditure significantly higher than the workout alone."
      }
    },
    {
      "@type": "Question",
      "name": "How often should I do HIIT workouts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most experts recommend 2-4 HIIT sessions per week with at least 48 hours between sessions for recovery. Doing HIIT daily can lead to overtraining, increased injury risk, and elevated cortisol levels. On non-HIIT days, consider low-intensity activities like walking, yoga, or light cycling. Beginners should start with 2 sessions per week and gradually increase."
      }
    },
    {
      "@type": "Question",
      "name": "What work-to-rest ratio should beginners use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beginners should start with a 1:2 work-to-rest ratio — for example, 20 seconds of work followed by 40 seconds of rest. This allows adequate recovery between intervals. As fitness improves, progress to 1:1 (30 seconds work, 30 seconds rest), then to 2:1 (40 seconds work, 20 seconds rest) for advanced training. The Beginner preset in this timer uses a 1:2 ratio with 6 rounds."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="HIIT Workout Timer — Interval Training Timer | bodycount"
  description="Customizable HIIT interval timer with work/rest periods, round tracking, audio cues, and calorie estimates. Includes Tabata, Sprint, and Beginner presets."
  canonical="https://bodycount.photonbuilder.com/hiit-timer" schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --color-work: #22c55e;
            --color-rest: #ef4444;
            --color-warmup: #f59e0b;
            --color-cooldown: #3b82f6;
            --color-done: #2DB89A;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .form-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .form-col {
            flex: 1;
            min-width: 140px;
        }

        input[type="number"] {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s;
            appearance: none;
        }

        input[type="number"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .presets-group {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .preset-btn {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.625rem 0.5rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }

        .preset-btn:hover {
            border-color: var(--accent-color);
        }

        .preset-btn.active {
            border-color: var(--accent-color);
            background-color: rgba(45, 184, 154, 0.1);
        }

        .preset-btn small {
            display: block;
            font-size: 0.7rem;
            font-weight: 400;
            color: var(--text-secondary);
            margin-top: 0.2rem;
        }

        button.calculate-btn {
            width: 100%;
            background-color: var(--accent-color);
            color: #000000;
            border: none;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 0.5rem;
            font-family: var(--font-ui);
        }

        button.calculate-btn:hover {
            background-color: var(--accent-hover);
        }

        .timer-controls {
            display: flex;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }

        .timer-controls button {
            flex: 1;
            padding: 0.875rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            font-family: var(--font-ui);
            border: 1px solid var(--border-color);
            transition: all 0.2s;
        }

        #pauseBtn {
            background-color: var(--color-warmup);
            color: #000;
            border-color: var(--color-warmup);
        }

        #resetBtn {
            background-color: transparent;
            color: var(--text-primary);
        }

        #resetBtn:hover {
            border-color: var(--accent-color);
        }

        .timer-display {
            display: none;
            text-align: center;
            padding: 2rem 1rem;
        }

        .timer-display.active {
            display: block;
        }

        .timer-phase {
            font-size: 1.25rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.5rem;
        }

        .timer-countdown {
            font-family: var(--font-mono);
            font-size: 7rem;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 0.75rem;
        }

        .timer-round {
            font-size: 1.125rem;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .progress-bar-wrapper {
            width: 100%;
            height: 8px;
            background-color: var(--bg-color);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

        .progress-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s linear, background-color 0.3s;
            width: 0%;
        }

        .timer-stats {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .timer-stat {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            min-width: 120px;
            text-align: center;
        }

        .timer-stat-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .timer-stat-value {
            font-family: var(--font-mono);
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--accent-color);
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 1rem;
            margin-top: 1rem;
        }

        .workout-summary {
            display: none;
            margin-top: 2rem;
            animation: fadeIn 0.3s ease-in-out;
        }

        .workout-summary.active {
            display: block;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .summary-item {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.25rem;
            text-align: center;
        }

        .summary-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .summary-value {
            font-family: var(--font-mono);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent-color);
        }

        .faq-section {
            margin-top: 2rem;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 0;
        }

        .faq-question {
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-primary);
        }

        .faq-question::after {
            content: '+';
            font-size: 1.25rem;
            color: var(--accent-color);
            transition: transform 0.2s;
        }

        .faq-item.open .faq-question::after {
            content: '−';
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.7;
        }

        .faq-item.open .faq-answer {
            max-height: 500px;
            padding-top: 0.75rem;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.03); }
        }

        .timer-countdown.pulse {
            animation: pulse 0.5s ease-in-out;
        }

        @media (max-width: 640px) {
            h1 { font-size: 1.5rem; }
            .presets-group { grid-template-columns: repeat(2, 1fr); }
            .timer-countdown { font-size: 5rem; }
            .summary-grid { grid-template-columns: 1fr; }
            .timer-stats { flex-direction: column; align-items: center; }
        }
  </style>

  <div class="container">
    <div style="background:rgba(224,90,90,0.08);border:1px solid rgba(224,90,90,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
      🔥 <strong style="color:#E05A5A;">HIIT burns 25-30% more calories than steady cardio in the same time — and keeps burning for 24 hours after.</strong> A 20-minute HIIT session equals 40 minutes of jogging for fat loss. Choose a preset or customize your intervals below. <a href="https://gab.ae/news/rfk-food-policy-companies-push-back-2026" style="color:#E05A5A;">Why efficient exercise wins →</a>
    </div>
    <h1>HIIT Workout Timer</h1>
    <p class="subtitle">Customizable interval timer for high-intensity workouts. Set your intervals, press start, and go.</p>

    <div class="card" style="margin-top: 2rem;" id="setupCard">
      <label>Presets</label>
      <div class="presets-group">
        <button class="preset-btn" data-preset="tabata">Tabata<small>20/10 × 8</small></button>
        <button class="preset-btn" data-preset="classic">Classic<small>30/30 × 10</small></button>
        <button class="preset-btn" data-preset="sprint">Sprint<small>40/20 × 6</small></button>
        <button class="preset-btn" data-preset="beginner">Beginner<small>20/40 × 6</small></button>
      </div>

      <div class="form-row">
        <div class="form-col">
          <div class="form-group">
            <label for="work-time">Work Interval (sec)</label>
            <input type="number" id="work-time" min="10" max="120" value="20" />
          </div>
        </div>
        <div class="form-col">
          <div class="form-group">
            <label for="rest-time">Rest Interval (sec)</label>
            <input type="number" id="rest-time" min="5" max="120" value="10" />
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-col">
          <div class="form-group">
            <label for="rounds">Rounds</label>
            <input type="number" id="rounds" min="1" max="30" value="8" />
          </div>
        </div>
        <div class="form-col">
          <div class="form-group">
            <label for="body-weight">Body Weight (lbs)</label>
            <input type="number" id="body-weight" min="66" max="660" value="165" />
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-col">
          <div class="form-group">
            <label for="warmup-time">Warm-up (min)</label>
            <input type="number" id="warmup-time" min="0" max="5" value="1" />
          </div>
        </div>
        <div class="form-col">
          <div class="form-group">
            <label for="cooldown-time">Cool-down (min)</label>
            <input type="number" id="cooldown-time" min="0" max="5" value="1" />
          </div>
        </div>
      </div>

      <button class="calculate-btn" id="startBtn">Start Workout</button>
    </div>

    <div class="card timer-display" id="timerDisplay">
      <div class="timer-phase" id="timerPhase">GET READY</div>
      <div class="timer-countdown" id="timerCountdown">00</div>
      <div class="timer-round" id="timerRound">Round 0 / 0</div>

      <div class="progress-bar-wrapper">
        <div class="progress-bar-fill" id="progressBar"></div>
      </div>

      <div class="timer-stats">
        <div class="timer-stat">
          <div class="timer-stat-label">Elapsed</div>
          <div class="timer-stat-value" id="elapsedTime">0:00</div>
        </div>
        <div class="timer-stat">
          <div class="timer-stat-label">Remaining</div>
          <div class="timer-stat-value" id="remainingTime">0:00</div>
        </div>
        <div class="timer-stat">
          <div class="timer-stat-label">Calories</div>
          <div class="timer-stat-value" id="caloriesBurned">0</div>
        </div>
      </div>

      <div class="timer-controls">
        <button id="pauseBtn">Pause</button>
        <button id="resetBtn">Reset</button>
      </div>
    </div>

    <div class="workout-summary" id="workoutSummary">
      <div class="card">
        <h2 class="section-title">Workout Complete</h2>
        <div class="summary-grid">
          <div class="summary-item">
            <div class="summary-label">Total Time</div>
            <div class="summary-value" id="summaryTime">0:00</div>
          </div>
          <div class="summary-item">
            <div class="summary-label">Rounds</div>
            <div class="summary-value" id="summaryRounds">0</div>
          </div>
          <div class="summary-item">
            <div class="summary-label">Calories Burned</div>
            <div class="summary-value" id="summaryCalories">0</div>
          </div>
        </div>
        <button class="calculate-btn" id="restartBtn">Start New Workout</button>
      </div>
    </div>

    <div class="card faq-section">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-question">What is HIIT and how does it work?</div>
        <div class="faq-answer">HIIT (High-Intensity Interval Training) alternates between short bursts of intense exercise and brief rest periods. A typical session lasts 10-30 minutes. During work intervals you push to 80-95% of your max heart rate, then recover during rest intervals. This approach burns more calories per minute than steady-state cardio and creates an afterburn effect (EPOC) that keeps your metabolism elevated for hours after the workout.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">What is Tabata training?</div>
        <div class="faq-answer">Tabata is a specific HIIT protocol created by Dr. Izumi Tabata in 1996. It consists of 8 rounds of 20 seconds all-out work followed by 10 seconds rest, totaling just 4 minutes. Despite its short duration, studies show Tabata improves both aerobic and anaerobic fitness. It's one of the most time-efficient workout formats ever studied.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">How many calories does HIIT burn?</div>
        <div class="faq-answer">HIIT burns approximately 10-16 calories per minute depending on body weight, intensity, and exercise selection. A 150 lb person can burn 200-350 calories in a 20-minute HIIT session. Additionally, HIIT creates an afterburn effect (EPOC) that can increase calorie burn by 6-15% for several hours post-workout, making the total calorie expenditure significantly higher than the workout alone.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">How often should I do HIIT workouts?</div>
        <div class="faq-answer">Most experts recommend 2-4 HIIT sessions per week with at least 48 hours between sessions for recovery. Doing HIIT daily can lead to overtraining, increased injury risk, and elevated cortisol levels. On non-HIIT days, consider low-intensity activities like walking, yoga, or light cycling. Beginners should start with 2 sessions per week and gradually increase.</div>
      </div>
      <div class="faq-item">
        <div class="faq-question">What work-to-rest ratio should beginners use?</div>
        <div class="faq-answer">Beginners should start with a 1:2 work-to-rest ratio — for example, 20 seconds of work followed by 40 seconds of rest. This allows adequate recovery between intervals. As fitness improves, progress to 1:1 (30 seconds work, 30 seconds rest), then to 2:1 (40 seconds work, 20 seconds rest) for advanced training. The Beginner preset in this timer uses a 1:2 ratio with 6 rounds.</div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Presets
      const presets = {
        tabata:   { work: 20, rest: 10, rounds: 8,  warmup: 1, cooldown: 1 },
        classic:  { work: 30, rest: 30, rounds: 10, warmup: 1, cooldown: 1 },
        sprint:   { work: 40, rest: 20, rounds: 6,  warmup: 2, cooldown: 2 },
        beginner: { work: 20, rest: 40, rounds: 6,  warmup: 2, cooldown: 1 }
      };

      document.querySelectorAll('.preset-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const p = presets[btn.dataset.preset];
          if (!p) return;
          document.getElementById('work-time').value = p.work;
          document.getElementById('rest-time').value = p.rest;
          document.getElementById('rounds').value = p.rounds;
          document.getElementById('warmup-time').value = p.warmup;
          document.getElementById('cooldown-time').value = p.cooldown;
          document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        });
      });

      // FAQ toggle
      document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => q.parentElement.classList.toggle('open'));
      });

      // Audio context for beeps
      let audioCtx = null;
      function getAudioCtx() {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        return audioCtx;
      }

      function beep(freq, duration, count) {
        try {
          const ctx = getAudioCtx();
          for (let i = 0; i < count; i++) {
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.frequency.value = freq;
            osc.type = 'sine';
            gain.gain.value = 0.3;
            const start = ctx.currentTime + i * (duration / 1000 + 0.1);
            osc.start(start);
            gain.gain.setValueAtTime(0.3, start);
            gain.gain.exponentialRampToValueAtTime(0.001, start + duration / 1000);
            osc.stop(start + duration / 1000);
          }
        } catch (e) { /* audio not supported */ }
      }

      // Timer state
      let timerInterval = null;
      let isPaused = false;
      let currentSecond = 0;
      let totalSeconds = 0;
      let elapsedSeconds = 0;
      let phases = [];
      let phaseIndex = 0;
      let phaseSecondsLeft = 0;
      let config = {};

      function getConfig() {
        return {
          work: Math.max(10, Math.min(120, parseInt(document.getElementById('work-time').value) || 20)),
          rest: Math.max(5, Math.min(120, parseInt(document.getElementById('rest-time').value) || 10)),
          rounds: Math.max(1, Math.min(30, parseInt(document.getElementById('rounds').value) || 8)),
          warmup: Math.max(0, Math.min(5, parseInt(document.getElementById('warmup-time').value) || 0)) * 60,
          cooldown: Math.max(0, Math.min(5, parseInt(document.getElementById('cooldown-time').value) || 0)) * 60,
          bodyWeight: Math.max(66, Math.min(660, parseInt(document.getElementById('body-weight').value) || 165))
        };
      }

      function buildPhases(cfg) {
        const p = [];
        if (cfg.warmup > 0) p.push({ type: 'warmup', duration: cfg.warmup, round: 0 });
        for (let r = 1; r <= cfg.rounds; r++) {
          p.push({ type: 'work', duration: cfg.work, round: r });
          if (r < cfg.rounds) p.push({ type: 'rest', duration: cfg.rest, round: r });
        }
        if (cfg.cooldown > 0) p.push({ type: 'cooldown', duration: cfg.cooldown, round: 0 });
        return p;
      }

      function formatTime(secs) {
        const m = Math.floor(secs / 60);
        const s = secs % 60;
        return m + ':' + String(s).padStart(2, '0');
      }

      function getPhaseColor(type) {
        switch (type) {
          case 'work': return 'var(--color-work)';
          case 'rest': return 'var(--color-rest)';
          case 'warmup': return 'var(--color-warmup)';
          case 'cooldown': return 'var(--color-cooldown)';
          default: return 'var(--accent-color)';
        }
      }

      function getPhaseLabel(type) {
        switch (type) {
          case 'work': return 'WORK';
          case 'rest': return 'REST';
          case 'warmup': return 'WARM UP';
          case 'cooldown': return 'COOL DOWN';
          default: return '';
        }
      }

      function calcCalories(elapsedSec, bodyWeightLbs) {
        // Rough HIIT estimate: ~12 cal/min per 150 lbs
        const calPerMin = 12 * (bodyWeightLbs / 150);
        return Math.round(calPerMin * (elapsedSec / 60));
      }

      function updateDisplay() {
        const phase = phases[phaseIndex];
        const phaseEl = document.getElementById('timerPhase');
        const countdownEl = document.getElementById('timerCountdown');
        const roundEl = document.getElementById('timerRound');
        const progressEl = document.getElementById('progressBar');
        const elapsedEl = document.getElementById('elapsedTime');
        const remainingEl = document.getElementById('remainingTime');
        const caloriesEl = document.getElementById('caloriesBurned');

        const color = getPhaseColor(phase.type);
        phaseEl.textContent = getPhaseLabel(phase.type);
        phaseEl.style.color = color;
        countdownEl.textContent = phaseSecondsLeft;
        countdownEl.style.color = color;

        if (phase.type === 'work' || phase.type === 'rest') {
          roundEl.textContent = `Round ${phase.round} / ${config.rounds}`;
        } else {
          roundEl.textContent = getPhaseLabel(phase.type);
        }

        // Overall progress
        const pct = totalSeconds > 0 ? (elapsedSeconds / totalSeconds) * 100 : 0;
        progressEl.style.width = pct + '%';
        progressEl.style.backgroundColor = color;

        elapsedEl.textContent = formatTime(elapsedSeconds);
        remainingEl.textContent = formatTime(Math.max(0, totalSeconds - elapsedSeconds));
        caloriesEl.textContent = calcCalories(elapsedSeconds, config.bodyWeight);
      }

      function tick() {
        if (isPaused) return;

        phaseSecondsLeft--;
        elapsedSeconds++;

        // Countdown beeps at 3, 2, 1
        if (phaseSecondsLeft <= 3 && phaseSecondsLeft > 0) {
          beep(880, 100, 1);
        }

        if (phaseSecondsLeft <= 0) {
          // Phase transition
          phaseIndex++;
          if (phaseIndex >= phases.length) {
            // Workout complete
            finishWorkout();
            return;
          }
          phaseSecondsLeft = phases[phaseIndex].duration;
          // Transition beep
          if (phases[phaseIndex].type === 'work') {
            beep(1200, 150, 2);
          } else if (phases[phaseIndex].type === 'rest') {
            beep(600, 200, 1);
          } else {
            beep(800, 150, 1);
          }
        }

        updateDisplay();
      }

      function startWorkout() {
        config = getConfig();
        phases = buildPhases(config);
        totalSeconds = phases.reduce((sum, p) => sum + p.duration, 0);
        phaseIndex = 0;
        phaseSecondsLeft = phases[0].duration;
        elapsedSeconds = 0;
        isPaused = false;

        document.getElementById('setupCard').style.display = 'none';
        document.getElementById('workoutSummary').classList.remove('active');
        document.getElementById('timerDisplay').classList.add('active');
        document.getElementById('pauseBtn').textContent = 'Pause';

        // Initial beep
        beep(1000, 200, 1);

        updateDisplay();
        timerInterval = setInterval(tick, 1000);
      }

      function finishWorkout() {
        clearInterval(timerInterval);
        timerInterval = null;

        beep(1000, 200, 3);

        document.getElementById('timerDisplay').classList.remove('active');
        document.getElementById('workoutSummary').classList.add('active');

        document.getElementById('summaryTime').textContent = formatTime(elapsedSeconds);
        document.getElementById('summaryRounds').textContent = config.rounds;
        document.getElementById('summaryCalories').textContent = calcCalories(elapsedSeconds, config.bodyWeight);

        document.getElementById('workoutSummary').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      function resetWorkout() {
        clearInterval(timerInterval);
        timerInterval = null;
        isPaused = false;

        document.getElementById('timerDisplay').classList.remove('active');
        document.getElementById('workoutSummary').classList.remove('active');
        document.getElementById('setupCard').style.display = '';
      }

      // Event listeners
      document.getElementById('startBtn').addEventListener('click', startWorkout);
      document.getElementById('restartBtn').addEventListener('click', () => {
        resetWorkout();
      });

      document.getElementById('pauseBtn').addEventListener('click', () => {
        if (!timerInterval) return;
        isPaused = !isPaused;
        document.getElementById('pauseBtn').textContent = isPaused ? 'Resume' : 'Pause';
      });

      document.getElementById('resetBtn').addEventListener('click', resetWorkout);
    });
  </script>

