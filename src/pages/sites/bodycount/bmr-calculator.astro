---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "BMR Calculator",
  "url": "https://photonbuilder.com/health/bmr-calculator.html",
  "description": "Calculate your Basal Metabolic Rate using Mifflin-St Jeor, Harris-Benedict, and Katch-McArdle formulas. Compare results and estimate your TDEE.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is BMR?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BMR (Basal Metabolic Rate) is the number of calories your body burns at complete rest to maintain basic life-sustaining functions like breathing, circulation, and cell production. It represents the minimum energy your body needs to survive if you were to stay in bed all day. BMR typically accounts for 60-75% of your total daily calorie expenditure."
      }
    },
    {
      "@type": "Question",
      "name": "Which BMR formula is the most accurate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Mifflin-St Jeor equation is considered the most accurate for the general population and is recommended by the Academy of Nutrition and Dietetics. However, if you know your body fat percentage, the Katch-McArdle formula can be more accurate because it accounts for lean body mass. The original Harris-Benedict equation tends to overestimate BMR by about 5%."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between BMR and TDEE?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BMR is the calories your body burns at complete rest. TDEE (Total Daily Energy Expenditure) is your BMR multiplied by an activity factor that accounts for all physical activity including exercise, walking, and daily tasks. TDEE represents the total calories you burn in a day. To maintain your weight, eat at your TDEE. To lose weight, eat below it."
      }
    },
    {
      "@type": "Question",
      "name": "How does age affect BMR?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BMR decreases by roughly 1-2% per decade after age 20. This decline is primarily due to loss of muscle mass (sarcopenia) and hormonal changes. A 50-year-old typically has a BMR about 200-300 calories lower than a 20-year-old of the same size. Regular strength training can help slow this decline by preserving muscle mass."
      }
    },
    {
      "@type": "Question",
      "name": "Can I increase my BMR?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, the most effective way to increase your BMR is to build lean muscle mass through strength training, since muscle burns more calories at rest than fat. Other factors include getting adequate sleep, eating enough protein, staying hydrated, and avoiding prolonged extreme calorie restriction which can lower your metabolic rate."
      }
    },
    {
      "@type": "Question",
      "name": "Should I eat at my BMR to lose weight?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, you should not eat at or below your BMR for extended periods. Your BMR represents the bare minimum your body needs for basic functions. Eating below BMR can cause metabolic adaptation, muscle loss, nutrient deficiencies, and hormonal disruption. Instead, calculate your TDEE and create a moderate deficit of 500-750 calories below TDEE for safe, sustainable weight loss."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Katch-McArdle formula?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Katch-McArdle formula calculates BMR based on lean body mass rather than total body weight: BMR = 370 + (21.6 × lean mass in kg). It requires knowing your body fat percentage. This formula is especially useful for athletic or muscular individuals, as it accounts for the metabolic advantage of having more muscle mass."
      }
    },
    {
      "@type": "Question",
      "name": "Why do men have a higher BMR than women?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Men generally have a higher BMR because they tend to have more lean muscle mass, larger organs, and higher testosterone levels. On average, men's BMR is 5-10% higher than women's of similar height and weight. This is why most BMR formulas include a gender-specific adjustment factor."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="BMR Calculator — Basal Metabolic Rate | ijustwantto.live"
  description="Calculate your Basal Metabolic Rate with 3 formulas: Mifflin-St Jeor, Harris-Benedict, and Katch-McArdle. Compare results, estimate TDEE, and learn what affects your metabolism."
  canonical="https://photonbuilder.com/health/bmr-calculator" schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --color-mifflin: #3b82f6;
            --color-harris: #f59e0b;
            --color-katch: #a855f7;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .form-row {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .form-col {
            flex: 1;
            min-width: 140px;
        }

        input[type="number"],
        select {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: var(--font-ui);
            font-size: 1rem;
            transition: border-color 0.2s;
            appearance: none;
        }

        input[type="number"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .radio-group {
            display: flex;
            gap: 1rem;
        }

        .radio-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 400;
            cursor: pointer;
            padding: 0.75rem;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            flex: 1;
            justify-content: center;
            background-color: var(--bg-color);
            transition: all 0.2s;
        }

        .radio-label:has(input:checked) {
            border-color: var(--accent-color);
            background-color: rgba(45, 184, 154, 0.1);
        }

        input[type="radio"] {
            display: none;
        }

        button.calculate-btn {
            width: 100%;
            background-color: var(--accent-color);
            color: #000000;
            border: none;
            padding: 1rem;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 1rem;
            font-family: var(--font-ui);
        }

        button.calculate-btn:hover {
            background-color: var(--accent-hover);
        }

        .unit-toggle-container {
            display: flex;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .unit-toggle {
            display: flex;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
        }

        .unit-btn {
            background: none;
            border: none;
            color: var(--text-secondary);
            padding: 0.5rem 1.5rem;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: var(--font-ui);
        }

        .unit-btn.active {
            background-color: var(--accent-color);
            color: #000000;
        }

        .imperial-inputs {
            display: none;
        }

        .bf-row {
            margin-top: 0.5rem;
        }

        .bf-note {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .results {
            display: none;
            margin-top: 2rem;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .results.active {
            display: block;
        }

        .bmr-comparison {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .bmr-card {
            flex: 1;
            min-width: 140px;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.25rem;
            text-align: center;
        }

        .bmr-card-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .bmr-card-value {
            font-family: var(--font-mono);
            font-size: 1.5rem;
            font-weight: 700;
        }

        .bmr-card-detail {
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        .bmr-card-formula {
            font-size: 0.65rem;
            color: var(--text-secondary);
            margin-top: 0.5rem;
            font-family: var(--font-mono);
            opacity: 0.7;
        }

        .bar-chart-container {
            margin-bottom: 2rem;
        }

        .bar-chart-title {
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        .bar-row {
            display: flex;
            align-items: center;
            margin-bottom: 0.75rem;
            gap: 0.75rem;
        }

        .bar-label {
            width: 110px;
            font-size: 0.8rem;
            color: var(--text-secondary);
            flex-shrink: 0;
            text-align: right;
        }

        .bar-track {
            flex: 1;
            height: 36px;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            overflow: hidden;
            position: relative;
        }

        .bar-fill {
            height: 100%;
            border-radius: 6px;
            display: flex;
            align-items: center;
            padding-left: 0.75rem;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 600;
            color: #000;
            transition: width 0.5s ease;
            min-width: fit-content;
        }

        .bar-fill.mifflin { background-color: var(--color-mifflin); }
        .bar-fill.harris { background-color: var(--color-harris); }
        .bar-fill.katch { background-color: var(--color-katch); }

        .activity-table-container {
            margin-bottom: 2rem;
            overflow-x: auto;
        }

        .activity-table-title {
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        table.activity-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        table.activity-table th,
        table.activity-table td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        table.activity-table th {
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        table.activity-table td {
            color: var(--text-primary);
        }

        table.activity-table td.highlight {
            color: var(--accent-color);
            font-weight: 600;
            font-family: var(--font-mono);
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 1rem;
            margin-top: 1rem;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .info-item {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem;
        }

        .info-item-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--accent-color);
            margin-bottom: 0.5rem;
        }

        .info-item-text {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .tips-list {
            list-style: none;
            padding: 0;
        }

        .tips-list li {
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            color: var(--text-secondary);
            display: flex;
            gap: 0.75rem;
            align-items: flex-start;
        }

        .tips-list li:last-child {
            border-bottom: none;
        }

        .tip-number {
            font-family: var(--font-mono);
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--accent-color);
            background-color: rgba(45, 184, 154, 0.1);
            border-radius: 4px;
            padding: 0.2rem 0.5rem;
            flex-shrink: 0;
        }

        .faq-section {
            margin-top: 2rem;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 0;
        }

        .faq-question {
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--text-primary);
        }

        .faq-question::after {
            content: '+';
            font-size: 1.25rem;
            color: var(--accent-color);
            transition: transform 0.2s;
        }

        .faq-item.open .faq-question::after {
            content: '−';
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.7;
        }

        .faq-item.open .faq-answer {
            max-height: 500px;
            padding-top: 0.75rem;
        }

        .related-links {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 2rem;
        }

        .related-link {
            flex: 1;
            min-width: 200px;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1rem 1.25rem;
            text-decoration: none;
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }

        .related-link:hover {
            border-color: var(--accent-color);
        }

        .related-link span {
            display: block;
            font-size: 0.75rem;
            color: var(--text-secondary);
            font-weight: 400;
            margin-top: 0.25rem;
        }

        @media (max-width: 640px) {
            h1 { font-size: 1.5rem; }
            .bmr-comparison { flex-direction: column; }
            .info-grid { grid-template-columns: 1fr; }
            .bar-label { width: 80px; font-size: 0.7rem; }
        }
  </style>

  <div class="container">
    <h1>BMR Calculator</h1>
    <p class="subtitle">Calculate your Basal Metabolic Rate using 3 proven formulas and compare results side by side.</p>

    <div class="card" style="margin-top: 2rem;">
      <div class="unit-toggle-container">
        <div class="unit-toggle">
          <button class="unit-btn active" data-unit="metric">Metric</button>
          <button class="unit-btn" data-unit="imperial">Imperial</button>
        </div>
      </div>

      <div class="form-group">
        <label>Gender</label>
        <div class="radio-group">
          <label class="radio-label"><input type="radio" name="gender" value="male" checked /> Male</label>
          <label class="radio-label"><input type="radio" name="gender" value="female" /> Female</label>
        </div>
      </div>

      <div class="form-row">
        <div class="form-col">
          <div class="form-group">
            <label for="age">Age</label>
            <input type="number" id="age" min="15" max="100" value="30" />
          </div>
        </div>
        <div class="form-col metric-inputs">
          <div class="form-group">
            <label for="weight-kg">Weight (kg)</label>
            <input type="number" id="weight-kg" min="30" max="300" value="75" />
          </div>
        </div>
        <div class="form-col imperial-inputs">
          <div class="form-group">
            <label for="weight-lbs">Weight (lbs)</label>
            <input type="number" id="weight-lbs" min="66" max="660" value="165" />
          </div>
        </div>
      </div>

      <div class="form-row metric-inputs">
        <div class="form-col">
          <div class="form-group">
            <label for="height-cm">Height (cm)</label>
            <input type="number" id="height-cm" min="100" max="250" value="175" />
          </div>
        </div>
      </div>

      <div class="form-row imperial-inputs">
        <div class="form-col">
          <div class="form-group">
            <label for="height-ft">Height (ft)</label>
            <input type="number" id="height-ft" min="3" max="8" value="5" />
          </div>
        </div>
        <div class="form-col">
          <div class="form-group">
            <label for="height-in">Height (in)</label>
            <input type="number" id="height-in" min="0" max="11" value="9" />
          </div>
        </div>
      </div>

      <div class="form-row bf-row">
        <div class="form-col">
          <div class="form-group">
            <label for="bodyfat">Body Fat % <span style="font-weight:400;color:var(--text-secondary)">(optional — for Katch-McArdle)</span></label>
            <input type="number" id="bodyfat" min="3" max="60" step="0.5" placeholder="e.g. 20" />
            <div class="bf-note">Leave blank to skip Katch-McArdle formula</div>
          </div>
        </div>
      </div>

      <button class="calculate-btn" id="calculateBtn">Calculate BMR</button>
    </div>

    <div class="results" id="results">
      <div class="card">
        <h2 class="section-title">Your BMR Results</h2>

        <div class="bmr-comparison">
          <div class="bmr-card">
            <div class="bmr-card-label">Mifflin-St Jeor</div>
            <div class="bmr-card-value" id="mifflinValue" style="color: var(--color-mifflin);">—</div>
            <div class="bmr-card-detail">cal/day</div>
            <div class="bmr-card-formula">Most recommended</div>
          </div>
          <div class="bmr-card">
            <div class="bmr-card-label">Harris-Benedict</div>
            <div class="bmr-card-value" id="harrisValue" style="color: var(--color-harris);">—</div>
            <div class="bmr-card-detail">cal/day</div>
            <div class="bmr-card-formula">Original (1919)</div>
          </div>
          <div class="bmr-card" id="katchCard">
            <div class="bmr-card-label">Katch-McArdle</div>
            <div class="bmr-card-value" id="katchValue" style="color: var(--color-katch);">—</div>
            <div class="bmr-card-detail">cal/day</div>
            <div class="bmr-card-formula">Lean mass based</div>
          </div>
        </div>

        <div class="bar-chart-container">
          <div class="bar-chart-title">BMR Comparison</div>
          <div class="bar-row">
            <div class="bar-label">Mifflin-St Jeor</div>
            <div class="bar-track"><div class="bar-fill mifflin" id="barMifflin"></div></div>
          </div>
          <div class="bar-row">
            <div class="bar-label">Harris-Benedict</div>
            <div class="bar-track"><div class="bar-fill harris" id="barHarris"></div></div>
          </div>
          <div class="bar-row" id="barKatchRow">
            <div class="bar-label">Katch-McArdle</div>
            <div class="bar-track"><div class="bar-fill katch" id="barKatch"></div></div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="activity-table-container">
          <div class="activity-table-title">Estimated TDEE by Activity Level</div>
          <table class="activity-table">
            <thead>
              <tr>
                <th>Activity Level</th>
                <th>Multiplier</th>
                <th>Daily Calories</th>
              </tr>
            </thead>
            <tbody id="activityTableBody"></tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <h2 class="section-title">What Affects Your BMR</h2>
        <div class="info-grid">
          <div class="info-item">
            <div class="info-item-title">Muscle Mass</div>
            <div class="info-item-text">Muscle tissue burns significantly more calories at rest than fat tissue — roughly 6 cal/lb vs 2 cal/lb per day. More lean mass means a higher BMR, which is why strength training is the most effective way to boost your metabolism long-term.</div>
          </div>
          <div class="info-item">
            <div class="info-item-title">Age</div>
            <div class="info-item-text">BMR declines approximately 1-2% per decade after your 20s, primarily due to age-related muscle loss (sarcopenia). By age 60, you may burn 200-400 fewer calories at rest compared to age 20. Staying active helps counteract this decline.</div>
          </div>
          <div class="info-item">
            <div class="info-item-title">Hormones</div>
            <div class="info-item-text">Thyroid hormones (T3 and T4) are the primary regulators of metabolic rate. Testosterone, growth hormone, and insulin also play significant roles. Conditions like hypothyroidism can lower BMR by 15-40%, while hyperthyroidism can raise it significantly.</div>
          </div>
          <div class="info-item">
            <div class="info-item-title">Body Temperature</div>
            <div class="info-item-text">For every 0.5°C increase in body temperature, BMR rises by approximately 7%. Cold exposure activates brown fat and can temporarily boost metabolic rate. Fever, climate, and even spicy food can cause short-term BMR increases.</div>
          </div>
        </div>
      </div>

      <div class="card">
        <h2 class="section-title">Tips to Boost Your Metabolism</h2>
        <ul class="tips-list">
          <li><span class="tip-number">01</span>Build lean muscle with strength training — each pound of muscle burns ~6 calories per day at rest, compared to ~2 for fat. Compound lifts like squats, deadlifts, and bench press are most effective.</li>
          <li><span class="tip-number">02</span>Eat enough protein — the thermic effect of protein is 20-30%, meaning your body burns 20-30% of protein calories just digesting it. Aim for 0.7-1g per pound of body weight daily.</li>
          <li><span class="tip-number">03</span>Don't crash diet — severe calorie restriction (below BMR) triggers metabolic adaptation, where your body lowers its metabolic rate to conserve energy. Stick to moderate deficits of 500-750 cal below TDEE.</li>
          <li><span class="tip-number">04</span>Stay hydrated — even mild dehydration can slow metabolism by 2-3%. Drinking cold water may provide a small additional boost as your body expends energy warming it up.</li>
          <li><span class="tip-number">05</span>Prioritize sleep — poor sleep (less than 7 hours) is linked to lower BMR, increased hunger hormones, and reduced muscle recovery. Aim for 7-9 hours of quality sleep per night.</li>
          <li><span class="tip-number">06</span>Move more throughout the day — NEAT (Non-Exercise Activity Thermogenesis) from fidgeting, standing, and walking can account for 200-900 calories per day. Take breaks from sitting every 30 minutes.</li>
        </ul>
      </div>

      <div class="card faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-item">
          <div class="faq-question">What is BMR?</div>
          <div class="faq-answer">BMR (Basal Metabolic Rate) is the number of calories your body burns at complete rest to maintain basic life-sustaining functions like breathing, circulation, and cell production. It represents the minimum energy your body needs to survive if you were to stay in bed all day. BMR typically accounts for 60-75% of your total daily calorie expenditure.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Which BMR formula is the most accurate?</div>
          <div class="faq-answer">The Mifflin-St Jeor equation is considered the most accurate for the general population and is recommended by the Academy of Nutrition and Dietetics. However, if you know your body fat percentage, the Katch-McArdle formula can be more accurate because it accounts for lean body mass. The original Harris-Benedict equation tends to overestimate BMR by about 5%.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">What is the difference between BMR and TDEE?</div>
          <div class="faq-answer">BMR is the calories your body burns at complete rest. TDEE (Total Daily Energy Expenditure) is your BMR multiplied by an activity factor that accounts for all physical activity including exercise, walking, and daily tasks. TDEE represents the total calories you burn in a day. To maintain your weight, eat at your TDEE. To lose weight, eat below it.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">How does age affect BMR?</div>
          <div class="faq-answer">BMR decreases by roughly 1-2% per decade after age 20. This decline is primarily due to loss of muscle mass (sarcopenia) and hormonal changes. A 50-year-old typically has a BMR about 200-300 calories lower than a 20-year-old of the same size. Regular strength training can help slow this decline by preserving muscle mass.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Can I increase my BMR?</div>
          <div class="faq-answer">Yes, the most effective way to increase your BMR is to build lean muscle mass through strength training, since muscle burns more calories at rest than fat. Other factors include getting adequate sleep, eating enough protein, staying hydrated, and avoiding prolonged extreme calorie restriction which can lower your metabolic rate.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Should I eat at my BMR to lose weight?</div>
          <div class="faq-answer">No, you should not eat at or below your BMR for extended periods. Your BMR represents the bare minimum your body needs for basic functions. Eating below BMR can cause metabolic adaptation, muscle loss, nutrient deficiencies, and hormonal disruption. Instead, calculate your TDEE and create a moderate deficit of 500-750 calories below TDEE for safe, sustainable weight loss.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">What is the Katch-McArdle formula?</div>
          <div class="faq-answer">The Katch-McArdle formula calculates BMR based on lean body mass rather than total body weight: BMR = 370 + (21.6 × lean mass in kg). It requires knowing your body fat percentage. This formula is especially useful for athletic or muscular individuals, as it accounts for the metabolic advantage of having more muscle mass.</div>
        </div>
        <div class="faq-item">
          <div class="faq-question">Why do men have a higher BMR than women?</div>
          <div class="faq-answer">Men generally have a higher BMR because they tend to have more lean muscle mass, larger organs, and higher testosterone levels. On average, men's BMR is 5-10% higher than women's of similar height and weight. This is why most BMR formulas include a gender-specific adjustment factor.</div>
        </div>
      </div>

