  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let currentUnit = 'metric';

      // Unit toggle
      document.querySelectorAll('.unit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentUnit = btn.dataset.unit;
          document.querySelectorAll('.metric-inputs').forEach(el => el.style.display = currentUnit === 'metric' ? '' : 'none');
          document.querySelectorAll('.imperial-inputs').forEach(el => el.style.display = currentUnit === 'imperial' ? '' : 'none');
        });
      });

      // FAQ toggle
      document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => {
          q.parentElement.classList.toggle('open');
        });
      });

      // Calculate
      document.getElementById('calculateBtn').addEventListener('click', calculate);

      function getInputs() {
        const gender = document.querySelector('input[name="gender"]:checked').value;
        const age = parseFloat(document.getElementById('age').value);
        const bodyfat = document.getElementById('bodyfat').value ? parseFloat(document.getElementById('bodyfat').value) : null;

        let weightKg, heightCm;
        if (currentUnit === 'metric') {
          weightKg = parseFloat(document.getElementById('weight-kg').value);
          heightCm = parseFloat(document.getElementById('height-cm').value);
        } else {
          weightKg = parseFloat(document.getElementById('weight-lbs').value) * 0.453592;
          const ft = parseFloat(document.getElementById('height-ft').value) || 0;
          const inches = parseFloat(document.getElementById('height-in').value) || 0;
          heightCm = (ft * 12 + inches) * 2.54;
        }

        return { gender, age, weightKg, heightCm, bodyfat };
      }

      function calcMifflin(gender, weightKg, heightCm, age) {
        if (gender === 'male') {
          return 10 * weightKg + 6.25 * heightCm - 5 * age + 5;
        }
        return 10 * weightKg + 6.25 * heightCm - 5 * age - 161;
      }

      function calcHarris(gender, weightKg, heightCm, age) {
        if (gender === 'male') {
          return 88.362 + 13.397 * weightKg + 4.799 * heightCm - 5.677 * age;
        }
        return 447.593 + 9.247 * weightKg + 3.098 * heightCm - 4.330 * age;
      }

      function calcKatch(weightKg, bodyfat) {
        const leanMass = weightKg * (1 - bodyfat / 100);
        return 370 + 21.6 * leanMass;
      }

      function calculate() {
        const { gender, age, weightKg, heightCm, bodyfat } = getInputs();

        if (!weightKg || !heightCm || !age) return;

        const mifflin = Math.round(calcMifflin(gender, weightKg, heightCm, age));
        const harris = Math.round(calcHarris(gender, weightKg, heightCm, age));
        let katch = null;

        if (bodyfat !== null && bodyfat > 0 && bodyfat < 100) {
          katch = Math.round(calcKatch(weightKg, bodyfat));
        }

        // Display values
        document.getElementById('mifflinValue').textContent = mifflin.toLocaleString();
        document.getElementById('harrisValue').textContent = harris.toLocaleString();

        const katchCard = document.getElementById('katchCard');
        const katchRow = document.getElementById('barKatchRow');
        if (katch !== null) {
          document.getElementById('katchValue').textContent = katch.toLocaleString();
          document.getElementById('katchValue').style.opacity = '1';
          katchCard.style.opacity = '1';
          katchRow.style.display = '';
        } else {
          document.getElementById('katchValue').textContent = '—';
          document.getElementById('katchValue').style.opacity = '0.4';
          katchCard.style.opacity = '0.5';
          katchRow.style.display = 'none';
        }

        // Bar chart
        const allValues = [mifflin, harris];
        if (katch !== null) allValues.push(katch);
        const maxVal = Math.max(...allValues) * 1.15;

        document.getElementById('barMifflin').style.width = `${(mifflin / maxVal) * 100}%`;
        document.getElementById('barMifflin').textContent = `${mifflin.toLocaleString()} cal`;
        document.getElementById('barHarris').style.width = `${(harris / maxVal) * 100}%`;
        document.getElementById('barHarris').textContent = `${harris.toLocaleString()} cal`;

        if (katch !== null) {
          document.getElementById('barKatch').style.width = `${(katch / maxVal) * 100}%`;
          document.getElementById('barKatch').textContent = `${katch.toLocaleString()} cal`;
        }

        // TDEE table — use Mifflin as primary BMR
        const bmrForTdee = mifflin;
        const activities = [
          { name: 'Sedentary', mult: 1.2, desc: 'Little or no exercise, desk job' },
          { name: 'Lightly Active', mult: 1.375, desc: 'Light exercise 1-3 days/week' },
          { name: 'Moderately Active', mult: 1.55, desc: 'Moderate exercise 3-5 days/week' },
          { name: 'Very Active', mult: 1.725, desc: 'Hard exercise 6-7 days/week' },
          { name: 'Extra Active', mult: 1.9, desc: 'Very hard exercise, physical job' }
        ];

        const tbody = document.getElementById('activityTableBody');
        tbody.innerHTML = '';
        activities.forEach(a => {
          const tdee = Math.round(bmrForTdee * a.mult);
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>${a.name}<br><small style="color:var(--text-secondary)">${a.desc}</small></td>
            <td>×${a.mult}</td>
            <td class="highlight">${tdee.toLocaleString()}</td>
          `;
          tbody.appendChild(tr);
        });

        // Show results
        document.getElementById('results').classList.add('active');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Auto-calculate on load
      calculate();
    });
  </script>
