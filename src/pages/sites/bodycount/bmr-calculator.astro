  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let currentUnit = 'metric';

      // Unit toggle
      document.querySelectorAll('.unit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentUnit = btn.dataset.unit;
          document.querySelectorAll('.metric-inputs').forEach(el => el.style.display = currentUnit === 'metric' ? '' : 'none');
          document.querySelectorAll('.imperial-inputs').forEach(el => el.style.display = currentUnit === 'imperial' ? '' : 'none');
        });
      });

      // Formula toggle — show/hide body fat field
      document.querySelectorAll('input[name="formula"]').forEach(radio => {
        radio.addEventListener('change', () => {
          const bfGroup = document.getElementById('bfGroup');
          bfGroup.classList.toggle('active', radio.value === 'katch');
        });
      });

      // FAQ toggle
      document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => {
          q.parentElement.classList.toggle('open');
        });
      });

      // Calculate
      document.getElementById('calculateBtn').addEventListener('click', calculate);

      function getInputs() {
        const gender = document.querySelector('input[name="gender"]:checked').value;
        const age = parseFloat(document.getElementById('age').value);
        const activity = parseFloat(document.getElementById('activity').value);
        const formula = document.querySelector('input[name="formula"]:checked').value;
        const bodyFat = parseFloat(document.getElementById('body-fat').value) || 20;

        let weightKg, heightCm;
        if (currentUnit === 'metric') {
          weightKg = parseFloat(document.getElementById('weight-kg').value);
          heightCm = parseFloat(document.getElementById('height-cm').value);
        } else {
          weightKg = parseFloat(document.getElementById('weight-lbs').value) * 0.453592;
          const ft = parseFloat(document.getElementById('height-ft').value) || 0;
          const inches = parseFloat(document.getElementById('height-in').value) || 0;
          heightCm = (ft * 12 + inches) * 2.54;
        }

        return { gender, age, weightKg, heightCm, activity, formula, bodyFat };
      }

      function calcMifflin(gender, weightKg, heightCm, age) {
        if (gender === 'male') {
          return 10 * weightKg + 6.25 * heightCm - 5 * age + 5;
        }
        return 10 * weightKg + 6.25 * heightCm - 5 * age - 161;
      }

      function calcHarris(gender, weightKg, heightCm, age) {
        if (gender === 'male') {
          return 88.362 + 13.397 * weightKg + 4.799 * heightCm - 5.677 * age;
        }
        return 447.593 + 9.247 * weightKg + 3.098 * heightCm - 4.330 * age;
      }

      function calcKatch(weightKg, bodyFat) {
        const lbm = weightKg * (1 - bodyFat / 100);
        return 370 + 21.6 * lbm;
      }

      function getBMR(formula, gender, weightKg, heightCm, age, bodyFat) {
        switch (formula) {
          case 'harris': return calcHarris(gender, weightKg, heightCm, age);
          case 'katch': return calcKatch(weightKg, bodyFat);
          default: return calcMifflin(gender, weightKg, heightCm, age);
        }
      }

      const activities = [
        { name: 'Sedentary', mult: 1.2, desc: 'Office job, little exercise' },
        { name: 'Lightly Active', mult: 1.375, desc: 'Light exercise 1-3 days/wk' },
        { name: 'Moderately Active', mult: 1.55, desc: 'Moderate exercise 3-5 days/wk' },
        { name: 'Very Active', mult: 1.725, desc: 'Hard exercise 6-7 days/wk' },
        { name: 'Extra Active', mult: 1.9, desc: 'Very hard exercise, physical job' }
      ];

      function calculate() {
        const { gender, age, weightKg, heightCm, activity, formula, bodyFat } = getInputs();
        if (!weightKg || !heightCm || !age) return;

        const bmr = Math.round(getBMR(formula, gender, weightKg, heightCm, age, bodyFat));
        const tdee = Math.round(bmr * activity);

        // Hero values
        document.getElementById('bmrValue').textContent = bmr.toLocaleString();
        document.getElementById('tdeeValue').textContent = tdee.toLocaleString();
        document.getElementById('bmrHourly').textContent = (bmr / 24).toFixed(1);

        // Formula name
        const formulaNames = { mifflin: 'Mifflin-St Jeor', harris: 'Harris-Benedict (revised)', katch: 'Katch-McArdle' };
        document.getElementById('formulaUsed').textContent = formulaNames[formula];
        document.getElementById('formulaEmoji').textContent = formula === 'mifflin' ? 'Recommended' : formula === 'katch' ? 'Uses body fat %' : 'Classic';

        // TDEE detail
        const currentActivity = activities.find(a => Math.abs(a.mult - activity) < 0.01);
        document.getElementById('tdeeDetail').textContent = 'BMR \u00d7 ' + activity + ' (' + (currentActivity ? currentActivity.name : 'Custom') + ')';

        // Stacked bar chart — BMR vs TDEE across activity levels
        const stackedContainer = document.getElementById('stackedChart');
        stackedContainer.innerHTML = '';
        const maxTdee = Math.round(bmr * 1.9);
        activities.forEach(a => {
          const aTdee = Math.round(bmr * a.mult);
          const activityCals = aTdee - bmr;
          const bmrPct = (bmr / maxTdee) * 100;
          const actPct = (activityCals / maxTdee) * 100;
          const isCurrent = Math.abs(a.mult - activity) < 0.01;
          const row = document.createElement('div');
          row.className = 'stacked-row';
          row.innerHTML =
            '<div class="stacked-label"' + (isCurrent ? ' style="color:var(--accent-color);font-weight:600"' : '') + '>' + a.name + '</div>' +
            '<div class="stacked-track">' +
              '<div class="stacked-segment bmr-seg" style="width:' + bmrPct + '%">' + (bmrPct > 18 ? bmr.toLocaleString() : '') + '</div>' +
              '<div class="stacked-segment tdee-seg" style="width:' + actPct + '%">' + (actPct > 10 ? '+' + activityCals.toLocaleString() : '') + '</div>' +
            '</div>' +
            '<div class="stacked-val"' + (isCurrent ? ' style="color:var(--accent-color)"' : '') + '>' + aTdee.toLocaleString() + '</div>';
          stackedContainer.appendChild(row);
        });

        // Activity scale visual
        const activityIndex = activities.findIndex(a => Math.abs(a.mult - activity) < 0.01);
        const pct = activityIndex >= 0 ? (activityIndex / (activities.length - 1)) * 100 : 50;
        document.getElementById('scalePointer').style.left = pct + '%';
        document.getElementById('scaleValue').style.left = pct + '%';
        document.getElementById('scaleValue').textContent = tdee.toLocaleString() + ' cal';

        for (let i = 0; i < 5; i++) {
          const marker = document.getElementById('marker' + i);
          marker.classList.toggle('active-marker', i === activityIndex);
        }

        // Activity table
        const tbody = document.getElementById('activityTableBody');
        tbody.innerHTML = '';
        activities.forEach(a => {
          const aTdee = Math.round(bmr * a.mult);
          const isCurrent = Math.abs(a.mult - activity) < 0.01;
          const tr = document.createElement('tr');
          if (isCurrent) tr.classList.add('current');
          tr.innerHTML = '<td>' + a.name + (isCurrent ? ' \u2605' : '') + '<br><small style="color:var(--text-secondary)">' + a.desc + '</small></td>' +
            '<td>\u00d7' + a.mult + '</td>' +
            '<td class="highlight">' + aTdee.toLocaleString() + '</td>';
          tbody.appendChild(tr);
        });

        // Formula comparison
        const mifflinBMR = Math.round(calcMifflin(gender, weightKg, heightCm, age));
        const harrisBMR = Math.round(calcHarris(gender, weightKg, heightCm, age));
        const katchBMR = Math.round(calcKatch(weightKg, bodyFat));

        const formulas = [
          { name: 'Mifflin-St Jeor', bmr: mifflinBMR, cls: 'mifflin', key: 'mifflin' },
          { name: 'Harris-Benedict', bmr: harrisBMR, cls: 'harris', key: 'harris' },
          { name: 'Katch-McArdle', bmr: katchBMR, cls: 'katch', key: 'katch' }
        ];

        const maxBMR = Math.max(mifflinBMR, harrisBMR, katchBMR);

        // Bar chart
        const barsContainer = document.getElementById('formulaBars');
        barsContainer.innerHTML = '';
        formulas.forEach(f => {
          const row = document.createElement('div');
          row.className = 'formula-bar-row';
          const widthPct = (f.bmr / maxBMR) * 100;
          row.innerHTML = '<div class="formula-bar-label"><span class="formula-dot ' + f.cls + '"></span>' + f.name + '</div>' +
            '<div class="formula-bar-track"><div class="formula-bar-fill ' + f.cls + '" style="width: ' + widthPct + '%">' + f.bmr.toLocaleString() + ' cal</div></div>';
          barsContainer.appendChild(row);
        });

        // Comparison table
        const compBody = document.getElementById('comparisonTableBody');
        compBody.innerHTML = '';
        formulas.forEach(f => {
          const fTdee = Math.round(f.bmr * activity);
          const diff = f.bmr - mifflinBMR;
          const diffStr = f.key === 'mifflin' ? 'baseline' : (diff > 0 ? '+' + diff : '' + diff);
          const isCurrent = f.key === formula;
          const tr = document.createElement('tr');
          if (isCurrent) tr.classList.add('current');
          const diffColor = diff > 0 ? '#22c55e' : (diff < 0 ? '#ef4444' : 'var(--text-secondary)');
          tr.innerHTML = '<td><span class="formula-dot ' + f.cls + '"></span>' + f.name + (isCurrent ? ' \u2605' : '') + '</td>' +
            '<td class="highlight">' + f.bmr.toLocaleString() + '</td>' +
            '<td class="highlight">' + fTdee.toLocaleString() + '</td>' +
            '<td style="color: ' + diffColor + '">' + diffStr + '</td>';
          compBody.appendChild(tr);
        });

        // Show results
        document.getElementById('results').classList.add('active');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Auto-calculate on load
      calculate();
    });
  </script>
</SiteLayout>
