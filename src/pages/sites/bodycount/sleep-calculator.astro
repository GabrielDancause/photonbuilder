  <script is:inline>
let currentMode = 'wakeup';
const FALL_ASLEEP_MINUTES = 14;
const CYCLE_MINUTES = 90;

function setMode(mode) {
    currentMode = mode;
    document.getElementById('btnWakeUp').classList.toggle('active', mode === 'wakeup');
    document.getElementById('btnBedtime').classList.toggle('active', mode === 'bedtime');
    document.getElementById('wakeupMode').style.display = mode === 'wakeup' ? 'block' : 'none';
    document.getElementById('bedtimeMode').style.display = mode === 'bedtime' ? 'block' : 'none';
    document.getElementById('results').classList.remove('active');
}

function formatTime(date) {
    let h = date.getHours();
    const m = date.getMinutes();
    const ampm = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    return `${h}:${m.toString().padStart(2, '0')} ${ampm}`;
}

function totalHours(cycles) {
    return (cycles * CYCLE_MINUTES) / 60;
}

document.getElementById('sleepForm').addEventListener('submit', function(e) {
    e.preventDefault();

    const grid = document.getElementById('cycleGrid');
    grid.innerHTML = '';

    const cycleOptions = [6, 5, 4, 3]; // cycles from most to least

    if (currentMode === 'wakeup') {
        const wakeVal = document.getElementById('wakeTime').value;
        if (!wakeVal) return;
        const [wh, wm] = wakeVal.split(':').map(Number);

        document.getElementById('resultsTitle').textContent = 'Ideal bedtimes';
        document.getElementById('resultsSubtitle').textContent = `To wake up at ${formatTimeFromParts(wh, wm)} — includes ~14 min to fall asleep`;

        cycleOptions.forEach(cycles => {
            const totalMin = (cycles * CYCLE_MINUTES) + FALL_ASLEEP_MINUTES;
            const bedtime = new Date(2000, 0, 2, wh, wm);
            bedtime.setMinutes(bedtime.getMinutes() - totalMin);

            const hours = totalHours(cycles);
            const recommended = cycles === 5 || cycles === 6;
            const card = createCycleCard(formatTime(bedtime), cycles, hours, recommended);
            grid.appendChild(card);
        });
    } else {
        const bedVal = document.getElementById('bedTime').value;
        if (!bedVal) return;
        const [bh, bm] = bedVal.split(':').map(Number);

        document.getElementById('resultsTitle').textContent = 'Ideal wake-up times';
        document.getElementById('resultsSubtitle').textContent = `Going to bed at ${formatTimeFromParts(bh, bm)} — includes ~14 min to fall asleep`;

        cycleOptions.forEach(cycles => {
            const totalMin = (cycles * CYCLE_MINUTES) + FALL_ASLEEP_MINUTES;
            const wakeTime = new Date(2000, 0, 1, bh, bm);
            wakeTime.setMinutes(wakeTime.getMinutes() + totalMin);

            const hours = totalHours(cycles);
            const recommended = cycles === 5 || cycles === 6;
            const card = createCycleCard(formatTime(wakeTime), cycles, hours, recommended);
            grid.appendChild(card);
        });
    }

    document.getElementById('results').classList.add('active');
});

function formatTimeFromParts(h, m) {
    const ampm = h >= 12 ? 'PM' : 'AM';
    const h12 = h % 12 || 12;
    return `${h12}:${m.toString().padStart(2, '0')} ${ampm}`;
}

function createCycleCard(timeStr, cycles, hours, recommended) {
    const card = document.createElement('div');
    card.className = 'cycle-card' + (recommended ? ' recommended' : '');

    let badgeHtml = '';
    if (cycles === 6) badgeHtml = '<div class="cycle-badge">Optimal</div>';
    else if (cycles === 5) badgeHtml = '<div class="cycle-badge">Recommended</div>';

    card.innerHTML = `
        <div class="cycle-time">${timeStr}</div>
        <div class="cycle-meta">
            <div class="cycle-count">${cycles} cycles</div>
            <div class="cycle-hours">${hours} hours of sleep</div>
            ${badgeHtml}
        </div>
    `;
    return card;
}

function toggleFaq(el) {
    el.parentElement.classList.toggle('open');
}
  </script>
