---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const exercises = [
  { muscleGroup: "Chest & Triceps", name: "Push-ups", execution: "Keep body in a straight line, lower chest to the floor, and press up.", mod: "Knee push-ups or wall push-ups." },
  { muscleGroup: "Quads & Glutes", name: "Squats", execution: "Keep chest up, push hips back, and squat until thighs are parallel to the floor.", mod: "Assisted squats holding a door frame or chair." },
  { muscleGroup: "Legs & Core", name: "Lunges", execution: "Step forward, lowering back knee toward the ground. Keep front knee over ankle.", mod: "Reverse lunges or partial range of motion." },
  { muscleGroup: "Core", name: "Planks", execution: "Rest on forearms and toes, maintaining a straight line from head to heels.", mod: "Knee planks or elevated planks on a stable surface." },
  { muscleGroup: "Full Body & Cardio", name: "Burpees", execution: "Drop into a push-up, jump feet back in, and jump up explosively.", mod: "Step-back burpees with no jump (apartment-friendly)." },
  { muscleGroup: "Core & Cardio", name: "Mountain Climbers", execution: "In a plank position, rapidly drive knees toward your chest alternating legs.", mod: "Slow paced step-ins." },
  { muscleGroup: "Triceps & Chest", name: "Dips", execution: "Use a sturdy chair or couch. Lower hips toward the floor and press back up.", mod: "Keep knees bent and feet flat on the floor." },
  { muscleGroup: "Shoulders & Triceps", name: "Pike Push-ups", execution: "Start in a downward dog position and lower your head toward the floor.", mod: "Standard push-ups or hold the pike position." }
];

const fourWeekPlan = [
  { week: "Week 1", focus: "Building the Foundation", days: "Day 1: Full Body (3 sets x 10-12 reps). Day 2: Core & Cardio (3 rounds). Day 3: Lower Body & Push (3 sets x 10-15 reps).", progression: "Focus entirely on form, not speed. Rest 60-90 seconds between sets." },
  { week: "Week 2", focus: "Increasing Volume", days: "Day 1: Full Body (4 sets x 10-15 reps). Day 2: Core & Cardio (4 rounds). Day 3: Lower Body & Push (4 sets x 12-15 reps).", progression: "Add an extra set to each exercise. Rest time remains 60-90 seconds." },
  { week: "Week 3", focus: "Intensity & Density", days: "Day 1: Full Body EMOM (Every Minute on the Minute). Day 2: Core & Cardio AMRAP. Day 3: Lower Body & Push (4 sets x 15-20 reps).", progression: "Incorporate EMOM and AMRAP formats to increase heart rate and density." },
  { week: "Week 4", focus: "Peak Performance", days: "Day 1: Full Body (AMRAP for each exercise in 20 mins). Day 2: Advanced Core & Cardio. Day 3: Lower Body & Push (5 sets x 15-20 reps).", progression: "Push for maximum reps within good form. Decrease rest to 45-60 seconds." }
];

const warmupCooldown = [
  { phase: "Warm-Up", duration: "5-10 Minutes", movements: "Arm circles, leg swings, torso twists, high knees, inchworms.", goal: "Increase blood flow, elevate heart rate, and lubricate joints before intense work." },
  { phase: "Cool-Down", duration: "5-10 Minutes", movements: "Child's pose, standing quad stretch, hamstring stretch, chest opener, deep breathing.", goal: "Lower heart rate gradually, improve flexibility, and reduce muscle tension." }
];

const trainingFormats = [
  { name: "AMRAP (As Many Rounds/Reps As Possible)", description: "Set a timer (e.g., 15 minutes) and complete a circuit of exercises as many times as you can with good form. Great for building endurance and burning calories." },
  { name: "EMOM (Every Minute on the Minute)", description: "Start an exercise at the beginning of a minute, perform a set number of reps, and rest for the remainder of the minute. Excellent for pacing and work capacity." },
  { name: "Progression System", description: "Advance when you can comfortably complete the target rep range with perfect form. Progression can be adding reps, reducing rest time, or performing a harder variation." }
];

const modifications = [
  { name: "Apartment-Friendly (No Jumping)", description: "Swap burpees for step-back burpees. Replace jump squats with regular bodyweight squats or pulse squats. Substitute mountain climbers with slow, deliberate knee drives. This keeps your heart rate up without upsetting the neighbors." },
  { name: "Beginner Adjustments", description: "Use knee push-ups or incline push-ups instead of full push-ups. Reduce total sets and reps. Focus on the mind-muscle connection and mastering the technique before adding volume or intensity." }
];

const faqList = [
  {
    question: "Can I actually build muscle with no equipment?",
    answer: "Yes, you can build muscle using only your body weight by applying progressive overload. You can achieve this by increasing reps, slowing down the tempo, reducing rest periods, or progressing to more difficult exercise variations."
  },
  {
    question: "How often should I do this home workout?",
    answer: "This progressive plan is designed for 3 days a week, which allows for optimal recovery. For best results, leave at least one rest day between full-body workout sessions."
  },
  {
    question: "What if I can't do a full push-up yet?",
    answer: "Start with modifications such as wall push-ups, incline push-ups on a sturdy chair, or knee push-ups. Focus on keeping your core tight and lowering your chest completely before pushing back up."
  },
  {
    question: "Do I need to do cardio in addition to this routine?",
    answer: "This program incorporates cardiovascular elements, especially in the EMOM and AMRAP formats. However, walking on your rest days or adding light cardio can aid in recovery and overall heart health."
  },
  {
    question: "How long does each workout take?",
    answer: "Including the warm-up and cool-down, most sessions in this 4-week plan will take between 30 to 45 minutes, making them highly efficient and easy to fit into a busy schedule."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/home-workout-no-equipment"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<SiteLayout
  site="bodycount"
  title="Home Workout Plan (No Equipment) | BodyCount"
  description="A complete 4-week bodyweight workout program you can do at home with no equipment. Includes exercises, progressions, AMRAP/EMOM formats, and apartment-friendly modifications."
  canonical="https://bodycount.photonbuilder.com/home-workout-no-equipment"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Home Workout Plan (No Equipment)</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        A complete 4-week bodyweight workout program you can do at home with no equipment. Includes exercises, progressions, AMRAP/EMOM formats, and apartment-friendly modifications.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Exercises by Muscle Group</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Master these fundamental bodyweight movements to effectively target all major muscle groups without any equipment.</div>
        <table>
          <thead>
            <tr>
              <th>Exercise</th>
              <th>Muscle Group</th>
              <th>Execution</th>
              <th>Beginner Mod</th>
            </tr>
          </thead>
          <tbody>
            {exercises.map(item => (
              <tr>
                <td><strong>{item.name}</strong></td>
                <td>{item.muscleGroup}</td>
                <td>{item.execution}</td>
                <td><em>{item.mod}</em></td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>4-Week Progressive Plan (3 Days/Week)</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">A structured 4-week program designed to build strength, increase endurance, and establish a solid fitness routine.</div>
        <table>
          <thead>
            <tr>
              <th>Week</th>
              <th>Focus</th>
              <th>Routine</th>
              <th>Progression</th>
            </tr>
          </thead>
          <tbody>
            {fourWeekPlan.map(item => (
              <tr>
                <td><strong>{item.week}</strong></td>
                <td>{item.focus}</td>
                <td>{item.days}</td>
                <td>{item.progression}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Warm-Up & Cool-Down</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Properly preparing your body before training and winding down afterward is crucial for injury prevention and recovery.</div>
        <table>
          <thead>
            <tr>
              <th>Phase</th>
              <th>Duration</th>
              <th>Movements</th>
              <th>Goal</th>
            </tr>
          </thead>
          <tbody>
            {warmupCooldown.map(item => (
              <tr>
                <td><strong>{item.phase}</strong></td>
                <td>{item.duration}</td>
                <td>{item.movements}</td>
                <td>{item.goal}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Training Formats & Progression</h2>
        <ul>
          {trainingFormats.map(format => (
            <li><strong>{format.name}:</strong> {format.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Modifications</h2>
        <div class="highlight-box">
          <h4>Adapting Your Workout</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">Make the program work for your specific living situation and fitness level.</div>
          <ul style="margin-bottom: 0;">
            {modifications.map(item => (
              <li><strong>{item.name}:</strong> {item.description}</li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
