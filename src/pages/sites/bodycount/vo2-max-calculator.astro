<script is:inline>
var currentMethod = 'cooper';
var distanceUnit = 'meters';
var weightUnit = 'lbs';

// VO2 max norms: [veryPoorMax, poorMax, fairMax, goodMax, excellentMax]
var NORMS = {
    male: {
        20: [32, 36, 41, 45, 52],
        30: [30, 34, 38, 42, 48],
        40: [27, 31, 35, 40, 45],
        50: [24, 28, 32, 37, 43],
        60: [21, 25, 29, 34, 40],
        70: [18, 22, 26, 30, 36]
    },
    female: {
        20: [23, 28, 32, 36, 44],
        30: [21, 26, 30, 34, 41],
        40: [19, 24, 28, 32, 39],
        50: [17, 22, 26, 31, 37],
        60: [15, 20, 24, 29, 35],
        70: [13, 18, 22, 27, 33]
    }
};

function getAgeGroup(age) {
    if (age < 30) return 20;
    if (age < 40) return 30;
    if (age < 50) return 40;
    if (age < 60) return 50;
    if (age < 70) return 60;
    return 70;
}

function getCategory(vo2, age, gender) {
    var ag = getAgeGroup(age);
    var n = NORMS[gender][ag];
    if (vo2 < n[0]) return { cat: 'Very Poor', color: 'var(--cat-very-poor)', index: 0 };
    if (vo2 <= n[1]) return { cat: 'Poor', color: 'var(--cat-poor)', index: 1 };
    if (vo2 <= n[2]) return { cat: 'Fair', color: 'var(--cat-fair)', index: 2 };
    if (vo2 <= n[3]) return { cat: 'Good', color: 'var(--cat-good)', index: 3 };
    if (vo2 <= n[4]) return { cat: 'Excellent', color: 'var(--cat-excellent)', index: 4 };
    return { cat: 'Superior', color: 'var(--cat-superior)', index: 5 };
}

function getPercentile(vo2, age, gender) {
    var ag = getAgeGroup(age);
    var n = NORMS[gender][ag];
    // Approximate percentile based on category boundaries
    var mid = (n[2] + n[3]) / 2; // midpoint of fair-good
    var low = n[0] - 5;
    var high = n[4] + 10;
    var pct = ((vo2 - low) / (high - low)) * 100;
    return Math.max(1, Math.min(99, Math.round(pct)));
}

function setMethod(method) {
    currentMethod = method;
    document.getElementById('methodCooper').classList.toggle('active', method === 'cooper');
    document.getElementById('methodWalk').classList.toggle('active', method === 'walk');
    document.getElementById('methodRhr').classList.toggle('active', method === 'rhr');

    document.getElementById('cooperFields').classList.toggle('active', method === 'cooper');
    document.getElementById('walkFields').classList.toggle('active', method === 'walk');
    document.getElementById('rhrFields').classList.toggle('active', method === 'rhr');

    // Update required fields
    document.getElementById('cooperDistance').required = (method === 'cooper');
    document.getElementById('results').classList.remove('active');
}

function setUnit(unit) {
    distanceUnit = unit;
    document.getElementById('unitMeters').classList.toggle('active', unit === 'meters');
    document.getElementById('unitMiles').classList.toggle('active', unit === 'miles');
    var input = document.getElementById('cooperDistance');
    if (unit === 'miles') {
        input.placeholder = 'e.g. 1.5';
        input.step = '0.01';
    } else {
        input.placeholder = 'e.g. 2400';
        input.step = 'any';
    }
}

function setWeightUnit(unit) {
    weightUnit = unit;
    document.getElementById('unitLbs').classList.toggle('active', unit === 'lbs');
    document.getElementById('unitKg').classList.toggle('active', unit === 'kg');
    var input = document.getElementById('walkWeight');
    input.placeholder = unit === 'kg' ? 'e.g. 73' : 'e.g. 160';
}

function updateGauge(vo2) {
    // Map VO2 max to angle: 10 ml/kg/min = -90deg (left), 70 ml/kg/min = 90deg (right)
    var minVal = 10, maxVal = 70;
    var clamped = Math.max(minVal, Math.min(maxVal, vo2));
    var angle = ((clamped - minVal) / (maxVal - minVal)) * 180 - 90;

    var needle = document.getElementById('gaugeNeedle');
    var anim = document.getElementById('needleAnim');
    anim.setAttribute('from', '0 130 130');
    anim.setAttribute('to', angle + ' 130 130');
    // Restart animation
    anim.beginElement();

    document.getElementById('gaugeValue').textContent = vo2.toFixed(1);
}

document.getElementById('vo2Form').addEventListener('submit', function(e) {
    e.preventDefault();

    var age = parseInt(document.getElementById('age').value);
    var gender = document.getElementById('gender').value;
    if (isNaN(age)) return;

    var vo2 = 0;
    var methodName = '';
    var methodSub = '';

    if (currentMethod === 'cooper') {
        var dist = parseFloat(document.getElementById('cooperDistance').value);
        if (isNaN(dist) || dist <= 0) return;
        // Convert to meters if in miles
        var distMeters = distanceUnit === 'miles' ? dist * 1609.34 : dist;
        vo2 = (distMeters - 504.9) / 44.73;
        methodName = 'Cooper Test';
        methodSub = Math.round(distMeters) + ' m in 12 min';
    } else if (currentMethod === 'walk') {
        var mins = parseInt(document.getElementById('walkMinutes').value) || 0;
        var secs = parseInt(document.getElementById('walkSeconds').value) || 0;
        var hr = parseInt(document.getElementById('walkHr').value);
        var wt = parseFloat(document.getElementById('walkWeight').value);
        if (!mins || isNaN(hr) || isNaN(wt)) return;
        var totalMin = mins + secs / 60;
        var wtLbs = weightUnit === 'kg' ? wt * 2.20462 : wt;
        var genderVal = gender === 'male' ? 1 : 0;
        vo2 = 132.853 - (0.0769 * wtLbs) - (0.3877 * age) + (6.315 * genderVal) - (3.2649 * totalMin) - (0.1565 * hr);
        methodName = '1-Mile Walk';
        methodSub = totalMin.toFixed(1) + ' min, ' + hr + ' bpm';
    } else if (currentMethod === 'rhr') {
        var rhr = parseInt(document.getElementById('restingHr').value);
        if (isNaN(rhr) || rhr <= 0) return;
        var maxHr = 220 - age;
        vo2 = 15.3 * (maxHr / rhr);
        methodName = 'Resting HR';
        methodSub = rhr + ' bpm resting';
    }

    if (vo2 <= 0) return;

    var category = getCategory(vo2, age, gender);
    var percentile = getPercentile(vo2, age, gender);

    // Update gauge
    updateGauge(vo2);

    // Update result cards
    document.getElementById('resultVo2').textContent = vo2.toFixed(1);
    document.getElementById('resultCategory').textContent = category.cat;
    document.getElementById('resultCategory').style.color = category.color;
    document.getElementById('resultCategorySub').textContent = 'for ' + gender + ', age ' + age;
    document.getElementById('resultPercentile').textContent = percentile + getSuffix(percentile);
    document.getElementById('resultMethod').textContent = methodName;
    document.getElementById('resultMethodSub').textContent = methodSub;

    // Highlight relevant row in norms table
    highlightNormsRow(age, gender);

    document.getElementById('results').classList.add('active');
});

function getSuffix(n) {
    if (n >= 11 && n <= 13) return 'th';
    var last = n % 10;
    if (last === 1) return 'st';
    if (last === 2) return 'nd';
    if (last === 3) return 'rd';
    return 'th';
}

function highlightNormsRow(age, gender) {
    // Clear all highlights
    var tables = document.querySelectorAll('#maleNormsTable tbody tr, #femaleNormsTable tbody tr');
    tables.forEach(function(tr) { tr.classList.remove('highlight-row'); });

    var ag = getAgeGroup(age);
    var ageRanges = [20, 30, 40, 50, 60, 70];
    var rowIdx = ageRanges.indexOf(ag);
    if (rowIdx === -1) return;

    var tableId = gender === 'male' ? 'maleNormsTable' : 'femaleNormsTable';
    var rows = document.getElementById(tableId).querySelectorAll('tbody tr');
    if (rows[rowIdx]) rows[rowIdx].classList.add('highlight-row');
}
</script>


