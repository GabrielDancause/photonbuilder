        {name:'Red Wine',cat:'Beverages',servings:[{label:'5 oz glass (148ml)',g:148},{label:'100ml',g:100}],per100:{cal:85,p:0.1,c:2.6,f:0}},
        {name:'Coffee (black)',cat:'Beverages',servings:[{label:'1 cup (237ml)',g:237},{label:'100ml',g:100}],per100:{cal:1,p:0.1,c:0,f:0}},
        {name:'Latte (whole milk)',cat:'Beverages',servings:[{label:'12 oz (355ml)',g:355},{label:'16 oz (473ml)',g:473}],per100:{cal:42,p:2.2,c:3.4,f:2.2}},
        {name:'Smoothie (fruit)',cat:'Beverages',servings:[{label:'12 oz (355ml)',g:355},{label:'16 oz (473ml)',g:473}],per100:{cal:54,p:0.8,c:12,f:0.3}},
        {name:'Protein Shake (pre-made)',cat:'Beverages',servings:[{label:'1 bottle (414ml)',g:414},{label:'100ml',g:100}],per100:{cal:36,p:7.2,c:1.2,f:0.2}},
        {name:'Coconut Water',cat:'Beverages',servings:[{label:'1 cup (240ml)',g:240},{label:'100ml',g:100}],per100:{cal:19,p:0.7,c:3.7,f:0.2}},

        // LEGUMES
        {name:'Black Beans (cooked)',cat:'Grains',servings:[{label:'½ cup (86g)',g:86},{label:'100g',g:100}],per100:{cal:132,p:8.9,c:24,f:0.5}},
        {name:'Chickpeas (cooked)',cat:'Grains',servings:[{label:'½ cup (82g)',g:82},{label:'100g',g:100}],per100:{cal:164,p:8.9,c:27,f:2.6}},
        {name:'Lentils (cooked)',cat:'Grains',servings:[{label:'½ cup (99g)',g:99},{label:'100g',g:100}],per100:{cal:116,p:9,c:20,f:0.4}},
        {name:'Kidney Beans (cooked)',cat:'Grains',servings:[{label:'½ cup (89g)',g:89},{label:'100g',g:100}],per100:{cal:127,p:8.7,c:23,f:0.5}},
        {name:'Pinto Beans (cooked)',cat:'Grains',servings:[{label:'½ cup (86g)',g:86},{label:'100g',g:100}],per100:{cal:143,p:9,c:26,f:0.6}},

        // SNACKS / MISC
        {name:'Rice Cake',cat:'Grains',servings:[{label:'1 cake (9g)',g:9},{label:'100g',g:100}],per100:{cal:387,p:8,c:82,f:2.8}},
        {name:'Popcorn (air-popped)',cat:'Grains',servings:[{label:'1 cup (8g)',g:8},{label:'3 cups (24g)',g:24}],per100:{cal:387,p:13,c:78,f:4.5}},
        {name:'Dark Chocolate (70%)',cat:'Fats',servings:[{label:'1 oz (28g)',g:28},{label:'1 square (10g)',g:10}],per100:{cal:598,p:8,c:46,f:43}},
        {name:'Protein Bar (avg)',cat:'Grains',servings:[{label:'1 bar (60g)',g:60},{label:'100g',g:100}],per100:{cal:350,p:33,c:38,f:10}},
        {name:'Trail Mix',cat:'Fats',servings:[{label:'¼ cup (38g)',g:38},{label:'1 oz (28g)',g:28}],per100:{cal:462,p:14,c:44,f:29}},
      ];

      const categories = ['All','Proteins','Grains','Vegetables','Fruits','Dairy','Fats','Sauces','Beverages'];

      // ========== RESTAURANT PRESETS ==========
      const presets = [
        {name:"McDonald's Big Mac",cal:550,p:25,c:45,f:30},
        {name:"McDonald's Quarter Pounder w/ Cheese",cal:520,p:30,c:42,f:27},
        {name:"McDonald's 10pc McNuggets",cal:410,p:24,c:26,f:24},
        {name:"Chipotle Chicken Burrito Bowl",cal:665,p:50,c:56,f:22},
        {name:"Chipotle Steak Burrito",cal:930,p:50,c:99,f:34},
        {name:"Subway 6\" Turkey Breast",cal:280,p:18,c:40,f:3.5},
        {name:"Subway 6\" Italian BMT",cal:410,p:20,c:42,f:18},
        {name:"Chick-fil-A Original Sandwich",cal:440,p:28,c:40,f:19},
        {name:"Chick-fil-A 12pc Nuggets",cal:380,p:40,c:14,f:18},
        {name:"Wendy's Dave's Single",cal:590,p:30,c:45,f:34},
        {name:"Taco Bell Crunchy Taco",cal:170,p:8,c:13,f:10},
        {name:"Taco Bell Burrito Supreme",cal:400,p:16,c:52,f:14},
        {name:"Panda Express Orange Chicken",cal:490,p:25,c:51,f:23},
        {name:"Pizza (cheese, 2 slices)",cal:570,p:24,c:64,f:22},
        {name:"Starbucks Caffe Latte (Grande)",cal:190,p:13,c:19,f:7},
        {name:"Starbucks Caramel Frappuccino (Grande)",cal:380,p:5,c:54,f:16},
        {name:"Five Guys Cheeseburger",cal:840,p:47,c:40,f:55},
        {name:"In-N-Out Double-Double",cal:670,p:37,c:39,f:41},
        {name:"Popeyes Chicken Sandwich",cal:700,p:28,c:50,f:42},
        {name:"KFC Original Recipe (2pc)",cal:480,p:38,c:16,f:30},
      ];

      // ========== STATE ==========
      let mealItems = [];
      let selectedFoodIdx = null;
      let currentCategory = 'All';

      // ========== CORE CALC ==========
      function calcItem(item) {
        if (item.preset) {
          const p = presets[item.presetIdx];
          return {
            name: p.name, serving: '1 meal', qty: item.qty,
            cal: Math.round(p.cal * item.qty),
            p: Math.round(p.p * item.qty * 10) / 10,
            c: Math.round(p.c * item.qty * 10) / 10,
            f: Math.round(p.f * item.qty * 10) / 10,
          };
        }
        const food = foods[item.foodIdx];
        const serving = food.servings[item.servingIdx];
        const mult = (serving.g / 100) * item.qty;
        return {
          name: food.name, serving: serving.label, qty: item.qty,
          cal: Math.round(food.per100.cal * mult),
          p: Math.round(food.per100.p * mult * 10) / 10,
          c: Math.round(food.per100.c * mult * 10) / 10,
          f: Math.round(food.per100.f * mult * 10) / 10,
        };
      }

      // ========== CATEGORY TABS ==========
      const tabsEl = document.getElementById('categoryTabs');
      categories.forEach(cat => {
        const btn = document.createElement('button');
        btn.className = 'cat-tab' + (cat === 'All' ? ' active' : '');
        btn.textContent = cat;
        btn.addEventListener('click', () => {
          currentCategory = cat;
          document.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          showFilteredFoods();
        });
        tabsEl.appendChild(btn);
      });

      // ========== SEARCH ==========
      const searchInput = document.getElementById('foodSearch');
      const searchResultsEl = document.getElementById('searchResults');

      searchInput.addEventListener('input', showFilteredFoods);
      searchInput.addEventListener('focus', showFilteredFoods);

      document.addEventListener('click', (e) => {
        if (!e.target.closest('.search-container')) {
          searchResultsEl.classList.remove('active');
        }
      });

      function showFilteredFoods() {
        const query = searchInput.value.toLowerCase().trim();
        let filtered = foods.map((f, i) => ({...f, idx: i}));

        if (currentCategory !== 'All') {
          filtered = filtered.filter(f => f.cat === currentCategory);
        }
        if (query) {
          filtered = filtered.filter(f => f.name.toLowerCase().includes(query));
        }
        filtered = filtered.slice(0, 30);

        if (filtered.length === 0) {
          searchResultsEl.innerHTML = '<div style="padding:0.75rem;color:var(--text-secondary);font-size:0.85rem;">No foods found</div>';
        } else {
          searchResultsEl.innerHTML = filtered.map(f => {
            const cal = Math.round(f.per100.cal * f.servings[0].g / 100);
            return `<div class="search-result-item" data-idx="${f.idx}">
              <span><span class="food-name">${f.name}</span><span class="food-category">${f.cat}</span></span>
              <span class="food-cal">${cal} cal / ${f.servings[0].label}</span>
            </div>`;
          }).join('');

          searchResultsEl.querySelectorAll('.search-result-item').forEach(item => {
            item.addEventListener('click', () => selectFood(parseInt(item.dataset.idx)));
          });
        }
        searchResultsEl.classList.add('active');
      }

      function selectFood(idx) {
        selectedFoodIdx = idx;
        const food = foods[idx];
        document.getElementById('selectedFood').value = food.name;
        document.getElementById('addRow').style.display = '';
        document.getElementById('servingSelect').innerHTML = food.servings.map((s, i) => `<option value="${i}">${s.label}</option>`).join('');
        document.getElementById('qtyInput').value = '1';
        searchResultsEl.classList.remove('active');
        searchInput.value = '';
      }

      // ========== ADD FOOD ==========
      document.getElementById('addFoodBtn').addEventListener('click', () => {
        if (selectedFoodIdx === null) return;
        const servingIdx = parseInt(document.getElementById('servingSelect').value);
        const qty = parseFloat(document.getElementById('qtyInput').value) || 1;
        mealItems.push({ foodIdx: selectedFoodIdx, servingIdx, qty });
        selectedFoodIdx = null;
        document.getElementById('addRow').style.display = 'none';
        renderMeal();
      });

      // ========== RENDER MEAL ==========
      function renderMeal() {
        const table = document.getElementById('mealTable');
        const emptyMsg = document.getElementById('emptyMsg');
        const tbody = document.getElementById('mealBody');

        if (mealItems.length === 0) {
          table.style.display = 'none';
          emptyMsg.style.display = '';
          updateTotals(0, 0, 0, 0);
          return;
        }

        table.style.display = '';
        emptyMsg.style.display = 'none';

        let totalCal = 0, totalP = 0, totalC = 0, totalF = 0;

        tbody.innerHTML = mealItems.map((item, i) => {
          const d = calcItem(item);
          totalCal += d.cal; totalP += d.p; totalC += d.c; totalF += d.f;
          return `<tr>
            <td class="food-col">${d.name}</td>
            <td>${d.serving}</td>
            <td style="text-align:center;"><input type="number" class="qty-input" value="${d.qty}" min="0.25" step="0.25" data-idx="${i}" /></td>
            <td class="num-col">${d.cal}</td>
            <td class="num-col">${d.p.toFixed(1)}</td>
            <td class="num-col">${d.c.toFixed(1)}</td>
            <td class="num-col">${d.f.toFixed(1)}</td>
            <td><button class="remove-btn" data-idx="${i}" title="Remove">✕</button></td>
          </tr>`;
        }).join('');

        tbody.querySelectorAll('.qty-input').forEach(input => {
          input.addEventListener('change', (e) => {
            const val = parseFloat(e.target.value);
            if (val > 0) { mealItems[parseInt(e.target.dataset.idx)].qty = val; renderMeal(); }
          });
        });

        tbody.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            mealItems.splice(parseInt(e.target.dataset.idx), 1);
            renderMeal();
          });
        });

        totalP = Math.round(totalP * 10) / 10;
        totalC = Math.round(totalC * 10) / 10;
        totalF = Math.round(totalF * 10) / 10;

        document.getElementById('footCal').textContent = totalCal;
        document.getElementById('footP').textContent = totalP.toFixed(1);
        document.getElementById('footC').textContent = totalC.toFixed(1);
        document.getElementById('footF').textContent = totalF.toFixed(1);

        updateTotals(totalCal, totalP, totalC, totalF);
      }

      function updateTotals(cal, p, c, f) {
        document.getElementById('totalCal').textContent = cal;
        document.getElementById('totalProtein').textContent = typeof p === 'number' ? p.toFixed(1) : p;
        document.getElementById('totalCarbs').textContent = typeof c === 'number' ? c.toFixed(1) : c;
        document.getElementById('totalFat').textContent = typeof f === 'number' ? f.toFixed(1) : f;

        const pie = document.getElementById('pieChart');
        const totalMacroGrams = p + c + f;

        if (totalMacroGrams === 0) {
          pie.style.background = '';
          pie.classList.add('pie-chart-empty');
          document.getElementById('proteinPct').textContent = '0%';
          document.getElementById('carbsPct').textContent = '0%';
          document.getElementById('fatPct').textContent = '0%';
          return;
        }

        pie.classList.remove('pie-chart-empty');

        const pCal = p * 4, cCal = c * 4, fCal = f * 9;
        const totalMacroCal = pCal + cCal + fCal;
        const pPct = Math.round((pCal / totalMacroCal) * 100);
        const cPct = Math.round((cCal / totalMacroCal) * 100);
        const fPct = 100 - pPct - cPct;

        pie.style.background = `conic-gradient(var(--color-protein) 0% ${pPct}%, var(--color-carbs) ${pPct}% ${pPct + cPct}%, var(--color-fat) ${pPct + cPct}% 100%)`;
        document.getElementById('proteinPct').textContent = pPct + '%';
        document.getElementById('carbsPct').textContent = cPct + '%';
        document.getElementById('fatPct').textContent = fPct + '%';
      }

      // ========== CLEAR MEAL ==========
      document.getElementById('clearMealBtn').addEventListener('click', () => {
        mealItems = [];
        renderMeal();
      });

      // ========== SAVE / LOAD MEALS ==========
      const STORAGE_KEY = 'bodycount_saved_meals';

      function getSavedMeals() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
        catch { return []; }
      }

      function saveMeals(meals) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(meals));
      }

      document.getElementById('saveMealBtn').addEventListener('click', () => {
        if (mealItems.length === 0) return;
        const name = prompt('Name this meal:');
        if (!name) return;

        const meals = getSavedMeals();
        let totalCal = 0;
        mealItems.forEach(item => { totalCal += calcItem(item).cal; });
        meals.push({ name, items: [...mealItems], totalCal });
        saveMeals(meals);
        renderSavedMeals();
      });

      function renderSavedMeals() {
        const meals = getSavedMeals();
        const card = document.getElementById('savedMealsCard');
        const list = document.getElementById('savedMealsList');

        if (meals.length === 0) { card.style.display = 'none'; return; }

        card.style.display = '';
        list.innerHTML = meals.map((m, i) => `
          <div class="saved-meal-item">
            <div>
              <div class="saved-meal-name">${m.name}</div>
              <div class="saved-meal-cal">${m.totalCal} cal · ${m.items.length} items</div>
            </div>
            <div class="saved-meal-actions">
              <button class="btn btn-sm btn-outline load-meal-btn" data-idx="${i}">Load</button>
              <button class="btn btn-sm btn-danger delete-meal-btn" data-idx="${i}">Delete</button>
            </div>
          </div>
        `).join('');

        list.querySelectorAll('.load-meal-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            mealItems = [...meals[parseInt(btn.dataset.idx)].items];
            renderMeal();
          });
        });

        list.querySelectorAll('.delete-meal-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const idx = parseInt(btn.dataset.idx);
            meals.splice(idx, 1);
            saveMeals(meals);
            renderSavedMeals();
          });
        });
      }

      // ========== PRESETS ==========
      const presetGrid = document.getElementById('presetGrid');
      presets.forEach((preset, i) => {
        const div = document.createElement('div');
        div.className = 'preset-card';
        div.innerHTML = `<div class="preset-name">${preset.name}</div><div class="preset-info">${preset.cal} cal · P${preset.p}g C${preset.c}g F${preset.f}g</div>`;
        div.addEventListener('click', () => {
          mealItems.push({ preset: true, presetIdx: i, qty: 1 });
          renderMeal();
        });
        presetGrid.appendChild(div);
      });

      // ========== FAQ TOGGLE ==========
      document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => q.parentElement.classList.toggle('open'));
      });

      // ========== INIT ==========
      renderSavedMeals();
    });
  </script>
</SiteLayout>
