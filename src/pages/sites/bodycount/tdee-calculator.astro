  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let currentUnit = 'metric';

      // Unit toggle
      document.querySelectorAll('.unit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.unit-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentUnit = btn.dataset.unit;
          document.querySelectorAll('.metric-inputs').forEach(el => el.style.display = currentUnit === 'metric' ? '' : 'none');
          document.querySelectorAll('.imperial-inputs').forEach(el => el.style.display = currentUnit === 'imperial' ? '' : 'none');
        });
      });

      // FAQ toggle
      document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => {
          q.parentElement.classList.toggle('open');
        });
      });

      document.getElementById('calculateBtn').addEventListener('click', calculate);

      const exercises = [
        ['Running (6 mph)', 9.8],
        ['Running (8 mph)', 11.8],
        ['Cycling (moderate)', 8.0],
        ['Cycling (vigorous)', 10.0],
        ['Swimming (laps)', 8.0],
        ['Jump Rope', 12.3],
        ['Rowing Machine', 7.0],
        ['Elliptical Trainer', 5.0],
        ['Walking (3.5 mph)', 4.3],
        ['Hiking', 6.0],
        ['HIIT / Circuit Training', 8.0],
        ['Weight Lifting (moderate)', 3.5],
        ['Weight Lifting (vigorous)', 6.0],
        ['Yoga', 3.0],
        ['Pilates', 3.0],
        ['Basketball', 6.5],
        ['Soccer', 7.0],
        ['Tennis', 7.3],
        ['Boxing (sparring)', 7.8],
        ['Dancing (aerobic)', 6.5]
      ];

      function getInputs() {
        const gender = document.querySelector('input[name="gender"]:checked').value;
        const age = parseFloat(document.getElementById('age').value);
        const activity = parseFloat(document.getElementById('activity').value);
        const bodyfat = document.getElementById('bodyfat').value ? parseFloat(document.getElementById('bodyfat').value) : null;

        let weightKg, heightCm;
        if (currentUnit === 'metric') {
          weightKg = parseFloat(document.getElementById('weight-kg').value);
          heightCm = parseFloat(document.getElementById('height-cm').value);
        } else {
          weightKg = parseFloat(document.getElementById('weight-lbs').value) * 0.453592;
          const ft = parseFloat(document.getElementById('height-ft').value) || 0;
          const inches = parseFloat(document.getElementById('height-in').value) || 0;
          heightCm = (ft * 12 + inches) * 2.54;
        }

        return { gender, age, weightKg, heightCm, activity, bodyfat };
      }

      function calcBMR_MSJ(gender, weightKg, heightCm, age) {
        if (gender === 'male') {
          return 10 * weightKg + 6.25 * heightCm - 5 * age + 5;
        }
        return 10 * weightKg + 6.25 * heightCm - 5 * age - 161;
      }

      function calcBMR_KM(weightKg, bodyfatPct) {
        const lbm = weightKg * (1 - bodyfatPct / 100);
        return 370 + 21.6 * lbm;
      }

      function calculate() {
        const { gender, age, weightKg, heightCm, activity, bodyfat } = getInputs();
        if (!weightKg || !heightCm || !age) return;

        const bmrMSJ = Math.round(calcBMR_MSJ(gender, weightKg, heightCm, age));
        let bmrKM = null;
        let bmrUsed = bmrMSJ;

        document.getElementById('bmrMSJ').textContent = bmrMSJ.toLocaleString();

        const kmCard = document.getElementById('bmrKMCard');
        if (bodyfat !== null && bodyfat > 0) {
          bmrKM = Math.round(calcBMR_KM(weightKg, bodyfat));
          document.getElementById('bmrKM').textContent = bmrKM.toLocaleString();
          kmCard.style.display = '';
          bmrUsed = Math.round((bmrMSJ + bmrKM) / 2);
        } else {
          kmCard.style.display = 'none';
        }

        const tdee = Math.round(bmrUsed * activity);
        const cutCals = tdee - 500;
        const bulkCals = tdee + 500;

        // TDEE highlight
        document.getElementById('tdeeValue').textContent = tdee.toLocaleString();
        const formulaUsed = bmrKM !== null ? 'Average of Mifflin-St Jeor & Katch-McArdle' : 'Mifflin-St Jeor';
        document.getElementById('tdeeDetail').textContent = `calories/day \u00b7 ${formulaUsed}`;

        // Calorie meter
        const maxCal = bulkCals * 1.1;
        document.getElementById('meterBulk').style.width = `${(bulkCals / maxCal) * 100}%`;
        document.getElementById('meterBulk').textContent = `Bulk ${bulkCals.toLocaleString()}`;
        document.getElementById('meterTdee').style.width = `${(tdee / maxCal) * 100}%`;
        document.getElementById('meterTdee').textContent = `Maintain ${tdee.toLocaleString()}`;
        document.getElementById('meterCut').style.width = `${(cutCals / maxCal) * 100}%`;
        document.getElementById('meterCut').textContent = `Cut ${cutCals.toLocaleString()}`;

        document.getElementById('legendCut').textContent = `(${cutCals.toLocaleString()})`;
        document.getElementById('legendMaintain').textContent = `(${tdee.toLocaleString()})`;
        document.getElementById('legendBulk').textContent = `(${bulkCals.toLocaleString()})`;

        // Activity comparison table
        const activityLevels = [
          { name: 'Sedentary', mult: 1.2, desc: 'Office job, little exercise' },
          { name: 'Lightly Active', mult: 1.375, desc: 'Light exercise 1-3 days/wk' },
          { name: 'Moderately Active', mult: 1.55, desc: 'Moderate exercise 3-5 days/wk' },
          { name: 'Active', mult: 1.725, desc: 'Hard exercise 6-7 days/wk' },
          { name: 'Very Active', mult: 1.9, desc: 'Very hard exercise, physical job' },
          { name: 'Athlete', mult: 2.1, desc: '2x daily training, competitive' }
        ];

        const tbody = document.getElementById('activityTableBody');
        tbody.innerHTML = '';
        activityLevels.forEach(a => {
          const levelTdee = Math.round(bmrUsed * a.mult);
          const isCurrent = Math.abs(a.mult - activity) < 0.01;
          const tr = document.createElement('tr');
          if (isCurrent) tr.classList.add('current');
          tr.innerHTML = `
            <td>${a.name}${isCurrent ? ' \u2605' : ''}<br><small style="color:var(--text-secondary)">${a.desc}</small></td>
            <td>\u00d7${a.mult}</td>
            <td class="highlight">${levelTdee.toLocaleString()}</td>
          `;
          tbody.appendChild(tr);
        });

        // Macro suggestions
        document.getElementById('cutCals').innerHTML = `${cutCals.toLocaleString()} <small>cal/day</small>`;
        document.getElementById('cutProtein').textContent = Math.round((cutCals * 0.40) / 4) + 'g';
        document.getElementById('cutCarbs').textContent = Math.round((cutCals * 0.35) / 4) + 'g';
        document.getElementById('cutFat').textContent = Math.round((cutCals * 0.25) / 9) + 'g';

        document.getElementById('maintainCals').innerHTML = `${tdee.toLocaleString()} <small>cal/day</small>`;
        document.getElementById('maintainProtein').textContent = Math.round((tdee * 0.30) / 4) + 'g';
        document.getElementById('maintainCarbs').textContent = Math.round((tdee * 0.40) / 4) + 'g';
        document.getElementById('maintainFat').textContent = Math.round((tdee * 0.30) / 9) + 'g';

        document.getElementById('bulkCals').innerHTML = `${bulkCals.toLocaleString()} <small>cal/day</small>`;
        document.getElementById('bulkProtein').textContent = Math.round((bulkCals * 0.30) / 4) + 'g';
        document.getElementById('bulkCarbs').textContent = Math.round((bulkCals * 0.45) / 4) + 'g';
        document.getElementById('bulkFat').textContent = Math.round((bulkCals * 0.25) / 9) + 'g';

        // Exercise calories table
        const exBody = document.getElementById('exerciseTableBody');
        exBody.innerHTML = '';
        exercises.forEach(([name, met]) => {
          const calsPerHour = Math.round(met * 3.5 * weightKg / 200 * 60);
          const tr = document.createElement('tr');
          tr.innerHTML = `<td>${name}</td><td>${calsPerHour.toLocaleString()}</td>`;
          exBody.appendChild(tr);
        });

        // Show results
        document.getElementById('results').classList.add('active');
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      calculate();
    });
  </script>
</SiteLayout>
