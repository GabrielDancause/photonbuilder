      <div class="card">
        <div class="table-container">
          <div class="table-title">Exercise Calories Burned Per Hour</div>
          <p style="font-size:0.8rem;color:var(--text-secondary);margin-bottom:1rem;" id="exerciseNote">Based on your weight. Actual burn varies by intensity and fitness level.</p>
          <table class="exercise-table">
            <thead>
              <tr>
                <th>Activity</th>
                <th>Cal/Hour</th>
              </tr>
            </thead>
            <tbody id="exerciseTableBody"></tbody>
          </table>
