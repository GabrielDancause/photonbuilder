---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "ASCVD Risk Calculator (10-Year Cardiovascular Risk)",
  description: "Calculate your 10-year risk of heart disease or stroke. What hidden factors might be affecting your cardiovascular health? Find out now.",
  category: "tool",
  published: "2024-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is ASCVD?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ASCVD stands for Atherosclerotic Cardiovascular Disease. It includes conditions like coronary heart disease (such as myocardial infarction), cerebrovascular disease (such as stroke), and peripheral artery disease. It is primarily caused by plaque buildup in the arterial walls."
        }
      },
      {
        "@type": "Question",
        "name": "How is the 10-year ASCVD risk calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The 10-year ASCVD risk is estimated using the Pooled Cohort Equations (PCEs). The calculation incorporates several key risk factors: age, sex, race, total cholesterol, HDL cholesterol, systolic blood pressure, use of blood pressure-lowering medication, diabetes status, and smoking status."
        }
      },
      {
        "@type": "Question",
        "name": "What is considered a high ASCVD risk?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 10-year ASCVD risk score of 20% or higher is generally considered high risk. A score between 7.5% and 19.9% is considered intermediate risk, 5% to 7.4% is borderline risk, and less than 5% is considered low risk. Treatment recommendations typically become more aggressive as the risk category increases."
        }
      },
      {
        "@type": "Question",
        "name": "Can I lower my ASCVD risk?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, ASCVD risk can often be lowered through lifestyle modifications (such as eating a heart-healthy diet, exercising regularly, quitting smoking, and maintaining a healthy weight) and sometimes through medications like statins or blood pressure drugs, as prescribed by a healthcare provider."
        }
      },
      {
        "@type": "Question",
        "name": "Who should use this ASCVD risk calculator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The calculator is generally intended for adults between the ages of 40 and 79 who do not already have cardiovascular disease. Individuals outside this age range or those with existing ASCVD should consult their doctor for a more personalized risk assessment."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "ASCVD Risk Calculator (10-Year Cardiovascular Risk)",
    "description": "Calculate your 10-year risk of heart disease or stroke. What hidden factors might be affecting your cardiovascular health? Find out now.",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    }
  }
];
---
<SiteLayout site="bodycount" title={meta.title} description={meta.description} canonical="https://photonbuilder.com/bodycount/ascvd-risk-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>ASCVD Risk Calculator</h1>
      <p class="subtitle">Estimate your 10-year risk of atherosclerotic cardiovascular disease</p>
    </div>

    <div class="calculator-container">
      <form id="ascvd-form">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
          <div>
            <label for="age" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Age (20-79)</label>
            <input type="number" id="age" name="age" min="20" max="79" required placeholder="e.g. 55">
            <div id="age-error" style="color: #ef4444; font-size: 0.875rem; display: none; margin-top: 0.25rem;">Age must be between 20 and 79.</div>
          </div>
          <div>
            <label for="sex" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Sex</label>
            <select id="sex" name="sex" required>
              <option value="">Select Sex</option>
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
            <div id="sex-error" style="color: #ef4444; font-size: 0.875rem; display: none; margin-top: 0.25rem;">Please select sex.</div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
          <div>
            <label for="race" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Race</label>
            <select id="race" name="race" required>
              <option value="">Select Race</option>
              <option value="white">White</option>
              <option value="african_american">African American</option>
              <option value="other">Other</option>
            </select>
            <div id="race-error" style="color: #ef4444; font-size: 0.875rem; display: none; margin-top: 0.25rem;">Please select race.</div>
          </div>
          <div>
            <label for="total-cholesterol" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Total Cholesterol (mg/dL)</label>
            <input type="number" id="total-cholesterol" name="total-cholesterol" min="130" max="320" required placeholder="e.g. 213">
            <div id="tc-error" style="color: #ef4444; font-size: 0.875rem; display: none; margin-top: 0.25rem;">Value must be 130-320 mg/dL.</div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
          <div>
            <label for="hdl-cholesterol" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">HDL Cholesterol (mg/dL)</label>
            <input type="number" id="hdl-cholesterol" name="hdl-cholesterol" min="20" max="100" required placeholder="e.g. 50">
            <div id="hdl-error" style="color: #ef4444; font-size: 0.875rem; display: none; margin-top: 0.25rem;">Value must be 20-100 mg/dL.</div>
          </div>
          <div>
            <label for="systolic-bp" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Systolic Blood Pressure (mmHg)</label>
            <input type="number" id="systolic-bp" name="systolic-bp" min="90" max="200" required placeholder="e.g. 120">
            <div id="sbp-error" style="color: #ef4444; font-size: 0.875rem; display: none; margin-top: 0.25rem;">Value must be 90-200 mmHg.</div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
           <div>
            <label for="bp-meds" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">On BP Medication?</label>
            <select id="bp-meds" name="bp-meds" required>
              <option value="no">No</option>
              <option value="yes">Yes</option>
            </select>
          </div>
          <div>
            <label for="diabetes" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Diabetes?</label>
            <select id="diabetes" name="diabetes" required>
              <option value="no">No</option>
              <option value="yes">Yes</option>
            </select>
          </div>
          <div>
            <label for="smoker" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Smoker?</label>
            <select id="smoker" name="smoker" required>
              <option value="no">No</option>
              <option value="yes">Yes</option>
            </select>
          </div>
        </div>
      </form>

      <div class="result-card" id="result-container" style="display: none;">
        <h3 style="margin-top: 0; color: var(--text-primary); font-size: 1.25rem;">Estimated 10-Year ASCVD Risk</h3>
        <div class="result-value" id="risk-result">--%</div>
        <p id="risk-category" style="margin-top: 0.5rem; font-weight: 600; color: var(--text-secondary);"></p>
        <p style="margin-top: 1rem; font-size: 0.9rem; color: var(--text-secondary);">
          This calculator provides an estimate based on the Pooled Cohort Equations. It is for informational purposes only and should not replace professional medical advice.
        </p>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding ASCVD Risk</h2>
      <p>Atherosclerotic Cardiovascular Disease (ASCVD) represents a significant global health burden. It encompasses a range of clinical conditions that arise from the buildup of plaque in the arterial walls, a process known as atherosclerosis. This plaque, primarily composed of cholesterol, fatty substances, cellular waste products, calcium, and fibrin, gradually narrows the arteries and stiffens them, impairing blood flow to vital organs and tissues. The most common and life-threatening manifestations of ASCVD include coronary artery disease (which can lead to myocardial infarction or heart attack), cerebrovascular disease (which can result in ischemic stroke or transient ischemic attack), and peripheral artery disease (which affects blood flow to the limbs, most commonly the legs).</p>

      <p>Estimating an individual's risk of developing ASCVD is a fundamental aspect of preventive cardiology. By identifying patients who are at an elevated risk of experiencing a cardiovascular event in the near future, healthcare providers can implement targeted interventions, such as lifestyle modifications and pharmacological therapies, to mitigate that risk. The 10-year ASCVD risk score is a widely utilized metric in clinical practice, providing a quantitative assessment of the probability that an individual will experience a first hard ASCVD event (defined as nonfatal myocardial infarction, coronary heart disease death, or fatal or nonfatal stroke) over the next decade.</p>

      <h3>The Pooled Cohort Equations (PCEs)</h3>
      <p>The calculation of the 10-year ASCVD risk is most commonly performed using the Pooled Cohort Equations (PCEs), which were introduced by the American College of Cardiology (ACC) and the American Heart Association (AHA) in their 2013 guideline on the assessment of cardiovascular risk. These equations were developed by analyzing data from several large, ethnically diverse, population-based cohorts in the United States, including the Atherosclerosis Risk in Communities (ARIC) study, the Cardiovascular Health Study (CHS), and the Coronary Artery Risk Development in Young Adults (CARDIA) study, among others.</p>

      <p>The PCEs integrate a specific set of clinical and demographic variables that have been robustly identified as independent predictors of ASCVD. These variables include:</p>
      <ul>
        <li><strong>Age:</strong> The risk of ASCVD increases significantly with advancing age. The equations are validated for individuals between 40 and 79 years of age. For those younger than 40, lifetime risk assessment may be more appropriate.</li>
        <li><strong>Sex:</strong> Men generally have a higher baseline risk of ASCVD compared to premenopausal women. However, women's risk increases substantially after menopause. The PCEs provide separate equations for men and women.</li>
        <li><strong>Race:</strong> The original PCEs provided specific equations for Non-Hispanic White and Non-Hispanic African American individuals, reflecting observed differences in risk profiles and outcomes in the derivation cohorts. Individuals of other racial or ethnic backgrounds are typically assessed using the equations for Non-Hispanic White populations, though this is recognized as an area requiring further refinement in risk prediction models.</li>
        <li><strong>Total Cholesterol and HDL Cholesterol:</strong> Elevated levels of total cholesterol and low levels of High-Density Lipoprotein (HDL) cholesterol are well-established atherogenic factors. The ratio of total to HDL cholesterol is often indicative of the overall lipid burden.</li>
        <li><strong>Systolic Blood Pressure (SBP):</strong> Hypertension is a major driver of vascular injury and atherosclerosis. The equations consider both the absolute SBP level and whether the patient is currently receiving treatment with blood pressure-lowering medication, as treated hypertension carries a different risk profile than untreated hypertension.</li>
        <li><strong>Diabetes Mellitus:</strong> The presence of diabetes is considered a significant risk equivalent for cardiovascular disease. It accelerates the atherosclerotic process and increases the likelihood of adverse events.</li>
        <li><strong>Smoking Status:</strong> Current cigarette smoking is one of the most potent modifiable risk factors for ASCVD. It promotes endothelial dysfunction, increases oxidative stress, and enhances thrombosis.</li>
      </ul>

      <h3>Methodology and Mathematical Formulation</h3>
      <p>The fundamental mathematical structure of the Pooled Cohort Equations is based on the Cox proportional hazards regression model. The Cox model estimates the hazard (or risk) of an event occurring at a specific time, given that the individual has survived up to that point. In the context of the PCEs, the model predicts the probability of a first hard ASCVD event occurring within a 10-year timeframe.</p>

      <p>The general form of the equation used to calculate the 10-year risk probability (P) is:</p>
      <div style="background: var(--card-bg); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); margin: 1rem 0; overflow-x: auto; font-family: var(--font-mono); text-align: center;">
        P = 1 - S<sub>10</sub><sup>exp(Sum - Mean_Sum)</sup>
      </div>

      <p>Where:</p>
      <ul>
        <li><strong>S<sub>10</sub>:</strong> Represents the baseline survival rate at 10 years for a specific demographic group (defined by sex and race). This is a constant derived from the cohort data. It essentially reflects the probability of surviving 10 years without an ASCVD event for a hypothetical individual with average risk factor levels.</li>
        <li><strong>Sum:</strong> Is the sum of the products of each individual risk factor value (often mathematically transformed, e.g., using natural logarithms) multiplied by its corresponding regression coefficient (beta weight). The specific variables, transformations, and coefficients differ depending on the demographic group (e.g., White Men, African American Women).</li>
        <li><strong>Mean_Sum:</strong> Is the mean value of the "Sum" calculated from the specific derivation cohort. It acts as an anchor point for the calculation.</li>
      </ul>

      <p>The calculation involves evaluating the complex interactions between variables. For example, in some equations, there are interaction terms (e.g., Natural Log of Age multiplied by Natural Log of Total Cholesterol), which acknowledge that the impact of a risk factor like cholesterol may vary depending on the patient's age. The detailed coefficients and baseline survival rates are published in the ACC/AHA guidelines and are hardcoded into the calculator logic.</p>

      <h3>Clinical Interpretation and Application</h3>
      <p>Once the 10-year risk score is calculated, it is typically categorized to guide clinical decision-making regarding preventive interventions, particularly the initiation of statin therapy. The ACC/AHA guidelines generally define the following risk categories:</p>
      <ul>
        <li><strong>Low Risk (&lt;5%):</strong> Lifestyle modifications (diet, exercise) are emphasized. Pharmacological intervention is generally not recommended unless specific risk enhancers are present.</li>
        <li><strong>Borderline Risk (5% to &lt;7.5%):</strong> A risk discussion between the patient and provider is recommended. If risk-enhancing factors are present, statin therapy may be considered.</li>
        <li><strong>Intermediate Risk (7.5% to &lt;20%):</strong> This group often benefits most from statin therapy. A moderate-intensity statin is frequently recommended, particularly if a risk discussion favors treatment. Coronary Artery Calcium (CAC) scoring may be used to further stratify risk if the decision is uncertain.</li>
        <li><strong>High Risk (&ge;20%):</strong> Initiation of high-intensity statin therapy is strongly recommended to aggressively lower LDL cholesterol and reduce the risk of imminent events.</li>
      </ul>

      <p>It is crucial to emphasize that the ASCVD risk calculator is a tool to facilitate shared decision-making, not a definitive diagnostic test. The calculated risk is an estimate for a population with similar characteristics, and individual patient factors must be carefully considered by a qualified healthcare professional. Other factors, known as "risk-enhancing factors" (such as family history of premature ASCVD, chronic kidney disease, metabolic syndrome, or certain inflammatory conditions), may influence treatment decisions, especially in patients classified as borderline or intermediate risk. Therefore, the calculator results should always be interpreted within the context of a comprehensive clinical evaluation.</p>
      <p>Check out our Square Footage Calculator for other helpful tools.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is ASCVD?</summary>
        <p>ASCVD stands for Atherosclerotic Cardiovascular Disease. It includes conditions like coronary heart disease (such as myocardial infarction), cerebrovascular disease (such as stroke), and peripheral artery disease. It is primarily caused by plaque buildup in the arterial walls.</p>
      </details>
      <details>
        <summary>How is the 10-year ASCVD risk calculated?</summary>
        <p>The 10-year ASCVD risk is estimated using the Pooled Cohort Equations (PCEs). The calculation incorporates several key risk factors: age, sex, race, total cholesterol, HDL cholesterol, systolic blood pressure, use of blood pressure-lowering medication, diabetes status, and smoking status.</p>
      </details>
      <details>
        <summary>What is considered a high ASCVD risk?</summary>
        <p>A 10-year ASCVD risk score of 20% or higher is generally considered high risk. A score between 7.5% and 19.9% is considered intermediate risk, 5% to 7.4% is borderline risk, and less than 5% is considered low risk. Treatment recommendations typically become more aggressive as the risk category increases.</p>
      </details>
      <details>
        <summary>Can I lower my ASCVD risk?</summary>
        <p>Yes, ASCVD risk can often be lowered through lifestyle modifications (such as eating a heart-healthy diet, exercising regularly, quitting smoking, and maintaining a healthy weight) and sometimes through medications like statins or blood pressure drugs, as prescribed by a healthcare provider.</p>
      </details>
      <details>
        <summary>Who should use this ASCVD risk calculator?</summary>
        <p>The calculator is generally intended for adults between the ages of 40 and 79 who do not already have cardiovascular disease. Individuals outside this age range or those with existing ASCVD should consult their doctor for a more personalized risk assessment.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    const form = document.getElementById('ascvd-form');
    const resultContainer = document.getElementById('result-container');
    const riskResult = document.getElementById('risk-result');
    const riskCategory = document.getElementById('risk-category');

    const inputs = ['age', 'sex', 'race', 'total-cholesterol', 'hdl-cholesterol', 'systolic-bp', 'bp-meds', 'diabetes', 'smoker'];
    const errorEls = {
      age: document.getElementById('age-error'),
      sex: document.getElementById('sex-error'),
      race: document.getElementById('race-error'),
      'total-cholesterol': document.getElementById('tc-error'),
      'hdl-cholesterol': document.getElementById('hdl-error'),
      'systolic-bp': document.getElementById('sbp-error')
    };

    function validateInput(id, value, min, max) {
      if (!errorEls[id]) return true;
      if (value === '' || isNaN(value) || value < min || value > max) {
        errorEls[id].style.display = 'block';
        return false;
      } else {
        errorEls[id].style.display = 'none';
        return true;
      }
    }

    function validateSelect(id, value) {
      if (!errorEls[id]) return true;
      if (value === '') {
        errorEls[id].style.display = 'block';
        return false;
      } else {
        errorEls[id].style.display = 'none';
        return true;
      }
    }

    function calculateRisk() {
      const ageRaw = document.getElementById('age').value;
      const sex = document.getElementById('sex').value;
      const race = document.getElementById('race').value;
      const tcRaw = document.getElementById('total-cholesterol').value;
      const hdlRaw = document.getElementById('hdl-cholesterol').value;
      const sbpRaw = document.getElementById('systolic-bp').value;
      const bpMeds = document.getElementById('bp-meds').value === 'yes' ? 1 : 0;
      const diabetes = document.getElementById('diabetes').value === 'yes' ? 1 : 0;
      const smoker = document.getElementById('smoker').value === 'yes' ? 1 : 0;

      let isValid = true;
      isValid = validateInput('age', ageRaw, 20, 79) && isValid;
      isValid = validateSelect('sex', sex) && isValid;
      isValid = validateSelect('race', race) && isValid;
      isValid = validateInput('total-cholesterol', tcRaw, 130, 320) && isValid;
      isValid = validateInput('hdl-cholesterol', hdlRaw, 20, 100) && isValid;
      isValid = validateInput('systolic-bp', sbpRaw, 90, 200) && isValid;

      if (!isValid) {
        resultContainer.style.display = 'none';
        return;
      }

      const age = parseFloat(ageRaw);
      const tc = parseFloat(tcRaw);
      const hdl = parseFloat(hdlRaw);
      const sbp = parseFloat(sbpRaw);

      let ln_age = Math.log(age);
      let ln_tc = Math.log(tc);
      let ln_hdl = Math.log(hdl);
      let ln_sbp = Math.log(sbp);

      let sum = 0;
      let mean_sum = 0;
      let baseline_survival = 0;

      // 2013 ACC/AHA Pooled Cohort Equations
      if (race === 'african_american' && sex === 'female') {
        sum = 17.114 * ln_age + 0.940 * ln_tc - 18.920 * ln_hdl + 4.475 * ln_age * ln_hdl + 29.291 * ln_sbp - 6.432 * ln_age * ln_sbp + bpMeds * (29.291 * ln_sbp - 6.432 * ln_age * ln_sbp) + smoker * 0.691 + diabetes * 0.874;
        // Correction for treated SBP, using same coefficient as untreated + extra if treated
        sum = 17.114 * ln_age + 0.940 * ln_tc - 18.920 * ln_hdl + 4.475 * ln_age * ln_hdl;
        if (bpMeds) {
            sum += 29.291 * ln_sbp - 6.432 * ln_age * ln_sbp;
        } else {
            sum += 27.820 * ln_sbp - 6.087 * ln_age * ln_sbp;
        }
        sum += smoker * 0.691 + diabetes * 0.874;

        mean_sum = 86.61;
        baseline_survival = 0.9533;
      } else if (race === 'african_american' && sex === 'male') {
        sum = 2.469 * ln_age + 0.302 * ln_tc - 0.307 * ln_hdl;
        if (bpMeds) {
            sum += 1.916 * ln_sbp;
        } else {
            sum += 1.809 * ln_sbp;
        }
        sum += smoker * 0.549 + diabetes * 0.645;

        mean_sum = 19.54;
        baseline_survival = 0.8954;
      } else if (sex === 'female') { // White or Other Female
        sum = -29.799 * ln_age + 4.884 * Math.pow(ln_age, 2) + 13.540 * ln_tc - 3.114 * ln_age * ln_tc - 13.578 * ln_hdl + 3.149 * ln_age * ln_hdl;
        if (bpMeds) {
             sum += 2.019 * ln_sbp;
        } else {
             sum += 1.957 * ln_sbp;
        }
        sum += smoker * 7.574 - 1.665 * ln_age * smoker + diabetes * 0.661;

        mean_sum = -29.18;
        baseline_survival = 0.9665;
      } else { // White or Other Male
        sum = 12.344 * ln_age + 11.853 * ln_tc - 2.664 * ln_age * ln_tc - 7.990 * ln_hdl + 1.769 * ln_age * ln_hdl;
        if (bpMeds) {
            sum += 1.797 * ln_sbp;
        } else {
            sum += 1.764 * ln_sbp;
        }
        sum += smoker * 7.837 - 1.795 * ln_age * smoker + diabetes * 0.658;

        mean_sum = 61.18;
        baseline_survival = 0.9144;
      }

      const risk = 1 - Math.pow(baseline_survival, Math.exp(sum - mean_sum));
      const riskPercentage = (risk * 100).toFixed(1);

      riskResult.textContent = riskPercentage + '%';

      let catText = '';
      if (riskPercentage < 5) {
        catText = 'Low Risk';
        riskResult.style.color = '#22c55e'; // green
      } else if (riskPercentage < 7.5) {
        catText = 'Borderline Risk';
        riskResult.style.color = '#eab308'; // yellow
      } else if (riskPercentage < 20) {
        catText = 'Intermediate Risk';
        riskResult.style.color = '#f97316'; // orange
      } else {
        catText = 'High Risk';
        riskResult.style.color = '#ef4444'; // red
      }
      riskCategory.textContent = catText;

      resultContainer.style.display = 'block';
    }

    inputs.forEach(id => {
      document.getElementById(id).addEventListener('input', calculateRisk);
      document.getElementById(id).addEventListener('change', calculateRisk);
    });

    // Initial check (won't show result until valid)
    calculateRisk();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
  </style>
</SiteLayout>
