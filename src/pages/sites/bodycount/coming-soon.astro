    ]
  },
  {
    icon: '🥗',
    title: 'Nutrition',
    description: 'Nutrition trackers, diet tools, and meal planners',
    total: 10,
    items: [
      { name: 'Chipotle Nutrition Calculator', searches: '80,000', status: 'published', href: '/bodycount/chipotle-nutrition-calculator' },
      { name: 'Nutrition Calculator', searches: '19,000', status: 'building', href: '' },
      { name: 'Starbucks Nutrition Calculator', searches: '11,000', status: 'building', href: '' },
      { name: 'Recipe Nutrition Calculator', searches: '5,800', status: 'building', href: '' },
      { name: 'Subway Nutrition Calculator', searches: '4,400', status: 'building', href: '' },
      { name: 'Chick Fil A Nutrition Calculator', searches: '2,400', status: 'building', href: '' },
      { name: 'Mcdonald\'S Nutrition Calculator', searches: '2,300', status: 'building', href: '' },
      { name: 'Cava Nutrition Calculator', searches: '2,000', status: 'building', href: '' }
    ]
  },
  {
    icon: '🤰',
    title: 'Pregnancy & Fertility',
    description: 'Due date, ovulation, and fertility tools',
    total: 9,
    items: [
      { name: 'Due Date Calculator', searches: '217,000', status: 'building', href: '' },
      { name: 'Pregnancy Calculator', searches: '129,750', status: 'published', href: '/bodycount/pregnancy-calculator' },
      { name: 'Ovulation Calculator', searches: '109,600', status: 'published', href: '/bodycount/ovulation-calculator' },
      { name: 'Conception Calculator', searches: '49,000', status: 'published', href: '/bodycount/conception-calculator' },
      { name: 'Pregnancy Due Date Calculator', searches: '16,000', status: 'building', href: '' },
      { name: 'Ivf Due Date Calculator', searches: '13,000', status: 'published', href: '/bodycount/ivf-due-date-calculator' },
      { name: 'Baby Due Date Calculator', searches: '9,900', status: 'building', href: '' },
      { name: 'Dog Pregnancy Calculator', searches: '3,100', status: 'building', href: '' }
    ]
  },
  {
    icon: '⚕️',
    title: 'Medical Calculators',
    description: 'Clinical calculators for healthcare professionals',
    total: 8,
    items: [
      { name: 'Bac Calculator', searches: '73,000', status: 'published', href: '/bodycount/bac-calculator' },
      { name: 'A1C Calculator', searches: '22,000', status: 'published', href: '/bodycount/a1c-calculator' },
      { name: 'Creatinine Clearance Calculator', searches: '19,000', status: 'published', href: '/bodycount/creatinine-clearance-calculator' },
      { name: 'Ascvd Risk Calculator', searches: '17,000', status: 'published', href: '/bodycount/ascvd-risk-calculator' },
      { name: 'Gfr Calculator', searches: '15,000', status: 'published', href: '/bodycount/gfr-calculator' },
      { name: 'Egfr Calculator', searches: '9,800', status: 'building', href: '' },
      { name: 'Gmi To A1C Calculator', searches: '3,600', status: 'building', href: '' },
      { name: 'Vbac Calculator', searches: '3,100', status: 'building', href: '' }
    ]
  },
  {
    icon: '🏥',
    title: 'Body Count',
    description: 'General health and wellness tools',
    total: 54,
    items: [
      { name: 'Peptide Calculator', searches: '103,000', status: 'published', href: '/bodycount/peptide-calculator' },
      { name: 'Height Calculator', searches: '73,650', status: 'published', href: '/bodycount/height-calculator' },
      { name: 'Sleep Calculator', searches: '70,500', status: 'building', href: '' },
