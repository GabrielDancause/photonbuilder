---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Coming Soon — Content Roadmap', description: 'See what tools, guides, and research are coming next to Body Count.', category: 'guides', published: '2026-03-15' };

const SITE_ID = 'bodycount';

const allPages = import.meta.glob('./*.astro', { eager: true });
