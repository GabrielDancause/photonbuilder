    title: 'Fitness & Body',
    description: 'BMI, TDEE, body fat, and fitness calculators',
    total: 53,
    items: [
      { name: 'Bmi Calculator', searches: '2,110,000', status: 'published', href: '/bodycount/bmi-calculator' },
      { name: 'Calorie Calculator', searches: '912,000', status: 'building', href: '' },
      { name: 'Tdee Calculator', searches: '385,000', status: 'published', href: '/bodycount/tdee-calculator' },
      { name: 'Calorie Deficit Calculator', searches: '230,000', status: 'published', href: '/bodycount/calorie-deficit-calculator' },
