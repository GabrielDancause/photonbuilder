---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Coming Soon — Content Roadmap', description: 'See what tools, guides, and research are coming next to Body Count.', category: 'guides', published: '2026-03-15' };

const SITE_ID = 'bodycount';

const allPages = import.meta.glob('./*.astro', { eager: true });
const publishedCount = Object.keys(allPages).filter(k => !k.includes('index') && !k.includes('coming-soon')).length;

const categories = [
  {
    icon: '💪',
    title: 'Fitness & Body',
    description: 'BMI, TDEE, body fat, and fitness calculators',
    total: 11,
    items: [
      { name: 'E2 Protein Overview', searches: '—', status: 'published', href: '/bodycount/e2-protein-overview' },
      { name: 'Starbucks Calorie Calculator', searches: '—', status: 'published', href: '/bodycount/starbucks-calorie-calculator' },
      { name: 'Protein Per Dollar', searches: '—', status: 'published', href: '/bodycount/protein-per-dollar' },
      { name: 'Calorie Deficit Calculator', searches: '—', status: 'published', href: '/bodycount/calorie-deficit-calculator' },
      { name: 'Body Fat Percentage Calculator', searches: '—', status: 'published', href: '/bodycount/body-fat-percentage-calculator' },
      { name: 'Protein Intake Calculator', searches: '—', status: 'published', href: '/bodycount/protein-intake-calculator' },
      { name: 'Tdee Calculator', searches: '—', status: 'published', href: '/bodycount/tdee-calculator' },
      { name: 'Tdee Calculator Free', searches: '—', status: 'published', href: '/bodycount/tdee-calculator-free' }
    ]
  },
  {
    icon: '🥗',
    title: 'Nutrition',
    description: 'Nutrition trackers, diet tools, and meal planners',
    total: 1,
    items: [
      { name: 'Chipotle Nutrition Calculator', searches: '—', status: 'published', href: '/bodycount/chipotle-nutrition-calculator' }
    ]
  },
  {
    icon: '🤰',
    title: 'Pregnancy & Fertility',
    description: 'Due date, ovulation, and fertility tools',
    total: 4,
    items: [
      { name: 'Pregnancy Calculator', searches: '—', status: 'published', href: '/bodycount/pregnancy-calculator' },
      { name: 'Conception Calculator', searches: '—', status: 'published', href: '/bodycount/conception-calculator' },
      { name: 'Ovulation Calculator', searches: '—', status: 'published', href: '/bodycount/ovulation-calculator' },
      { name: 'Ivf Due Date Calculator', searches: '—', status: 'published', href: '/bodycount/ivf-due-date-calculator' }
    ]
  },
  {
    icon: '⚕️',
    title: 'Medical Calculators',
    description: 'Clinical calculators for healthcare professionals',
    total: 5,
    items: [
      { name: 'Bac Calculator', searches: '—', status: 'published', href: '/bodycount/bac-calculator' },
      { name: 'Gfr Calculator', searches: '—', status: 'published', href: '/bodycount/gfr-calculator' },
      { name: 'Creatinine Clearance Calculator', searches: '—', status: 'published', href: '/bodycount/creatinine-clearance-calculator' },
      { name: 'Ascvd Risk Calculator', searches: '—', status: 'published', href: '/bodycount/ascvd-risk-calculator' },
      { name: 'A1C Calculator', searches: '—', status: 'published', href: '/bodycount/a1c-calculator' }
    ]
  },
  {
    icon: '🏥',
    title: 'Body Count',
    description: 'General health and wellness tools',
    total: 36,
    items: [
      { name: 'Height Calculator', searches: '—', status: 'published', href: '/bodycount/height-calculator' },
      { name: 'Chronological Age Calculator', searches: '—', status: 'published', href: '/bodycount/chronological-age-calculator' },
      { name: 'Hpv Screening Guide', searches: '—', status: 'published', href: '/bodycount/hpv-screening-guide' },
      { name: 'E2 Integration Patterns', searches: '—', status: 'published', href: '/bodycount/e2-integration-patterns' },
      { name: 'Hpv Vaccine Asia', searches: '—', status: 'published', href: '/bodycount/hpv-vaccine-asia' },
      { name: 'What Are Hpv Warts', searches: '—', status: 'published', href: '/bodycount/what-are-hpv-warts' },
      { name: 'Hpv Natural History', searches: '—', status: 'published', href: '/bodycount/hpv-natural-history' },
      { name: 'What Is Cervical Dysplasia', searches: '—', status: 'published', href: '/bodycount/what-is-cervical-dysplasia' }
    ]
  }
];
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID}>
  <style is:inline>
    .coming-soon-hero { text-align: center; padding: 3rem 1rem 2rem; max-width: 800px; margin: 0 auto; }
    .coming-soon-hero h1 { font-size: 2.2rem; margin-bottom: 0.5rem; background: linear-gradient(135deg, var(--accent), #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .coming-soon-hero p { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.6; }
    .stats-bar { display: flex; justify-content: center; gap: 2rem; padding: 1.5rem; margin: 0 auto 2rem; max-width: 700px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; }
    .stat { text-align: center; }
    .stat-number { font-size: 1.8rem; font-weight: 700; color: var(--accent); }
    .stat-label { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem; }
    .category-section { max-width: 900px; margin: 0 auto 2.5rem; padding: 0 1rem; }
    .category-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
    .category-header h2 { font-size: 1.4rem; margin: 0; }
    .category-count { background: var(--card-bg); border: 1px solid var(--border); padding: 0.15rem 0.6rem; border-radius: 20px; font-size: 0.75rem; color: var(--text-secondary); }
    .category-desc { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }
    .items-grid { display: grid; gap: 0.5rem; }
    .item-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; transition: border-color 0.2s; }
    .item-row:hover { border-color: var(--accent); }
    .item-row a { color: var(--text-primary); text-decoration: none; font-weight: 500; }
    .item-row a:hover { color: var(--accent); }
    .item-name { font-weight: 500; }
    .item-right { display: flex; align-items: center; gap: 1rem; }
    .item-searches { font-size: 0.8rem; color: var(--text-secondary); }
    .badge { font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; }
    .badge-published { background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }
    .badge-building { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
    .more-coming { text-align: center; padding: 1rem; color: var(--text-secondary); font-size: 0.9rem; border-top: 1px solid var(--border); margin-top: 0.5rem; }
    @media (max-width: 640px) { .stats-bar { flex-wrap: wrap; gap: 1rem; } .item-searches { display: none; } .coming-soon-hero h1 { font-size: 1.6rem; } }
  </style>

  <div class="coming-soon-hero">
    <h1>📋 Content Roadmap</h1>
    <p>Here's what's published and what's coming next.</p>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-number">{publishedCount}</div>
      <div class="stat-label">Published</div>
    </div>
    <div class="stat">
      <div class="stat-number">0</div>
      <div class="stat-label">In Pipeline</div>
    </div>
    <div class="stat">
      <div class="stat-number">5</div>
      <div class="stat-label">Categories</div>
    </div>
  </div>

  {categories.map(cat => (
    <div class="category-section">
      <div class="category-header">
        <span style="font-size:1.5rem">{cat.icon}</span>
        <h2>{cat.title}</h2>
        <span class="category-count">{cat.total} planned</span>
      </div>
      <p class="category-desc">{cat.description}</p>
      <div class="items-grid">
        {cat.items.map(item => (
          <div class="item-row">
            {item.status === 'published' && item.href ? (
              <a href={item.href}>{item.name}</a>
            ) : (
              <span class="item-name">{item.name}</span>
            )}
            <div class="item-right">
              <span class="item-searches">{item.searches}/mo</span>
              <span class={`badge ${item.status === 'published' ? 'badge-published' : 'badge-building'}`}>
                {item.status === 'published' ? '✓ Live' : '🔨 Building'}
              </span>
            </div>
          </div>
        ))}
      </div>
      {cat.total > 8 && (
        <div class="more-coming">+ {cat.total - 8} more {cat.title.toLowerCase()} coming soon</div>
      )}
    </div>
  ))}
</SiteLayout>
