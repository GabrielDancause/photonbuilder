        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      });
    });

    // Piercing diagram clicks
    function renderDetail(key) {
      const d = piercingData[key];
      if (!d) return;

      document.querySelectorAll('.piercing-dot').forEach(dot => dot.classList.remove('selected'));
      document.querySelector(`.piercing-dot[data-piercing="${key}"]`)?.classList.add('selected');

      document.getElementById('detail-empty').style.display = 'none';
      const el = document.getElementById('detail-content');
      el.classList.add('active');

      const painClass = d.pain <= 3 ? 'pain-low' : d.pain <= 6 ? 'pain-med' : 'pain-high';
      const diffClass = 'difficulty-' + d.difficulty;

      el.innerHTML = `
        <div class="detail-header">
          <h3>${d.name}</h3>
          <span class="difficulty-badge ${diffClass}">${d.difficulty}</span>
        </div>
        <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:1rem;">${d.desc}</p>
        <div class="detail-grid">
          <div class="detail-item">
            <div class="detail-item-label">Pain Level</div>
            <div class="detail-item-value">${d.pain}/10</div>
            <div class="pain-bar-track"><div class="pain-bar-fill ${painClass}" style="width:${d.pain * 10}%"></div></div>
          </div>
          <div class="detail-item">
            <div class="detail-item-label">Healing Time</div>
            <div class="detail-item-value">${d.healingWeeks}</div>
          </div>
          <div class="detail-item">
            <div class="detail-item-label">Average Cost</div>
            <div class="detail-item-value">${d.cost}</div>
          </div>
          <div class="detail-item">
            <div class="detail-item-label">Jewelry Types</div>
            <div class="detail-item-value" style="font-size:0.8rem;">${d.jewelry}</div>
          </div>
        </div>
        <div class="detail-item-label" style="margin-bottom:0.25rem;">Aftercare Notes</div>
        <div class="aftercare-summary">${d.aftercare}</div>
      `;
    }

    document.querySelectorAll('.piercing-dot').forEach(dot => {
      dot.addEventListener('click', () => renderDetail(dot.dataset.piercing));
    });

    // Comparison table
    const tbody = document.getElementById('compare-body');
    let sortCol = 'name';
    let sortAsc = true;

    function painDotsHtml(pain) {
      let html = '<span class="pain-dots">';
      for (let i = 1; i <= 10; i++) {
        const color = i <= 3 ? '#34d399' : i <= 6 ? '#fbbf24' : '#f87171';
        html += i <= pain
          ? `<span class="pain-dot-filled" style="background:${color}"></span>`
          : '<span class="pain-dot-empty"></span>';
      }
      return html + '</span>';
    }

    function renderTable() {
      const entries = Object.entries(piercingData);
      entries.sort((a, b) => {
        let va, vb;
        if (sortCol === 'name') { va = a[1].name; vb = b[1].name; }
        else if (sortCol === 'pain') { va = a[1].pain; vb = b[1].pain; }
        else if (sortCol === 'healing') { va = a[1].healingSort; vb = b[1].healingSort; }
        else if (sortCol === 'cost') { va = a[1].costSort; vb = b[1].costSort; }
        else if (sortCol === 'jewelry') { va = a[1].jewelry; vb = b[1].jewelry; }
        else if (sortCol === 'difficulty') {
          const order = { easy: 1, moderate: 2, advanced: 3 };
          va = order[a[1].difficulty]; vb = order[b[1].difficulty];
        }
        if (typeof va === 'string') return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
        return sortAsc ? va - vb : vb - va;
      });

      tbody.innerHTML = entries.map(([key, d]) => {
        const diffClass = 'difficulty-' + d.difficulty;
        return `<tr>
          <td style="font-weight:600;">${d.name}</td>
          <td>${painDotsHtml(d.pain)} <span style="color:var(--text-secondary);font-size:0.75rem;margin-left:4px;">${d.pain}</span></td>
          <td>${d.healingWeeks}</td>
          <td>${d.cost}</td>
          <td style="font-size:0.8rem;">${d.jewelry}</td>
          <td><span class="difficulty-badge ${diffClass}">${d.difficulty}</span></td>
        </tr>`;
      }).join('');

      document.querySelectorAll('#compare-table th').forEach(th => {
        th.classList.toggle('sorted', th.dataset.sort === sortCol);
        const arrow = th.querySelector('.sort-arrow');
        if (th.dataset.sort === sortCol) {
          arrow.innerHTML = sortAsc ? '&#9650;' : '&#9660;';
        } else {
          arrow.innerHTML = '&#9650;';
        }
      });
    }

    document.querySelectorAll('#compare-table th').forEach(th => {
      th.addEventListener('click', () => {
        if (sortCol === th.dataset.sort) { sortAsc = !sortAsc; }
        else { sortCol = th.dataset.sort; sortAsc = true; }
        renderTable();
      });
    });

    renderTable();

    // Quiz
    const quizQuestions = [
      {
        label: 'Pain Tolerance',
        text: 'How would you rate your pain tolerance?',
        options: [
          { text: 'Low — I want minimal pain', value: 'low' },
          { text: 'Medium — I can handle some discomfort', value: 'medium' },
          { text: 'High — pain doesn\'t bother me', value: 'high' }
