            <g class="piercing-dot" data-piercing="tragus">
              <circle class="dot-ring" cx="125" cy="205" r="12"/>
              <circle class="dot-core" cx="125" cy="205" r="4"/>
              <text class="piercing-label" x="96" y="200">Tragus</text>
            </g>

            <g class="piercing-dot" data-piercing="anti-tragus">
              <circle class="dot-ring" cx="132" cy="275" r="12"/>
              <circle class="dot-core" cx="132" cy="275" r="4"/>
              <text class="piercing-label" x="95" y="280">Anti-tragus</text>
            </g>

            <g class="piercing-dot" data-piercing="inner-conch">
              <circle class="dot-ring" cx="165" cy="200" r="12"/>
              <circle class="dot-core" cx="165" cy="200" r="4"/>
              <text class="piercing-label" x="177" y="204">Inner Conch</text>
            </g>

            <g class="piercing-dot" data-piercing="outer-conch">
              <circle class="dot-ring" cx="150" cy="165" r="12"/>
              <circle class="dot-core" cx="150" cy="165" r="4"/>
              <text class="piercing-label" x="113" y="162">Outer Conch</text>
            </g>

            <g class="piercing-dot" data-piercing="daith">
              <circle class="dot-ring" cx="158" cy="175" r="12"/>
              <circle class="dot-core" cx="158" cy="175" r="4"/>
              <text class="piercing-label" x="170" y="178">Daith</text>
            </g>

            <g class="piercing-dot" data-piercing="rook">
              <circle class="dot-ring" cx="172" cy="140" r="12"/>
              <circle class="dot-core" cx="172" cy="140" r="4"/>
              <text class="piercing-label" x="184" y="144">Rook</text>
            </g>

            <g class="piercing-dot" data-piercing="industrial">
              <circle class="dot-ring" cx="140" cy="82" r="12"/>
              <circle class="dot-core" cx="140" cy="82" r="4"/>
              <line x1="140" y1="82" x2="220" y2="155" stroke="var(--accent-color)" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.4"/>
              <circle class="dot-ring" cx="220" cy="155" r="12"/>
              <circle class="dot-core" cx="220" cy="155" r="4"/>
              <text class="piercing-label" x="222" y="145">Industrial</text>
            </g>

            <g class="piercing-dot" data-piercing="snug">
              <circle class="dot-ring" cx="155" cy="230" r="12"/>
              <circle class="dot-core" cx="155" cy="230" r="4"/>
              <text class="piercing-label" x="167" y="234">Snug</text>
            </g>

            <g class="piercing-dot" data-piercing="flat">
              <circle class="dot-ring" cx="190" cy="115" r="12"/>
              <circle class="dot-core" cx="190" cy="115" r="4"/>
              <text class="piercing-label" x="202" y="119">Flat</text>
            </g>
          </svg>
        </div>

        <div class="detail-panel">
          <div class="empty-state" id="detail-empty">
            Click a piercing on the ear diagram to see details
