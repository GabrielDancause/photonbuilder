    const quizContainer = document.getElementById('quiz-questions');
    let quizStep = 0;
    const quizAnswers = [];

    function renderQuiz() {
      quizContainer.innerHTML = quizQuestions.map((q, i) => `
        <div class="quiz-question ${i === 0 ? 'active' : ''}" data-step="${i}">
          <div class="quiz-q-label">Question ${i + 1} of ${quizQuestions.length}</div>
          <div class="quiz-q-text">${q.text}</div>
          <div class="quiz-options">
            ${q.options.map((opt, j) => `<button class="quiz-opt" data-step="${i}" data-value="${opt.value}">${opt.text}</button>`).join('')}
