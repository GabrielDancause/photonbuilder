        </div>
      `).join('');

      quizContainer.querySelectorAll('.quiz-opt').forEach(btn => {
        btn.addEventListener('click', () => {
          const step = parseInt(btn.dataset.step);
          quizAnswers[step] = btn.dataset.value;
          quizStep = step + 1;

          if (quizStep >= quizQuestions.length) {
            showQuizResults();
          } else {
            quizContainer.querySelectorAll('.quiz-question').forEach(q => q.classList.remove('active'));
            quizContainer.querySelector(`[data-step="${quizStep}"]`).classList.add('active');
          }
          updateQuizProgress();
        });
      });
    }

    function updateQuizProgress() {
      const pct = Math.round((quizStep / quizQuestions.length) * 100);
      document.getElementById('quiz-step-text').textContent = quizStep >= quizQuestions.length ? 'Done!' : `Question ${quizStep + 1} of ${quizQuestions.length}`;
      document.getElementById('quiz-pct-text').textContent = pct + '%';
      document.getElementById('quiz-bar-fill').style.width = pct + '%';
    }

    function showQuizResults() {
      const [painTol, budget, style, patience] = quizAnswers;

      const scores = {};
      Object.entries(piercingData).forEach(([key, d]) => {
        let score = 50;

        // Pain tolerance scoring
        if (painTol === 'low') { score += (10 - d.pain) * 5; if (d.pain > 5) score -= 20; }
        else if (painTol === 'medium') { score += d.pain <= 6 ? 15 : -10; }
        else { score += 10; }

        // Budget scoring
        if (budget === 'budget') { score += d.costSort <= 40 ? 20 : d.costSort <= 55 ? 0 : -15; }
        else if (budget === 'mid') { score += d.costSort <= 60 ? 15 : 0; }
        else { score += 10; }

        // Style scoring
        if (style === 'subtle') {
          if (['lobe', 'upper-lobe', 'helix', 'flat'].includes(key)) score += 25;
          if (['industrial', 'snug'].includes(key)) score -= 15;
        } else if (style === 'trendy') {
          if (['forward-helix', 'tragus', 'helix', 'flat', 'conch'].includes(key) || key === 'inner-conch' || key === 'outer-conch') score += 25;
        } else if (style === 'bold') {
          if (['industrial', 'inner-conch', 'daith'].includes(key)) score += 25;
          if (['lobe', 'upper-lobe'].includes(key)) score -= 10;
        } else if (style === 'unique') {
          if (['daith', 'rook', 'snug', 'anti-tragus'].includes(key)) score += 25;
          if (['lobe', 'helix'].includes(key)) score -= 10;
        }

        // Patience scoring
        if (patience === 'fast') { score += d.healingSort <= 10 ? 30 : d.healingSort <= 35 ? -5 : -20; }
        else if (patience === 'moderate') { score += d.healingSort <= 35 ? 15 : 0; }
        else { score += 10; }

        scores[key] = score;
      });

      const top3 = Object.entries(scores).sort((a, b) => b[1] - a[1]).slice(0, 3);

      const reasons = {
        'lobe': 'Minimal pain, fast healing, and affordable — the perfect starter piercing.',
        'upper-lobe': 'Low pain with a slightly elevated look. Great for building an ear stack.',
        'helix': 'Classic cartilage piercing that works with almost any style.',
        'forward-helix': 'Trendy and eye-catching, perfect for the curated ear look.',
        'tragus': 'Stylish and subtle, a conversation starter without being too bold.',
        'anti-tragus': 'Uncommon placement that sets you apart from the crowd.',
        'inner-conch': 'Versatile placement with room for statement pieces or delicate studs.',
        'outer-conch': 'A balanced choice — visible enough to show off but not overwhelming.',
        'daith': 'Unique placement with beautiful jewelry options. A real head-turner.',
        'rook': 'Nestled in a cartilage fold for a sheltered, interesting look.',
        'industrial': 'The boldest ear piercing — a straight bar across the upper ear.',
        'snug': 'Rare and eye-catching. For those who want something truly uncommon.',
        'flat': 'Clean canvas for decorative tops. Subtle yet trendy.'
      };

      const listEl = document.getElementById('quiz-results-list');
      listEl.innerHTML = top3.map(([key, score], i) => {
        const d = piercingData[key];
        return `<div class="quiz-result-card">
          <div class="quiz-result-rank">#${i + 1} Pick</div>
          <div class="quiz-result-name">${d.name}</div>
          <div class="quiz-result-reason">${reasons[key]} Pain: ${d.pain}/10 · Healing: ${d.healingWeeks} · Cost: ${d.cost}</div>
        </div>`;
      }).join('');

      quizContainer.style.display = 'none';
      document.getElementById('quiz-results').classList.add('active');
    }

    document.getElementById('quiz-restart').addEventListener('click', () => {
      quizStep = 0;
      quizAnswers.length = 0;
      quizContainer.style.display = 'block';
      document.getElementById('quiz-results').classList.remove('active');
      quizContainer.querySelectorAll('.quiz-question').forEach(q => q.classList.remove('active'));
      quizContainer.querySelector('[data-step="0"]').classList.add('active');
      updateQuizProgress();
    });

    renderQuiz();
    updateQuizProgress();

    // FAQ accordion
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const wasOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!wasOpen) item.classList.add('open');
      });
    });
  </script>
</SiteLayout>
