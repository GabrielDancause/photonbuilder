            <!-- Lobe area -->
            <path d="M115,330 C108,340 110,358 125,362 C140,366 155,358 160,345 C165,332 158,318 148,312" fill="none" stroke="var(--border-color)" stroke-width="1.5" opacity="0.4"/>

            <!-- Piercing dots -->
            <g class="piercing-dot" data-piercing="lobe">
              <circle class="dot-ring" cx="135" cy="350" r="12"/>
              <circle class="dot-core" cx="135" cy="350" r="4"/>
              <text class="piercing-label" x="147" y="354">Lobe</text>
            </g>

            <g class="piercing-dot" data-piercing="upper-lobe">
              <circle class="dot-ring" cx="148" cy="318" r="12"/>
              <circle class="dot-core" cx="148" cy="318" r="4"/>
              <text class="piercing-label" x="160" y="322">Upper Lobe</text>
            </g>

            <g class="piercing-dot" data-piercing="helix">
              <circle class="dot-ring" cx="112" cy="110" r="12"/>
              <circle class="dot-core" cx="112" cy="110" r="4"/>
              <text class="piercing-label" x="82" y="106">Helix</text>
            </g>

            <g class="piercing-dot" data-piercing="forward-helix">
              <circle class="dot-ring" cx="172" cy="88" r="12"/>
              <circle class="dot-core" cx="172" cy="88" r="4"/>
