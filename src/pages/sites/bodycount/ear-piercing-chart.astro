            <!-- Inner ear details -->
            <path d="M175,100 C200,105 220,125 225,155 C230,185 220,210 205,225 C190,240 175,240 168,230" fill="none" stroke="var(--border-color)" stroke-width="1.8"/>
            <path d="M168,230 C160,218 162,200 170,185 C178,170 175,155 165,148 C155,141 142,148 138,162 C134,176 140,195 135,210 C130,225 118,238 112,248" fill="none" stroke="var(--border-color)" stroke-width="1.8"/>
