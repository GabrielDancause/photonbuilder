---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool", title: "Ear Piercing Chart — Interactive Guide to All Ear Piercing Types", description: "Interactive ear piercing chart with pain levels, healing times, costs, and aftercare. Click each piercing location to learn more. Take our quiz to find your perfect piercing.", published: "2026-03-29" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Ear Piercing Chart & Guide",
  "url": "https://bodycount.photonbuilder.com/ear-piercing-chart.html",
  "description": "Interactive ear piercing chart with pain levels, healing times, costs, and aftercare info for every ear piercing type. Includes a quiz to find your ideal piercing.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the least painful ear piercing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard lobe piercing is the least painful ear piercing, typically rated 2-3 out of 10 on the pain scale. The lobe is soft tissue with fewer nerve endings compared to cartilage piercings. Upper lobe piercings are also relatively painless."
      }
    },
    {
      "@type": "Question",
      "name": "How long do ear piercings take to heal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Healing times vary by location. Lobe piercings heal in 6-8 weeks, while cartilage piercings like helix, tragus, and conch take 6-12 months. Industrial piercings can take 9-12 months. Daith and rook piercings typically need 6-9 months to fully heal."
      }
    },
    {
      "@type": "Question",
      "name": "How much do ear piercings cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard lobe piercings cost $20-$50, while cartilage piercings range from $30-$80. Specialty piercings like industrial or daith can cost $40-$90. Prices vary by location, studio reputation, and jewelry quality. Always choose a reputable piercer over the cheapest option."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best ear piercing for beginners?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard lobe piercing is the best choice for beginners due to its low pain level, fast healing time (6-8 weeks), affordable cost, and wide jewelry options. Upper lobe and helix piercings are also good beginner-friendly options if you want something slightly more unique."
      }
    },
    {
      "@type": "Question",
      "name": "How do I clean a new ear piercing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Clean your piercing 2-3 times daily with sterile saline solution (0.9% sodium chloride). Spray or soak the area for 5 minutes. Avoid touching with unwashed hands, rotating the jewelry, using alcohol or hydrogen peroxide, or submerging in pools or hot tubs until fully healed."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Ear Piercing Chart — Interactive Guide to All Ear Piercing Types"
  description="Interactive ear piercing chart with pain levels, healing times, costs, and aftercare. Click each piercing location to learn more. Take our quiz to find your perfect piercing."
  canonical="https://bodycount.photonbuilder.com/ear-piercing-chart"
  schema={schema}
>
  <style>
    :root {
      --bg-color: #060c0a;
      --card-bg: #0c1410;
      --border-color: #1a2a24;
      --accent-color: #2DB89A;
      --accent-hover: #24987f;
      --text-primary: #c8e0d8;
      --text-secondary: #888888;
      --font-ui: 'Inter', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-ui);
      background-color: var(--bg-color);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .container { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }

    header { text-align: center; margin-bottom: 2rem; }

    h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; color: #ffffff; }

    p.subtitle { color: var(--text-secondary); font-size: 1rem; max-width: 600px; margin: 0 auto; }

    h2 { font-size: 1.4rem; font-weight: 700; color: #ffffff; margin-bottom: 1rem; }

    h3 { font-size: 1.1rem; font-weight: 600; color: #ffffff; margin-bottom: 0.5rem; }

    .card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    /* Tabs */
    .tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .tab-btn {
      padding: 0.5rem 1rem;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      background: var(--card-bg);
      color: var(--text-secondary);
      cursor: pointer;
      font-size: 0.85rem;
      font-weight: 600;
      font-family: var(--font-ui);
      transition: all 0.2s;
    }

    .tab-btn:hover { border-color: var(--accent-color); color: var(--text-primary); }

    .tab-btn.active {
      background: var(--accent-color);
      color: #ffffff;
      border-color: var(--accent-color);
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.3s ease; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Ear Diagram */
    .ear-diagram-section {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      align-items: start;
    }

    .ear-svg-wrap {
      position: relative;
      width: 100%;
      max-width: 360px;
      margin: 0 auto;
    }

    .ear-svg-wrap svg { width: 100%; height: auto; }

    .piercing-dot {
      cursor: pointer;
      transition: all 0.2s;
    }

    .piercing-dot circle.dot-ring {
      fill: var(--accent-color);
      opacity: 0.3;
      transition: opacity 0.2s;
    }

    .piercing-dot circle.dot-core {
      fill: var(--accent-color);
      transition: r 0.2s;
    }

    .piercing-dot:hover circle.dot-ring { opacity: 0.6; }
    .piercing-dot:hover circle.dot-core { r: 5; }

    .piercing-dot.selected circle.dot-ring { opacity: 0.7; fill: #ffffff; }
    .piercing-dot.selected circle.dot-core { fill: #ffffff; r: 5; }

    .piercing-label {
      font-size: 9px;
      fill: var(--text-secondary);
      pointer-events: none;
      font-family: var(--font-ui);
      font-weight: 600;
    }

    .detail-panel {
      min-height: 300px;
    }

    .detail-panel .empty-state {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 300px;
      color: var(--text-secondary);
      font-size: 0.9rem;
      text-align: center;
    }

    .detail-content { display: none; }
    .detail-content.active { display: block; animation: fadeIn 0.3s ease; }

    .detail-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .detail-header h3 { margin: 0; font-size: 1.25rem; }

    .difficulty-badge {
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .difficulty-easy { background: #0d3320; color: #34d399; }
    .difficulty-moderate { background: #332b0d; color: #fbbf24; }
    .difficulty-advanced { background: #330d0d; color: #f87171; }

    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .detail-item {
      background: var(--bg-color);
      border-radius: 8px;
      padding: 0.75rem;
    }

    .detail-item-label {
      font-size: 0.7rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
    }

    .detail-item-value {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    /* Pain bar */
    .pain-bar-track {
      width: 100%;
      height: 6px;
      background: var(--bg-color);
      border-radius: 3px;
      margin-top: 0.4rem;
      overflow: hidden;
    }

    .pain-bar-fill {
      height: 100%;
      border-radius: 3px;
      transition: width 0.4s ease;
    }

    .pain-low { background: #34d399; }
    .pain-med { background: #fbbf24; }
    .pain-high { background: #f87171; }

    .aftercare-summary {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.5;
      margin-top: 0.5rem;
    }

    /* Comparison Table */
    .table-wrap { overflow-x: auto; }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }

    th {
      text-align: left;
      padding: 0.75rem;
      border-bottom: 2px solid var(--border-color);
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }

    th:hover { color: var(--accent-color); }

    th .sort-arrow {
      margin-left: 0.3rem;
      font-size: 0.65rem;
      opacity: 0.4;
    }

    th.sorted .sort-arrow { opacity: 1; color: var(--accent-color); }

    td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:hover td { background: rgba(45, 184, 154, 0.04); }

    .pain-dots {
      display: inline-flex;
      gap: 3px;
    }

    .pain-dot-filled {
      width: 8px; height: 8px; border-radius: 50%;
    }

    .pain-dot-empty {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--border-color);
    }

    /* Quiz */
    .quiz-section { }

    .quiz-progress {
      display: flex;
      justify-content: space-between;
      font-size: 0.8rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
    }

    .quiz-bar {
      width: 100%;
      height: 6px;
      background: var(--bg-color);
      border-radius: 3px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }

    .quiz-bar-fill {
      height: 100%;
      background: var(--accent-color);
      border-radius: 3px;
      transition: width 0.3s ease;
    }

    .quiz-question { display: none; }
    .quiz-question.active { display: block; animation: fadeIn 0.3s ease; }

    .quiz-q-label {
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .quiz-q-text {
      font-size: 1.1rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 1rem;
    }

    .quiz-options { display: flex; flex-direction: column; gap: 0.5rem; }

    .quiz-opt {
      padding: 0.75rem 1rem;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      background: var(--bg-color);
      color: var(--text-primary);
      cursor: pointer;
      font-size: 0.9rem;
      font-family: var(--font-ui);
      text-align: left;
      transition: all 0.2s;
    }

    .quiz-opt:hover {
      border-color: var(--accent-color);
      background: rgba(45, 184, 154, 0.08);
    }

    .quiz-results { display: none; }
    .quiz-results.active { display: block; animation: fadeIn 0.3s ease; }

    .quiz-result-card {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 0.75rem;
    }

    .quiz-result-rank {
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .quiz-result-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: #ffffff;
      margin: 0.25rem 0;
    }

    .quiz-result-reason {
      font-size: 0.85rem;
      color: var(--text-secondary);
    }

    .quiz-restart {
      display: inline-block;
      margin-top: 1rem;
      padding: 0.6rem 1.2rem;
      background: var(--accent-color);
      color: #ffffff;
      border: none;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      font-family: var(--font-ui);
      transition: background 0.2s;
    }

    .quiz-restart:hover { background: var(--accent-hover); }

    /* Aftercare */
    .aftercare-columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .aftercare-list {
      list-style: none;
      padding: 0;
    }

    .aftercare-list li {
      padding: 0.4rem 0;
      font-size: 0.85rem;
      color: var(--text-primary);
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .aftercare-list li .icon {
      flex-shrink: 0;
      font-size: 0.9rem;
      margin-top: 0.1rem;
    }

    .do-icon { color: #34d399; }
    .dont-icon { color: #f87171; }

    .aftercare-heading {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
    }

    .aftercare-heading.do-heading { color: #34d399; }
    .aftercare-heading.dont-heading { color: #f87171; }

    /* FAQ */
    .faq-item {
      border-bottom: 1px solid var(--border-color);
    }

    .faq-item:last-child { border-bottom: none; }

    .faq-question {
      width: 100%;
      padding: 1rem 0;
      background: none;
      border: none;
      color: #ffffff;
      font-size: 0.95rem;
      font-weight: 600;
      text-align: left;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: var(--font-ui);
    }

    .faq-question:hover { color: var(--accent-color); }

    .faq-arrow {
      font-size: 0.75rem;
      transition: transform 0.2s;
      color: var(--text-secondary);
    }

    .faq-item.open .faq-arrow { transform: rotate(180deg); }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .faq-answer-inner {
      padding-bottom: 1rem;
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .faq-item.open .faq-answer { max-height: 300px; }

    /* Responsive */
    @media (max-width: 700px) {
      .ear-diagram-section {
        grid-template-columns: 1fr;
      }

      .detail-panel { min-height: auto; }

      .detail-grid { grid-template-columns: 1fr; }

      .aftercare-columns { grid-template-columns: 1fr; }

      h1 { font-size: 1.5rem; }

      .tabs { gap: 0.35rem; }
      .tab-btn { font-size: 0.75rem; padding: 0.4rem 0.75rem; }
    }

    .intro-text {
      font-size: 0.9rem;
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 2rem;
    }

    .intro-text p { margin-bottom: 0.75rem; }
  </style>

  <div class="container">
    <div style="background:rgba(224,90,90,0.08);border:1px solid rgba(224,90,90,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1.5rem;">
