---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Interactive Macro Nutrient Calculator | bodycount',
  description: 'Calculate your TDEE and perfect macro split for fat loss, maintenance, or muscle growth. Interactive tool visualizing calories, protein, carbs, and fat.',
  category: 'calculator',
  keywords: ["macro calculator", "TDEE calculator", "macro split", "protein requirements", "calorie deficit calculator", "bodybuilding macros", "nutrition calculator"]
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Interactive Macro Nutrient Calculator | bodycount",
    "description": "Calculate your TDEE and perfect macro split for fat loss, maintenance, or muscle growth. Interactive tool visualizing calories, protein, carbs, and fat.",
    "author": {
      "@type": "Organization",
      "name": "bodycount"
    },
    "publisher": {
      "@type": "Organization",
      "name": "bodycount"
    },
    "datePublished": "2026-03-22",
    "dateModified": "2026-03-22"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is my TDEE calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This calculator uses the highly accurate Mifflin-St Jeor equation to estimate your Basal Metabolic Rate (BMR), then multiplies it by an activity multiplier based on your lifestyle to determine your Total Daily Energy Expenditure (TDEE)."
        }
      },
      {
        "@type": "Question",
        "name": "What is the best macro split for losing fat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For fat loss, a high-protein approach is generally best to preserve muscle while in a calorie deficit. A common and effective split is 40% protein, 40% carbs, and 20% fat, or 30% protein, 40% carbs, and 30% fat. The most important factor is remaining in a caloric deficit."
        }
      },
      {
        "@type": "Question",
        "name": "How much protein do I actually need to build muscle?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most research suggests that 0.7 to 1 gram of protein per pound of body weight (1.6 to 2.2 grams per kg) is optimal for maximizing muscle growth when combined with resistance training. Consuming more than this offers little additional benefit for muscle building."
        }
      },
      {
        "@type": "Question",
        "name": "Should I adjust my macros on workout days vs rest days?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While advanced athletes sometimes use 'carb cycling' (more carbs on training days, fewer on rest days), most people get excellent results simply hitting the same macro targets consistently every day. Consistency is easier to track and maintain."
        }
      },
      {
        "@type": "Question",
        "name": "Why are fats important in my macro split?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dietary fats are essential for hormone production (like testosterone), absorbing fat-soluble vitamins (A, D, E, K), and maintaining cell membrane health. It's generally recommended not to let fats drop below 20% of your total daily calories for extended periods."
        }
      }
    ]
  }
]);
---

<SiteLayout site="bodycount" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <!-- HERO -->
  <section class="mill-hero">
    <div class="mill-hero-badge">INTERACTIVE CALCULATOR</div>
    <h1>The Ultimate <em>Macro Nutrient</em> Calculator</h1>
    <p class="mill-hero-hook">Your body burns <strong>1,800-2,400 cal/day just existing</strong>. <br/>Find your exact numbers to crush your goals.</p>
    <div class="mill-hero-stats">
      <div class="mill-stat">
        <span class="mill-stat-num">4</span>
        <span class="mill-stat-label">Cals per 1g Protein</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num">4</span>
        <span class="mill-stat-label">Cals per 1g Carbs</span>
      </div>
      <div class="mill-stat">
        <span class="mill-stat-num">9</span>
        <span class="mill-stat-label">Cals per 1g Fat</span>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="mill-section">
    <h2 class="mill-section-title">Dial In Your Nutrition</h2>
    <p class="mill-section-sub">Enter your stats to find your Total Daily Energy Expenditure (TDEE) and optimal macro split.</p>

    <div class="mill-calc-container">
      <div class="mill-calc-inputs">
        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="calc-gender">Gender</label>
            <select id="calc-gender">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </div>
          <div class="mill-input-group">
            <label for="calc-age">Age</label>
            <input type="number" id="calc-age" min="15" max="100" value="30" />
          </div>
        </div>

        <div class="mill-input-row">
          <div class="mill-input-group">
            <label for="calc-weight">Weight (lbs)</label>
            <input type="number" id="calc-weight" min="80" max="400" value="180" />
          </div>
          <div class="mill-input-group">
            <label for="calc-height-ft">Height</label>
            <div class="mill-height-wrap">
              <input type="number" id="calc-height-ft" min="4" max="7" value="5" placeholder="ft" />
              <input type="number" id="calc-height-in" min="0" max="11" value="10" placeholder="in" />
            </div>
          </div>
        </div>

        <div class="mill-input-group">
          <label for="calc-activity">Activity Level</label>
          <select id="calc-activity">
            <option value="1.2">Sedentary (office job, little/no exercise)</option>
            <option value="1.375">Lightly Active (light exercise 1-3 days/week)</option>
            <option value="1.55" selected>Moderately Active (moderate exercise 3-5 days/week)</option>
            <option value="1.725">Very Active (heavy exercise 6-7 days/week)</option>
            <option value="1.9">Extra Active (very heavy exercise, physical job)</option>
          </select>
        </div>

        <div class="mill-input-group">
          <label for="calc-goal">Your Primary Goal</label>
          <select id="calc-goal">
            <option value="lose">Lose Fat (-500 cal/day)</option>
            <option value="maintain" selected>Maintain Weight</option>
            <option value="build">Build Muscle (+500 cal/day)</option>
          </select>
        </div>

        <div class="mill-input-group">
          <label for="calc-split">Macro Split Preference</label>
          <select id="calc-split">
            <option value="balanced">Balanced (30% P / 40% C / 30% F)</option>
            <option value="high-protein" selected>High Protein / Lower Carb (40% P / 30% C / 30% F)</option>
            <option value="low-carb">Low Carb / High Fat (30% P / 20% C / 50% F)</option>
            <option value="high-carb">High Carb / Lower Fat (30% P / 50% C / 20% F)</option>
            <option value="custom">Custom Split...</option>
          </select>
        </div>

        <div id="custom-split-wrap" class="mill-input-row" style="display:none; align-items:flex-end;">
            <div class="mill-input-group">
                <label>Protein %</label>
                <input type="number" id="custom-p" min="10" max="80" value="30" />
            </div>
            <div class="mill-input-group">
                <label>Carbs %</label>
                <input type="number" id="custom-c" min="10" max="80" value="40" />
            </div>
            <div class="mill-input-group">
                <label>Fat %</label>
                <input type="number" id="custom-f" min="10" max="80" value="30" />
            </div>
        </div>
        <div id="custom-error" style="color:#ff6b6b; font-size:0.8rem; display:none; margin-top:-10px; margin-bottom:10px;">Total must equal 100%</div>

        <button id="calc-btn" class="mill-btn">Calculate My Macros</button>
      </div>

      <!-- RESULTS -->
      <div class="mill-calc-results" id="results-panel" style="display:none;">
        <div class="mill-result-header">
          <div class="mill-result-title">Your Daily Targets</div>
          <div class="mill-result-age" style="font-size:2rem; color:var(--accent-color, #E05A5A); margin: 10px 0;"><strong id="res-cals">—</strong> <span style="font-size:1rem; color:var(--text-secondary);">Calories</span></div>
          <div class="mill-result-years">TDEE: <span id="res-tdee">—</span> cal/day</div>
        </div>

        <!-- MACRO CIRCLES -->
        <div class="mill-milestones" id="macro-circles" style="grid-template-columns: repeat(3, 1fr);">
            <div class="mill-milestone" style="border-color: #3b82f6;">
                <div style="font-size:0.8rem; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px; margin-bottom:5px;">Protein</div>
                <div style="font-size:1.8rem; font-weight:700; color:#3b82f6;" id="res-p-g">—g</div>
                <div style="font-size:0.85rem; color:var(--text-secondary); margin-top:5px;"><span id="res-p-cal">—</span> cal (<span id="res-p-pct">—</span>%)</div>
            </div>
            <div class="mill-milestone" style="border-color: #f59e0b;">
                <div style="font-size:0.8rem; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px; margin-bottom:5px;">Carbs</div>
                <div style="font-size:1.8rem; font-weight:700; color:#f59e0b;" id="res-c-g">—g</div>
                <div style="font-size:0.85rem; color:var(--text-secondary); margin-top:5px;"><span id="res-c-cal">—</span> cal (<span id="res-c-pct">—</span>%)</div>
            </div>
            <div class="mill-milestone" style="border-color: #ef4444;">
                <div style="font-size:0.8rem; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px; margin-bottom:5px;">Fat</div>
                <div style="font-size:1.8rem; font-weight:700; color:#ef4444;" id="res-f-g">—g</div>
                <div style="font-size:0.85rem; color:var(--text-secondary); margin-top:5px;"><span id="res-f-cal">—</span> cal (<span id="res-f-pct">—</span>%)</div>
            </div>
        </div>

        <!-- VISUALIZER -->
        <div class="mill-chart-wrap" style="padding-top:1rem;">
          <div class="mill-chart-title">Macro Distribution</div>
          <div style="height: 20px; width:100%; display:flex; border-radius:10px; overflow:hidden; margin: 15px 0;">
            <div id="bar-p" style="background:#3b82f6; width:33.3%; transition:width 0.5s;"></div>
            <div id="bar-c" style="background:#f59e0b; width:33.3%; transition:width 0.5s;"></div>
            <div id="bar-f" style="background:#ef4444; width:33.3%; transition:width 0.5s;"></div>
          </div>
          <div class="mill-chart-legend">
            <span><i class="mill-legend-dot" style="background:#3b82f6;"></i> Protein</span>
            <span><i class="mill-legend-dot" style="background:#f59e0b;"></i> Carbs</span>
            <span><i class="mill-legend-dot" style="background:#ef4444;"></i> Fat</span>
          </div>
        </div>

        <!-- MEAL PLAN BUILDER -->
        <div class="mill-chart-wrap" style="margin-top:20px;">
          <div class="mill-chart-title" style="display:flex; justify-content:space-between; align-items:center;">
            <span>Meal Plan Distribution</span>
            <select id="meal-count" style="width:120px; padding:4px 8px; font-size:0.8rem; background:var(--bg-color, #060c0a); color:white; border:1px solid var(--border-color, #152040); border-radius:4px;">
                <option value="3">3 Meals</option>
                <option value="4" selected>4 Meals</option>
                <option value="5">5 Meals</option>
            </select>
          </div>
          <div id="meal-table-container" style="margin-top:15px; overflow-x:auto;">
            <table style="width:100%; border-collapse:collapse; font-size:0.9rem; text-align:left;">
                <thead>
                    <tr style="border-bottom:1px solid rgba(255,255,255,0.1); color:var(--text-secondary);">
                        <th style="padding:8px 4px; font-weight:normal;">Meal</th>
                        <th style="padding:8px 4px; font-weight:normal;">Cals</th>
                        <th style="padding:8px 4px; font-weight:normal; color:#3b82f6;">Pro (g)</th>
                        <th style="padding:8px 4px; font-weight:normal; color:#f59e0b;">Carb (g)</th>
                        <th style="padding:8px 4px; font-weight:normal; color:#ef4444;">Fat (g)</th>
                    </tr>
                </thead>
                <tbody id="meal-table-body">
                </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- THE 3 LEVERS -->
  <section class="mill-section">
    <h2 class="mill-section-title">The Big Three Macros</h2>
    <div class="mill-levers">
      <div class="mill-lever-card">
        <div class="mill-lever-icon" style="color:#3b82f6;">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M18 4L4 12v12l14 8 14-8V12L18 4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M4 12l14 8 14-8M18 20v12" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        </div>
        <h3>Protein</h3>
        <p>The building block of muscle. Protein has the highest thermic effect of food (TEF), meaning your body burns more calories just digesting it compared to carbs or fats. Essential for recovery and satiety.</p>
        <div class="mill-lever-impact">Calories/Gram: <strong style="color:#3b82f6;">4</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon" style="color:#f59e0b;">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="14" stroke="currentColor" stroke-width="2"/><path d="M12 18h12M18 12v12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h3>Carbohydrates</h3>
        <p>Your body's preferred primary energy source. Carbs fuel intense workouts and replenish muscle glycogen. While you can survive without them, optimal performance usually requires adequate carbohydrate intake.</p>
        <div class="mill-lever-impact">Calories/Gram: <strong style="color:#f59e0b;">4</strong></div>
      </div>
      <div class="mill-lever-card">
        <div class="mill-lever-icon" style="color:#ef4444;">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><path d="M18 4c-6 6-10 12-10 18a10 10 0 0020 0c0-6-4-12-10-18z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        </div>
        <h3>Fats</h3>
        <p>Crucial for hormone regulation (including testosterone), brain health, and the absorption of fat-soluble vitamins (A, D, E, K). Fats are the most calorie-dense macronutrient, so tracking them accurately is key.</p>
        <div class="mill-lever-impact">Calories/Gram: <strong style="color:#ef4444;">9</strong></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mill-section">
    <h2 class="mill-section-title">Frequently Asked Questions</h2>
    <div class="mill-faq">
      <details class="mill-faq-item">
        <summary>How is my TDEE calculated?</summary>
        <p>This calculator uses the highly accurate Mifflin-St Jeor equation to estimate your Basal Metabolic Rate (BMR), then multiplies it by an activity multiplier based on your lifestyle to determine your Total Daily Energy Expenditure (TDEE).</p>
      </details>
      <details class="mill-faq-item">
        <summary>What is the best macro split for losing fat?</summary>
        <p>For fat loss, a high-protein approach is generally best to preserve muscle while in a calorie deficit. A common and effective split is 40% protein, 40% carbs, and 20% fat, or 30% protein, 40% carbs, and 30% fat. The most important factor is remaining in a caloric deficit.</p>
      </details>
      <details class="mill-faq-item">
        <summary>How much protein do I actually need to build muscle?</summary>
        <p>Most research suggests that 0.7 to 1 gram of protein per pound of body weight (1.6 to 2.2 grams per kg) is optimal for maximizing muscle growth when combined with resistance training. Consuming more than this offers little additional benefit for muscle building.</p>
      </details>
      <details class="mill-faq-item">
        <summary>Should I adjust my macros on workout days vs rest days?</summary>
        <p>While advanced athletes sometimes use "carb cycling" (more carbs on training days, fewer on rest days), most people get excellent results simply hitting the same macro targets consistently every day. Consistency is easier to track and maintain.</p>
      </details>
      <details class="mill-faq-item">
        <summary>Why are fats important in my macro split?</summary>
        <p>Dietary fats are essential for hormone production (like testosterone), absorbing fat-soluble vitamins (A, D, E, K), and maintaining cell membrane health. It's generally recommended not to let fats drop below 20% of your total daily calories for extended periods.</p>
      </details>
    </div>
  </section>

  <div class="mill-disclaimer">
    <p><strong>Disclaimer:</strong> This calculator provides estimates based on the Mifflin-St Jeor equation. Individual metabolic rates vary. Consult with a registered dietitian or healthcare provider before making significant changes to your diet, especially if you have underlying health conditions.</p>
  </div>
</SiteLayout>

<style is:global>
  /* ===== CALCULATOR STYLES ===== */
  :root {
    --accent-color: #E05A5A;
  }
  .mill-page { max-width: 1100px; margin: 0 auto; }
  .mill-hero {
    text-align: center;
    padding: 2.5rem 1.5rem 2rem;
    background: linear-gradient(135deg, rgba(224,90,90,0.12) 0%, rgba(224,90,90,0.02) 60%, rgba(224,90,90,0.08) 100%);
    border-bottom: 1px solid var(--border-color, #152040);
    position: relative;
    overflow: hidden;
  }
  .mill-hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(224,90,90,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(224,90,90,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .mill-hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    padding: 0.35rem 1rem;
    border: 1px solid var(--accent-color);
    border-radius: 100px;
    color: var(--accent-color);
    margin-bottom: 1.5rem;
    font-weight: 600;
    animation: mill-fadeUp 0.6s ease both;
  }
  .mill-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--text-primary, #c8d0de);
    animation: mill-fadeUp 0.6s ease 0.1s both;
  }
  .mill-hero h1 em {
    font-style: normal;
    color: var(--accent-color);
  }
  .mill-hero-hook {
    font-size: 1.1rem;
    color: var(--text-secondary, #94a3b8);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.5;
    animation: mill-fadeUp 0.6s ease 0.2s both;
  }
  .mill-hero-hook strong {
    color: var(--text-primary, #c8d0de);
  }
  .mill-hero-stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    animation: mill-fadeUp 0.6s ease 0.3s both;
  }
  @media (max-width: 600px) {
    .mill-hero-stats { gap: 1rem; flex-wrap: wrap; }
  }
  .mill-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .mill-stat-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary, #c8d0de);
  }
  .mill-stat-label {
    font-size: 0.8rem;
    color: var(--text-secondary, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Animations */
  @keyframes mill-fadeUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Sections */
  .mill-section {
    padding: 3rem 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  .mill-section-title {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
    text-align: center;
    color: var(--text-primary, #c8d0de);
  }
  .mill-section-sub {
    text-align: center;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 2rem;
  }

  /* Calculator Form */
  .mill-calc-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  }
  @media (min-width: 850px) {
    .mill-calc-container { grid-template-columns: 1fr 1fr; }
  }
  .mill-calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .mill-input-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .mill-input-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mill-height-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .mill-input-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
  }
  .mill-input-group label strong {
    color: var(--accent-color);
  }
  .mill-input-group input,
  .mill-input-group select {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--bg-color, #060c0a);
    border: 1px solid var(--border-color, #152040);
    border-radius: 8px;
    color: var(--text-primary, #c8d0de);
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .mill-input-group input:focus,
  .mill-input-group select:focus {
    outline: none;
    border-color: var(--accent-color);
    box-shadow: 0 0 0 2px rgba(224,90,90,0.2);
  }

  .mill-btn {
    width: 100%;
    padding: 1rem;
    background: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    margin-top: 0.5rem;
  }
  .mill-btn:hover { background: #c54a4a; }
  .mill-btn:active { transform: scale(0.98); }

  /* Results Panel */
  .mill-calc-results {
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border-color, #152040);
    border-radius: 10px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: mill-fadeUp 0.4s ease both;
  }
  .mill-calc-results.active { display: flex !important; }
  .mill-result-header {
    text-align: center;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .mill-result-title {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary, #94a3b8);
  }
  .mill-result-years {
    color: var(--text-secondary, #94a3b8);
    font-size: 0.95rem;
  }

  /* Milestones */
  .mill-milestones {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .mill-milestone {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 10px;
    padding: 1rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  /* Chart */
  .mill-chart-wrap {
    background: rgba(0,0,0,0.2);
    border-radius: 8px;
    padding: 1rem;
  }
  .mill-chart-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.5rem;
  }
  .mill-chart-legend {
    display: flex;
    justify-content: center;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--text-secondary, #94a3b8);
    margin-top: 0.5rem;
  }
  .mill-legend-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 4px;
  }

  /* Levers */
  .mill-levers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  .mill-lever-card {
    background: var(--card-bg, #0a1020);
    border: 1px solid var(--border-color, #152040);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform 0.3s, border-color 0.3s;
  }
  .mill-lever-card:hover {
    transform: translateY(-5px);
    border-color: rgba(224,90,90,0.3);
  }
  .mill-lever-icon {
    margin-bottom: 1rem;
  }
  .mill-lever-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary, #c8d0de);
  }
  .mill-lever-card p {
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .mill-lever-impact {
    font-size: 0.85rem;
    color: var(--text-primary, #c8d0de);
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  /* FAQ */
  .mill-faq {
    max-width: 700px;
    margin: 0 auto;
  }
  .mill-faq-item {
    border: 1px solid var(--border-color, #152040);
    border-radius: 10px;
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .mill-faq-item[open] {
    border-color: rgba(224,90,90,0.3);
  }
  .mill-faq-item summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
    font-size: 0.95rem;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.2s;
    user-select: none;
  }
  .mill-faq-item summary:hover {
    background: rgba(224,90,90,0.04);
  }
  .mill-faq-item summary::-webkit-details-marker { display: none; }
  .mill-faq-item summary::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--accent-color);
    font-weight: 300;
    transition: transform 0.3s;
  }
  .mill-faq-item[open] summary::after {
    transform: rotate(45deg);
  }
  .mill-faq-item p {
    padding: 0 1.25rem 1.25rem;
    color: var(--text-secondary, #94a3b8);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .mill-disclaimer {
    max-width: 800px;
    margin: 0 auto 3rem;
    padding: 1.5rem;
    background: rgba(255,255,255,0.02);
    border-left: 3px solid var(--accent-color);
    border-radius: 0 10px 10px 0;
    font-size: 0.85rem;
    color: var(--text-secondary, #94a3b8);
  }
</style>

<script is:inline>
(function() {
  var calcBtn = document.getElementById('calc-btn');
  var splitSelect = document.getElementById('calc-split');
  var customWrap = document.getElementById('custom-split-wrap');
  var customErr = document.getElementById('custom-error');
  var mealSelect = document.getElementById('meal-count');

  var state = {
      cals: 0,
      pG: 0,
      cG: 0,
      fG: 0
  };

  splitSelect.addEventListener('change', function() {
      if (this.value === 'custom') {
          customWrap.style.display = 'flex';
      } else {
          customWrap.style.display = 'none';
          customErr.style.display = 'none';
      }
  });

  mealSelect.addEventListener('change', function() {
      if(state.cals > 0) buildMealTable();
  });

  calcBtn.addEventListener('click', calculateMacros);

  function calculateMacros() {
    var gender = document.getElementById('calc-gender').value;
    var age = parseInt(document.getElementById('calc-age').value);
    var weightLbs = parseFloat(document.getElementById('calc-weight').value);
    var heightFt = parseFloat(document.getElementById('calc-height-ft').value);
    var heightIn = parseFloat(document.getElementById('calc-height-in').value);
    var activity = parseFloat(document.getElementById('calc-activity').value);
    var goal = document.getElementById('calc-goal').value;
    var split = splitSelect.value;

    if (!age || !weightLbs || !heightFt || isNaN(heightIn)) return alert('Please fill out all fields.');

    // Convert to metric for Mifflin-St Jeor
    var weightKg = weightLbs * 0.453592;
    var heightCm = ((heightFt * 12) + heightIn) * 2.54;

    // BMR
    var bmr = 0;
    if (gender === 'male') {
        bmr = (10 * weightKg) + (6.25 * heightCm) - (5 * age) + 5;
    } else {
        bmr = (10 * weightKg) + (6.25 * heightCm) - (5 * age) - 161;
    }

    // TDEE
    var tdee = Math.round(bmr * activity);

    // Goal Adjust
    var targetCals = tdee;
    if (goal === 'lose') targetCals -= 500;
    if (goal === 'build') targetCals += 500;

    // Limits
    if(gender === 'male' && targetCals < 1500) targetCals = 1500;
    if(gender === 'female' && targetCals < 1200) targetCals = 1200;

    // Split
    var pPct, cPct, fPct;
    if (split === 'balanced') { pPct = 30; cPct = 40; fPct = 30; }
    else if (split === 'high-protein') { pPct = 40; cPct = 30; fPct = 30; }
    else if (split === 'low-carb') { pPct = 30; cPct = 20; fPct = 50; }
    else if (split === 'high-carb') { pPct = 30; cPct = 50; fPct = 20; }
    else {
        pPct = parseInt(document.getElementById('custom-p').value) || 0;
        cPct = parseInt(document.getElementById('custom-c').value) || 0;
        fPct = parseInt(document.getElementById('custom-f').value) || 0;
        if (pPct + cPct + fPct !== 100) {
            customErr.style.display = 'block';
            return;
        }
        customErr.style.display = 'none';
    }

    // Grams
    var pCals = Math.round(targetCals * (pPct / 100));
    var cCals = Math.round(targetCals * (cPct / 100));
    var fCals = Math.round(targetCals * (fPct / 100));

    var pG = Math.round(pCals / 4);
    var cG = Math.round(cCals / 4);
    var fG = Math.round(fCals / 9);

    state.cals = targetCals;
    state.pG = pG;
    state.cG = cG;
    state.fG = fG;

    // UI Update
    document.getElementById('res-tdee').textContent = tdee.toLocaleString();

    animateValue('res-cals', 0, targetCals, 1000, '');

    animateValue('res-p-g', 0, pG, 1000, 'g');
    document.getElementById('res-p-cal').textContent = pCals;
    document.getElementById('res-p-pct').textContent = pPct;

    animateValue('res-c-g', 0, cG, 1000, 'g');
    document.getElementById('res-c-cal').textContent = cCals;
    document.getElementById('res-c-pct').textContent = cPct;

    animateValue('res-f-g', 0, fG, 1000, 'g');
    document.getElementById('res-f-cal').textContent = fCals;
    document.getElementById('res-f-pct').textContent = fPct;

    // Bars
    setTimeout(function() {
        document.getElementById('bar-p').style.width = pPct + '%';
        document.getElementById('bar-c').style.width = cPct + '%';
        document.getElementById('bar-f').style.width = fPct + '%';
    }, 100);

    buildMealTable();

    document.getElementById('results-panel').style.display = 'flex';
    document.getElementById('results-panel').scrollIntoView({behavior: "smooth", block: "nearest"});
  }

  function buildMealTable() {
      var meals = parseInt(mealSelect.value);
      var tbody = document.getElementById('meal-table-body');
      tbody.innerHTML = '';

      var distributions = {
          3: [ {n: 'Breakfast', pct: 0.3}, {n: 'Lunch', pct: 0.4}, {n: 'Dinner', pct: 0.3} ],
          4: [ {n: 'Breakfast', pct: 0.25}, {n: 'Lunch', pct: 0.35}, {n: 'Snack', pct: 0.15}, {n: 'Dinner', pct: 0.25} ],
          5: [ {n: 'Breakfast', pct: 0.2}, {n: 'Snack 1', pct: 0.1}, {n: 'Lunch', pct: 0.35}, {n: 'Snack 2', pct: 0.1}, {n: 'Dinner', pct: 0.25} ]
      };

      var dist = distributions[meals];

      for(var i=0; i<dist.length; i++) {
          var r = dist[i].pct;
          var tr = document.createElement('tr');
          tr.style.borderBottom = '1px solid rgba(255,255,255,0.05)';

          tr.innerHTML =
            '<td style="padding:10px 4px;">' + dist[i].n + '</td>' +
            '<td style="padding:10px 4px;">' + Math.round(state.cals * r) + '</td>' +
            '<td style="padding:10px 4px; color:#3b82f6;">' + Math.round(state.pG * r) + 'g</td>' +
            '<td style="padding:10px 4px; color:#f59e0b;">' + Math.round(state.cG * r) + 'g</td>' +
            '<td style="padding:10px 4px; color:#ef4444;">' + Math.round(state.fG * r) + 'g</td>';

          tbody.appendChild(tr);
      }
  }

  function animateValue(id, start, end, duration, suffix) {
      var obj = document.getElementById(id);
      var startTimestamp = null;
      var step = function(timestamp) {
          if (!startTimestamp) startTimestamp = timestamp;
          var progress = Math.min((timestamp - startTimestamp) / duration, 1);
          var current = Math.floor(progress * (end - start) + start);
          obj.textContent = current.toLocaleString() + suffix;
          if (progress < 1) {
              window.requestAnimationFrame(step);
          } else {
              obj.textContent = end.toLocaleString() + suffix;
          }
      };
      window.requestAnimationFrame(step);
  }

  // Trigger initial calculation
  setTimeout(function() {
      document.getElementById('calc-btn').click();
  }, 500);

})();
</script>
