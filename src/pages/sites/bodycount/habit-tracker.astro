---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Habit Tracker",
  "url": "https://bodycount.photonbuilder.com/habit-tracker",
  "description": "Track daily habits with a visual streak calendar. Monitor exercise, water intake, sleep, meditation and more. See current streaks, longest streaks, completion rates, and monthly heatmaps.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the habit tracker store my data?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All your habit data is stored locally in your browser using localStorage. Nothing is sent to any server. Your data stays private on your device. If you clear your browser data, your habit history will be lost, so consider exporting your data periodically."
      }
    },
    {
      "@type": "Question",
      "name": "How many habits can I track at once?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can track up to 10 habits simultaneously. Research suggests focusing on a small number of habits at a time is more effective than trying to change too many behaviors at once. Start with 2-3 key habits and add more as they become automatic."
      }
    },
    {
      "@type": "Question",
      "name": "What is a habit streak and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A habit streak is the number of consecutive days you have completed a habit without missing a day. Streaks leverage the psychological principle of loss aversion — once you build a streak, you are motivated not to break it. Research shows that habits typically take 66 days on average to become automatic."
      }
    },
    {
      "@type": "Question",
      "name": "How is the completion rate calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The completion rate is the percentage of days you completed a habit out of the total days since you created it. For example, if you created a habit 30 days ago and completed it on 24 of those days, your completion rate is 80%. Only days from the habit creation date onward are counted."
      }
    },
    {
      "@type": "Question",
      "name": "What are good daily habits for health and fitness?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Some of the most impactful daily habits for health include: exercising for at least 30 minutes, drinking 8 glasses of water, sleeping 7-9 hours, meditating for 10 minutes, eating 5 servings of fruits and vegetables, taking a daily walk, stretching, and limiting screen time before bed. Start with the habits that will have the biggest impact on your specific goals."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Habit Tracker — Daily Streak Calendar | bodycount"
  description="Track daily habits with visual streak calendars. Monitor exercise, water, sleep, meditation and more. See streaks, completion rates, and monthly heatmaps."
  canonical="https://bodycount.photonbuilder.com/habit-tracker" schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --color-streak: #f59e0b;
            --color-best: #3b82f6;
            --color-rate: #2DB89A;
            --heat-0: #0c1410;
            --heat-1: #0d3320;
            --heat-2: #166534;
            --heat-3: #22c55e;
            --heat-4: #4ade80;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            letter-spacing: -0.03em;
        }

        .subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
            margin-bottom: 2rem;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .card-title {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-secondary);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .add-habit-row {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .add-habit-row input {
            flex: 1;
            padding: 0.6rem 0.8rem;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            font-family: var(--font-ui);
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .add-habit-row input:focus {
            border-color: var(--accent-color);
        }

        .add-habit-row input::placeholder {
            color: var(--text-secondary);
        }

        .btn {
            padding: 0.6rem 1.2rem;
            background: var(--accent-color);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-family: var(--font-ui);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
            white-space: nowrap;
        }

        .btn:hover {
            background: var(--accent-hover);
        }

        .btn-small {
            padding: 0.3rem 0.6rem;
            font-size: 0.75rem;
            border-radius: 6px;
        }

        .btn-danger {
            background: #3b1515;
            color: #ef4444;
        }

        .btn-danger:hover {
            background: #4a1c1c;
        }

        .presets {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-bottom: 1rem;
        }

        .preset-chip {
            padding: 0.3rem 0.7rem;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            color: var(--text-secondary);
            font-size: 0.78rem;
            cursor: pointer;
            transition: all 0.2s;
            font-family: var(--font-ui);
        }

        .preset-chip:hover {
            border-color: var(--accent-color);
            color: var(--accent-color);
        }

        .habit-count {
            font-size: 0.78rem;
            color: var(--text-secondary);
            text-align: right;
            margin-bottom: 0.5rem;
        }

        .habit-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .habit-item {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 1rem;
            transition: border-color 0.2s;
        }

        .habit-item:hover {
            border-color: #2a3a34;
        }

        .habit-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
        }

        .habit-name-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .habit-check {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--border-color);
            background: transparent;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .habit-check:hover {
            border-color: var(--accent-color);
        }

        .habit-check.done {
            background: var(--accent-color);
            border-color: var(--accent-color);
        }

        .habit-check.done::after {
            content: '✓';
            color: #fff;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .habit-name {
            font-weight: 600;
            font-size: 0.95rem;
        }

        .habit-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.5rem;
            margin-bottom: 0.75rem;
        }

        .stat-box {
            text-align: center;
            padding: 0.4rem;
            background: var(--card-bg);
            border-radius: 6px;
        }

        .stat-value {
            font-family: var(--font-mono);
            font-size: 1.1rem;
            font-weight: 700;
        }

        .stat-value.streak { color: var(--color-streak); }
        .stat-value.best { color: var(--color-best); }
        .stat-value.rate { color: var(--color-rate); }

        .stat-label {
            font-size: 0.68rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .heatmap {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
        }

        .heatmap-month-label {
            font-size: 0.72rem;
            color: var(--text-secondary);
            margin-bottom: 0.25rem;
            font-weight: 600;
        }

        .heatmap-row-labels {
            display: flex;
            gap: 0.15rem;
            margin-bottom: 0.15rem;
        }

        .heatmap-day-label {
            width: 14px;
            height: 14px;
            font-size: 0.55rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .heatmap-grid {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
        }

        .heatmap-week {
            display: flex;
            gap: 0.15rem;
        }

        .heatmap-cell {
            width: 14px;
            height: 14px;
            border-radius: 2px;
            background: var(--heat-0);
            position: relative;
        }

        .heatmap-cell.future {
            opacity: 0.3;
        }

        .heatmap-cell.level-1 { background: var(--heat-1); }
        .heatmap-cell.level-2 { background: var(--heat-2); }
        .heatmap-cell.level-3 { background: var(--heat-3); }
        .heatmap-cell.level-4 { background: var(--heat-4); }

        .heatmap-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 0.5rem;
        }

        .heatmap-nav button {
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            border-radius: 6px;
            padding: 0.2rem 0.5rem;
            cursor: pointer;
            font-size: 0.75rem;
            font-family: var(--font-ui);
            transition: all 0.2s;
        }

        .heatmap-nav button:hover {
            border-color: var(--accent-color);
            color: var(--accent-color);
        }

        .heatmap-legend {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            margin-top: 0.5rem;
            justify-content: flex-end;
        }

        .heatmap-legend span {
            font-size: 0.65rem;
            color: var(--text-secondary);
        }

        .heatmap-legend-cell {
            width: 10px;
            height: 10px;
            border-radius: 2px;
        }

        .empty-state {
            text-align: center;
            padding: 2rem;
            color: var(--text-secondary);
        }

        .empty-state p {
            margin-bottom: 0.5rem;
        }

        .faq-section {
            margin-top: 2rem;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 0;
        }

        .faq-item:last-child {
            border-bottom: none;
        }

        .faq-q {
            font-weight: 600;
            font-size: 0.95rem;
            margin-bottom: 0.4rem;
            color: var(--text-primary);
        }

        .faq-a {
            font-size: 0.88rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        @media (max-width: 600px) {
            h1 { font-size: 1.5rem; }
            .habit-stats { grid-template-columns: repeat(3, 1fr); gap: 0.3rem; }
            .stat-value { font-size: 0.95rem; }
            .heatmap-cell { width: 11px; height: 11px; }
            .heatmap-day-label { width: 11px; height: 11px; font-size: 0.5rem; }
        }
  </style>

  <div class="container">
    <h1>Habit Tracker</h1>
    <p class="subtitle">Track daily habits. Build streaks. See your progress.</p>

    <div class="card">
      <div class="card-title">Add a Habit</div>
      <div class="add-habit-row">
        <input type="text" id="habitInput" placeholder="e.g. Exercise 30 min" maxlength="40" />
        <button class="btn" id="addBtn">Add</button>
      </div>
      <div class="presets" id="presets"></div>
      <div class="habit-count" id="habitCount"></div>
    </div>

    <div id="habitList" class="habit-list"></div>
    <div id="emptyState" class="empty-state card" style="display:none;">
      <p>No habits yet.</p>
      <p>Add a habit above or pick a preset to get started.</p>
    </div>

    <div class="card faq-section">
      <div class="card-title">Frequently Asked Questions</div>
      {faqSchema.mainEntity.map((item: any) => (
        <div class="faq-item">
          <div class="faq-q">{item.name}</div>
          <div class="faq-a">{item.acceptedAnswer.text}</div>
        </div>
      ))}
    </div>
  </div>

  <script>
    const STORAGE_KEY = 'bodycount_habits';
    const MAX_HABITS = 10;
    const PRESETS = [
      'Exercise 30 min', 'Drink 8 glasses water', 'Sleep 8 hours',
      'Meditate 10 min', 'Eat vegetables', 'No alcohol',
      'Read 20 min', 'Take a walk', 'Stretch', 'No junk food'
    ];

    function getToday() {
      const d = new Date();
      return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
    }

    function loadHabits() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch { return []; }
    }

    function saveHabits(habits) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(habits));
    }

    function calcStreak(dates) {
      if (!dates.length) return 0;
      const sorted = [...dates].sort().reverse();
      const today = getToday();
      const yesterday = (() => { const d = new Date(); d.setDate(d.getDate() - 1); return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); })();
      if (sorted[0] !== today && sorted[0] !== yesterday) return 0;
      let streak = 1;
      for (let i = 1; i < sorted.length; i++) {
        const prev = new Date(sorted[i - 1]);
        const curr = new Date(sorted[i]);
        const diff = (prev.getTime() - curr.getTime()) / 86400000;
        if (Math.round(diff) === 1) streak++;
        else break;
      }
      return streak;
    }

    function calcLongestStreak(dates) {
      if (!dates.length) return 0;
      const sorted = [...dates].sort();
      let longest = 1, current = 1;
      for (let i = 1; i < sorted.length; i++) {
        const prev = new Date(sorted[i - 1]);
        const curr = new Date(sorted[i]);
        const diff = Math.round((curr.getTime() - prev.getTime()) / 86400000);
        if (diff === 1) { current++; longest = Math.max(longest, current); }
        else if (diff > 1) current = 1;
      }
      return longest;
    }

    function calcRate(dates, createdAt) {
      const start = new Date(createdAt);
      const now = new Date(getToday());
      const totalDays = Math.max(1, Math.round((now.getTime() - start.getTime()) / 86400000) + 1);
      return Math.round((dates.length / totalDays) * 100);
    }

    function renderPresets() {
      const container = document.getElementById('presets');
      const habits = loadHabits();
      const names = new Set(habits.map(h => h.name));
      container.innerHTML = PRESETS.filter(p => !names.has(p)).map(p =>
        `<button class="preset-chip" data-name="${p}">${p}</button>`
      ).join('');
      container.querySelectorAll('.preset-chip').forEach(btn => {
        btn.addEventListener('click', () => addHabit(btn.dataset.name));
      });
    }

    function addHabit(name) {
      name = name.trim();
      if (!name) return;
      const habits = loadHabits();
      if (habits.length >= MAX_HABITS) { alert('Maximum ' + MAX_HABITS + ' habits reached.'); return; }
      if (habits.some(h => h.name === name)) { alert('Habit already exists.'); return; }
      habits.push({ name, createdAt: getToday(), dates: [] });
      saveHabits(habits);
      document.getElementById('habitInput').value = '';
      render();
    }

    function removeHabit(index) {
      if (!confirm('Delete this habit and all its data?')) return;
      const habits = loadHabits();
      habits.splice(index, 1);
      saveHabits(habits);
      render();
    }

    function toggleToday(index) {
      const habits = loadHabits();
      const today = getToday();
      const h = habits[index];
      const idx = h.dates.indexOf(today);
      if (idx > -1) h.dates.splice(idx, 1);
      else h.dates.push(today);
      saveHabits(habits);
      render();
    }

    function buildHeatmap(dates, createdAt, monthOffset) {
      const now = new Date();
      now.setMonth(now.getMonth() + monthOffset);
      const year = now.getFullYear();
      const month = now.getMonth();
      const firstDay = new Date(year, month, 1);
      const lastDay = new Date(year, month + 1, 0);
      const today = getToday();
      const dateSet = new Set(dates);

      const monthName = firstDay.toLocaleString('default', { month: 'long', year: 'numeric' });
      const dayLabels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];

      let html = `<div class="heatmap-row-labels">${dayLabels.map(d => `<div class="heatmap-day-label">${d}</div>`).join('')}</div>`;
      html += '<div class="heatmap-grid">';

      let week = '<div class="heatmap-week">';
      for (let i = 0; i < firstDay.getDay(); i++) {
        week += '<div class="heatmap-cell"></div>';
      }

      for (let d = 1; d <= lastDay.getDate(); d++) {
        const dateStr = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
        const isFuture = dateStr > today;
        const done = dateSet.has(dateStr);
        let level = '';
        if (done) level = 'level-4';
        else if (!isFuture && dateStr >= createdAt) level = '';
        week += `<div class="heatmap-cell ${level} ${isFuture ? 'future' : ''}"></div>`;

        const dayOfWeek = new Date(year, month, d).getDay();
        if (dayOfWeek === 6 && d < lastDay.getDate()) {
          week += '</div><div class="heatmap-week">';
        }
      }

      const lastDayOfWeek = lastDay.getDay();
      for (let i = lastDayOfWeek + 1; i <= 6; i++) {
        week += '<div class="heatmap-cell"></div>';
      }
      week += '</div>';
      html += week + '</div>';

      return { html, monthName };
    }

    const monthOffsets = {};

    function render() {
      const habits = loadHabits();
      const today = getToday();
      const list = document.getElementById('habitList');
      const empty = document.getElementById('emptyState');
      const countEl = document.getElementById('habitCount');

      countEl.textContent = habits.length + ' / ' + MAX_HABITS + ' habits';
      empty.style.display = habits.length === 0 ? 'block' : 'none';

      list.innerHTML = habits.map((h, i) => {
        const isDone = h.dates.includes(today);
        const streak = calcStreak(h.dates);
        const longest = calcLongestStreak(h.dates);
        const rate = calcRate(h.dates, h.createdAt);
        if (monthOffsets[i] === undefined) monthOffsets[i] = 0;
        const heatmap = buildHeatmap(h.dates, h.createdAt, monthOffsets[i]);

        return `<div class="habit-item">
          <div class="habit-header">
            <div class="habit-name-row">
              <button class="habit-check ${isDone ? 'done' : ''}" data-toggle="${i}" aria-label="Toggle habit"></button>
              <span class="habit-name">${h.name}</span>
            </div>
            <button class="btn btn-small btn-danger" data-remove="${i}">Remove</button>
          </div>
          <div class="habit-stats">
            <div class="stat-box"><div class="stat-value streak">${streak}</div><div class="stat-label">Streak</div></div>
            <div class="stat-box"><div class="stat-value best">${longest}</div><div class="stat-label">Best</div></div>
            <div class="stat-box"><div class="stat-value rate">${rate}%</div><div class="stat-label">Rate</div></div>
          </div>
          <div class="heatmap">
            <div class="heatmap-nav">
              <button data-month-prev="${i}">◀</button>
              <span class="heatmap-month-label">${heatmap.monthName}</span>
              <button data-month-next="${i}">▶</button>
            </div>
            ${heatmap.html}
            <div class="heatmap-legend">
              <span>Less</span>
              <div class="heatmap-legend-cell" style="background:var(--heat-0)"></div>
              <div class="heatmap-legend-cell" style="background:var(--heat-4)"></div>
              <span>Done</span>
            </div>
          </div>
        </div>`;
      }).join('');

      list.querySelectorAll('[data-toggle]').forEach(btn => {
        btn.addEventListener('click', () => toggleToday(parseInt(btn.dataset.toggle)));
      });
      list.querySelectorAll('[data-remove]').forEach(btn => {
        btn.addEventListener('click', () => removeHabit(parseInt(btn.dataset.remove)));
      });
      list.querySelectorAll('[data-month-prev]').forEach(btn => {
        btn.addEventListener('click', () => { monthOffsets[parseInt(btn.dataset.monthPrev)]--; render(); });
      });
      list.querySelectorAll('[data-month-next]').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.monthNext);
          if (monthOffsets[idx] < 0) { monthOffsets[idx]++; render(); }
        });
      });

      renderPresets();
    }

    document.getElementById('addBtn').addEventListener('click', () => addHabit(document.getElementById('habitInput').value));
    document.getElementById('habitInput').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') addHabit(e.target.value);
    });

    render();
  </script>
</SiteLayout>
