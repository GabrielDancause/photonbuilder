---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "HPV Risk Assessment Tool: Personalized Risk Level and Recommendations",
  "description": "Interactive educational tool to assess your general risk profile for HPV infection and related complications based on age, vaccination status, and screening history.",
  "author": {
    "@type": "Organization",
    "name": "HPV Research"
  },
  "publisher": {
    "@type": "Organization",
    "name": "HPV Research",
    "logo": {
      "@type": "ImageObject",
      "url": "https://photonbuilder.com/bodycount/logo.png"
    }
  },
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does having multiple sexual partners increase my risk of HPV?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, because HPV is a very common sexually transmitted infection, having multiple lifetime sexual partners, or a new sexual partner, increases the statistical likelihood of being exposed to one or more types of the virus."
        }
      },
      {
        "@type": "Question",
        "name": "Does smoking increase the risk of HPV causing cancer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, smoking is a major cofactor in the progression of HPV to cancer. Carcinogens from tobacco smoke concentrate in cervical and oral tissues, damaging the local immune response and making it harder for the body to clear the virus naturally."
        }
      },
      {
        "@type": "Question",
        "name": "Am I still at risk if I am vaccinated against HPV?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While the Gardasil 9 vaccine drastically reduces your risk of the most dangerous HPV types (which cause over 90% of cervical cancers), it does not protect against every single high-risk type. Therefore, you are at a very low risk, but routine screening (if you have a cervix) is still required."
        }
      }
    ]
  }
};

export const meta = {
  title: "Interactive HPV Risk Assessment Tool",
  description: "Personalized, anonymous HPV risk assessment based on age, vaccination history, screening, and behavioral factors. Educational tool, not medical advice.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="bodycount"
  title="Interactive HPV Risk Assessment Tool"
  description="Personalized, anonymous HPV risk assessment based on age, vaccination history, screening, and behavioral factors. Educational tool, not medical advice."
  canonical="https://photonbuilder.com/bodycount/hpv-risk-assessment"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>HPV Risk Assessment</h1>
      <p>Evaluate your general risk profile for HPV infection and related complications.</p>
    </div>

    <div class="content-body">
      <div class="disclaimer-banner">
        <strong>Disclaimer:</strong> This tool is for educational purposes only. It is not a diagnostic tool and does not provide medical advice. Almost all sexually active adults will be exposed to HPV. Always consult a healthcare professional for personalized medical advice and screening.
      </div>

      <p>For more foundational information on preventing HPV, start with our <a href="/sites/hpv-research/hpv-prevention-guide">Pillar Guide on HPV Prevention</a>.</p>

      <p>Understanding your personal risk factors for acquiring Human Papillomavirus (HPV) and, more importantly, for developing complications (like high-grade dysplasia or cancer) from a persistent infection is key to proactive health management. This assessment considers primary prevention (vaccination), secondary prevention (screening), and known biological and behavioral cofactors.</p>

      <div class="calculator-card" id="risk-tool">
        <h3>Anonymous Risk Profile Questionnaire</h3>

        <form id="risk-form" onsubmit="return false;">

          <div class="input-group">
            <label for="q-age">What is your age?</label>
            <select id="q-age" required>
              <option value="">Select age range...</option>
              <option value="under21">Under 21</option>
              <option value="21to29">21 - 29</option>
              <option value="30to45">30 - 45</option>
              <option value="over45">Over 45</option>
            </select>
          </div>

          <div class="input-group">
            <label for="q-vax">Have you received the full series of the HPV vaccine (e.g., Gardasil)?</label>
            <select id="q-vax" required>
              <option value="">Select vaccination status...</option>
              <option value="yes_early">Yes, before age 15 (or before becoming sexually active)</option>
              <option value="yes_late">Yes, after becoming sexually active</option>
              <option value="partial">Received some doses, but not the full series</option>
              <option value="no">No, or unsure</option>
            </select>
          </div>

          <div class="input-group">
            <label for="q-cervix">Do you have a cervix?</label>
            <select id="q-cervix" required>
              <option value="">Select...</option>
              <option value="yes">Yes</option>
              <option value="no">No</option>
            </select>
          </div>

          <div class="input-group" id="screening-group" style="display: none;">
            <label for="q-screen">Are you up-to-date on cervical cancer screening (Pap smear and/or HPV test)?</label>
            <select id="q-screen">
              <option value="">Select screening status...</option>
              <option value="yes_normal">Yes, and my last results were normal</option>
              <option value="yes_abnormal">Yes, but my last results were abnormal (ASCUS, LSIL, HSIL, or HPV+)</option>
              <option value="no">No, I am overdue or have never been screened</option>
              <option value="na">Not applicable (under 21)</option>
            </select>
          </div>

          <div class="input-group">
            <label for="q-smoking">Do you currently smoke tobacco?</label>
            <select id="q-smoking" required>
              <option value="">Select smoking status...</option>
              <option value="yes">Yes</option>
              <option value="no">No (or quit >5 years ago)</option>
            </select>
          </div>

          <div class="input-group">
            <label for="q-immune">Do you have an immunocompromising condition (e.g., HIV, taking immunosuppressants)?</label>
            <select id="q-immune" required>
              <option value="">Select immune status...</option>
              <option value="yes">Yes</option>
              <option value="no">No</option>
            </select>
          </div>

          <button id="calculate-risk-btn" type="submit" style="width: 100%; padding: 1rem; background: var(--accent-color); color: #000; border: none; border-radius: 8px; font-weight: 700; font-size: 1.1rem; cursor: pointer; margin-top: 1rem; transition: opacity 0.2s;">Calculate Risk Profile</button>
        </form>

        <div class="calc-result" id="result-container" style="display: none; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
          <div style="text-align: center;">
            <span class="calc-result-label">Estimated Risk Profile for HPV Complications:</span>
            <div id="risk-badge" style="display: inline-block; padding: 0.5rem 1.5rem; font-size: 1.5rem; font-weight: 800; border-radius: 8px; margin: 1rem 0; text-transform: uppercase;"></div>
          </div>

          <div id="risk-explanation" style="font-size: 1.05rem; line-height: 1.6; color: var(--text-primary); margin-top: 1rem;"></div>

          <h4 style="color: var(--accent-color); margin-top: 1.5rem; margin-bottom: 0.5rem;">Recommended Actions:</h4>
          <ul id="action-items" style="padding-left: 1.5rem; color: var(--text-secondary);"></ul>
        </div>
      </div>

    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('risk-form');
      const cervixSelect = document.getElementById('q-cervix');
      const screeningGroup = document.getElementById('screening-group');
      const screeningSelect = document.getElementById('q-screen');
      const resultContainer = document.getElementById('result-container');
      const riskBadge = document.getElementById('risk-badge');
      const riskExplanation = document.getElementById('risk-explanation');
      const actionItems = document.getElementById('action-items');

      // Toggle screening question based on cervix presence
      cervixSelect.addEventListener('change', (e) => {
        if (e.target.value === 'yes') {
          screeningGroup.style.display = 'block';
          screeningSelect.setAttribute('required', 'required');
        } else {
          screeningGroup.style.display = 'none';
          screeningSelect.removeAttribute('required');
          screeningSelect.value = '';
        }
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const age = document.getElementById('q-age').value;
        const vax = document.getElementById('q-vax').value;
        const hasCervix = cervixSelect.value === 'yes';
        const screen = screeningSelect.value;
        const smoking = document.getElementById('q-smoking').value === 'yes';
        const immune = document.getElementById('q-immune').value === 'yes';

        let riskScore = 0;
        let reasons = [];
        let actions = [];

        // Base risk on vaccination (Primary Prevention)
        if (vax === 'yes_early') {
          riskScore -= 3;
          reasons.push("You received the vaccine before likely exposure, providing excellent protection against the most oncogenic HPV types.");
        } else if (vax === 'yes_late') {
          riskScore -= 1;
          reasons.push("You are vaccinated, which protects against types you haven't been exposed to, but you may have been exposed to some types prior to vaccination.");
        } else if (vax === 'partial') {
          riskScore += 1;
          reasons.push("Incomplete vaccination series may offer lower or shorter-lasting protection.");
          actions.push("Talk to your provider about completing your HPV vaccine series.");
        } else {
          riskScore += 2;
          reasons.push("You are unvaccinated, leaving you susceptible to high-risk HPV types.");
          if (age === 'under21' || age === '21to29' || age === '30to45') {
            actions.push("Discuss 'catch-up' HPV vaccination with your healthcare provider. It is FDA approved up to age 45.");
          }
        }

        // Risk based on Screening (Secondary Prevention)
        if (hasCervix) {
          if (screen === 'yes_normal') {
            riskScore -= 2;
            reasons.push("Recent normal screening indicates no current significant cervical dysplasia.");
            actions.push("Continue routine screening based on your age and national guidelines.");
          } else if (screen === 'yes_abnormal') {
            riskScore += 3;
            reasons.push("An abnormal screening result indicates active viral presence or cellular changes that require monitoring.");
            actions.push("Strictly adhere to the follow-up timeline (e.g., colposcopy or repeat Pap) recommended by your gynecologist.");
          } else if (screen === 'no') {
            riskScore += 3;
            reasons.push("Being overdue for screening is a significant risk factor, as cellular changes can progress undetected.");
            actions.push("Schedule a cervical cancer screening (Pap smear and/or HPV test) as soon as possible.");
          }
        } else {
            // No cervix, check for routine anal/oral screening isn't standard, rely on vax
            actions.push("Since you do not have a cervix, routine population screening for HPV-related cancers is not currently standard. Maintain awareness of any unusual oral or anal symptoms.");
        }

        // Cofactors
        if (smoking) {
          riskScore += 2;
          reasons.push("Smoking is a major cofactor that impairs local immune response, making it much harder for your body to clear an HPV infection naturally.");
          actions.push("Consider a smoking cessation program to significantly improve your immune system's ability to clear HPV and reduce cancer risk.");
        }

        if (immune) {
          riskScore += 3;
          reasons.push("An immunocompromised state significantly increases the risk that an HPV infection will persist rather than clear, and it accelerates the progression to high-grade lesions.");
          actions.push("Work closely with your specialist to manage your immune health. You may require more frequent cancer screenings.");
        }

        // Determine Category
        let riskCategory = "Low Risk";
        let riskColor = "#22c55e"; // Green
        let riskBg = "rgba(34, 197, 94, 0.1)";

        if (riskScore >= 4) {
          riskCategory = "Elevated Risk";
          riskColor = "#ef4444"; // Red
          riskBg = "rgba(239, 68, 68, 0.1)";
        } else if (riskScore >= 1) {
          riskCategory = "Moderate Risk";
          riskColor = "#eab308"; // Yellow/Orange
          riskBg = "rgba(234, 179, 8, 0.1)";
        } else {
            // Default Low Risk
        }

        // Render Results
        riskBadge.textContent = riskCategory;
        riskBadge.style.color = riskColor;
        riskBadge.style.backgroundColor = riskBg;
        riskBadge.style.border = `1px solid ${riskColor}`;

        riskExplanation.innerHTML = `<p><strong>Why this profile?</strong></p><ul>` +
          reasons.map(r => `<li>${r}</li>`).join('') + `</ul>`;

        if (actions.length === 0) {
            actions.push("Maintain your current preventive health routines.");
        }

        actionItems.innerHTML = actions.map(a => `<li style="margin-bottom: 0.5rem;">${a}</li>`).join('');

        resultContainer.style.display = 'block';

        // Scroll to results
        resultContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; }
    .content-body p, .content-body ul { font-size: 1.05rem; line-height: 1.7; color: var(--text-primary); margin-bottom: 1.25rem; }
    .content-body h2 { font-size: 1.8rem; font-weight: 700; color: var(--accent-color); margin-top: 2.5rem; margin-bottom: 1rem; }
    .content-body h3 { font-size: 1.3rem; font-weight: 600; color: var(--text-primary); margin-top: 1.5rem; margin-bottom: 0.75rem; }
    .content-body a { color: var(--accent-color); text-decoration: none; }
    .content-body a:hover { text-decoration: underline; }
    .disclaimer-banner { background-color: rgba(239, 68, 68, 0.1); border-left: 4px solid #ef4444; padding: 1rem; margin-bottom: 2rem; border-radius: 0 8px 8px 0; font-size: 0.95rem; color: var(--text-primary); }
    .calculator-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
    .input-group { margin-bottom: 1.25rem; }
    .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: var(--text-primary); }
    .input-group select { width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-color); color: var(--text-primary); font-family: var(--font-ui); font-size: 1rem; appearance: auto; }
    .input-group select:focus { outline: none; border-color: var(--accent-color); }
    #calculate-risk-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  </style>
</SiteLayout>
