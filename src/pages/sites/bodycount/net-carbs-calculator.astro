  <script type="text/javascript">
    // Net Carbs Calculator
    const calcBtn = document.getElementById('calcBtn');
    const resultsDiv = document.getElementById('results');

    calcBtn.addEventListener('click', function() {
      const totalCarbs = parseFloat(document.getElementById('totalCarbs').value) || 0;
      const fiber = parseFloat(document.getElementById('fiber').value) || 0;
      const sugarAlcohols = parseFloat(document.getElementById('sugarAlcohols').value) || 0;
      const absorptionRate = parseFloat(document.getElementById('alcoholType').value);

      const alcoholImpact = sugarAlcohols * absorptionRate;
      const alcoholSubtracted = sugarAlcohols - alcoholImpact;
      const netCarbs = Math.max(0, totalCarbs - fiber - alcoholSubtracted);

      document.getElementById('netCarbsResult').textContent = netCarbs.toFixed(1) + 'g';
      document.getElementById('rTotalCarbs').textContent = totalCarbs.toFixed(1) + 'g';
      document.getElementById('rFiber').textContent = '-' + fiber.toFixed(1) + 'g';
      document.getElementById('rAlcohol').textContent = '-' + alcoholSubtracted.toFixed(1) + 'g';
      document.getElementById('rNetCarbs').textContent = netCarbs.toFixed(1) + 'g';

      const typeName = document.getElementById('alcoholType').selectedOptions[0].text.split(' (')[0];
      document.getElementById('rAlcoholNote').textContent = sugarAlcohols > 0
        ? typeName + ' — ' + (absorptionRate * 100) + '% absorbed, ' + ((1 - absorptionRate) * 100) + '% subtracted'
        : 'No sugar alcohols entered';

      let formula = '<span class="highlight">' + netCarbs.toFixed(1) + 'g</span> = ' + totalCarbs.toFixed(1) + 'g − ' + fiber.toFixed(1) + 'g fiber';
      if (sugarAlcohols > 0) {
        formula += ' − ' + alcoholSubtracted.toFixed(1) + 'g sugar alcohols';
      }
      document.getElementById('formulaDisplay').innerHTML = formula;

      resultsDiv.classList.add('active');
    });

    // Daily Keto Tracker
    let trackerFoods = [];

    const dailyLimitInput = document.getElementById('dailyLimit');
    const foodNameInput = document.getElementById('foodName');
    const foodCarbsInput = document.getElementById('foodCarbs');
    const addFoodBtn = document.getElementById('addFoodBtn');
    const clearTrackerBtn = document.getElementById('clearTracker');
    const foodListEl = document.getElementById('foodList');
    const emptyState = document.getElementById('emptyState');

    function updateTracker() {
      const limit = parseFloat(dailyLimitInput.value) || 20;
      const total = trackerFoods.reduce(function(sum, f) { return sum + f.carbs; }, 0);
      const remaining = Math.max(0, limit - total);
      const pct = Math.min(100, (total / limit) * 100);

      document.getElementById('trackerCurrent').textContent = total.toFixed(1) + 'g consumed';
      document.getElementById('trackerRemaining').textContent = remaining.toFixed(1) + 'g remaining';
      document.getElementById('trackerPct').textContent = pct.toFixed(0) + '% of daily limit';

      const fill = document.getElementById('trackerFill');
      fill.style.width = pct + '%';
      fill.className = 'progress-bar-fill';
      if (pct >= 100) fill.classList.add('danger');
      else if (pct >= 75) fill.classList.add('warning');

      // Render food list
      if (trackerFoods.length === 0) {
        foodListEl.innerHTML = '<li class="empty-state">No foods added yet. Start tracking your daily net carbs above.</li>';
        return;
      }

      foodListEl.innerHTML = '';
      trackerFoods.forEach(function(food, i) {
        const li = document.createElement('li');
        li.className = 'food-item';
        li.innerHTML = '<span class="food-name">' + escapeHtml(food.name) + '</span><span class="food-carbs">' + food.carbs.toFixed(1) + 'g<button class="remove-btn" data-index="' + i + '">&times;</button></span>';
        foodListEl.appendChild(li);
      });

      // Add remove handlers
      foodListEl.querySelectorAll('.remove-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          trackerFoods.splice(parseInt(this.dataset.index), 1);
          updateTracker();
        });
      });
    }

    function escapeHtml(str) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    addFoodBtn.addEventListener('click', function() {
      const name = foodNameInput.value.trim();
      const carbs = parseFloat(foodCarbsInput.value);
      if (!name || isNaN(carbs) || carbs < 0) return;

      trackerFoods.push({ name: name, carbs: carbs });
      foodNameInput.value = '';
      foodCarbsInput.value = '';
      foodNameInput.focus();
      updateTracker();
    });

    foodNameInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        foodCarbsInput.focus();
      }
    });

    foodCarbsInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        addFoodBtn.click();
      }
    });

    clearTrackerBtn.addEventListener('click', function() {
      trackerFoods = [];
      updateTracker();
    });

    dailyLimitInput.addEventListener('change', updateTracker);

    updateTracker();
  </script>
