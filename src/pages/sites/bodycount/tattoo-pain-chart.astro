      ankle_back_l:      { name: "Ankle (Back)", pain: 7, feels: "Sharp stinging, Achilles sensitivity", why: "Achilles tendon, thin skin, bone", heal: "3-4 weeks", tip: "The Achilles area can swell significantly. Wear open-back shoes or sandals during healing.", desc: "The back of the ankle over the Achilles tendon has thin skin and high sensitivity. The tendon transmits vibration up the calf. Shoes rubbing on this area can complicate healing." },
      ankle_back_r:      { name: "Ankle (Back)", pain: 7, feels: "Sharp stinging, Achilles sensitivity", why: "Achilles tendon, thin skin, bone", heal: "3-4 weeks", tip: "The Achilles area can swell significantly. Wear open-back shoes or sandals during healing.", desc: "The back of the ankle over the Achilles tendon has thin skin and high sensitivity. The tendon transmits vibration up the calf. Shoes rubbing on this area can complicate healing." },
      foot_top_l:        { name: "Top of Foot", pain: 9, feels: "Intense bone vibration, sharp stinging", why: "Metatarsal bones, thin skin, dense nerve network", heal: "3-4 weeks", tip: "Wear open-toed shoes or sandals during healing. Foot tattoos fade faster — plan for touch-ups.", desc: "The top of the foot is essentially thin skin over a grid of small bones and tendons. There's no muscular padding. The vibration across the metatarsals is intense, and foot tattoos are notorious for fading quickly." },
