      hamstring_l:       { name: "Back of Thigh", pain: 3, feels: "Mild scratching, dull ache", why: "Good muscle padding, thicker skin", heal: "2 weeks", tip: "Sitting may be uncomfortable for a few days after. Consider timing around any long drives or flights.", desc: "The hamstring area has good muscular padding and thicker skin, making it quite tolerable. Pain increases toward the inner thigh and the crease below the buttocks." },
      hamstring_r:       { name: "Back of Thigh", pain: 3, feels: "Mild scratching, dull ache", why: "Good muscle padding, thicker skin", heal: "2 weeks", tip: "Sitting may be uncomfortable for a few days after. Consider timing around any long drives or flights.", desc: "The hamstring area has good muscular padding and thicker skin, making it quite tolerable. Pain increases toward the inner thigh and the crease below the buttocks." },
      ankle_l:           { name: "Ankle", pain: 7, feels: "Sharp bone grinding, nerve stinging", why: "Thin skin, ankle bone, tendons, nerve pathways", heal: "3-4 weeks", tip: "Avoid tight shoes and socks for 2-3 weeks. Ankle tattoos are prone to swelling — elevate when resting.", desc: "The ankle has very thin skin stretched over bone and tendons. The lateral and medial malleolus (ankle bones) create intense bone vibration. Swelling is common and healing is slower due to gravity and footwear." },
