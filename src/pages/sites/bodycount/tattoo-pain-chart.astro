              <!-- Inner bicep -->
              <path data-zone="inner_bicep_l" d="M46,95 L56,95 L54,128 L44,128 Z" class="body-zone"/>
              <path data-zone="inner_bicep_r" d="M144,95 L154,95 L156,128 L146,128 Z" class="body-zone"/>
