              <ellipse data-zone="temple_r" cx="124" cy="38" rx="6" ry="8" class="body-zone"/>
              <!-- Neck front -->
              <rect data-zone="neck_front" x="90" y="52" width="20" height="16" rx="4" class="body-zone"/>
