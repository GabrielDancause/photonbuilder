              <path d="M100,12 C78,12 72,34 72,46 L72,52 C64,56 56,68 52,80 L36,92 C28,96 26,108 30,128 L32,172 L32,182 C28,188 26,198 32,206 L56,206 C56,206 58,200 62,190 L66,210 L66,290 C64,296 62,304 66,310 L68,380 C66,386 64,394 66,400 L66,432 L96,432 L96,394 L92,310 C96,304 100,296 100,290"
                fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5" pointer-events="none"/>
            </svg>
          </div>
        </div>

        <!-- BACK VIEW -->
        <div class="body-view">
          <h3>Back View</h3>
          <div class="body-svg-container">
            <svg viewBox="0 0 200 480" xmlns="http://www.w3.org/2000/svg">
              <!-- Scalp -->
              <ellipse data-zone="scalp" cx="100" cy="26" rx="22" ry="16" class="body-zone"/>
              <!-- Behind ear -->
              <ellipse data-zone="behind_ear_l" cx="74" cy="38" rx="5" ry="7" class="body-zone"/>
              <ellipse data-zone="behind_ear_r" cx="126" cy="38" rx="5" ry="7" class="body-zone"/>
              <!-- Neck back -->
              <rect data-zone="neck_back" x="88" y="50" width="24" height="18" rx="4" class="body-zone"/>
              <!-- Upper back -->
              <path data-zone="upper_back" d="M64,76 L136,76 L138,110 L62,110 Z" class="body-zone"/>
              <!-- Spine -->
              <rect data-zone="spine" x="94" y="110" width="12" height="80" rx="3" class="body-zone"/>
              <!-- Lower back -->
              <path data-zone="lower_back_l" d="M64,140 L94,140 L94,190 L66,188 Z" class="body-zone"/>
              <path data-zone="lower_back_r" d="M106,140 L136,140 L134,188 L106,190 Z" class="body-zone"/>
              <!-- Shoulder blade area reuses upper_back -->
              <!-- Buttocks -->
              <path data-zone="buttocks_l" d="M68,198 L100,198 L100,240 L66,238 Z" class="body-zone"/>
              <path data-zone="buttocks_r" d="M100,198 L132,198 L134,238 L100,240 Z" class="body-zone"/>
              <!-- Back of arm (outer bicep back) -->
              <path data-zone="outer_bicep_back_l" d="M36,90 L52,90 L50,128 L34,128 Z" class="body-zone"/>
              <path data-zone="outer_bicep_back_r" d="M148,90 L164,90 L166,128 L150,128 Z" class="body-zone"/>
              <!-- Back of forearm -->
              <path data-zone="outer_forearm_back_l" d="M34,132 L50,132 L48,172 L32,172 Z" class="body-zone"/>
              <path data-zone="outer_forearm_back_r" d="M150,132 L166,132 L168,172 L152,172 Z" class="body-zone"/>
              <!-- Elbow back -->
              <ellipse data-zone="elbow_back_l" cx="42" cy="130" rx="8" ry="5" class="body-zone"/>
              <ellipse data-zone="elbow_back_r" cx="158" cy="130" rx="8" ry="5" class="body-zone"/>
              <!-- Wrist back -->
              <rect data-zone="wrist_back_l" x="34" y="172" width="16" height="10" rx="3" class="body-zone"/>
              <rect data-zone="wrist_back_r" x="150" y="172" width="16" height="10" rx="3" class="body-zone"/>
              <!-- Fingers -->
              <path data-zone="fingers_l" d="M34,182 L50,182 L54,204 L48,208 L42,206 L36,208 L30,204 Z" class="body-zone"/>
              <path data-zone="fingers_r" d="M150,182 L166,182 L170,204 L164,208 L158,206 L152,208 L148,204 Z" class="body-zone"/>
              <!-- Back of thigh (hamstring) -->
              <path data-zone="hamstring_l" d="M68,242 L98,242 L96,296 L70,296 Z" class="body-zone"/>
              <path data-zone="hamstring_r" d="M102,242 L132,242 L130,296 L104,296 Z" class="body-zone"/>
              <!-- Calf -->
              <path data-zone="calf_l" d="M72,310 L94,310 L92,380 L74,380 Z" class="body-zone"/>
