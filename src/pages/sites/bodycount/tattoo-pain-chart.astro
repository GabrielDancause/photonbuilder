              <path data-zone="chest_center" d="M88,80 L112,80 L114,110 L86,110 Z" class="body-zone"/>
              <path data-zone="chest_side_l" d="M60,80 L88,80 L86,110 L62,108 Z" class="body-zone"/>
              <path data-zone="chest_side_r" d="M112,80 L140,80 L138,108 L114,110 Z" class="body-zone"/>
