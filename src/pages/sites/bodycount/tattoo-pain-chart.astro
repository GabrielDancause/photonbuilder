      toes_l:            { name: "Toes", pain: 9, feels: "Intense sharp stinging", why: "Tiny bones, thin skin, many nerve endings", heal: "3-4 weeks", tip: "Toe tattoos require extra aftercare attention. Keep feet clean and dry, avoid closed shoes when possible.", desc: "Toes have thin skin over small bones with dense nerve clusters, similar to fingers. The vibration and stinging are intense. Like finger tattoos, toe tattoos blur and fade quickly." },
      toes_r:            { name: "Toes", pain: 9, feels: "Intense sharp stinging", why: "Tiny bones, thin skin, many nerve endings", heal: "3-4 weeks", tip: "Toe tattoos require extra aftercare attention. Keep feet clean and dry, avoid closed shoes when possible.", desc: "Toes have thin skin over small bones with dense nerve clusters, similar to fingers. The vibration and stinging are intense. Like finger tattoos, toe tattoos blur and fade quickly." },
      upper_back:        { name: "Upper Back", pain: 2, feels: "Mild vibration, light pressure", why: "Thick muscle (trapezius, lats), good fat padding", heal: "2 weeks", tip: "Large flat canvas perfect for detailed work. Avoid backpacks and sleeping on your back during the first week.", desc: "The upper back has thick muscle coverage from the trapezius and latissimus dorsi. It's one of the least painful tattoo locations, offering a huge canvas for large designs. Most people find it very tolerable." },
      spine:             { name: "Spine", pain: 8, feels: "Deep grinding vibration through vertebrae", why: "Vertebrae directly under thin skin, spinal nerves", heal: "3-4 weeks", tip: "You'll feel the vibration through your whole back. Avoid sleeping on your back for the first week. Short sessions help.", desc: "The spine runs vertebrae right below the skin surface. The needle vibration transmits through the bone and radiates outward. The closer to the center of each vertebra, the more intense the grinding sensation." },
