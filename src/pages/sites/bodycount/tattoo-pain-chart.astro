              <!-- Foot top -->
              <path data-zone="foot_top_l" d="M72,394 L92,394 L94,420 L70,420 Z" class="body-zone"/>
              <path data-zone="foot_top_r" d="M108,394 L128,394 L130,420 L106,420 Z" class="body-zone"/>
              <!-- Toes -->
              <path data-zone="toes_l" d="M70,420 L94,420 L96,432 L68,432 Z" class="body-zone"/>
              <path data-zone="toes_r" d="M106,420 L130,420 L132,432 L104,432 Z" class="body-zone"/>
