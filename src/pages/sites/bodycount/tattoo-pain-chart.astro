      buttocks_l:        { name: "Buttocks", pain: 3, feels: "Mild scratching, dull pressure", why: "Good fat and muscle padding", heal: "2 weeks", tip: "Sitting will be uncomfortable for a few days. Wear soft cotton underwear during healing.", desc: "The buttocks have excellent padding from the gluteal muscles and fat tissue. It's surprisingly low-pain for most people. The main challenge is the awkward positioning during the session and discomfort while sitting afterward." },
      buttocks_r:        { name: "Buttocks", pain: 3, feels: "Mild scratching, dull pressure", why: "Good fat and muscle padding", heal: "2 weeks", tip: "Sitting will be uncomfortable for a few days. Wear soft cotton underwear during healing.", desc: "The buttocks have excellent padding from the gluteal muscles and fat tissue. It's surprisingly low-pain for most people. The main challenge is the awkward positioning during the session and discomfort while sitting afterward." }
    };

    function getPainColor(pain) {
      if (pain <= 2) return 'var(--pain-low)';
      if (pain <= 4) return 'var(--pain-moderate)';
      if (pain <= 6) return 'var(--pain-high)';
      if (pain <= 8) return 'var(--pain-very-high)';
      return 'var(--pain-extreme)';
    }

    function getPainColorHex(pain) {
      if (pain <= 2) return '#22c55e';
      if (pain <= 4) return '#eab308';
      if (pain <= 6) return '#f97316';
      if (pain <= 8) return '#ef4444';
      return '#dc2626';
    }

    function getPainCategory(pain) {
      if (pain <= 2) return 'Low';
      if (pain <= 4) return 'Moderate';
      if (pain <= 6) return 'Painful';
      if (pain <= 8) return 'Very Painful';
      return 'Extreme';
    }

    // Color all zones
    var allZones = document.querySelectorAll('.body-zone');
    allZones.forEach(function(el) {
      var zoneId = el.getAttribute('data-zone');
      if (zones[zoneId]) {
        el.style.fill = getPainColorHex(zones[zoneId].pain);
        el.style.fillOpacity = '0.55';
        el.addEventListener('click', function() { showZone(zoneId); });
      }
    });

    var activeZone = null;

    function showZone(zoneId) {
      var z = zones[zoneId];
      if (!z) return;

      // Update active state
      allZones.forEach(function(el) { el.classList.remove('active'); });
      document.querySelectorAll('[data-zone="' + zoneId + '"]').forEach(function(el) {
        el.classList.add('active');
      });
      activeZone = zoneId;

      var color = getPainColorHex(z.pain);
      document.getElementById('detailPlaceholder').style.display = 'none';
      var panel = document.getElementById('detailPanel');
      panel.classList.remove('visible');
      void panel.offsetWidth;
      panel.classList.add('visible');

      document.getElementById('detailTitle').textContent = z.name;
      var badge = document.getElementById('detailBadge');
      badge.textContent = z.pain + '/10 — ' + getPainCategory(z.pain);
      badge.style.background = color;
      badge.style.color = z.pain <= 4 ? '#000' : '#fff';

      var bar = document.getElementById('detailBar');
      bar.style.width = (z.pain * 10) + '%';
      bar.style.background = color;

      document.getElementById('detailLevel').textContent = z.pain + ' / 10 — ' + getPainCategory(z.pain);
      document.getElementById('detailFeels').textContent = z.feels;
      document.getElementById('detailHeal').textContent = z.heal;
      document.getElementById('detailWhy').textContent = z.why;
      document.getElementById('detailDesc').textContent = z.desc;
      document.getElementById('detailTip').textContent = z.tip;

      document.getElementById('detailCard').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    window.closeDetail = function() {
      document.getElementById('detailPanel').classList.remove('visible');
      document.getElementById('detailPlaceholder').style.display = 'block';
      allZones.forEach(function(el) { el.classList.remove('active'); });
      activeZone = null;
    };

    // Build comparison table — deduplicate by name
    var seen = {};
    var tableData = [];
    Object.keys(zones).forEach(function(key) {
      var z = zones[key];
      if (!seen[z.name]) {
        seen[z.name] = true;
        tableData.push({ id: key, name: z.name, pain: z.pain, heal: z.heal, category: getPainCategory(z.pain) });
      }
    });

    var sortCol = 'pain';
    var sortDir = -1;

    function healToNum(h) {
      var m = h.match(/(\d+)/);
      return m ? parseInt(m[1]) : 0;
    }

    function renderTable() {
      tableData.sort(function(a, b) {
        var va, vb;
        if (sortCol === 'name' || sortCol === 'category') {
          va = a[sortCol]; vb = b[sortCol];
          return sortDir * va.localeCompare(vb);
        } else if (sortCol === 'heal') {
          va = healToNum(a.heal); vb = healToNum(b.heal);
        } else {
          va = a[sortCol]; vb = b[sortCol];
        }
        return sortDir * (va - vb);
      });

      var html = '';
      tableData.forEach(function(row) {
        html += '<tr style="cursor:pointer" data-zone="' + row.id + '">';
        html += '<td>' + row.name + '</td>';
        html += '<td><span class="pain-dot" style="background:' + getPainColorHex(row.pain) + '"></span>' + row.pain + '/10</td>';
        html += '<td>' + row.heal + '</td>';
        html += '<td>' + row.category + '</td>';
        html += '</tr>';
      });
      document.getElementById('painTableBody').innerHTML = html;

      // Add click handlers to rows
      document.querySelectorAll('#painTableBody tr').forEach(function(tr) {
        tr.addEventListener('click', function() {
          showZone(this.getAttribute('data-zone'));
        });
      });
    }

    document.querySelectorAll('#painTable th').forEach(function(th) {
      th.addEventListener('click', function() {
        var col = this.getAttribute('data-sort');
        if (sortCol === col) { sortDir *= -1; }
        else { sortCol = col; sortDir = 1; }
        renderTable();
      });
    });

    renderTable();

    // FAQ toggle
    window.toggleFaq = function(btn) {
      var item = btn.closest('.faq-item');
      item.classList.toggle('open');
    };
  })();
  </script>

</SiteLayout>
