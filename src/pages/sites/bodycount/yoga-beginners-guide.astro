---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const faqList = [
  {
    question: "Do I need to be flexible to start yoga?",
    answer: "Not at all! Flexibility is a result of practicing yoga, not a prerequisite. Beginners should focus on proper alignment and breathing rather than how deep they can go into a pose."
  },
  {
    question: "How often should a beginner practice yoga?",
    answer: "Aim for 2-3 times a week, starting with 20-30 minute sessions. Consistency is more important than duration. Even 10 minutes a day can yield significant benefits over time."
  },
  {
    question: "What is the best type of yoga for absolute beginners?",
    answer: "Hatha or Restorative yoga are excellent starting points. They are slower-paced, focusing on basic postures and breathing techniques, allowing you to build a strong foundation without feeling rushed."
  },
  {
    question: "Should I eat before a yoga class?",
    answer: "It is best to practice on an empty or light stomach. Wait about 2 hours after a heavy meal, or 30-60 minutes after a light snack like a banana or a handful of almonds."
  },
  {
    question: "What should I wear to my first yoga class?",
    answer: "Wear comfortable, breathable clothing that allows for a full range of motion. Avoid anything too loose that might get in the way during inversions or complex poses."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Complete Yoga for Beginners Guide",
    "description": "A complete yoga starter guide covering styles, fundamental poses, beginner flow, breathing techniques, equipment, and yoga etiquette.",
    "author": {
      "@type": "Organization",
      "name": "BodyCount"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/yoga-beginners-guide"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];

const yogaStyles = [
  { name: "Hatha", description: "A slower-paced, foundational style focusing on basic postures and breathing. Perfect for beginners learning alignment." },
  { name: "Vinyasa", description: "A dynamic practice linking breath with continuous movement. Expect a faster pace and a moderate cardiovascular workout." },
  { name: "Yin", description: "A slow, meditative style holding passive poses for 3-5 minutes to target deep connective tissues and increase flexibility." },
  { name: "Ashtanga", description: "A rigorous, physically demanding style following a specific sequence of postures. Best for those seeking structure and a challenge." },
  { name: "Bikram", description: "Practiced in a room heated to 105°F with 40% humidity, consisting of a strict sequence of 26 postures and 2 breathing exercises." },
  { name: "Restorative", description: "Focuses on deep relaxation using props (bolsters, blocks) to support the body in passive poses for extended periods." }
];

const fundamentalPoses = [
  { name: "Mountain Pose (Tadasana)", cues: "Feet hip-width apart, root down through all four corners of feet, engage quads, lengthen spine, palms face forward." },
  { name: "Downward-Facing Dog (Adho Mukha Svanasana)", cues: "Hands shoulder-width, feet hip-width. Press hips up and back, fingers spread wide, heels reach toward the floor." },
  { name: "Child's Pose (Balasana)", cues: "Knees wide, big toes touching. Hips sink back to heels, arms extended forward, forehead resting on the mat." },
  { name: "Plank Pose", cues: "Shoulders stacked over wrists, core engaged, straight line from head to heels. Push the floor away." },
  { name: "Chaturanga Dandasana (Four-Limbed Staff Pose)", cues: "From plank, shift forward, lower halfway down, elbows hug the ribs, shoulders aligned with elbows." },
  { name: "Upward-Facing Dog (Urdhva Mukha Svanasana)", cues: "Tops of feet on the mat, thighs lifted. Press through hands to lift chest, shoulders back and down." },
  { name: "Warrior I (Virabhadrasana I)", cues: "Front knee bent 90 degrees, back foot flat at a 45-degree angle. Hips square to the front, arms reach up." },
  { name: "Warrior II (Virabhadrasana II)", cues: "Front knee bent, back foot parallel to the back of the mat. Hips open to the side, arms parallel to the floor, gaze over front fingers." },
  { name: "Triangle Pose (Trikonasana)", cues: "Legs straight, front foot forward, back foot at 90 degrees. Reach forward, then hinge at the hip, bottom hand to shin/block, top arm reaches up." },
  { name: "Tree Pose (Vrksasana)", cues: "Stand on one leg, place the sole of the opposite foot on the inner thigh or calf (avoid the knee). Hands at heart center, find a focal point." },
  { name: "Bridge Pose (Setu Bandhasana)", cues: "Lie on back, knees bent, feet flat near glutes. Press into feet to lift hips, interlace fingers underneath, roll shoulders under." },
  { name: "Seated Forward Fold (Paschimottanasana)", cues: "Sit with legs extended. Inhale to lengthen spine, exhale to hinge at the hips and reach for shins or feet. Keep back straight." },
  { name: "Cobbler's Pose (Baddha Konasana)", cues: "Sit tall, bring soles of feet together, knees drop out to the sides. Hold feet, inhale lengthen, exhale fold forward slightly." },
  { name: "Cat-Cow (Marjaryasana-Bitilasana)", cues: "On hands and knees. Inhale, drop belly, lift chest (Cow). Exhale, round spine, tuck chin (Cat)." },
  { name: "Corpse Pose (Savasana)", cues: "Lie flat on back, feet flop open, arms by sides, palms up. Completely relax all muscles and let go of breath control." }
];

const equipment = [
  { name: "Yoga Mat", details: "Thickness matters. A standard 1/8 inch (3mm) mat is versatile. A 1/4 inch (6mm) offers more cushioning for sensitive joints. Look for good grip to prevent slipping." },
  { name: "Yoga Blocks", details: "Essential for bringing the floor closer to you. They help maintain proper alignment in poses where you can't quite reach the ground safely." },
  { name: "Yoga Strap", details: "Useful for extending your reach in stretches and binding poses. Helps maintain alignment without straining." }
];
---

<SiteLayout
  site="bodycount"
  title="Complete Yoga for Beginners Guide | BodyCount"
  description="A complete yoga starter guide covering styles, fundamental poses, beginner flow, breathing techniques, equipment, and yoga etiquette."
  canonical="https://bodycount.photonbuilder.com/yoga-beginners-guide"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;
      background-color: var(--bg-color);
      color: var(--text-primary);
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Complete Yoga for Beginners Guide</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        Your ultimate starter guide to beginning a yoga practice. Discover styles, essential poses, breathing techniques, and tips to start your journey confidently.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Understanding Yoga Styles</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">With so many variations, choosing the right class can be overwhelming. Here is a breakdown of popular styles to help you find your fit.</div>
        <ul>
          {yogaStyles.map(style => (
            <li><strong>{style.name}:</strong> {style.description}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>15 Fundamental Poses with Alignment Cues</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Mastering these foundational poses will prepare you for almost any beginner or open-level class. Focus on how the pose feels rather than how it looks.</div>
        <table>
          <thead>
            <tr>
              <th>Pose Name</th>
              <th>Key Alignment Cues</th>
            </tr>
          </thead>
          <tbody>
            {fundamentalPoses.map(pose => (
              <tr>
                <td><strong>{pose.name}</strong></td>
                <td>{pose.cues}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>A 20-Minute Beginner Flow</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Practice this simple sequence at home to build familiarity with the poses and linking breath to movement.</div>
        <ol>
          <li><strong>Centering (3 mins):</strong> Easy Pose (Sukhasana) or Child's Pose. Focus on deepening your breath.</li>
          <li><strong>Warm-up (5 mins):</strong> 5-10 rounds of Cat-Cow, followed by Downward-Facing Dog. Walk your feet out to stretch the calves.</li>
          <li><strong>Standing Sequence (7 mins):</strong> Transition from Downward Dog to Mountain Pose. Move through a slow Sun Salutation A (Mountain, Forward Fold, Plank, Chaturanga, Upward Dog, Downward Dog). Add Warrior I and Warrior II on each side.</li>
          <li><strong>Cool-down (5 mins):</strong> Seated Forward Fold, Bridge Pose, and final relaxation in Corpse Pose (Savasana).</li>
        </ol>
      </section>

      <section>
        <h2>Essential Breathing Techniques (Pranayama)</h2>
        <div class="highlight-box">
          <h4>The Power of Breath</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">In yoga, the breath is just as important as the physical postures. It anchors your mind and regulates your nervous system.</div>
          <ul style="margin-bottom: 0;">
            <li><strong>Ujjayi Breath (Victorious Breath):</strong> Inhale and exhale deeply through the nose while slightly constricting the back of the throat. It creates an audible, ocean-like sound. Used during Vinyasa flows to build heat and maintain focus.</li>
            <li><strong>Nadi Shodhana (Alternate Nostril Breathing):</strong> Use your thumb and ring finger to alternate closing one nostril at a time while breathing. Excellent for balancing the nervous system, reducing stress, and preparing for meditation.</li>
          </ul>
        </div>
      </section>

      <section>
        <h2>Yoga Equipment Guide</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">You don't need much to start, but having the right tools can make your practice safer and more comfortable.</div>
        <ul>
          {equipment.map(item => (
            <li><strong>{item.name}:</strong> {item.details}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Yoga for Specific Goals</h2>
        <ul>
          <li><strong>For Flexibility:</strong> Yin Yoga and Restorative Yoga are best. Long holds gently stretch connective tissues.</li>
          <li><strong>For Strength:</strong> Ashtanga, Vinyasa, and Power Yoga involve weight-bearing poses and continuous movement that build functional strength.</li>
          <li><strong>For Stress Relief:</strong> Hatha, Restorative, and any practice heavily focused on breathwork and meditation will lower cortisol levels.</li>
          <li><strong>For Back Pain:</strong> Gentle Hatha or therapeutic yoga. Focus on core strengthening (Plank) and gentle mobility (Cat-Cow). Avoid deep backbends initially.</li>
        </ul>
      </section>

      <section>
        <h2>Online vs. Studio Practice</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Both avenues offer unique benefits for beginners:</div>
        <ul>
          <li><strong>Studio Classes:</strong> Offer hands-on adjustments from a qualified instructor to ensure proper alignment. Great for community and minimizing distractions.</li>
          <li><strong>Online Platforms:</strong> (e.g., YouTube, YogaGlo) Provide flexibility to practice anytime, anywhere, and often at a lower cost. Ideal if you are self-conscious about starting in a group setting.</li>
        </ul>
      </section>

      <section>
        <h2>Yoga Etiquette for Beginners</h2>
        <ul>
          <li><strong>Arrive Early:</strong> Aim to be 10-15 minutes early to settle in, introduce yourself to the teacher, and mention any injuries.</li>
          <li><strong>Unplug:</strong> Leave your phone outside the studio room. Yoga is a time to disconnect.</li>
          <li><strong>Respect the Space:</strong> Remove your shoes before entering the studio space. Try not to step on other people's mats.</li>
          <li><strong>Stay for Savasana:</strong> The final resting pose is crucial. If you must leave early, tell the instructor beforehand and leave quietly before Savasana begins.</li>
        </ul>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
