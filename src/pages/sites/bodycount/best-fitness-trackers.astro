---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Fitness Trackers 2026",
    "description": "Top fitness trackers: Apple Watch, Garmin Venu/Forerunner, Fitbit Charge 6, Samsung Galaxy Watch, Whoop 4.0, Oura Ring, Amazfit.",
    "url": "https://bodycount.photonbuilder.com/best-fitness-trackers"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which fitness tracker is most accurate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Apple Watch Series 9 and Garmin Forerunner series consistently test highest for heart rate and GPS accuracy."
        }
      },
      {
        "@type": "Question",
        "name": "Do I have to pay a subscription?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Whoop, Oura, and Fitbit require a subscription for premium features. Garmin and Apple Watch do not have monthly fees."
        }
      },
      {
        "@type": "Question",
        "name": "Which tracker is best for sleep?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Oura Ring and Whoop are considered the best for sleep tracking due to their detailed analytics and comfortable form factor."
        }
      },
      {
        "@type": "Question",
        "name": "Are these trackers water-resistant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, all top trackers are water-resistant to at least 50 meters, making them suitable for swimming and showering."
        }
      },
      {
        "@type": "Question",
        "name": "How long does the battery last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Battery life varies. Apple and Samsung last 1-2 days, while Garmin and Amazfit can last over a week or even two weeks."
        }
      }
    ]
  }
];

const trackers = [
  { brand: 'Apple Watch', hr: 'Excellent', gps: 'Excellent', sleep: 'Good', battery: '1-2 days', water: '50m', app: 'iOS Only', sub: 'No', price: 399 },
  { brand: 'Garmin Venu/Forerunner', hr: 'Excellent', gps: 'Excellent', sleep: 'Good', battery: '13 days', water: '50m', app: 'iOS/Android', sub: 'No', price: 449 },
  { brand: 'Fitbit Charge 6', hr: 'Very Good', gps: 'Good', sleep: 'Excellent', battery: '7 days', water: '50m', app: 'iOS/Android', sub: 'Yes (Premium)', price: 159 },
  { brand: 'Samsung Galaxy Watch', hr: 'Good', gps: 'Good', sleep: 'Good', battery: '1.5 days', water: '50m', app: 'Android Only', sub: 'No', price: 299 },
  { brand: 'Whoop 4.0', hr: 'Very Good', gps: 'N/A', sleep: 'Excellent', battery: '4-5 days', water: '10m', app: 'iOS/Android', sub: 'Required', price: 0 },
  { brand: 'Oura Ring', hr: 'Good', gps: 'N/A', sleep: 'Excellent', battery: '4-7 days', water: '100m', app: 'iOS/Android', sub: 'Required', price: 299 },
  { brand: 'Amazfit', hr: 'Good', gps: 'Excellent', sleep: 'Fair', battery: '14 days', water: '50m', app: 'iOS/Android', sub: 'No', price: 229 }
];
---

<SiteLayout
  site="bodycount"
  title="Best Fitness Trackers 2026 - BodyCount"
  description="Top fitness trackers: Apple Watch, Garmin, Fitbit, Samsung, Whoop, Oura, Amazfit. Compare heart rate, GPS, sleep, battery, and price."
  canonical="https://bodycount.photonbuilder.com/best-fitness-trackers"
>
  <div class="page-wrapper">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style>
      .page-wrapper {
        --bg-color: #0f1115;
        --card-bg: #1a1d24;
        --border-color: #2a2f3a;
        --accent-color: #4ade80;
        --accent-hover: #22c55e;
        --text-primary: #f8fafc;
        --text-secondary: #94a3b8;
        --chart-header: #212530;
        --table-hover: #262b36;

        background-color: var(--bg-color);
        color: var(--text-primary);
        min-height: 100vh;
        font-family: system-ui, -apple-system, sans-serif;
      }

      .hero-section {
        background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
        padding: 4rem 1.5rem 3rem;
        text-align: center;
        border-bottom: 1px solid var(--border-color);
      }

      .hero-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        letter-spacing: -0.025em;
        margin-top: 0;
      }

      .hero-subtitle {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 42rem;
        margin: 0 auto;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .section-title {
        font-size: 1.875rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        text-align: center;
        margin-top: 0;
      }

      .table-container {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow-x: auto;
        margin-bottom: 4rem;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
      }

      th {
        background: var(--chart-header);
        padding: 1rem 1.5rem;
        font-weight: 600;
        color: var(--text-secondary);
        border-bottom: 2px solid var(--border-color);
        white-space: nowrap;
      }

      td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-primary);
      }

      tr:last-child td {
        border-bottom: none;
      }

      tr:hover td {
        background: var(--table-hover);
      }

      .val-price {
        font-family: monospace;
        font-size: 0.875rem;
      }

      .faq-section {
        max-width: 800px;
        margin: 0 auto 4rem;
      }

      .faq-item {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1rem;
      }

      .faq-q {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
      }

      .faq-a {
        color: var(--text-secondary);
        line-height: 1.6;
      }
    </style>

    <div class="hero-section">
      <h1 class="hero-title">Best Fitness Trackers 2026</h1>
      <p class="hero-subtitle">
        Compare the top fitness trackers: Apple Watch, Garmin, Fitbit, Samsung, Whoop, Oura, and Amazfit.
      </p>
    </div>

    <main class="container">
      <section>
        <h2 class="section-title" style="text-align: left;">Compare Fitness Trackers</h2>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Brand & Model</th>
                <th>HR Accuracy</th>
                <th>GPS</th>
                <th>Sleep Tracking</th>
                <th>Battery Life</th>
                <th>Water Resistance</th>
                <th>App Ecosystem</th>
                <th>Subscription</th>
                <th>Price</th>
              </tr>
            </thead>
            <tbody>
              {trackers.map(tracker => (
                <tr>
                  <td style="font-weight: 500;">{tracker.brand}</td>
                  <td>{tracker.hr}</td>
                  <td>{tracker.gps}</td>
                  <td>{tracker.sleep}</td>
                  <td>{tracker.battery}</td>
                  <td>{tracker.water}</td>
                  <td>{tracker.app}</td>
                  <td>{tracker.sub}</td>
                  <td class="val-price">{tracker.price === 0 ? 'Free w/ Sub' : '$' + tracker.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          {schema[1].mainEntity.map((faq: any) => (
            <div class="faq-item">
              <div class="faq-q">{faq.name}</div>
              <div class="faq-a">{faq.acceptedAnswer.text}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
