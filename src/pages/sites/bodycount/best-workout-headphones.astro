---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Workout Headphones 2026",
    "description": "Top workout headphones and earbuds for gym, running, and outdoor training.",
    "url": "https://bodycount.photonbuilder.com/best-workout-headphones"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are true wireless earbuds better for working out?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, true wireless earbuds offer the most freedom of movement, preventing tangled wires or snagging during workouts."
        }
      },
      {
        "@type": "Question",
        "name": "What IP rating do I need for workout headphones?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Look for at least an IPX4 rating to ensure resistance against sweat and light splashes. For heavy sweaters or running in the rain, IPX5 or higher is recommended."
        }
      },
      {
        "@type": "Question",
        "name": "Is active noise cancellation (ANC) good for workouts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ANC is great for blocking out gym noise, but for outdoor workouts like running or cycling, you should use an awareness or transparency mode to hear your surroundings."
        }
      },
      {
        "@type": "Question",
        "name": "How important is a secure fit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A secure fit is crucial. Earbuds with ear hooks or wingtips generally stay in place better during high-intensity movements than standard designs."
        }
      },
      {
        "@type": "Question",
        "name": "Do open-ear headphones sound good?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Open-ear headphones prioritize situational awareness and comfort over deep bass. While sound quality is improving, they don't offer the immersive audio of in-ear models."
        }
      }
    ]
  }
];

const categories = [
  { name: 'Best Overall', brand: 'Beats Fit Pro', desc: 'Secure wingtips, great sound, and excellent Apple integration.' },
  { name: 'Best for Running', brand: 'Jabra Elite 8 Active', desc: 'Incredibly durable with a secure shake-proof fit.' },
  { name: 'Best Sound Quality', brand: 'Sony WF-1000XM5', desc: 'Premium audio and top-tier noise cancellation for the gym.' },
  { name: 'Best Open-Ear', brand: 'Shokz OpenRun Pro', desc: 'Bone conduction technology for ultimate situational awareness.' },
  { name: 'Best Budget', brand: 'JBL Endurance Race', desc: 'Affordable waterproof earbuds with a rugged design.' },
  { name: 'Best Comfort', brand: 'Bose Sport Earbuds', desc: 'StayHear Max tips provide a secure yet pressure-free fit.' }
];

const headphones = [
  { brand: 'Beats Fit Pro', fit: 'Wingtips', ipx: 'IPX4', battery: '6 hours', sound: 'Excellent', anc: 'Yes', awareness: 'Yes', price: 200 },
  { brand: 'Jabra Elite 8 Active', fit: 'ShakeGrip', ipx: 'IP68', battery: '8 hours', sound: 'Very Good', anc: 'Yes', awareness: 'Yes', price: 200 },
  { brand: 'AirPods Pro 2', fit: 'In-Ear', ipx: 'IPX4', battery: '6 hours', sound: 'Excellent', anc: 'Yes', awareness: 'Yes', price: 250 },
  { brand: 'Sony WF-1000XM5', fit: 'Foam Tips', ipx: 'IPX4', battery: '8 hours', sound: 'Exceptional', anc: 'Yes', awareness: 'Yes', price: 300 },
  { brand: 'Bose Sport Earbuds', fit: 'StayHear Max', ipx: 'IPX4', battery: '5 hours', sound: 'Very Good', anc: 'No', awareness: 'No', price: 150 },
  { brand: 'Shokz OpenRun Pro', fit: 'Neckband', ipx: 'IP55', battery: '10 hours', sound: 'Good', anc: 'No', awareness: 'Always', price: 180 },
  { brand: 'JBL Endurance Race', fit: 'Wingtips', ipx: 'IP67', battery: '10 hours', sound: 'Good', anc: 'No', awareness: 'Yes', price: 80 }
];
---

<SiteLayout
  site="bodycount"
  canonical="https://bodycount.photonbuilder.com/best-workout-headphones"
>
  <div class="page-wrapper">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style>
      .page-wrapper {
        --bg-color: #0f1115;
        --card-bg: #1a1d24;
        --border-color: #2a2f3a;
        --accent-color: #4ade80;
        --accent-hover: #22c55e;
        --text-primary: #f8fafc;
        --text-secondary: #94a3b8;
        --chart-header: #212530;
        --table-hover: #262b36;

        background-color: var(--bg-color);
        color: var(--text-primary);
        min-height: 100vh;
        font-family: system-ui, -apple-system, sans-serif;
      }

      .hero-section {
        background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
        padding: 4rem 1.5rem 3rem;
        text-align: center;
        border-bottom: 1px solid var(--border-color);
      }

      .hero-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        letter-spacing: -0.025em;
        margin-top: 0;
      }

      .hero-subtitle {
        font-size: 1.25rem;
        color: var(--text-secondary);
        max-width: 42rem;
        margin: 0 auto;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      /* Category Grid */
      .section-title {
        font-size: 1.875rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        text-align: center;
        margin-top: 0;
      }

      .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
      }

      .category-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        transition: transform 0.2s, border-color 0.2s;
      }

      .category-card:hover {
        transform: translateY(-2px);
        border-color: var(--accent-color);
      }

      .cat-title {
        font-size: 0.875rem;
        color: var(--accent-color);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        margin-bottom: 0.5rem;
      }

      .cat-brand {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
      }

      .cat-desc {
        color: var(--text-secondary);
        font-size: 0.875rem;
        line-height: 1.5;
      }

      /* Environment Guide Section */
      .gait-guide {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 4rem;
      }

      .gait-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 2rem;
      }

      @media (max-width: 768px) {
        .gait-grid {
          grid-template-columns: 1fr;
        }
      }

      .gait-type h3 {
        color: var(--accent-color);
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        margin-top: 0;
      }

      .gait-type p {
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
      }

      /* Table Styles */
      .table-container {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow-x: auto;
        margin-bottom: 4rem;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
      }

      th {
        background: var(--chart-header);
        padding: 1rem 1.5rem;
        font-weight: 600;
        color: var(--text-secondary);
        border-bottom: 2px solid var(--border-color);
        white-space: nowrap;
      }

      td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-primary);
      }

      tr:last-child td {
        border-bottom: none;
      }

      tr:hover td {
        background: var(--table-hover);
      }

      .type-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        background: rgba(148, 163, 184, 0.1);
        color: var(--text-secondary);
      }

      .val-price {
        font-family: monospace;
        font-size: 0.875rem;
      }

      /* FAQ Section */
      .faq-section {
        max-width: 800px;
        margin: 0 auto 4rem;
      }

      .faq-item {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1rem;
      }

      .faq-q {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
      }

      .faq-a {
        color: var(--text-secondary);
        line-height: 1.6;
      }
    </style>

    <div class="hero-section">
      <h1 class="hero-title">Best Workout Headphones 2026</h1>
      <p class="hero-subtitle">
        Compare the top earbuds for your fitness routine.
      </p>
    </div>

    <main class="container">
      <section>
        <h2 class="section-title">Top Category Winners</h2>
        <div class="category-grid">
          {categories.map(cat => (
            <div class="category-card">
              <div class="cat-title">{cat.name}</div>
              <div class="cat-brand">{cat.brand}</div>
              <div class="cat-desc">{cat.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-title">Workout Environment Guide</h2>
        <div class="gait-guide">
          <div class="gait-grid">
            <div class="gait-type">
              <h3>Gym</h3>
              <p>For weightlifting or indoor cardio, look for Active Noise Cancellation (ANC) to block out the gym's music. Fit is important but a completely secure lock isn't as critical.</p>
            </div>
            <div class="gait-type">
              <h3>Running</h3>
              <p>A completely secure fit (like wingtips or ear hooks) is paramount. Sweat resistance (IPX4 or higher) is a must, and lightweight models reduce ear fatigue over long distances.</p>
            </div>
            <div class="gait-type">
              <h3>Outdoor</h3>
              <p>For cycling or trail running, situational awareness is vital for safety. Open-ear headphones or models with an excellent transparency mode are highly recommended.</p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title" style="text-align: left;">Compare Workout Headphones</h2>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Brand & Model</th>
                <th>Fit Security</th>
                <th>IP Rating</th>
                <th>Battery Life</th>
                <th>Sound Quality</th>
                <th>ANC</th>
                <th>Awareness Mode</th>
                <th>Price</th>
              </tr>
            </thead>
            <tbody>
              {headphones.map(hp => (
                <tr>
                  <td style="font-weight: 500;">{hp.brand}</td>
                  <td><span class="type-badge">{hp.fit}</span></td>
                  <td>{hp.ipx}</td>
                  <td>{hp.battery}</td>
                  <td>{hp.sound}</td>
                  <td>{hp.anc}</td>
                  <td>{hp.awareness}</td>
                  <td class="val-price">${hp.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          {schema[1].mainEntity.map((faq: any) => (
            <div class="faq-item">
              <div class="faq-q">{faq.name}</div>
              <div class="faq-a">{faq.acceptedAnswer.text}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
