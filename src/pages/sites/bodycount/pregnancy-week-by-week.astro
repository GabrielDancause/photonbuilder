    function getWeekFromDueDate(dueDateStr) {
      const dueDate = new Date(dueDateStr + 'T00:00:00');
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const totalDays = 280;
      const lmpDate = new Date(dueDate);
      lmpDate.setDate(lmpDate.getDate() - totalDays);
      const daysSinceLMP = Math.floor((today - lmpDate) / (1000 * 60 * 60 * 24));
      return Math.max(1, Math.min(40, Math.floor(daysSinceLMP / 7)));
    }

    function renderWeek(week) {
      currentWeek = Math.max(1, Math.min(40, week));
      const data = WEEK_DATA[currentWeek];

      // Week label and trimester
      document.getElementById('weekLabel').textContent = 'Week ' + currentWeek;
      let trimLabel, trimClass;
      if (currentWeek <= 12) { trimLabel = '1st Trimester'; trimClass = 't1'; }
      else if (currentWeek <= 27) { trimLabel = '2nd Trimester'; trimClass = 't2'; }
      else { trimLabel = '3rd Trimester'; trimClass = 't3'; }

      const triEl = document.getElementById('weekTrimester');
      triEl.textContent = trimLabel;
      triEl.className = 'week-nav-trimester ' + trimClass;

      // Nav buttons
      document.getElementById('prevWeek').disabled = currentWeek <= 1;
      document.getElementById('nextWeek').disabled = currentWeek >= 40;

      // Timeline marker
      const progress = Math.max(0, Math.min(100, ((currentWeek - 1) / 39) * 100));
      document.getElementById('timelineMarker').style.left = progress + '%';

      // Size hero
      document.getElementById('sizeEmoji').textContent = data.emoji;
      document.getElementById('sizeFruit').textContent = 'Size of a ' + data.fruit;
      let measurements = '~' + data.length + ' long';
      if (data.weight) measurements += ' · ~' + data.weight;
      document.getElementById('sizeMeasurements').textContent = measurements;

      // Developments
      const devList = document.getElementById('developmentsList');
      devList.innerHTML = '';
      data.developments.forEach(d => {
        const li = document.createElement('li');
        li.textContent = d;
        devList.appendChild(li);
      });

      // Symptoms
      const symList = document.getElementById('symptomsList');
      symList.innerHTML = '';
      data.symptoms.forEach(s => {
        const li = document.createElement('li');
        li.textContent = s;
        symList.appendChild(li);
      });

      // Tips
      const tipList = document.getElementById('tipsList');
      tipList.innerHTML = '';
      data.tips.forEach(t => {
        const li = document.createElement('li');
        li.textContent = t;
        tipList.appendChild(li);
      });

      // Milestones
      const mlTimeline = document.getElementById('milestoneTimeline');
      mlTimeline.innerHTML = '';
      MILESTONES.forEach(m => {
        const done = currentWeek >= m.week;
        const isCurrent = currentWeek >= m.week && (MILESTONES.indexOf(m) === MILESTONES.length - 1 || currentWeek < MILESTONES[MILESTONES.indexOf(m) + 1].week);
        const div = document.createElement('div');
        div.className = 'milestone' + (done ? ' ms-done' : '') + (isCurrent ? ' ms-current' : '');
        div.innerHTML = '<div class="ms-week">' + m.week + 'w</div><div class="ms-icon">' + m.icon + '</div><div class="ms-info"><div class="ms-title">' + m.title + '</div></div>';
        mlTimeline.appendChild(div);
      });

      document.getElementById('weekDisplay').classList.add('active');
    }

    // Form submit
    document.getElementById('weekForm').addEventListener('submit', function(e) {
      e.preventDefault();
      if (currentMethod === 'week') {
        const val = parseInt(document.getElementById('weekInput').value);
        if (!val || val < 1 || val > 40) return;
        renderWeek(val);
      } else {
        const val = document.getElementById('dueDateInput').value;
        if (!val) return;
        renderWeek(getWeekFromDueDate(val));
      }
      document.getElementById('weekDisplay').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Navigation arrows
    document.getElementById('prevWeek').addEventListener('click', function() {
      renderWeek(currentWeek - 1);
    });

    document.getElementById('nextWeek').addEventListener('click', function() {
      renderWeek(currentWeek + 1);
    });

    // Keyboard navigation
    document.addEventListener('keydown', function(e) {
      if (!document.getElementById('weekDisplay').classList.contains('active')) return;
      if (e.key === 'ArrowLeft') { renderWeek(currentWeek - 1); }
      if (e.key === 'ArrowRight') { renderWeek(currentWeek + 1); }
    });

    // Set default due date
    (function() {
      const today = new Date();
      const fourMonthsOut = new Date(today);
      fourMonthsOut.setMonth(fourMonthsOut.getMonth() + 4);
      document.getElementById('dueDateInput').value = fourMonthsOut.toISOString().split('T')[0];
    })();

    // Render milestones on load
    (function() {
      const mlTimeline = document.getElementById('milestoneTimeline');
      mlTimeline.innerHTML = '';
      MILESTONES.forEach(m => {
        const div = document.createElement('div');
        div.className = 'milestone';
        div.innerHTML = '<div class="ms-week">' + m.week + 'w</div><div class="ms-icon">' + m.icon + '</div><div class="ms-info"><div class="ms-title">' + m.title + '</div></div>';
        mlTimeline.appendChild(div);
      });
    })();
  </script>

</SiteLayout>
