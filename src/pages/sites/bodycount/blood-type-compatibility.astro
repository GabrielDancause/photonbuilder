---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Blood Type Compatibility Chart — Find Your Match | bodycount",
  description: "Interactive blood type compatibility tool. See who can donate to whom, find your compatible types, Rh factor explained, and distribution by ethnicity.",
  category: "tool"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Blood Type Compatibility Chart",
      "url": "https://bodycount.photonbuilder.com/blood-type-compatibility",
      "description": "Interactive blood type compatibility tool showing donation and receiving matrices, Rh factor info, and blood type distribution by ethnicity.",
      "applicationCategory": "HealthAndFitnessApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the universal blood donor type?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "O negative (O-) is the universal red blood cell donor type. It can be given to patients of any blood type in emergencies when there is no time to determine the recipient's blood type. This is why O- blood is always in high demand at blood banks."
          }
        },
        {
          "@type": "Question",
          "name": "What is the universal blood recipient type?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "AB positive (AB+) is the universal recipient. People with AB+ blood can receive red blood cells from any blood type — A, B, AB, or O, whether positive or negative. However, AB+ plasma is not universal; O type plasma is considered the universal plasma donor."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Rh factor and why does it matter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Rh factor is a protein (antigen D) found on the surface of red blood cells. If you have this protein, you are Rh positive (+); if not, you are Rh negative (-). It matters because receiving Rh-incompatible blood can trigger an immune response. Rh-negative individuals should only receive Rh-negative blood, while Rh-positive individuals can receive both."
          }
        },
        {
          "@type": "Question",
          "name": "What is the rarest blood type?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "AB negative (AB-) is the rarest blood type, found in less than 1% of the global population. In the US, about 0.6% of people have AB- blood. The most common blood type globally is O+, found in about 37-39% of the population."
          }
        },
        {
          "@type": "Question",
          "name": "Can parents with different blood types have a child with a third blood type?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Blood type inheritance follows Mendelian genetics. For example, a parent with type A blood and a parent with type B blood can have children with type A, B, AB, or even O blood, depending on whether their A and B alleles are homozygous or heterozygous. The Rh factor is similarly inherited, with Rh positive being dominant over Rh negative."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title={meta.title}
  description={meta.description}
  canonical="https://bodycount.photonbuilder.com/blood-type-compatibility"
  schema={schema}
>
  <style>
    .tool-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
    }
    .tool-header {
      text-align: center;
      margin-bottom: 2rem;
    }
    .tool-header h1 {
      font-size: 1.8rem;
      margin-bottom: 0.5rem;
    }
    .tool-header p {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    .selector-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      text-align: center;
    }
    .selector-section h2 {
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }
    .blood-type-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
    }
    .blood-type-buttons button {
      background: transparent;
      border: 1px solid var(--border-color);
      color: inherit;
      padding: 0.6rem 1.2rem;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 600;
      transition: all 0.2s;
    }
    .blood-type-buttons button:hover {
      border-color: var(--accent-color);
      color: var(--accent-color);
    }
    .blood-type-buttons button.active {
      background: var(--accent-color);
      border-color: var(--accent-color);
      color: #000;
    }

    .result-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1.5rem;
    }
    @media (max-width: 600px) {
      .result-cards { grid-template-columns: 1fr; }
    }
    .result-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      padding: 1.2rem;
    }
    .result-card h3 {
      font-size: 0.95rem;
      color: var(--text-secondary);
      margin-bottom: 0.75rem;
    }
    .result-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .result-tag {
      background: var(--accent-color);
      color: #000;
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.9rem;
    }
    .result-hidden {
      display: none;
    }
    .universal-badge {
      display: inline-block;
      background: var(--accent-color);
      color: #000;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 700;
      margin-left: 0.5rem;
      vertical-align: middle;
    }

    .section-title {
      font-size: 1.3rem;
      margin-bottom: 1rem;
      margin-top: 0;
    }

    .matrix-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      overflow-x: auto;
    }
    .matrix-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
      min-width: 500px;
    }
    .matrix-table th,
    .matrix-table td {
      padding: 0.5rem;
      text-align: center;
      border: 1px solid var(--border-color);
    }
    .matrix-table th {
      background: var(--border-color);
      font-weight: 600;
      font-size: 0.8rem;
    }
    .matrix-table th:first-child {
      text-align: left;
    }
    .matrix-table td:first-child {
      font-weight: 600;
      text-align: left;
      white-space: nowrap;
    }
    .matrix-table .compat {
      color: var(--accent-color);
      font-weight: 700;
    }
    .matrix-table .no-compat {
      color: var(--text-secondary);
      opacity: 0.4;
    }
    .matrix-table .highlight-row td {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
    }
    .matrix-table .highlight-col {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
    }

    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    @media (max-width: 600px) {
      .info-grid { grid-template-columns: 1fr; }
    }
    .info-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }
    .info-card h2 {
      font-size: 1.1rem;
      margin-bottom: 1rem;
    }
    .info-card p {
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .info-card strong {
      color: var(--accent-color);
    }

    .dist-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      overflow-x: auto;
    }
    .dist-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
      min-width: 600px;
    }
    .dist-table th,
    .dist-table td {
      padding: 0.5rem 0.6rem;
      text-align: center;
      border: 1px solid var(--border-color);
    }
    .dist-table th {
      background: var(--border-color);
      font-weight: 600;
      font-size: 0.8rem;
    }
    .dist-table td:first-child {
      text-align: left;
      font-weight: 600;
      white-space: nowrap;
    }
    .dist-bar {
      display: inline-block;
      height: 6px;
      background: var(--accent-color);
      border-radius: 3px;
      vertical-align: middle;
      margin-right: 0.4rem;
    }

    .faq-section {
      margin-bottom: 2rem;
    }
    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      margin-bottom: 0.75rem;
      overflow: hidden;
    }
    .faq-q {
      padding: 1rem 1.2rem;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
      font-size: 0.95rem;
    }
    .faq-q:hover { color: var(--accent-color); }
    .faq-q .arrow {
      transition: transform 0.2s;
      font-size: 0.8rem;
      color: var(--text-secondary);
    }
    .faq-item.open .faq-q .arrow { transform: rotate(180deg); }
    .faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .faq-a-inner {
      padding: 0 1.2rem 1rem;
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .faq-item.open .faq-a {
      max-height: 300px;
    }

    .rh-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }
    .rh-section h2 { font-size: 1.2rem; margin-bottom: 1rem; }
    .rh-section p {
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.7;
      margin-bottom: 0.75rem;
    }
    .rh-section ul {
      color: var(--text-secondary);
      font-size: 0.9rem;
      line-height: 1.7;
      padding-left: 1.2rem;
    }
    .rh-section li { margin-bottom: 0.3rem; }
  </style>

  <div class="tool-container">
    <div class="tool-header">
      <h1>Blood Type Compatibility Chart</h1>
      <p>Interactive tool to check blood type donation and receiving compatibility</p>
    </div>

    <!-- Selector -->
    <div class="selector-section">
      <h2>Find Your Compatible Types</h2>
      <div class="blood-type-buttons" id="typeButtons">
        <button data-type="O-">O−</button>
        <button data-type="O+">O+</button>
        <button data-type="A-">A−</button>
        <button data-type="A+">A+</button>
        <button data-type="B-">B−</button>
        <button data-type="B+">B+</button>
        <button data-type="AB-">AB−</button>
        <button data-type="AB+">AB+</button>
      </div>
      <div class="result-cards result-hidden" id="resultCards">
        <div class="result-card">
          <h3>You Can Donate To</h3>
          <div class="result-tags" id="donateTo"></div>
        </div>
        <div class="result-card">
          <h3>You Can Receive From</h3>
          <div class="result-tags" id="receiveFrom"></div>
        </div>
      </div>
    </div>

    <!-- Universal info cards -->
    <div class="info-grid">
      <div class="info-card">
        <h2>Universal Donor <span class="universal-badge">O−</span></h2>
        <p>O negative blood can be transfused to <strong>any patient</strong> regardless of their blood type. It's the type used in emergencies when there's no time to test. Only about <strong>7%</strong> of the population has O− blood, making it always in high demand.</p>
      </div>
      <div class="info-card">
        <h2>Universal Recipient <span class="universal-badge">AB+</span></h2>
        <p>AB positive individuals can receive red blood cells from <strong>any blood type</strong>. They have both A and B antigens and the Rh factor, so their immune system won't reject any donor type. Only about <strong>3%</strong> of the population has AB+ blood.</p>
      </div>
    </div>

    <!-- Donation Matrix -->
    <div class="matrix-section">
      <h2 class="section-title">Donation Compatibility Matrix</h2>
      <p style="color:var(--text-secondary);font-size:0.85rem;margin-bottom:1rem;">Rows = donor type, Columns = recipient type. ✓ = compatible.</p>
      <table class="matrix-table" id="donationMatrix">
        <thead>
          <tr>
            <th>Donor ↓ / Recipient →</th>
            <th>O−</th><th>O+</th><th>A−</th><th>A+</th><th>B−</th><th>B+</th><th>AB−</th><th>AB+</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>

    <!-- Receiving Matrix -->
    <div class="matrix-section">
      <h2 class="section-title">Receiving Compatibility Matrix</h2>
      <p style="color:var(--text-secondary);font-size:0.85rem;margin-bottom:1rem;">Rows = recipient type, Columns = donor type. ✓ = can receive from.</p>
      <table class="matrix-table" id="receivingMatrix">
        <thead>
          <tr>
            <th>Recipient ↓ / Donor →</th>
            <th>O−</th><th>O+</th><th>A−</th><th>A+</th><th>B−</th><th>B+</th><th>AB−</th><th>AB+</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>

    <!-- Rh Factor -->
    <div class="rh-section">
      <h2>Understanding the Rh Factor</h2>
      <p>The Rh factor (also called Rhesus factor) is a protein — specifically antigen D — found on the surface of red blood cells. Your blood type is classified as <strong>Rh positive (+)</strong> if you have this protein, or <strong>Rh negative (−)</strong> if you don't.</p>
      <p><strong>Key rules for Rh compatibility:</strong></p>
      <ul>
        <li><strong>Rh+ individuals</strong> can receive both Rh+ and Rh− blood.</li>
        <li><strong>Rh− individuals</strong> should only receive Rh− blood to avoid an immune reaction.</li>
        <li>About <strong>85%</strong> of the population is Rh positive.</li>
        <li><strong>Pregnancy concern:</strong> If an Rh− mother carries an Rh+ baby, her body may produce antibodies against the baby's blood. This is managed with RhoGAM injections.</li>
      </ul>
    </div>

    <!-- Distribution by Ethnicity -->
    <div class="dist-section">
      <h2 class="section-title">Blood Type Distribution by Ethnicity (US)</h2>
      <table class="dist-table" id="distTable">
        <thead>
          <tr>
            <th>Blood Type</th>
            <th>Caucasian</th>
            <th>African American</th>
            <th>Hispanic</th>
            <th>Asian</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q">What is the universal blood donor type?<span class="arrow">▼</span></div>
        <div class="faq-a"><div class="faq-a-inner">O negative (O−) is the universal red blood cell donor type. It can be given to patients of any blood type in emergencies when there's no time to determine the recipient's blood type. This is why O− blood is always in high demand at blood banks.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What is the universal blood recipient type?<span class="arrow">▼</span></div>
        <div class="faq-a"><div class="faq-a-inner">AB positive (AB+) is the universal recipient. People with AB+ blood can receive red blood cells from any blood type — A, B, AB, or O, whether positive or negative. However, AB+ plasma is not universal; O type plasma is considered the universal plasma donor.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What is the Rh factor and why does it matter?<span class="arrow">▼</span></div>
        <div class="faq-a"><div class="faq-a-inner">The Rh factor is a protein (antigen D) found on the surface of red blood cells. If you have this protein, you are Rh positive (+); if not, you are Rh negative (−). Receiving Rh-incompatible blood can trigger an immune response. Rh-negative individuals should only receive Rh-negative blood, while Rh-positive individuals can receive both.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What is the rarest blood type?<span class="arrow">▼</span></div>
        <div class="faq-a"><div class="faq-a-inner">AB negative (AB−) is the rarest blood type, found in less than 1% of the global population. In the US, about 0.6% of people have AB− blood. The most common blood type globally is O+, found in about 37–39% of the population.</div></div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Can parents with different blood types have a child with a third type?<span class="arrow">▼</span></div>
        <div class="faq-a"><div class="faq-a-inner">Yes. Blood type inheritance follows Mendelian genetics. For example, a parent with type A blood and a parent with type B blood can have children with type A, B, AB, or even O blood, depending on whether their A and B alleles are homozygous or heterozygous. The Rh factor is similarly inherited, with Rh positive being dominant.</div></div>
      </div>
    </div>
  </div>

  <script>
    const TYPES = ['O-','O+','A-','A+','B-','B+','AB-','AB+'];

    // Compatibility: which types each type can DONATE TO
    const canDonateTo = {
      'O-': ['O-','O+','A-','A+','B-','B+','AB-','AB+'],
      'O+': ['O+','A+','B+','AB+'],
      'A-': ['A-','A+','AB-','AB+'],
      'A+': ['A+','AB+'],
      'B-': ['B-','B+','AB-','AB+'],
      'B+': ['B+','AB+'],
      'AB-': ['AB-','AB+'],
      'AB+': ['AB+']
    };

    // Derive receiving from donation data
    const canReceiveFrom = {};
    TYPES.forEach(t => { canReceiveFrom[t] = []; });
    TYPES.forEach(donor => {
      canDonateTo[donor].forEach(recipient => {
        canReceiveFrom[recipient].push(donor);
      });
    });

    // Build donation matrix
    function buildMatrix(tableId, getData) {
      const tbody = document.getElementById(tableId).querySelector('tbody');
      TYPES.forEach(rowType => {
        const tr = document.createElement('tr');
        tr.dataset.type = rowType;
        const label = document.createElement('td');
        label.textContent = rowType;
        tr.appendChild(label);
        TYPES.forEach(colType => {
          const td = document.createElement('td');
          td.dataset.col = colType;
          const isCompat = getData(rowType, colType);
          td.textContent = isCompat ? '✓' : '—';
          td.className = isCompat ? 'compat' : 'no-compat';
          tr.appendChild(td);
        });
        tbody.appendChild(tr);
      });
    }

    buildMatrix('donationMatrix', (donor, recipient) => canDonateTo[donor].includes(recipient));
    buildMatrix('receivingMatrix', (recipient, donor) => canReceiveFrom[recipient].includes(donor));

    // Distribution data (approximate US percentages)
    const distribution = [
      { type: 'O+', caucasian: 37, african: 47, hispanic: 53, asian: 39 },
      { type: 'O-', caucasian: 8, african: 4, hispanic: 4, asian: 1 },
      { type: 'A+', caucasian: 33, african: 24, hispanic: 29, asian: 27 },
      { type: 'A-', caucasian: 7, african: 2, hispanic: 2, asian: 0.5 },
      { type: 'B+', caucasian: 9, african: 18, hispanic: 9, asian: 25 },
      { type: 'B-', caucasian: 2, african: 1, hispanic: 1, asian: 0.4 },
      { type: 'AB+', caucasian: 3, african: 4, hispanic: 2, asian: 7 },
      { type: 'AB-', caucasian: 1, african: 0.3, hispanic: 0.2, asian: 0.1 }
    ];

    const distTbody = document.getElementById('distTable').querySelector('tbody');
    distribution.forEach(row => {
      const tr = document.createElement('tr');
      const makeTd = (val, isLabel) => {
        const td = document.createElement('td');
        if (isLabel) {
          td.textContent = val;
        } else {
          const bar = document.createElement('span');
          bar.className = 'dist-bar';
          bar.style.width = Math.max(val * 2, 2) + 'px';
          td.appendChild(bar);
          td.appendChild(document.createTextNode(val + '%'));
        }
        return td;
      };
      tr.appendChild(makeTd(row.type, true));
      tr.appendChild(makeTd(row.caucasian));
      tr.appendChild(makeTd(row.african));
      tr.appendChild(makeTd(row.hispanic));
      tr.appendChild(makeTd(row.asian));
      distTbody.appendChild(tr);
    });

    // Type selector
    let selectedType = null;
    const buttons = document.querySelectorAll('#typeButtons button');
    const resultCards = document.getElementById('resultCards');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.type;
        if (selectedType === type) {
          selectedType = null;
          btn.classList.remove('active');
          resultCards.classList.add('result-hidden');
          clearHighlights();
          return;
        }
        selectedType = type;
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        resultCards.classList.remove('result-hidden');

        // Populate results
        const donateToEl = document.getElementById('donateTo');
        const receiveFromEl = document.getElementById('receiveFrom');
        donateToEl.innerHTML = '';
        receiveFromEl.innerHTML = '';
        canDonateTo[type].forEach(t => {
          const span = document.createElement('span');
          span.className = 'result-tag';
          span.textContent = t;
          donateToEl.appendChild(span);
        });
        canReceiveFrom[type].forEach(t => {
          const span = document.createElement('span');
          span.className = 'result-tag';
          span.textContent = t;
          receiveFromEl.appendChild(span);
        });

        highlightMatrices(type);
      });
    });

    function clearHighlights() {
      document.querySelectorAll('.matrix-table tr').forEach(tr => tr.classList.remove('highlight-row'));
      document.querySelectorAll('.matrix-table td, .matrix-table th').forEach(el => el.classList.remove('highlight-col'));
    }

    function highlightMatrices(type) {
      clearHighlights();
      // Highlight row in donation matrix
      document.querySelectorAll('#donationMatrix tbody tr').forEach(tr => {
        if (tr.dataset.type === type) tr.classList.add('highlight-row');
      });
      // Highlight column in donation matrix (where this type is recipient)
      const donIdx = TYPES.indexOf(type) + 1; // +1 for label col
      document.querySelectorAll('#donationMatrix tr').forEach(tr => {
        const cells = tr.children;
        if (cells[donIdx]) cells[donIdx].classList.add('highlight-col');
      });
      // Highlight row in receiving matrix
      document.querySelectorAll('#receivingMatrix tbody tr').forEach(tr => {
        if (tr.dataset.type === type) tr.classList.add('highlight-row');
      });
      // Highlight column in receiving matrix
      document.querySelectorAll('#receivingMatrix tr').forEach(tr => {
        const cells = tr.children;
        if (cells[donIdx]) cells[donIdx].classList.add('highlight-col');
      });
    }

    // FAQ accordion
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => {
        q.parentElement.classList.toggle('open');
      });
    });
  </script>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
