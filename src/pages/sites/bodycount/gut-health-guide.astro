---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'guide' };

const biotics = [
  { type: "Prebiotics", description: "Non-digestible fibers that feed beneficial gut bacteria.", sources: "Garlic, onions, leeks, asparagus, bananas, oats, apples." },
  { type: "Probiotics", description: "Live beneficial bacteria found in certain foods and supplements.", sources: "Yogurt, kefir, sauerkraut, kimchi, kombucha, miso, tempeh." },
  { type: "Postbiotics", description: "Beneficial compounds produced when probiotics break down prebiotics.", sources: "Short-chain fatty acids (SCFAs) like butyrate, produced during digestion." }
];

const fermentedFoods = [
  { food: "Yogurt", benefits: "Rich in lactobacillus and bifidobacterium. Look for 'live and active cultures' on the label." },
  { food: "Kefir", benefits: "A fermented milk drink with a wider variety of probiotic strains than most yogurts." },
  { food: "Sauerkraut", benefits: "Fermented cabbage that provides probiotics, fiber, and vitamins C and K." },
  { food: "Kimchi", benefits: "Spicy Korean fermented vegetables containing beneficial lactic acid bacteria." },
  { food: "Kombucha", benefits: "A lightly effervescent fermented tea. Choose low-sugar varieties for best results." }
];

const fiberTypes = [
  { type: "Soluble Fiber", role: "Dissolves in water to form a gel-like substance, slowing digestion and feeding gut bacteria.", sources: "Oats, beans, lentils, apples, blueberries." },
  { type: "Insoluble Fiber", role: "Adds bulk to stool and helps food pass more quickly through the stomach and intestines.", sources: "Whole wheat, quinoa, brown rice, legumes, leafy greens." }
];

const poorGutHealthSigns = [
  { sign: "Digestive Issues", details: "Frequent bloating, gas, diarrhea, constipation, or heartburn." },
  { sign: "Unintentional Weight Changes", details: "Gaining or losing weight without making changes to diet or exercise habits." },
  { sign: "Sleep Disturbances", details: "Insomnia or poor sleep quality, as most of the body's serotonin is produced in the gut." },
  { sign: "Skin Conditions", details: "Eczema, acne, and other skin irritations may be related to inflammation in the gut." },
  { sign: "Food Intolerances", details: "Difficulty digesting certain foods, often leading to bloating and abdominal pain." }
];

const eliminationSteps = [
  { step: "1. Elimination", description: "Remove suspected trigger foods (like dairy, gluten, soy, artificial sweeteners) for 2-4 weeks to let the gut heal." },
  { step: "2. Reintroduction", description: "Slowly reintroduce one food group at a time, every 3-4 days, while monitoring for symptoms." },
  { step: "3. Personalization", description: "Create a customized, sustainable diet that avoids only the specific foods that cause symptoms." }
];

const probioticStrains = [
  { strain: "Lactobacillus acidophilus", function: "Helps digest lactose, reduces diarrhea, and supports vaginal health." },
  { strain: "Bifidobacterium bifidum", function: "Supports immune function, aids in digestion, and fights harmful bacteria in the intestine." },
  { strain: "Lactobacillus rhamnosus", function: "May help prevent and treat gastrointestinal infections and diarrhea." },
  { strain: "Saccharomyces boulardii", function: "A beneficial yeast that helps treat and prevent diarrhea, including antibiotic-associated diarrhea." }
];

const lifestyleFactors = [
  { factor: "Sleep", impact: "Poor sleep can negatively affect the microbiome, while good gut health can improve sleep quality." },
  { factor: "Stress", impact: "Chronic stress alters the gut bacteria composition and can increase intestinal permeability." },
  { factor: "Exercise", impact: "Regular physical activity increases the diversity of beneficial microbial species in the gut." }
];

const faqList = [
  {
    question: "How long does it take to improve gut health?",
    answer: "You can see some changes in your gut microbiome within a few days of changing your diet, but significant, lasting improvements usually take several weeks to months of consistent dietary and lifestyle habits."
  },
  {
    question: "Do I need to take a probiotic supplement?",
    answer: "Not necessarily. If you eat a diverse diet rich in fiber and fermented foods, you may not need a supplement. However, specific strains can be helpful for certain conditions like irritable bowel syndrome (IBS) or after taking antibiotics."
  },
  {
    question: "What are FODMAPs?",
    answer: "FODMAPs are fermentable oligosaccharides, disaccharides, monosaccharides, and polyols. These are types of carbohydrates that are poorly absorbed in the small intestine and can cause digestive distress in sensitive individuals."
  },
  {
    question: "What is the gut-brain axis?",
    answer: "The gut-brain axis is the two-way communication network between your central nervous system (brain) and the enteric nervous system (gut). This connection explains why stress affects digestion and why gut health impacts mood."
  },
  {
    question: "Can drinking water help my gut health?",
    answer: "Yes, staying hydrated has been shown to have a beneficial effect on the mucosal lining of the intestines, as well as on the balance of good bacteria in the gut. It also helps fiber do its job of keeping your bowel movements regular."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://bodycount.photonbuilder.com/gut-health-guide"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqList.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  }
];
---

<SiteLayout
  site="bodycount"
  title="Gut Health Guide | BodyCount"
  description="Evidence-based gut health guide covering microbiome basics, probiotics, fermented foods, fiber, elimination diets, and the gut-brain axis."
  canonical="https://bodycount.photonbuilder.com/gut-health-guide"
  schema={JSON.stringify(schema)}
>
  <style>
    .page-wrapper {
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 2rem 1rem;
    }

    h1, h2, h4 {
      color: var(--text-primary);
    }

    h1 {
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    ul, ol {
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 1.5rem;
      padding-left: 1.5rem;
    }

    li {
      margin-bottom: 0.5rem;
    }

    li strong {
      color: var(--text-primary);
    }

    .highlight-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      border-radius: 0 8px 8px 0;
      margin: 2rem 0;
    }

    .highlight-box h4 {
      color: var(--accent-color);
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    th {
      background: var(--chart-header);
      color: var(--text-primary);
      font-weight: 600;
    }

    tr:last-child td {
      border-bottom: none;
    }
  </style>

  <div class="page-wrapper">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h1>Gut Health Guide</h1>
      <div style="max-width: 800px; margin: 0 auto; color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem;">
        An evidence-based guide to understanding your microbiome. Learn about probiotics, fiber, fermented foods, elimination diets, and the gut-brain axis to optimize your digestion and overall well-being.
      </div>
    </div>

    <main style="max-width: 1000px; margin: 0 auto;">
      <section>
        <h2>Microbiome Basics & The Gut-Brain Axis</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">
          Your gut microbiome consists of trillions of bacteria, viruses, and fungi living in your digestive tract. This complex ecosystem plays a crucial role in digestion, immune function, and metabolism.
          <br/><br/>
          Through the <strong>gut-brain axis</strong>, a bidirectional communication network, the health of your gut directly influences your central nervous system. This explains why emotional stress can trigger digestive issues, and conversely, why an imbalanced microbiome can affect mood, anxiety, and cognitive function.
        </div>
      </section>

      <section>
        <h2>Signs of Poor Gut Health</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Recognize the common symptoms that indicate your microbiome might be out of balance.</div>
        <ul>
          {poorGutHealthSigns.map(item => (
            <li><strong>{item.sign}:</strong> {item.details}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Prebiotics vs. Probiotics vs. Postbiotics</h2>
        <table>
          <thead>
            <tr>
              <th>Type</th>
              <th>Description</th>
              <th>Common Sources</th>
            </tr>
          </thead>
          <tbody>
            {biotics.map(item => (
              <tr>
                <td><strong>{item.type}</strong></td>
                <td>{item.description}</td>
                <td>{item.sources}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Fermented Foods for Gut Health</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Incorporate these naturally probiotic-rich foods into your diet.</div>
        <ul>
          {fermentedFoods.map(item => (
            <li><strong>{item.food}:</strong> {item.benefits}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Fiber Types & Sources</h2>
        <div class="highlight-box">
          <h4>Fuel for Your Microbiome</h4>
          <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1rem;">Fiber is essential for gut motility and feeding beneficial bacteria. Both types are necessary for optimal health.</div>
          <ul style="margin-bottom: 0;">
            {fiberTypes.map(item => (
              <li><strong>{item.type}:</strong> {item.role} <em>Sources: {item.sources}</em></li>
            ))}
          </ul>
        </div>
      </section>

      <section>
        <h2>The Elimination Diet Protocol & FODMAPs</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">
          An elimination diet helps identify food intolerances. One common approach targets <strong>FODMAPs</strong> (Fermentable Oligosaccharides, Disaccharides, Monosaccharides, and Polyols)—types of carbohydrates that are poorly absorbed and can trigger digestive distress.
        </div>
        <ol>
          {eliminationSteps.map(item => (
            <li><strong>{item.step}:</strong> {item.description}</li>
          ))}
        </ol>
      </section>

      <section>
        <h2>Probiotic Supplements</h2>
        <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">Specific bacterial strains offer different health benefits.</div>
        <table>
          <thead>
            <tr>
              <th>Strain</th>
              <th>Function</th>
            </tr>
          </thead>
          <tbody>
            {probioticStrains.map(item => (
              <tr>
                <td><strong>{item.strain}</strong></td>
                <td>{item.function}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Lifestyle Factors</h2>
        <ul>
          {lifestyleFactors.map(item => (
            <li><strong>{item.factor}:</strong> {item.impact}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2 style="text-align: center;">Frequently Asked Questions</h2>
        <div>
          {faqList.map(faq => (
            <div style="margin-bottom: 1.5rem;">
              <div style="font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary);">{faq.question}</div>
              <div style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; font-size: 1.05rem;">{faq.answer}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
