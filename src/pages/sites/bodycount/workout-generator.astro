        { name: 'Dead Bug', muscle: 'core', equipment: 'bodyweight', difficulty: 'beginner', tip: 'On back, arms up, knees at 90. Extend opposite arm and leg. Keep lower back flat on floor.' },
        { name: 'Side Plank', muscle: 'core', equipment: 'bodyweight', difficulty: 'intermediate', tip: 'On one forearm and stacked feet. Hips up, body straight. Hold for time each side.' },
        { name: 'Hanging Knee Raises', muscle: 'core', equipment: 'bodyweight', difficulty: 'intermediate', tip: 'Hang from bar, bring knees to chest. Do not swing. Control the movement.' },
        { name: 'Hanging Leg Raises', muscle: 'core', equipment: 'bodyweight', difficulty: 'advanced', tip: 'Hang from bar, raise straight legs to parallel. Requires strong grip and hip flexors.' },
        { name: 'L-Sit Hold', muscle: 'core', equipment: 'bodyweight', difficulty: 'advanced', tip: 'Support on parallel bars or floor with legs extended in front. Hold. Extremely demanding.' },
        { name: 'Dragon Flags', muscle: 'core', equipment: 'bodyweight', difficulty: 'advanced', tip: 'Lie on bench, grip behind head. Raise body as one unit. Lower slowly with control.' },
        { name: 'V-Ups', muscle: 'core', equipment: 'bodyweight', difficulty: 'intermediate', tip: 'Lie flat, simultaneously raise legs and torso to touch toes. Lower with control.' },

        // CORE — Dumbbells
        { name: 'Dumbbell Russian Twist', muscle: 'core', equipment: 'dumbbells', difficulty: 'intermediate', tip: 'Hold dumbbell at chest, lean back. Rotate side to side touching weight to floor.' },
        { name: 'Dumbbell Side Bend', muscle: 'core', equipment: 'dumbbells', difficulty: 'beginner', tip: 'Hold dumbbell in one hand, bend sideways. Return to upright. Hit both sides evenly.' },
        { name: 'Weighted Sit-Ups', muscle: 'core', equipment: 'dumbbells', difficulty: 'intermediate', tip: 'Hold dumbbell at chest. Perform sit-up. Add weight gradually as you get stronger.' },
        { name: 'Dumbbell Woodchop', muscle: 'core', equipment: 'dumbbells', difficulty: 'intermediate', tip: 'Diagonal chop from high to low or low to high. Engages entire core rotationally.' },
        { name: 'Farmer Carry', muscle: 'core', equipment: 'dumbbells', difficulty: 'beginner', tip: 'Hold heavy dumbbells at sides and walk. Grip strength, core stability, and posture all benefit.' },

        // CORE — Barbell
        { name: 'Ab Rollout', muscle: 'core', equipment: 'barbell', difficulty: 'intermediate', tip: 'Kneel, roll barbell forward extending body. Pull back with abs. Do not let hips sag.' },
        { name: 'Barbell Landmine Rotation', muscle: 'core', equipment: 'barbell', difficulty: 'intermediate', tip: 'One end in corner, press and rotate to each side. Targets obliques powerfully.' },
        { name: 'Suitcase Deadlift', muscle: 'core', equipment: 'barbell', difficulty: 'advanced', tip: 'Deadlift barbell with one hand at center. Anti-lateral flexion challenge for the core.' },

        // CORE — Bands
        { name: 'Band Pallof Press', muscle: 'core', equipment: 'bands', difficulty: 'beginner', tip: 'Anchor at chest height. Press band straight out resisting rotation. Hold 2-3 seconds.' },
        { name: 'Band Woodchop', muscle: 'core', equipment: 'bands', difficulty: 'intermediate', tip: 'Anchor high or low. Pull diagonally across body. Controlled rotation through the core.' },
        { name: 'Band Dead Bug', muscle: 'core', equipment: 'bands', difficulty: 'intermediate', tip: 'Attach band to rig, perform dead bug with added resistance. Enhances the anti-extension demand.' },

        // CORE — Gym
        { name: 'Cable Crunch', muscle: 'core', equipment: 'gym', difficulty: 'beginner', tip: 'Kneel facing cable, crunch down bringing elbows to knees. Keep hips stationary.' },
        { name: 'Cable Woodchop', muscle: 'core', equipment: 'gym', difficulty: 'intermediate', tip: 'Set cable high or low. Pull across body in chopping motion. Rotate through the torso.' },
        { name: 'Cable Pallof Press', muscle: 'core', equipment: 'gym', difficulty: 'beginner', tip: 'Stand perpendicular to cable. Press handle forward resisting the pull. Anti-rotation exercise.' },
        { name: 'Ab Machine Crunch', muscle: 'core', equipment: 'gym', difficulty: 'beginner', tip: 'Adjust pad on shoulders. Crunch forward with abs, not arms. Controlled tempo.' }
      ];

      const MUSCLE_NAMES = {
        chest: 'Chest', back: 'Back', shoulders: 'Shoulders',
        legs: 'Legs', arms: 'Arms', core: 'Core', fullbody: 'Full Body'
      };
      const EQUIP_NAMES = {
        bodyweight: 'Bodyweight', dumbbells: 'Dumbbells', barbell: 'Barbell',
        bands: 'Bands', gym: 'Full Gym'
      };

      const DIFF_CONFIG = {
        beginner:     { sets: [2, 3], reps: [10, 15], rest: [60, 90] },
        intermediate: { sets: [3, 4], reps: [8, 12],  rest: [45, 75] },
        advanced:     { sets: [4, 5], reps: [6, 10],  rest: [30, 60] }
      };

      const DURATION_EXERCISES = { 15: 4, 30: 5, 45: 6, 60: 8 };

      let currentWorkout = null;

      function getVal(name) {
        const el = document.querySelector(`input[name="${name}"]:checked`);
        return el ? el.value : null;
      }

      function randBetween(min, max) {
        return Math.floor(Math.random() * (max - min + 1)) + min;
      }

      function shuffle(arr) {
        const a = [...arr];
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
      }

      function filterExercises(muscle, equipment, difficulty) {
        const equipmentOptions = equipment === 'gym'
          ? ['bodyweight', 'dumbbells', 'barbell', 'gym']
          : equipment === 'barbell'
            ? ['bodyweight', 'barbell']
            : equipment === 'dumbbells'
              ? ['bodyweight', 'dumbbells']
              : [equipment];

        const difficultyOptions = difficulty === 'advanced'
          ? ['beginner', 'intermediate', 'advanced']
          : difficulty === 'intermediate'
            ? ['beginner', 'intermediate']
            : ['beginner'];

        let muscles;
        if (muscle === 'fullbody') {
          muscles = ['chest', 'back', 'shoulders', 'legs', 'arms', 'core'];
        } else {
          muscles = [muscle];
        }

        return EXERCISES.filter(e =>
          muscles.includes(e.muscle) &&
          equipmentOptions.includes(e.equipment) &&
          difficultyOptions.includes(e.difficulty)
        );
      }

      function generateWorkout() {
        const muscle = getVal('muscle');
        const equipment = getVal('equipment');
        const difficulty = getVal('difficulty');
        const duration = parseInt(getVal('duration'));

        if (!muscle || !equipment || !difficulty || !duration) return;

        const count = DURATION_EXERCISES[duration];
        const config = DIFF_CONFIG[difficulty];
        let pool = filterExercises(muscle, equipment, difficulty);

        if (pool.length === 0) return;

        let selected;
        if (muscle === 'fullbody') {
          const muscleGroups = ['chest', 'back', 'shoulders', 'legs', 'arms', 'core'];
          selected = [];
          const perGroup = Math.max(1, Math.floor(count / muscleGroups.length));
          const shuffledGroups = shuffle(muscleGroups);

          for (const mg of shuffledGroups) {
            const groupPool = pool.filter(e => e.muscle === mg);
            if (groupPool.length === 0) continue;
            const picked = shuffle(groupPool).slice(0, perGroup);
            selected.push(...picked);
            if (selected.length >= count) break;
          }

          // Fill remaining slots if needed
          if (selected.length < count) {
            const remaining = pool.filter(e => !selected.includes(e));
            selected.push(...shuffle(remaining).slice(0, count - selected.length));
          }
          selected = selected.slice(0, count);
        } else {
          selected = shuffle(pool).slice(0, count);
        }

        const workout = selected.map((exercise, i) => {
          const sets = randBetween(config.sets[0], config.sets[1]);
          const reps = randBetween(config.reps[0], config.reps[1]);
          const rest = randBetween(config.rest[0], config.rest[1]);
          return { ...exercise, sets, reps, rest, order: i + 1 };
        });

        currentWorkout = {
          id: Date.now(),
          muscle, equipment, difficulty, duration,
          exercises: workout,
          createdAt: new Date().toISOString()
        };

        renderWorkout(currentWorkout);
      }

      function renderWorkout(workout) {
        const { muscle, equipment, difficulty, duration, exercises } = workout;

        document.getElementById('workoutTitle').textContent =
          `${MUSCLE_NAMES[muscle]} Workout`;

        const metaEl = document.getElementById('workoutMeta');
        metaEl.innerHTML = `
          <span class="workout-meta-item">${EQUIP_NAMES[equipment]}</span>
          <span class="workout-meta-item">${difficulty.charAt(0).toUpperCase() + difficulty.slice(1)}</span>
          <span class="workout-meta-item">${duration} min</span>
        `;

        const totalSets = exercises.reduce((sum, e) => sum + e.sets, 0);

        document.getElementById('totalExercises').textContent = exercises.length;
        document.getElementById('totalSets').textContent = totalSets;
        document.getElementById('totalDuration').textContent = duration;

        const listEl = document.getElementById('exerciseList');
        listEl.innerHTML = exercises.map(e => `
          <div class="exercise-item">
            <div class="exercise-top">
              <div>
                <div class="exercise-number">EXERCISE ${e.order}</div>
                <div class="exercise-name">${e.name}</div>
              </div>
              <div class="exercise-badges">
                <span class="exercise-badge badge-muscle">${MUSCLE_NAMES[e.muscle]}</span>
                <span class="exercise-badge badge-equip">${EQUIP_NAMES[e.equipment]}</span>
              </div>
            </div>
            <div class="exercise-details">
              <div class="exercise-detail">
                <div class="exercise-detail-label">Sets</div>
                <div class="exercise-detail-value">${e.sets}</div>
              </div>
              <div class="exercise-detail">
                <div class="exercise-detail-label">Reps</div>
                <div class="exercise-detail-value">${e.reps}</div>
              </div>
              <div class="exercise-detail">
                <div class="exercise-detail-label">Rest</div>
                <div class="exercise-detail-value">${e.rest}s</div>
              </div>
            </div>
            <div class="exercise-tip"><strong>Form tip:</strong> ${e.tip}</div>
          </div>
        `).join('');

        // Update save button state
        const saveBtn = document.getElementById('saveBtn');
        const favorites = getFavorites();
        const isSaved = favorites.some(f => f.id === workout.id);
        saveBtn.textContent = isSaved ? 'Saved' : 'Save to Favorites';
        saveBtn.classList.toggle('saved', isSaved);

        document.getElementById('results').classList.add('active');
        renderFavorites();
        document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Favorites management
      function getFavorites() {
        try {
          return JSON.parse(localStorage.getItem('bc_workout_favorites') || '[]');
        } catch { return []; }
      }

      function saveFavorites(favs) {
        localStorage.setItem('bc_workout_favorites', JSON.stringify(favs));
      }

      function renderFavorites() {
        const favs = getFavorites();
        const container = document.getElementById('favoritesList');
        const section = document.getElementById('favoritesSection');

        if (favs.length === 0) {
          container.innerHTML = '<div class="no-favorites">No saved workouts yet. Generate a workout and save it.</div>';
          return;
        }

        container.innerHTML = favs.map((fav, idx) => {
          const date = new Date(fav.createdAt).toLocaleDateString();
          return `
            <div class="favorite-item">
              <div class="favorite-info">
                <div class="favorite-name">${MUSCLE_NAMES[fav.muscle]} Workout</div>
                <div class="favorite-details">${EQUIP_NAMES[fav.equipment]} &middot; ${fav.difficulty} &middot; ${fav.duration} min &middot; ${fav.exercises.length} exercises &middot; ${date}</div>
              </div>
              <div class="favorite-actions">
                <button class="favorite-load-btn" data-idx="${idx}">Load</button>
                <button class="favorite-delete-btn" data-idx="${idx}">Delete</button>
              </div>
            </div>
          `;
        }).join('');

        container.querySelectorAll('.favorite-load-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const idx = parseInt(btn.dataset.idx);
            const fav = getFavorites()[idx];
            if (fav) {
              currentWorkout = fav;
              renderWorkout(fav);
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          });
        });

        container.querySelectorAll('.favorite-delete-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const idx = parseInt(btn.dataset.idx);
            const favs = getFavorites();
            favs.splice(idx, 1);
            saveFavorites(favs);
            renderFavorites();
          });
        });
      }

      // Event listeners
      document.getElementById('generateBtn').addEventListener('click', generateWorkout);
      document.getElementById('shuffleBtn').addEventListener('click', generateWorkout);

      document.getElementById('saveBtn').addEventListener('click', () => {
        if (!currentWorkout) return;
        const favs = getFavorites();
        const exists = favs.some(f => f.id === currentWorkout.id);
        if (!exists) {
          favs.unshift(currentWorkout);
          if (favs.length > 20) favs.pop();
          saveFavorites(favs);
          const saveBtn = document.getElementById('saveBtn');
          saveBtn.textContent = 'Saved';
          saveBtn.classList.add('saved');
          renderFavorites();
        }
      });

      document.getElementById('clearFavoritesBtn').addEventListener('click', () => {
        if (confirm('Clear all saved workouts?')) {
          saveFavorites([]);
          renderFavorites();
        }
      });

      // FAQ toggle
      document.querySelectorAll('.faq-question').forEach(q => {
        q.addEventListener('click', () => {
          q.parentElement.classList.toggle('open');
        });
      });

      // Initialize favorites display
      renderFavorites();
    });
  </script>
</SiteLayout>
