---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Best Protein Powders",
    "url": "https://bodycount.photonbuilder.com/best-protein-powders",
    "description": "The ultimate guide to the 12 best protein powders. Compare whey, casein, and plant-based options by protein, calories, sugar, and price. Find the best protein powder for your goals."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the best type of protein powder?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Whey protein isolate is generally considered the best for post-workout due to its rapid absorption and high amino acid profile. Casein is great for sustained release (e.g., before bed), and plant-based blends are best for vegans."
        }
      },
      {
        "@type": "Question",
        "name": "Is whey or plant protein better?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Whey is a complete protein with higher bioavailability, making it slightly superior for muscle synthesis. However, a high-quality plant-based blend (e.g., pea and rice) can be equally effective and is better for those with dairy sensitivities."
        }
      },
      {
        "@type": "Question",
        "name": "How much protein powder should I consume per day?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on your overall daily protein goals. Most people use 1-2 scoops (20-50g) daily to supplement their diet. Whole foods should make up the majority of your intake."
        }
      },
      {
        "@type": "Question",
        "name": "Can protein powder cause bloating?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, especially whey concentrate if you are sensitive to lactose. Artificial sweeteners or thickeners can also cause bloating. Choosing an isolate, a plant-based option, or a powder without artificial additives can help."
        }
      },
      {
        "@type": "Question",
        "name": "What should I look for when buying protein powder?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Look for a high protein-to-calorie ratio, minimal added sugars, third-party testing for purity, and a short ingredient list. Avoid excessive fillers or artificial colors."
        }
      },
      {
        "@type": "Question",
        "name": "Does protein powder expire?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, it typically has a shelf life of 12-18 months. If stored in a cool, dry place, it can last longer, but consuming it past the expiration date can decrease its potency or cause stomach upset if it has spoiled."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use protein powder for baking?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, whey and casein blends work well for baking. Plant proteins can be trickier as they absorb more liquid. You may need to adjust the recipe's wet ingredients when substituting flour with protein powder."
        }
      }
    ]
  }
];

const categories = [
  { name: 'Best Overall', brand: 'Optimum Nutrition Gold Standard', desc: 'The gold standard for a reason. Great taste, mixability, and value.' },
  { name: 'Best Budget', brand: 'MyProtein Impact Whey', desc: 'Incredible value without sacrificing quality or protein content.' },
  { name: 'Best Tasting', brand: 'Ghost Whey', desc: 'Unique flavor collaborations that actually taste amazing.' },
  { name: 'Best Vegan', brand: 'Vega Sport Premium', desc: 'High protein plant blend with added BCAAs for recovery.' },
  { name: 'Best for Lactose Intolerant', brand: 'Dymatize ISO100', desc: 'Hydrolyzed whey isolate that is ultra-fast digesting and lactose-free.' },
];

const powders = [
  { brand: 'Optimum Nutrition Gold Standard', type: 'Whey Blend', protein: 24, calories: 120, sugar: 1, price: 0.85 },
  { brand: 'Dymatize ISO100', type: 'Hydrolyzed Whey', protein: 25, calories: 110, sugar: '<1', price: 1.15 },
  { brand: 'MyProtein Impact', type: 'Whey Concentrate', protein: 21, calories: 100, sugar: 1, price: 0.55 },
  { brand: 'Ghost Whey', type: 'Whey Blend', protein: 25, calories: 130, sugar: 2, price: 1.40 },
  { brand: 'Transparent Labs', type: 'Whey Isolate', protein: 28, calories: 120, sugar: 0, price: 1.66 },
  { brand: 'Garden of Life Organic', type: 'Plant', protein: 22, calories: 130, sugar: 0, price: 1.50 },
  { brand: 'Orgain', type: 'Plant', protein: 21, calories: 150, sugar: 0, price: 1.10 },
  { brand: 'Vega Sport', type: 'Plant', protein: 30, calories: 160, sugar: 1, price: 1.80 },
  { brand: 'BSN Syntha-6', type: 'Whey/Casein Blend', protein: 22, calories: 200, sugar: 3, price: 1.05 },
  { brand: 'Isopure', type: 'Whey Isolate', protein: 25, calories: 100, sugar: 0, price: 1.45 },
  { brand: 'PEScience Select', type: 'Whey/Casein Blend', protein: 24, calories: 110, sugar: '<1', price: 1.25 },
  { brand: 'Premier Protein', type: 'Whey/Casein Blend', protein: 30, calories: 160, sugar: 1, price: 1.00 },
];
---

<SiteLayout
  site="bodycount"
  title="12 Best Protein Powders (Whey, Casein, Plant) - BodyCount"
  description="Compare the 12 best protein powders for muscle growth. See nutrition facts, prices, and top picks for whey, casein, and plant proteins."
  canonical="https://bodycount.photonbuilder.com/best-protein-powders"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <style is:global>
    :root {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-primary);
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Category Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .category-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }

    .cat-title {
      font-size: 0.875rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .cat-brand {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .cat-desc {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
    }

    /* Table Styles */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 4rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background: var(--chart-header);
      padding: 1rem 1.5rem;
      font-weight: 600;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
      transition: color 0.2s;
    }

    th:hover {
      color: var(--text-primary);
    }

    td {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--table-hover);
    }

    .type-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-secondary);
    }

    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <div class="hero-section">
    <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">12 Best Protein Powders</h1>
    <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
      Compare the top whey, casein, and plant-based protein powders based on nutrition, price, and quality.
    </p>
  </div>

  <main class="container">
    <section>
      <h2 class="text-3xl font-bold mb-6 text-center">Top Category Winners</h2>
      <div class="category-grid">
        {categories.map(cat => (
          <div class="category-card">
            <div class="cat-title">{cat.name}</div>
            <div class="cat-brand">{cat.brand}</div>
            <div class="cat-desc">{cat.desc}</div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Compare All Protein Powders</h2>
      <p class="text-[var(--text-secondary)] mb-6 text-sm">Click column headers to sort.</p>

      <div class="table-container">
        <table id="powderTable">
          <thead>
            <tr>
              <th data-sort="brand">Brand ↕</th>
              <th data-sort="type">Type ↕</th>
              <th data-sort="protein">Protein (g) ↕</th>
              <th data-sort="calories">Calories ↕</th>
              <th data-sort="sugar">Sugar (g) ↕</th>
              <th data-sort="price">Price / Serving ($) ↕</th>
            </tr>
          </thead>
          <tbody id="powderTbody">
            {powders.map(powder => (
              <tr>
                <td class="font-medium">{powder.brand}</td>
                <td><span class="type-badge">{powder.type}</span></td>
                <td class="font-bold text-[var(--accent-color)]" data-val={powder.protein}>{powder.protein}g</td>
                <td data-val={powder.calories}>{powder.calories}</td>
                <td data-val={powder.sugar === '<1' ? 0.5 : powder.sugar}>{powder.sugar}g</td>
                <td class="font-mono text-sm" data-val={powder.price}>${powder.price.toFixed(2)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="faq-section">
      <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="faq-list">
        {schema[1].mainEntity.map((faq: any) => (
          <div class="faq-item">
            <div class="faq-q">{faq.name}</div>
            <div class="faq-a">{faq.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    const tbody = document.getElementById('powderTbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    let currentSort = { col: null, asc: true };

    function applySort() {
      rows.sort((a, b) => {
        let valA, valB;
        if (currentSort.col === 'brand' || currentSort.col === 'type') {
          valA = a.querySelector(`td:nth-child(${currentSort.col === 'brand' ? 1 : 2})`).textContent.trim();
          valB = b.querySelector(`td:nth-child(${currentSort.col === 'brand' ? 1 : 2})`).textContent.trim();
          return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else {
          const idx = currentSort.col === 'protein' ? 3 : (currentSort.col === 'calories' ? 4 : (currentSort.col === 'sugar' ? 5 : 6));
          valA = parseFloat(a.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          valB = parseFloat(b.querySelector(`td:nth-child(${idx})`).getAttribute('data-val'));
          return currentSort.asc ? valA - valB : valB - valA;
        }
      });

      tbody.innerHTML = '';
      rows.forEach(r => tbody.appendChild(r));
    }

    function handleSortClick(e) {
      if (e.target.tagName !== 'TH' || !e.target.dataset.sort) return;

      const col = e.target.dataset.sort;
      if (currentSort.col === col) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort.col = col;
        currentSort.asc = true;
      }

      applySort();
    }

    document.querySelector('thead').addEventListener('click', handleSortClick);
  </script>
</SiteLayout>
