---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = { category: "tool" };

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Body Type Quiz",
  "url": "https://bodycount.photonbuilder.com/body-type-quiz.html",
  "description": "Take our body type quiz to find out if you're an ectomorph, mesomorph, or endomorph. Get personalized training and nutrition recommendations for your somatotype.",
  "applicationCategory": "HealthAndFitnessApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the 3 body types?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The three somatotypes are ectomorph (lean, long limbs, fast metabolism), mesomorph (muscular, medium frame, gains muscle easily), and endomorph (wider build, stores fat easily, strong lower body). Most people are a combination of two or all three types."
      }
    },
    {
      "@type": "Question",
      "name": "Can your body type change over time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your skeletal frame and genetic predispositions don't change, but your body composition absolutely can. Through targeted training and nutrition, an endomorph can become lean and an ectomorph can build significant muscle. Body type describes your natural tendencies, not your destiny."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate is the ectomorph mesomorph endomorph quiz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Somatotype quizzes provide a useful general classification based on your bone structure, metabolism, and body composition tendencies. While not a clinical assessment, they help identify your dominant body type so you can tailor your training and nutrition approach. Most people are a blend of two types."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best diet for my body type?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ectomorphs benefit from higher carb and calorie intake to support growth. Mesomorphs do well with balanced macros (40% carbs, 30% protein, 30% fat). Endomorphs often respond best to higher protein and fat with moderate carbs. However, total calories and protein intake matter more than body type for most goals."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best workout for my body type?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ectomorphs should focus on heavy compound lifts with lower volume and longer rest periods. Mesomorphs respond well to varied training with moderate volume. Endomorphs benefit from combining resistance training with higher-intensity cardio. All body types should prioritize progressive overload and consistency."
      }
    },
    {
      "@type": "Question",
      "name": "Can you be a combination of body types?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — most people are a combination. Common blends include ecto-mesomorph (lean and muscular), endo-mesomorph (muscular but carries more fat), and ecto-endomorph (slim upper body, stores fat in lower body). Our quiz gives you percentage scores for each type to show your unique blend."
      }
    }
  ]
};
---

<SiteLayout
  site="bodycount"
  title="Body Type Quiz — Ectomorph, Mesomorph, or Endomorph | ijustwantto.live"
  description="Take this body type quiz to discover your somatotype. Find out if you're an ectomorph, mesomorph, or endomorph and get personalized training and nutrition advice."
  canonical="https://bodycount.photonbuilder.com/body-type-quiz" schema={schema}
>
  <style>
:root {
            --bg-color: #060c0a;
            --card-bg: #0c1410;
            --border-color: #1a2a24;
            --accent-color: #2DB89A;
            --accent-hover: #24987f;
            --text-primary: #c8e0d8;
            --text-secondary: #888888;
            --font-ui: 'Inter', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;

            --ecto-color: #3b82f6;
            --meso-color: #10b981;
            --endo-color: #f59e0b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-ui);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        header {
            text-align: center;
            margin-bottom: 2rem;
        }

        h1 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
            color: #ffffff;
        }

        p.subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        /* Progress bar */
        .progress-container {
            margin-bottom: 1.5rem;
        }

        .progress-info {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 0.5rem;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background-color: var(--bg-color);
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background-color: var(--accent-color);
            border-radius: 3px;
            transition: width 0.3s ease;
            width: 0%;
        }

        /* Quiz questions */
        .question-container {
            display: none;
        }

        .question-container.active {
            display: block;
            animation: fadeIn 0.3s ease-in-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .question-number {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .question-text {
            font-size: 1.125rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 1.25rem;
            line-height: 1.4;
        }

        .options {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .option-btn {
            width: 100%;
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 1rem 1.25rem;
            border-radius: 8px;
            font-size: 0.95rem;
            font-family: var(--font-ui);
            text-align: left;
            cursor: pointer;
            transition: all 0.2s;
            line-height: 1.4;
        }

        .option-btn:hover {
            border-color: var(--accent-color);
            background-color: rgba(45, 184, 154, 0.05);
        }

        .option-btn.selected {
            border-color: var(--accent-color);
            background-color: rgba(45, 184, 154, 0.1);
        }

        /* Navigation */
        .quiz-nav {
            display: flex;
            justify-content: space-between;
            margin-top: 1.5rem;
            gap: 1rem;
        }

        .nav-btn {
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            font-family: var(--font-ui);
            transition: all 0.2s;
        }

        .nav-btn:hover {
            border-color: var(--accent-color);
        }

        .nav-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .nav-btn.primary {
            background-color: var(--accent-color);
            color: #000;
            border-color: var(--accent-color);
        }

        .nav-btn.primary:hover {
            background-color: var(--accent-hover);
        }

        .nav-btn.primary:disabled {
            opacity: 0.3;
        }

        /* Results */
        .results {
            display: none;
            animation: fadeIn 0.3s ease-in-out;
        }

        .results.active {
            display: block;
        }

        .result-type-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .result-type-label {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--accent-color);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.5rem;
        }

        .result-type-name {
            font-size: 2rem;
            font-weight: 800;
            color: #ffffff;
            margin-bottom: 0.25rem;
        }

        .result-type-desc {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        /* Body shape illustration */
        .body-illustration {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .body-figure {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            opacity: 0.35;
            transition: opacity 0.3s;
        }

        .body-figure.highlighted {
            opacity: 1;
        }

        .body-shape {
            width: 60px;
            height: 120px;
            position: relative;
        }

        /* Ectomorph - narrow, linear */
        .shape-ecto .body-torso {
            width: 20px;
            height: 50px;
            background: var(--ecto-color);
            border-radius: 8px 8px 4px 4px;
            margin: 0 auto;
        }
        .shape-ecto .body-head {
            width: 18px;
            height: 18px;
            background: var(--ecto-color);
            border-radius: 50%;
            margin: 0 auto 4px;
        }
        .shape-ecto .body-hips {
            width: 22px;
            height: 30px;
            background: var(--ecto-color);
            border-radius: 0 0 6px 6px;
            margin: 2px auto 0;
        }
        .shape-ecto .body-legs {
            display: flex;
            gap: 4px;
            justify-content: center;
        }
        .shape-ecto .body-leg {
            width: 8px;
            height: 28px;
            background: var(--ecto-color);
            border-radius: 0 0 4px 4px;
        }

        /* Mesomorph - V-taper, broad shoulders */
        .shape-meso .body-torso {
            width: 36px;
            height: 48px;
            background: var(--meso-color);
            border-radius: 12px 12px 6px 6px;
            margin: 0 auto;
            clip-path: polygon(5% 0%, 95% 0%, 75% 100%, 25% 100%);
        }
        .shape-meso .body-head {
            width: 20px;
            height: 20px;
            background: var(--meso-color);
            border-radius: 50%;
            margin: 0 auto 4px;
        }
        .shape-meso .body-hips {
            width: 26px;
            height: 28px;
            background: var(--meso-color);
            border-radius: 0 0 6px 6px;
            margin: 2px auto 0;
        }
        .shape-meso .body-legs {
            display: flex;
            gap: 4px;
            justify-content: center;
        }
        .shape-meso .body-leg {
            width: 10px;
            height: 26px;
            background: var(--meso-color);
            border-radius: 0 0 4px 4px;
        }

        /* Endomorph - rounder, wider midsection */
        .shape-endo .body-torso {
            width: 34px;
            height: 46px;
            background: var(--endo-color);
            border-radius: 10px 10px 14px 14px;
            margin: 0 auto;
        }
        .shape-endo .body-head {
            width: 20px;
            height: 20px;
            background: var(--endo-color);
            border-radius: 50%;
            margin: 0 auto 4px;
        }
        .shape-endo .body-hips {
            width: 38px;
            height: 30px;
            background: var(--endo-color);
            border-radius: 8px 8px 8px 8px;
            margin: 2px auto 0;
        }
        .shape-endo .body-legs {
            display: flex;
            gap: 4px;
            justify-content: center;
        }
        .shape-endo .body-leg {
            width: 12px;
            height: 24px;
            background: var(--endo-color);
            border-radius: 0 0 5px 5px;
        }

        .body-figure-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .label-ecto { color: var(--ecto-color); }
        .label-meso { color: var(--meso-color); }
        .label-endo { color: var(--endo-color); }

        /* Percentage bars */
        .type-bars {
            margin-bottom: 2rem;
        }

        .type-bar-row {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 0.75rem;
        }

        .type-bar-label {
            font-size: 0.8rem;
            font-weight: 700;
            width: 100px;
            text-align: right;
        }

        .type-bar-track {
            flex: 1;
            height: 24px;
            background-color: var(--bg-color);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .type-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.6s ease;
        }

        .type-bar-fill.ecto { background-color: var(--ecto-color); }
        .type-bar-fill.meso { background-color: var(--meso-color); }
        .type-bar-fill.endo { background-color: var(--endo-color); }

        .type-bar-pct {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 700;
            width: 50px;
        }

        /* Info sections */
        .info-section {
            margin-bottom: 1.5rem;
        }

        .info-section h3 {
            font-size: 1rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .info-section h3 .icon {
            font-size: 1.1rem;
        }

        .info-section ul {
            list-style: none;
            padding: 0;
        }

        .info-section li {
            padding: 0.5rem 0;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            color: var(--text-primary);
            padding-left: 1rem;
            position: relative;
        }

        .info-section li:last-child {
            border-bottom: none;
        }

        .info-section li::before {
            content: '›';
            position: absolute;
            left: 0;
            color: var(--accent-color);
            font-weight: 700;
        }

        /* Famous athletes */
        .athletes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 0.75rem;
        }

        .athlete-card {
            background-color: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 0.75rem 1rem;
        }

        .athlete-name {
            font-size: 0.875rem;
            font-weight: 700;
            color: #ffffff;
        }

        .athlete-sport {
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        /* Retake button */
        .retake-btn {
            width: 100%;
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.85rem;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            font-family: var(--font-ui);
            transition: all 0.2s;
            margin-top: 1rem;
        }

        .retake-btn:hover {
            border-color: var(--accent-color);
        }

        /* SEO content */
        .seo-content {
            padding: 2rem 0;
        }

        .seo-content h2 {
            font-size: 1.25rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 0.75rem;
            margin-top: 2rem;
        }

        .seo-content h2:first-child {
            margin-top: 0;
        }

        .seo-content h3 {
            font-size: 1rem;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 0.5rem;
            margin-top: 1.25rem;
        }

        .seo-content p {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 1rem;
            line-height: 1.7;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
        }

        .data-table th {
            background-color: var(--card-bg);
            color: var(--accent-color);
            text-align: left;
            padding: 0.75rem;
            font-weight: 700;
            border-bottom: 2px solid var(--border-color);
        }

        .data-table td {
            padding: 0.75rem;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-primary);
        }

        .data-table tr:hover td {
            background-color: rgba(45, 184, 154, 0.03);
        }

        /* FAQ */
        .faq-section {
            margin-top: 2rem;
        }

        .faq-item {
            border-bottom: 1px solid var(--border-color);
        }

        .faq-q {
            width: 100%;
            background: none;
            border: none;
            color: #ffffff;
            font-size: 0.95rem;
            font-weight: 600;
            text-align: left;
            padding: 1rem 0;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: var(--font-ui);
        }

        .faq-q::after {
            content: '+';
            font-size: 1.25rem;
            color: var(--accent-color);
            transition: transform 0.2s;
        }

        .faq-item.open .faq-q::after {
            content: '−';
        }

        .faq-a {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.7;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.3s ease;
            padding-bottom: 0;
        }

        .faq-item.open .faq-a {
            max-height: 500px;
            padding-bottom: 1rem;
        }

        @media (max-width: 600px) {
            h1 { font-size: 1.5rem; }
            .body-illustration { gap: 1rem; }
            .body-shape { width: 50px; height: 100px; }
            .type-bar-label { width: 80px; font-size: 0.75rem; }
            .athletes-grid { grid-template-columns: 1fr; }
        }
  </style>

  <div class="container">
    <header>
      <h1>Body Type Quiz</h1>
      <p class="subtitle">Answer 12 questions to discover your somatotype — ectomorph, mesomorph, or endomorph</p>
    </header>

    <!-- Quiz Card -->
    <div class="card" id="quizCard">
      <div class="progress-container">
        <div class="progress-info">
          <span id="progressText">Question 1 of 12</span>
          <span id="progressPct">0%</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill"></div>
        </div>
      </div>

      <div id="questionsWrapper">
        <!-- Questions rendered by JS -->
      </div>

      <div class="quiz-nav">
        <button class="nav-btn" id="prevBtn" onclick="prevQuestion()" disabled>Back</button>
        <button class="nav-btn primary" id="nextBtn" onclick="nextQuestion()" disabled>Next</button>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="results">
      <div class="card">
        <div class="result-type-header">
          <div class="result-type-label">Your Primary Body Type</div>
          <div class="result-type-name" id="primaryType">Mesomorph</div>
          <div class="result-type-desc" id="primaryDesc"></div>
        </div>

        <!-- Body shape illustrations -->
        <div class="body-illustration">
          <div class="body-figure" id="figEcto">
            <div class="body-shape shape-ecto">
              <div class="body-head"></div>
              <div class="body-torso"></div>
              <div class="body-hips"></div>
              <div class="body-legs"><div class="body-leg"></div><div class="body-leg"></div></div>
            </div>
            <div class="body-figure-label label-ecto">Ectomorph</div>
          </div>
          <div class="body-figure" id="figMeso">
            <div class="body-shape shape-meso">
              <div class="body-head"></div>
              <div class="body-torso"></div>
              <div class="body-hips"></div>
              <div class="body-legs"><div class="body-leg"></div><div class="body-leg"></div></div>
            </div>
            <div class="body-figure-label label-meso">Mesomorph</div>
          </div>
          <div class="body-figure" id="figEndo">
            <div class="body-shape shape-endo">
              <div class="body-head"></div>
              <div class="body-torso"></div>
              <div class="body-hips"></div>
              <div class="body-legs"><div class="body-leg"></div><div class="body-leg"></div></div>
            </div>
            <div class="body-figure-label label-endo">Endomorph</div>
          </div>
        </div>

        <!-- Percentage bars -->
        <div class="type-bars">
          <div class="type-bar-row">
            <div class="type-bar-label label-ecto">Ectomorph</div>
            <div class="type-bar-track"><div class="type-bar-fill ecto" id="barEcto"></div></div>
            <div class="type-bar-pct" id="pctEcto">0%</div>
          </div>
          <div class="type-bar-row">
            <div class="type-bar-label label-meso">Mesomorph</div>
            <div class="type-bar-track"><div class="type-bar-fill meso" id="barMeso"></div></div>
            <div class="type-bar-pct" id="pctMeso">0%</div>
          </div>
          <div class="type-bar-row">
            <div class="type-bar-label label-endo">Endomorph</div>
            <div class="type-bar-track"><div class="type-bar-fill endo" id="barEndo"></div></div>
            <div class="type-bar-pct" id="pctEndo">0%</div>
          </div>
        </div>

        <!-- Training recommendations -->
        <div class="info-section" id="trainingSection">
          <h3><span class="icon">&#9899;</span> Training Recommendations</h3>
          <ul id="trainingList"></ul>
        </div>

        <!-- Nutrition guidelines -->
        <div class="info-section" id="nutritionSection">
          <h3><span class="icon">&#9899;</span> Nutrition Guidelines</h3>
          <ul id="nutritionList"></ul>
        </div>

        <!-- Famous athletes -->
        <div class="info-section">
          <h3><span class="icon">&#9899;</span> Famous Athletes With Your Body Type</h3>
          <div class="athletes-grid" id="athletesGrid"></div>
        </div>

        <button class="retake-btn" onclick="retakeQuiz()">Retake Quiz</button>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="seo-content">
      <h2>Understanding the 3 Body Types (Somatotypes)</h2>
      <p>The somatotype system was developed by psychologist William Sheldon in the 1940s and classifies human physiques into three categories: ectomorph, mesomorph, and endomorph. While modern exercise science recognizes that genetics, lifestyle, and training all shape your body, understanding your natural body type helps you choose more effective training and nutrition strategies.</p>

      <h3>Ectomorph</h3>
      <p>Ectomorphs are characterized by a lean, long-limbed build with narrow shoulders and hips. They have a fast metabolism and find it difficult to gain weight — both muscle and fat. Ectomorphs often excel in endurance sports like long-distance running, cycling, and swimming.</p>

      <h3>Mesomorph</h3>
      <p>Mesomorphs have a naturally athletic, medium-framed build with broad shoulders and a narrow waist. They gain muscle relatively easily and can lose fat without extreme effort. Mesomorphs tend to excel in power sports, bodybuilding, and team sports that require both speed and strength.</p>

      <h3>Endomorph</h3>
      <p>Endomorphs have a wider, stockier build with broader hips and a tendency to store body fat, especially around the midsection. They are often naturally strong, particularly in the lower body. Endomorphs do well in powerlifting, football, and sports requiring mass and power.</p>

      <h2>Body Type Comparison</h2>
      <table class="data-table">
        <thead>
          <tr><th>Trait</th><th>Ectomorph</th><th>Mesomorph</th><th>Endomorph</th></tr>
        </thead>
        <tbody>
          <tr><td>Frame size</td><td>Small / narrow</td><td>Medium / broad shoulders</td><td>Large / wide</td></tr>
          <tr><td>Metabolism</td><td>Fast</td><td>Moderate</td><td>Slow</td></tr>
          <tr><td>Muscle gain</td><td>Difficult</td><td>Easy</td><td>Moderate</td></tr>
          <tr><td>Fat storage</td><td>Low</td><td>Moderate</td><td>High</td></tr>
          <tr><td>Best cardio</td><td>Minimal HIIT</td><td>Moderate mix</td><td>Regular HIIT + LISS</td></tr>
          <tr><td>Ideal macros</td><td>High carb</td><td>Balanced</td><td>Higher protein/fat</td></tr>
        </tbody>
      </table>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-section">
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">What are the 3 body types?</button>
          <div class="faq-a">The three somatotypes are ectomorph (lean, long limbs, fast metabolism), mesomorph (muscular, medium frame, gains muscle easily), and endomorph (wider build, stores fat easily, strong lower body). Most people are a combination of two or all three types.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">Can your body type change over time?</button>
          <div class="faq-a">Your skeletal frame and genetic predispositions don't change, but your body composition absolutely can. Through targeted training and nutrition, an endomorph can become lean and an ectomorph can build significant muscle. Body type describes your natural tendencies, not your destiny.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">How accurate is this body type quiz?</button>
          <div class="faq-a">Somatotype quizzes provide a useful general classification based on your bone structure, metabolism, and body composition tendencies. While not a clinical assessment, they help identify your dominant body type so you can tailor your training and nutrition approach. Most people are a blend of two types.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">What is the best diet for my body type?</button>
          <div class="faq-a">Ectomorphs benefit from higher carb and calorie intake to support growth. Mesomorphs do well with balanced macros (40% carbs, 30% protein, 30% fat). Endomorphs often respond best to higher protein and fat with moderate carbs. However, total calories and protein intake matter more than body type for most goals.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">What is the best workout for my body type?</button>
          <div class="faq-a">Ectomorphs should focus on heavy compound lifts with lower volume and longer rest periods. Mesomorphs respond well to varied training with moderate volume. Endomorphs benefit from combining resistance training with higher-intensity cardio. All body types should prioritize progressive overload and consistency.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)">Can you be a combination of body types?</button>
          <div class="faq-a">Yes — most people are a combination. Common blends include ecto-mesomorph (lean and muscular), endo-mesomorph (muscular but carries more fat), and ecto-endomorph (slim upper body, stores fat in lower body). Our quiz gives you percentage scores for each type to show your unique blend.</div>
        </div>
      </div>
    </div>
  </div>

  <script type="text/javascript" is:inline>
    const questions = [
      {
        q: "How would you describe your bone structure?",
        options: [
          { text: "Small joints, narrow wrists and ankles", scores: [3, 0, 0] },
          { text: "Medium joints, average bone size", scores: [0, 3, 0] },
          { text: "Large joints, thick wrists and ankles", scores: [0, 0, 3] }
        ]
      },
      {
        q: "How do your shoulders compare to your hips?",
        options: [
          { text: "My shoulders and hips are about the same width", scores: [3, 0, 0] },
          { text: "My shoulders are noticeably wider than my hips", scores: [0, 3, 0] },
          { text: "My hips are as wide or wider than my shoulders", scores: [0, 0, 3] }
        ]
      },
      {
        q: "If you wrap your thumb and middle finger around your wrist, what happens?",
        options: [
          { text: "My fingers overlap easily", scores: [3, 0, 0] },
          { text: "My fingers just barely touch", scores: [0, 3, 0] },
          { text: "My fingers don't touch at all", scores: [0, 0, 3] }
        ]
      },
      {
        q: "How would you describe your natural build (without training)?",
        options: [
          { text: "Long and lean — I look thin even when I don't exercise", scores: [3, 0, 0] },
          { text: "Naturally athletic — I look somewhat muscular without trying", scores: [0, 3, 0] },
          { text: "Soft and round — I tend to carry extra weight easily", scores: [0, 0, 3] }
        ]
      },
      {
        q: "What best describes your metabolism and appetite?",
        options: [
          { text: "Fast metabolism — I can eat a lot without gaining weight", scores: [3, 0, 0] },
          { text: "Moderate — I maintain weight fairly easily", scores: [0, 3, 0] },
          { text: "Slow metabolism — I gain weight easily, even eating modestly", scores: [0, 0, 3] }
        ]
      },
      {
        q: "When you gain weight, where does it tend to go first?",
        options: [
          { text: "I rarely gain noticeable weight anywhere", scores: [3, 0, 0] },
          { text: "It distributes fairly evenly across my body", scores: [0, 3, 0] },
          { text: "Mostly around my stomach, hips, or thighs", scores: [0, 0, 3] }
        ]
      },
      {
        q: "How easily do you build muscle?",
        options: [
          { text: "Very difficult — I have to work extremely hard to see gains", scores: [3, 0, 0] },
          { text: "Fairly easy — I notice results within a few weeks of training", scores: [0, 3, 0] },
          { text: "I get strong quickly but muscle definition is harder to see", scores: [0, 0, 3] }
        ]
      },
      {
        q: "What is your torso shape like?",
        options: [
          { text: "Long and narrow, relatively flat chest", scores: [3, 0, 0] },
          { text: "Medium length with a V-shape or hourglass taper", scores: [0, 3, 0] },
          { text: "Shorter and wider, fuller midsection", scores: [0, 0, 3] }
        ]
      },
      {
        q: "How would you describe your limbs?",
        options: [
          { text: "Long arms and legs relative to my torso", scores: [3, 0, 0] },
          { text: "Proportional — arms and legs match my torso well", scores: [0, 3, 0] },
          { text: "Shorter arms and legs relative to my torso", scores: [0, 0, 3] }
        ]
      },
      {
        q: "What happens when you stop exercising for a few weeks?",
        options: [
          { text: "I lose what little muscle I had very quickly", scores: [3, 0, 0] },
          { text: "I maintain most of my shape and muscle", scores: [0, 3, 0] },
          { text: "I gain fat quickly but keep my strength", scores: [0, 0, 3] }
        ]
      },
      {
        q: "Which best describes your energy levels throughout the day?",
        options: [
          { text: "Consistently high energy — I'm restless and fidgety", scores: [3, 0, 0] },
          { text: "Steady and balanced — I have sustained energy", scores: [0, 3, 0] },
          { text: "I tend to feel sluggish, especially after meals", scores: [0, 0, 3] }
        ]
      },
      {
        q: "Which clothing fit issue do you relate to most?",
        options: [
          { text: "Clothes are often too loose or baggy on me", scores: [3, 0, 0] },
          { text: "Standard sizes fit me well off the rack", scores: [0, 3, 0] },
          { text: "I often need a larger size for my waist or hips", scores: [0, 0, 3] }
        ]
      }
    ];

    const typeData = {
      ectomorph: {
        name: "Ectomorph",
        desc: "Lean build, fast metabolism, long limbs — the classic hardgainer",
        training: [
          "Focus on heavy compound lifts (squats, deadlifts, bench press, rows)",
          "Keep volume moderate — 3-4 sets of 6-8 reps per exercise",
          "Rest 2-3 minutes between sets to maximize strength",
          "Limit cardio to 1-2 short sessions per week",
          "Train 3-4 days per week with full rest days between sessions",
          "Prioritize progressive overload — add weight consistently"
        ],
        nutrition: [
          "Eat in a caloric surplus of 300-500 calories above maintenance",
          "High carb intake — aim for 50-60% of total calories from carbs",
          "Protein: 0.8-1g per pound of bodyweight",
          "Eat frequently — 4-6 meals per day to hit calorie goals",
          "Focus on calorie-dense foods: nuts, oats, rice, whole milk",
          "Consider a pre-bed meal to prevent overnight catabolism"
        ],
        athletes: [
          { name: "Usain Bolt", sport: "Sprinting" },
          { name: "Kevin Durant", sport: "Basketball" },
          { name: "Mo Farah", sport: "Distance Running" },
          { name: "Bruce Lee", sport: "Martial Arts" },
          { name: "Michael Phelps", sport: "Swimming" },
          { name: "Eliud Kipchoge", sport: "Marathon Running" }
        ]
      },
      mesomorph: {
        name: "Mesomorph",
        desc: "Naturally athletic build, gains muscle easily, broad shoulders",
        training: [
          "Respond well to varied training — mix heavy, moderate, and light days",
          "Moderate volume works best — 3-4 sets of 8-12 reps",
          "Can handle higher frequency — 4-5 training days per week",
          "Mix compound and isolation exercises for balanced development",
          "Include 2-3 moderate cardio sessions per week",
          "Periodize training to avoid plateaus — change programs every 8-12 weeks"
        ],
        nutrition: [
          "Balanced macros: 40% carbs, 30% protein, 30% fat",
          "Protein: 1g per pound of bodyweight",
          "Eat at maintenance for recomposition, or slight surplus for bulking",
          "Nutrient timing around workouts can provide extra benefit",
          "Focus on whole foods — lean meats, vegetables, complex carbs",
          "Can handle moderate treats without significant fat gain"
        ],
        athletes: [
          { name: "Cristiano Ronaldo", sport: "Soccer" },
          { name: "LeBron James", sport: "Basketball" },
          { name: "Serena Williams", sport: "Tennis" },
          { name: "Arnold Schwarzenegger", sport: "Bodybuilding" },
          { name: "Herschel Walker", sport: "Football / MMA" },
          { name: "Simone Biles", sport: "Gymnastics" }
        ]
      },
      endomorph: {
        name: "Endomorph",
        desc: "Wider build, stores fat easily, naturally strong — especially lower body",
        training: [
          "Combine resistance training with regular cardio (4-5 sessions/week)",
          "Higher rep ranges work well — 3-4 sets of 10-15 reps",
          "Include HIIT 2-3 times per week for metabolic boost",
          "Full-body or upper/lower splits to maximize calorie burn",
          "Keep rest periods shorter (60-90 seconds) to maintain heart rate",
          "Prioritize compound movements to burn more calories per session"
        ],
        nutrition: [
          "Higher protein and fat, moderate carbs — 25% carbs, 35% protein, 40% fat",
          "Protein: 1-1.2g per pound of bodyweight to preserve muscle",
          "Time carbs around workouts for better utilization",
          "Eat at a moderate deficit (300-500 cals) for fat loss",
          "Focus on fiber-rich vegetables, lean protein, and healthy fats",
          "Avoid liquid calories and processed carbs — they add up fast"
        ],
        athletes: [
          { name: "Hafþór Björnsson", sport: "Strongman" },
          { name: "Brock Lesnar", sport: "Wrestling / MMA" },
          { name: "Jay Cutler", sport: "Bodybuilding" },
          { name: "Vince Wilfork", sport: "Football" },
          { name: "Butterbean", sport: "Boxing" },
          { name: "Brian Shaw", sport: "Strongman" }
        ]
      }
    };

    let currentQuestion = 0;
    let answers = new Array(questions.length).fill(null);

    function renderQuestions() {
      const wrapper = document.getElementById('questionsWrapper');
      wrapper.innerHTML = '';
      questions.forEach((q, i) => {
        const div = document.createElement('div');
        div.className = 'question-container' + (i === 0 ? ' active' : '');
        div.id = 'q' + i;
        div.innerHTML =
          '<div class="question-number">Question ' + (i + 1) + ' of 12</div>' +
          '<div class="question-text">' + q.q + '</div>' +
          '<div class="options">' +
          q.options.map((opt, j) =>
            '<button class="option-btn" data-q="' + i + '" data-opt="' + j + '" onclick="selectOption(' + i + ',' + j + ')">' + opt.text + '</button>'
          ).join('') +
          '</div>';
        wrapper.appendChild(div);
      });
    }

    function selectOption(qIndex, optIndex) {
      answers[qIndex] = optIndex;
      // Highlight selected
      const btns = document.querySelectorAll('#q' + qIndex + ' .option-btn');
      btns.forEach((b, i) => {
        b.classList.toggle('selected', i === optIndex);
      });
      updateNav();
      // Auto-advance after short delay
      if (qIndex < questions.length - 1) {
        setTimeout(() => nextQuestion(), 300);
      }
    }

    function updateNav() {
      document.getElementById('prevBtn').disabled = currentQuestion === 0;
      const isLast = currentQuestion === questions.length - 1;
      const nextBtn = document.getElementById('nextBtn');
      nextBtn.disabled = answers[currentQuestion] === null;
      nextBtn.textContent = isLast ? 'See Results' : 'Next';
    }

    function updateProgress() {
      const answered = answers.filter(a => a !== null).length;
      const pct = Math.round((answered / questions.length) * 100);
      document.getElementById('progressFill').style.width = pct + '%';
      document.getElementById('progressPct').textContent = pct + '%';
      document.getElementById('progressText').textContent = 'Question ' + (currentQuestion + 1) + ' of 12';
    }

    function showQuestion(index) {
      document.querySelectorAll('.question-container').forEach(el => el.classList.remove('active'));
      document.getElementById('q' + index).classList.add('active');
      currentQuestion = index;
      updateNav();
      updateProgress();
    }

    function nextQuestion() {
      if (answers[currentQuestion] === null) return;
      if (currentQuestion < questions.length - 1) {
        showQuestion(currentQuestion + 1);
      } else {
        showResults();
      }
    }

    function prevQuestion() {
      if (currentQuestion > 0) {
        showQuestion(currentQuestion - 1);
      }
    }

    function showResults() {
      let ecto = 0, meso = 0, endo = 0;
      answers.forEach((a, i) => {
        if (a !== null) {
          const scores = questions[i].options[a].scores;
          ecto += scores[0];
          meso += scores[1];
          endo += scores[2];
        }
      });

      const total = ecto + meso + endo;
      const ectoPct = Math.round((ecto / total) * 100);
      const mesoPct = Math.round((meso / total) * 100);
      const endoPct = 100 - ectoPct - mesoPct;

      // Determine primary type
      let primary = 'mesomorph';
      if (ecto >= meso && ecto >= endo) primary = 'ectomorph';
      else if (endo >= meso && endo >= ecto) primary = 'endomorph';

      const data = typeData[primary];

      // Update header
      document.getElementById('primaryType').textContent = data.name;
      document.getElementById('primaryType').style.color =
        primary === 'ectomorph' ? 'var(--ecto-color)' :
        primary === 'mesomorph' ? 'var(--meso-color)' : 'var(--endo-color)';
      document.getElementById('primaryDesc').textContent = data.desc;

      // Highlight figure
      document.getElementById('figEcto').classList.toggle('highlighted', primary === 'ectomorph');
      document.getElementById('figMeso').classList.toggle('highlighted', primary === 'mesomorph');
      document.getElementById('figEndo').classList.toggle('highlighted', primary === 'endomorph');

      // Bars
      document.getElementById('barEcto').style.width = ectoPct + '%';
      document.getElementById('barMeso').style.width = mesoPct + '%';
      document.getElementById('barEndo').style.width = endoPct + '%';
      document.getElementById('pctEcto').textContent = ectoPct + '%';
      document.getElementById('pctMeso').textContent = mesoPct + '%';
      document.getElementById('pctEndo').textContent = endoPct + '%';

      // Training
      const tList = document.getElementById('trainingList');
      tList.innerHTML = data.training.map(t => '<li>' + t + '</li>').join('');

      // Nutrition
      const nList = document.getElementById('nutritionList');
      nList.innerHTML = data.nutrition.map(n => '<li>' + n + '</li>').join('');

      // Athletes
      const aGrid = document.getElementById('athletesGrid');
      aGrid.innerHTML = data.athletes.map(a =>
        '<div class="athlete-card"><div class="athlete-name">' + a.name + '</div><div class="athlete-sport">' + a.sport + '</div></div>'
      ).join('');

      // Show results, hide quiz
      document.getElementById('quizCard').style.display = 'none';
      document.getElementById('results').classList.add('active');
    }

    function retakeQuiz() {
      answers = new Array(questions.length).fill(null);
      currentQuestion = 0;
      document.getElementById('results').classList.remove('active');
      document.getElementById('quizCard').style.display = 'block';
      renderQuestions();
      showQuestion(0);
    }

    function toggleFaq(btn) {
      const item = btn.parentElement;
      item.classList.toggle('open');
    }

    // Initialize
    renderQuestions();
    updateNav();
    updateProgress();
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

