---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = { category: 'list' };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "name": "Best Home Gym Equipment 2026",
    "url": "https://bodycount.photonbuilder.com/best-home-gym-equipment",
    "description": "The ultimate guide to the best home gym equipment for 2026. Compare top gear by budget for compact apartment setups and full garage gym builds."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much space do I need for a home gym?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Space requirements vary wildly. A compact apartment setup with resistance bands and adjustable dumbbells can fit in a closet. A full power rack garage gym build requires at least an 8x8 foot dedicated footprint, ideally 10x10 feet for comfortable barbell clearance."
        }
      },
      {
        "@type": "Question",
        "name": "What flooring is best for a home gym?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For heavy lifting and barbell drops, 3/4-inch horse stall mats are the gold standard for durability and shock absorption. For lighter workouts or yoga, interlocking EVA foam puzzle mats are sufficient and budget-friendly."
        }
      },
      {
        "@type": "Question",
        "name": "What is essential versus nice-to-have equipment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Essentials include a flat or adjustable bench, adjustable dumbbells, and a pull-up bar (or rack). Nice-to-haves include cable machines, specialized cardio equipment like a fan bike, and isolated specialty machines like leg curls."
        }
      },
      {
        "@type": "Question",
        "name": "Can I build a good home gym in an apartment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Focus on high-versatility, low-footprint items like adjustable dumbbells (e.g., Bowflex or PowerBlock), resistance bands, door-mounted pull-up bars, and a foldable bench that can slide under a bed."
        }
      },
      {
        "@type": "Question",
        "name": "Which premium brands are best for a full garage gym build?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For a robust garage gym, Rogue Fitness offers top-tier American-made racks and barbells. Rep Fitness provides excellent value with premium features, and Titan Fitness is great for budget-conscious but heavy-duty structural pieces."
        }
      }
    ]
  }
];

const categories = [
  { name: 'Best Under $200', brand: 'Resistance Bands & Adjustable Dumbbells', desc: 'Compact apartment setups focusing on versatility and minimal footprint.' },
  { name: 'Best Under $500', brand: 'Kettlebells, Bench, & Barbell', desc: 'The fundamental strength builder kit for serious but budget-conscious lifters.' },
  { name: 'Best Under $1000', brand: 'Power Rack & Cable Machine', desc: 'A complete setup allowing for heavy, safe compound movements.' },
  { name: 'Best Premium Build', brand: 'Rogue, Rep Fitness, Titan', desc: 'High-end, commercial-grade equipment for full garage gym builds.' }
];

const equipmentList = [
  { item: 'Resistance Bands Kit', brand: 'Various', tier: 'Under $200', space: 'Minimal', type: 'Accessory', coreUse: 'Mobility/Pump' },
  { item: 'Doorway Pull-up Bar', brand: 'Iron Gym', tier: 'Under $200', space: 'Minimal', type: 'Bodyweight', coreUse: 'Back/Biceps' },
  { item: 'Adjustable Dumbbells', brand: 'PowerBlock/Bowflex', tier: 'Under $200-$500', space: 'Compact', type: 'Free Weight', coreUse: 'Full Body' },
  { item: 'Cast Iron Kettlebells', brand: 'Rep Fitness', tier: 'Under $500', space: 'Compact', type: 'Free Weight', coreUse: 'Conditioning' },
  { item: 'Adjustable Bench', brand: 'Titan Fitness', tier: 'Under $500', space: 'Medium', type: 'Structural', coreUse: 'Pressing/Rows' },
  { item: 'Olympic Barbell', brand: 'Rogue Ohio Bar', tier: 'Under $500', space: 'Medium', type: 'Free Weight', coreUse: 'Heavy Lifts' },
  { item: 'Squat Stand / Power Rack', brand: 'Rep PR-4000', tier: 'Under $1000', space: 'Large', type: 'Structural', coreUse: 'Squats/Presses' },
  { item: 'Functional Trainer', brand: 'Titan Fitness', tier: 'Premium', space: 'Large', type: 'Cable Machine', coreUse: 'Isolation/Hypertrophy' }
];
---

<SiteLayout
  site="bodycount"
  canonical="https://bodycount.photonbuilder.com/best-home-gym-equipment"
  schema={schema}
>
  <style>
    .page-wrapper {
      --bg-color: #0f1115;
      --card-bg: #1a1d24;
      --border-color: #2a2f3a;
      --accent-color: #4ade80;
      --accent-hover: #22c55e;
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      --chart-header: #212530;
      --table-hover: #262b36;

      background-color: var(--bg-color);
      color: var(--text-primary);
    }

    .hero-section {
      background: linear-gradient(180deg, rgba(74, 222, 128, 0.05) 0%, rgba(15, 17, 21, 0) 100%);
      padding: 4rem 1.5rem 3rem;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Category Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      transition: transform 0.2s, border-color 0.2s;
    }

    .category-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent-color);
    }

    .cat-title {
      font-size: 0.875rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .cat-brand {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .cat-desc {
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.5;
    }

    /* Table Styles */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 4rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    th {
      background: var(--chart-header);
      padding: 1rem 1.5rem;
      font-weight: 600;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border-color);
      white-space: nowrap;
    }

    td {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:last-child td {
      border-bottom: none;
    }

    tr:hover td {
      background: var(--table-hover);
    }

    .type-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(148, 163, 184, 0.1);
      color: var(--text-secondary);
    }

    /* FAQ Section */
    .faq-section {
      max-width: 800px;
      margin: 0 auto 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.6;
    }
  </style>

  <div class="page-wrapper">
    <div class="hero-section">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Best Home Gym Equipment 2026</h1>
      <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto">
        Compare the top home gym equipment by budget. From compact apartment setups to full premium garage gym builds.
      </p>
    </div>

    <main class="container">
      <section>
        <h2 class="text-3xl font-bold mb-6 text-center">Top Setups by Budget</h2>
        <div class="category-grid">
          {categories.map(cat => (
            <div class="category-card">
              <div class="cat-title">{cat.name}</div>
              <div class="cat-brand">{cat.brand}</div>
              <div class="cat-desc">{cat.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold mb-6">Compare Equipment</h2>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Item</th>
                <th>Brand / Example</th>
                <th>Budget Tier</th>
                <th>Space Required</th>
                <th>Type</th>
                <th>Core Use</th>
              </tr>
            </thead>
            <tbody>
              {equipmentList.map(eq => (
                <tr>
                  <td class="font-medium">{eq.item}</td>
                  <td>{eq.brand}</td>
                  <td><span class="type-badge">{eq.tier}</span></td>
                  <td>{eq.space}</td>
                  <td>{eq.type}</td>
                  <td>{eq.coreUse}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="faq-section">
        <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
        <div class="faq-list">
          {schema[1].mainEntity.map((faq: any) => (
            <div class="faq-item">
              <div class="faq-q">{faq.name}</div>
              <div class="faq-a">{faq.acceptedAnswer.text}</div>
            </div>
          ))}
        </div>
      </section>
    </main>
  </div>
</SiteLayout>
