      'constant': { 'Gout': 3, 'Ankle Arthritis': 3, 'Jones Fracture': 3, 'Bunion': 2 },
      'rest':     { 'Gout': 4, 'Stress Fracture': 2, 'Ankle Arthritis': 2 },

      /* Q3: Aggravator */
      'walking':  { 'Plantar Fasciitis': 2, 'Metatarsalgia': 3, 'Stress Fracture': 3, 'Achilles Tendonitis': 2 },
      'standing': { 'Plantar Fasciitis': 3, 'Flat Feet': 3, 'Metatarsalgia': 2 },
      'shoes':    { 'Bunion': 4, "Morton's Neuroma": 3, 'Hammertoe': 3, 'Corns': 3, "Haglund's Deformity": 3 },
      'barefoot': { 'Plantar Fasciitis': 3, 'Stone Bruise': 3, 'Flat Feet': 2 },

      /* Q4: Duration */
      'days':    { 'Ankle Sprain': 3, 'Gout': 3, 'Stone Bruise': 3, 'Ingrown Toenail': 2 },
      'weeks':   { 'Stress Fracture': 3, 'Peroneal Tendonitis': 2, 'Metatarsalgia': 2, 'Extensor Tendonitis': 2 },
      'months':  { 'Plantar Fasciitis': 3, 'Achilles Tendonitis': 3, "Morton's Neuroma": 2, 'Bunion': 2 },
      'chronic': { 'Plantar Fasciitis': 3, 'Bunion': 3, 'Hammertoe': 3, 'Ankle Arthritis': 3, 'Flat Feet': 3 },

      /* Q5: Visible changes */
      'swelling':   { 'Ankle Sprain': 3, 'Gout': 3, 'Jones Fracture': 3, 'Stress Fracture': 2 },
      'redness':    { 'Gout': 4, 'Ingrown Toenail': 3, 'Ankle Sprain': 2 },
      'deformity':  { 'Bunion': 4, 'Hammertoe': 4, "Haglund's Deformity": 3, 'Heel Spurs': 2 },
      'none':       { 'Plantar Fasciitis': 2, "Morton's Neuroma": 2, 'Achilles Tendonitis': 2, 'Flat Feet': 2 }
    };

    /* ═══════════════════════════════════════════
       DETAIL PANEL
    ═══════════════════════════════════════════ */
    const detailPanel = document.getElementById('detail-panel');
    const detailTitle = document.getElementById('detail-name');
    const detailIcon = document.getElementById('detail-icon');
    const detailContent = document.getElementById('detail-content');
    const detailClose = document.getElementById('detail-close');

    function showZone(zoneId) {
      const zone = ZONES[zoneId];
      if (!zone) return;

      document.querySelectorAll('.foot-zone').forEach(el => el.classList.remove('active'));
      document.querySelectorAll(`.foot-zone[data-zone="${zoneId}"]`).forEach(el => el.classList.add('active'));

      detailIcon.textContent = zone.icon;
      detailTitle.textContent = zone.name + ' Pain';

      let html = '';
      zone.conditions.forEach(c => {
        html += `<div class="condition-card">
          <h4><span class="condition-rank">#${c.rank}</span> ${c.name}</h4>
          <p style="font-size:0.8rem;color:var(--text-secondary);margin-bottom:0.5rem;">${c.likelihood}</p>
          <dl class="condition-meta">
            <div><dt>Symptoms</dt><dd>${c.symptoms}</dd></div>
            <div><dt>Common Causes</dt><dd>${c.causes}</dd></div>
            <div><dt>Home Treatment</dt><dd>${c.treatment}</dd></div>
            <div><dt>Recovery Timeline</dt><dd>${c.recovery}</dd></div>
          </dl>
          <div class="red-flag"><strong>When to see a doctor:</strong><p>${c.redFlags}</p></div>
        </div>`;
      });

      detailContent.innerHTML = html;
      detailPanel.classList.add('visible');
      detailPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    document.querySelectorAll('.foot-zone').forEach(el => {
      el.addEventListener('click', () => showZone(el.dataset.zone));
    });

    detailClose.addEventListener('click', () => {
      detailPanel.classList.remove('visible');
      document.querySelectorAll('.foot-zone').forEach(el => el.classList.remove('active'));
    });

    /* ═══════════════════════════════════════════
       CONDITIONS TABLE
    ═══════════════════════════════════════════ */
    const tbody = document.getElementById('conditions-tbody');
    let sortCol = 'name';
    let sortDir = 1;

    function painDots(n) {
      return '<span class="pain-dots">' + '●'.repeat(n) + '<span style="opacity:0.2">' + '●'.repeat(5 - n) + '</span></span>';
    }

    function doctorTag(text) {
      if (text.toLowerCase().startsWith('yes')) return `<span class="tag-yes">${text}</span>`;
      if (text.toLowerCase().startsWith('if')) return `<span class="tag-maybe">${text}</span>`;
      return `<span class="tag-no">${text}</span>`;
    }

    function renderTable() {
      const sorted = [...CONDITIONS_TABLE].sort((a, b) => {
        let va = a[sortCol], vb = b[sortCol];
        if (typeof va === 'number') return (va - vb) * sortDir;
        return String(va).localeCompare(String(vb)) * sortDir;
      });

      tbody.innerHTML = sorted.map(r => `<tr>
        <td style="font-weight:600;color:var(--text-primary)">${r.name}</td>
        <td>${r.location}</td>
        <td>${painDots(r.pain)}</td>
        <td>${r.recovery}</td>
        <td>${doctorTag(r.doctor)}</td>
      </tr>`).join('');
    }

    document.querySelectorAll('#conditions-table th').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.col;
        if (sortCol === col) sortDir *= -1;
        else { sortCol = col; sortDir = 1; }
        renderTable();
      });
    });

    renderTable();

    /* ═══════════════════════════════════════════
       SYMPTOM CHECKER QUIZ
    ═══════════════════════════════════════════ */
    const quizSteps = document.getElementById('quiz-steps');
    const quizProgress = document.getElementById('quiz-progress');
    const quizResults = document.getElementById('quiz-results');
    const quizResultsList = document.getElementById('quiz-results-list');
    const quizRestart = document.getElementById('quiz-restart');

    let currentStep = 0;
    let answers = [];

    function buildQuiz() {
      quizProgress.innerHTML = QUIZ_QUESTIONS.map((_, i) =>
        `<div class="quiz-progress-dot${i <= currentStep ? ' filled' : ''}"></div>`
      ).join('');

      quizSteps.innerHTML = QUIZ_QUESTIONS.map((q, qi) => `
        <div class="quiz-step${qi === currentStep ? ' active' : ''}" data-step="${qi}">
          <div class="quiz-question">Q${qi + 1}. ${q.question}</div>
          <div class="quiz-options">
            ${q.options.map(o => `<button class="quiz-option${answers[qi] === o.value ? ' selected' : ''}" data-value="${o.value}">${o.label}</button>`).join('')}
          </div>
          <div class="quiz-nav">
            <button class="quiz-btn secondary" ${qi === 0 ? 'disabled' : ''} data-action="prev">Back</button>
            ${qi < QUIZ_QUESTIONS.length - 1
              ? `<button class="quiz-btn" data-action="next" ${!answers[qi] ? 'disabled' : ''}>Next</button>`
              : `<button class="quiz-btn" data-action="finish" ${!answers[qi] ? 'disabled' : ''}>See Results</button>`}
          </div>
        </div>
      `).join('');

      quizSteps.querySelectorAll('.quiz-option').forEach(btn => {
        btn.addEventListener('click', function() {
          const step = +this.closest('.quiz-step').dataset.step;
          answers[step] = this.dataset.value;
          buildQuiz();
        });
      });

      quizSteps.querySelectorAll('[data-action="next"]').forEach(btn => {
        btn.addEventListener('click', () => { if (answers[currentStep]) { currentStep++; buildQuiz(); } });
      });

      quizSteps.querySelectorAll('[data-action="prev"]').forEach(btn => {
        btn.addEventListener('click', () => { if (currentStep > 0) { currentStep--; buildQuiz(); } });
      });

      quizSteps.querySelectorAll('[data-action="finish"]').forEach(btn => {
        btn.addEventListener('click', () => { if (answers[currentStep]) showResults(); });
      });
    }

    function showResults() {
      quizSteps.style.display = 'none';
      quizProgress.style.display = 'none';

      const scores = {};
      answers.forEach(val => {
        const s = QUIZ_SCORING[val];
        if (s) {
          for (const [cond, pts] of Object.entries(s)) {
            scores[cond] = (scores[cond] || 0) + pts;
          }
        }
      });

      const ranked = Object.entries(scores).sort((a, b) => b[1] - a[1]).slice(0, 3);
      const maxScore = ranked[0] ? ranked[0][1] : 1;

      quizResultsList.innerHTML = ranked.map((r, i) => {
        const pct = Math.round((r[1] / maxScore) * 100);
        let likelihoodClass = 'likelihood-possible';
        let likelihoodText = 'Possible';
        if (pct >= 80) { likelihoodClass = 'likelihood-high'; likelihoodText = 'Most Likely'; }
        else if (pct >= 50) { likelihoodClass = 'likelihood-moderate'; likelihoodText = 'Likely'; }

        return `<div class="result-card">
          <h4>${i + 1}. ${r[0]}</h4>
          <div class="result-likelihood ${likelihoodClass}">${likelihoodText} (match score: ${pct}%)</div>
          <p style="font-size:0.85rem;color:var(--text-secondary)">Based on your pain location, timing, aggravating factors, duration, and visible symptoms.</p>
        </div>`;
      }).join('');

      quizResults.classList.add('visible');
    }

    quizRestart.addEventListener('click', () => {
      currentStep = 0;
      answers = [];
      quizSteps.style.display = '';
      quizProgress.style.display = '';
      quizResults.classList.remove('visible');
      buildQuiz();
    });

    buildQuiz();

    /* ═══════════════════════════════════════════
       FAQ ACCORDION
    ═══════════════════════════════════════════ */
    document.querySelectorAll('.faq-q').forEach(q => {
      q.addEventListener('click', () => {
        q.parentElement.classList.toggle('open');
      });
    });
  })();
  </script>
</SiteLayout>
