  <script is:inline>
// Beverage database: name, caffeine mg, serving size, category
const beverages = [
    // Coffee
    { name: 'Espresso (single shot)', mg: 63, serving: '1 oz', category: 'coffee' },
    { name: 'Espresso (double shot)', mg: 126, serving: '2 oz', category: 'coffee' },
    { name: 'Drip Coffee', mg: 95, serving: '8 oz', category: 'coffee' },
    { name: 'Drip Coffee (large)', mg: 190, serving: '16 oz', category: 'coffee' },
    { name: 'Cold Brew', mg: 200, serving: '12 oz', category: 'coffee' },
    { name: 'Cold Brew (large)', mg: 300, serving: '16 oz', category: 'coffee' },
    { name: 'Latte', mg: 63, serving: '8 oz', category: 'coffee' },
    { name: 'Latte (large)', mg: 126, serving: '16 oz', category: 'coffee' },
    { name: 'Cappuccino', mg: 63, serving: '8 oz', category: 'coffee' },
    { name: 'Americano', mg: 126, serving: '12 oz', category: 'coffee' },
    { name: 'Flat White', mg: 130, serving: '8 oz', category: 'coffee' },
    { name: 'Mocha', mg: 95, serving: '12 oz', category: 'coffee' },
    { name: 'Instant Coffee', mg: 62, serving: '8 oz', category: 'coffee' },
    { name: 'Decaf Coffee', mg: 7, serving: '8 oz', category: 'coffee' },
    { name: 'French Press', mg: 107, serving: '8 oz', category: 'coffee' },
    // Tea
    { name: 'Black Tea', mg: 47, serving: '8 oz', category: 'tea' },
    { name: 'Green Tea', mg: 28, serving: '8 oz', category: 'tea' },
    { name: 'Matcha', mg: 70, serving: '2 oz (1 tsp)', category: 'tea' },
    { name: 'Matcha Latte', mg: 70, serving: '12 oz', category: 'tea' },
    { name: 'Earl Grey', mg: 47, serving: '8 oz', category: 'tea' },
    { name: 'Chai Tea', mg: 50, serving: '8 oz', category: 'tea' },
    { name: 'Chai Latte', mg: 50, serving: '12 oz', category: 'tea' },
    { name: 'White Tea', mg: 15, serving: '8 oz', category: 'tea' },
    { name: 'Oolong Tea', mg: 38, serving: '8 oz', category: 'tea' },
    { name: 'Yerba Mate', mg: 85, serving: '8 oz', category: 'tea' },
    // Energy drinks
    { name: 'Red Bull', mg: 80, serving: '8.4 oz', category: 'energy' },
    { name: 'Red Bull (large)', mg: 148, serving: '16 oz', category: 'energy' },
    { name: 'Monster Energy', mg: 160, serving: '16 oz', category: 'energy' },
    { name: 'Celsius', mg: 200, serving: '12 oz', category: 'energy' },
    { name: 'Bang Energy', mg: 300, serving: '16 oz', category: 'energy' },
    { name: 'Reign', mg: 300, serving: '16 oz', category: 'energy' },
    { name: 'Rockstar', mg: 160, serving: '16 oz', category: 'energy' },
    { name: 'G Fuel Can', mg: 140, serving: '16 oz', category: 'energy' },
    { name: '5-Hour Energy', mg: 200, serving: '1.93 oz', category: 'energy' },
    { name: 'ZOA Energy', mg: 160, serving: '16 oz', category: 'energy' },
    // Soda
    { name: 'Coca-Cola', mg: 34, serving: '12 oz', category: 'soda' },
    { name: 'Diet Coke', mg: 46, serving: '12 oz', category: 'soda' },
    { name: 'Pepsi', mg: 38, serving: '12 oz', category: 'soda' },
    { name: 'Mountain Dew', mg: 54, serving: '12 oz', category: 'soda' },
    { name: 'Dr Pepper', mg: 41, serving: '12 oz', category: 'soda' },
    { name: 'Diet Mountain Dew', mg: 54, serving: '12 oz', category: 'soda' },
];

let drinkLog = [];
let currentCategory = 'all';

function populateSelect(category) {
    const sel = document.getElementById('drinkSelect');
    sel.innerHTML = '';
    const filtered = category === 'all' ? beverages : beverages.filter(b => b.category === category);
    filtered.forEach((b, i) => {
        const idx = beverages.indexOf(b);
        const opt = document.createElement('option');
        opt.value = idx;
        opt.textContent = b.name + ' — ' + b.mg + ' mg (' + b.serving + ')';
        sel.appendChild(opt);
    });
}

function filterCategory(cat) {
    currentCategory = cat;
    document.querySelectorAll('.category-tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    populateSelect(cat);
}

function setDefaultTime() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    document.getElementById('drinkTime').value = h + ':' + m;
}

function addDrink() {
    const sel = document.getElementById('drinkSelect');
    const timeInput = document.getElementById('drinkTime');
    if (!sel.value || !timeInput.value) return;

    const bev = beverages[parseInt(sel.value)];
    const time = timeInput.value;

    drinkLog.push({ ...bev, time: time, id: Date.now() });
    drinkLog.sort((a, b) => a.time.localeCompare(b.time));
    renderDrinkList();
    setDefaultTime();
}

function removeDrink(id) {
    drinkLog = drinkLog.filter(d => d.id !== id);
    renderDrinkList();
    if (drinkLog.length === 0) {
        document.getElementById('results').classList.remove('active');
    }
}

function renderDrinkList() {
    const container = document.getElementById('drinkList');
    const empty = document.getElementById('emptyState');

    if (drinkLog.length === 0) {
        empty.style.display = 'block';
        container.querySelectorAll('.drink-item').forEach(el => el.remove());
        return;
    }

    empty.style.display = 'none';
    // Remove old items
    container.querySelectorAll('.drink-item').forEach(el => el.remove());

    drinkLog.forEach(d => {
        const div = document.createElement('div');
        div.className = 'drink-item';
        div.innerHTML = '<div class="drink-item-info">' +
            '<div class="drink-item-name">' + d.name + '</div>' +
            '<div class="drink-item-details">' + formatTime12(d.time) + ' · ' + d.serving + '</div>' +
            '</div>' +
            '<div class="drink-item-mg">' + d.mg + ' mg</div>' +
            '<button class="remove-btn" onclick="removeDrink(' + d.id + ')">&times;</button>';
        container.appendChild(div);
    });
}

function formatTime12(t) {
    const parts = t.split(':');
    let h = parseInt(parts[0]);
    const m = parts[1];
    const ampm = h >= 12 ? 'PM' : 'AM';
    if (h === 0) h = 12;
    else if (h > 12) h -= 12;
    return h + ':' + m + ' ' + ampm;
}

function timeToMinutes(t) {
    const parts = t.split(':');
    return parseInt(parts[0]) * 60 + parseInt(parts[1]);
}

function minutesToTime12(mins) {
    let h = Math.floor(mins / 60) % 24;
    const m = Math.round(mins % 60);
    const ampm = h >= 12 ? 'PM' : 'AM';
    if (h === 0) h = 12;
    else if (h > 12) h -= 12;
    return h + ':' + String(m).padStart(2, '0') + ' ' + ampm;
}

function caffeineAtTime(drinkMg, drinkTimeMins, targetTimeMins, halfLifeHrs) {
    let elapsed = targetTimeMins - drinkTimeMins;
    if (elapsed < 0) elapsed += 1440; // next day
    const elapsedHrs = elapsed / 60;
    if (elapsedHrs < 0) return drinkMg;
    return drinkMg * Math.pow(0.5, elapsedHrs / halfLifeHrs);
}

function calculate() {
    if (drinkLog.length === 0) return;

    const halfLife = parseFloat(document.getElementById('halflife').value);
    const bedtimeStr = document.getElementById('bedtime').value;
    const bedtimeMins = timeToMinutes(bedtimeStr);
    const totalMg = drinkLog.reduce((sum, d) => sum + d.mg, 0);

    // Update total gauge
    document.getElementById('totalMg').textContent = totalMg;
    const pct = Math.min(100, (totalMg / 600) * 100);
    document.getElementById('gaugeFill').style.width = pct + '%';

    const limitMsg = document.getElementById('limitMessage');
    if (totalMg <= 200) {
        limitMsg.innerHTML = '<span style="color: var(--safe-color);">&#10003; Low intake — well within safe limits</span>';
    } else if (totalMg <= 400) {
        limitMsg.innerHTML = '<span style="color: var(--caffeine-color);">&#9888; Moderate — within FDA\'s 400 mg daily limit</span>';
    } else {
        limitMsg.innerHTML = '<span style="color: var(--danger-color);">&#9888; Exceeds FDA\'s recommended 400 mg daily limit</span>';
    }

    // Caffeine at bedtime
    let bedtimeCaffeine = 0;
    drinkLog.forEach(d => {
        bedtimeCaffeine += caffeineAtTime(d.mg, timeToMinutes(d.time), bedtimeMins, halfLife);
    });

    document.getElementById('resultDrinks').textContent = drinkLog.length;
    document.getElementById('resultBedtime').textContent = Math.round(bedtimeCaffeine) + ' mg';

    // Calculate caffeine cutoff time
    // Work backwards: for a single drink of ~95mg (standard coffee), find latest time
    // such that caffeine at bedtime < 25mg
    // 25 = 95 * 0.5^(t/halfLife) => t = halfLife * log2(95/25) = halfLife * 1.93
    const hoursBeforeBed = halfLife * Math.log2(95 / 25);
    let cutoffMins = bedtimeMins - Math.round(hoursBeforeBed * 60);
    if (cutoffMins < 0) cutoffMins += 1440;
    document.getElementById('cutoffTime').textContent = minutesToTime12(cutoffMins);
    document.getElementById('cutoffDesc').textContent = 'Stop caffeine ~' + Math.round(hoursBeforeBed) + ' hrs before bedtime for < 25 mg at ' + formatTime12(bedtimeStr);

    // Build decay chart (hourly from earliest drink to bedtime + 2 hrs)
    buildDecayChart(halfLife, bedtimeMins);

    // Build per-drink breakdown table
    buildBreakdown(halfLife, bedtimeMins);

    document.getElementById('results').classList.add('active');
}

function buildDecayChart(halfLife, bedtimeMins) {
    const container = document.getElementById('decayChart');
    container.innerHTML = '';

    if (drinkLog.length === 0) return;

    // Find time range: earliest drink to bedtime + 2 hours
    const earliestMins = timeToMinutes(drinkLog[0].time);
    let endMins = bedtimeMins + 120;
    if (endMins <= earliestMins) endMins += 1440;

    // Calculate total caffeine at each hour
    const points = [];
    let maxCaffeine = 0;

    for (let t = earliestMins; t <= endMins; t += 60) {
        let total = 0;
        drinkLog.forEach(d => {
            const drinkMins = timeToMinutes(d.time);
            let elapsed = t - drinkMins;
            if (elapsed < 0) elapsed += 1440;
            if (elapsed >= 0) {
                total += d.mg * Math.pow(0.5, (elapsed / 60) / halfLife);
            }
        });
        points.push({ time: t % 1440, caffeine: total });
        if (total > maxCaffeine) maxCaffeine = total;
    }

    // Render as horizontal bars
    points.forEach(p => {
        const row = document.createElement('div');
        row.className = 'chart-bar-row';

        const isBedtime = Math.abs(p.time - bedtimeMins) < 30;
        const barPct = maxCaffeine > 0 ? (p.caffeine / maxCaffeine) * 100 : 0;

        let barColor = 'var(--safe-color)';
        if (p.caffeine > 200) barColor = 'var(--danger-color)';
        else if (p.caffeine > 50) barColor = 'var(--caffeine-color)';

        row.innerHTML = '<div class="chart-bar-label">' + minutesToTime12(p.time) + '</div>' +
            '<div class="chart-bar-track">' +
            '<div class="chart-bar-fill" style="width: ' + barPct + '%; background-color: ' + barColor + ';"></div>' +
            '<div class="chart-bar-value">' + Math.round(p.caffeine) + ' mg</div>' +
            '</div>';

        if (isBedtime) {
            row.style.border = '1px solid var(--accent-color)';
            row.style.borderRadius = '6px';
            row.style.padding = '2px';
        }

        container.appendChild(row);
    });
}

function buildBreakdown(halfLife, bedtimeMins) {
    const tbody = document.getElementById('breakdownBody');
    tbody.innerHTML = '';

    drinkLog.forEach(d => {
        const remaining = caffeineAtTime(d.mg, timeToMinutes(d.time), bedtimeMins, halfLife);
        const tr = document.createElement('tr');

        let badgeClass = 'badge-safe';
        let badgeText = 'Low';
        if (remaining > 50) { badgeClass = 'badge-danger'; badgeText = 'High'; }
        else if (remaining > 20) { badgeClass = 'badge-warning'; badgeText = 'Moderate'; }

        tr.innerHTML = '<td>' + formatTime12(d.time) + '</td>' +
            '<td>' + d.name + '</td>' +
            '<td style="font-family: var(--font-mono); color: var(--caffeine-color);">' + d.mg + ' mg</td>' +
            '<td><span class="status-badge ' + badgeClass + '">' + Math.round(remaining) + ' mg — ' + badgeText + '</span></td>';
        tbody.appendChild(tr);
    });
}

function buildReferenceTable() {
    const tbody = document.getElementById('referenceBody');
    beverages.forEach(b => {
        const tr = document.createElement('tr');
        const catLabel = b.category.charAt(0).toUpperCase() + b.category.slice(1);
        tr.innerHTML = '<td>' + b.name + '</td>' +
            '<td style="color: var(--text-secondary);">' + b.serving + '</td>' +
            '<td style="font-family: var(--font-mono); color: var(--caffeine-color);">' + b.mg + ' mg</td>' +
            '<td style="color: var(--text-secondary);">' + catLabel + '</td>';
        tbody.appendChild(tr);
    });
}

function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    item.classList.toggle('open');
}

// Initialize
populateSelect('all');
setDefaultTime();
buildReferenceTable();
  </script>
