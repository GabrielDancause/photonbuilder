  { us: 7.75, uk: 'O½', eu: 56.3, diameter: 17.9, circumference: 56.3 },
  { us: 8, uk: 'P', eu: 57.0, diameter: 18.1, circumference: 57.0 },
  { us: 8.25, uk: 'P½', eu: 57.6, diameter: 18.3, circumference: 57.6 },
  { us: 8.5, uk: 'Q', eu: 58.3, diameter: 18.5, circumference: 58.3 },
  { us: 8.75, uk: 'Q½', eu: 58.9, diameter: 18.8, circumference: 58.9 },
  { us: 9, uk: 'R', eu: 59.5, diameter: 19.0, circumference: 59.5 },
