  { us: 9.5, uk: 'S', eu: 60.8, diameter: 19.4, circumference: 60.8 },
  { us: 9.75, uk: 'S½', eu: 61.4, diameter: 19.6, circumference: 61.4 },
  { us: 10, uk: 'T', eu: 62.1, diameter: 19.8, circumference: 62.1 },
  { us: 10.25, uk: 'T½', eu: 62.7, diameter: 20.0, circumference: 62.7 },
  { us: 10.5, uk: 'U', eu: 63.4, diameter: 20.2, circumference: 63.4 },
  { us: 10.75, uk: 'U½', eu: 64.0, diameter: 20.4, circumference: 64.0 },
  { us: 11, uk: 'V', eu: 64.6, diameter: 20.6, circumference: 64.6 },
  { us: 11.25, uk: 'V½', eu: 65.3, diameter: 20.8, circumference: 65.3 },
  { us: 11.5, uk: 'W', eu: 65.9, diameter: 21.0, circumference: 65.9 },
  { us: 11.75, uk: 'W½', eu: 66.6, diameter: 21.2, circumference: 66.6 },
  { us: 12, uk: 'X', eu: 67.2, diameter: 21.4, circumference: 67.2 },
  { us: 12.25, uk: 'X½', eu: 67.8, diameter: 21.6, circumference: 67.8 },
  { us: 12.5, uk: 'Y', eu: 68.5, diameter: 21.8, circumference: 68.5 },
  { us: 12.75, uk: 'Y½', eu: 69.1, diameter: 22.0, circumference: 69.1 },
  { us: 13, uk: 'Z', eu: 69.7, diameter: 22.2, circumference: 69.7 },
  { us: 13.25, uk: 'Z½', eu: 70.4, diameter: 22.4, circumference: 70.4 },
  { us: 13.5, uk: 'Z1', eu: 71.0, diameter: 22.6, circumference: 71.0 },
  { us: 13.75, uk: 'Z1½', eu: 71.6, diameter: 22.8, circumference: 71.6 },
  { us: 14, uk: 'Z2', eu: 72.3, diameter: 23.0, circumference: 72.3 },
  { us: 14.25, uk: 'Z2½', eu: 72.9, diameter: 23.2, circumference: 72.9 },
  { us: 14.5, uk: 'Z3', eu: 73.5, diameter: 23.4, circumference: 73.5 },
  { us: 14.75, uk: 'Z3½', eu: 74.2, diameter: 23.6, circumference: 74.2 },
  { us: 15, uk: 'Z4', eu: 74.8, diameter: 23.8, circumference: 74.8 }
];

// Convert US size to Asian size (approximate)
function usToAsian(usSize) {
  return Math.round(usSize + 2.5);
}

// Initialize the tool
document.addEventListener('DOMContentLoaded', function() {
  populateTable();
  setupTabSwitching();
});

function setupTabSwitching() {
  const tabBtns = document.querySelectorAll('.tab-btn');
  const methodContents = document.querySelectorAll('.method-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const method = this.dataset.method;
      
      // Update active tab
      tabBtns.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      
      // Show corresponding content
      methodContents.forEach(content => {
        content.classList.remove('active');
        if (content.id === method + '-method') {
          content.classList.add('active');
        }
      });
    });
  });
}

function populateTable() {
  const tbody = document.getElementById('size-table-body');
  tbody.innerHTML = '';

  ringData.forEach(ring => {
    const row = document.createElement('tr');
    const asian = usToAsian(ring.us);
    
    row.innerHTML = `
      <td>${ring.us}</td>
      <td>${ring.uk}</td>
      <td>${ring.eu}</td>
      <td>${ring.diameter}</td>
      <td>${ring.circumference}</td>
    `;
    tbody.appendChild(row);
  });
}

function findClosestSize(diameter) {
  let closest = ringData[0];
  let minDiff = Math.abs(diameter - closest.diameter);

  for (let i = 1; i < ringData.length; i++) {
    const diff = Math.abs(diameter - ringData[i].diameter);
    if (diff < minDiff) {
      minDiff = diff;
      closest = ringData[i];
    }
  }

  return closest;
}

function calculateFromDiameter() {
  const diameterInput = document.getElementById('diameter-input');
  const diameter = parseFloat(diameterInput.value);

  if (!diameter || diameter < 10 || diameter > 30) {
    alert('Please enter a valid diameter between 10-30mm');
    return;
  }

  const size = findClosestSize(diameter);
  displayResults(size, diameter);
  updateRingVisual(diameter);
}

function calculateFromCircumference() {
  const circumferenceInput = document.getElementById('circumference-input');
  const circumference = parseFloat(circumferenceInput.value);

  if (!circumference || circumference < 35 || circumference > 80) {
    alert('Please enter a valid circumference between 35-80mm');
    return;
  }

  // Convert circumference to diameter: diameter = circumference / π
  const diameter = circumference / Math.PI;
  const size = findClosestSize(diameter);
  displayResults(size, diameter, circumference);
  updateRingVisual(diameter);
}

function displayResults(size, diameter, inputCircumference = null) {
  const resultsDiv = document.getElementById('size-results');
  const asian = usToAsian(size.us);
  
  document.getElementById('us-size').textContent = size.us;
  document.getElementById('uk-size').textContent = size.uk;
  document.getElementById('eu-size').textContent = size.eu;
  document.getElementById('asian-size').textContent = asian;
  
  document.getElementById('result-diameter').textContent = diameter.toFixed(1);
  document.getElementById('result-circumference').textContent = 
    (inputCircumference || size.circumference).toFixed(1);
  
  resultsDiv.classList.remove('hidden');
  resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function updateRingVisual(diameter) {
  const ringCircle = document.getElementById('ring-circle');
  // Scale to reasonable visual size (pixels)
  const visualSize = Math.max(20, Math.min(100, diameter * 3));
  ringCircle.style.width = visualSize + 'px';
  ringCircle.style.height = visualSize + 'px';
}

function printRingSizer() {
  const printContent = document.getElementById('print-content');
  printContent.innerHTML = `
    <h2>Ring Sizing Strip</h2>
    <p><strong>Instructions:</strong> Print at 100% scale. Cut out the strip below and wrap around your finger.</p>
    <div style="border: 1px solid #000; margin: 20px 0; padding: 10px;">
      <div style="display: flex; align-items: center; height: 20px; border: 1px solid #000; position: relative;">
        ${generateSizingStrip()}
      </div>
    </div>
    <p><strong>Scale Test:</strong> This ruler should measure exactly 5cm: <span style="display: inline-block; width: 50mm; height: 2px; background: #000; vertical-align: middle; margin: 0 5px;"></span></p>
  `;
  printContent.classList.remove('hidden');
  setTimeout(() => window.print(), 100);
}

function generateSizingStrip() {
  let strip = '';
  for (let i = 0; i < ringData.length; i += 2) {
    const size = ringData[i];
    const widthMm = size.circumference;
    const widthPx = widthMm * 3.78; // Convert mm to pixels at 96 DPI
    
    strip += `<div style="width: ${widthPx}px; height: 100%; border-right: 1px solid #000; display: flex; align-items: center; justify-content: center; font-size: 8px; position: relative;">
      <span style="transform: rotate(-90deg); white-space: nowrap;">${size.us}</span>
    </div>`;
  }
  return strip;
}

function printRingCircles() {
  const printContent = document.getElementById('print-content');
  let circles = '<h2>Ring Size Comparison Circles</h2><p><strong>Instructions:</strong> Print at 100% scale. Compare your existing ring to these circles.</p><div style="display: flex; flex-wrap: wrap; gap: 10px; margin: 20px 0;">';
  
  for (let i = 0; i < ringData.length; i += 3) {
    const size = ringData[i];
    const diameterPx = size.diameter * 3.78; // Convert mm to pixels
    
    circles += `<div style="text-align: center; margin: 10px;">
      <div style="width: ${diameterPx}px; height: ${diameterPx}px; border: 2px solid #000; border-radius: 50%; margin: 0 auto 5px;"></div>
      <div style="font-size: 10px;">US ${size.us}</div>
    </div>`;
  }
  
  circles += '</div>';
  printContent.innerHTML = circles;
  printContent.classList.remove('hidden');
  setTimeout(() => window.print(), 100);
}

// Table functionality
let sortDirection = {};

function sortTable(columnIndex) {
  const table = document.getElementById('size-table');
  const tbody = table.querySelector('tbody');
  const rows = Array.from(tbody.rows);
  
  const isNumeric = columnIndex >= 2; // EU size, diameter, circumference are numeric
  const direction = sortDirection[columnIndex] === 'asc' ? 'desc' : 'asc';
  sortDirection[columnIndex] = direction;
  
  rows.sort((a, b) => {
    let aVal = a.cells[columnIndex].textContent;
    let bVal = b.cells[columnIndex].textContent;
    
    if (isNumeric) {
      aVal = parseFloat(aVal);
      bVal = parseFloat(bVal);
    }
    
    if (direction === 'asc') {
      return aVal > bVal ? 1 : -1;
    } else {
      return aVal < bVal ? 1 : -1;
    }
  });
  
  // Clear and repopulate tbody
  tbody.innerHTML = '';
  rows.forEach(row => tbody.appendChild(row));
  
  // Update sort arrows
  document.querySelectorAll('.sort-arrow').forEach((arrow, index) => {
    if (index === columnIndex) {
      arrow.textContent = direction === 'asc' ? '↑' : '↓';
    } else {
      arrow.textContent = '↕';
    }
  });
}

function filterTable() {
  const filter = document.getElementById('table-filter').value.toLowerCase();
  const tbody = document.getElementById('size-table-body');
  const rows = tbody.querySelectorAll('tr');
  
  rows.forEach(row => {
    const text = row.textContent.toLowerCase();
    row.style.display = text.includes(filter) ? '' : 'none';
  });
}

function filterBySystem() {
  const system = document.getElementById('size-system').value;
  const tbody = document.getElementById('size-table-body');
  const rows = tbody.querySelectorAll('tr');
  
  if (!system) {
    rows.forEach(row => row.style.display = '');
    return;
  }
  
  rows.forEach(row => {
    let show = false;
    const cells = row.cells;
    
    switch(system) {
      case 'us':
        show = parseFloat(cells[0].textContent) % 1 === 0; // Whole numbers only
        break;
      case 'uk':
        show = !cells[1].textContent.includes('½'); // No half sizes
        break;
      case 'eu':
        show = parseFloat(cells[2].textContent) % 1 === 0; // Whole numbers only
        break;
    }
    
    row.style.display = show ? '' : 'none';
  });
}
</script>