<script is:inline>
// Ring size conversion data (industry standard measurements)
const ringData = [
  { us: 3, uk: 'F', eu: 44.0, diameter: 14.0, circumference: 44.0 },
  { us: 3.25, uk: 'F½', eu: 44.8, diameter: 14.3, circumference: 44.8 },
  { us: 3.5, uk: 'G', eu: 45.5, diameter: 14.4, circumference: 45.2 },
  { us: 3.75, uk: 'G½', eu: 46.3, diameter: 14.7, circumference: 46.0 },
  { us: 4, uk: 'H', eu: 46.8, diameter: 14.9, circumference: 46.7 },
  { us: 4.25, uk: 'H½', eu: 47.4, diameter: 15.1, circumference: 47.4 },
  { us: 4.5, uk: 'I', eu: 48.0, diameter: 15.3, circumference: 48.0 },
  { us: 4.75, uk: 'I½', eu: 48.7, diameter: 15.5, circumference: 48.7 },
  { us: 5, uk: 'J', eu: 49.3, diameter: 15.7, circumference: 49.3 },
