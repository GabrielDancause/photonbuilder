---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  category: "tool"
};
---

<SiteLayout 
  site="eeniemeenie"
  title="Ring Size Chart & Interactive Ring Sizer | Free Measurement Tool"
  description="Find your perfect ring size with our interactive ring sizer. Measure existing rings, use string method, or print our sizing chart. Accurate US, UK, EU & Asian size conversions."
>
  <div class="container">
    <header class="hero">
      <h1>Ring Size Chart & Interactive Sizer</h1>
      <p>Find your perfect ring size with multiple measurement methods and accurate conversions across US, UK, European, and Asian sizing systems.</p>
    </header>

    <!-- Interactive Ring Sizer -->
    <section class="card">
      <h2>Interactive Ring Sizer</h2>
      <p>Choose your preferred measurement method below:</p>
      
      <div class="method-tabs">
        <button class="tab-btn active" data-method="existing">Measure Existing Ring</button>
        <button class="tab-btn" data-method="string">String/Paper Method</button>
        <button class="tab-btn" data-method="print">Print Ring Sizer</button>
      </div>

      <!-- Method A: Existing Ring -->
      <div class="method-content active" id="existing-method">
        <h3>Method A: Measure an Existing Ring</h3>
        <p>Measure the inner diameter of a ring that fits well on the intended finger.</p>
        
        <div class="input-group">
          <label for="diameter-input">Ring Inner Diameter (mm):</label>
          <input type="number" id="diameter-input" placeholder="14.0" step="0.1" min="10" max="25">
          <button onclick="calculateFromDiameter()">Find My Size</button>
        </div>
        
        <div id="visual-ring" class="ring-visual">
          <div class="ring-circle" id="ring-circle"></div>
          <p class="ring-label">Actual size preview</p>
        </div>
      </div>

      <!-- Method B: String Method -->
      <div class="method-content" id="string-method">
        <h3>Method B: String or Paper Method</h3>
        <ol>
          <li>Wrap a string or thin strip of paper around your finger</li>
          <li>Mark where the string/paper overlaps</li>
          <li>Measure the marked length with a ruler</li>
          <li>Enter the measurement below</li>
        </ol>
        
        <div class="input-group">
          <label for="circumference-input">Finger Circumference (mm):</label>
          <input type="number" id="circumference-input" placeholder="50.0" step="0.1" min="35" max="80">
          <button onclick="calculateFromCircumference()">Find My Size</button>
        </div>
      </div>

      <!-- Method C: Print Sizer -->
      <div class="method-content" id="print-method">
        <h3>Method C: Print Ring Sizer</h3>
        <p>Print these tools at 100% scale (no scaling) for accurate measurements.</p>
        
        <div class="print-options">
          <button onclick="printRingSizer()" class="print-btn">Print Ring Sizing Strip</button>
          <button onclick="printRingCircles()" class="print-btn">Print Ring Comparison Circles</button>
        </div>
        
        <div id="print-content" class="print-content hidden">
          <!-- Print content will be generated here -->
        </div>
      </div>

      <!-- Results Display -->
      <div id="size-results" class="size-results hidden">
        <h3>Your Ring Size</h3>
        <div class="size-display">
          <div class="size-item">
            <span class="label">US/Canada:</span>
            <span class="value" id="us-size">-</span>
          </div>
          <div class="size-item">
            <span class="label">UK/Australia:</span>
            <span class="value" id="uk-size">-</span>
          </div>
          <div class="size-item">
            <span class="label">European:</span>
            <span class="value" id="eu-size">-</span>
          </div>
          <div class="size-item">
            <span class="label">Asian:</span>
            <span class="value" id="asian-size">-</span>
          </div>
        </div>
        <div class="measurements">
          <p><strong>Inner Diameter:</strong> <span id="result-diameter">-</span> mm</p>
          <p><strong>Circumference:</strong> <span id="result-circumference">-</span> mm</p>
        </div>
      </div>
    </section>

    <!-- Comprehensive Size Chart -->
    <section class="card">
      <h2>Ring Size Conversion Chart</h2>
      <p>Complete conversion table for all major sizing systems. Click column headers to sort.</p>
      
      <div class="table-controls">
        <input type="text" id="table-filter" placeholder="Search sizes..." onkeyup="filterTable()">
        <select id="size-system" onchange="filterBySystem()">
          <option value="">All Systems</option>
          <option value="us">US Sizes</option>
          <option value="uk">UK Sizes</option>
          <option value="eu">European</option>
        </select>
      </div>
      
      <div class="table-container">
        <table id="size-table" class="size-table">
          <thead>
            <tr>
              <th onclick="sortTable(0)">US Size <span class="sort-arrow">↕</span></th>
              <th onclick="sortTable(1)">UK Size <span class="sort-arrow">↕</span></th>
              <th onclick="sortTable(2)">EU Size <span class="sort-arrow">↕</span></th>
              <th onclick="sortTable(3)">Inner Diameter (mm) <span class="sort-arrow">↕</span></th>
              <th onclick="sortTable(4)">Circumference (mm) <span class="sort-arrow">↕</span></th>
            </tr>
          </thead>
          <tbody id="size-table-body">
            <!-- Table data will be generated by JavaScript -->
          </tbody>
        </table>
      </div>
    </section>

    <!-- Average Sizes Guide -->
    <section class="card">
      <h2>Average Ring Sizes & Measuring Tips</h2>
      
      <div class="average-sizes">
        <div class="average-item">
          <h3>Women's Average</h3>
          <p><strong>US Size 6-7</strong> (16.5-17.3mm diameter)</p>
        </div>
        <div class="average-item">
          <h3>Men's Average</h3>
          <p><strong>US Size 9-10</strong> (19.0-19.8mm diameter)</p>
        </div>
      </div>

      <div class="measuring-tips">
        <h3>Important Measuring Tips</h3>
        <ul>
          <li><strong>Best time:</strong> Measure in the evening when hands are warm</li>
          <li><strong>Dominant hand:</strong> Usually 0.5 size larger than non-dominant</li>
          <li><strong>Temperature:</strong> Cold hands measure smaller than actual size</li>
          <li><strong>Knuckles:</strong> Ring must fit over knuckle but not be loose at base</li>
          <li><strong>Multiple measurements:</strong> Measure 3 times and take the average</li>
        </ul>
      </div>
    </section>

    <!-- Country Systems -->
    <section class="card">
      <h2>Ring Sizing Systems by Country</h2>
      
      <div class="system-grid">
        <div class="system-item">
          <h3>🇺🇸 US/Canada</h3>
          <p><strong>Numbered system (3-15)</strong></p>
          <p>Uses numerical sizing with half sizes. Most common system in North America.</p>
        </div>
        
        <div class="system-item">
          <h3>🇬🇧 UK/Australia</h3>
          <p><strong>Letter system (A-Z)</strong></p>
          <p>Uses alphabetical sizing starting from A. Adult sizes typically range F-Z.</p>
        </div>
        
        <div class="system-item">
          <h3>🇪🇺 European</h3>
          <p><strong>Circumference (44-70)</strong></p>
          <p>Based on inner circumference in millimeters. Most precise system.</p>
        </div>
        
        <div class="system-item">
          <h3>🇯🇵 Japanese/Asian</h3>
          <p><strong>Numbered (1-30)</strong></p>
          <p>Uses numerical system with different scaling than US sizes.</p>
        </div>
      </div>
    </section>

    <!-- How to Measure -->
    <section class="card">
      <h2>How to Measure Ring Size at Home</h2>
      
      <div class="method-guide">
        <div class="method-step">
          <h3>1. String Method (Most Popular)</h3>
          <p>Wrap a string around your finger where the ring will sit. Mark where it overlaps, then measure the marked length. This gives you the circumference. Works best with non-stretchy string or dental floss.</p>
        </div>
        
        <div class="method-step">
          <h3>2. Paper Strip Method</h3>
          <p>Cut a thin strip of paper (about 1cm wide). Wrap it around your finger, mark the overlap, and measure. Paper is stiffer than string and may give a more accurate measurement for some people.</p>
        </div>
        
        <div class="method-step">
          <h3>3. Existing Ring Method</h3>
          <p>Use a ring that already fits well. Measure the inner diameter with a ruler or calipers. This is the most accurate method if you have a well-fitting ring for the same finger.</p>
        </div>
        
        <div class="method-step">
          <h3>4. Visit a Jeweler</h3>
          <p>Professional jewelers use ring mandrels and sizers for the most accurate measurements. Many jewelers offer free sizing services, especially if you're considering a purchase.</p>
        </div>
      </div>

      <div class="common-mistakes">
        <h3>Common Mistakes to Avoid</h3>
        <ul>
          <li><strong>Measuring when cold:</strong> Fingers shrink in cold weather</li>
          <li><strong>Wrong time of day:</strong> Fingers are smallest in the morning</li>
          <li><strong>Too tight/loose:</strong> Ring should slide over knuckle with slight resistance</li>
          <li><strong>Wrong finger:</strong> Each finger is different, even on the same hand</li>
          <li><strong>Ignoring knuckle size:</strong> Large knuckles need larger sizes</li>
        </ul>
      </div>
    </section>

    <!-- Ring Width Effect -->
    <section class="card">
      <h2>Ring Width & Comfort Fit Guide</h2>
      
      <div class="width-guide">
        <h3>How Band Width Affects Size</h3>
        <p>Wider rings feel tighter and may require a larger size:</p>
        
        <div class="width-examples">
          <div class="width-item">
            <div class="width-visual thin-band"></div>
            <p><strong>Thin bands (2-4mm):</strong> Use your measured size</p>
          </div>
          <div class="width-item">
            <div class="width-visual medium-band"></div>
            <p><strong>Medium bands (4-6mm):</strong> Consider 0.25 size larger</p>
          </div>
          <div class="width-item">
            <div class="width-visual wide-band"></div>
            <p><strong>Wide bands (6mm+):</strong> Usually need 0.5-1 size larger</p>
          </div>
        </div>
      </div>

      <div class="comfort-fit">
        <h3>Standard vs Comfort Fit</h3>
        <div class="fit-comparison">
          <div class="fit-item">
            <h4>Standard Fit</h4>
            <p>Flat interior surface. True to size measurements.</p>
          </div>
          <div class="fit-item">
            <h4>Comfort Fit</h4>
            <p>Rounded, domed interior. Usually requires 0.5 size smaller than standard fit.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="card">
      <h2>Related Measurement Tools</h2>
      <div class="related-tools">
        <a href="../shoe-size-converter/" class="tool-link">Shoe Size Converter</a>
        <a href="../clothing-size-chart/" class="tool-link">Clothing Size Chart</a>
        <a href="../bra-size-calculator/" class="tool-link">Bra Size Calculator</a>
        <a href="../hat-size-chart/" class="tool-link">Hat Size Chart</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="card">
      <h2>Frequently Asked Questions</h2>
      
      <div class="faq-list">
        <div class="faq-item">
          <h3>What is the most common ring size for women?</h3>
          <p>The most common women's ring size is US size 6-7, which corresponds to an inner diameter of 16.5-17.3mm. However, sizes can vary significantly based on height, weight, and genetics.</p>
        </div>
        
        <div class="faq-item">
          <h3>How do I measure ring size at home accurately?</h3>
          <p>The most accurate home method is measuring an existing ring's inner diameter. If you don't have one, use the string method: wrap string around your finger, mark the overlap, and measure the length. Measure in the evening when hands are warm.</p>
        </div>
        
        <div class="faq-item">
          <h3>What is my ring size in European measurements?</h3>
          <p>European ring sizes correspond to the inner circumference in millimeters. For example, US size 6 = EU size 51.9, and US size 7 = EU size 54.4. Use our conversion chart above for exact measurements.</p>
        </div>
        
        <div class="faq-item">
          <h3>Should I size up or down for a wide band?</h3>
          <p>Size up for wide bands. Bands wider than 6mm typically require 0.5-1 size larger than your measured size because they cover more surface area and feel tighter on your finger.</p>
        </div>
        
        <div class="faq-item">
          <h3>Can ring size change over time?</h3>
          <p>Yes, ring size can change due to weight fluctuations, temperature, time of day, pregnancy, aging, and medical conditions. It's normal for size to vary by 0.25-0.5 sizes throughout the day.</p>
        </div>
        
        <div class="faq-item">
          <h3>What if I'm between sizes?</h3>
          <p>If you're between sizes, consider the ring width and your lifestyle. For thin bands or active lifestyles, choose the smaller size. For wide bands or if you have large knuckles, choose the larger size.</p>
        </div>
      </div>
    </section>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the most common ring size for women?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most common women's ring size is US size 6-7, which corresponds to an inner diameter of 16.5-17.3mm. However, sizes can vary significantly based on height, weight, and genetics."
        }
      },
      {
        "@type": "Question",
        "name": "How do I measure ring size at home accurately?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most accurate home method is measuring an existing ring's inner diameter. If you don't have one, use the string method: wrap string around your finger, mark the overlap, and measure the length. Measure in the evening when hands are warm."
        }
      },
      {
        "@type": "Question",
        "name": "Should I size up or down for a wide band?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Size up for wide bands. Bands wider than 6mm typically require 0.5-1 size larger than your measured size because they cover more surface area and feel tighter on your finger."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Ring Size Chart & Interactive Ring Sizer",
    "description": "Find your perfect ring size with our interactive ring sizer. Measure existing rings, use string method, or print our sizing chart. Accurate US, UK, EU & Asian size conversions.",
    "author": {
      "@type": "Organization",
      "name": "eeniemeenie"
    },
    "publisher": {
      "@type": "Organization",
      "name": "eeniemeenie"
    },
    "articleSection": "Tools",
    "keywords": "ring size chart, ring sizer, ring size converter, measure ring size, ring size guide"
  }
  </script>
</SiteLayout>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: #060a12;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    line-height: 1.6;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #E040FB, #ffffff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p {
    font-size: 1.2rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .card {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
  }

  .card h2 {
    color: #E040FB;
    margin-bottom: 1rem;
    font-size: 1.8rem;
  }

  .method-tabs {
    display: flex;
    gap: 1rem;
    margin: 1.5rem 0;
    flex-wrap: wrap;
  }

  .tab-btn {
    background: #152040;
    color: #ffffff;
    border: 1px solid #2a3a5a;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.9rem;
  }

  .tab-btn:hover {
    background: #1a2550;
    border-color: #E040FB;
  }

  .tab-btn.active {
    background: #E040FB;
    border-color: #E040FB;
    color: #ffffff;
  }

  .method-content {
    display: none;
    margin-top: 1.5rem;
  }

  .method-content.active {
    display: block;
  }

  .method-content h3 {
    color: #E040FB;
    margin-bottom: 1rem;
  }

  .input-group {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin: 1rem 0;
    flex-wrap: wrap;
  }

  .input-group label {
    font-weight: 500;
    min-width: 200px;
  }

  .input-group input {
    background: #152040;
    border: 1px solid #2a3a5a;
    color: #ffffff;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    width: 120px;
  }

  .input-group input:focus {
    outline: none;
    border-color: #E040FB;
    box-shadow: 0 0 0 2px rgba(224, 64, 251, 0.2);
  }

  .input-group button {
    background: #E040FB;
    color: #ffffff;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: background 0.3s ease;
  }

  .input-group button:hover {
    background: #d030eb;
  }

  .ring-visual {
    margin: 2rem 0;
    text-align: center;
  }

  .ring-circle {
    width: 50px;
    height: 50px;
    border: 3px solid #E040FB;
    border-radius: 50%;
    margin: 0 auto 0.5rem;
    background: transparent;
    transition: all 0.3s ease;
  }

  .ring-label {
    font-size: 0.9rem;
    color: #999;
    font-family: 'JetBrains Mono', monospace;
  }

  .print-options {
    display: flex;
    gap: 1rem;
    margin: 1rem 0;
  }

  .print-btn {
    background: #152040;
    color: #ffffff;
    border: 1px solid #2a3a5a;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .print-btn:hover {
    background: #1a2550;
    border-color: #E040FB;
  }

  .print-content {
    background: #ffffff;
    color: #000000;
    padding: 2rem;
    margin: 1rem 0;
    border-radius: 8px;
  }

  .hidden {
    display: none;
  }

  .size-results {
    background: #152040;
    padding: 1.5rem;
    border-radius: 8px;
    margin-top: 1rem;
  }

  .size-display {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .size-item {
    background: #0a1020;
    padding: 1rem;
    border-radius: 6px;
    border: 1px solid #2a3a5a;
  }

  .size-item .label {
    display: block;
    font-size: 0.9rem;
    color: #999;
    margin-bottom: 0.5rem;
  }

  .size-item .value {
    display: block;
    font-size: 1.5rem;
    font-weight: bold;
    color: #E040FB;
    font-family: 'JetBrains Mono', monospace;
  }

  .measurements {
    border-top: 1px solid #2a3a5a;
    padding-top: 1rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .table-controls {
    display: flex;
    gap: 1rem;
    margin: 1rem 0;
    flex-wrap: wrap;
  }

  .table-controls input,
  .table-controls select {
    background: #152040;
    border: 1px solid #2a3a5a;
    color: #ffffff;
    padding: 0.75rem 1rem;
    border-radius: 6px;
  }

  .table-controls input:focus,
  .table-controls select:focus {
    outline: none;
    border-color: #E040FB;
  }

  .table-container {
    overflow-x: auto;
  }

  .size-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
  }

  .size-table th,
  .size-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid #152040;
  }

  .size-table th {
    background: #152040;
    color: #E040FB;
    cursor: pointer;
    position: sticky;
    top: 0;
    user-select: none;
  }

  .size-table th:hover {
    background: #1a2550;
  }

  .sort-arrow {
    margin-left: 0.5rem;
    opacity: 0.5;
  }

  .size-table tbody tr:hover {
    background: rgba(224, 64, 251, 0.05);
  }

  .average-sizes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 1.5rem 0;
  }

  .average-item {
    background: #152040;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid #2a3a5a;
    text-align: center;
  }

  .average-item h3 {
    color: #E040FB;
    margin-bottom: 0.5rem;
  }

  .measuring-tips ul {
    list-style: none;
    padding: 0;
  }

  .measuring-tips li {
    padding: 0.5rem 0;
    border-bottom: 1px solid #152040;
  }

  .measuring-tips li:last-child {
    border-bottom: none;
  }

  .system-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .system-item {
    background: #152040;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid #2a3a5a;
  }

  .system-item h3 {
    color: #E040FB;
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .method-guide {
    margin: 1.5rem 0;
  }

  .method-step {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #152040;
  }

  .method-step:last-child {
    border-bottom: none;
  }

  .method-step h3 {
    color: #E040FB;
    margin-bottom: 0.5rem;
  }

  .common-mistakes ul {
    list-style: none;
    padding: 0;
  }

  .common-mistakes li {
    padding: 0.5rem 0;
    border-bottom: 1px solid #152040;
  }

  .width-examples {
    display: flex;
    gap: 2rem;
    margin: 1.5rem 0;
    flex-wrap: wrap;
  }

  .width-item {
    text-align: center;
    flex: 1;
    min-width: 200px;
  }

  .width-visual {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin: 0 auto 1rem;
    border: 3px solid #E040FB;
  }

  .thin-band {
    border-width: 2px;
  }

  .medium-band {
    border-width: 4px;
  }

  .wide-band {
    border-width: 6px;
  }

  .fit-comparison {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 1rem 0;
  }

  .fit-item {
    background: #152040;
    padding: 1.5rem;
    border-radius: 8px;
