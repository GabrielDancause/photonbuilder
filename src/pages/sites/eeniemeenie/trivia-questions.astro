const faqItems = [
  { q: 'How many trivia questions are included?', a: 'This page includes 300 curated trivia questions across 8 categories: General Knowledge, Science, History, Geography, Pop Culture, Sports, Food & Drink, and Technology.' },
  { q: 'Can I play these as an interactive quiz?', a: 'Yes! Click "Start Quiz" to play in quiz mode with a timer, score tracking, and multiple choice answers. You can filter by category and difficulty.' },
  { q: 'What difficulty levels are available?', a: 'Every question is rated Easy, Medium, or Hard. In quiz mode, you can filter to play only questions at your preferred difficulty.' },
  { q: 'Can I use these for a virtual trivia night?', a: 'Absolutely. These questions work great for Zoom parties, family gatherings, pub quizzes, or classroom activities. Use browse mode to see all questions and answers at once.' },
  { q: 'How is the quiz scored?', a: 'You earn 1 point for Easy, 2 for Medium, and 3 for Hard questions answered correctly. Your final score shows total points, accuracy, and average time per question.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": { "@type": "Organization", "name": "Eenie Meenie" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL} schema={JSON.stringify([articleSchema, faqSchema])}>
  <style>
    :root {
      --quiz-green: #22c55e;
      --quiz-red: #ef4444;
      --quiz-yellow: #eab308;
      --quiz-blue: #3b82f6;
    }

    .page-wrap { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }

    /* Hero */
    .hero { text-align: center; margin-bottom: 2rem; }
    .hero h1 { font-size: 2.4rem; color: var(--accent-color); margin-bottom: 0.75rem; line-height: 1.2; }
    .hero p { font-size: 1.05rem; color: var(--text-secondary); max-width: 650px; margin: 0 auto 1.5rem; line-height: 1.6; }

    /* Mode toggle */
    .mode-toggle { display: flex; justify-content: center; gap: 0.5rem; margin-bottom: 2rem; }
    .mode-btn {
      padding: 0.75rem 2rem; border-radius: 30px; border: 2px solid var(--border-color);
      background: var(--card-bg); color: var(--text-primary); font-size: 1rem; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .mode-btn:hover { border-color: var(--accent-color); }
    .mode-btn.active { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }

    /* Quiz setup */
    .quiz-setup { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; }
    .setup-title { font-size: 1.3rem; font-weight: 700; margin-bottom: 1.5rem; text-align: center; }

    .filter-row { margin-bottom: 1.5rem; }
    .filter-label { font-weight: 600; margin-bottom: 0.75rem; display: block; color: var(--text-secondary); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px; }

    .chip-group { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .chip {
      padding: 0.5rem 1rem; border-radius: 20px; border: 1.5px solid var(--border-color);
      background: transparent; color: var(--text-primary); font-size: 0.85rem; font-weight: 500;
      cursor: pointer; transition: all 0.15s; user-select: none;
    }
    .chip:hover { border-color: var(--accent-color); }
    .chip.selected { background: var(--accent-color); color: #fff; border-color: var(--accent-color); }

    .setup-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; flex-wrap: wrap; gap: 1rem; }
    .q-count { color: var(--text-secondary); font-size: 0.95rem; }
    .q-count strong { color: var(--accent-color); }

    .start-btn {
      padding: 0.85rem 2.5rem; border-radius: 30px; border: none;
      background: var(--accent-color); color: #fff; font-size: 1.1rem; font-weight: 700;
      cursor: pointer; transition: all 0.2s;
    }
    .start-btn:hover { transform: translateY(-1px); filter: brightness(1.1); }
    .start-btn:disabled { opacity: 0.5; cursor: default; transform: none; }

    /* Timer toggle */
    .timer-toggle { display: flex; align-items: center; gap: 0.75rem; }
    .toggle-switch {
      position: relative; width: 48px; height: 26px; background: var(--border-color);
      border-radius: 13px; cursor: pointer; transition: 0.2s;
    }
    .toggle-switch.on { background: var(--accent-color); }
    .toggle-switch::after {
      content: ''; position: absolute; top: 3px; left: 3px; width: 20px; height: 20px;
      background: #fff; border-radius: 50%; transition: 0.2s;
    }
    .toggle-switch.on::after { left: 25px; }
    .toggle-label { font-size: 0.9rem; color: var(--text-secondary); }

    /* Quiz play */
    .quiz-play { display: none; }
    .quiz-play.active { display: block; }

    .progress-bar { background: var(--card-bg); border-radius: 8px; height: 8px; margin-bottom: 1rem; overflow: hidden; border: 1px solid var(--border-color); }
    .progress-fill { height: 100%; background: var(--accent-color); transition: width 0.3s; border-radius: 8px; }

    .quiz-hud {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 1.5rem; font-size: 0.9rem; color: var(--text-secondary); flex-wrap: wrap; gap: 0.5rem;
    }
    .hud-item { display: flex; align-items: center; gap: 0.35rem; }
    .hud-score { color: var(--quiz-green); font-weight: 700; }
    .hud-timer { font-variant-numeric: tabular-nums; min-width: 2.5rem; text-align: center; }
    .hud-timer.warning { color: var(--quiz-red); font-weight: 700; }

    .question-stage {
      background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px;
      padding: 2.5rem 2rem; text-align: center; min-height: 350px;
      display: flex; flex-direction: column; justify-content: center;
    }

    .stage-cat { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin-bottom: 0.5rem; }
    .stage-diff { display: inline-block; font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1.5rem; }
    .stage-diff.easy { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
    .stage-diff.medium { background: rgba(234, 179, 8, 0.15); color: #eab308; }
    .stage-diff.hard { background: rgba(239, 68, 68, 0.15); color: #ef4444; }

    .stage-question { font-size: 1.5rem; font-weight: 700; line-height: 1.4; margin-bottom: 2rem; color: var(--text-primary); }

    .choices { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; max-width: 600px; margin: 0 auto; }
    .choice-btn {
      padding: 1rem; border-radius: 12px; border: 2px solid var(--border-color);
      background: var(--card-bg); color: var(--text-primary); font-size: 1rem; font-weight: 500;
      cursor: pointer; transition: all 0.15s; text-align: left;
    }
    .choice-btn:hover:not(.locked) { border-color: var(--accent-color); background: rgba(224, 64, 251, 0.05); }
    .choice-btn.correct { border-color: var(--quiz-green); background: rgba(34, 197, 94, 0.15); color: var(--quiz-green); }
    .choice-btn.wrong { border-color: var(--quiz-red); background: rgba(239, 68, 68, 0.15); color: var(--quiz-red); }
    .choice-btn.locked { cursor: default; opacity: 0.6; }
    .choice-btn.locked.correct { opacity: 1; }

    .choice-letter { font-weight: 700; margin-right: 0.5rem; opacity: 0.5; }

    .next-btn {
      margin-top: 1.5rem; padding: 0.75rem 2rem; border-radius: 25px; border: none;
      background: var(--accent-color); color: #fff; font-size: 1rem; font-weight: 600;
      cursor: pointer; display: none;
    }
    .next-btn.visible { display: inline-block; }

    /* Results */
    .results-card {
      background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px;
      padding: 3rem 2rem; text-align: center; display: none;
    }
    .results-card.active { display: block; }

    .results-emoji { font-size: 4rem; margin-bottom: 1rem; }
    .results-title { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .results-subtitle { color: var(--text-secondary); margin-bottom: 2rem; font-size: 1.1rem; }

    .results-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2rem; }
    .stat-box { padding: 1.25rem; background: rgba(0,0,0,0.15); border-radius: 12px; }
    .stat-val { font-size: 2rem; font-weight: 800; color: var(--accent-color); }
    .stat-label { font-size: 0.8rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 0.25rem; }

    .results-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
    .results-actions button {
      padding: 0.75rem 1.75rem; border-radius: 25px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: 0.2s;
    }
    .btn-share { background: var(--accent-color); color: #fff; border: none; }
    .btn-retry { background: transparent; color: var(--text-primary); border: 2px solid var(--border-color); }
    .btn-retry:hover { border-color: var(--accent-color); }

    /* Browse mode */
    .browse-mode { display: none; }
    .browse-mode.active { display: block; }

    .cat-nav {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem;
      margin-bottom: 2rem; position: sticky; top: 60px;
      background: var(--bg-color); padding: 0.75rem 0; z-index: 10; border-bottom: 1px solid var(--border-color);
    }
    .cat-nav a {
      background: var(--card-bg); border: 1px solid var(--border-color); color: var(--text-primary);
      padding: 0.4rem 0.9rem; border-radius: 18px; text-decoration: none; font-size: 0.85rem;
      font-weight: 500; transition: 0.2s;
    }
    .cat-nav a:hover { border-color: var(--accent-color); color: var(--accent-color); }

    .browse-section { margin-bottom: 3rem; }
    .browse-section h2 { color: var(--accent-color); border-bottom: 2px solid var(--accent-color); padding-bottom: 0.4rem; margin-bottom: 1.5rem; }

    .browse-grid { display: flex; flex-direction: column; gap: 0.75rem; }

    .browse-card {
      background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px;
      padding: 1.25rem; cursor: pointer; transition: border-color 0.2s; user-select: none;
    }
    .browse-card:hover { border-color: var(--accent-color); }

    .browse-q-row { display: flex; justify-content: space-between; align-items: flex-start; }
    .browse-q { font-weight: 600; font-size: 1.05rem; flex: 1; }

    .browse-answer {
      margin-top: 0.75rem; padding: 0.75rem 1rem; background: rgba(0,0,0,0.2);
      border-left: 3px solid var(--accent-color); border-radius: 6px;
      display: none;
    }
    .browse-card.revealed .browse-answer { display: block; }
    .browse-card .tap-hint { font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.5rem; }
    .browse-card.revealed .tap-hint { display: none; }

    .browse-a-label { font-size: 0.7rem; color: var(--text-secondary); text-transform: uppercase; }
    .browse-a-text { font-weight: 700; color: var(--text-primary); }

    /* FAQ */
    .faq-section { margin-top: 3rem; }
    .faq-section h2 { text-align: center; margin-bottom: 1.5rem; color: var(--accent-color); }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.25rem; margin-bottom: 0.75rem; }
    .faq-q { font-weight: 700; margin-bottom: 0.4rem; font-size: 1.05rem; }
    .faq-a { color: var(--text-secondary); line-height: 1.5; }

    /* Guide */
    .guide-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 3rem 0; }
    .guide-section h2 { text-align: center; margin-bottom: 1.5rem; }
    .guide-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
    .guide-item h3 { color: var(--accent-color); margin-bottom: 0.5rem; font-size: 1rem; }
    .guide-item p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.8rem; }
      .choices { grid-template-columns: 1fr; }
      .results-stats { grid-template-columns: 1fr; }
      .stage-question { font-size: 1.25rem; }
      .question-stage { padding: 2rem 1.25rem; min-height: 300px; }
    }
  </style>

  <div class="page-wrap">
    <div class="hero">
      <h1>300 Trivia Questions & Answers</h1>
      <p>Play as an interactive quiz with scoring and a timer, or browse all 300 questions by category. 8 categories, 3 difficulty levels.</p>
    </div>

    <div class="mode-toggle">
      <button class="mode-btn active" data-mode="quiz" id="btn-quiz">🎯 Play Quiz</button>
      <button class="mode-btn" data-mode="browse" id="btn-browse">📖 Browse All</button>
    </div>

    <!-- QUIZ MODE -->
    <div id="quiz-mode">
      <div class="quiz-setup" id="quiz-setup">
        <div class="setup-title">Set Up Your Quiz</div>

        <div class="filter-row">
          <span class="filter-label">Categories</span>
          <div class="chip-group" id="cat-chips"></div>
        </div>

        <div class="filter-row">
          <span class="filter-label">Difficulty</span>
          <div class="chip-group" id="diff-chips">
            <button class="chip selected" data-diff="Easy">Easy</button>
            <button class="chip selected" data-diff="Medium">Medium</button>
            <button class="chip selected" data-diff="Hard">Hard</button>
          </div>
        </div>

        <div class="filter-row">
          <span class="filter-label">Questions</span>
          <div class="chip-group" id="count-chips">
            <button class="chip" data-count="10">10</button>
            <button class="chip selected" data-count="20">20</button>
            <button class="chip" data-count="50">50</button>
            <button class="chip" data-count="all">All</button>
          </div>
        </div>

        <div class="filter-row">
          <div class="timer-toggle">
            <div class="toggle-switch on" id="timer-toggle"></div>
            <span class="toggle-label">15-second timer per question</span>
          </div>
        </div>

        <div class="setup-footer">
          <div class="q-count"><strong id="available-count">300</strong> questions match your filters</div>
          <button class="start-btn" id="start-btn">Start Quiz →</button>
        </div>
      </div>

      <div class="quiz-play" id="quiz-play">
        <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
        <div class="quiz-hud">
          <div class="hud-item">Q <strong id="hud-current">1</strong> / <span id="hud-total">20</span></div>
          <div class="hud-item">Score: <span class="hud-score" id="hud-score">0</span></div>
          <div class="hud-item" id="hud-timer-wrap">⏱ <span class="hud-timer" id="hud-timer">15</span></div>
        </div>

        <div class="question-stage" id="question-stage">
          <div class="stage-cat" id="stage-cat"></div>
          <div class="stage-diff" id="stage-diff"></div>
          <div class="stage-question" id="stage-question"></div>
          <div class="choices" id="choices"></div>
          <button class="next-btn" id="next-btn">Next →</button>
        </div>
      </div>

      <div class="results-card" id="results-card">
        <div class="results-emoji" id="results-emoji">🏆</div>
        <div class="results-title" id="results-title">Nice Work!</div>
        <div class="results-subtitle" id="results-subtitle"></div>
        <div class="results-stats">
          <div class="stat-box"><div class="stat-val" id="stat-score">0</div><div class="stat-label">Points</div></div>
          <div class="stat-box"><div class="stat-val" id="stat-acc">0%</div><div class="stat-label">Accuracy</div></div>
          <div class="stat-box"><div class="stat-val" id="stat-time">0s</div><div class="stat-label">Avg Time</div></div>
        </div>
        <div class="results-actions">
          <button class="btn-share" id="btn-copy-score">📋 Copy Score</button>
          <button class="btn-retry" id="btn-retry">Play Again</button>
        </div>
      </div>
    </div>

    <!-- BROWSE MODE -->
    <div class="browse-mode" id="browse-mode">
      <nav class="cat-nav" id="cat-nav"></nav>
      <div id="browse-sections"></div>
    </div>

    <!-- GUIDE (static, always visible) -->
    <section class="guide-section" id="hosting-guide">
      <h2>How to Host a Great Trivia Night</h2>
      <div class="guide-grid">
        <div class="guide-item">
          <h3>1. Balance Difficulty</h3>
          <p>Mix Easy, Medium, and Hard. Mostly Easy/Medium keeps everyone engaged — Hard questions break ties.</p>
        </div>
        <div class="guide-item">
          <h3>2. Mix Categories</h3>
          <p>Don't stick to one topic. Variety means every player gets a chance to shine.</p>
        </div>
        <div class="guide-item">
          <h3>3. Clear Rules Upfront</h3>
          <p>Decide scoring, partial credit, and spelling rules before question one.</p>
        </div>
        <div class="guide-item">
          <h3>4. Good Pacing</h3>
          <p>30–45 seconds per question. Read each one twice. Don't rush.</p>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {faqItems.map(item => (
        <div class="faq-item">
          <div class="faq-q">{item.q}</div>
          <div class="faq-a">{item.a}</div>
        </div>
      ))}
    </section>
  </div>

  <script define:vars={{ categories }}>
    const CATS = categories;
    const LETTERS = ['A','B','C','D'];
    const POINTS = { Easy: 1, Medium: 2, Hard: 3 };

    // State
    let selectedCats = new Set(CATS.map(c => c.id));
    let selectedDiffs = new Set(['Easy','Medium','Hard']);
    let questionCount = 20;
    let timerEnabled = true;
    let quizQuestions = [];
    let currentIdx = 0;
    let score = 0;
    let correct = 0;
    let totalTime = 0;
    let timerInterval = null;
    let timeLeft = 15;
    let answered = false;

    // DOM
    const $ = id => document.getElementById(id);

    // Init category chips
    function initSetup() {
      const catChips = $('cat-chips');
      catChips.innerHTML = `<button class="chip selected" data-cat="all">All</button>` +
        CATS.map(c => `<button class="chip selected" data-cat="${c.id}">${c.emoji} ${c.name}</button>`).join('');

      catChips.addEventListener('click', e => {
        const btn = e.target.closest('.chip');
        if (!btn) return;
        const cat = btn.dataset.cat;
        if (cat === 'all') {
          const allSelected = selectedCats.size === CATS.length;
          if (allSelected) { selectedCats.clear(); } else { CATS.forEach(c => selectedCats.add(c.id)); }
        } else {
          selectedCats.has(cat) ? selectedCats.delete(cat) : selectedCats.add(cat);
        }
        updateChipUI();
        updateCount();
      });

      $('diff-chips').addEventListener('click', e => {
        const btn = e.target.closest('.chip');
        if (!btn) return;
        const d = btn.dataset.diff;
        selectedDiffs.has(d) ? selectedDiffs.delete(d) : selectedDiffs.add(d);
        btn.classList.toggle('selected');
        updateCount();
      });

      $('count-chips').addEventListener('click', e => {
        const btn = e.target.closest('.chip');
        if (!btn) return;
        $('count-chips').querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
        btn.classList.add('selected');
        questionCount = btn.dataset.count === 'all' ? 9999 : parseInt(btn.dataset.count);
      });

      $('timer-toggle').addEventListener('click', () => {
        timerEnabled = !timerEnabled;
        $('timer-toggle').classList.toggle('on', timerEnabled);
      });

      $('start-btn').addEventListener('click', startQuiz);
      $('next-btn').addEventListener('click', nextQuestion);
      $('btn-retry').addEventListener('click', resetToSetup);
      $('btn-copy-score').addEventListener('click', copyScore);

      // Mode toggle
      $('btn-quiz').addEventListener('click', () => setMode('quiz'));
      $('btn-browse').addEventListener('click', () => setMode('browse'));

      updateCount();
      buildBrowse();
    }

    function updateChipUI() {
      const chips = $('cat-chips').querySelectorAll('.chip');
      chips.forEach(ch => {
        if (ch.dataset.cat === 'all') {
          ch.classList.toggle('selected', selectedCats.size === CATS.length);
        } else {
          ch.classList.toggle('selected', selectedCats.has(ch.dataset.cat));
        }
      });
    }

    function getFiltered() {
      let pool = [];
      CATS.forEach(cat => {
        if (!selectedCats.has(cat.id)) return;
        cat.questions.forEach(q => {
          if (selectedDiffs.has(q.d)) pool.push({ ...q, cat: cat.name, catEmoji: cat.emoji, catId: cat.id });
        });
      });
      return pool;
    }

    function updateCount() {
      const n = getFiltered().length;
      $('available-count').textContent = n;
      $('start-btn').disabled = n === 0;
    }

    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function generateChoices(correctQ) {
      // Get all answers from the same category, then from all categories as fallback
      const sameCat = CATS.find(c => c.id === correctQ.catId);
      let pool = sameCat ? sameCat.questions.map(q => q.a).filter(a => a !== correctQ.a) : [];

      // If not enough from same category, pull from others
      if (pool.length < 3) {
        CATS.forEach(c => {
          c.questions.forEach(q => {
            if (q.a !== correctQ.a && !pool.includes(q.a)) pool.push(q.a);
          });
        });
      }

      shuffle(pool);
      const wrong = pool.slice(0, 3);
      const choices = [...wrong, correctQ.a];
      shuffle(choices);
      return choices;
    }

    function startQuiz() {
      let pool = getFiltered();
      shuffle(pool);
      quizQuestions = pool.slice(0, Math.min(questionCount, pool.length));
      currentIdx = 0; score = 0; correct = 0; totalTime = 0;

      $('quiz-setup').style.display = 'none';
      $('results-card').classList.remove('active');
      $('quiz-play').classList.add('active');
      $('hud-total').textContent = quizQuestions.length;
      $('hud-timer-wrap').style.display = timerEnabled ? '' : 'none';

      showQuestion();
    }

    function showQuestion() {
      answered = false;
      const q = quizQuestions[currentIdx];
      const choices = generateChoices(q);

      $('hud-current').textContent = currentIdx + 1;
      $('hud-score').textContent = score;
      $('progress-fill').style.width = ((currentIdx) / quizQuestions.length * 100) + '%';

      $('stage-cat').textContent = `${q.catEmoji} ${q.cat}`;
      const diffEl = $('stage-diff');
      diffEl.textContent = q.d;
      diffEl.className = 'stage-diff ' + q.d.toLowerCase();

      $('stage-question').textContent = q.q;

      const choicesEl = $('choices');
      choicesEl.innerHTML = choices.map((c, i) =>
        `<button class="choice-btn" data-answer="${c.replace(/"/g, '&quot;')}"><span class="choice-letter">${LETTERS[i]}</span>${c}</button>`
      ).join('');

      choicesEl.querySelectorAll('.choice-btn').forEach(btn => {
        btn.addEventListener('click', () => handleAnswer(btn, q));
      });

      $('next-btn').classList.remove('visible');

      if (timerEnabled) {
        timeLeft = 15;
        $('hud-timer').textContent = timeLeft;
        $('hud-timer').classList.remove('warning');
        clearInterval(timerInterval);
        timerInterval = setInterval(() => {
          timeLeft--;
          $('hud-timer').textContent = timeLeft;
          if (timeLeft <= 5) $('hud-timer').classList.add('warning');
          if (timeLeft <= 0) {
            clearInterval(timerInterval);
            timeUp(q);
          }
        }, 1000);
      }
    }

    function handleAnswer(btn, q) {
      if (answered) return;
      answered = true;
      clearInterval(timerInterval);

      const picked = btn.dataset.answer;
      const isCorrect = picked === q.a;
      const elapsed = timerEnabled ? (15 - timeLeft) : 0;
      totalTime += elapsed;

      // Lock all buttons
      $('choices').querySelectorAll('.choice-btn').forEach(b => {
        b.classList.add('locked');
        if (b.dataset.answer === q.a) b.classList.add('correct');
      });

      if (isCorrect) {
        btn.classList.add('correct');
        score += POINTS[q.d] || 1;
        correct++;
        $('hud-score').textContent = score;
      } else {
        btn.classList.add('wrong');
      }

      $('next-btn').textContent = currentIdx < quizQuestions.length - 1 ? 'Next →' : 'See Results';
      $('next-btn').classList.add('visible');
    }

    function timeUp(q) {
      if (answered) return;
      answered = true;
      totalTime += 15;

      $('choices').querySelectorAll('.choice-btn').forEach(b => {
        b.classList.add('locked');
        if (b.dataset.answer === q.a) b.classList.add('correct');
      });

      $('next-btn').textContent = currentIdx < quizQuestions.length - 1 ? 'Next →' : 'See Results';
      $('next-btn').classList.add('visible');
    }

    function nextQuestion() {
      currentIdx++;
      if (currentIdx >= quizQuestions.length) {
        showResults();
      } else {
        showQuestion();
      }
    }

    function showResults() {
      $('quiz-play').classList.remove('active');
      $('results-card').classList.add('active');
      $('progress-fill').style.width = '100%';

      const total = quizQuestions.length;
      const acc = Math.round((correct / total) * 100);
      const avgTime = timerEnabled ? (totalTime / total).toFixed(1) : '—';

      let emoji = '🏆'; let title = 'Trivia Master!';
      if (acc < 30) { emoji = '😅'; title = 'Better Luck Next Time'; }
      else if (acc < 50) { emoji = '🤔'; title = 'Not Bad!'; }
      else if (acc < 70) { emoji = '👏'; title = 'Nice Work!'; }
      else if (acc < 90) { emoji = '🔥'; title = 'Impressive!'; }

      $('results-emoji').textContent = emoji;
      $('results-title').textContent = title;
      $('results-subtitle').textContent = `${correct} of ${total} correct`;
      $('stat-score').textContent = score;
      $('stat-acc').textContent = acc + '%';
      $('stat-time').textContent = timerEnabled ? avgTime + 's' : '—';
    }

    function copyScore() {
      const total = quizQuestions.length;
      const acc = Math.round((correct / total) * 100);
      const text = `🎯 Trivia Quiz: ${correct}/${total} correct (${acc}%) — ${score} pts\nPlay at eeniemeenie.photonbuilder.com/trivia-questions`;
      navigator.clipboard.writeText(text).then(() => {
        $('btn-copy-score').textContent = '✅ Copied!';
        setTimeout(() => $('btn-copy-score').textContent = '📋 Copy Score', 2000);
      });
    }

    function resetToSetup() {
      $('quiz-play').classList.remove('active');
      $('results-card').classList.remove('active');
      $('quiz-setup').style.display = '';
    }

    function setMode(mode) {
      $('btn-quiz').classList.toggle('active', mode === 'quiz');
      $('btn-browse').classList.toggle('active', mode === 'browse');
      $('quiz-mode').style.display = mode === 'quiz' ? '' : 'none';
      $('browse-mode').classList.toggle('active', mode === 'browse');
    }

    // Browse mode
    function buildBrowse() {
      const nav = $('cat-nav');
      nav.innerHTML = CATS.map(c => `<a href="#browse-${c.id}">${c.emoji} ${c.name}</a>`).join('');

      const sections = $('browse-sections');
      let globalNum = 0;
      sections.innerHTML = CATS.map(cat => {
        const cards = cat.questions.map(q => {
          globalNum++;
          const diffClass = q.d.toLowerCase();
          return `<div class="browse-card" onclick="this.classList.toggle('revealed')">
            <div class="browse-q-row">
              <span class="browse-q">${globalNum}. ${q.q}</span>
              <span class="stage-diff ${diffClass}" style="flex-shrink:0;margin-left:0.5rem">${q.d}</span>
            </div>
            <div class="tap-hint">Tap to reveal answer</div>
            <div class="browse-answer">
              <span class="browse-a-label">Answer</span><br>
              <span class="browse-a-text">${q.a}</span>
            </div>
          </div>`;
        }).join('');
        return `<section id="browse-${cat.id}" class="browse-section"><h2>${cat.emoji} ${cat.name}</h2><div class="browse-grid">${cards}</div></section>`;
      }).join('');
    }

    // Boot
    initSetup();
  </script>
</SiteLayout>
