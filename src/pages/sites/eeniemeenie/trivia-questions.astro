const faqItems = [
  { q: 'How many trivia questions are included in this list?', a: 'This guide includes 300 curated trivia questions across 8 major categories.' },
  { q: 'What categories are covered?', a: 'We cover General Knowledge, Science, History, Geography, Pop Culture, Sports, Food, and Technology.' },
  { q: 'Are there different difficulty levels?', a: 'Yes, every question is marked as Easy, Medium, or Hard to help you balance your trivia night.' },
  { q: 'Can I use these for a virtual trivia night?', a: 'Absolutely! These questions are perfect for Zoom parties, family gatherings, or pub quizzes.' },
  { q: 'How do I host a successful trivia night?', a: 'Pick a good mix of categories, use a clear scoring system, and consider using a visual presentation or printed answer sheets.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

let questionCounter = 0;
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL} schema={JSON.stringify([articleSchema, faqSchema])}>
  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .category-nav {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 3rem;
      position: sticky;
      top: 60px;
      background: var(--bg-color);
      padding: 1rem 0;
      z-index: 10;
      border-bottom: 1px solid var(--border-color);
    }

    .nav-link {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.5rem 1rem;
      border-radius: 20px;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: all 0.2s;
    }

    .nav-link:hover {
      border-color: var(--accent-color);
      color: var(--accent-color);
    }

    .trivia-section {
      margin-bottom: 4rem;
    }

    .trivia-section h2 {
      color: var(--accent-color);
      border-bottom: 2px solid var(--accent-color);
      padding-bottom: 0.5rem;
      margin-bottom: 2rem;
    }

    .questions-grid {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .question-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .q-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1rem;
    }

    .q-number {
      font-weight: bold;
      color: var(--accent-color);
      font-size: 1.1rem;
    }

    .difficulty {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-weight: 600;
    }

    .difficulty.easy { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
    .difficulty.medium { background: rgba(234, 179, 8, 0.1); color: #eab308; }
    .difficulty.hard { background: rgba(239, 68, 68, 0.1); color: #ef4444; }

    .question-text {
      font-size: 1.1rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
      font-weight: 500;
    }

    .answer-box {
      background: rgba(0,0,0,0.2);
      padding: 1rem;
      border-radius: 8px;
      border-left: 4px solid var(--accent-color);
    }

    .answer-label {
      display: block;
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      margin-bottom: 0.25rem;
    }

    .answer-text {
      font-size: 1rem;
      color: var(--text-primary);
      font-weight: 600;
    }

    .guide-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2.5rem;
      margin: 4rem 0;
    }

    .guide-section h2 {
      text-align: center;
      margin-bottom: 2rem;
    }

    .guide-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .guide-item h3 {
      color: var(--accent-color);
      margin-bottom: 0.75rem;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }

    @media (max-width: 600px) {
      .category-nav {
        top: 50px;
      }
      .hero h1 {
        font-size: 2rem;
      }
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>300 Best Trivia Questions & Answers</h1>
      <p>{meta.description}</p>
    </div>

    <nav class="category-nav">
      {categories.map(cat => (
        <a href={`#${cat.id}`} class="nav-link">{cat.name}</a>
      ))}
      <a href="#hosting-guide" class="nav-link">Hosting Guide</a>
    </nav>

    {categories.map(cat => (
      <section id={cat.id} class="trivia-section">
        <h2>{cat.name}</h2>
        <div class="questions-grid">
          {cat.questions.map(q => {
            questionCounter++;
            return (
              <div class="question-card">
                <div class="q-header">
                  <span class="q-number">Question #{questionCounter}</span>
                  <span class={`difficulty ${q.difficulty.toLowerCase()}`}>{q.difficulty}</span>
                </div>
                <div class="question-text">{q.question}</div>
                <div class="answer-box">
                  <span class="answer-label">Answer</span>
                  <span class="answer-text">{q.answer}</span>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ))}

    <section id="hosting-guide" class="guide-section">
      <h2>How to Host a Flawless Trivia Night</h2>
      <div class="guide-grid">
        <div class="guide-item">
          <h3>1. Balance the Difficulty</h3>
          <p>A good trivia night has a mix of Easy, Medium, and Hard questions. Use mostly Easy/Medium to keep players engaged, and Hard questions to break ties between top teams.</p>
        </div>
        <div class="guide-item">
          <h3>2. Diverse Categories</h3>
          <p>Don't stick to one topic. Mix science with pop culture and history to ensure everyone on a team has a chance to shine with their specific knowledge.</p>
        </div>
        <div class="guide-item">
          <h3>3. Clear Rules</h3>
          <p>Decide on scoring early. Will there be partial points? Is spelling critical? Make sure all players know the rules before the first question is read.</p>
        </div>
        <div class="guide-item">
          <h3>4. The Right Pace</h3>
          <p>Give teams about 30-45 seconds to discuss and write down their answers. Read each question twice clearly before moving to the next one.</p>
        </div>
      </div>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>
