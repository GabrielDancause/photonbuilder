const faqItems = [
  { q: 'What is the game Would You Rather?', a: 'Would You Rather is a conversation game where players are given a dilemma with two difficult choices and must choose one, explaining their reasoning.' },
  { q: 'How many people can play Would You Rather?', a: 'It can be played with as few as two people or with a large group. There is no maximum player limit, making it a great party game or icebreaker.' },
  { q: 'What makes a good Would You Rather question?', a: 'A good question creates a tough dilemma where both options are equally appealing or equally terrible, sparking debate and revealing values.' },
  { q: 'Can Would You Rather be played with kids?', a: 'Absolutely! Our Kids/Family-Friendly category is specifically designed to be safe, fun, and imaginative for all ages.' },
  { q: 'Why do Would You Rather questions reveal personality?', a: 'These questions force players to prioritize their values, fears, and desires. How someone justifies their choice often reveals their logical reasoning and emotional priorities.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .games-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .game-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .game-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }

    .game-title-area {
      flex-grow: 1;
    }

    .game-title {
      font-size: 1.5rem;
      margin: 0;
      color: var(--text-primary);
    }

    .game-category {
      font-size: 0.85rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      margin-top: 0.25rem;
    }

    .game-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>{meta.title}</h1>
      <p>{meta.description}</p>
    </div>

    <div>
      <h2>Tips for Using These Questions</h2>
      <p>Would You Rather questions are incredibly versatile. Here are some of the best ways to use them:</p>
      <ul>
        <li><strong>In Games &amp; Party Settings:</strong> Take turns asking the group a question. Everyone must vote on their choice, and the minority has to take a penalty!</li>
        <li><strong>As Icebreakers:</strong> Kick off a meeting or a workshop with a lighthearted workplace question to get everyone comfortable and talking.</li>
        <li><strong>For Date Nights:</strong> Use the dating and deep questions to spark meaningful conversations and learn new things about your partner.</li>
        <li><strong>Classroom Activities:</strong> Engage students with kids and family-friendly questions to practice debate skills and critical thinking.</li>
      </ul>

      <h2>The Psychology Behind Would You Rather</h2>
      <p>Why are these questions so effective at revealing personality? When faced with a dilemma, our brains must quickly weigh risks, benefits, and core values. The choices we make often reflect our underlying fears (like choosing physical pain over public embarrassment) or our deepest desires. Even more revealing is the justification we provide for our choice, which highlights our logical reasoning and emotional priorities.</p>
    </div>

    <br />

    <div class="games-list">
      {questionsList.map((item, index) => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-title-area">
              <h2 class="game-title">Question #{index + 1}</h2>
              <div class="game-category">{item.category}</div>
            </div>
          </div>
          <p class="game-desc">{item.q}</p>
        </article>
      ))}
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>
