      {name:"Buffalo Wings",cuisine:"American",mealType:"Snack",diet:["Gluten-Free","Keto"],prepTime:40,effort:"Easy",emoji:"🍗",desc:"Crispy chicken wings tossed in spicy buffalo sauce."},
      {name:"Pancakes",cuisine:"American",mealType:"Breakfast",diet:["Vegetarian"],prepTime:15,effort:"Easy",emoji:"🥞",desc:"Fluffy buttermilk pancakes stacked high with maple syrup."},
