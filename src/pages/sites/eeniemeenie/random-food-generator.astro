      {name:"Tres Leches Cake",cuisine:"Mexican",mealType:"Dessert",diet:["Vegetarian"],prepTime:50,effort:"Medium",emoji:"🍰",desc:"Sponge cake soaked in three milks, topped with whipped cream."},
      {name:"Chilaquiles",cuisine:"Mexican",mealType:"Breakfast",diet:["Vegetarian","Gluten-Free"],prepTime:20,effort:"Easy",emoji:"🌮",desc:"Crispy tortilla chips simmered in salsa with cheese and cream."},

