      // === ITALIAN ===
      {name:"Margherita Pizza",cuisine:"Italian",mealType:"Dinner",diet:["Vegetarian"],prepTime:30,effort:"Medium",emoji:"🍕",desc:"Simple perfection: tomato, mozzarella, basil on thin crust."},
      {name:"Spaghetti Carbonara",cuisine:"Italian",mealType:"Dinner",diet:[],prepTime:25,effort:"Medium",emoji:"🍝",desc:"Pasta in a silky sauce of egg, pecorino, guanciale, and pepper."},
      {name:"Risotto",cuisine:"Italian",mealType:"Dinner",diet:["Vegetarian","Gluten-Free"],prepTime:40,effort:"Medium",emoji:"🍚",desc:"Creamy arborio rice slowly stirred with broth and parmesan."},
      {name:"Bruschetta",cuisine:"Italian",mealType:"Snack",diet:["Vegan","Dairy-Free"],prepTime:10,effort:"Easy",emoji:"🍅",desc:"Toasted bread topped with diced tomatoes, basil, and garlic."},
