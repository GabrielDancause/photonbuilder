    let currentPick = null;
    let excluded = new Set();
    let history = [];

    const STORAGE_KEY = 'foodgen_history';

    const $ = id => document.getElementById(id);

    function loadHistory() {
      try { history = JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; } catch { history = []; }
      renderHistory();
    }

    function saveHistory() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(history.slice(0, 10)));
    }

    function addToHistory(food) {
      history = [food, ...history.filter(f => f.name !== food.name)].slice(0, 10);
      saveHistory();
      renderHistory();
    }

    function renderHistory() {
      const sec = $('historySection');
      const list = $('historyList');
      if (history.length === 0) { sec.style.display = 'none'; return; }
      sec.style.display = 'block';
      list.innerHTML = history.map(f =>
        `<div class="history-item"><span class="h-emoji">${f.emoji}</span><span><span class="h-name">${f.name}</span><br><span class="h-cuisine">${f.cuisine} · ${f.mealType}</span></span></div>`
      ).join('');
    }

    function getFiltered() {
      const cuisine = $('filterCuisine').value;
      const meal = $('filterMeal').value;
      const diet = $('filterDiet').value;
      const time = $('filterTime').value;
      const effort = $('filterEffort').value;

      return FOODS.filter(f => {
        if (excluded.has(f.name)) return false;
        if (cuisine !== 'all' && f.cuisine !== cuisine) return false;
        if (meal !== 'all' && f.mealType !== meal) return false;
        if (diet !== 'all' && !f.diet.includes(diet)) return false;
        if (time !== 'any' && f.prepTime > parseInt(time)) return false;
        if (effort !== 'all' && f.effort !== effort) return false;
        return true;
      });
    }

    function showResult(food) {
      $('placeholder').style.display = 'none';
      $('noResults').style.display = 'none';
      $('resultContent').style.display = '';
      $('foodEmoji').textContent = food.emoji;
      $('foodName').textContent = food.name;
      $('foodCuisine').textContent = food.cuisine + ' · ' + food.mealType;
      $('foodDesc').textContent = food.desc;

      let tags = '';
      tags += `<span class="tag time">⏱ ${food.prepTime} min</span>`;
      const effortClass = food.effort === 'Easy' ? 'effort-easy' : food.effort === 'Medium' ? 'effort-medium' : 'effort-chef';
      tags += `<span class="tag ${effortClass}">${food.effort === 'Chef Mode' ? '👨‍🍳' : food.effort === 'Medium' ? '🔥' : '✅'} ${food.effort}</span>`;
      food.diet.forEach(d => { tags += `<span class="tag diet">${d}</span>`; });
      $('foodMeta').innerHTML = tags;

      $('resultCard').classList.add('revealed');
      $('actionBtns').style.display = 'flex';
      setTimeout(() => $('resultCard').classList.remove('revealed'), 500);
    }

    function showNoResults() {
      $('placeholder').style.display = 'none';
      $('resultContent').style.display = 'none';
      $('noResults').style.display = '';
      $('actionBtns').style.display = 'none';
    }

    async function spin() {
      const pool = getFiltered();
      if (pool.length === 0) { showNoResults(); return; }

      const btn = $('spinBtn');
      btn.disabled = true;
      $('actionBtns').style.display = 'none';

      // Spin animation
      const reel = $('spinReel');
      const reelEmoji = $('reelEmoji');
      $('placeholder').style.display = 'none';
      $('resultContent').style.display = 'none';
      $('noResults').style.display = 'none';
      reel.style.display = 'flex';
      $('resultCard').classList.add('spinning');

      const allEmojis = pool.map(f => f.emoji);
      let tick = 0;
      const totalTicks = 18;

      await new Promise(resolve => {
        const interval = setInterval(() => {
          reelEmoji.textContent = allEmojis[Math.floor(Math.random() * allEmojis.length)];
          reelEmoji.style.fontSize = (3 + Math.random())  + 'rem';
          tick++;
          if (tick >= totalTicks) { clearInterval(interval); resolve(); }
        }, 80 + tick * 8);
      });

      // Pick random
      const pick = pool[Math.floor(Math.random() * pool.length)];
      currentPick = pick;

      reel.style.display = 'none';
      $('resultCard').classList.remove('spinning');
      showResult(pick);
      addToHistory(pick);
      btn.disabled = false;
    }

    // Init
    loadHistory();

    $('spinBtn').addEventListener('click', () => { excluded.clear(); spin(); });

    $('dislikeBtn').addEventListener('click', () => {
      if (currentPick) excluded.add(currentPick.name);
      spin();
    });

    $('respinBtn').addEventListener('click', () => spin());

    $('clearHistory').addEventListener('click', () => {
      history = [];
      localStorage.removeItem(STORAGE_KEY);
      renderHistory();
    });

    $('filtersToggle').addEventListener('click', () => {
      const grid = $('filtersGrid');
      const arrow = $('filtersToggle').querySelector('.arrow');
      grid.classList.toggle('collapsed');
      arrow.classList.toggle('open');
    });

    // FAQ toggles
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('open');
        btn.nextElementSibling.classList.toggle('open');
      });
    });
  </script>
