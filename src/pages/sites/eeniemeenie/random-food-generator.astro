      // === MEXICAN ===
      {name:"Tacos al Pastor",cuisine:"Mexican",mealType:"Dinner",diet:["Dairy-Free"],prepTime:35,effort:"Medium",emoji:"🌮",desc:"Marinated pork on corn tortillas with pineapple and cilantro."},
      {name:"Guacamole & Chips",cuisine:"Mexican",mealType:"Snack",diet:["Vegan","Gluten-Free","Dairy-Free"],prepTime:10,effort:"Easy",emoji:"🥑",desc:"Chunky avocado dip with lime, cilantro, and fresh tortilla chips."},
      {name:"Chicken Burrito",cuisine:"Mexican",mealType:"Lunch",diet:[],prepTime:25,effort:"Easy",emoji:"🌯",desc:"Flour tortilla stuffed with chicken, rice, beans, and salsa."},
      {name:"Churros",cuisine:"Mexican",mealType:"Dessert",diet:["Vegetarian"],prepTime:30,effort:"Medium",emoji:"🍩",desc:"Fried dough sticks coated in cinnamon sugar with chocolate sauce."},
      {name:"Enchiladas",cuisine:"Mexican",mealType:"Dinner",diet:["Gluten-Free"],prepTime:40,effort:"Medium",emoji:"🌮",desc:"Corn tortillas rolled with chicken, smothered in red chili sauce."},
      {name:"Quesadilla",cuisine:"Mexican",mealType:"Lunch",diet:["Vegetarian"],prepTime:10,effort:"Easy",emoji:"🧀",desc:"Crispy tortilla filled with melted cheese, peppers, and onions."},
      {name:"Elote",cuisine:"Mexican",mealType:"Snack",diet:["Vegetarian","Gluten-Free"],prepTime:15,effort:"Easy",emoji:"🌽",desc:"Grilled Mexican street corn with mayo, cotija, chili, and lime."},
