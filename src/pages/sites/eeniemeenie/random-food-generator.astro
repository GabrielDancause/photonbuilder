      {name:"Tiramisu",cuisine:"Italian",mealType:"Dessert",diet:["Vegetarian"],prepTime:30,effort:"Medium",emoji:"🍰",desc:"Espresso-soaked ladyfingers layered with mascarpone cream."},
      {name:"Lasagna",cuisine:"Italian",mealType:"Dinner",diet:[],prepTime:90,effort:"Chef Mode",emoji:"🍝",desc:"Layers of pasta, rich meat ragu, bechamel, and melted cheese."},
