---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Random Food Generator: What Should I Eat?',
  description: 'Can\'t decide what to eat? Spin the random food generator! Filter by cuisine, diet, prep time, and effort. 120+ real dishes with fun slot-machine animation.',
  category: 'tool',
  published: '2026-03-29'
};

const SITE_ID = 'eeniemeenie';
const CANONICAL = 'https://eeniemeenie.photonbuilder.com/random-food-generator';

const faqItems = [
  { q: 'How does the random food generator work?', a: 'Our generator picks from a database of 120+ real dishes. Set your filters (cuisine, meal type, diet, prep time, effort) and hit the button. A slot-machine animation spins through options before landing on your meal. Don\'t like it? Hit "Try Again" to re-spin without repeats.' },
  { q: 'Can I filter for dietary restrictions?', a: 'Yes! Filter by Vegetarian, Vegan, Gluten-Free, Keto, or Dairy-Free. The generator only shows dishes matching your selected diet. Many dishes carry multiple tags, so you\'ll still get plenty of variety.' },
  { q: 'What cuisines are included?', a: 'The database covers American, Italian, Mexican, Asian, Indian, Mediterranean, Japanese, Thai, and French cuisines — over 120 dishes spanning breakfast, lunch, dinner, snacks, and desserts.' },
  { q: 'Does it remember what I\'ve been suggested?', a: 'Yes! Your last 10 picks are saved in your browser\'s local storage and displayed in the history section. Clear history anytime with one click. Nothing is sent to any server.' },
  { q: 'What if I keep getting foods I don\'t like?', a: 'Use the "I Don\'t Like That" button to exclude the current pick and re-spin. You can also narrow your filters — try selecting a specific cuisine or meal type to get more relevant suggestions.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": { "@type": "Organization", "name": "Eenie Meenie" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL} schema={JSON.stringify([articleSchema, faqSchema])}>
  <style>
    :root {
      --food-orange: #f97316;
      --food-green: #22c55e;
      --food-pink: #ec4899;
      --food-blue: #3b82f6;
      --food-yellow: #eab308;
      --food-purple: #a855f7;
    }

    .page-wrap { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }

    .hero { text-align: center; margin-bottom: 2rem; }
    .hero h1 { font-size: 2.4rem; color: var(--accent-color); margin-bottom: 0.5rem; line-height: 1.2; }
    .hero .emoji-row { font-size: 2rem; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

    /* Filters */
    .filters { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem; margin-bottom: 1.5rem; }
    .filters-title { font-size: 1rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; cursor: pointer; user-select: none; }
    .filters-title .arrow { transition: transform 0.2s; display: inline-block; }
    .filters-title .arrow.open { transform: rotate(90deg); }
    .filters-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
    .filters-grid.collapsed { display: none; }
    .filter-group label { display: block; font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 0.35rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .filter-group select { width: 100%; padding: 0.5rem; background: var(--bg-color); color: var(--text-color); border: 1px solid var(--border-color); border-radius: 8px; font-size: 0.95rem; cursor: pointer; }
    .filter-group select:focus { outline: none; border-color: var(--accent-color); }

    /* Spinner area */
    .spinner-area { text-align: center; margin-bottom: 2rem; }
    .spin-btn { background: linear-gradient(135deg, var(--food-orange), var(--food-pink)); color: #fff; border: none; padding: 1rem 2.5rem; font-size: 1.3rem; font-weight: 700; border-radius: 60px; cursor: pointer; transition: transform 0.15s, box-shadow 0.15s; box-shadow: 0 4px 20px rgba(249,115,22,0.3); }
    .spin-btn:hover { transform: scale(1.05); box-shadow: 0 6px 28px rgba(249,115,22,0.45); }
    .spin-btn:active { transform: scale(0.97); }
    .spin-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    /* Result card */
    .result-card { background: var(--card-bg); border: 2px solid var(--border-color); border-radius: 16px; padding: 2rem; margin: 1.5rem auto; max-width: 500px; text-align: center; position: relative; overflow: hidden; min-height: 220px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .result-card.spinning { border-color: var(--food-orange); }
    .result-card .food-emoji { font-size: 4rem; margin-bottom: 0.5rem; transition: transform 0.3s; }
    .result-card.revealed .food-emoji { animation: pop 0.4s ease; }
    .result-card .food-name { font-size: 1.8rem; font-weight: 800; color: var(--text-color); margin-bottom: 0.25rem; }
    .result-card .food-cuisine { font-size: 1rem; color: var(--food-orange); font-weight: 600; margin-bottom: 0.75rem; }
    .result-card .food-desc { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 1rem; max-width: 400px; }
    .result-card .food-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
    .result-card .tag { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 20px; padding: 0.25rem 0.75rem; font-size: 0.8rem; color: var(--text-secondary); }
    .result-card .tag.time { border-color: var(--food-blue); color: var(--food-blue); }
    .result-card .tag.effort-easy { border-color: var(--food-green); color: var(--food-green); }
    .result-card .tag.effort-medium { border-color: var(--food-yellow); color: var(--food-yellow); }
    .result-card .tag.effort-chef { border-color: var(--food-purple); color: var(--food-purple); }
    .result-card .tag.diet { border-color: var(--food-pink); color: var(--food-pink); }

    .result-placeholder { color: var(--text-secondary); font-size: 1.1rem; }
    .result-placeholder .big-emoji { font-size: 3rem; display: block; margin-bottom: 0.5rem; }

    /* Spin animation overlay */
    .spin-reel { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--card-bg); z-index: 2; }
    .spin-reel .reel-item { font-size: 3rem; position: absolute; animation: slotSpin 0.12s linear infinite; }

    @keyframes slotSpin {
      0% { transform: translateY(-60px); opacity: 0; }
      20% { opacity: 1; }
      80% { opacity: 1; }
      100% { transform: translateY(60px); opacity: 0; }
    }

    @keyframes pop {
      0% { transform: scale(0.3) rotate(-15deg); }
      50% { transform: scale(1.2) rotate(5deg); }
      100% { transform: scale(1) rotate(0); }
    }

    /* Action buttons */
    .action-btns { display: flex; gap: 0.75rem; justify-content: center; margin-top: 1rem; flex-wrap: wrap; }
    .btn-secondary { background: var(--card-bg); color: var(--text-color); border: 1px solid var(--border-color); padding: 0.6rem 1.25rem; border-radius: 8px; font-size: 0.95rem; cursor: pointer; transition: border-color 0.15s; }
    .btn-secondary:hover { border-color: var(--accent-color); }
    .btn-dislike { border-color: var(--food-pink); color: var(--food-pink); }
    .btn-dislike:hover { background: rgba(236,72,153,0.1); }

    .no-results { text-align: center; padding: 2rem; color: var(--text-secondary); }
    .no-results .big-emoji { font-size: 3rem; display: block; margin-bottom: 0.5rem; }

    /* History */
    .history-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem; margin-bottom: 2rem; }
    .history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .history-header h2 { font-size: 1.2rem; color: var(--text-color); margin: 0; }
    .clear-btn { background: none; border: none; color: var(--text-secondary); font-size: 0.85rem; cursor: pointer; text-decoration: underline; }
    .clear-btn:hover { color: var(--food-pink); }
    .history-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .history-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0.75rem; background: var(--bg-color); border-radius: 8px; font-size: 0.9rem; }
    .history-item .h-emoji { font-size: 1.4rem; flex-shrink: 0; }
    .history-item .h-name { font-weight: 600; color: var(--text-color); }
    .history-item .h-cuisine { color: var(--text-secondary); font-size: 0.8rem; }
    .history-empty { color: var(--text-secondary); font-size: 0.9rem; text-align: center; padding: 1rem; }

    /* FAQ */
    .faq-section { margin-top: 2.5rem; }
    .faq-section h2 { font-size: 1.5rem; color: var(--text-color); margin-bottom: 1rem; }
    .faq-item { border-bottom: 1px solid var(--border-color); }
    .faq-q { width: 100%; background: none; border: none; color: var(--text-color); font-size: 1rem; font-weight: 600; padding: 1rem 0; text-align: left; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .faq-q:hover { color: var(--accent-color); }
    .faq-q .faq-arrow { transition: transform 0.2s; font-size: 0.8rem; color: var(--text-secondary); }
    .faq-q.open .faq-arrow { transform: rotate(90deg); }
    .faq-a { padding: 0 0 1rem; color: var(--text-secondary); line-height: 1.6; display: none; }
    .faq-a.open { display: block; }

    /* Intro */
    .intro { color: var(--text-secondary); line-height: 1.7; margin-bottom: 2rem; max-width: 700px; margin-left: auto; margin-right: auto; }
    .intro h2 { color: var(--text-color); font-size: 1.3rem; margin-bottom: 0.5rem; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.7rem; }
      .filters-grid { grid-template-columns: 1fr 1fr; }
      .spin-btn { font-size: 1.1rem; padding: 0.85rem 2rem; }
      .result-card .food-name { font-size: 1.4rem; }
      .result-card { padding: 1.5rem 1rem; }
    }
  </style>

  <main class="page-wrap">
    <div style="background:rgba(224,64,251,0.08);border:1px solid rgba(224,64,251,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      🍽️ <strong style="color:#E040FB;">Americans spend 40 minutes/day deciding what to eat.</strong> That's 243 hours/year wasted on decision fatigue. With food prices up 15%, let randomness pick — then cook at home and save. <a href="https://gab.ae/news/grocery-prices-rising-raspberries-oil-costs-2026" style="color:#E040FB;">Why food costs more →</a>
    </div>
    <section class="hero">
      <div class="emoji-row">🍕 🌮 🍣 🍜 🥗</div>
      <h1>Random Food Generator</h1>
      <p>Can't decide what to eat? Let fate decide! Filter by cuisine, diet, and more — then spin for your next meal.</p>
    </section>

    <section class="filters">
      <div class="filters-title" id="filtersToggle">
        <span class="arrow open">▶</span> Filters
      </div>
      <div class="filters-grid" id="filtersGrid">
        <div class="filter-group">
          <label>Cuisine</label>
          <select id="filterCuisine">
            <option value="all">All Cuisines</option>
            <option value="American">American</option>
            <option value="Italian">Italian</option>
            <option value="Mexican">Mexican</option>
            <option value="Asian">Asian</option>
            <option value="Indian">Indian</option>
            <option value="Mediterranean">Mediterranean</option>
            <option value="Japanese">Japanese</option>
            <option value="Thai">Thai</option>
            <option value="French">French</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Meal Type</label>
          <select id="filterMeal">
            <option value="all">Any Meal</option>
            <option value="Breakfast">Breakfast</option>
            <option value="Lunch">Lunch</option>
            <option value="Dinner">Dinner</option>
            <option value="Snack">Snack</option>
            <option value="Dessert">Dessert</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Diet</label>
          <select id="filterDiet">
            <option value="all">Any Diet</option>
            <option value="Vegetarian">Vegetarian</option>
            <option value="Vegan">Vegan</option>
            <option value="Gluten-Free">Gluten-Free</option>
            <option value="Keto">Keto</option>
            <option value="Dairy-Free">Dairy-Free</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Max Prep Time</label>
          <select id="filterTime">
            <option value="any">Any</option>
            <option value="15">Under 15 min</option>
            <option value="30">Under 30 min</option>
            <option value="60">Under 60 min</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Effort</label>
          <select id="filterEffort">
            <option value="all">Any Effort</option>
            <option value="Easy">Easy</option>
            <option value="Medium">Medium</option>
            <option value="Chef Mode">Chef Mode</option>
          </select>
        </div>
      </div>
    </section>

    <section class="spinner-area">
      <button class="spin-btn" id="spinBtn">🎰 What Should I Eat?</button>

      <div class="result-card" id="resultCard">
        <div class="result-placeholder" id="placeholder">
          <span class="big-emoji">🤔</span>
          Hungry? Hit the button!
        </div>
        <div id="resultContent" style="display:none;">
          <div class="food-emoji" id="foodEmoji"></div>
          <div class="food-name" id="foodName"></div>
          <div class="food-cuisine" id="foodCuisine"></div>
          <div class="food-desc" id="foodDesc"></div>
          <div class="food-meta" id="foodMeta"></div>
        </div>
        <div id="spinReel" style="display:none;" class="spin-reel">
          <div class="reel-item" id="reelEmoji"></div>
        </div>
        <div id="noResults" style="display:none;" class="no-results">
          <span class="big-emoji">😅</span>
          No dishes match your filters. Try loosening them up!
        </div>
      </div>

      <div class="action-btns" id="actionBtns" style="display:none;">
        <button class="btn-secondary btn-dislike" id="dislikeBtn">👎 I Don't Like That</button>
        <button class="btn-secondary" id="respinBtn">🔄 Spin Again</button>
      </div>
    </section>

    <section class="history-section" id="historySection" style="display:none;">
      <div class="history-header">
        <h2>🕐 Recent Picks</h2>
        <button class="clear-btn" id="clearHistory">Clear</button>
      </div>
      <div class="history-list" id="historyList"></div>
    </section>

    <section class="intro">
      <h2>How It Works</h2>
      <p>Set your preferences using the filters above — pick a cuisine, meal type, dietary restriction, prep time, or effort level. Then hit the big button and watch the slot-machine animation spin through options. You'll land on a random dish complete with its emoji, cuisine, prep time, effort level, and dietary tags. Don't like the result? Hit "I Don't Like That" to exclude it and spin again. Your last 10 picks are saved so you can look back at your options.</p>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {faqItems.map(item => (
        <div class="faq-item">
          <button class="faq-q">{item.q} <span class="faq-arrow">▶</span></button>
          <div class="faq-a">{item.a}</div>
        </div>
      ))}
    </section>
  </main>

  <script>
    const FOODS = [
      // === AMERICAN ===
