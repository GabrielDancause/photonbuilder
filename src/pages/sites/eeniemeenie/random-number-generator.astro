      <div class="dice-buttons">
        <button class="dice-btn" data-sides="4">d4</button>
        <button class="dice-btn" data-sides="6">d6</button>
        <button class="dice-btn" data-sides="8">d8</button>
        <button class="dice-btn" data-sides="10">d10</button>
        <button class="dice-btn" data-sides="12">d12</button>
        <button class="dice-btn" data-sides="20">d20</button>
      </div>
      <div class="dice-result" id="dice-result"></div>
    </div>

    <!-- PIN Generator -->
    <div class="card">
      <h3>PIN Generator</h3>
      <p>Generate a secure random numeric PIN code.</p>
      <div class="pin-controls">
        <button class="pin-len-btn active" data-len="4">4 digits</button>
        <button class="pin-len-btn" data-len="5">5 digits</button>
        <button class="pin-len-btn" data-len="6">6 digits</button>
        <button class="pin-len-btn" data-len="8">8 digits</button>
      </div>
      <button class="mode-generate-btn" id="btn-pin">Generate PIN</button>
      <div class="pin-result" id="pin-result"></div>
    </div>

  </div>

  <!-- History -->
  <div class="card history-section">
    <h3>Generation History <span id="history-count" style="font-weight:400;color:var(--text-secondary);font-size:0.85rem;">(last 20)</span></h3>
    <div id="history-list" class="history-list">
      <div class="history-empty">No numbers generated yet.</div>
    </div>
