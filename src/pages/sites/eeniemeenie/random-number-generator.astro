    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .card h3 {
    color: var(--accent-color);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }
  .card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  /* Lottery */
  .lottery-result {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
    min-height: 42px;
  }
  .lottery-ball {
