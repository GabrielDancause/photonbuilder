  .mode-generate-btn {
    padding: 0.6rem 1.2rem;
    background: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
    width: 100%;
  }
  .mode-generate-btn:hover { opacity: 0.9; }

  /* History */
  .history-section {
    margin-top: 2rem;
    width: 100%;
  }
  .history-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 400px;
    overflow-y: auto;
  }
  .history-entry {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 1rem;
    background: var(--bg-color);
    border-radius: 8px;
    font-size: 0.85rem;
  }
  .history-nums {
    color: var(--text-primary);
    font-weight: 600;
    word-break: break-all;
  }
  .history-meta {
    color: var(--text-secondary);
    font-size: 0.75rem;
    white-space: nowrap;
    margin-left: 1rem;
  }
  .history-empty {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-style: italic;
    text-align: center;
    padding: 1rem;
  }

  /* FAQ */
  .faq-section {
    margin-top: 3rem;
    max-width: 700px;
    width: 100%;
  }
  .faq-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
  }
  .faq-q {
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--accent-color);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item.open .faq-q::after {
    content: '−';
  }
  .faq-a {
    color: var(--text-secondary);
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding-top: 0;
  }
  .faq-item.open .faq-a {
    max-height: 300px;
    padding-top: 0.75rem;
  }

  /* Related */
  .related-section {
    margin-top: 3rem;
    width: 100%;
  }
  .related-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
  }
  .related-link {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-link:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .related-link h4 { margin-bottom: 0.4rem; }
  .related-link p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; }

</style>
<div class="page-content">

<div class="hero">
  <h1>Random Number Generator</h1>
  <p>Generate truly random numbers in any range. Fast, fair, and powered by cryptographic randomness.</p>
</div>

<div class="container">

  <!-- Dice animation -->
  <div class="dice-container" id="dice-anim">
    <div class="dice-inner" id="dice-inner">
      <div class="dice-face">?</div>
    </div>
  </div>

  <!-- Result display -->
  <div class="result-area">
    <div class="result-box" id="result-box">
      <span class="result-number" id="result-placeholder" style="color:var(--text-secondary);font-size:2rem;font-weight:400;">Press Generate to start</span>
    </div>

    <!-- Generator form -->
    <div class="generator-form">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="input-min">Minimum</label>
