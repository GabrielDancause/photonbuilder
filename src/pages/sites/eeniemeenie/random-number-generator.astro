</div>
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {

  const inputMin = document.getElementById('input-min');
  const inputMax = document.getElementById('input-max');
  const inputQty = document.getElementById('input-qty');
  const btnGenerate = document.getElementById('btn-generate');
  const resultBox = document.getElementById('result-box');
  const diceAnim = document.getElementById('dice-anim');
  const diceInner = document.getElementById('dice-inner');
  const historyList = document.getElementById('history-list');

  let allowDupes = true;
  let sortResults = false;
  let parityFilter = 'any';
  let pinLength = 4;
  let history = [];
  let isGenerating = false;

  // Crypto random integer in [min, max] inclusive
  function cryptoRandInt(min, max) {
    const range = max - min + 1;
    if (range <= 0) return min;
    const arr = new Uint32Array(1);
    crypto.getRandomValues(arr);
    return min + (arr[0] % range);
  }

  // Generate numbers with current settings
  function generateNumbers() {
    if (isGenerating) return;

    const min = parseInt(inputMin.value);
    const max = parseInt(inputMax.value);
    let qty = parseInt(inputQty.value);

    if (isNaN(min) || isNaN(max) || isNaN(qty)) return;
    if (min > max) { inputMin.value = max; inputMax.value = min; return generateNumbers(); }
    if (qty < 1) qty = 1;
    if (qty > 100) qty = 100;
    inputQty.value = qty;

    // Filter available numbers by parity
    let available = [];
    if (parityFilter === 'any') {
      available = null; // use full range
    } else {
      const rangeSize = max - min + 1;
      if (rangeSize <= 200000) {
        for (let i = min; i <= max; i++) {
          if (parityFilter === 'even' && i % 2 === 0) available.push(i);
          else if (parityFilter === 'odd' && i % 2 !== 0) available.push(i);
        }
      } else {
        available = null; // fallback: generate and filter
      }
    }

    if (!allowDupes) {
      const poolSize = available ? available.length : (max - min + 1);
      if (qty > poolSize) {
        qty = poolSize;
        inputQty.value = qty;
      }
      if (qty === 0) return;
    }

    isGenerating = true;
    btnGenerate.disabled = true;

    // Show dice animation
    diceAnim.classList.add('visible');
    diceInner.classList.remove('rolling');
    void diceInner.offsetWidth;
    diceInner.classList.add('rolling');

    setTimeout(() => {
      const results = [];

      if (available && !allowDupes) {
        // Shuffle and pick from filtered pool
        const pool = [...available];
        for (let i = pool.length - 1; i > 0; i--) {
          const j = cryptoRandInt(0, i);
          [pool[i], pool[j]] = [pool[j], pool[i]];
        }
        results.push(...pool.slice(0, qty));
      } else if (!allowDupes) {
        const used = new Set();
        while (results.length < qty) {
          const n = cryptoRandInt(min, max);
          if (parityFilter === 'even' && n % 2 !== 0) continue;
          if (parityFilter === 'odd' && n % 2 === 0) continue;
          if (!used.has(n)) {
            used.add(n);
            results.push(n);
          }
        }
      } else {
        for (let i = 0; i < qty; i++) {
          let n;
          do {
            n = cryptoRandInt(min, max);
          } while (
            (parityFilter === 'even' && n % 2 !== 0) ||
            (parityFilter === 'odd' && n % 2 === 0)
          );
          results.push(n);
        }
      }

      if (sortResults) results.sort((a, b) => a - b);

      displayResults(results);
      addHistory(results, min + '–' + max);

      diceAnim.classList.remove('visible');
      isGenerating = false;
      btnGenerate.disabled = false;
    }, 850);
  }

  function displayResults(numbers) {
    resultBox.innerHTML = '';
    numbers.forEach((n, i) => {
      const span = document.createElement('span');
      span.className = 'result-number' + (numbers.length > 1 ? ' multi' : '');
      span.textContent = n;
      span.style.animationDelay = (i * 0.05) + 's';
      resultBox.appendChild(span);
      requestAnimationFrame(() => span.classList.add('animate'));
    });
  }

  function addHistory(numbers, rangeLabel) {
    history.unshift({ numbers: [...numbers], range: rangeLabel, time: new Date() });
    if (history.length > 20) history.pop();
    renderHistory();
  }

  function renderHistory() {
    if (history.length === 0) {
      historyList.innerHTML = '<div class="history-empty">No numbers generated yet.</div>';
      return;
    }
    historyList.innerHTML = history.map(entry => {
      const nums = entry.numbers.length > 10
        ? entry.numbers.slice(0, 10).join(', ') + ' … +' + (entry.numbers.length - 10) + ' more'
        : entry.numbers.join(', ');
      const time = entry.time.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      return '<div class="history-entry"><span class="history-nums">' + nums + '</span><span class="history-meta">' + entry.range + ' · ' + time + '</span></div>';
    }).join('');
  }

  // Option toggles
  document.getElementById('opt-dupes').addEventListener('click', function() {
    allowDupes = !allowDupes;
    this.classList.toggle('active', allowDupes);
  });
  document.getElementById('opt-sort').addEventListener('click', function() {
    sortResults = !sortResults;
    this.classList.toggle('active', sortResults);
  });

  // Parity toggles
  ['opt-even', 'opt-odd', 'opt-any'].forEach(id => {
    document.getElementById(id).addEventListener('click', function() {
      const val = this.querySelector('input').value;
      parityFilter = val;
      document.getElementById('opt-even').classList.toggle('active', val === 'even');
      document.getElementById('opt-odd').classList.toggle('active', val === 'odd');
      document.getElementById('opt-any').classList.toggle('active', val === 'any');
    });
  });

  // Generate button
  btnGenerate.addEventListener('click', generateNumbers);

  // Spacebar
  document.addEventListener('keydown', (e) => {
    if (e.code === 'Space' && !e.repeat && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
      e.preventDefault();
      generateNumbers();
    }
  });

  // Lottery
  document.getElementById('btn-lottery').addEventListener('click', () => {
    const nums = [];
    while (nums.length < 6) {
      const n = cryptoRandInt(1, 49);
      if (!nums.includes(n)) nums.push(n);
    }
    nums.sort((a, b) => a - b);

    const container = document.getElementById('lottery-result');
    container.innerHTML = '';
    nums.forEach((n, i) => {
      const ball = document.createElement('span');
      ball.className = 'lottery-ball';
      ball.textContent = n;
      ball.style.animationDelay = (i * 0.1) + 's';
      container.appendChild(ball);
      requestAnimationFrame(() => ball.classList.add('animate'));
    });

    addHistory(nums, 'Lottery 1–49');
  });

  // D&D Dice
  document.querySelectorAll('.dice-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const sides = parseInt(btn.dataset.sides);
      const result = cryptoRandInt(1, sides);

      diceAnim.classList.add('visible');
      diceInner.classList.remove('rolling');
      void diceInner.offsetWidth;
      diceInner.classList.add('rolling');

      const diceResultEl = document.getElementById('dice-result');
      diceResultEl.textContent = '';

      setTimeout(() => {
        diceAnim.classList.remove('visible');
        diceResultEl.textContent = 'd' + sides + ' → ' + result;
        addHistory([result], 'd' + sides);
      }, 800);
    });
  });

  // PIN Generator
  const pinLenBtns = document.querySelectorAll('.pin-len-btn');
  pinLenBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      pinLength = parseInt(btn.dataset.len);
      pinLenBtns.forEach(b => b.classList.toggle('active', b === btn));
    });
  });

  document.getElementById('btn-pin').addEventListener('click', () => {
    let pin = '';
    for (let i = 0; i < pinLength; i++) {
      pin += cryptoRandInt(0, 9).toString();
    }
    document.getElementById('pin-result').textContent = pin;
    addHistory([pin], pinLength + '-digit PIN');
  });

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement.classList.toggle('open');
    });
  });

});
</script>
</SiteLayout>
