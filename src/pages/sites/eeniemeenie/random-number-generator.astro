---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Random Number Generator — Generate Random Numbers Online', description: 'Generate truly random numbers instantly. Set min/max, generate multiple numbers, lottery picks, D&D dice rolls, and PIN codes. Uses crypto-grade randomness.', category: 'tool', published: '2026-03-21' };
const SITE_ID = 'eeniemeenie';

const faqItems = [
  { q: 'Are these random numbers truly random?', a: 'Yes. This generator uses your browser\'s crypto.getRandomValues() API, which provides cryptographically secure random numbers. This is the same source of randomness used by password managers and encryption software — far more random than Math.random() or physical dice.' },
  { q: 'Can I generate random numbers without duplicates?', a: 'Yes! Toggle off the "Allow Duplicates" option and the generator will ensure every number in your result set is unique. Note that the quantity cannot exceed the range size when duplicates are disabled — for example, you can\'t generate 10 unique numbers from a 1–5 range.' },
  { q: 'What is the maximum range I can use?', a: 'You can set minimum and maximum values anywhere from -999,999,999 to 999,999,999. The generator supports both positive and negative ranges, so you can generate numbers like -50 to 50 or 1 to 1,000,000.' },
  { q: 'How does the lottery number mode work?', a: 'The lottery mode generates 6 unique numbers from 1 to 49, sorted in ascending order — matching the format used by many popular lotteries worldwide. Each draw is completely independent and uses cryptographic randomness.' },
  { q: 'What D&D dice types are supported?', a: 'All standard polyhedral dice used in tabletop RPGs: d4 (1–4), d6 (1–6), d8 (1–8), d10 (1–10), d12 (1–12), and d20 (1–20). You can roll any of them with a single click, and results appear with a visual dice animation.' },
  { q: 'Is the PIN generator secure enough for real use?', a: 'The PINs are generated using cryptographic randomness, making them as unpredictable as possible. However, for sensitive applications like bank PINs, we recommend using your institution\'s official tools. Our generator is great for app lock codes, temporary access codes, or any situation where you need a random numeric code.' },
  { q: 'Does the generator save my history?', a: 'Your generation history is stored only in your current browser session and is never sent to any server. It resets when you reload the page. We keep the last 20 generations for your convenience.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} schema={faqSchema} canonical="https://eeniemeenie.photonbuilder.com/random-number-generator">
<style is:inline>

  .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    width: 100%;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Result display */
  .result-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }
  .result-box {
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1.5rem;
    width: 100%;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }
  .result-number {
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--accent-color);
    line-height: 1;
  }
  .result-number.multi {
    font-size: 1.8rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 0.5rem 1rem;
    min-width: 60px;
    text-align: center;
  }
  .result-number.animate {
    animation: numPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  @keyframes numPop {
    0% { transform: scale(0.3) rotateY(180deg); opacity: 0; }
    60% { transform: scale(1.1) rotateY(0deg); }
    100% { transform: scale(1) rotateY(0deg); opacity: 1; }
  }

  /* Dice animation */
  .dice-container {
    perspective: 400px;
    width: 80px;
    height: 80px;
    margin: 0 auto 1rem;
    display: none;
  }
  .dice-container.visible { display: block; }
  .dice-inner {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
  }
  .dice-inner.rolling {
    animation: diceRoll 0.8s ease-out;
  }
  @keyframes diceRoll {
    0% { transform: rotateX(0) rotateY(0) rotateZ(0); }
    25% { transform: rotateX(270deg) rotateY(180deg) rotateZ(90deg); }
    50% { transform: rotateX(540deg) rotateY(90deg) rotateZ(180deg); }
    75% { transform: rotateX(630deg) rotateY(270deg) rotateZ(270deg); }
    100% { transform: rotateX(720deg) rotateY(360deg) rotateZ(360deg); }
  }
  .dice-face {
    position: absolute;
    width: 100%;
    height: 100%;
    background: var(--card-bg);
    border: 2px solid var(--accent-color);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 900;
    color: var(--accent-color);
    backface-visibility: hidden;
  }

  /* Inputs */
  .generator-form {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    width: 100%;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .form-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }
  .form-input {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.65rem 0.75rem;
    border-radius: 6px;
    font-size: 1rem;
    font-family: var(--font-body);
    width: 100%;
    box-sizing: border-box;
  }
  .form-input:focus { outline: none; border-color: var(--accent-color); }

  /* Options toggles */
  .options-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .option-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
