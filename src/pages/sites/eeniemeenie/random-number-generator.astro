---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Random Number Generator', description: 'Need a fast, unpredictable number? Our random number generator reveals exactly what you need in seconds.', category: 'tools', published: '2026-03-15' };
const SITE_ID = 'eeniemeenie';
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID}>
<style is:inline>

  .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    width: 100%;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  .rng-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .toggle-group {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }
  .toggle-label {
    display: flex;
    align-items: center;
    cursor: pointer;
    gap: 0.5rem;
    color: var(--text-primary);
  }
  .toggle-label input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--accent-color);
  }
  .btn-primary {
    display: block;
    width: 100%;
    padding: 1rem;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
  }
  .btn-primary:hover {
    opacity: 0.9;
  }
  .btn-primary:active {
    transform: scale(0.98);
  }
  .result-area {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
  }
  .result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .btn-icon {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-icon:hover {
    color: var(--accent-color);
    border-color: var(--accent-color);
  }
  .rng-result-display {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--accent-color);
    word-break: break-all;
    min-height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rng-result-display.animate {
    animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  @keyframes popIn {
    0% { transform: scale(0.8); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  .history-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
  }
  .history-card h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.2rem;
    color: var(--text-primary);
  }
  .history-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .history-list li {
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-family: var(--font-mono);
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

</style>
<div class="page-content">

<div class="hero">
  <h1>Random Number Generator</h1>
  <p>Generate truly random numbers instantly with customizable ranges.</p>
</div>

<div class="container">
  <div class="calculator-card">
    <div class="rng-grid">
      <div class="input-group">
        <label for="rng-min">Minimum Value</label>
        <div class="input-wrapper">
          <input type="number" id="rng-min" value="1">
        </div>
      </div>

      <div class="input-group">
        <label for="rng-max">Maximum Value</label>
        <div class="input-wrapper">
          <input type="number" id="rng-max" value="100">
        </div>
      </div>

      <div class="input-group">
        <label for="rng-qty">Quantity (1-100)</label>
        <div class="input-wrapper">
          <input type="number" id="rng-qty" value="1" min="1" max="100">
        </div>
      </div>
    </div>

    <div class="toggle-group">
      <label class="toggle-label">
        <input type="checkbox" id="rng-decimal">
        <span class="toggle-text">Allow Decimals</span>
      </label>
    </div>

    <button id="btn-generate" class="btn-primary">Generate Number</button>

    <div class="result-area" style="display: none;" id="result-container">
      <div class="result-header">
        <span class="calc-result-label">Result:</span>
        <button id="btn-copy" class="btn-icon" aria-label="Copy">Copy</button>
      </div>
      <div id="rng-result" class="rng-result-display"></div>
    </div>
  </div>

  <div class="history-card" style="display: none;" id="history-container">
    <h3>Recent History</h3>
    <ul id="rng-history" class="history-list"></ul>
  </div>
</div>

</div>
<script is:inline>

  document.addEventListener('DOMContentLoaded', () => {
    const minInput = document.getElementById('rng-min');
    const maxInput = document.getElementById('rng-max');
    const qtyInput = document.getElementById('rng-qty');
    const decimalToggle = document.getElementById('rng-decimal');
    const btnGenerate = document.getElementById('btn-generate');
    const btnCopy = document.getElementById('btn-copy');
    const resultContainer = document.getElementById('result-container');
    const resultDisplay = document.getElementById('rng-result');
    const historyContainer = document.getElementById('history-container');
    const historyList = document.getElementById('rng-history');

    let history = [];

    function generate() {
      const min = parseFloat(minInput.value);
      const max = parseFloat(maxInput.value);
      let qty = parseInt(qtyInput.value, 10);
      const allowDecimals = decimalToggle.checked;

      if (isNaN(min) || isNaN(max) || isNaN(qty)) return;

      if (min > max) {
        resultDisplay.textContent = 'Min > Max';
        resultContainer.style.display = 'block';
        return;
      }

      if (qty < 1) qty = 1;
      if (qty > 100) qty = 100;

      const results = [];
      for (let i = 0; i < qty; i++) {
        let val;
        if (allowDecimals) {
          val = Math.random() * (max - min) + min;
          val = parseFloat(val.toFixed(4));
        } else {
          const minInt = Math.ceil(min);
          const maxInt = Math.floor(max);
          val = Math.floor(Math.random() * (maxInt - minInt + 1)) + minInt;
        }
        results.push(val);
      }

      const resultString = results.join(', ');

      // Update UI
      resultContainer.style.display = 'block';

      // Animation trigger
      resultDisplay.classList.remove('animate');
      void resultDisplay.offsetWidth; // Force reflow
      resultDisplay.classList.add('animate');

      resultDisplay.textContent = resultString;

      // Update history
      history.unshift(resultString);
      if (history.length > 10) history.pop();
      updateHistoryUI();
    }

    function updateHistoryUI() {
      if (history.length > 0) {
        historyContainer.style.display = 'block';
        historyList.innerHTML = history.map(item => `<li>${item}</li>`).join('');
      }
    }

    btnGenerate.addEventListener('click', generate);

    btnCopy.addEventListener('click', () => {
      const text = resultDisplay.textContent;
      if (!text || text === 'Min > Max') return;

      navigator.clipboard.writeText(text).then(() => {
        const originalText = btnCopy.textContent;
        btnCopy.textContent = 'Copied!';
        setTimeout(() => {
          btnCopy.textContent = originalText;
        }, 2000);
      });
    });
  });

</script>
</SiteLayout>
