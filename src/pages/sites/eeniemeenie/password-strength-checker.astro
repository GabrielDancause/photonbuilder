---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Password Strength Checker — Test How Strong Your Password Is', description: 'Check your password strength instantly. See entropy bits, estimated crack time, pattern warnings, and character analysis. Generate secure passwords. 100% client-side — nothing is ever transmitted.', category: 'tool', published: '2026-03-21' };
const SITE_ID = 'eeniemeenie';

const faqItems = [
  { q: 'Is it safe to type my password here?', a: 'Absolutely. This tool runs entirely in your browser using JavaScript. Your password never leaves your device — it is not sent to any server, stored in any database, or logged anywhere. You can verify this by disconnecting from the internet and using the tool offline.' },
  { q: 'How is password entropy calculated?', a: 'Entropy is measured in bits and represents the number of possible combinations an attacker would need to try. It\'s calculated as log₂(pool_size^length), where pool size is the number of unique character types used (lowercase = 26, uppercase = 26, digits = 10, symbols = 33). A password with 60+ bits of entropy is considered strong.' },
  { q: 'What makes a password weak?', a: 'Common weaknesses include: short length (under 10 characters), using only one character type, dictionary words, keyboard patterns like "qwerty", repeated characters like "aaa", predictable substitutions like "@" for "a" (l33t speak), and personal information like dates or names. Our checker detects all of these patterns.' },
  { q: 'How accurate are the crack time estimates?', a: 'Our estimates are based on two scenarios: brute force (trying every combination) at 10 billion guesses per second (modern GPU cluster), and dictionary/rule-based attacks at 1 billion guesses per second. Real-world times vary based on the attacker\'s hardware, but these give a realistic ballpark for a well-resourced attacker.' },
  { q: 'What length should my password be?', a: 'We recommend at least 14 characters using a mix of uppercase, lowercase, numbers, and symbols. Better yet, use a passphrase of 4–5 random words (20+ characters). Length is the single most important factor in password strength — each additional character exponentially increases the time needed to crack it.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Password Strength Checker",
  "url": "https://eeniemeenie.photonbuilder.com/password-strength-checker",
  "applicationCategory": "SecurityApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": meta.description
};

const combinedSchema = [appSchema, faqSchema];
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical="https://eeniemeenie.photonbuilder.com/password-strength-checker" schema={combinedSchema}>
<style is:inline>

  .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    width: 100%;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Password input */
  .password-input-wrap {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }
  .password-input {
    width: 100%;
    padding: 1rem 3.5rem 1rem 1rem;
    font-size: 1.2rem;
    font-family: monospace;
    background: var(--card-bg);
    border: 2px solid var(--border-color);
    color: var(--text-primary);
    border-radius: 10px;
    box-sizing: border-box;
    transition: border-color 0.3s;
  }
  .password-input:focus { outline: none; border-color: var(--accent-color); }
  .toggle-visibility {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 1.3rem;
    padding: 0.25rem;
  }
  .toggle-visibility:hover { color: var(--text-primary); }

  /* Strength meter */
  .strength-meter {
    width: 100%;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }
  .meter-bar-track {
    width: 100%;
    height: 8px;
    background: var(--border-color);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  .meter-bar-fill {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: width 0.4s ease, background 0.4s ease;
  }
  .meter-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .meter-strength {
    font-weight: 800;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .meter-entropy {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  /* Analysis cards */
  .analysis-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    width: 100%;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 500px) {
    .analysis-grid { grid-template-columns: 1fr; }
  }
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .card h3 {
    color: var(--accent-color);
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .card-full { grid-column: 1 / -1; }

  /* Crack time */
  .crack-row {
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.9rem;
  }
  .crack-row:last-child { border-bottom: none; }
  .crack-label { color: var(--text-secondary); }
  .crack-value { font-weight: 700; color: var(--text-primary); }

  /* Composition */
  .comp-bar-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
  }
  .comp-bar-row:last-child { margin-bottom: 0; }
  .comp-label { width: 80px; color: var(--text-secondary); flex-shrink: 0; }
  .comp-track {
    flex: 1;
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    overflow: hidden;
  }
  .comp-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--accent-color);
    transition: width 0.3s;
  }
  .comp-count { width: 28px; text-align: right; color: var(--text-primary); font-weight: 600; }

  /* Warnings */
  .warnings-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .warnings-list li {
    padding: 0.4rem 0;
    font-size: 0.88rem;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .warn-icon { flex-shrink: 0; }
  .warn-icon.bad { color: #ef4444; }
  .warn-icon.tip { color: #f59e0b; }
  .no-warnings { color: var(--text-secondary); font-size: 0.88rem; font-style: italic; }

  /* Suggestions */
  .suggestions-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .suggestions-list li {
    padding: 0.35rem 0;
    font-size: 0.88rem;
    color: var(--text-secondary);
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .sug-icon { color: #22c55e; flex-shrink: 0; }
  .no-suggestions { color: var(--text-secondary); font-size: 0.88rem; font-style: italic; }

  /* Generator */
  .generator-section {
    width: 100%;
    max-width: 600px;
    margin-top: 1rem;
    margin-bottom: 2rem;
  }
  .gen-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .gen-length-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    margin-bottom: 0.5rem;
  }
  .gen-length-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    width: 90px;
    flex-shrink: 0;
  }
  .gen-slider {
    flex: 1;
    accent-color: var(--accent-color);
  }
  .gen-length-val {
    font-weight: 700;
    color: var(--accent-color);
    min-width: 28px;
    text-align: center;
  }
  .option-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
  }
  .option-toggle:hover { border-color: var(--accent-color); color: var(--text-primary); }
  .option-toggle.active { border-color: var(--accent-color); color: var(--accent-color); background: rgba(224, 64, 251, 0.08); }
  .option-toggle input { display: none; }

  .gen-output-wrap {
    position: relative;
    margin-bottom: 1rem;
  }
  .gen-output {
    width: 100%;
    padding: 0.8rem 3rem 0.8rem 1rem;
    font-family: monospace;
    font-size: 1.1rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--accent-color);
    border-radius: 8px;
    box-sizing: border-box;
    font-weight: 700;
    letter-spacing: 1px;
  }
  .gen-output:focus { outline: none; }
  .copy-btn {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.3rem;
  }
  .copy-btn:hover { color: var(--accent-color); }
  .btn-primary {
    padding: 0.8rem 2rem;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    letter-spacing: 1px;
    text-transform: uppercase;
    width: 100%;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:active { transform: scale(0.97); }

  /* Privacy badge */
  .privacy-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.25);
    border-radius: 6px;
    font-size: 0.8rem;
    color: #22c55e;
    margin-bottom: 1.5rem;
  }

  /* Empty state */
  .empty-state {
    color: var(--text-secondary);
    font-size: 0.95rem;
    text-align: center;
    padding: 1rem 0;
  }

  /* FAQ */
  .faq-section {
    margin-top: 3rem;
    max-width: 700px;
    width: 100%;
  }
  .faq-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
  }
  .faq-q {
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--accent-color);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item.open .faq-q::after {
    content: '−';
  }
  .faq-a {
    color: var(--text-secondary);
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding-top: 0;
  }
  .faq-item.open .faq-a {
    max-height: 300px;
    padding-top: 0.75rem;
  }

</style>
<div class="page-content">

<div class="hero">
  <h1>Password Strength Checker</h1>
  <p>Type a password to see real-time strength analysis with entropy, crack time estimates, and pattern warnings. Everything runs locally — nothing is ever transmitted.</p>
</div>

<div class="container">

  <div class="privacy-badge">&#128274; 100% client-side — your password never leaves this device</div>

  <!-- Password input -->
  <div class="password-input-wrap">
    <input type="password" class="password-input" id="pw-input" placeholder="Type a password to check…" autocomplete="off" spellcheck="false">
    <button class="toggle-visibility" id="toggle-vis" title="Toggle visibility">&#128065;</button>
  </div>

  <!-- Strength meter -->
  <div class="strength-meter" id="strength-meter" style="display:none;">
    <div class="meter-bar-track">
      <div class="meter-bar-fill" id="meter-fill"></div>
    </div>
    <div class="meter-label">
      <span class="meter-strength" id="meter-text">—</span>
      <span class="meter-entropy" id="meter-entropy">0 bits of entropy</span>
    </div>
  </div>

  <!-- Analysis -->
  <div class="analysis-grid" id="analysis" style="display:none;">

    <div class="card">
      <h3>Crack Time</h3>
      <div id="crack-times">
        <div class="crack-row"><span class="crack-label">Brute Force</span><span class="crack-value" id="ct-brute">—</span></div>
        <div class="crack-row"><span class="crack-label">Dictionary Attack</span><span class="crack-value" id="ct-dict">—</span></div>
      </div>
    </div>

    <div class="card">
      <h3>Composition</h3>
      <div id="composition">
        <div class="comp-bar-row"><span class="comp-label">Lowercase</span><div class="comp-track"><div class="comp-fill" id="comp-lower"></div></div><span class="comp-count" id="cnt-lower">0</span></div>
        <div class="comp-bar-row"><span class="comp-label">Uppercase</span><div class="comp-track"><div class="comp-fill" id="comp-upper"></div></div><span class="comp-count" id="cnt-upper">0</span></div>
        <div class="comp-bar-row"><span class="comp-label">Digits</span><div class="comp-track"><div class="comp-fill" id="comp-digit"></div></div><span class="comp-count" id="cnt-digit">0</span></div>
        <div class="comp-bar-row"><span class="comp-label">Symbols</span><div class="comp-track"><div class="comp-fill" id="comp-symbol"></div></div><span class="comp-count" id="cnt-symbol">0</span></div>
      </div>
    </div>

    <div class="card card-full">
      <h3>Warnings &amp; Patterns</h3>
      <div id="warnings-area"><p class="empty-state">Enter a password to see analysis</p></div>
    </div>

    <div class="card card-full">
      <h3>Suggestions</h3>
      <div id="suggestions-area"><p class="empty-state">Enter a password to see suggestions</p></div>
    </div>

  </div>

  <!-- Password generator -->
  <div class="generator-section">
    <div class="card">
      <h3>Secure Password Generator</h3>
      <div class="gen-length-wrap">
        <span class="gen-length-label">Length</span>
        <input type="range" class="gen-slider" id="gen-length" min="8" max="64" value="20">
        <span class="gen-length-val" id="gen-length-val">20</span>
      </div>
      <div class="gen-options">
        <label class="option-toggle active" id="opt-upper"><input type="checkbox" checked> Uppercase</label>
        <label class="option-toggle active" id="opt-lower"><input type="checkbox" checked> Lowercase</label>
        <label class="option-toggle active" id="opt-digits"><input type="checkbox" checked> Numbers</label>
        <label class="option-toggle active" id="opt-symbols"><input type="checkbox" checked> Symbols</label>
      </div>
      <div class="gen-output-wrap">
        <input type="text" class="gen-output" id="gen-output" readonly>
        <button class="copy-btn" id="copy-btn" title="Copy to clipboard">&#128203;</button>
      </div>
      <button class="btn-primary" id="btn-generate">Generate Password</button>
    </div>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {faqItems.map(item => (
      <div class="faq-item">
        <div class="faq-q">{item.q}</div>
        <div class="faq-a">{item.a}</div>
      </div>
    ))}
  </div>

</div>
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {

  const pwInput = document.getElementById('pw-input');
  const toggleVis = document.getElementById('toggle-vis');
  const meterEl = document.getElementById('strength-meter');
  const meterFill = document.getElementById('meter-fill');
  const meterText = document.getElementById('meter-text');
  const meterEntropy = document.getElementById('meter-entropy');
  const analysisEl = document.getElementById('analysis');

  // Toggle password visibility
  toggleVis.addEventListener('click', () => {
    const isPassword = pwInput.type === 'password';
    pwInput.type = isPassword ? 'text' : 'password';
    toggleVis.innerHTML = isPassword ? '&#128064;' : '&#128065;';
  });

  // Real-time analysis
  pwInput.addEventListener('input', () => {
    const pw = pwInput.value;
    if (!pw) {
      meterEl.style.display = 'none';
      analysisEl.style.display = 'none';
      return;
    }
    meterEl.style.display = '';
    analysisEl.style.display = '';
    analyze(pw);
  });

  function analyze(pw) {
    const len = pw.length;

    // Character counts
    let lower = 0, upper = 0, digit = 0, symbol = 0;
    for (let i = 0; i < len; i++) {
      const c = pw[i];
      if (/[a-z]/.test(c)) lower++;
      else if (/[A-Z]/.test(c)) upper++;
      else if (/[0-9]/.test(c)) digit++;
      else symbol++;
    }

    // Pool size
    let pool = 0;
    if (lower > 0) pool += 26;
    if (upper > 0) pool += 26;
    if (digit > 0) pool += 10;
    if (symbol > 0) pool += 33;
    if (pool === 0) pool = 26;

    // Entropy
    const entropy = Math.floor(len * Math.log2(pool));

    // Strength rating
    let strength, color, pct;
    if (entropy < 25) { strength = 'Terrible'; color = '#ef4444'; pct = 10; }
    else if (entropy < 40) { strength = 'Weak'; color = '#f97316'; pct = 25; }
    else if (entropy < 60) { strength = 'Fair'; color = '#f59e0b'; pct = 50; }
    else if (entropy < 80) { strength = 'Strong'; color = '#22c55e'; pct = 75; }
    else { strength = 'Excellent'; color = '#10b981'; pct = 100; }

    // Update meter
    meterFill.style.width = pct + '%';
    meterFill.style.background = color;
    meterText.textContent = strength;
    meterText.style.color = color;
    meterEntropy.textContent = entropy + ' bits of entropy';

    // Composition bars
    updateComp('lower', lower, len);
    updateComp('upper', upper, len);
    updateComp('digit', digit, len);
    updateComp('symbol', symbol, len);

    // Crack times
    const bruteCombs = Math.pow(pool, len);
    const guessesPerSecBrute = 1e10;
    const guessesPerSecDict = 1e9;
    // Dictionary attack assumes reduced search space
    const dictFactor = Math.max(1, detectDictWeakness(pw));
    const dictCombs = bruteCombs / dictFactor;

    document.getElementById('ct-brute').textContent = formatTime(bruteCombs / guessesPerSecBrute);
    document.getElementById('ct-dict').textContent = formatTime(dictCombs / guessesPerSecDict);

    // Warnings
    const warnings = detectPatterns(pw);
    const warningsArea = document.getElementById('warnings-area');
    if (warnings.length === 0) {
      warningsArea.innerHTML = '<p class="no-warnings">No common patterns detected.</p>';
    } else {
      warningsArea.innerHTML = '<ul class="warnings-list">' + warnings.map(w =>
        '<li><span class="warn-icon bad">&#9888;</span>' + w + '</li>'
      ).join('') + '</ul>';
    }

    // Suggestions
    const suggestions = getSuggestions(pw, lower, upper, digit, symbol, len, entropy);
    const sugArea = document.getElementById('suggestions-area');
    if (suggestions.length === 0) {
      sugArea.innerHTML = '<p class="no-suggestions">Your password looks great!</p>';
    } else {
      sugArea.innerHTML = '<ul class="suggestions-list">' + suggestions.map(s =>
        '<li><span class="sug-icon">&#10003;</span>' + s + '</li>'
      ).join('') + '</ul>';
    }
  }

  function updateComp(type, count, total) {
    const pct = total > 0 ? (count / total * 100) : 0;
    document.getElementById('comp-' + type).style.width = pct + '%';
    document.getElementById('cnt-' + type).textContent = count;
  }

  function formatTime(seconds) {
    if (!isFinite(seconds) || seconds > 1e18) return 'centuries+';
    if (seconds < 0.001) return 'instant';
    if (seconds < 1) return 'less than a second';
    if (seconds < 60) return Math.floor(seconds) + ' seconds';
    if (seconds < 3600) return Math.floor(seconds / 60) + ' minutes';
    if (seconds < 86400) return Math.floor(seconds / 3600) + ' hours';
    if (seconds < 31536000) return Math.floor(seconds / 86400) + ' days';
    if (seconds < 31536000 * 100) return Math.floor(seconds / 31536000) + ' years';
    if (seconds < 31536000 * 1e6) return Math.floor(seconds / 31536000).toLocaleString() + ' years';
    if (seconds < 31536000 * 1e9) return Math.floor(seconds / (31536000 * 1e6)).toLocaleString() + ' million years';
    return 'centuries+';
  }

  function detectDictWeakness(pw) {
    let factor = 1;
    const lower = pw.toLowerCase();
    // Common words check
    const commonWords = ['password','123456','qwerty','admin','welcome','letmein','monkey','dragon','master','login','abc123','trustno1','iloveyou','sunshine','princess','football','shadow','superman','michael','jennifer','charlie','robert','thomas','jessica','pepper','ginger','ranger','buster','soccer','hockey','hunter','andrew','joshua','daniel'];
    for (const word of commonWords) {
      if (lower.includes(word)) { factor *= 1e6; break; }
    }
    // L33t speak
    const l33t = lower.replace(/[@4]/g, 'a').replace(/[3]/g, 'e').replace(/[1!|]/g, 'i').replace(/[0]/g, 'o').replace(/[5$]/g, 's').replace(/[7]/g, 't');
    if (l33t !== lower) {
      for (const word of commonWords) {
        if (l33t.includes(word)) { factor *= 1e4; break; }
      }
    }
    return factor;
  }

  function detectPatterns(pw) {
    const warnings = [];
    const len = pw.length;
    if (len < 6) return ['Extremely short password — easily cracked.'];

    // Keyboard walks
    const walks = ['qwerty','qwertz','azerty','asdf','zxcv','1234','2345','3456','4567','5678','6789','7890','0987','9876','8765','7654','6543','5432','4321'];
    const lower = pw.toLowerCase();
    for (const walk of walks) {
      if (lower.includes(walk)) {
        warnings.push('Contains keyboard walk pattern: "' + walk + '"');
        break;
      }
    }

    // Repeated characters (3+)
    if (/(.)\1{2,}/.test(pw)) {
      warnings.push('Contains repeated characters (e.g., "aaa")');
    }

    // Sequential letters (3+)
    let seqCount = 0;
    for (let i = 1; i < len; i++) {
      if (pw.charCodeAt(i) === pw.charCodeAt(i - 1) + 1) {
        seqCount++;
        if (seqCount >= 2) {
          warnings.push('Contains sequential characters (e.g., "abc", "123")');
          break;
        }
      } else {
        seqCount = 0;
      }
    }

    // Date patterns
    if (/(?:19|20)\d{2}/.test(pw)) {
      warnings.push('Contains a year pattern (e.g., "1990", "2024")');
    }
    if (/\d{1,2}[\/\-\.]\d{1,2}[\/\-\.]\d{2,4}/.test(pw)) {
      warnings.push('Contains a date pattern');
    }

    // L33t speak
    const l33tMap = { '@': 'a', '4': 'a', '3': 'e', '1': 'i', '!': 'i', '0': 'o', '5': 's', '$': 's', '7': 't' };
    let hasL33t = false;
    for (const c of pw) {
      if (l33tMap[c]) { hasL33t = true; break; }
    }
    if (hasL33t) {
      warnings.push('Uses l33t speak substitutions — attackers check these automatically');
    }

    // All same case
    if (pw === pw.toLowerCase() && /[a-z]/.test(pw) && !/[0-9]/.test(pw) && !/[^a-zA-Z0-9]/.test(pw)) {
      warnings.push('Only lowercase letters — very limited character pool');
    }
    if (pw === pw.toUpperCase() && /[A-Z]/.test(pw) && !/[0-9]/.test(pw) && !/[^a-zA-Z0-9]/.test(pw)) {
      warnings.push('Only uppercase letters — very limited character pool');
    }

    // All digits
    if (/^\d+$/.test(pw)) {
      warnings.push('Only digits — extremely small character pool');
    }

    // Common passwords (full match)
    const commonFull = ['password','123456','12345678','qwerty','abc123','monkey','1234567','letmein','trustno1','dragon','baseball','iloveyou','master','sunshine','ashley','bailey','passw0rd','shadow','123123','654321','superman','qazwsx','michael','football','password1','password123','admin','welcome'];
    if (commonFull.includes(lower)) {
      warnings.push('This is one of the most commonly used passwords');
    }

    return warnings;
  }

  function getSuggestions(pw, lower, upper, digit, symbol, len, entropy) {
    const suggestions = [];
    if (len < 14) suggestions.push('Increase length to at least 14 characters');
    if (lower === 0) suggestions.push('Add lowercase letters (a-z)');
    if (upper === 0) suggestions.push('Add uppercase letters (A-Z)');
    if (digit === 0) suggestions.push('Add numbers (0-9)');
    if (symbol === 0) suggestions.push('Add symbols (!@#$%^&*)');
    if (len >= 14 && entropy < 60) suggestions.push('Use more varied character types');
    if (/(.)\1{2,}/.test(pw)) suggestions.push('Avoid repeated characters');
    if (entropy < 40) suggestions.push('Consider using a random passphrase of 4–5 words');
    return suggestions;
  }

  // ---- Password Generator ----
  const genLength = document.getElementById('gen-length');
  const genLengthVal = document.getElementById('gen-length-val');
  const genOutput = document.getElementById('gen-output');
  const copyBtn = document.getElementById('copy-btn');
  const btnGenerate = document.getElementById('btn-generate');

  const genToggles = {
    upper: { el: document.getElementById('opt-upper'), active: true, chars: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ' },
    lower: { el: document.getElementById('opt-lower'), active: true, chars: 'abcdefghijklmnopqrstuvwxyz' },
    digits: { el: document.getElementById('opt-digits'), active: true, chars: '0123456789' },
    symbols: { el: document.getElementById('opt-symbols'), active: true, chars: '!@#$%^&*()_+-=[]{}|;:,.<>?' }
  };

  genLength.addEventListener('input', () => {
    genLengthVal.textContent = genLength.value;
  });

  Object.keys(genToggles).forEach(key => {
    genToggles[key].el.addEventListener('click', () => {
      const t = genToggles[key];
      t.active = !t.active;
      t.el.classList.toggle('active', t.active);
      // Ensure at least one is active
      const anyActive = Object.values(genToggles).some(v => v.active);
      if (!anyActive) {
        t.active = true;
        t.el.classList.add('active');
      }
    });
  });

  function generatePassword() {
    let charset = '';
    Object.values(genToggles).forEach(t => { if (t.active) charset += t.chars; });
    if (!charset) charset = 'abcdefghijklmnopqrstuvwxyz';
    const length = parseInt(genLength.value);
    const arr = new Uint32Array(length);
    crypto.getRandomValues(arr);
    let result = '';
    for (let i = 0; i < length; i++) {
      result += charset[arr[i] % charset.length];
    }
    genOutput.value = result;
  }

  btnGenerate.addEventListener('click', generatePassword);

  copyBtn.addEventListener('click', () => {
    if (!genOutput.value) return;
    navigator.clipboard.writeText(genOutput.value).then(() => {
      copyBtn.innerHTML = '&#10003;';
      setTimeout(() => { copyBtn.innerHTML = '&#128203;'; }, 1500);
    });
  });

  // Generate initial password
  generatePassword();

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement.classList.toggle('open');
    });
  });

});
</script>
</SiteLayout>
