---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: '200+ Best Charades Ideas & Complete Guide',
  description: 'The ultimate charades guide with 200 ideas by category, rules, acting tips, and variations for kids, adults, and virtual parties.',
  category: 'guide',
  published: '2024-05-20'
};

const SITE_ID = 'eeniemeenie';
const CANONICAL = 'https://eeniemeenie.photonbuilder.com/charades-guide';

const categories = [
  {
    name: "Movies",
    ideas: ["Titanic", "Jurassic Park", "Star Wars", "Jaws", "The Lion King", "Toy Story", "Frozen", "The Matrix", "Pulp Fiction", "Forrest Gump", "Back to the Future", "Ghostbusters", "The Wizard of Oz", "Home Alone", "Harry Potter", "Indiana Jones", "The Avengers", "Spider-Man", "Batman", "Shrek", "Finding Nemo", "Up", "Inception", "Pirates of the Caribbean", "Gladiator", "Braveheart", "The Godfather", "Psycho", "E.T.", "The Sound of Music"]
  },
  {
    name: "TV Shows",
    ideas: ["Friends", "Game of Thrones", "Breaking Bad", "Stranger Things", "The Office", "The Simpsons", "SpongeBob SquarePants", "The Big Bang Theory", "Seinfeld", "Grey's Anatomy", "The Walking Dead", "Lost", "House", "Sherlock", "Black Mirror", "The Mandalorian", "Squid Game", "Ted Lasso", "Succession", "The Crown", "Parks and Recreation", "Brooklyn Nine-Nine", "Modern Family", "How I Met Your Mother", "Glee", "Saturday Night Live", "Jeopardy!", "Wheel of Fortune", "The Bachelor", "Survivor"]
  },
  {
    name: "Songs",
    ideas: ["Baby Shark", "Bohemian Rhapsody", "Thriller", "Shake It Off", "Rolling in the Deep", "Despacito", "Uptown Funk", "Stayin' Alive", "Y.M.C.A.", "Single Ladies", "Happy", "Let It Go", "Old Town Road", "Blinding Lights", "Poker Face", "Billie Jean", "Like a Virgin", "Wonderwall", "Smells Like Teen Spirit", "Hey Jude", "Imagine", "Eye of the Tiger", "Girls Just Want to Have Fun", "I Will Always Love You", "My Heart Will Go On", "Waka Waka", "Gangnam Style", "Hotline Bling", "Shape of You", "Firework"]
  },
  {
    name: "Books",
    ideas: ["Harry Potter", "The Hobbit", "Twilight", "The Hunger Games", "The Great Gatsby", "To Kill a Mockingbird", "1984", "Animal Farm", "Pride and Prejudice", "Little Women", "The Catcher in the Rye", "Romeo and Juliet", "Moby Dick", "Treasure Island", "Alice in Wonderland", "Peter Pan", "Pinocchio", "The Cat in the Hat", "Green Eggs and Ham", "Charlie and the Chocolate Factory", "Matilda", "The Chronicles of Narnia", "A Game of Thrones", "The Da Vinci Code", "Fifty Shades of Grey", "Gone Girl", "The Fault in Our Stars", "Life of Pi", "Frankenstein", "Dracula"]
  },
  {
    name: "Animals",
    ideas: ["Elephant", "Giraffe", "Kangaroo", "Penguin", "Snake", "Lion", "Monkey", "Shark", "Butterfly", "Frog", "Bat", "Owl", "Cat", "Dog", "Horse", "Cow", "Pig", "Chicken", "Bee", "Spider", "Crab", "Dolphin", "Whale", "Bear", "Rabbit", "Squirrel", "Turtle", "Octopus", "Flamingo", "Zebra"]
  },
  {
    name: "Actions",
    ideas: ["Brushing teeth", "Tying shoes", "Driving a car", "Playing tennis", "Flipping a pancake", "Taking a selfie", "Mowing the lawn", "Flying a kite", "Opening a gift", "Blowing out candles", "Painting a picture", "Sewing", "Reading a book", "Swimming", "Fishing", "Bowling", "Skiing", "Surfing", "Yoga", "Ironing clothes", "Washing dishes", "Vacuuming", "Rock climbing", "Bungee jumping", "Tightrope walking", "Scuba diving", "Archery", "Baking a cake", "Changing a diaper", "Walking a dog"]
  },
  {
    name: "Kids Edition",
    ideas: ["Superman", "Mickey Mouse", "Elsa", "Pikachu", "Iron Man", "Mario", "Harry Potter", "Cinderella", "Buzz Lightyear", "Winnie the Pooh", "Dinosaur", "Astronaut", "Pirate", "Firefighter", "Doctor", "Teacher", "Robot", "Ghost", "Witch", "Ninja"]
  }
];

const faqItems = [
  { q: 'What are the basic rules of charades?', a: 'Players must act out a word or phrase without speaking while their team tries to guess it within a time limit.' },
  { q: 'Can you use props in charades?', a: 'Standard rules prohibit props or pointing at objects in the room, focusing entirely on body movements and gestures.' },
  { q: 'What is reverse charades?', a: 'In reverse charades, the whole team acts out the clue for one person to guess, rather than one person acting for the whole team.' },
  { q: 'How do you play charades virtually?', a: 'Use a random word generator and send the clue via private message to the actor. The rest of the rules remain the same over a video call.' },
  { q: 'What are common signals in charades?', a: 'Common signals include holding up fingers for the number of words, tugging an earlobe for "sounds like," and "chopping" your arm to indicate a shorter version of a word.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL} schema={JSON.stringify([articleSchema, faqSchema])}>
  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .guide-section {
      margin-bottom: 3rem;
    }

    .guide-section h2 {
      color: var(--accent-color);
      margin-bottom: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    .guide-section p, .guide-section li {
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .ideas-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .category-card h3 {
      color: var(--accent-color);
      margin-top: 0;
      margin-bottom: 1rem;
      font-size: 1.25rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .count-badge {
      font-size: 0.8rem;
      background: var(--accent-color);
      color: white;
      padding: 2px 8px;
      border-radius: 12px;
    }

    .idea-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .idea-item {
      background: rgba(255, 255, 255, 0.05);
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 0.9rem;
      color: var(--text-primary);
    }

    .tips-box {
      background: var(--card-bg);
      border-left: 4px solid var(--accent-color);
      padding: 1.5rem;
      margin: 2rem 0;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .faq-a {
      color: var(--text-secondary);
    }
  </style>

  <div class="page-container">
    <header class="hero">
      <h1>{meta.title}</h1>
      <p>{meta.description}</p>
    </header>

    <section class="guide-section">
      <h2>How to Play Charades: The Official Rules</h2>
      <p>Charades is a classic party game that tests your acting skills and your team's intuition. The goal is simple: act out a word or phrase without speaking, making noises, or using props.</p>

      <h3>Team Setup</h3>
      <ul>
        <li>Split into two even teams.</li>
        <li>One player from Team A acts out a clue for their teammates.</li>
        <li>Team A has a set time limit (usually 2-3 minutes) to guess the clue.</li>
        <li>If they guess correctly, they get a point. If not, no point is awarded.</li>
        <li>Teams alternate until everyone has had a chance to act or you reach a winning score.</li>
      </ul>

      <h3>Difficulty Levels</h3>
      <p>You can adjust the game by choosing categories of varying difficulty:</p>
      <ul>
        <li><strong>Easy:</strong> Animals, basic actions, and famous Disney characters.</li>
        <li><strong>Medium:</strong> Popular movies, TV shows, and common phrases.</li>
        <li><strong>Hard:</strong> Specific book titles, classic songs, or abstract concepts.</li>
      </ul>
    </section>

    <section class="tips-box">
      <h3>Pro Acting Tips</h3>
      <ul>
        <li><strong>Use Signals:</strong> Start by indicating the category (e.g., pretending to turn a camera for a movie).</li>
        <li><strong>Word Count:</strong> Hold up fingers to show how many words are in the phrase.</li>
        <li><strong>Break it Down:</strong> Act out each word individually if the whole phrase is too hard.</li>
        <li><strong>Watch the Clock:</strong> If your team is stuck, quickly pivot to a different way of acting out the same word.</li>
      </ul>
    </section>

    <section class="guide-section">
      <h2>200+ Charades Ideas by Category</h2>
      <p>Browse our curated list of charades ideas to find the perfect clues for your next game night.</p>

      <div class="ideas-grid">
        {categories.map(cat => (
          <div class="category-card">
            <h3>{cat.name} <span class="count-badge">{cat.ideas.length}</span></h3>
            <div class="idea-list">
              {cat.ideas.map(idea => (
                <span class="idea-item">{idea}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="guide-section">
      <h2>Fun Variations</h2>
      <h3>Reverse Charades</h3>
      <p>In this hilarious twist, one person guesses while the rest of their team acts out the clue together. It's often much more chaotic and energetic than the traditional game!</p>

      <h3>Virtual Charades</h3>
      <p>To play over Zoom or FaceTime, the "host" can use a random generator and private message the clue to the actor. Make sure the actor stays in frame and everyone else stays on mute to let the actor have the spotlight!</p>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/truth-or-dare-guide" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">250 Best Truth or Dare Questions: The Ultimate Guide</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Explore 250 of the best Truth or Dare questions organized by category, including kids, teens, adults, and couples!</p>
      </a>
    </div>
  </div>
</SiteLayout>
