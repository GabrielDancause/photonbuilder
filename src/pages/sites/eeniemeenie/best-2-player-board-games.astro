const faqItems = [
  { q: 'What is the best 2-player board game for couples?', a: 'Patchwork, Fog of Love, and Lost Cities are excellent choices tailored for couples due to their engaging mechanics and varying levels of thematic involvement.' },
  { q: 'Are there any good cooperative 2-player board games?', a: 'Absolutely! Codenames Duet and various campaign games allow both players to work together against the game instead of each other.' },
  { q: 'What are the best travel-friendly 2-player games?', a: 'Hive and Star Realms are perfect for travel. Hive has highly durable bakelite tiles with no board, and Star Realms is just a small deck of cards.' },
  { q: 'How long do 2-player board games usually take?', a: 'It varies wildly. Quick games like Jaipur take 20 minutes, while grand strategy games like Twilight Struggle or War of the Ring can take 3 hours or more.' },
  { q: 'What makes a good 2-player strategy game?', a: 'A great 2-player strategy game features deep tactical decisions, high replayability, and tight interaction, ensuring that every move significantly impacts your opponent.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL} schema={JSON.stringify([articleSchema, faqSchema])}>
  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .games-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .game-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .game-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }

    .game-rank {
      background: var(--accent-color);
      color: white;
      font-size: 1.5rem;
      font-weight: bold;
      width: 45px;
      height: 45px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .game-title-area {
      display: flex;
      flex-direction: column;
    }

    .game-title {
      font-size: 1.5rem;
      color: var(--text-primary);
      margin: 0;
    }

    .game-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    .game-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 1rem;
      background: rgba(0,0,0,0.1);
      padding: 1rem;
      border-radius: 8px;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-primary);
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }

    @media (max-width: 600px) {
      .game-stats {
        grid-template-columns: 1fr 1fr;
      }
      .game-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>Top 25 Best 2-Player Board Games Ranked</h1>
      <p>{meta.description}</p>
    </div>

    <div class="games-list">
      {games.map(game => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-rank">#{game.rank}</div>
            <div class="game-title-area">
              <h2 class="game-title">{game.name}</h2>
            </div>
          </div>

          <p class="game-desc">{game.desc}</p>

          <div class="game-stats">
            <div class="stat-item">
              <span class="stat-label">Play Time</span>
              <span class="stat-value">{game.playTime}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Complexity</span>
              <span class="stat-value">{game.complexity}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Theme</span>
              <span class="stat-value">{game.theme}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Replayability</span>
              <span class="stat-value">{game.replayability}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Price</span>
              <span class="stat-value">{game.price}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/best-board-games" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">20 Best Board Games of 2026</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Discover the top 20 board games for every group size and experience level. Featuring family classics, deep strategy game...</p>
      </a>
    </div>
  </div>
</SiteLayout>
