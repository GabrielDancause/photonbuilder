const faqItems = [
  { q: 'What is the game Never Have I Ever?', a: 'Never Have I Ever is a classic party game where players take turns admitting things they have never done. If someone else in the group has done it, they usually take a penalty (like taking a sip of a drink or losing a point).' },
  { q: 'How many people can play Never Have I Ever?', a: 'It can be played with as few as two people or with a large group. It works best with 4-10 players, making it a great party game or icebreaker.' },
  { q: 'What makes a good Never Have I Ever question?', a: 'A good question is relatable but reveals something surprising or funny about the players. It should prompt storytelling and laughter.' },
  { q: 'Can Never Have I Ever be played with kids?', a: 'Absolutely! Our Clean/Family category is specifically designed to be safe, fun, and appropriate for all ages to enjoy.' },
  { q: 'How do you keep score in Never Have I Ever?', a: 'You can play without keeping score, or start everyone with 10 fingers up. Each time you have done the action, put a finger down. The last person with fingers remaining wins!' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .games-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .game-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .game-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }

    .game-title-area {
      flex-grow: 1;
    }

    .game-title {
      font-size: 1.5rem;
      margin: 0;
      color: var(--text-primary);
    }

    .game-category {
      font-size: 0.85rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      margin-top: 0.25rem;
    }

    .game-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>{meta.title}</h1>
      <p>{meta.description}</p>
    </div>

    <div>
      <h2>How to Play Never Have I Ever</h2>
      <p>Never Have I Ever is a versatile game that can be adapted for any group. Here are a few ways to play:</p>
      <ul>
        <li><strong>Ten Fingers (Point-Based):</strong> Everyone holds up 10 fingers. When a statement is read, if you have done it, put a finger down. The last person with fingers remaining wins!</li>
        <li><strong>Drinking Game Version:</strong> (For adults 21+) If you have done the action, take a sip of your drink. <em>Disclaimer: Please drink responsibly and know your limits.</em></li>
        <li><strong>Virtual Adaptations:</strong> Perfect for Zoom or video calls! Players can turn off their cameras if they have done the action, or simply use their hands on screen.</li>
        <li><strong>Celebrity Edition:</strong> Instead of personal secrets, try to guess if a specific celebrity has done the action! Discuss and debate before revealing the truth.</li>
      </ul>

      <h2>Why We Love This Game</h2>
      <p>It's the perfect icebreaker because it levels the playing field. Everyone has embarrassing stories, strange habits, or wild adventures. This game helps break down walls and creates immediate connections through shared (or shockingly different) experiences.</p>
    </div>

    <br />

    <div class="games-list">
      {questionsList.map((item, index) => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-title-area">
              <h2 class="game-title">Question #{index + 1}</h2>
              <div class="game-category">{item.category}</div>
            </div>
          </div>
          <p class="game-desc">{item.q}</p>
        </article>
      ))}
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>
