const faqItems = [
  { q: 'What is the best party card game for large groups?', a: 'Games like Cards Against Humanity, Wavelength, and Codenames are perfect for large groups as they can accommodate 8 or more players easily and keep everyone engaged.' },
  { q: 'Are there any good party card games for just two players?', a: 'Yes! Love Letter and The Mind are fantastic options that play exceptionally well with just two players or as a couple.' },
  { q: 'What makes a good party card game?', a: 'The best party card games are easy to learn, quick to play, have high player interaction, and create memorable, hilarious moments among friends and family.' },
  { q: 'Can these games be played with kids?', a: 'Many of them can! Games like Taco Cat Goat Cheese Pizza, Sushi Go, and Exploding Kittens are family-friendly. Always check the NSFW rating before playing with younger audiences.' },
  { q: 'How long do party card games usually take?', a: 'Most party card games are designed to be fast-paced, typically taking anywhere from 15 to 45 minutes per round.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL} schema={JSON.stringify([articleSchema, faqSchema])}>
  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .games-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .game-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .game-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }

    .game-rank {
      background: var(--accent-color);
      color: white;
      font-size: 1.5rem;
      font-weight: bold;
      width: 45px;
      height: 45px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .game-title-area {
      display: flex;
      flex-direction: column;
    }

    .game-title {
      font-size: 1.5rem;
      color: var(--text-primary);
      margin: 0;
    }

    .game-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    .game-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 1rem;
      background: rgba(0,0,0,0.1);
      padding: 1rem;
      border-radius: 8px;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-primary);
    }

    .extra-sections {
      margin-top: 4rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .extra-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .extra-card h2 {
      color: var(--accent-color);
      margin-bottom: 1rem;
      font-size: 1.5rem;
    }

    .extra-card p {
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 1rem;
    }

    .extra-card ul {
      color: var(--text-secondary);
      line-height: 1.6;
      padding-left: 1.5rem;
      margin-bottom: 0;
    }

    .extra-card li {
      margin-bottom: 0.5rem;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }

    @media (max-width: 600px) {
      .game-stats {
        grid-template-columns: 1fr 1fr;
      }
      .game-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>The 25 Best Party Card Games Ranked</h1>
      <p>{meta.description}</p>
    </div>

    <div class="games-list">
      {games.map(game => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-rank">#{game.rank}</div>
            <div class="game-title-area">
              <h2 class="game-title">{game.name}</h2>
            </div>
          </div>

          <p class="game-desc">{game.desc}</p>

          <div class="game-stats">
            <div class="stat-item">
              <span class="stat-label">Players</span>
              <span class="stat-value">{game.players}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Play Time</span>
              <span class="stat-value">{game.time}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Difficulty</span>
              <span class="stat-value">{game.difficulty}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">NSFW Rating</span>
              <span class="stat-value">{game.nsfw}</span>
            </div>
            <div class="stat-item">
              <span class="stat-label">Best For</span>
              <span class="stat-value">{game.bestFor}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="extra-sections">
      <div class="extra-card">
        <h2>Drinking Game Adaptations</h2>
        <p>Many of these party card games can be easily adapted into fun drinking games for adults:</p>
        <ul>
          <li><strong>Cards Against Humanity:</strong> Take a drink if your card is picked as the worst answer, or if you don't understand the winning reference.</li>
          <li><strong>Exploding Kittens:</strong> Drink when you draw an Exploding Kitten, or whenever you play an attack card.</li>
          <li><strong>What Do You Meme?:</strong> The person who plays the funniest meme assigns a drink to someone else.</li>
          <li><strong>Uno (DIY rules):</strong> Take a sip every time a +2 or Reverse is played. Finish your drink for a +4!</li>
        </ul>
      </div>

      <div class="extra-card">
        <h2>DIY Card Game Ideas</h2>
        <p>Don't have a game on hand? Create your own with blank cards or standard decks:</p>
        <ul>
          <li><strong>Custom Cards Against Humanity:</strong> Write inside jokes, friend names, and personal references on blank index cards.</li>
          <li><strong>The Hat Game / Monikers:</strong> Everyone writes down 5 nouns (people, places, things) on slips of paper. Put them in a hat and play charades/taboo in teams.</li>
          <li><strong>Spoons:</strong> All you need is a standard deck of cards and some spoons from the kitchen for this fast-paced matching game.</li>
          <li><strong>Kings Cup:</strong> A classic party drinking game using just a standard deck of cards and assigning rules to each card value.</li>
        </ul>
      </div>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/best-2-player-board-games" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Top 25 Best 2-Player Board Games Ranked</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Discover the ultimate ranked list of the 25 best 2-player board games for every occasion, covering strategy, quick games...</p>
      </a>
    </div>
  </div>
</SiteLayout>
