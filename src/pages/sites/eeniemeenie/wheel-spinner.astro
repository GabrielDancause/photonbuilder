---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Random Wheel Spinner', description: 'Can\'t decide? Add your options and spin the wheel. Who knows what fate has in store for you next.', category: 'tools', published: '2026-03-15' };
const SITE_ID = 'eeniemeenie';
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID}>
<style is:inline>

  .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    width: 100%;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  .wheel-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .wheel-layout {
      grid-template-columns: 1fr;
    }
  }

  .wheel-section {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .wheel-container {
    position: relative;
    width: 320px;
    height: 320px;
    margin-bottom: 2rem;
  }

  .wheel-pointer {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 15px solid transparent;
    border-right: 15px solid transparent;
    border-top: 30px solid var(--text-primary);
    z-index: 10;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }

  .wheel {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 4px solid var(--border-color);
    box-shadow: 0 0 20px rgba(0,0,0,0.3);
    transition: transform 4s cubic-bezier(0.1, 0.8, 0.2, 1);
    background: conic-gradient(from 0deg, var(--card-bg) 0deg, var(--card-bg) 360deg);
  }

  .spin-btn {
    width: 200px;
    font-size: 1.5rem;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    padding: 1rem;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    text-align: center;
  }
  .btn-primary:hover {
    opacity: 0.9;
  }
  .btn-primary:active {
    transform: scale(0.98);
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    width: 100%;
    padding: 0.8rem;
    background-color: transparent;
    border: 1px solid var(--accent-color);
    color: var(--accent-color);
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-secondary:hover {
    background-color: rgba(224, 64, 251, 0.1);
  }

  .winner-display {
    min-height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent-color);
    text-align: center;
    word-break: break-word;
    width: 100%;
  }
  .winner-display.celebrate {
    animation: bounceIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  @keyframes bounceIn {
    0% { transform: scale(0.5); opacity: 0; }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
  }

  .input-card {
    margin: 0;
  }
  .input-help {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }
  .entries-input {
    width: 100%;
    background-color: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem;
    border-radius: 8px;
    resize: vertical;
    margin-bottom: 1rem;
  }
  .entries-input:focus {
    outline: none;
    border-color: var(--accent-color);
  }

</style>
<div class="page-content">

<div class="hero">
  <h1>Random Wheel Spinner</h1>
  <p>Add your options, spin the wheel, and let fate decide.</p>
</div>

<div class="container">
  <div class="wheel-layout">
    <div class="wheel-section">
      <div class="wheel-container">
        <div class="wheel-pointer"></div>
        <div id="wheel" class="wheel"></div>
      </div>
      <button id="btn-spin" class="btn-primary spin-btn">SPIN</button>
      <div id="winner-display" class="winner-display"></div>
    </div>

    <div class="input-section">
      <div class="calculator-card input-card">
        <h3>Entries</h3>
        <p class="input-help">Enter one option per line</p>
        <textarea id="wheel-entries" class="entries-input" rows="12">Yes
No
Maybe
Try Again
Definitely</textarea>
        <button id="btn-update" class="btn-secondary">Update Wheel</button>
      </div>
    </div>
  </div>
</div>

</div>
<script is:inline>

  document.addEventListener('DOMContentLoaded', () => {
    const wheel = document.getElementById('wheel');
    const btnSpin = document.getElementById('btn-spin');
    const btnUpdate = document.getElementById('btn-update');
    const entriesInput = document.getElementById('wheel-entries');
    const winnerDisplay = document.getElementById('winner-display');

    let currentRotation = 0;
    let isSpinning = false;
    let entries = [];

    // Palette for wheel segments
    const colors = [
      '#E040FB', '#8E24AA', '#5E35B1', '#3949AB', '#1E88E5',
      '#039BE5', '#00ACC1', '#00897B', '#43A047', '#7CB342',
      '#C0CA33', '#FDD835', '#FFB300', '#FB8C00', '#F4511E',
      '#E53935', '#D81B60'
    ];

    function updateWheel() {
      const rawEntries = entriesInput.value.split('\n').map(e => e.trim()).filter(e => e.length > 0);
      entries = rawEntries.length > 0 ? rawEntries : ['Empty'];

      const total = entries.length;
      let gradientParts = [];
      const anglePerSegment = 360 / total;

      for (let i = 0; i < total; i++) {
        const color = colors[i % colors.length];
        const startAngle = i * anglePerSegment;
        const endAngle = (i + 1) * anglePerSegment;
        gradientParts.push(`${color} ${startAngle}deg ${endAngle}deg`);
      }

      wheel.style.background = `conic-gradient(from 0deg, ${gradientParts.join(', ')})`;

      // Reset state
      wheel.style.transition = 'none';
      wheel.style.transform = `rotate(${currentRotation}deg)`;
      winnerDisplay.textContent = '';
      winnerDisplay.classList.remove('celebrate');
    }

    function spin() {
      if (isSpinning || entries.length === 0) return;

      isSpinning = true;
      btnSpin.disabled = true;
      winnerDisplay.textContent = 'Spinning...';
      winnerDisplay.classList.remove('celebrate');

      const spins = Math.floor(Math.random() * 5) + 5; // 5 to 9 full spins
      const extraDegrees = Math.floor(Math.random() * 360);
      const totalRotation = currentRotation + (spins * 360) + extraDegrees;

      wheel.style.transition = 'transform 4s cubic-bezier(0.1, 0.8, 0.2, 1)';
      wheel.style.transform = `rotate(${totalRotation}deg)`;

      setTimeout(() => {
        isSpinning = false;
        btnSpin.disabled = false;
        currentRotation = totalRotation;

        // Calculate winner
        // The pointer is at the top (0 degrees).
        // The wheel rotates clockwise.
        // A rotation of `totalRotation` means the segment at `-totalRotation` is now at the top.
        const normalizedRotation = totalRotation % 360;

        // The top is 0 deg. When we rotate by `normalizedRotation`, the angle at the top
        // in the wheel's original coordinate system is `360 - normalizedRotation`.
        const pointerAngle = (360 - normalizedRotation) % 360;

        const anglePerSegment = 360 / entries.length;
        const winnerIndex = Math.floor(pointerAngle / anglePerSegment);

        winnerDisplay.textContent = entries[winnerIndex];

        // Trigger celebration
        void winnerDisplay.offsetWidth; // Force reflow
        winnerDisplay.classList.add('celebrate');

      }, 4000); // Wait for transition to finish
    }

    btnUpdate.addEventListener('click', updateWheel);
    btnSpin.addEventListener('click', spin);

    // Initial setup
    updateWheel();
  });

</script>
</SiteLayout>
