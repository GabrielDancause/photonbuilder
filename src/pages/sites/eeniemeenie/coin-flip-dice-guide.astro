---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Best Coin Flip and Dice Rolling Methods Guide',
  description: 'A comprehensive guide to randomness in decision-making, covering coin flip probability, tabletop dice (D4-D20), true random vs pseudorandom, and Monte Carlo simulations.',
  category: 'guide',
  published: '2023-11-20'
};

const SITE_ID = 'eeniemeenie';
const CANONICAL = 'https://eeniemeenie.photonbuilder.com/coin-flip-dice-guide';

const concepts = [
  {
    type: "Coin Flip Probability",
    focus: "Physical Physics, 50/50 Myth",
    desc: "While considered 50/50, physical coin flips are slightly biased depending on the side facing up before the flip, aerodynamic properties, and the surface it lands on."
  },
  {
    type: "Tabletop Dice Probability (D4 to D20)",
    focus: "Gaming, Polyhedrons",
    desc: "In tabletop gaming, different dice offer different distributions. A D20 gives a flat 5% chance per face, while rolling multiple dice (like 2D6) creates a bell curve favoring middle numbers."
  },
  {
    type: "Weighted Dice Detection",
    focus: "Fairness, Balance Testing",
    desc: "Physical dice can be biased by air bubbles or uneven weight. You can test them by floating them in salt water and observing if they consistently roll to the same number."
  },
  {
    type: "True Random vs Pseudorandom",
    focus: "Computing, algorithms",
    desc: "Computers generally use pseudorandom algorithms (like Math.random) based on math. True random numbers (like random.org) are generated by measuring atmospheric noise or radioactive decay."
  },
  {
    type: "Monte Carlo Simulations",
    focus: "Statistics, Modeling",
    desc: "A statistical technique that uses repeated random sampling to understand the probability of different outcomes in complex systems, heavily used in finance and physics."
  }
];

const applications = [
  {
    topic: "Using Randomness for Decisions",
    detail: "Research suggests using random selection for trivial choices can combat decision fatigue, freeing up cognitive resources for more important matters."
  },
  {
    topic: "Digital vs Physical Random",
    detail: "Physical randomization (rolling dice) offers tactile feedback and transparency, while digital tools provide speed, logging, and complex algorithmic balancing for digital groups."
  },
  {
    topic: "Lottery Number Generators",
    detail: "Lottery generators use algorithms to pick numbers without human pattern-bias, though mathematically, every combination still has the exact same probability of winning."
  },
  {
    topic: "Gambling Probability Basics",
    detail: "Understanding expected value and variance is crucial. The house always has an edge, meaning over infinite iterations of random events, the casino mathematically wins."
  }
];

const faqItems = [
  { q: 'Is a coin flip actually 50/50?', a: 'Mathematically yes, but physically, studies show a coin is slightly more likely (about 51%) to land on the side that was facing up before it was flipped.' },
  { q: 'What is the difference between Math.random and random.org?', a: 'Math.random uses a deterministic algorithm to simulate randomness (pseudorandom), while random.org measures actual unpredictable atmospheric noise (true random).' },
  { q: 'How do you check if tabletop dice are weighted?', a: 'Float the die in heavily salted water and flick it. If it repeatedly stops on the same face, its weight is unevenly distributed.' },
  { q: 'Why roll 2D6 instead of 1D12?', a: 'Rolling two six-sided dice creates a normal distribution (bell curve) where 7 is the most common result. A 1D12 gives an equal 8.3% chance to every number from 1 to 12.' },
  { q: 'How does randomness help with decision fatigue?', a: 'Flipping a coin for low-stakes choices bypasses the mental energy needed to weigh minor pros and cons, preserving willpower for significant decisions.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL} schema={JSON.stringify([articleSchema, faqSchema])}>
  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .games-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .game-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .game-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }

    .game-title-area {
      flex-grow: 1;
    }

    .game-title {
      font-size: 1.5rem;
      margin: 0;
      color: var(--text-primary);
    }

    .game-category {
      font-size: 0.85rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      margin-top: 0.25rem;
    }

    .game-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>Best Coin Flip and Dice Rolling Methods Guide</h1>
      <p>{meta.description}</p>
    </div>

    <div class="games-list">
      {concepts.map(method => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-title-area">
              <h2 class="game-title">{method.type}</h2>
              <div class="game-category">{method.focus}</div>
            </div>
          </div>
          <p class="game-desc">{method.desc}</p>
        </article>
      ))}

      {applications.map(uc => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-title-area">
              <h2 class="game-title">{uc.topic}</h2>
            </div>
          </div>
          <p class="game-desc">{uc.detail}</p>
        </article>
      ))}
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>
