---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tier List Maker | Create & Share Custom Tier Lists Free",
  description: "Drag-and-drop tier list maker. Add images or text, rank items from S to F tier, customize colors and labels, and export as an image. No sign-up required.",
  category: "tool",
  published: "2026-03-28",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Tier List Maker",
    "description": "Free online tier list maker with drag-and-drop ranking, custom tiers, image support, and PNG export.",
    "url": "https://eeniemeenie.photonbuilder.com/tier-list-maker",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "EenieMeenie", "url": "https://eeniemeenie.photonbuilder.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What is a tier list?", "acceptedAnswer": { "@type": "Answer", "text": "A tier list is a ranking system that organizes items into tiers from best to worst, typically labeled S (superior), A, B, C, D, and F. Originally popularized in fighting game communities to rank character strength, tier lists are now used to rank anything — foods, movies, games, music, and more." } },
      { "@type": "Question", "name": "What does S tier mean?", "acceptedAnswer": { "@type": "Answer", "text": "S tier stands for 'Superior' or 'Superb' and represents the highest ranking in a tier list, above A tier. The convention originated from Japanese gaming culture, where S-rank (from the German 'Sehr gut' meaning 'very good') was used in arcade games as the highest grade." } },
      { "@type": "Question", "name": "How do I make a tier list?", "acceptedAnswer": { "@type": "Answer", "text": "Add items to the unranked pool (type names or paste images), then drag each item into the tier where you think it belongs. You can rearrange items within tiers, customize tier labels and colors, add or remove tiers, and export the finished list as a PNG image to share." } },
      { "@type": "Question", "name": "Can I add images to my tier list?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Click 'Add Images' to upload photos or paste image URLs. You can also drag and drop image files directly into the item pool. Each image is displayed as a thumbnail in the tier list and included in the PNG export." } },
      { "@type": "Question", "name": "How do I share my tier list?", "acceptedAnswer": { "@type": "Answer", "text": "Click the 'Export as PNG' button to download your tier list as an image file. You can then share it on social media, Discord, Reddit, or anywhere else. The exported image includes all tiers, items, and your custom colors." } }
    ]
  }
];
---

<SiteLayout title={meta.title} description={meta.description} site="eeniemeenie">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <style>
    .tl-container { max-width: 960px; margin: 0 auto; padding: 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #c8d6e5; }
    h1 { font-size: 2rem; color: #f1f5f9; text-align: center; margin-bottom: 8px; }
    .subtitle { text-align: center; color: #64748b; margin-bottom: 28px; font-size: 1.05rem; }
    h2 { font-size: 1.4rem; color: #e2e8f0; margin: 40px 0 16px; border-bottom: 1px solid #152040; padding-bottom: 8px; }

    .toolbar { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; align-items: center; }
    .toolbar input[type="text"] { flex: 1; min-width: 180px; padding: 10px 14px; background: #0a1020; border: 1px solid #152040; border-radius: 8px; color: #f1f5f9; font-size: 0.95rem; }
    .toolbar input[type="text"]:focus { outline: none; border-color: #E040FB; }
    .tb-btn { padding: 10px 16px; border: 1px solid #152040; border-radius: 8px; background: #0a1020; color: #c8d6e5; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; white-space: nowrap; }
    .tb-btn:hover { border-color: #E040FB; color: #fff; }
    .tb-btn.primary { background: #E040FB; border-color: #E040FB; color: #fff; font-weight: 600; }
    .tb-btn.primary:hover { background: #c026d3; }
    .tb-btn.export { background: #22c55e; border-color: #22c55e; color: #fff; font-weight: 600; }
    .tb-btn.export:hover { background: #16a34a; }

    .tier-row { display: flex; min-height: 72px; margin-bottom: 4px; border-radius: 8px; overflow: hidden; background: #0a1020; border: 1px solid #152040; }
    .tier-label { width: 90px; min-width: 90px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: 800; cursor: pointer; user-select: none; position: relative; flex-shrink: 0; }
    .tier-label:hover::after { content: '✎'; position: absolute; bottom: 4px; right: 6px; font-size: 0.6rem; opacity: 0.6; }
    .tier-items { flex: 1; display: flex; flex-wrap: wrap; align-items: center; gap: 6px; padding: 8px; min-height: 56px; }
    .tier-items.drag-over { background: rgba(224, 64, 251, 0.08); }

    .item { width: 56px; height: 56px; border-radius: 6px; display: flex; align-items: center; justify-content: center; cursor: grab; position: relative; overflow: hidden; border: 1px solid #1e293b; background: #152040; font-size: 0.7rem; text-align: center; padding: 2px; word-break: break-word; line-height: 1.2; user-select: none; transition: transform 0.1s, box-shadow 0.1s; }
    .item:active { cursor: grabbing; }
    .item.dragging { opacity: 0.4; transform: scale(0.95); }
    .item img { width: 100%; height: 100%; object-fit: cover; border-radius: 4px; pointer-events: none; }
    .item .del-btn { position: absolute; top: -2px; right: -2px; width: 16px; height: 16px; background: #ef4444; color: #fff; border: none; border-radius: 50%; font-size: 0.6rem; cursor: pointer; display: none; align-items: center; justify-content: center; line-height: 1; padding: 0; }
    .item:hover .del-btn { display: flex; }

    .pool-section { margin: 20px 0; }
    .pool-label { font-size: 0.85rem; color: #64748b; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
    .pool { display: flex; flex-wrap: wrap; gap: 6px; padding: 16px; background: #0a1020; border: 1px solid #152040; border-radius: 10px; min-height: 72px; }
    .pool.drag-over { background: rgba(224, 64, 251, 0.08); }

    .tier-actions { display: flex; gap: 6px; margin: 12px 0; }
    .tier-action-btn { padding: 6px 12px; border: 1px dashed #1e293b; border-radius: 6px; background: transparent; color: #64748b; cursor: pointer; font-size: 0.85rem; }
    .tier-action-btn:hover { border-color: #E040FB; color: #c8d6e5; }

    .edit-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); display: none; align-items: center; justify-content: center; z-index: 100; }
    .edit-modal.show { display: flex; }
    .edit-panel { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 24px; min-width: 300px; }
    .edit-panel h3 { color: #e2e8f0; margin: 0 0 16px; }
    .edit-panel input { width: 100%; padding: 10px; background: #060a12; border: 1px solid #152040; border-radius: 8px; color: #f1f5f9; font-size: 1rem; margin-bottom: 12px; box-sizing: border-box; }
    .edit-panel .color-row { display: flex; gap: 8px; margin-bottom: 16px; }
    .edit-panel .color-swatch { width: 36px; height: 36px; border-radius: 6px; cursor: pointer; border: 2px solid transparent; }
    .edit-panel .color-swatch.active { border-color: #fff; }
    .edit-panel .btn-row { display: flex; gap: 8px; justify-content: flex-end; }
    .edit-panel .btn-row button { padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 0.9rem; border: none; }
    .btn-save { background: #E040FB; color: #fff; }
    .btn-cancel { background: #1e293b; color: #c8d6e5; }
    .btn-delete { background: #ef4444; color: #fff; }

    .how-section { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 24px; margin: 32px 0; }
    .how-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 16px; }
    .how-step { text-align: center; }
    .how-num { width: 36px; height: 36px; background: #1e1040; color: #E040FB; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; margin-bottom: 8px; }
    .how-step h4 { color: #e2e8f0; margin: 4px 0; }
    .how-step p { color: #94a3b8; font-size: 0.9rem; margin: 0; }

    .faq-section { margin-top: 40px; }
    .faq-item { border: 1px solid #152040; border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
    .faq-q { padding: 16px 20px; background: #0a1020; cursor: pointer; display: flex; justify-content: space-between; align-items: center; color: #e2e8f0; font-weight: 500; }
    .faq-q:hover { background: #0f1629; }
    .faq-arrow { transition: transform 0.2s; color: #E040FB; }
    .faq-item.open .faq-arrow { transform: rotate(180deg); }
    .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.3s, padding 0.3s; }
    .faq-item.open .faq-a { max-height: 300px; padding: 16px 20px; }
    .faq-a p { color: #94a3b8; line-height: 1.7; margin: 0; }

    .hidden-file-input { display: none; }

    @media (max-width: 600px) {
      .tier-label { width: 60px; min-width: 60px; font-size: 1.1rem; }
      .item { width: 44px; height: 44px; font-size: 0.6rem; }
    }
  </style>

  <div class="tl-container">
    <div style="background:rgba(224,64,251,0.08);border:1px solid rgba(224,64,251,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:var(--text-secondary);line-height:1.6;margin-bottom:1rem;">
      🏆 <strong style="color:#E040FB;">Tier lists get 3× more engagement than standard reviews on social media.</strong> Rank anything from games to foods to movies — then export as a shareable image. No login, no watermarks, instant results. <a href="https://gab.ae/news/ps5-price-hike-pc-gaming-bottleneck-2026" style="color:#E040FB;">Gaming tier lists are trending →</a>
    </div>
    <h1>Tier List Maker</h1>
    <p class="subtitle">Drag and drop to rank anything — export as a shareable image</p>

    <div class="toolbar">
      <input type="text" id="itemInput" placeholder="Type an item name and press Enter..." onkeydown="if(event.key==='Enter')addTextItem()">
      <button class="tb-btn" onclick="addTextItem()">+ Add</button>
      <button class="tb-btn" onclick="document.getElementById('imgUpload').click()">📷 Add Images</button>
      <button class="tb-btn" onclick="clearAll()">🗑️ Clear</button>
      <button class="tb-btn export" onclick="exportPNG()">📥 Export PNG</button>
      <input type="file" id="imgUpload" class="hidden-file-input" multiple accept="image/*" onchange="handleImages(this.files)">
    </div>

    <div id="tierContainer"></div>

    <div class="tier-actions">
      <button class="tier-action-btn" onclick="addTier()">+ Add Tier</button>
      <button class="tier-action-btn" onclick="resetTiers()">↺ Reset to Default</button>
    </div>

    <div class="pool-section">
      <div class="pool-label">Unranked Items</div>
      <div class="pool" id="pool"></div>
    </div>

    <!-- Edit Modal -->
    <div class="edit-modal" id="editModal">
      <div class="edit-panel">
        <h3>Edit Tier</h3>
        <input type="text" id="editLabel" placeholder="Tier label (e.g. S, A, B...)">
        <div class="color-row" id="colorRow"></div>
        <div class="btn-row">
          <button class="btn-delete" onclick="deleteTier()">Delete</button>
          <button class="btn-cancel" onclick="closeModal()">Cancel</button>
          <button class="btn-save" onclick="saveTier()">Save</button>
        </div>
      </div>
    </div>

    <!-- How to Use -->
    <div class="how-section">
      <h2 style="margin-top:0;border:none;padding:0;">How to Make a Tier List</h2>
      <div class="how-grid">
        <div class="how-step">
          <div class="how-num">1</div>
          <h4>Add Items</h4>
          <p>Type names or upload images to build your item pool</p>
        </div>
        <div class="how-step">
          <div class="how-num">2</div>
          <h4>Drag & Rank</h4>
          <p>Drag items from the pool into the tier where they belong</p>
        </div>
        <div class="how-step">
          <div class="how-num">3</div>
          <h4>Customize</h4>
          <p>Click tier labels to change names, colors, or add new tiers</p>
        </div>
        <div class="how-step">
          <div class="how-num">4</div>
          <h4>Export & Share</h4>
          <p>Download as PNG and share on Discord, Reddit, or social media</p>
        </div>
      </div>
    </div>

    <!-- What is a Tier List -->
    <h2>What Is a Tier List?</h2>
    <p>A tier list is a visual ranking system that organizes items into horizontal rows (tiers) from best to worst. The standard tiers run from <strong>S</strong> (superior — the absolute best) through <strong>A</strong>, <strong>B</strong>, <strong>C</strong>, <strong>D</strong>, down to <strong>F</strong> (the worst).</p>
    <p>The format originated in fighting game communities during the 1990s, where players ranked character strength to help with competitive strategy. The "S tier" convention comes from Japanese arcade gaming, where S-rank (from the German <em>Sehr gut</em>, "very good") sat above the standard A-through-F grading scale.</p>
    <p>Today, tier lists have exploded beyond gaming. People make tier lists for fast food chains, Marvel movies, pizza toppings, programming languages, dog breeds — anything that can be compared and debated. The format works because it's visual, opinionated, and inherently shareable. A well-made tier list almost always starts a conversation.</p>

    <!-- Popular Uses -->
    <h2>Popular Tier List Categories</h2>
    <div class="how-grid">
      <div class="how-step">
        <div class="how-num">🎮</div>
        <h4>Video Games</h4>
        <p>Characters, weapons, maps, bosses, entire game series</p>
      </div>
      <div class="how-step">
        <div class="how-num">🍕</div>
        <h4>Food & Drink</h4>
        <p>Fast food, candy, sodas, cuisines, cereal brands</p>
      </div>
      <div class="how-step">
        <div class="how-num">🎬</div>
        <h4>Movies & TV</h4>
        <p>MCU films, horror franchises, sitcoms, anime</p>
      </div>
      <div class="how-step">
        <div class="how-num">🏀</div>
        <h4>Sports</h4>
        <p>Athletes, teams, draft picks, all-time GOATs</p>
      </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">What is a tier list? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>A tier list is a ranking system that organizes items into tiers from best to worst, typically labeled S (superior), A, B, C, D, and F. Originally popularized in fighting game communities to rank character strength, tier lists are now used to rank anything — foods, movies, games, music, and more.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">What does S tier mean? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>S tier stands for "Superior" or "Superb" and represents the highest ranking, above A tier. The convention originated from Japanese gaming culture, where S-rank (from the German "Sehr gut" meaning "very good") was used in arcade games as the highest grade.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">How do I make a tier list? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>Add items to the unranked pool (type names or paste images), then drag each item into the tier where you think it belongs. Customize tier labels and colors by clicking them, and export the finished list as a PNG image to share.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">Can I add images to my tier list? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>Yes. Click "Add Images" to upload photos from your device. Each image is displayed as a thumbnail in the tier list and included in the PNG export. You can mix text items and images freely.</p></div>
      </div>
      <div class="faq-item">
        <div class="faq-q" onclick="toggleFaq(this)">How do I share my tier list? <span class="faq-arrow">▼</span></div>
        <div class="faq-a"><p>Click "Export as PNG" to download your tier list as an image. Share it on social media, Discord, Reddit, or anywhere you want. The exported image includes all tiers, items, and your custom colors.</p></div>
      </div>
    </div>
  </div>

  <script is:inline>
    const DEFAULT_TIERS = [
      { label: 'S', color: '#ff7f7f' },
      { label: 'A', color: '#ffbf7f' },
      { label: 'B', color: '#ffdf7f' },
      { label: 'C', color: '#ffff7f' },
      { label: 'D', color: '#bfff7f' },
      { label: 'F', color: '#7fbfff' }
    ];

    let tiers = JSON.parse(JSON.stringify(DEFAULT_TIERS));
    let items = []; // { id, type: 'text'|'image', content, tier: null|index }
    let editIndex = null;
    let dragItem = null;
    let itemIdCounter = 0;

    const COLORS = ['#ff7f7f','#ffbf7f','#ffdf7f','#ffff7f','#bfff7f','#7fff7f','#7fbfff','#7f7fff','#bf7fff','#ff7fbf','#ff5555','#55aaff'];

    function render() {
      const container = document.getElementById('tierContainer');
      container.innerHTML = '';
      tiers.forEach((t, i) => {
        const row = document.createElement('div');
        row.className = 'tier-row';
        const label = document.createElement('div');
        label.className = 'tier-label';
        label.style.background = t.color;
        label.style.color = luminance(t.color) > 0.5 ? '#111' : '#fff';
        label.textContent = t.label;
        label.onclick = () => openEdit(i);
        row.appendChild(label);

        const itemsDiv = document.createElement('div');
        itemsDiv.className = 'tier-items';
        itemsDiv.dataset.tier = i;
        itemsDiv.addEventListener('dragover', e => { e.preventDefault(); itemsDiv.classList.add('drag-over'); });
        itemsDiv.addEventListener('dragleave', () => itemsDiv.classList.remove('drag-over'));
        itemsDiv.addEventListener('drop', e => { e.preventDefault(); itemsDiv.classList.remove('drag-over'); dropItem(i); });

        items.filter(it => it.tier === i).forEach(it => itemsDiv.appendChild(createItemEl(it)));
        row.appendChild(itemsDiv);
        container.appendChild(row);
      });

      const pool = document.getElementById('pool');
      pool.innerHTML = '';
      items.filter(it => it.tier === null).forEach(it => pool.appendChild(createItemEl(it)));
    }

    function createItemEl(it) {
      const el = document.createElement('div');
      el.className = 'item';
      el.draggable = true;
      el.dataset.id = it.id;
      if (it.type === 'image') {
        const img = document.createElement('img');
        img.src = it.content;
        img.alt = 'tier item';
        el.appendChild(img);
      } else {
        el.textContent = it.content;
      }
      const del = document.createElement('button');
      del.className = 'del-btn';
      del.textContent = '×';
      del.onclick = (e) => { e.stopPropagation(); items = items.filter(x => x.id !== it.id); render(); };
      el.appendChild(del);

      el.addEventListener('dragstart', e => {
        dragItem = it.id;
        el.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
      });
      el.addEventListener('dragend', () => { el.classList.remove('dragging'); dragItem = null; });
      return el;
    }

    function dropItem(tierIndex) {
      if (dragItem === null) return;
      const it = items.find(x => x.id === dragItem);
      if (it) { it.tier = tierIndex; render(); }
    }

    // Pool drop
    document.addEventListener('DOMContentLoaded', () => {
      const pool = document.getElementById('pool');
      pool.addEventListener('dragover', e => { e.preventDefault(); pool.classList.add('drag-over'); });
      pool.addEventListener('dragleave', () => pool.classList.remove('drag-over'));
      pool.addEventListener('drop', e => {
        e.preventDefault(); pool.classList.remove('drag-over');
        if (dragItem !== null) { const it = items.find(x => x.id === dragItem); if (it) { it.tier = null; render(); } }
      });
      render();
    });

    function addTextItem() {
      const input = document.getElementById('itemInput');
      const val = input.value.trim();
      if (!val) return;
      items.push({ id: ++itemIdCounter, type: 'text', content: val, tier: null });
      input.value = '';
      render();
    }

    function handleImages(files) {
      Array.from(files).forEach(f => {
        const reader = new FileReader();
        reader.onload = e => {
          items.push({ id: ++itemIdCounter, type: 'image', content: e.target.result, tier: null });
          render();
        };
        reader.readAsDataURL(f);
      });
    }

    function clearAll() {
      if (!confirm('Remove all items?')) return;
      items = [];
      render();
    }

    function addTier() {
      const letters = 'SABCDEF';
      const used = tiers.map(t => t.label);
      let label = '';
      for (const l of letters) { if (!used.includes(l)) { label = l; break; } }
      if (!label) label = 'T' + (tiers.length + 1);
      tiers.push({ label, color: COLORS[tiers.length % COLORS.length] });
      render();
    }

    function resetTiers() {
      // Move all ranked items back to pool
      items.forEach(it => it.tier = null);
      tiers = JSON.parse(JSON.stringify(DEFAULT_TIERS));
      render();
    }

    function openEdit(i) {
      editIndex = i;
      document.getElementById('editLabel').value = tiers[i].label;
      const colorRow = document.getElementById('colorRow');
      colorRow.innerHTML = '';
      COLORS.forEach(c => {
        const swatch = document.createElement('div');
        swatch.className = 'color-swatch' + (c === tiers[i].color ? ' active' : '');
        swatch.style.background = c;
        swatch.onclick = () => {
          colorRow.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
          swatch.classList.add('active');
        };
        colorRow.appendChild(swatch);
      });
      document.getElementById('editModal').classList.add('show');
    }

    function closeModal() { document.getElementById('editModal').classList.remove('show'); editIndex = null; }

    function saveTier() {
      if (editIndex === null) return;
      tiers[editIndex].label = document.getElementById('editLabel').value || tiers[editIndex].label;
      const active = document.querySelector('#colorRow .color-swatch.active');
      if (active) tiers[editIndex].color = active.style.background || active.style.backgroundColor;
      closeModal();
      render();
    }

    function deleteTier() {
      if (editIndex === null) return;
      if (tiers.length <= 1) { alert('Need at least one tier.'); return; }
      // Move items back to pool
      items.forEach(it => { if (it.tier === editIndex) it.tier = null; else if (it.tier > editIndex) it.tier--; });
      tiers.splice(editIndex, 1);
      closeModal();
      render();
    }

    function luminance(hex) {
      hex = hex.replace('#', '');
      const r = parseInt(hex.substr(0, 2), 16) / 255;
      const g = parseInt(hex.substr(2, 2), 16) / 255;
      const b = parseInt(hex.substr(4, 2), 16) / 255;
      return 0.299 * r + 0.587 * g + 0.114 * b;
    }

    function toggleFaq(el) { el.parentElement.classList.toggle('open'); }

    // Export as PNG using canvas
    function exportPNG() {
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      const W = 800, rowH = 70, labelW = 90, itemS = 56, pad = 8;

      // Calculate height
      let totalRows = 0;
      tiers.forEach((t, i) => {
        const tierItems = items.filter(it => it.tier === i);
        const cols = Math.floor((W - labelW - pad * 2) / (itemS + 6));
        const rows = Math.max(1, Math.ceil(tierItems.length / cols));
        totalRows += rows;
      });
      const H = totalRows * rowH + 40;
      canvas.width = W;
      canvas.height = H;

      // Background
      ctx.fillStyle = '#060a12';
      ctx.fillRect(0, 0, W, H);

      let y = 10;
      tiers.forEach((t, i) => {
        const tierItems = items.filter(it => it.tier === i);
        const cols = Math.floor((W - labelW - pad * 2) / (itemS + 6));
        const rows = Math.max(1, Math.ceil(tierItems.length / cols));
        const h = rows * rowH;

        // Label background
        ctx.fillStyle = t.color;
        ctx.fillRect(0, y, labelW, h);
        ctx.fillStyle = luminance(t.color) > 0.5 ? '#111' : '#fff';
        ctx.font = 'bold 28px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(t.label, labelW / 2, y + h / 2);

        // Row background
        ctx.fillStyle = '#0a1020';
        ctx.fillRect(labelW, y, W - labelW, h);

        // Items
        tierItems.forEach((it, j) => {
          const col = j % cols;
          const row = Math.floor(j / cols);
          const ix = labelW + pad + col * (itemS + 6);
          const iy = y + row * rowH + (rowH - itemS) / 2;

          ctx.fillStyle = '#152040';
          ctx.fillRect(ix, iy, itemS, itemS);

          if (it.type === 'text') {
            ctx.fillStyle = '#c8d6e5';
            ctx.font = '10px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            const lines = wrapText(ctx, it.content, itemS - 4);
            lines.forEach((line, li) => {
              ctx.fillText(line, ix + itemS / 2, iy + itemS / 2 + (li - (lines.length - 1) / 2) * 12);
            });
          }
        });

        y += h + 4;
      });

      // Handle image items with Promise.all
      const imageItems = [];
      tiers.forEach((t, i) => {
        const tierItems = items.filter(it => it.tier === i);
        tierItems.forEach((it, j) => {
          if (it.type === 'image') imageItems.push({ item: it, tierIndex: i, j });
        });
      });

      if (imageItems.length === 0) {
        downloadCanvas(canvas);
      } else {
        let loaded = 0;
        imageItems.forEach(({ item, tierIndex, j }) => {
          const img = new Image();
          img.onload = () => {
            // Recalculate position
            let yy = 10;
            for (let ti = 0; ti < tierIndex; ti++) {
              const tItems = items.filter(it => it.tier === ti);
              const c = Math.floor((W - labelW - pad * 2) / (itemS + 6));
              const r = Math.max(1, Math.ceil(tItems.length / c));
              yy += r * rowH + 4;
            }
            const cols = Math.floor((W - labelW - pad * 2) / (itemS + 6));
            const col = j % cols;
            const row = Math.floor(j / cols);
            const ix = labelW + pad + col * (itemS + 6);
            const iy = yy + row * rowH + (rowH - itemS) / 2;
            ctx.drawImage(img, ix, iy, itemS, itemS);
            loaded++;
            if (loaded === imageItems.length) downloadCanvas(canvas);
          };
          img.onerror = () => { loaded++; if (loaded === imageItems.length) downloadCanvas(canvas); };
          img.src = item.content;
        });
      }
    }

    function downloadCanvas(canvas) {
      const link = document.createElement('a');
      link.download = 'tier-list.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    }

    function wrapText(ctx, text, maxW) {
      const words = text.split(' ');
      const lines = [];
      let current = '';
      words.forEach(w => {
        const test = current ? current + ' ' + w : w;
        if (ctx.measureText(test).width <= maxW) { current = test; }
        else { if (current) lines.push(current); current = w; }
      });
      if (current) lines.push(current);
      return lines.length ? lines : [text.slice(0, 8)];
    }
  </script>

