---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: '20 Best Dice Games: The Ultimate Guide to Dice Gaming',
  description: 'Discover the 20 best dice games for all occasions, covering classic, party, educational, RPG, and solo dice games. Learn probability concepts and dice types.',
  category: 'guide',
  published: '2023-12-01'
};

const SITE_ID = 'eeniemeenie';
const CANONICAL = 'https://eeniemeenie.photonbuilder.com/best-dice-games';

const games = [
  {
    type: "Yahtzee",
    focus: "Classic",
    desc: "A classic dice game of probability and luck where players roll five dice to make specific scoring combinations. The strategy involves calculating the odds of rolling specific numbers to maximize points."
  },
  {
    type: "Farkle",
    focus: "Classic",
    desc: "A high-risk, high-reward push-your-luck game using six dice. Players must decide whether to bank their points or risk it all for more, heavily relying on expected value and probability."
  },
  {
    type: "Bunco",
    focus: "Classic",
    desc: "A fast-paced social dice game played in teams with three dice. The probability of rolling a 'Bunco' (three of a kind matching the target number) is exactly 1 in 216."
  },
  {
    type: "Liar's Dice",
    focus: "Classic",
    desc: "A game of bluffing and probability using a set of five dice per player. Players must estimate the total number of specific dice faces across all hidden hands, relying on statistical averages."
  },
  {
    type: "Ship, Captain, and Crew",
    focus: "Party",
    desc: "A casual bar and party game where players roll five dice to qualify with a 6, 5, and 4, then score with the remaining two dice. Understanding the sequence probability is key."
  },
  {
    type: "Mexico",
    focus: "Party",
    desc: "A popular elimination game using two dice, where rolling a 2 and 1 (Mexico) is the highest score. It teaches basic two-dice roll combinations and elimination odds."
  },
  {
    type: "Bar Dice",
    focus: "Party",
    desc: "A quick game often played to determine who pays for a round. Usually involves matching faces or rolling higher totals, blending pure luck with simple probability."
  },
  {
    type: "Math Dice",
    focus: "Educational",
    desc: "Players use two target dice and three scoring dice to practice mental math. It reinforces arithmetic skills and teaches how different numbers can combine to reach a target."
  },
  {
    type: "Prime Climb",
    focus: "Educational",
    desc: "Using two ten-sided dice (d10), players add, subtract, multiply, or divide their way to the center of the board. Excellent for teaching factors, primes, and operations."
  },
  {
    type: "Dungeons & Dragons Basics",
    focus: "RPG Dice",
    desc: "The core of D&D relies on the d20 (20-sided die) for action resolution. It teaches uniform probability where each face has a flat 5% chance of appearing."
  },
  {
    type: "Polyhedral Sets",
    focus: "RPG Dice",
    desc: "Standard RPG sets include d4, d6, d8, d10, d12, and d20. Each die has a unique probability distribution, showing how geometric shapes influence random outcomes."
  },
  {
    type: "Three Man",
    focus: "Drinking Games (Please drink responsibly)",
    desc: "A popular social game involving two dice. Players become the 'Three Man' and drink based on specific rolls. Demonstrates the probability of rolling a 3 or combinations that add to 3."
  },
  {
    type: "Cheers to the Governor",
    focus: "Drinking Games (Please drink responsibly)",
    desc: "A counting game often incorporating dice for rule changes. A fun social experience that highlights memory and pattern recognition over pure statistical odds."
  },
  {
    type: "Pass the Pigs",
    focus: "Travel",
    desc: "A travel-friendly push-your-luck game (often played with small pig figures acting as dice). Shows non-standard probability since the 'dice' are asymmetrical."
  },
  {
    type: "Zombie Dice",
    focus: "Travel",
    desc: "A quick, portable game where players roll custom dice to collect brains and avoid shotguns. A perfect introduction to weighted probability since different colored dice have different odds."
  },
  {
    type: "Qwixx",
    focus: "Travel",
    desc: "A fast-playing dice game where everyone plays on every roll. It uses two white and four colored dice, highlighting the bell curve of rolling two six-sided dice."
  },
  {
    type: "Button Men",
    focus: "Solo / 2-Player",
    desc: "A dice combat game where characters use different polyhedral dice. It teaches how to calculate odds of winning a head-to-head roll between different die types (e.g., d8 vs d12)."
  },
  {
    type: "Under Falling Skies",
    focus: "Solo",
    desc: "A solo dice placement game where higher rolls provide better actions but advance enemy ships faster. It requires balancing expected value against risk management."
  },
  {
    type: "Fair vs. Loaded Dice Detection",
    focus: "Concepts",
    desc: "You can test dice fairness using the float test in saltwater. True fair dice will have an even distribution of numbers over hundreds of rolls, while loaded dice will heavily skew."
  },
  {
    type: "Probability Distribution (d6 vs 2d6)",
    focus: "Concepts",
    desc: "Rolling one d6 gives a flat distribution (16.6% for each number). Rolling 2d6 creates a bell curve, making 7 the most common roll (16.6%) and 2 or 12 the least common (2.7%)."
  }
];

const faqItems = [
  { q: 'What is the most popular classic dice game?', a: 'Yahtzee is generally considered the most popular classic dice game, loved for its mix of luck and strategic probability management.' },
  { q: 'How many dice are in a standard RPG polyhedral set?', a: 'A standard RPG set contains seven dice: one d4, one d6, one d8, two d10s (one for ones, one for tens), one d12, and one d20.' },
  { q: 'What is the probability of rolling a 7 with two six-sided dice?', a: 'The probability of rolling a 7 is exactly 1/6 (or 16.67%), as there are 6 ways to roll a 7 out of 36 possible combinations.' },
  { q: 'How can I tell if my dice are fair or loaded?', a: 'You can test dice balance using the saltwater float test. Drop the die in saltwater and flick it; if the same number repeatedly floats to the top, it may be loaded or unbalanced.' },
  { q: 'Are drinking dice games based purely on luck?', a: 'Most are highly luck-dependent, but games like Three Man or Liar\'s Dice incorporate bluffing, probability tracking, and strategic risk-taking. Always remember to drink responsibly.' }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Eenie Meenie"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} canonical={CANONICAL}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 3rem;
    }

    .hero h1 {
      font-size: 2.5rem;
      color: var(--accent-color);
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--text-secondary);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .games-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .game-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .game-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }

    .game-title-area {
      flex-grow: 1;
    }

    .game-title {
      font-size: 1.5rem;
      margin: 0;
      color: var(--text-primary);
    }

    .game-category {
      font-size: 0.85rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      margin-top: 0.25rem;
    }

    .game-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>{meta.title}</h1>
      <p>{meta.description}</p>
    </div>

    <div class="games-list">
      {games.map(game => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-title-area">
              <h2 class="game-title">{game.type}</h2>
              <div class="game-category">{game.focus}</div>
            </div>
          </div>
          <p class="game-desc">{game.desc}</p>
        </article>
      ))}
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <div class="related-tools" style="margin-top:3rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
    <h2 style="font-size:1.2rem;margin-bottom:1rem;">🔗 Related Tools</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;">
      <a href="/best-2-player-board-games" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Top 25 Best 2-Player Board Games Ranked</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">Discover the ultimate ranked list of the 25 best 2-player board games for every occasion, covering strategy, quick games...</p>
      </a>
      <a href="https://leeroyjenkins.quest/keyboard-switches-guide" style="display:block;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:1.25rem;text-decoration:none;color:inherit;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.2)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)';this.style.transform='none'">
        <strong style="font-size:0.95rem;">Best Mechanical Keyboard Switches</strong>
        <p style="opacity:0.6;font-size:0.83rem;margin:0.4rem 0 0;line-height:1.4;">The ultimate guide to mechanical keyboard switches. Learn about switch types, Cherry MX, Gateron, Kailh, enthusiast swit...</p>
      </a>
    </div>
  </div>
</SiteLayout>