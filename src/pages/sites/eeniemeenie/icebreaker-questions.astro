const faqItems = [
  {
    "q": "What makes a good icebreaker question?",
    "a": "A good icebreaker question is open-ended, non-threatening, and easy to answer. It should encourage sharing without making people feel uncomfortable or put on the spot."
  },
  {
    "q": "How do you transition from an icebreaker to a real conversation?",
    "a": "Listen actively to the answer and ask follow-up questions. Find common ground or shared interests based on their response to steer the conversation naturally."
  },
  {
    "q": "What questions should you avoid as icebreakers?",
    "a": "Avoid controversial topics like politics or religion, deeply personal questions, or anything that could be interpreted as offensive or exclusionary."
  },
  {
    "q": "How do you read the room when using icebreakers?",
    "a": "Pay attention to body language and engagement levels. If a question falls flat, quickly pivot to a lighter topic. Ensure everyone has a chance to participate if they want to."
  },
  {
    "q": "What are the 36 Questions That Lead to Love?",
    "a": "Developed by psychologist Arthur Aron, these 36 questions are designed to accelerate intimacy between strangers. They start with simple questions and gradually become more personal."
  }
];

