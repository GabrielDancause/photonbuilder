      line-height: 1.6;
    }

    .content-section {
      margin-bottom: 3rem;
      line-height: 1.6;
      color: var(--text-secondary);
    }

    .content-section h2 {
      color: var(--accent-color);
      margin-bottom: 1rem;
    }

    .content-section h3 {
      color: var(--text-primary);
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .games-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 4rem;
    }

    .game-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .game-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
    }

    .game-title-area {
      flex-grow: 1;
    }

    .game-title {
      font-size: 1.5rem;
      margin: 0;
      color: var(--text-primary);
    }

    .game-category {
      font-size: 0.85rem;
      color: var(--accent-color);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      margin-top: 0.25rem;
    }

    .game-desc {
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0;
      font-size: 1.1rem;
    }

    .faq-section {
      margin-top: 4rem;
    }

    .faq-section h2 {
      text-align: center;
      margin-bottom: 2rem;
      color: var(--accent-color);
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.25rem;
    }

    .faq-q {
      font-weight: bold;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    .faq-a {
      color: var(--text-secondary);
      line-height: 1.5;
    }
  </style>

  <div class="page-container">
    <div class="hero">
      <h1>{meta.title}</h1>
      <p>{meta.description}</p>
    </div>

    <div class="content-section">
      <h2>The Art of the Icebreaker</h2>
      <p>Icebreaker questions are powerful tools for building connection, diffusing tension, and starting meaningful conversations. Whether you're in a boardroom or on a first date, the right question can make all the difference.</p>

      <h3>Tips for Delivery</h3>
      <p>Deliver icebreakers with genuine enthusiasm and curiosity. Maintain eye contact, smile, and make sure you're ready to actively listen to the response.</p>

      <h3>Reading the Room</h3>
      <p>Pay attention to body language. If a question seems to make someone uncomfortable, gracefully pivot. Adapt your tone and question choice based on the setting and the participants' energy levels.</p>

      <h3>Questions to Avoid</h3>
      <p>Steer clear of politics, religion, highly personal topics, or questions that require specific background knowledge that not everyone might have. Keep it inclusive and light.</p>

      <h3>Transitioning to Real Conversation</h3>
      <p>The icebreaker is just the start! Use the answers to find common ground. Ask follow-up questions like "Tell me more about that" or "How did you get into that hobby?"</p>

      <h3>The Psychology of First Impressions</h3>
      <p>First impressions form within seconds. A good icebreaker helps bypass superficial small talk, signaling warmth and openness, which are key components of a positive first impression.</p>

      <h3>36 Questions That Lead to Love</h3>
      <p>Psychologist Arthur Aron's famous study demonstrated that a specific set of 36 escalating questions could foster deep intimacy between strangers, highlighting the power of guided vulnerability.</p>
    </div>

    <div class="games-list">
      {questionsList.map((item, index) => (
        <article class="game-card">
          <div class="game-header">
            <div class="game-title-area">
              <h2 class="game-title">Question #{index + 1}</h2>
              <div class="game-category">{item.category}</div>
            </div>
          </div>
          <p class="game-desc">{item.q}</p>
        </article>
      ))}
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <div class="faq-q">{item.q}</div>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</SiteLayout>
