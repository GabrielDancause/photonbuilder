    <div class="form-row">
      <div class="form-group" id="fg-gender">
        <label class="form-label">Gender</label>
        <select class="form-select" id="filter-gender">
          <option value="any">Any</option>
          <option value="male">Male</option>
          <option value="female">Female</option>
        </select>
      </div>
      <div class="form-group" id="fg-origin">
        <label class="form-label">Origin</label>
        <select class="form-select" id="filter-origin">
          <option value="any">Any</option>
          <option value="american">American</option>
          <option value="british">British</option>
          <option value="french">French</option>
          <option value="german">German</option>
          <option value="indian">Indian</option>
          <option value="italian">Italian</option>
          <option value="japanese">Japanese</option>
          <option value="spanish">Spanish</option>
        </select>
      </div>
      <div class="form-group" id="fg-letter">
        <label class="form-label">Starting Letter</label>
        <select class="form-select" id="filter-letter">
          <option value="any">Any</option>
        </select>
      </div>
    </div>
    <div class="form-row" id="genre-row" style="display:none;">
      <div class="form-group">
        <label class="form-label">Genre</label>
        <select class="form-select" id="filter-genre">
          <option value="fantasy">Fantasy</option>
          <option value="scifi">Sci-Fi</option>
          <option value="medieval">Medieval</option>
        </select>
      </div>
    </div>
    <div class="qty-row">
      <span class="form-label">Quantity</span>
      <input type="range" class="qty-slider" id="qty-slider" min="1" max="20" value="5">
      <span class="qty-val" id="qty-val">5</span>
    </div>
  </div>

  <!-- Generate button -->
  <div class="btn-row">
    <button id="btn-generate" class="btn-primary">Generate</button>
    <div class="generate-hint">or press <kbd>Space</kbd></div>
  </div>

  <!-- Favorites -->
  <div class="favorites-section" id="favorites-section">
    <div class="favorites-header">
      <h3>Favorites <span id="fav-count" style="font-weight:400;color:var(--text-secondary);font-size:0.85rem;"></span></h3>
      <div class="fav-actions">
        <button class="fav-action-btn" id="btn-copy-favs">Copy All</button>
        <button class="fav-action-btn" id="btn-clear-favs">Clear</button>
      </div>
    </div>
    <div id="favorites-list" class="favorites-list">
      <div class="favorites-empty">No favorites saved yet. Click the &#9825; on a name to save it.</div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {faqItems.map(item => (
      <div class="faq-item">
        <div class="faq-q">{item.q}</div>
        <div class="faq-a">{item.a}</div>
      </div>
    ))}
  </div>

  <!-- Related pages -->
  <div class="related-section">
    <h2>More Random Tools</h2>
    <div class="related-grid">
      <a href="/eeniemeenie/coin-flip" class="related-link">
        <h4>Coin Flip</h4>
        <p>Heads or tails? Flip a coin with realistic animation.</p>
      </a>
      <a href="/eeniemeenie/random-number-generator" class="related-link">
        <h4>Random Number Generator</h4>
        <p>Generate truly random numbers in any range you need.</p>
      </a>
    </div>
  </div>

</div>
</div>

<!-- Toast notification -->
<div class="toast" id="toast"></div>

