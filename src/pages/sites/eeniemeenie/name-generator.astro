  // ──── HELPERS ────

  function cryptoRandInt(min, max) {
    const range = max - min + 1;
    if (range <= 0) return min;
    const arr = new Uint32Array(1);
    crypto.getRandomValues(arr);
    return min + (arr[0] % range);
  }

  function pick(arr) { return arr[cryptoRandInt(0, arr.length - 1)]; }

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = cryptoRandInt(0, i);
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  let toastTimer;
  function showToast(msg) {
    clearTimeout(toastTimer);
    toastEl.textContent = msg;
    toastEl.classList.add('show');
    toastTimer = setTimeout(() => toastEl.classList.remove('show'), 2000);
  }

  function copyText(text) {
    navigator.clipboard.writeText(text).then(() => showToast('Copied!')).catch(() => showToast('Copy failed'));
  }

  // ──── NAME GENERATION ────

  function generateBabyName(gender, origin, letter) {
    let pool = [];
    if (gender === 'any') {
      pool = [...NAMES.male, ...NAMES.female];
    } else {
      pool = NAMES[gender];
    }
    if (origin !== 'any') pool = pool.filter(n => n.o === origin);
    if (letter !== 'any') pool = pool.filter(n => n.n[0].toUpperCase() === letter);
    if (pool.length === 0) return null;
    const chosen = pick(pool);
    const lastName = pick(LAST_NAMES);
    return { name: chosen.n + ' ' + lastName, meaning: chosen.m, origin: chosen.o, display: chosen.n + ' ' + lastName };
  }

  function generateCharacterName(genre, letter) {
    const data = CHARACTER_NAMES[genre];
    let firsts = data.first;
    if (letter !== 'any') firsts = firsts.filter(n => n[0].toUpperCase() === letter);
    if (firsts.length === 0) return null;
    const first = pick(firsts);
    const last = pick(data.last);
    return { name: first + ' ' + last, meaning: null, origin: genre, display: first + ' ' + last };
  }

  function generateBusinessName(letter) {
    let prefixes = BUSINESS_PREFIXES;
    if (letter !== 'any') prefixes = prefixes.filter(p => p[0].toUpperCase() === letter);
    if (prefixes.length === 0) return null;
    const prefix = pick(prefixes);
    const suffix = pick(BUSINESS_SUFFIXES);
    const name = prefix + ' ' + suffix;
    return { name, meaning: null, origin: null, display: name };
  }

  function generateUsername(letter) {
    let parts1 = USERNAME_PARTS1;
    if (letter !== 'any') parts1 = parts1.filter(p => p[0].toUpperCase() === letter);
    if (parts1.length === 0) return null;
    const p1 = pick(parts1);
    const p2 = pick(USERNAME_PARTS2);
    const num = cryptoRandInt(0, 1) ? '' + cryptoRandInt(1, 999) : '';
    const sep = pick(['', '_', '']);
    const name = p1 + sep + p2 + num;
    return { name, meaning: null, origin: null, display: name };
  }

  function generateNames() {
    const qty = parseInt(qtySlider.value);
