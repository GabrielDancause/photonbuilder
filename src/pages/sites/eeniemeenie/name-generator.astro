    const origin = filterOrigin.value;
    const letter = filterLetter.value;
    const genre = filterGenre.value;
    const results = [];
    let attempts = 0;
    const usedNames = new Set();

    while (results.length < qty && attempts < qty * 10) {
      attempts++;
      let result = null;
      switch (currentMode) {
        case 'baby': result = generateBabyName(gender, origin, letter); break;
        case 'character': result = generateCharacterName(genre, letter); break;
        case 'business': result = generateBusinessName(letter); break;
        case 'username': result = generateUsername(letter); break;
      }
      if (result && !usedNames.has(result.name)) {
        usedNames.add(result.name);
        results.push(result);
      }
    }

    lastResults = results;
    renderResults(results);
  }

  // ──── RENDERING ────

  function renderResults(results) {
    if (results.length === 0) {
      resultsGrid.innerHTML = '';
      resultsPlaceholder.style.display = 'block';
      resultsPlaceholder.textContent = 'No names match your filters. Try different options.';
      return;
    }
    resultsPlaceholder.style.display = 'none';
    resultsGrid.innerHTML = '';

    results.forEach((r, i) => {
      const card = document.createElement('div');
      card.className = 'name-card';
      card.style.animationDelay = (i * 0.05) + 's';

      const isFav = favorites.some(f => f.name === r.name);

      let metaText = '';
      if (r.meaning) metaText += r.meaning;
      if (r.origin && (currentMode === 'baby' || currentMode === 'character')) {
        metaText += (metaText ? ' \u00b7 ' : '') + r.origin.charAt(0).toUpperCase() + r.origin.slice(1);
      }

      card.innerHTML =
        '<div class="name-info">' +
          '<span class="name-text">' + escHtml(r.display) + '</span>' +
          (metaText ? '<span class="name-meta">' + escHtml(metaText) + '</span>' : '') +
        '</div>' +
        '<div class="name-actions">' +
          '<button class="name-action-btn" data-action="copy" title="Copy name">\u2398</button>' +
          '<button class="name-action-btn' + (isFav ? ' favorited' : '') + '" data-action="fav" title="' + (isFav ? 'Remove from favorites' : 'Add to favorites') + '">' + (isFav ? '\u2665' : '\u2661') + '</button>' +
        '</div>';

      card.querySelector('[data-action="copy"]').addEventListener('click', () => copyText(r.display));

      card.querySelector('[data-action="fav"]').addEventListener('click', function() {
        toggleFavorite(r);
        const nowFav = favorites.some(f => f.name === r.name);
        this.classList.toggle('favorited', nowFav);
        this.textContent = nowFav ? '\u2665' : '\u2661';
        this.title = nowFav ? 'Remove from favorites' : 'Add to favorites';
      });

      resultsGrid.appendChild(card);
    });
  }

  function escHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  // ──── FAVORITES ────

  function toggleFavorite(nameObj) {
    const idx = favorites.findIndex(f => f.name === nameObj.name);
    if (idx >= 0) {
      favorites.splice(idx, 1);
    } else {
      favorites.push({ name: nameObj.name, display: nameObj.display });
    }
    saveFavorites();
    renderFavorites();
  }

  function saveFavorites() {
    localStorage.setItem('nameGenFavorites', JSON.stringify(favorites));
  }

  function renderFavorites() {
    const list = document.getElementById('favorites-list');
    const count = document.getElementById('fav-count');
    count.textContent = favorites.length > 0 ? '(' + favorites.length + ')' : '';

    if (favorites.length === 0) {
      list.innerHTML = '<div class="favorites-empty">No favorites saved yet. Click the \u2661 on a name to save it.</div>';
      return;
    }

    list.innerHTML = '';
    favorites.forEach((fav, i) => {
      const item = document.createElement('div');
      item.className = 'fav-item';
      item.innerHTML =
        '<span class="fav-item-name">' + escHtml(fav.display) + '</span>' +
        '<div class="fav-item-actions">' +
          '<button class="fav-remove-btn" data-action="copy-fav" title="Copy">\u2398</button>' +
          '<button class="fav-remove-btn" data-action="remove-fav" title="Remove">\u2715</button>' +
        '</div>';

      item.querySelector('[data-action="copy-fav"]').addEventListener('click', () => copyText(fav.display));
      item.querySelector('[data-action="remove-fav"]').addEventListener('click', () => {
        favorites.splice(i, 1);
        saveFavorites();
        renderFavorites();
        if (lastResults.length) renderResults(lastResults);
      });

      list.appendChild(item);
    });
  }

  document.getElementById('btn-copy-favs').addEventListener('click', () => {
    if (favorites.length === 0) return showToast('No favorites to copy');
    copyText(favorites.map(f => f.display).join('\n'));
  });

  document.getElementById('btn-clear-favs').addEventListener('click', () => {
    if (favorites.length === 0) return;
    favorites = [];
    saveFavorites();
    renderFavorites();
    if (lastResults.length) renderResults(lastResults);
    showToast('Favorites cleared');
  });

  // ──── MODE SWITCHING ────

  function updateFormVisibility() {
    const isBaby = currentMode === 'baby';
    const isCharacter = currentMode === 'character';

    fgGender.style.display = isBaby ? '' : 'none';
    fgOrigin.style.display = isBaby ? '' : 'none';
    genreRow.style.display = isCharacter ? '' : 'none';
  }

  document.querySelectorAll('.mode-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentMode = tab.dataset.mode;
      updateFormVisibility();
    });
  });

  // ──── EVENTS ────

  qtySlider.addEventListener('input', () => { qtyVal.textContent = qtySlider.value; });

  btnGenerate.addEventListener('click', generateNames);

  document.addEventListener('keydown', (e) => {
    if (e.code === 'Space' && !e.repeat && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA' && e.target.tagName !== 'SELECT') {
      e.preventDefault();
      generateNames();
    }
  });

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => q.parentElement.classList.toggle('open'));
  });

  // ──── INIT ────
  updateFormVisibility();
  renderFavorites();

});
</script>
</SiteLayout>
