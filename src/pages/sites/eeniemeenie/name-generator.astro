---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Random Name Generator — Baby Names, Character Names & More', description: 'Generate random names instantly. Baby names with meanings, fantasy/sci-fi character names, business names, and usernames. Filter by gender, origin, and starting letter.', category: 'tool', published: '2026-03-21' };
const SITE_ID = 'eeniemeenie';

const faqItems = [
  { q: 'How does the random name generator work?', a: 'Our generator uses a built-in database of over 500 first names and 200 last names. When you click Generate, it randomly selects names using your browser\'s cryptographic randomness API (crypto.getRandomValues), ensuring each name is truly random and unpredictable.' },
  { q: 'Can I use the baby name generator to find names with specific meanings?', a: 'Yes! When you generate baby names, each result includes the name\'s meaning and cultural origin when available. You can also filter by origin (American, British, Japanese, Spanish, and more) to find names from specific cultures.' },
  { q: 'What types of character names can I generate?', a: 'The Character Names mode supports three genres: Fantasy (elven, dwarven, and mystical names), Sci-Fi (futuristic and space-themed names), and Medieval (historically inspired names). Each genre has its own unique name pool for authentic-sounding results.' },
  { q: 'Are the generated names free to use?', a: 'Absolutely. All names generated by this tool are free to use for any purpose — naming a baby, a fictional character, a business, or an online account. There are no restrictions or attribution required.' },
  { q: 'Can I save names I like?', a: 'Yes! Click the heart icon next to any generated name to save it to your favorites list. Your favorites are stored in your browser\'s local storage, so they persist between visits. You can also copy individual names or your entire favorites list to your clipboard.' },
  { q: 'How many names can I generate at once?', a: 'You can generate between 1 and 20 names at a time. Use the quantity slider or input field to set how many names you want. This works across all modes — baby names, character names, business names, and usernames.' },
  { q: 'What filters are available for name generation?', a: 'You can filter by gender (male, female, or any), cultural origin (American, British, Japanese, Spanish, Indian, French, German, Italian, and more), and starting letter (A–Z). Not all filters apply to every mode — for example, business names and usernames don\'t have gender filters.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} schema={faqSchema} canonical="https://eeniemeenie.photonbuilder.com/name-generator">
<style is:inline>

  .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    width: 100%;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Mode tabs */
  .mode-tabs {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2rem;
  }
  .mode-tab {
    padding: 0.6rem 1.2rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .mode-tab:hover { border-color: var(--accent-color); color: var(--text-primary); }
  .mode-tab.active { border-color: var(--accent-color); color: var(--accent-color); background: rgba(224, 64, 251, 0.08); }

  /* Results area */
  .results-area {
    width: 100%;
    max-width: 700px;
    min-height: 120px;
    margin-bottom: 1.5rem;
  }
  .results-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  .name-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    animation: nameSlide 0.35s ease-out both;
  }
  @keyframes nameSlide {
    0% { opacity: 0; transform: translateY(12px) scale(0.97); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .name-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
    flex: 1;
  }
  .name-text {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .name-meta {
    font-size: 0.78rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .name-actions {
    display: flex;
    gap: 0.35rem;
    flex-shrink: 0;
    margin-left: 0.75rem;
  }
  .name-action-btn {
    background: none;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-secondary);
    cursor: pointer;
    padding: 0.35rem 0.5rem;
    font-size: 0.85rem;
    transition: all 0.2s;
    line-height: 1;
  }
  .name-action-btn:hover { border-color: var(--accent-color); color: var(--accent-color); }
  .name-action-btn.favorited { color: #e91e63; border-color: #e91e63; }
  .results-placeholder {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.1rem;
    padding: 2.5rem 1rem;
  }

  /* Generator form */
  .generator-form {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    width: 100%;
    max-width: 700px;
    margin-bottom: 1.5rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; }
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .form-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }
  .form-select {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.65rem 0.75rem;
    border-radius: 6px;
    font-size: 1rem;
    font-family: var(--font-body);
    width: 100%;
    box-sizing: border-box;
    cursor: pointer;
  }
  .form-select:focus { outline: none; border-color: var(--accent-color); }

  .qty-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0;
  }
  .qty-slider {
    flex: 1;
    accent-color: var(--accent-color);
    height: 6px;
  }
  .qty-val {
    font-weight: 700;
    color: var(--accent-color);
    min-width: 2ch;
    text-align: center;
  }

  /* Buttons */
  .btn-primary {
    padding: 1rem 2.5rem;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.3rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:active { transform: scale(0.97); }
  .generate-hint {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }
  .btn-row {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  /* Favorites */
  .favorites-section {
    width: 100%;
    max-width: 700px;
    margin-top: 1.5rem;
  }
  .favorites-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .favorites-header h3 {
    color: var(--accent-color);
    margin: 0;
  }
  .fav-actions {
    display: flex;
    gap: 0.5rem;
  }
  .fav-action-btn {
    padding: 0.4rem 0.8rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .fav-action-btn:hover { border-color: var(--accent-color); color: var(--accent-color); }
  .favorites-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .fav-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: var(--bg-color);
    border-radius: 8px;
    font-size: 0.9rem;
  }
  .fav-item-name {
    font-weight: 600;
    color: var(--text-primary);
  }
  .fav-item-actions {
    display: flex;
    gap: 0.35rem;
  }
  .fav-remove-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0.2rem 0.4rem;
    transition: color 0.2s;
  }
  .fav-remove-btn:hover { color: #e91e63; }
  .favorites-empty {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-style: italic;
    text-align: center;
    padding: 1rem;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--card-bg);
    border: 1px solid var(--accent-color);
    color: var(--text-primary);
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    z-index: 1000;
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    pointer-events: none;
  }
  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  /* FAQ */
  .faq-section {
    margin-top: 3rem;
    max-width: 700px;
    width: 100%;
  }
  .faq-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
  }
  .faq-q {
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--accent-color);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item.open .faq-q::after { content: '−'; }
  .faq-a {
    color: var(--text-secondary);
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding-top: 0;
  }
  .faq-item.open .faq-a {
    max-height: 300px;
    padding-top: 0.75rem;
  }

  /* Related */
  .related-section {
    margin-top: 3rem;
    width: 100%;
  }
  .related-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
  }
  .related-link {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-link:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .related-link h4 { margin-bottom: 0.4rem; }
  .related-link p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; }

</style>
<div class="page-content">

<div class="hero">
  <h1>Random Name Generator</h1>
  <p>Generate random baby names, character names, business names, and usernames. Filter by gender, origin, and more.</p>
</div>

<div class="container">

  <!-- Mode tabs -->
  <div class="mode-tabs">
    <button class="mode-tab active" data-mode="baby">Baby Names</button>
    <button class="mode-tab" data-mode="character">Character Names</button>
    <button class="mode-tab" data-mode="business">Business Names</button>
    <button class="mode-tab" data-mode="username">Usernames</button>
  </div>

  <!-- Results -->
