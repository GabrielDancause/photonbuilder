---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Coin Flip — Flip a Coin Online', description: 'Flip a coin instantly with realistic 3D animation. Heads or tails? Supports multi-flip mode, custom coins, streak tracking, and full statistics.', category: 'tool', published: '2026-03-21' };
const SITE_ID = 'eeniemeenie';

const faqItems = [
  { q: 'Is this coin flip truly random?', a: 'Yes. Each flip uses the browser\'s built-in cryptographic random number generator (crypto.getRandomValues) which provides statistically uniform randomness — far more random than a physical coin toss, which can be influenced by technique, weight distribution, and air currents.' },
  { q: 'What are the odds of getting heads or tails?', a: 'Exactly 50/50 for each flip. Unlike a real coin, which studies have shown has a slight bias toward the side facing up at launch (~51%), our digital coin is perfectly fair with equal probability for both outcomes.' },
  { q: 'Can I flip multiple coins at once?', a: 'Yes! Use the multi-flip mode to flip 2, 5, 10, or 100 coins simultaneously. Results are displayed in a grid showing each individual outcome along with a summary of totals.' },
  { q: 'Can I customize what\'s on each side of the coin?', a: 'Absolutely. Click the "Custom Coin" toggle to enter your own text for each side. Use it for any two-option decision — pizza vs sushi, study vs play, or any binary choice you need to make.' },
  { q: 'What is the longest possible streak?', a: 'There\'s no theoretical limit. The probability of flipping the same result N times in a row is (1/2)^N. So 10 in a row happens about once every 1,024 sequences. The tool tracks your current and longest streak across all flips in the session.' },
  { q: 'Does the coin flip history persist between visits?', a: 'No. Your flip history and statistics reset each time you reload the page. This keeps things lightweight and private — no data is stored on any server or in your browser\'s local storage.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} schema={faqSchema}>
<style is:inline>

  .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    width: 100%;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Coin */
  .coin-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }
  .coin-stage {
    perspective: 800px;
    width: 200px;
    height: 200px;
    margin-bottom: 1.5rem;
    cursor: pointer;
  }
  .coin {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.1s;
  }
  .coin.flipping {
    animation: coinFlip 1.2s ease-in-out forwards;
  }
  .coin.flipping-tails {
    animation: coinFlipTails 1.2s ease-in-out forwards;
  }
  @keyframes coinFlip {
    0% { transform: rotateX(0deg) scale(1); }
    15% { transform: rotateX(360deg) scale(1.1) translateY(-30px); }
    30% { transform: rotateX(720deg) scale(1.15) translateY(-50px); }
    50% { transform: rotateX(1260deg) scale(1.1) translateY(-40px); }
    70% { transform: rotateX(1620deg) scale(1.05) translateY(-15px); }
    85% { transform: rotateX(1800deg) scale(1) translateY(5px); }
    92% { transform: rotateX(1800deg) translateY(-3px); }
    100% { transform: rotateX(1800deg) translateY(0); }
  }
  @keyframes coinFlipTails {
    0% { transform: rotateX(0deg) scale(1); }
    15% { transform: rotateX(360deg) scale(1.1) translateY(-30px); }
    30% { transform: rotateX(720deg) scale(1.15) translateY(-50px); }
    50% { transform: rotateX(1260deg) scale(1.1) translateY(-40px); }
    70% { transform: rotateX(1620deg) scale(1.05) translateY(-15px); }
    85% { transform: rotateX(1980deg) scale(1) translateY(5px); }
    92% { transform: rotateX(1980deg) translateY(-3px); }
    100% { transform: rotateX(1980deg) translateY(0); }
  }
  .coin-face {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    border: 6px solid;
    box-shadow: 0 0 30px rgba(224, 64, 251, 0.15), inset 0 0 30px rgba(0,0,0,0.2);
    user-select: none;
  }
  .coin-heads {
    background: linear-gradient(145deg, #2a1e34 0%, #1a1024 50%, #2a1e34 100%);
    border-color: var(--accent-color);
    color: var(--accent-color);
  }
  .coin-tails {
    background: linear-gradient(145deg, #1e2a34 0%, #0e1a24 50%, #1e2a34 100%);
    border-color: #00ACC1;
    color: #00ACC1;
    transform: rotateX(180deg);
  }
  .coin-face .coin-icon {
    font-size: 2.8rem;
    display: block;
    line-height: 1;
  }
  .coin-face .coin-label {
    display: block;
    font-size: 0.85rem;
    margin-top: 0.3rem;
    letter-spacing: 3px;
  }

  /* Result display */
  .result-display {
    min-height: 3rem;
    font-size: 2rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 1rem;
  }
  .result-display.celebrate {
    animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .result-heads { color: var(--accent-color); }
  .result-tails { color: #00ACC1; }
  @keyframes bounceIn {
    0% { transform: scale(0.5); opacity: 0; }
    60% { transform: scale(1.15); }
    100% { transform: scale(1); opacity: 1; }
  }

  /* Buttons */
  .btn-primary {
    padding: 1rem 2.5rem;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.3rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:active { transform: scale(0.97); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

  .flip-hint {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }

  /* Controls row */
  .controls-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .toggle-btn {
    padding: 0.5rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    border-radius: 6px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .toggle-btn:hover { border-color: var(--accent-color); color: var(--text-primary); }
  .toggle-btn.active { border-color: var(--accent-color); color: var(--accent-color); background: rgba(224, 64, 251, 0.08); }

  /* Cards / sections */
  .tools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  @media (max-width: 768px) {
    .tools-grid { grid-template-columns: 1fr; }
  }
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .card h3 {
    color: var(--accent-color);
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .stat-item {
    text-align: center;
    padding: 0.75rem;
    background: var(--bg-color);
    border-radius: 8px;
  }
  .stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 0.25rem;
  }

  /* History */
  .history-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    max-height: 200px;
    overflow-y: auto;
  }
  .history-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .chip-heads { background: rgba(224, 64, 251, 0.15); color: var(--accent-color); }
  .chip-tails { background: rgba(0, 172, 193, 0.15); color: #00ACC1; }
  .history-empty {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-style: italic;
  }

  /* Multi-flip */
  .multi-section { margin-top: 2rem; }
  .multi-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .multi-btn {
    padding: 0.5rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .multi-btn:hover { border-color: var(--accent-color); }
  .multi-results-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.75rem;
  }
  .multi-coin-result {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.5px;
  }
  .multi-heads { background: rgba(224, 64, 251, 0.2); color: var(--accent-color); border: 1px solid rgba(224, 64, 251, 0.3); }
  .multi-tails { background: rgba(0, 172, 193, 0.2); color: #00ACC1; border: 1px solid rgba(0, 172, 193, 0.3); }
  .multi-summary {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }
  .multi-summary strong { color: var(--text-primary); }

  /* Custom coin */
  .custom-section { margin-top: 1.5rem; }
  .custom-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
  .custom-input {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    font-size: 0.95rem;
    font-family: var(--font-body);
  }
  .custom-input:focus { outline: none; border-color: var(--accent-color); }
  .custom-input::placeholder { color: var(--text-secondary); }

  /* FAQ */
  .faq-section {
    margin-top: 3rem;
    max-width: 700px;
    width: 100%;
  }
  .faq-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
  }
  .faq-q {
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--accent-color);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item.open .faq-q::after {
    content: '−';
  }
  .faq-a {
    color: var(--text-secondary);
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding-top: 0;
  }
  .faq-item.open .faq-a {
    max-height: 300px;
    padding-top: 0.75rem;
  }

  /* Related */
  .related-section {
    margin-top: 3rem;
    width: 100%;
  }
  .related-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
  }
  .related-link {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-link:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .related-link h4 { margin-bottom: 0.4rem; }
  .related-link p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; }

</style>
<div class="page-content">

<div class="hero">
  <h1>Flip a Coin</h1>
  <p>Heads or tails? Click the coin, tap the button, or press spacebar. Instant, fair, and satisfying.</p>
</div>

<div class="container">

  <!-- Main coin area -->
  <div class="coin-area">
    <div class="coin-stage" id="coin-stage" title="Click to flip">
      <div class="coin" id="coin">
        <div class="coin-face coin-heads">
          <div>
            <span class="coin-icon">&#x1F451;</span>
            <span class="coin-label" id="heads-label">Heads</span>
          </div>
        </div>
        <div class="coin-face coin-tails">
          <div>
            <span class="coin-icon">&#x1F43E;</span>
            <span class="coin-label" id="tails-label">Tails</span>
          </div>
        </div>
      </div>
    </div>

    <div id="result-display" class="result-display"></div>

    <button id="btn-flip" class="btn-primary">FLIP</button>
    <div class="flip-hint">or press <kbd>Space</kbd></div>

    <div class="controls-row">
      <button id="btn-sound" class="toggle-btn active">Sound On</button>
      <button id="btn-custom" class="toggle-btn">Custom Coin</button>
      <button id="btn-reset" class="toggle-btn">Reset Stats</button>
    </div>

    <!-- Custom coin inputs (hidden by default) -->
    <div id="custom-section" class="custom-section" style="display:none;">
      <div class="custom-inputs">
        <input type="text" class="custom-input" id="custom-heads" placeholder="Side 1 (Heads)" maxlength="12">
        <input type="text" class="custom-input" id="custom-tails" placeholder="Side 2 (Tails)" maxlength="12">
      </div>
    </div>
  </div>

  <!-- Stats + History -->
  <div class="tools-grid">
    <div class="card">
      <h3>Statistics</h3>
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-value" id="stat-total">0</div>
          <div class="stat-label">Total Flips</div>
        </div>
        <div class="stat-item">
          <div class="stat-value" id="stat-heads">0%</div>
          <div class="stat-label">Heads</div>
        </div>
        <div class="stat-item">
          <div class="stat-value" id="stat-tails">0%</div>
          <div class="stat-label">Tails</div>
        </div>
        <div class="stat-item">
          <div class="stat-value" id="stat-streak">0</div>
          <div class="stat-label">Current Streak</div>
        </div>
        <div class="stat-item">
          <div class="stat-value" id="stat-longest">0</div>
          <div class="stat-label">Longest Streak</div>
        </div>
        <div class="stat-item">
          <div class="stat-value" id="stat-longest-type">—</div>
          <div class="stat-label">Streak Side</div>
        </div>
      </div>
    </div>
    <div class="card">
      <h3>History <span id="history-count" style="font-weight:400;color:var(--text-secondary);font-size:0.85rem;">(last 20)</span></h3>
      <div id="history-list" class="history-list">
        <span class="history-empty">No flips yet — give it a go!</span>
      </div>
    </div>
  </div>

  <!-- Multi-flip -->
  <div class="card multi-section">
    <h3>Multi-Flip Mode</h3>
    <p style="color:var(--text-secondary);font-size:0.9rem;margin-bottom:1rem;">Flip multiple coins at once and see the distribution.</p>
    <div class="multi-buttons">
      <button class="multi-btn" data-count="2">Flip 2</button>
      <button class="multi-btn" data-count="5">Flip 5</button>
      <button class="multi-btn" data-count="10">Flip 10</button>
      <button class="multi-btn" data-count="100">Flip 100</button>
    </div>
    <div id="multi-results"></div>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {faqItems.map(item => (
      <div class="faq-item">
        <div class="faq-q">{item.q}</div>
        <div class="faq-a">{item.a}</div>
      </div>
    ))}
  </div>

  <!-- Related pages -->
  <div class="related-section">
    <h2>More Random Tools</h2>
    <div class="related-grid">
      <a href="/eeniemeenie/wheel-spinner" class="related-link">
        <h4>Wheel Spinner</h4>
        <p>Add your options and let the wheel decide for you.</p>
      </a>
      <a href="/eeniemeenie/random-number-generator" class="related-link">
        <h4>Random Number Generator</h4>
        <p>Generate random numbers in any range instantly.</p>
      </a>
      <a href="/eeniemeenie/name-generator" class="related-link">
        <h4>Name Generator</h4>
        <p>Pick a random name from your list in one click.</p>
      </a>
    </div>
  </div>

</div>
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {

  const coin = document.getElementById('coin');
  const coinStage = document.getElementById('coin-stage');
  const btnFlip = document.getElementById('btn-flip');
  const resultDisplay = document.getElementById('result-display');
  const btnSound = document.getElementById('btn-sound');
  const btnCustom = document.getElementById('btn-custom');
  const btnReset = document.getElementById('btn-reset');
  const customSection = document.getElementById('custom-section');
  const customHeadsInput = document.getElementById('custom-heads');
  const customTailsInput = document.getElementById('custom-tails');
  const headsLabel = document.getElementById('heads-label');
  const tailsLabel = document.getElementById('tails-label');
  const historyList = document.getElementById('history-list');

  let isFlipping = false;
  let soundEnabled = true;
  let customMode = false;
  let audioCtx = null;

  // Stats
  let totalFlips = 0;
  let headsCount = 0;
  let tailsCount = 0;
  let currentStreak = 0;
  let currentStreakSide = null;
  let longestStreak = 0;
  let longestStreakSide = null;
  let history = [];

  function getRandomResult() {
    const arr = new Uint32Array(1);
    crypto.getRandomValues(arr);
    return arr[0] % 2 === 0 ? 'heads' : 'tails';
  }

  function getSideName(side) {
    if (customMode) {
      const h = customHeadsInput.value.trim();
      const t = customTailsInput.value.trim();
      return side === 'heads' ? (h || 'Heads') : (t || 'Tails');
    }
    return side === 'heads' ? 'Heads' : 'Tails';
  }

  function playFlipSound() {
    if (!soundEnabled) return;
    try {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      // Coin toss whoosh + clink
      const now = audioCtx.currentTime;

      // Whoosh noise
      const bufferSize = audioCtx.sampleRate * 0.15;
      const noiseBuffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
      const data = noiseBuffer.getChannelData(0);
      for (let i = 0; i < bufferSize; i++) {
        data[i] = (Math.random() * 2 - 1) * (1 - i / bufferSize) * 0.15;
      }
      const noiseSource = audioCtx.createBufferSource();
      noiseSource.buffer = noiseBuffer;
      const noiseFilter = audioCtx.createBiquadFilter();
      noiseFilter.type = 'bandpass';
      noiseFilter.frequency.value = 3000;
      noiseSource.connect(noiseFilter);
      noiseFilter.connect(audioCtx.destination);
      noiseSource.start(now);

      // Metal clink at end
      setTimeout(() => {
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(4200, audioCtx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(2800, audioCtx.currentTime + 0.08);
        gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.15);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start(audioCtx.currentTime);
        osc.stop(audioCtx.currentTime + 0.15);
      }, 1000);
    } catch(e) {}
  }

  function flipCoin() {
    if (isFlipping) return;
    isFlipping = true;
    btnFlip.disabled = true;
    resultDisplay.textContent = '';
    resultDisplay.className = 'result-display';

    const result = getRandomResult();

    // Remove previous animation classes
    coin.classList.remove('flipping', 'flipping-tails');
    // Reset transform to start position
    coin.style.transform = 'rotateX(0deg)';
    void coin.offsetWidth; // force reflow

    playFlipSound();

    // Apply animation
    if (result === 'heads') {
      coin.classList.add('flipping');
    } else {
      coin.classList.add('flipping-tails');
    }

    setTimeout(() => {
      isFlipping = false;
      btnFlip.disabled = false;

      // Record result
      recordFlip(result);

      const name = getSideName(result);
      resultDisplay.textContent = name;
      resultDisplay.classList.add('celebrate', result === 'heads' ? 'result-heads' : 'result-tails');
    }, 1250);
  }

  function recordFlip(result) {
    totalFlips++;
    if (result === 'heads') headsCount++;
    else tailsCount++;

    // Streak
    if (result === currentStreakSide) {
      currentStreak++;
    } else {
      currentStreak = 1;
      currentStreakSide = result;
    }
    if (currentStreak > longestStreak) {
      longestStreak = currentStreak;
      longestStreakSide = currentStreakSide;
    }

    // History
    history.unshift(result);
    if (history.length > 20) history.pop();

    updateUI();
  }

  function updateUI() {
    // Stats
    document.getElementById('stat-total').textContent = totalFlips;
    document.getElementById('stat-heads').textContent = totalFlips > 0 ? ((headsCount / totalFlips) * 100).toFixed(1) + '%' : '0%';
    document.getElementById('stat-tails').textContent = totalFlips > 0 ? ((tailsCount / totalFlips) * 100).toFixed(1) + '%' : '0%';
    document.getElementById('stat-streak').textContent = currentStreak;
    document.getElementById('stat-longest').textContent = longestStreak;
    document.getElementById('stat-longest-type').textContent = longestStreakSide ? getSideName(longestStreakSide) : '—';

    // History
    if (history.length === 0) {
      historyList.innerHTML = '<span class="history-empty">No flips yet — give it a go!</span>';
    } else {
      historyList.innerHTML = history.map((h, i) => {
        const name = getSideName(h);
        const cls = h === 'heads' ? 'chip-heads' : 'chip-tails';
        return '<span class="history-chip ' + cls + '">' + (totalFlips - i) + '. ' + name + '</span>';
      }).join('');
    }
  }

  // Flip button + coin click
  btnFlip.addEventListener('click', flipCoin);
  coinStage.addEventListener('click', flipCoin);

  // Spacebar
  document.addEventListener('keydown', (e) => {
    if (e.code === 'Space' && !e.repeat && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
      e.preventDefault();
      flipCoin();
    }
  });

  // Sound toggle
  btnSound.addEventListener('click', () => {
    soundEnabled = !soundEnabled;
    btnSound.textContent = soundEnabled ? 'Sound On' : 'Sound Off';
    btnSound.classList.toggle('active', soundEnabled);
  });

  // Custom coin toggle
  btnCustom.addEventListener('click', () => {
    customMode = !customMode;
    btnCustom.classList.toggle('active', customMode);
    customSection.style.display = customMode ? 'block' : 'none';
    updateCoinLabels();
  });

  function updateCoinLabels() {
    if (customMode) {
      headsLabel.textContent = customHeadsInput.value.trim() || 'Heads';
      tailsLabel.textContent = customTailsInput.value.trim() || 'Tails';
    } else {
      headsLabel.textContent = 'Heads';
      tailsLabel.textContent = 'Tails';
    }
  }

  customHeadsInput.addEventListener('input', updateCoinLabels);
  customTailsInput.addEventListener('input', updateCoinLabels);

  // Reset
  btnReset.addEventListener('click', () => {
    totalFlips = 0; headsCount = 0; tailsCount = 0;
    currentStreak = 0; currentStreakSide = null;
    longestStreak = 0; longestStreakSide = null;
    history = [];
    resultDisplay.textContent = '';
    resultDisplay.className = 'result-display';
    document.getElementById('multi-results').innerHTML = '';
    updateUI();
  });

  // Multi-flip
  document.querySelectorAll('.multi-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const count = parseInt(btn.dataset.count);
      const results = [];
      for (let i = 0; i < count; i++) {
        results.push(getRandomResult());
      }
      const mHeads = results.filter(r => r === 'heads').length;
      const mTails = count - mHeads;

      // Record all into stats
      results.forEach(r => recordFlip(r));

      const container = document.getElementById('multi-results');
      let html = '<div class="multi-results-grid">';
      results.forEach(r => {
        const cls = r === 'heads' ? 'multi-heads' : 'multi-tails';
        const label = r === 'heads' ? 'H' : 'T';
        html += '<div class="multi-coin-result ' + cls + '">' + label + '</div>';
      });
      html += '</div>';
      html += '<div class="multi-summary"><strong>' + mHeads + '</strong> heads (' + ((mHeads/count)*100).toFixed(1) + '%) &nbsp;·&nbsp; <strong>' + mTails + '</strong> tails (' + ((mTails/count)*100).toFixed(1) + '%)</div>';
      container.innerHTML = html;
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement.classList.toggle('open');
    });
  });

});
</script>
</SiteLayout>
