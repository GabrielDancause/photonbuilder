      </div>
    </div>

    <div class="main-card" id="question-card">
      <div class="card-header">
        <span class="category-badge" id="current-category">Category</span>
        <span class="streak-counter">Streak: <span id="streak-val">0</span></span>
      </div>

      <div class="timer-bar-container" id="timer-bar-container" style="display:none;">
        <div class="timer-bar-fill" id="timer-bar-fill"></div>
      </div>

      <div class="question-text">Would you rather...</div>

      <div class="options-container" id="options-container">
        <div class="option-btn" id="btn-opt1" data-option="1">
          <span class="option-text" id="text-opt1">Loading...</span>
          <div class="vote-bar" id="bar-opt1"></div>
          <span class="vote-pct" id="pct-opt1"></span>
        </div>
        <div class="or-divider">OR</div>
        <div class="option-btn" id="btn-opt2" data-option="2">
          <span class="option-text" id="text-opt2">Loading...</span>
          <div class="vote-bar" id="bar-opt2"></div>
          <span class="vote-pct" id="pct-opt2"></span>
        </div>
      </div>

      <div class="action-buttons">
        <button class="primary-btn" id="next-btn">Next Question &rarr;</button>
        <button class="secondary-btn" id="share-btn" style="margin-top: 1rem; width: 100%; max-width: 300px; display: none;">Share as Image 📸</button>
      </div>
    </div>

    <div class="custom-card">
      <h3>Create Custom Question</h3>
      <div class="custom-inputs">
        <input type="text" id="custom-opt1" placeholder="Option 1..." />
        <span class="custom-or">OR</span>
        <input type="text" id="custom-opt2" placeholder="Option 2..." />
      </div>
      <button class="secondary-btn" id="create-custom-btn">Play Custom</button>
    </div>
  </div>

  <style is:global>
    :root {
      --accent: #EC4899;
      --accent-hover: #BE185D;
      --bg-dark: #1F2937;
      --bg-card: #374151;
      --text-main: #F9FAFB;
      --text-muted: #9CA3AF;
      --timer-color: #FBBF24;
      --opt1-color: #3B82F6;
      --opt2-color: #10B981;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      font-family: system-ui, -apple-system, sans-serif;
    }

    .calculator-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .calculator-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .calculator-header h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      color: var(--accent);
    }

    .subtitle {
      color: var(--text-muted);
      font-size: 1.1rem;
    }

    .controls-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: var(--bg-card);
      padding: 1rem;
      border-radius: 0.5rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    select, input[type="text"] {
      background: var(--bg-dark);
      color: var(--text-main);
      border: 1px solid #4B5563;
      padding: 0.5rem;
      border-radius: 0.25rem;
    }

    .main-card {
      background: var(--bg-card);
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
      position: relative;
      overflow: hidden;
      margin-bottom: 2rem;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 1rem;
      font-size: 0.9rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .category-badge {
      background: var(--accent);
      color: white;
      padding: 0.2rem 0.5rem;
      border-radius: 0.25rem;
      font-weight: bold;
    }

    .question-text {
      font-size: 2rem;
      font-weight: 800;
      text-align: center;
      margin: 1.5rem 0 2rem;
    }

    .options-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: relative;
    }

    @media (min-width: 640px) {
      .options-container {
        flex-direction: row;
        align-items: stretch;
      }
    }

    .option-btn {
      flex: 1;
      background: var(--bg-dark);
      border: 2px solid transparent;
      border-radius: 0.5rem;
      padding: 2rem 1rem;
      text-align: center;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 150px;
    }

    .option-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.3);
    }

    .option-btn.selected {
      border-color: var(--accent);
    }

    #btn-opt1:hover { border-color: var(--opt1-color); }
    #btn-opt2:hover { border-color: var(--opt2-color); }

    .option-text {
      font-size: 1.25rem;
      font-weight: 600;
      position: relative;
      z-index: 2;
    }

    .vote-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 0%;
      width: 100%;
      z-index: 1;
      transition: height 1s cubic-bezier(0.4, 0, 0.2, 1);
      opacity: 0.3;
    }

    #bar-opt1 { background-color: var(--opt1-color); }
    #bar-opt2 { background-color: var(--opt2-color); }

    .vote-pct {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      font-size: 1.5rem;
      font-weight: bold;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.5s ease;
    }

    .show-results .vote-pct {
      opacity: 1;
    }

    .or-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      color: var(--text-muted);
      padding: 1rem;
    }

    @media (min-width: 640px) {
      .or-divider {
        padding: 0 1rem;
      }
    }

    .action-buttons {
      margin-top: 2rem;
      text-align: center;
    }

    .primary-btn, .secondary-btn {
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 0.5rem;
      font-size: 1.1rem;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.2s;
    }

    .primary-btn {
      background: var(--accent);
      color: white;
      width: 100%;
      max-width: 300px;
    }

    .primary-btn:hover { background: var(--accent-hover); }
    .primary-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .secondary-btn {
      background: #4B5563;
      color: white;
    }
    .secondary-btn:hover { background: #6B7280; }

    .timer-bar-container {
      height: 6px;
      background: var(--bg-dark);
      border-radius: 3px;
      margin-bottom: 1rem;
      overflow: hidden;
    }

    .timer-bar-fill {
      height: 100%;
      background: var(--timer-color);
      width: 100%;
    }

    .custom-card {
      background: var(--bg-card);
      border-radius: 1rem;
      padding: 1.5rem;
      text-align: center;
    }

    .custom-inputs {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin: 1rem 0;
    }

    @media (min-width: 640px) {
      .custom-inputs {
        flex-direction: row;
        align-items: center;
      }
    }

    .custom-inputs input {
      flex: 1;
    }

    .custom-or {
      font-weight: bold;
      color: var(--text-muted);
    }
  </style>

  <script is:inline define:vars={{ ALL_QUESTIONS }}>
    (function() {
      const questions = ALL_QUESTIONS;
      let localVotes = JSON.parse(localStorage.getItem('wyr_votes') || '{}');
      let currentQuestion = null;
      let streak = 0;
      let timerInterval = null;
      let timeLeft = 100; // percent
      let hasVoted = false;

      const els = {
        catFilter: document.getElementById('category-filter'),
        partyMode: document.getElementById('party-mode-toggle'),
        catBadge: document.getElementById('current-category'),
        streakVal: document.getElementById('streak-val'),
        timerContainer: document.getElementById('timer-bar-container'),
        timerFill: document.getElementById('timer-bar-fill'),
        btnOpt1: document.getElementById('btn-opt1'),
        btnOpt2: document.getElementById('btn-opt2'),
        textOpt1: document.getElementById('text-opt1'),
        textOpt2: document.getElementById('text-opt2'),
        barOpt1: document.getElementById('bar-opt1'),
        barOpt2: document.getElementById('bar-opt2'),
        pctOpt1: document.getElementById('pct-opt1'),
        pctOpt2: document.getElementById('pct-opt2'),
        nextBtn: document.getElementById('next-btn'),
        optionsContainer: document.getElementById('options-container'),
        shareBtn: document.getElementById('share-btn'),
        cust1: document.getElementById('custom-opt1'),
        cust2: document.getElementById('custom-opt2'),
        custBtn: document.getElementById('create-custom-btn'),
        card: document.getElementById('question-card')
      };

      function getRandomQuestion(category) {
        let pool = questions;
        if (category !== 'all') {
          pool = questions.filter(q => q.category === category);
        }
        return pool[Math.floor(Math.random() * pool.length)];
      }

      function startTimer() {
        clearInterval(timerInterval);
        els.timerContainer.style.display = els.partyMode.checked ? 'block' : 'none';
        if (!els.partyMode.checked) return;

        timeLeft = 100;
        els.timerFill.style.width = '100%';
        els.timerFill.style.background = 'var(--timer-color)';

        timerInterval = setInterval(() => {
          timeLeft -= 0.5; // roughly 10 seconds total
          els.timerFill.style.width = timeLeft + '%';

          if (timeLeft < 30) els.timerFill.style.background = '#EF4444'; // red

          if (timeLeft <= 0) {
            clearInterval(timerInterval);
            if (!hasVoted) {
              streak = 0;
              updateStreak();
              revealResults(0); // 0 means time up, no selection
            }
          }
        }, 50);
      }

      function loadQuestion(q) {
        currentQuestion = q;
        hasVoted = false;

        els.catBadge.textContent = q.category === 'custom' ? 'Custom' : q.category;
        els.textOpt1.textContent = q.option1;
        els.textOpt2.textContent = q.option2;

        // Reset styles
        els.optionsContainer.classList.remove('show-results');
        els.btnOpt1.classList.remove('selected');
        els.btnOpt2.classList.remove('selected');
        els.barOpt1.style.height = '0%';
        els.barOpt2.style.height = '0%';
        els.pctOpt1.textContent = '';
        els.pctOpt2.textContent = '';
        els.nextBtn.disabled = true;
        els.shareBtn.style.display = 'none';

        startTimer();
      }

      function updateStreak() {
        els.streakVal.textContent = streak;
      }

      function revealResults(selectedOpt) {
        hasVoted = true;
        clearInterval(timerInterval);

        if (selectedOpt > 0) {
          streak++;
          updateStreak();
        }

        els.optionsContainer.classList.add('show-results');

        // Add real local vote
        let v1 = currentQuestion.votes1 || 0;
        let v2 = currentQuestion.votes2 || 0;

        if (localVotes[currentQuestion.id]) {
            if (localVotes[currentQuestion.id] === 1) v1++;
            if (localVotes[currentQuestion.id] === 2) v2++;
        }

        if (selectedOpt === 1) {
            v1++;
            localVotes[currentQuestion.id] = 1;
        }
        if (selectedOpt === 2) {
            v2++;
            localVotes[currentQuestion.id] = 2;
        }

        localStorage.setItem('wyr_votes', JSON.stringify(localVotes));

        const total = v1 + v2;
        const p1 = total > 0 ? Math.round((v1 / total) * 100) : 50;
        const p2 = 100 - p1;

        els.pctOpt1.textContent = p1 + '%';
        els.pctOpt2.textContent = p2 + '%';

        els.barOpt1.style.height = p1 + '%';
        els.barOpt2.style.height = p2 + '%';

        if (selectedOpt === 1) els.btnOpt1.classList.add('selected');
        if (selectedOpt === 2) els.btnOpt2.classList.add('selected');

        els.nextBtn.disabled = false;
        els.shareBtn.style.display = 'inline-block';
      }

      function drawCardToCanvas() {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = 800;
        canvas.height = 600;

        // Background
        ctx.fillStyle = '#374151';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Header
        ctx.fillStyle = '#EC4899';
        ctx.font = 'bold 24px system-ui, sans-serif';
        ctx.fillText(els.catBadge.textContent.toUpperCase(), 40, 50);

        ctx.fillStyle = '#9CA3AF';
        ctx.textAlign = 'right';
        ctx.fillText('Streak: ' + streak, 760, 50);

        // Question
        ctx.fillStyle = '#F9FAFB';
        ctx.textAlign = 'center';
        ctx.font = 'bold 40px system-ui, sans-serif';
        ctx.fillText('Would you rather...', 400, 120);

        // Options boxes
        function drawOption(x, y, text, pct, isOpt1) {
            ctx.fillStyle = '#1F2937';
            ctx.beginPath();
            ctx.roundRect(x, y, 320, 300, 10);
            ctx.fill();

            // Vote bar
            ctx.fillStyle = isOpt1 ? 'rgba(59, 130, 246, 0.3)' : 'rgba(16, 185, 129, 0.3)';
            const h = 300 * (parseInt(pct) / 100);
            ctx.beginPath();
            ctx.roundRect(x, y + 300 - h, 320, h, 10);
            ctx.fill();

            // Text
            ctx.fillStyle = '#F9FAFB';
            ctx.font = 'bold 24px system-ui, sans-serif';
            ctx.textAlign = 'center';

            // simple text wrap
            const words = text.split(' ');
            let line = '';
            let lineY = y + 150;
            for(let n = 0; n < words.length; n++) {
                const testLine = line + words[n] + ' ';
                const metrics = ctx.measureText(testLine);
                if (metrics.width > 280 && n > 0) {
                    ctx.fillText(line, x + 160, lineY);
                    line = words[n] + ' ';
                    lineY += 30;
                } else {
                    line = testLine;
                }
            }
            ctx.fillText(line, x + 160, lineY);

            // Pct
            ctx.fillStyle = '#F9FAFB';
            ctx.font = 'bold 32px system-ui, sans-serif';
            ctx.textAlign = 'right';
            ctx.fillText(pct, x + 300, y + 40);
        }

        drawOption(50, 180, currentQuestion.option1, els.pctOpt1.textContent, true);

        ctx.fillStyle = '#9CA3AF';
        ctx.textAlign = 'center';
        ctx.font = 'bold 24px system-ui, sans-serif';
        ctx.fillText('OR', 400, 330);

        drawOption(430, 180, currentQuestion.option2, els.pctOpt2.textContent, false);

        // Branding
        ctx.fillStyle = '#EC4899';
        ctx.font = 'bold 20px system-ui, sans-serif';
        ctx.fillText('EenieMeenie', 400, 560);

        return canvas;
      }

      // Events
      els.btnOpt1.addEventListener('click', () => !hasVoted && revealResults(1));
      els.btnOpt2.addEventListener('click', () => !hasVoted && revealResults(2));

      els.nextBtn.addEventListener('click', () => {
        loadQuestion(getRandomQuestion(els.catFilter.value));
      });

      els.catFilter.addEventListener('change', () => {
        streak = 0;
        updateStreak();
        loadQuestion(getRandomQuestion(els.catFilter.value));
      });

      els.partyMode.addEventListener('change', () => {
        streak = 0;
        updateStreak();
        loadQuestion(getRandomQuestion(els.catFilter.value));
      });

      els.shareBtn.addEventListener('click', () => {
        const canvas = drawCardToCanvas();
        canvas.toBlob((blob) => {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'would-you-rather.png';
            a.click();
            URL.revokeObjectURL(url);
        });
      });

      els.custBtn.addEventListener('click', () => {
        const o1 = els.cust1.value.trim();
        const o2 = els.cust2.value.trim();
        if (o1 && o2) {
          const customQ = {
            id: 'custom_' + Date.now(),
            category: 'custom',
            option1: o1,
            option2: o2,
            votes1: 0,
            votes2: 0
          };
          loadQuestion(customQ);
          els.cust1.value = '';
          els.cust2.value = '';
          // scroll to top
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });

      // Init
      loadQuestion(getRandomQuestion('all'));
    })();
  </script>
</SiteLayout>
