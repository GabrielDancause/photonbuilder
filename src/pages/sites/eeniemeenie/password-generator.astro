  .multi-count-btn.active { border-color: var(--accent-color); color: var(--accent-color); background: rgba(224, 64, 251, 0.08); }
  .mode-generate-btn {
    padding: 0.6rem 1.2rem;
    background: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
    width: 100%;
  }
  .mode-generate-btn:hover { opacity: 0.9; }
  .multi-results {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .multi-result-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--bg-color);
    border-radius: 6px;
  }
  .multi-result-text {
    flex: 1;
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    word-break: break-all;
  }
  .multi-copy-btn {
    padding: 0.3rem 0.6rem;
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .multi-copy-btn:hover { border-color: var(--accent-color); color: var(--accent-color); }
  .multi-copy-btn.copied { border-color: #4caf50; color: #4caf50; }

  /* FAQ */
  .faq-section {
    margin-top: 3rem;
    max-width: 700px;
    width: 100%;
  }
  .faq-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .faq-item {
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 0;
  }
  .faq-q {
    font-weight: 700;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .faq-q::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--accent-color);
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .faq-item.open .faq-q::after {
    content: '−';
  }
  .faq-a {
    color: var(--text-secondary);
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding-top: 0;
  }
  .faq-item.open .faq-a {
    max-height: 300px;
    padding-top: 0.75rem;
  }

  /* Related */
  .related-section {
    margin-top: 3rem;
    width: 100%;
  }
  .related-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--accent-color);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (max-width: 600px) {
    .related-grid { grid-template-columns: 1fr; }
  }
  .related-link {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: border-color 0.2s, transform 0.2s;
  }
  .related-link:hover { border-color: var(--accent-color); transform: translateY(-2px); }
  .related-link h4 { margin-bottom: 0.4rem; }
  .related-link p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; }

</style>
<div class="page-content">

<div style="max-width:800px;margin:0 auto;padding:16px 20px 0;">
