    'pool','poor','pope','pork','port','pose','post','pour','pray','prev','prey','prop','pull','pump','pure','push','quit','race','rack','rage',
    'raid','rail','rain','rank','rare','rate','read','real','rear','reef','rein','rely','rent','rest','rice','rich','ride','ring','rise','risk',
    'road','rock','rode','role','roll','roof','room','root','rope','rose','ruin','rule','rush','ruth','sack','safe','sage','said','sail','sake',
    'sale','salt','same','sand','sang','save','seal','seat','seed','seek','seem','seen','self','sell','send','sept','shed','ship','shop','shot',
    'show','shut','sick','side','sign','silk','sing','sink','site','size','skip','slam','slap','slim','slip','slot','slow','snap','snow','soap',
    'sock','soft','soil','sold','sole','some','song','soon','sort','soul','spin','spot','star','stay','stem','step','stir','stop','such','suit',
    'sure','swim','tale','talk','tall','tank','tape','task','taxi','team','tear','tell','tend','tent','term','test','text','than','that','them',
    'then','they','thin','this','thus','tide','tidy','tier','till','time','tiny','tire','told','toll','tone','took','tool','tops','tore','torn',
    'tour','town','trap','tray','tree','trim','trip','true','tube','tuck','tune','turn','twin','type','ugly','unit','unto','upon','urge','used',
    'user','vale','vary','vast','very','vice','view','vine','visa','void','volt','vote','wade','wage','wait','wake','walk','wall','want','ward',
    'warm','warn','wash','vast','wave','weak','wear','weed','week','well','went','were','west','what','when','whom','wide','wife','wild','will',
    'wind','wine','wing','wire','wise','wish','with','woke','wood','wool','word','wore','work','worm','worn','wrap','yard','yeah','year','yoga',
    'your','zero','zone','zoom'
  ];

  // Crypto random int in [min, max]
  function cryptoRandInt(min, max) {
    const range = max - min + 1;
    if (range <= 0) return min;
    const arr = new Uint32Array(1);
    crypto.getRandomValues(arr);
    return min + (arr[0] % range);
  }

  function buildCharset() {
    let charset = '';
    if (opts.upper) charset += UPPER;
    if (opts.lower) charset += LOWER;
    if (opts.numbers) charset += NUMBERS;
    if (opts.symbols) charset += SYMBOLS;
    if (opts.excludeAmbiguous) {
      charset = charset.split('').filter(c => !AMBIGUOUS.includes(c)).join('');
    }
    return charset;
  }

  function generatePassword() {
    if (mode === 'passphrase') {
      return generatePassphrase();
    }
    const charset = buildCharset();
    if (charset.length === 0) return '';
    const length = parseInt(lengthSlider.value);
    let pw = '';
    for (let i = 0; i < length; i++) {
      pw += charset[cryptoRandInt(0, charset.length - 1)];
    }
    return pw;
  }

  function generatePassphrase() {
    const count = parseInt(wordsSlider.value);
    const words = [];
    for (let i = 0; i < count; i++) {
      words.push(WORDLIST[cryptoRandInt(0, WORDLIST.length - 1)]);
    }
    return words.join('-');
  }

  function calcEntropy(pw) {
    if (mode === 'passphrase') {
      const wordCount = pw.split('-').length;
      return Math.round(wordCount * Math.log2(WORDLIST.length) * 100) / 100;
    }
    const charset = buildCharset();
    if (charset.length === 0) return 0;
    return Math.round(pw.length * Math.log2(charset.length) * 100) / 100;
  }

  function getStrength(entropy) {
    if (entropy < 28) return { label: 'Very Weak', color: '#f44336', pct: 10 };
    if (entropy < 36) return { label: 'Weak', color: '#ff9800', pct: 25 };
    if (entropy < 60) return { label: 'Fair', color: '#ffc107', pct: 50 };
    if (entropy < 80) return { label: 'Strong', color: '#8bc34a', pct: 75 };
    return { label: 'Very Strong', color: '#4caf50', pct: 100 };
  }

  function highlightPassword(pw) {
    if (mode === 'passphrase') return document.createTextNode(pw);
    const frag = document.createDocumentFragment();
    for (const ch of pw) {
      const span = document.createElement('span');
      span.textContent = ch;
      if (/[A-Z]/.test(ch)) span.className = 'char-upper';
      else if (/[0-9]/.test(ch)) span.className = 'char-num';
      else if (/[^a-zA-Z0-9]/.test(ch)) span.className = 'char-sym';
      frag.appendChild(span);
    }
    return frag;
  }

  function displayPassword(pw) {
    currentPassword = pw;
    passwordText.innerHTML = '';
    if (!pw) {
      passwordText.innerHTML = '<span style="color:var(--text-secondary);font-weight:400;">No character types selected</span>';
      strengthBar.style.width = '0';
      strengthLabel.textContent = '—';
      strengthLabel.style.color = 'var(--text-secondary)';
      entropyDisplay.textContent = '0 bits of entropy';
      return;
    }
    passwordText.appendChild(highlightPassword(pw));

    const entropy = calcEntropy(pw);
    const strength = getStrength(entropy);
    strengthBar.style.width = strength.pct + '%';
    strengthBar.style.backgroundColor = strength.color;
    strengthLabel.textContent = strength.label;
    strengthLabel.style.color = strength.color;
    entropyDisplay.textContent = entropy + ' bits of entropy';
  }

  function doGenerate() {
    const pw = generatePassword();
    displayPassword(pw);
    btnCopy.textContent = 'Copy';
    btnCopy.classList.remove('copied');
  }

  // Mode tabs
  document.querySelectorAll('.mode-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      mode = tab.dataset.mode;
      document.querySelectorAll('.mode-tab').forEach(t => t.classList.toggle('active', t === tab));
      passwordOptions.classList.toggle('hidden', mode === 'passphrase');
      passphraseOptions.classList.toggle('visible', mode === 'passphrase');
      doGenerate();
    });
  });

  // Length slider
  lengthSlider.addEventListener('input', () => {
    lengthValue.textContent = lengthSlider.value;
    doGenerate();
  });

  // Words slider
  wordsSlider.addEventListener('input', () => {
    wordsValue.textContent = wordsSlider.value;
    doGenerate();
  });

  // Character options
  const optMap = {
    'opt-upper': 'upper',
    'opt-lower': 'lower',
    'opt-numbers': 'numbers',
    'opt-symbols': 'symbols',
    'opt-ambiguous': 'excludeAmbiguous',
  };
  Object.entries(optMap).forEach(([id, key]) => {
    document.getElementById(id).addEventListener('click', function() {
      opts[key] = !opts[key];
      this.classList.toggle('active', opts[key]);
      // Ensure at least one charset is active
      if (!opts.upper && !opts.lower && !opts.numbers && !opts.symbols) {
        opts[key] = true;
        this.classList.add('active');
        return;
      }
      doGenerate();
    });
  });

  // Generate button
  btnGenerate.addEventListener('click', doGenerate);

  // Spacebar
  document.addEventListener('keydown', (e) => {
    if (e.code === 'Space' && !e.repeat && e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') {
      e.preventDefault();
      doGenerate();
    }
  });

  // Copy
  btnCopy.addEventListener('click', () => {
    if (!currentPassword) return;
    navigator.clipboard.writeText(currentPassword).then(() => {
      btnCopy.textContent = 'Copied!';
      btnCopy.classList.add('copied');
      setTimeout(() => { btnCopy.textContent = 'Copy'; btnCopy.classList.remove('copied'); }, 2000);
    });
  });

  // Multi count buttons
  document.querySelectorAll('.multi-count-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      multiCount = parseInt(btn.dataset.count);
      document.querySelectorAll('.multi-count-btn').forEach(b => b.classList.toggle('active', b === btn));
    });
  });

  // Generate multiple
  document.getElementById('btn-multi').addEventListener('click', () => {
    multiResults.innerHTML = '';
    for (let i = 0; i < multiCount; i++) {
      const pw = generatePassword();
      if (!pw) continue;
      const row = document.createElement('div');
      row.className = 'multi-result-row';
      const text = document.createElement('span');
      text.className = 'multi-result-text';
      text.textContent = pw;
      const copyBtn = document.createElement('button');
      copyBtn.className = 'multi-copy-btn';
      copyBtn.textContent = 'Copy';
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(pw).then(() => {
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.add('copied');
          setTimeout(() => { copyBtn.textContent = 'Copy'; copyBtn.classList.remove('copied'); }, 2000);
        });
      });
      row.appendChild(text);
      row.appendChild(copyBtn);
      multiResults.appendChild(row);
    }
  });

  // FAQ accordion
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement.classList.toggle('open');
    });
  });

  // Auto-generate on load
  doGenerate();

});
</script>

