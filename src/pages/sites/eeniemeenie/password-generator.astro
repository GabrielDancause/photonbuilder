        <label class="option-toggle" id="opt-ambiguous"><input type="checkbox"> Exclude Ambiguous (0OIl1)</label>
      </div>
    </div>

    <!-- Passphrase options -->
    <div class="passphrase-options" id="passphrase-options">
      <div class="slider-group">
        <div class="slider-header">
          <span class="form-label">Number of Words</span>
          <span class="slider-value" id="words-value">4</span>
        </div>
        <input type="range" class="form-slider" id="words-slider" min="4" max="8" value="4">
      </div>
    </div>
  </div>

  <div class="action-row">
    <button id="btn-generate" class="btn-primary">Generate</button>
    <div class="generate-hint">or press <kbd>Space</kbd></div>
  </div>

  <!-- Multiple passwords -->
  <div class="multi-section">
    <div class="card">
      <h3>Generate Multiple</h3>
      <p>Create several passwords at once with the same settings.</p>
      <div class="multi-controls">
        <button class="multi-count-btn" data-count="2">2</button>
        <button class="multi-count-btn" data-count="3">3</button>
        <button class="multi-count-btn active" data-count="5">5</button>
        <button class="multi-count-btn" data-count="10">10</button>
      </div>
      <button class="mode-generate-btn" id="btn-multi">Generate All</button>
      <div class="multi-results" id="multi-results"></div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>
    {faqItems.map(item => (
      <div class="faq-item">
        <div class="faq-q">{item.q}</div>
        <div class="faq-a">{item.a}</div>
      </div>
    ))}
  </div>

  <!-- Related pages -->
  <div class="related-section">
    <h2>More Random Tools</h2>
    <div class="related-grid">
      <a href="/random-number-generator" class="related-link">
        <h4>Random Number Generator</h4>
        <p>Generate truly random numbers in any range with crypto-grade randomness.</p>
      </a>
      <a href="/name-generator" class="related-link">
        <h4>Name Generator</h4>
        <p>Pick a random name from your list in one click.</p>
      </a>
    </div>
  </div>

</div>
</div>

<script is:inline>
