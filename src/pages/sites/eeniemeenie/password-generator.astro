---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Password Generator — Create Strong Random Passwords', description: 'Generate secure random passwords and passphrases instantly. Customize length, characters, and strength. Uses crypto-grade randomness for maximum security.', category: 'tool', published: '2026-03-21' };
const SITE_ID = 'eeniemeenie';

const faqItems = [
  { q: 'How does this password generator work?', a: 'This generator uses your browser\'s crypto.getRandomValues() API to produce cryptographically secure random passwords. Every character is selected with true randomness — the same source used by professional password managers and encryption software. No passwords are ever sent to a server; everything runs locally in your browser.' },
  { q: 'What makes a password "strong"?', a: 'Password strength depends primarily on entropy — the number of possible combinations an attacker would need to try. A strong password has at least 60 bits of entropy. This means using a mix of uppercase letters, lowercase letters, numbers, and symbols, with a length of at least 12 characters. Our strength meter calculates entropy in real time so you can see exactly how secure your password is.' },
  { q: 'What is a passphrase and why use one?', a: 'A passphrase is a password made of random words separated by dashes (e.g., "correct-horse-battery-staple"). Passphrases are easier to remember than random character strings while still being very secure. A 4-word passphrase has roughly 51 bits of entropy, while a 6-word passphrase exceeds 77 bits — strong enough for most purposes.' },
  { q: 'What does "exclude ambiguous characters" mean?', a: 'Ambiguous characters are ones that look similar in many fonts: 0 (zero) and O (letter O), 1 (one) and l (lowercase L) and I (uppercase i). Excluding them makes passwords easier to read and type manually, which is useful when you need to enter a password on a different device.' },
  { q: 'How long should my password be?', a: 'We recommend at least 16 characters for important accounts. For maximum security, use 20+ characters. The minimum secure length is 12 characters when using a mix of all character types. Longer passwords are exponentially harder to crack — each additional character multiplies the number of possible combinations.' },
  { q: 'Is it safe to generate passwords in a browser?', a: 'Yes, when using a generator like this one that runs entirely client-side. Your passwords are generated locally using your browser\'s built-in cryptographic random number generator. Nothing is transmitted over the network, stored on a server, or logged anywhere. You can even use this tool offline.' },
  { q: 'Can I generate multiple passwords at once?', a: 'Yes! Use the "Generate Multiple" section to create up to 10 passwords at once with the same settings. This is handy when you need to set up passwords for multiple accounts or want several options to choose from.' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID} schema={faqSchema} canonical="https://eeniemeenie.photonbuilder.com/password-generator">
<style is:inline>

  .page-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    width: 100%;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent-color);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Password display */
  .password-display {
    width: 100%;
    max-width: 650px;
    margin-bottom: 1.5rem;
  }
  .password-output {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 0.75rem;
  }
  .password-text {
    flex: 1;
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    word-break: break-all;
    line-height: 1.4;
    min-height: 1.8rem;
  }
  .password-text .char-upper { color: var(--accent-color); }
  .password-text .char-num { color: #4caf50; }
  .password-text .char-sym { color: #ff9800; }
  .btn-copy {
    padding: 0.55rem 1rem;
    background: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .btn-copy:hover { opacity: 0.9; }
  .btn-copy:active { transform: scale(0.95); }
  .btn-copy.copied { background: #4caf50; }

  /* Strength meter */
  .strength-bar-container {
    height: 6px;
    background: var(--border-color);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  .strength-bar {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s, background-color 0.3s;
    width: 0;
  }
  .strength-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
  }
  .strength-label {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .entropy-display {
    color: var(--text-secondary);
  }

  /* Generator form */
  .generator-form {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    width: 100%;
    max-width: 650px;
    margin-bottom: 1.5rem;
  }

  /* Mode tabs */
  .mode-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
  }
  .mode-tab {
    flex: 1;
    padding: 0.65rem 1rem;
    background: var(--bg-color);
    border: none;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }
  .mode-tab:not(:last-child) { border-right: 1px solid var(--border-color); }
  .mode-tab:hover { color: var(--text-primary); }
  .mode-tab.active { background: var(--accent-color); color: #fff; }

  /* Slider */
  .slider-group {
    margin-bottom: 1.25rem;
  }
  .slider-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .form-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }
  .slider-value {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--accent-color);
    min-width: 2.5rem;
    text-align: right;
  }
  .form-slider {
    -webkit-appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: var(--border-color);
    outline: none;
  }
  .form-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent-color);
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }
  .form-slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent-color);
    cursor: pointer;
    border: none;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }

  /* Options */
  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 480px) {
    .options-grid { grid-template-columns: 1fr; }
  }
  .option-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.8rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
  }
  .option-toggle:hover { border-color: var(--accent-color); color: var(--text-primary); }
  .option-toggle.active { border-color: var(--accent-color); color: var(--accent-color); background: rgba(224, 64, 251, 0.08); }
  .option-toggle.disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }
  .option-toggle input { display: none; }

  /* Passphrase options */
  .passphrase-options { display: none; }
  .passphrase-options.visible { display: block; }
  .password-char-options.hidden { display: none; }

  /* Buttons */
  .btn-primary {
    padding: 1rem 2.5rem;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.3rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-primary:active { transform: scale(0.97); }
  .generate-hint {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }
  .action-row {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Multiple passwords */
  .multi-section {
    width: 100%;
    max-width: 650px;
    margin-top: 2rem;
  }
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .card h3 {
    color: var(--accent-color);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }
  .card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .multi-controls {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .multi-count-btn {
    padding: 0.4rem 0.85rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
