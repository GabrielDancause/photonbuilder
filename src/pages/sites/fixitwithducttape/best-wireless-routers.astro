    vpn: "OpenVPN, PPTP, L2TP/IPSec",
    price: 1499,
    priceStr: "$1,499",
    summary: "If you need to blanket a massive home in multi-gigabit speeds, the TP-Link Deco BE85 WiFi 7 mesh system is unmatched. It provides seamless roaming and incredible wired backhaul options.",
    pros: ["Incredible whole-home coverage", "Dual 10Gbps ports on every unit", "Easy app-based setup"],
    cons: ["Astronomical price for the 3-pack", "Advanced parental controls require a subscription"]
  },
  {
    name: "Netgear Nighthawk RS700S",
    badge: "Best Premium Design",
    speed: "19000 Mbps",
    range: "Up to 3,500 sq ft",
    ports: "1x 10Gbps WAN, 1x 10Gbps LAN, 4x 1Gbps LAN",
    mesh: "No",
    parentalControls: "Premium Paid (Smart Parental Controls)",
    vpn: "OpenVPN",
    price: 699,
    priceStr: "$699",
    summary: "Netgear's first WiFi 7 router ditches the spaceship look for a sleek, vertical tower. It delivers exceptional throughput and features powerful internal antennas.",
    pros: ["Sleek, unobtrusive tower design", "Blistering WiFi 7 performance", "10Gbps WAN and LAN ports"],
    cons: ["Security and parental controls require paid subscriptions", "No multi-gig LAN ports besides the single 10G"]
  },
  {
    name: "Eero Max 7",
    badge: "Best Easy Setup",
    speed: "9400 Mbps (wireless), 9400 Mbps (wired)",
    range: "Up to 2,500 sq ft (1-pack)",
    ports: "2x 10Gbps, 2x 2.5Gbps",
    mesh: "Yes (Eero Mesh)",
    parentalControls: "Premium Paid (Eero Plus)",
    vpn: "No native VPN server (Passthrough only)",
    price: 599,
    priceStr: "$599",
    summary: "Amazon's Eero Max 7 brings WiFi 7 to the ridiculously easy-to-use Eero ecosystem. It features incredible multi-gig ports but locks many features behind the Eero Plus subscription.",
    pros: ["Dead-simple setup and management", "Excellent 10Gbps and 2.5Gbps ports", "Built-in Zigbee/Thread smart home hub"],
    cons: ["Almost all advanced features require a paid subscription", "No dedicated web interface, app only"]
  },
  {
    name: "Google Nest WiFi Pro",
    badge: "Best WiFi 6E Mesh",
    speed: "5400 Mbps",
    range: "Up to 6,600 sq ft (3-pack)",
    ports: "2x 1Gbps per node",
    mesh: "Yes (Nest Mesh)",
    parentalControls: "Basic Free (Family WiFi)",
    vpn: "No",
    price: 399,
    priceStr: "$399",
    summary: "While it lacks WiFi 7, the Google Nest WiFi Pro remains an excellent value for a WiFi 6E mesh system. It's beautiful, reliable, and integrates perfectly into Google Home.",
    pros: ["Attractive, living-room-friendly design", "Affordable for a 6E mesh system", "Solid, reliable performance"],
    cons: ["Only Gigabit ports (no multi-gig support)", "Lacks advanced networking features"]
  },
  {
    name: "Linksys Velop Pro 7",
    resolution: "WiFi 7",
    badge: "Best Cognitive Mesh",
    speed: "11000 Mbps",
    range: "Up to 9,000 sq ft (3-pack)",
    ports: "1x 2.5Gbps WAN, 4x 1Gbps LAN per node",
    mesh: "Yes (Velop Cognitive Mesh)",
    parentalControls: "Basic Free",
    vpn: "No native VPN server",
    price: 899,
    priceStr: "$899",
    summary: "Linksys uses a new 'droplet' design for the Velop Pro 7. It offers a very stable WiFi 7 mesh experience but falls short on wired connectivity compared to the Deco BE85.",
    pros: ["Stable and reliable mesh network", "Clean, modern design", "No subscription required for basic features"],
    cons: ["Only a 2.5G WAN and 1G LAN ports", "Slower top speeds than rival WiFi 7 mesh systems"]
  },
  {
    name: "Ubiquiti UniFi Dream Router",
    badge: "Best Prosumer",
