---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const drives = [
  {
    name: "Samsung T9",
    badge: "Best Portable SSD",
    category: "Portable SSD",
    capacity: "1TB - 4TB",
    speed: "2000 MB/s",
    interface: "USB-C 3.2 Gen 2x2",
    durability: "Drop resistant up to 3m",
    encryption: "AES 256-bit",
    pricePerTB: "$95 - $110",
    summary: "The Samsung T9 is currently the king of portable SSDs, offering blistering fast read and write speeds, a rugged rubberized exterior, and excellent thermal management.",
    pros: ["Incredibly fast speeds", "Durable, non-slip rubber exterior", "Hardware encryption"],
    cons: ["Requires USB 3.2 Gen 2x2 for max speed", "Premium price"]
  },
  {
    name: "WD My Passport SSD",
    badge: "Best Value SSD",
    category: "Portable SSD",
    capacity: "500GB - 4TB",
    speed: "1050 MB/s",
    interface: "USB-C 3.2 Gen 2",
    durability: "Drop resistant up to 1.98m",
    encryption: "AES 256-bit",
    pricePerTB: "$80 - $90",
    summary: "Offering a sweet spot between price and performance, the WD My Passport SSD provides very fast speeds in a stylish, compact metal design.",
    pros: ["Excellent value for money", "Compact and sleek design", "Hardware encryption"],
    cons: ["Gets warm under heavy load", "Included cable is short"]
  },
  {
    name: "SanDisk Extreme Portable SSD",
    badge: "Best for Outdoors",
    category: "Portable SSD",
    capacity: "500GB - 4TB",
    speed: "1050 MB/s",
    interface: "USB-C 3.2 Gen 2",
    durability: "IP65 water/dust, 3m drop",
    encryption: "AES 256-bit",
    pricePerTB: "$85 - $100",
    summary: "Built for adventurers and on-the-go photographers, the SanDisk Extreme features an IP65 rating for water and dust resistance, plus a handy carabiner loop.",
    pros: ["Rugged, IP65-rated design", "Handy carabiner loop", "Consistently fast speeds"],
    cons: ["Slightly larger than some competitors", "Rubber attracts lint"]
  },
  {
    name: "WD Elements Portable",
    badge: "Best Budget HDD",
    category: "Portable HDD",
    capacity: "1TB - 5TB",
    speed: "~130 MB/s",
    interface: "USB 3.0",
    durability: "Basic",
    encryption: "None",
    pricePerTB: "$25 - $30",
    summary: "If you need cheap, basic storage for backups and files where speed isn't a priority, the WD Elements is a reliable and highly affordable classic.",
    pros: ["Very affordable", "Plug-and-play simplicity", "Compact for a hard drive"],
    cons: ["Slow HDD speeds", "No hardware encryption"]
  },
  {
    name: "Seagate Backup Plus Portable",
    badge: "Best Backup Software",
    category: "Portable HDD",
    capacity: "1TB - 5TB",
    speed: "~120 MB/s",
    interface: "USB 3.0",
    durability: "Basic",
    encryption: "None",
    pricePerTB: "$26 - $32",
    summary: "Similar in performance to the WD Elements, but comes with excellent, easy-to-use backup software right out of the box.",
    pros: ["Great included backup software", "Sleek metal finish options", "Affordable"],
    cons: ["Slow transfer speeds", "Requires formatting for Mac out of the box"]
  },
  {
    name: "Toshiba Canvio Advance",
    badge: "Best Colorful HDD",
    category: "Portable HDD",
    capacity: "1TB - 4TB",
    speed: "~130 MB/s",
    interface: "USB 3.2 Gen 1",
    durability: "Basic",
    encryption: "Password protection",
    pricePerTB: "$28 - $35",
    summary: "A stylish alternative in the portable HDD space, offering textured finishes in various colors, along with basic backup and security software.",
    pros: ["Textured, colorful designs", "Included backup/security software", "Reliable performance"],
    cons: ["Software is basic", "Standard slow HDD speeds"]
  },
  {
    name: "WD My Book",
    badge: "Best High Capacity",
    category: "Desktop HDD",
    capacity: "4TB - 22TB",
    speed: "~180 MB/s",
    interface: "USB 3.0",
    durability: "Desktop use only",
    encryption: "AES 256-bit",
    pricePerTB: "$18 - $25",
    summary: "When you need massive amounts of storage for a home office or media library, the WD My Book offers massive capacities up to 22TB.",
    pros: ["Massive storage capacities", "Hardware encryption", "Included backup software"],
    cons: ["Requires external power supply", "Bulky desktop design"]
  },
  {
    name: "Seagate Expansion Desktop",
    badge: "Best Basic Desktop",
    category: "Desktop HDD",
    capacity: "4TB - 18TB",
    speed: "~160 MB/s",
    interface: "USB 3.0",
    durability: "Desktop use only",
    encryption: "None",
    pricePerTB: "$17 - $23",
    summary: "A no-frills, high-capacity desktop drive perfect for simple drag-and-drop storage or expanding console storage.",
    pros: ["Very low cost per TB", "Simple plug-and-play setup", "Quiet operation"],
    cons: ["No included backup software", "No encryption", "Requires external power"]
  },
  {
    name: "Synology DiskStation DS224+",
    badge: "Best Starter NAS",
    category: "NAS",
    capacity: "Diskless (Bring your own)",
    speed: "Network Dependent",
    interface: "Gigabit Ethernet",
    durability: "Desktop/Server",
    encryption: "Software based",
    pricePerTB: "Varies (Drive cost + $300 NAS)",
    summary: "For those ready to move beyond USB drives, this 2-bay NAS offers your own personal cloud, automatic backups for all devices, and media streaming.",
    pros: ["Access files from anywhere", "Excellent Synology DSM software", "Redundancy (RAID support)"],
    cons: ["Expensive upfront cost", "Requires separate hard drive purchase", "Setup learning curve"]
  }
];

const categoryWinners = [
  { category: "Best Portable SSD", pick: "Samsung T9", reason: "Unmatched combination of speed, durability, and features for power users." },
  { category: "Best Value Portable", pick: "WD My Passport SSD", reason: "Provides 1050MB/s speeds at a price point that makes older, slower drives obsolete." },
  { category: "Best Budget Storage", pick: "WD Elements Portable", reason: "The cheapest, most reliable way to back up terabytes of non-urgent data." },
  { category: "Best Desktop Archive", pick: "WD My Book", reason: "Massive capacities up to 22TB with reliable hardware encryption built-in." }
];

const ssdVsHddGuide = [
  {
    title: "Portable SSD (Solid State Drive)",
    description: "Uses flash memory with no moving parts. They are incredibly fast (up to 2000 MB/s), tiny, drop-resistant, and silent. Best for: Video editing, fast file transfers, running apps/games, and traveling.",
    pros: ["Incredibly fast", "Very durable", "Compact size"],
    cons: ["Higher cost per TB"]
  },
  {
    title: "Portable HDD (Hard Disk Drive)",
    description: "Uses spinning magnetic platters. They are slower (~130 MB/s), larger, and fragile (drops can break them), but offer massive storage for very little money. Best for: Cheap backups, storing large media libraries, archives.",
    pros: ["Very cheap per TB", "Large capacities available", "Good for cold storage"],
    cons: ["Slow transfer speeds", "Fragile moving parts"]
  },
  {
    title: "Desktop HDD",
    description: "Larger 3.5-inch spinning drives that require being plugged into a wall outlet for power. They offer the largest possible capacities (up to 22TB+) at the lowest cost per TB. Best for: Home servers, massive media archives, full system backups.",
    pros: ["Lowest cost per TB", "Massive capacities"],
    cons: ["Requires wall power", "Not portable"]
  }
];

const faqs = [
  {
    q: "Do I need an SSD or an HDD?",
    a: "If you need speed (for editing photos/video or running games) or portability (traveling, working in cafes), get an SSD. If you just need a cheap place to dump terabytes of family photos, movies, or full computer backups, an HDD is much more cost-effective."
  },
  {
    q: "What does USB 3.2 Gen 2x2 mean?",
    a: "It's a USB naming convention that indicates the maximum theoretical speed of the port. Gen 2x2 offers up to 20Gbps (around 2000 MB/s). To get these speeds, both your computer's port and the external drive must support it; otherwise, it will fall back to slower speeds."
  },
  {
    q: "Will these drives work on both Mac and Windows?",
    a: "Most drives come formatted for either Windows (NTFS) or Mac (APFS/HFS+), or sometimes exFAT for both. You can easily reformat any drive to work with your operating system of choice using built-in disk utility tools."
  },
  {
    q: "Is hardware encryption worth it?",
    a: "Yes, especially for portable drives. If you lose a portable drive, hardware encryption (like AES 256-bit) ensures your personal or business data cannot be accessed by whoever finds it. It requires a password to unlock every time it's plugged in."
  },
  {
    q: "What is a NAS?",
    a: "NAS stands for Network Attached Storage. Instead of plugging into your computer via USB, it plugs into your router. This allows every computer, phone, and tablet on your Wi-Fi to access the storage simultaneously, effectively creating your own personal cloud."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best External Hard Drives 2026",
    "description": "Discover the top external storage options by category, including portable SSDs, HDDs, desktop drives, and NAS solutions. Compare capacity, speed, and price per TB.",
    "author": {
      "@type": "Organization",
      "name": "Fix It With Duct Tape"
    },
    "datePublished": "2026-07-15",
    "dateModified": "2026-07-15"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Best External Hard Drives 2026",
  description: "Top external storage picks for 2026: portable SSDs, HDDs, desktop drives, and NAS solutions compared by capacity, speed, and price per TB.",
  category: "list",
  published: "2026-07-15",
};
---

<SiteLayout
  site="fixitwithducttape"
  title={meta.title}
  description={meta.description}
  canonical="https://fixitwithducttape.photonbuilder.com/best-external-hard-drives"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Best External Hard Drives and SSDs</h1>
      <p>Whether you need lightning-fast speeds for 4K video editing or massive, cheap storage for your family photo archive, we've broken down the top external storage options by category.</p>
    </div>

    <section class="content-section">
      <p>Choosing the right external drive comes down to balancing three factors: speed, capacity, and price. While blazing-fast portable SSDs have come down significantly in price, traditional spinning hard drives (HDDs) still rule when you need to store terabytes of data on a budget.</p>

      <h2>Category Winners</h2>
      <div class="winners-grid">
        {categoryWinners.map(w => (
          <div class="winner-card">
            <span class="winner-label">{w.category}</span>
            <strong>{w.pick}</strong>
            <span class="winner-reason">{w.reason}</span>
          </div>
        ))}
      </div>

      <h2>Quick Comparison</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Model</th>
              <th>Category</th>
              <th>Speed</th>
              <th>Interface</th>
              <th>Encryption</th>
              <th>Price/TB</th>
            </tr>
          </thead>
          <tbody>
            {drives.map(d => (
              <tr>
                <td><strong>{d.name}</strong></td>
                <td>{d.category}</td>
                <td>{d.speed}</td>
                <td>{d.interface}</td>
                <td>{d.encryption}</td>
                <td>{d.pricePerTB}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>SSD vs HDD: How to Choose</h2>
      <p>Before diving into specific models, it's crucial to understand the three main types of external storage available today:</p>
      <div class="switch-guide-grid">
        {ssdVsHddGuide.map(s => (
          <div class="switch-card">
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </div>
        ))}
      </div>

      <h2>Detailed Reviews</h2>
      {drives.map((d, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{d.name}</h3>
              {d.badge && <span class="badge">{d.badge}</span>}
            </div>
          </div>

          <p class="review-summary">{d.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Capacity</span><span class="spec-value">{d.capacity}</span></div>
            <div class="spec"><span class="spec-label">Speed</span><span class="spec-value">{d.speed}</span></div>
            <div class="spec"><span class="spec-label">Interface</span><span class="spec-value">{d.interface}</span></div>
            <div class="spec"><span class="spec-label">Durability</span><span class="spec-value">{d.durability}</span></div>
          </div>

          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{d.pros.map(pro => <li>{pro}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{d.cons.map(con => <li>{con}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}
    </section>
  </div>

  <style is:inline>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }

    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Winners Grid */
    .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
    .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
    .winner-card strong { font-size: 1.05rem; }
    .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

    /* Switch Guide (repurposed for SSD vs HDD) */
    .switch-guide-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .switch-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem; }
    .switch-card h3 { margin-top: 0; font-size: 1.1rem; color: var(--accent-color); }
    .switch-card p { margin-bottom: 0; font-size: 0.95rem; }

    /* Comparison Table */
    .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* Review Cards */
    .review-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .review-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
    .review-header > div { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .review-rank { font-size: 1.1rem; font-weight: 800; color: var(--accent-color); }
    .review-header h3 { margin: 0; font-size: 1.25rem; color: var(--text-primary); }
    .badge { background: var(--accent-color); color: #000; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 20px; white-space: nowrap; }
    .review-price { font-size: 1.1rem; font-weight: 800; color: var(--text-primary); }
    .review-summary { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

    .specs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-bottom: 1rem; }
    .spec { display: flex; flex-direction: column; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border-color); }
    .spec-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); font-weight: 600; }
    .spec-value { font-size: 0.95rem; color: var(--text-primary); font-weight: 600; }

    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .pros h4, .cons h4 { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .pros h4 { color: #22c55e; }
    .cons h4 { color: #ef4444; }
    .pros ul, .cons ul { margin: 0; padding-left: 1.2rem; font-size: 0.9rem; }
    .pros li, .cons li { margin-bottom: 0.3rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .pros-cons { grid-template-columns: 1fr; }
      .specs-grid { grid-template-columns: 1fr 1fr; }
      .review-header { flex-direction: column; }
      .winners-grid, .switch-guide-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>