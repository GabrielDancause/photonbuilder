const faqs = [
  {
    q: "What is active noise cancellation (ANC)?",
    a: "Active noise cancellation uses microphones to pick up low-frequency noise and neutralizes it before it reaches the ear by generating a sound that's phase-inverted by 180 degrees."
  },
  {
    q: "Are wireless earbuds good for phone calls?",
    a: "Yes, many modern wireless earbuds have multiple microphones and use algorithms to isolate your voice from background noise, making them excellent for phone calls."
  },
