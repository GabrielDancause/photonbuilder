                <td>{p.encryption}</td>
                <td>{p.bestFor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Detailed Reviews</h2>

      {cloudStorage.map((p, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{p.name}</h3>
              {p.badge && <span class="badge">{p.badge}</span>}
            </div>
            <span class="review-price">{p.paidPricingPerTB.split(' ')[0]}</span>
          </div>

          <p class="review-summary">{p.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Free Tier</span><span class="spec-value">{p.freeTier}</span></div>
            <div class="spec"><span class="spec-label">Price/TB</span><span class="spec-value">{p.paidPricingPerTB}</span></div>
            <div class="spec"><span class="spec-label">File Sharing</span><span class="spec-value">{p.fileSharing}</span></div>
            <div class="spec"><span class="spec-label">Collaboration</span><span class="spec-value">{p.collaboration}</span></div>
            <div class="spec"><span class="spec-label">Encryption</span><span class="spec-value">{p.encryption}</span></div>
            <div class="spec"><span class="spec-label">Desktop Sync Client</span><span class="spec-value">{p.desktopSyncClient}</span></div>
            <div class="spec"><span class="spec-label">Mobile App</span><span class="spec-value">{p.mobileApp}</span></div>
            <div class="spec"><span class="spec-label">Versioning</span><span class="spec-value">{p.versioning}</span></div>
            <div class="spec"><span class="spec-label">API Access</span><span class="spec-value">{p.apiAccess}</span></div>
            <div class="spec"><span class="spec-label">Speed</span><span class="spec-value">{p.speed}</span></div>
            <div class="spec"><span class="spec-label">Privacy Jurisdiction</span><span class="spec-value">{p.privacyJurisdiction}</span></div>
            <div class="spec"><span class="spec-label">Best For</span><span class="spec-value">{p.bestFor}</span></div>
          </div>

          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{p.pros.map(pro => <li>{pro}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{p.cons.map(con => <li>{con}</li>)}</ul>
            </div>
