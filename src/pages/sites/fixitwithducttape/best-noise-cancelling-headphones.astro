    summary: "The Sony WH-1000XM5 offer an exceptional blend of top-tier noise cancellation, comfortable design, and fantastic sound quality. The automatic ANC optimization is industry-leading.",
    pros: ["Superb noise cancellation", "Excellent sound quality", "Lightweight and comfortable", "LDAC support"],
    cons: ["Cannot fold up", "Design is somewhat divisive", "Pricey"]
  },
  {
    name: "Bose QC Ultra",
    type: "Over-ear",
    ancRating: "10/10",
    ancRatingNum: 10,
    battery: "24h",
    batteryNum: 24,
    price: 429,
    priceStr: "$429",
    codec: "SBC, AAC, aptX Adaptive",
    summary: "If you want the absolute best noise cancellation available today, the Bose QC Ultra headphones are unmatched. They completely silence the world around you while offering supreme comfort.",
    pros: ["Unmatched ANC performance", "Incredibly comfortable", "Immersive Audio feature is fun"],
    cons: ["Battery life is only average", "No USB-C audio", "Very expensive"]
  },
  {
    name: "Apple AirPods Max",
    type: "Over-ear",
    ancRating: "9.0/10",
    ancRatingNum: 9.0,
    battery: "20h",
    batteryNum: 20,
    price: 549,
    priceStr: "$549",
    codec: "SBC, AAC",
    summary: "The AirPods Max feature stunning aluminum build quality and seamless integration with Apple devices. Their spatial audio and transparency mode are still incredibly impressive.",
    pros: ["Premium build quality", "Fantastic transparency mode", "Seamless Apple ecosystem integration"],
    cons: ["Very heavy", "Expensive", "No high-res codec support", "Weird smart case"]
  },
  {
    name: "Sennheiser Momentum 4",
    type: "Over-ear",
    ancRating: "8.5/10",
    ancRatingNum: 8.5,
    battery: "60h",
    batteryNum: 60,
    price: 349,
    priceStr: "$349",
    codec: "SBC, AAC, aptX Adaptive",
    summary: "The Sennheiser Momentum 4 boasts an incredible 60 hours of battery life and delivers phenomenal, detailed sound. While the ANC isn't quite at Bose's level, it's still very good.",
    pros: ["Class-leading 60-hour battery life", "Audiophile-grade sound quality", "Comfortable for long sessions"],
    cons: ["ANC is good but not class-leading", "Design is a bit generic", "Touch controls can be finicky"]
  },
  {
    name: "Sony WF-1000XM5",
    type: "In-ear",
