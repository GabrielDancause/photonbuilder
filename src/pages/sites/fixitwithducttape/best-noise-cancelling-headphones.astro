    codec: "SBC, AAC, SSC",
    summary: "For Samsung users, the Galaxy Buds3 Pro offer fantastic seamless integration, very strong noise cancellation, and high-res audio support via Samsung's proprietary codec.",
    pros: ["Great ANC and transparency mode", "Seamless Samsung integration", "Comfortable fit"],
    cons: ["Stem design is derivative", "Best features require a Samsung phone"]
  },
  {
    name: "Jabra Elite 10",
    badge: "Best for Calls",
    type: "In-ear",
    ancRating: "8.0/10",
    ancRatingNum: 8.0,
    battery: "6h (27h case)",
    batteryNum: 6,
    price: 249,
    priceStr: "$249",
    codec: "SBC, AAC",
    summary: "The Jabra Elite 10 are incredibly comfortable thanks to their semi-open design. They also feature arguably the best microphone system for crystal clear phone calls in noisy environments.",
    pros: ["Extremely comfortable semi-open design", "Best-in-class microphone for calls", "Physical buttons instead of touch controls"],
    cons: ["ANC is weaker due to semi-open fit", "No high-res codec support"]
  },
  {
    name: "Google Pixel Buds Pro",
    badge: "Best Budget",
    type: "In-ear",
    ancRating: "8.0/10",
    ancRatingNum: 8.0,
    battery: "7h (20h case)",
    batteryNum: 7,
    price: 199,
    priceStr: "$199",
    codec: "SBC, AAC",
    summary: "Offering deep Google Assistant integration and very competent noise cancellation, the Pixel Buds Pro are an excellent value proposition for Android users.",
    pros: ["Great value for money", "Deep Google Assistant integration", "Comfortable fit", "Multipoint Bluetooth"],
