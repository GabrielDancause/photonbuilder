  },
  {
    name: "Bose QC Earbuds II",
    badge: "Best Earbuds",
    type: "In-ear",
    ancRating: "9.5/10",
    ancRatingNum: 9.5,
    battery: "6h (24h case)",
    batteryNum: 6,
    price: 279,
    priceStr: "$279",
    codec: "SBC, AAC",
    summary: "Bose somehow managed to put over-ear level noise cancellation into a set of earbuds. The QC Earbuds II offer a truly startling level of quiet.",
    pros: ["Mind-blowing ANC for earbuds", "Very comfortable and secure fit", "Great sound quality"],
