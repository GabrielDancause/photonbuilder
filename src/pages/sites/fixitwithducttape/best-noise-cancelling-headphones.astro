---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const headphones = [
  {
    name: "Sony WH-1000XM5",
    badge: "Best Overall",
    type: "Over-ear",
    ancRating: "9.5/10",
    ancRatingNum: 9.5,
    battery: "30h",
