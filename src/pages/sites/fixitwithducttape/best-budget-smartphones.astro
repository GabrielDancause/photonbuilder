---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const phones = [
  {
    name: "Google Pixel 8a",
    badge: "Best Overall & Best Camera",
    price: 399,
    priceStr: "$399",
    display: "6.1\" OLED 120Hz",
    processor: "Tensor G3",
    ram: "8GB",
    storage: "128GB",
    camera: "64MP Main, 13MP Ultrawide",
    battery: "4492mAh",
    has5G: "Yes",
    summary: "The Google Pixel 8a is the undisputed king of the budget category. It brings the flagship Tensor G3 chip from the Pixel 8 Pro down to a sub-$400 price point, offering unparalleled AI features, 7 years of software updates, and the best camera in its class.",
    pros: ["Class-leading camera performance", "7 years of OS updates", "Flagship Tensor G3 chip", "Excellent software experience"],
    cons: ["Slower charging speeds", "Thick bezels", "Battery life is just average"]
  },
  {
    name: "OnePlus 12R",
    badge: "Best Display & Best Battery",
    price: 399,
    priceStr: "$399",
    display: "6.78\" AMOLED 120Hz",
    processor: "Snapdragon 8 Gen 2",
    ram: "8GB",
    storage: "128GB",
    camera: "50MP Main, 8MP Ultrawide",
    battery: "5500mAh",
    has5G: "Yes",
    summary: "If you prioritize a massive, gorgeous screen, top-tier performance, and battery life that refuses to quit, the OnePlus 12R is the phone for you. It boasts the Snapdragon 8 Gen 2, ensuring blazing-fast performance for gaming and multitasking.",
    pros: ["Incredible battery life", "Stunningly bright display", "Flagship-tier performance", "Super-fast charging"],
    cons: ["Camera is average in low light", "No wireless charging", "Curved screen isn't for everyone"]
  },
  {
    name: "Nothing Phone 2a",
    badge: "Best Value",
    price: 349,
    priceStr: "$349",
    display: "6.7\" AMOLED 120Hz",
    processor: "Dimensity 7200 Pro",
    ram: "8GB",
    storage: "128GB",
    camera: "50MP Main, 50MP Ultrawide",
    battery: "5000mAh",
    has5G: "Yes",
    summary: "The Nothing Phone 2a brings the brand's unique transparent design and Glyph interface to a lower price point. It's an exceptionally smooth operator with its optimized Dimensity 7200 Pro, offering a clean, bloat-free OS and distinct aesthetics.",
    pros: ["Unique transparent design with Glyphs", "Clean Nothing OS software", "Great battery life", "Solid dual cameras"],
    cons: ["Plastic build feels less premium", "No wireless charging", "Limited availability in some regions"]
  },
  {
    name: "Samsung Galaxy A55",
    price: 399,
    priceStr: "$399",
    display: "6.6\" AMOLED 120Hz",
    processor: "Exynos 1480",
    ram: "8GB",
    storage: "128GB",
    camera: "50MP Main, 12MP Ultrawide",
    battery: "5000mAh",
    has5G: "Yes",
    summary: "The Galaxy A55 is the safe, reliable choice. It offers Samsung's robust ecosystem, a premium metal and glass build, reliable cameras, and strong software support, making it an excellent all-rounder.",
    pros: ["Premium metal and glass design", "Great vibrant display", "Long software support", "Reliable battery life"],
    cons: ["Exynos chip lags behind Snapdragon rivals", "Slower 25W charging", "Thick bezels"]
  },
  {
    name: "Motorola Edge 2024",
    price: 349,
    priceStr: "$349",
    display: "6.6\" pOLED 144Hz",
    processor: "Snapdragon 7s Gen 2",
    ram: "8GB",
    storage: "256GB",
    camera: "50MP Main, 13MP Ultrawide",
    battery: "5000mAh",
    has5G: "Yes",
    summary: "The Motorola Edge 2024 offers an incredibly sleek, lightweight design and a fast 144Hz curved display. It's perfect for media consumption and those who appreciate a clean Android experience with useful Moto gestures.",
    pros: ["Sleek, lightweight design", "Smooth 144Hz display", "Generous 256GB base storage", "Clean software"],
    cons: ["Camera falls short in low light", "Only 2 years of OS updates", "Curved display attracts accidental touches"]
  },
  {
    name: "Xiaomi Redmi Note 13 Pro",
    price: 299,
    priceStr: "$299",
    display: "6.67\" AMOLED 120Hz",
    processor: "Snapdragon 7s Gen 2",
    ram: "8GB",
    storage: "256GB",
    camera: "200MP Main, 8MP Ultrawide",
    battery: "5100mAh",
    has5G: "Yes",
    summary: "Xiaomi packs an insane 200MP camera sensor and a sharp AMOLED display into the highly affordable Redmi Note 13 Pro. It offers great value, particularly with its large storage base and fast 67W charging.",
    pros: ["Impressive 200MP main camera", "Fast 67W charging", "Bright 1.5K display resolution", "Great value for money"],
    cons: ["MIUI/HyperOS contains bloatware", "Macro camera is useless", "Software updates can be slow"]
  },
  {
    name: "Realme GT Neo 5",
    price: 379,
    priceStr: "$379",
    display: "6.74\" AMOLED 144Hz",
    processor: "Snapdragon 8+ Gen 1",
    ram: "12GB",
    storage: "256GB",
    camera: "50MP Main, 8MP Ultrawide",
    battery: "5000mAh",
    has5G: "Yes",
    summary: "A gamer's delight on a budget. The Realme GT Neo 5 features the older but highly capable Snapdragon 8+ Gen 1, paired with incredibly fast charging and a high refresh rate display.",
    pros: ["Excellent gaming performance", "Incredibly fast charging speeds", "144Hz refresh rate", "12GB RAM standard"],
    cons: ["Average camera system", "Plastic frame", "Software is heavy"]
  },
  {
    name: "Google Pixel 7a",
    price: 349,
    priceStr: "$349",
    display: "6.1\" OLED 90Hz",
    processor: "Tensor G2",
    ram: "8GB",
    storage: "128GB",
    camera: "64MP Main, 13MP Ultrawide",
    battery: "4385mAh",
    has5G: "Yes",
    summary: "Still a fantastic buy if you can find it discounted. The Pixel 7a offers 90% of the Pixel 8a's experience, with a stellar camera and Tensor G2 performance, though it misses out on the 120Hz screen.",
    pros: ["Top-tier camera quality", "Wireless charging included", "Compact size"],
    cons: ["Only 90Hz display", "Battery life is mediocre", "Slower charging"]
  },
  {
    name: "Samsung Galaxy A35",
    price: 299,
    priceStr: "$299",
    display: "6.6\" AMOLED 120Hz",
    processor: "Exynos 1380",
    ram: "6GB",
    storage: "128GB",
    camera: "50MP Main, 8MP Ultrawide",
    battery: "5000mAh",
    has5G: "Yes",
    summary: "The Galaxy A35 is a minor step down from the A55, offering a similar design and display but with a slightly weaker processor and 6GB of RAM. It's a great affordable entry into the Samsung ecosystem.",
    pros: ["Premium glass back design", "Solid AMOLED screen", "4 years of OS updates"],
    cons: ["Exynos 1380 can stutter occasionally", "6GB RAM base is limiting", "No charger in box"]
  },
  {
    name: "Poco X6 Pro",
    price: 319,
    priceStr: "$319",
    display: "6.67\" AMOLED 120Hz",
    processor: "Dimensity 8300 Ultra",
    ram: "8GB",
    storage: "256GB",
    camera: "64MP Main, 8MP Ultrawide",
    battery: "5000mAh",
    has5G: "Yes",
    summary: "The performance champion under $350. The Poco X6 Pro's Dimensity 8300 Ultra crushes benchmarks, making this the ideal phone for budget-conscious mobile gamers.",
    pros: ["Unbeatable performance for the price", "Sharp 1.5K display", "Fast 67W charging", "Includes case and charger"],
    cons: ["Plastic build", "Cameras are just okay", "Software contains bloatware"]
  },
  {
    name: "TCL 50 XL",
    price: 159,
    priceStr: "$159",
    display: "6.8\" LCD 120Hz",
    processor: "MediaTek MT6835",
    ram: "6GB",
    storage: "128GB",
    camera: "50MP Main, 2MP Macro",
    battery: "5010mAh",
    has5G: "Yes",
    summary: "For extreme budgets, the TCL 50 XL offers a massive 6.8-inch display and 5G connectivity for well under $200. It's basic, but it gets the job done for essential tasks and media viewing.",
    pros: ["Extremely affordable", "Huge display for media", "Long battery life"],
    cons: ["LCD display isn't very bright", "Performance is strictly entry-level", "Poor low-light camera"]
  },
  {
    name: "Nokia G42",
    price: 199,
    priceStr: "$199",
    display: "6.56\" LCD 90Hz",
    processor: "Snapdragon 480+",
    ram: "6GB",
    storage: "128GB",
    camera: "50MP Main, 2MP Macro",
    battery: "5000mAh",
    has5G: "Yes",
    summary: "The Nokia G42 stands out for its high repairability. Designed in collaboration with iFixit, you can easily replace the battery or screen yourself, adding to its longevity.",
    pros: ["User-repairable design", "Clean Android software", "Very affordable"],
    cons: ["720p LCD screen is dated", "Older Snapdragon 480+ chip", "Slow 20W charging"]
  }
];

const categoryWinners = [
  { category: "Best Overall", pick: "Google Pixel 8a", reason: "Unbeatable combination of camera quality, software support (7 years), and Tensor G3 performance." },
  { category: "Best Camera", pick: "Google Pixel 8a", reason: "Google's computational photography ensures flagship-level photos at a budget price." },
  { category: "Best Display", pick: "OnePlus 12R", reason: "A massive, incredibly bright AMOLED panel that outshines phones twice its price." },
  { category: "Best Battery", pick: "OnePlus 12R", reason: "5500mAh cell combined with excellent optimization means it easily lasts two days." },
  { category: "Best Value", pick: "Nothing Phone 2a", reason: "At $349, it offers a distinct design, smooth performance, and solid cameras without feeling cheap." }
];

const faqs = [
  {
    q: "Are budget phones good enough for gaming?",
    a: "Yes, many budget phones are surprisingly capable for gaming. Devices like the Poco X6 Pro, Realme GT Neo 5, and OnePlus 12R feature powerful processors that can handle demanding games like Genshin Impact or Call of Duty Mobile at high frame rates. However, phones heavily focused on cameras, like the Pixel 8a, may get warmer during extended gaming sessions."
  },
  {
    q: "How long do budget phones get software updates?",
    a: "Software support has improved dramatically. The Google Pixel 8a leads the pack with an incredible 7 years of OS and security updates. Samsung follows closely with 4 years of OS updates for its A-series. Motorola and Nothing typically offer 2 to 3 years of OS updates."
  },
  {
    q: "Can budget phones take good photos in low light?",
    a: "Generally, this is where budget phones struggle compared to flagships. However, the Google Pixel 8a and Pixel 7a are exceptions, capturing excellent low-light photos thanks to Google's Night Sight software. Most other budget phones will produce grainy or soft images in dim conditions."
  },
  {
    q: "Do budget phones have wireless charging?",
    a: "Wireless charging is still relatively rare in the sub-$400 category. The Google Pixel 8a and Pixel 7a are among the few that include it. Most manufacturers prioritize faster wired charging speeds or larger battery capacities over adding wireless charging hardware at this price point."
  },
  {
    q: "Is 5G necessary on a budget phone?",
    a: "While not strictly necessary, 5G is standard on almost all new budget phones in 2026, including every phone on our list. It ensures your phone is future-proofed for faster network speeds, even if 5G coverage in your immediate area isn't perfect yet."
  },
  {
    q: "Should I buy a new budget phone or a used flagship?",
    a: "It depends on your priorities. A used flagship (like a 2-year-old Galaxy S or iPhone) will typically offer a better build quality, wireless charging, and better secondary cameras. However, a new budget phone gives you a fresh battery, a warranty, and often longer remaining software support (as seen with the Pixel 8a)."
  },
  {
    q: "What is the average lifespan of a budget smartphone?",
    a: "With proper care, a modern budget smartphone can comfortably last 3 to 4 years. The determining factors are usually battery degradation and the length of software support. Phones with 4+ years of updates (Pixel, Samsung) will remain secure and usable longer than those with shorter update cycles."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Budget Smartphones 2026 — 12 Phones Under $400 Compared",
    "description": "Compare 12 of the best budget smartphones under $400 in 2026. Reviewing Google Pixel 8a, Samsung Galaxy A55, OnePlus 12R, Nothing Phone 2a, and more.",
    "author": {
      "@type": "Organization",
      "name": "Fix It With Duct Tape"
    },
    "datePublished": "2026-04-15",
    "dateModified": "2026-04-15"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Best Budget Smartphones 2026 — 12 Phones Under $400 Compared",
  description: "Compare 12 of the best budget smartphones under $400 in 2026. Reviewing Google Pixel 8a, Samsung Galaxy A55, OnePlus 12R, Nothing Phone 2a, and more.",
  category: "list",
  published: "2026-04-15",
};
---

<SiteLayout
  site="fixitwithducttape"
  title="Best Budget Smartphones 2026 — 12 Phones Under $400 Compared"
  description="Compare 12 of the best budget smartphones under $400 in 2026. Reviewing Google Pixel 8a, Samsung Galaxy A55, OnePlus 12R, Nothing Phone 2a, and more."
  canonical="https://fixitwithducttape.photonbuilder.com/best-budget-smartphones"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Best Budget Smartphones (2026)</h1>
      <p>We compared 12 smartphones under $400 across camera quality, battery life, performance, and software. Here are the best budget options worth your money.</p>
    </div>

    <section class="content-section">
      <p>Buying a budget smartphone used to mean accepting terrible cameras, sluggish performance, and screens you couldn't read in sunlight. In 2026, the sub-$400 market has fundamentally shifted. You can now buy a phone with the exact same processor as a $1,000 flagship, or a camera that uses industry-leading AI processing.</p>
      <p>Whether you're looking for the absolute best camera (Google Pixel 8a), incredible battery life (OnePlus 12R), or simply the best overall value (Nothing Phone 2a), we've compiled and compared the top 12 budget smartphones available today.</p>

      <h2>Category Winners</h2>
      <div class="winners-grid">
        {categoryWinners.map(w => (
          <div class="winner-card">
            <span class="winner-label">{w.category}</span>
            <strong>{w.pick}</strong>
            <span class="winner-reason">{w.reason}</span>
          </div>
        ))}
      </div>

      <h2>Comparison Table</h2>
      <p>Click any column header to sort the data. Prices reflect standard retail pricing in USD.</p>
      <div class="table-wrapper">
        <table id="comparison-table">
          <thead>
            <tr>
              <th data-sort="string">Phone</th>
              <th data-sort="number">Price</th>
              <th data-sort="string">Display</th>
              <th data-sort="string">Processor</th>
              <th data-sort="number">RAM</th>
              <th data-sort="number">Storage</th>
              <th data-sort="string">Camera</th>
              <th data-sort="number">Battery</th>
              <th data-sort="string">5G</th>
            </tr>
          </thead>
          <tbody>
            {phones.map(p => (
              <tr>
                <td><strong>{p.name}</strong></td>
                <td data-value={p.price}>{p.priceStr}</td>
                <td>{p.display}</td>
                <td>{p.processor}</td>
                <td data-value={parseInt(p.ram)}>{p.ram}</td>
                <td data-value={parseInt(p.storage)}>{p.storage}</td>
                <td>{p.camera}</td>
                <td data-value={parseInt(p.battery)}>{p.battery}</td>
                <td>{p.has5G}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Detailed Phone Reviews</h2>

      {phones.map((p, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{p.name}</h3>
              {p.badge && <span class="badge">{p.badge}</span>}
            </div>
            <span class="review-price">{p.priceStr}</span>
          </div>

          <p class="review-summary">{p.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Display</span><span class="spec-value">{p.display}</span></div>
            <div class="spec"><span class="spec-label">Processor</span><span class="spec-value">{p.processor}</span></div>
            <div class="spec"><span class="spec-label">RAM / Storage</span><span class="spec-value">{p.ram} / {p.storage}</span></div>
            <div class="spec"><span class="spec-label">Battery</span><span class="spec-value">{p.battery}</span></div>
          </div>

          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{p.pros.map(pro => <li>{pro}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{p.cons.map(con => <li>{con}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Buying Guide: How to Choose a Budget Phone</h2>
      <p>When shopping in the sub-$400 category, you can't have everything. Manufacturers have to cut corners somewhere to reach these price points. The key is identifying which compromises you are comfortable with.</p>

      <h3>1. Prioritize Software Support</h3>
      <p>Hardware is only as good as the software that runs it. Look for phones that promise at least 3 years of OS updates. The Google Pixel 8a is the gold standard here, offering an unprecedented 7 years of support. Samsung is also excellent, offering 4 years on its A-series devices.</p>

      <h3>2. Understand Processor Trade-offs</h3>
      <p>Processors fall into two camps: flagship chips and mid-range chips. Phones like the OnePlus 12R and Pixel 8a use flagship-grade chips (Snapdragon 8 Gen 2 and Tensor G3), meaning they perform identically to $1,000 phones. Others, like the Samsung Galaxy A55 or Nothing Phone 2a, use capable mid-range chips that handle everyday tasks well but might stutter on demanding games.</p>

      <h3>3. The Megapixel Myth</h3>
      <p>Don't be fooled by 200MP camera labels on budget phones. A higher megapixel count does not equal better photos. The Google Pixel 8a has a 64MP sensor but takes vastly superior photos to the 200MP Redmi Note 13 Pro because of Google's superior computational photography software.</p>

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

    </section>
  </div>

  <script is:inline>
    (function() {
      const table = document.getElementById('comparison-table');
      if (!table) return;
      const headers = table.querySelectorAll('th');
      let currentSort = { col: -1, asc: true };

      headers.forEach((th, index) => {
        th.style.cursor = 'pointer';
        th.addEventListener('click', () => {
          const sortType = th.dataset.sort;
          const asc = currentSort.col === index ? !currentSort.asc : true;
          currentSort = { col: index, asc };

          headers.forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
          th.classList.add(asc ? 'sort-asc' : 'sort-desc');

          const tbody = table.querySelector('tbody');
          const rows = Array.from(tbody.querySelectorAll('tr'));

          rows.sort((a, b) => {
            const cellA = a.children[index];
            const cellB = b.children[index];
            let valA, valB;

            if (sortType === 'number') {
              valA = parseFloat(cellA.dataset.value || cellA.textContent.replace(/[^0-9.\-]/g, ''));
              valB = parseFloat(cellB.dataset.value || cellB.textContent.replace(/[^0-9.\-]/g, ''));
              return asc ? valA - valB : valB - valA;
            } else {
              valA = cellA.textContent.trim().toLowerCase();
              valB = cellB.textContent.trim().toLowerCase();
              return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
            }
          });

          rows.forEach(row => tbody.appendChild(row));
        });
      });
    })();
  </script>

  <style is:inline>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }

    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Winners Grid */
    .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
    .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
    .winner-card strong { font-size: 1.05rem; }
    .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

    /* Comparison Table */
    .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; user-select: none; position: relative; }
    th::after { content: '⇅'; margin-left: 0.3rem; opacity: 0.3; font-size: 0.75rem; }
    th.sort-asc::after { content: '↑'; opacity: 0.8; }
    th.sort-desc::after { content: '↓'; opacity: 0.8; }
    td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* Review Cards */
    .review-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .review-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
    .review-header > div { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .review-rank { font-size: 1.1rem; font-weight: 800; color: var(--accent-color); }
    .review-header h3 { margin: 0; font-size: 1.25rem; color: var(--text-primary); }
    .badge { background: var(--accent-color); color: #000; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 20px; white-space: nowrap; }
    .review-price { font-size: 1.1rem; font-weight: 800; color: var(--text-primary); }
    .review-summary { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

    .specs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-bottom: 1rem; }
    .spec { display: flex; flex-direction: column; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border-color); }
    .spec-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); font-weight: 600; }
    .spec-value { font-size: 0.95rem; color: var(--text-primary); font-weight: 600; }

    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .pros h4, .cons h4 { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .pros h4 { color: #22c55e; }
    .cons h4 { color: #ef4444; }
    .pros ul, .cons ul { margin: 0; padding-left: 1.2rem; font-size: 0.9rem; }
    .pros li, .cons li { margin-bottom: 0.3rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .pros-cons { grid-template-columns: 1fr; }
      .specs-grid { grid-template-columns: 1fr 1fr; }
      .review-header { flex-direction: column; }
      .winners-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>
