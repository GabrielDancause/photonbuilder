---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const categoryWinners = [
  {
    category: "Best Smart Hub",
    pick: "Home Assistant",
    reason: "Unparalleled local control and massive automation capabilities."
  },
  {
    category: "Best Smart Speaker",
    pick: "Amazon Echo",
    reason: "Widest compatibility with third-party devices and responsive voice assistant."
  },
  {
    category: "Best Smart Lights",
    pick: "Philips Hue",
    reason: "The gold standard for reliability, color quality, and ecosystem support."
  },
  {
    category: "Best Smart Thermostat",
    pick: "Ecobee",
    reason: "Excellent room sensors and broad ecosystem integration including HomeKit."
  }
];

const devices = [
  {
    name: "Home Assistant",
    badge: "Best Hub",
    category: "Hub",
    ecosystem: "Universal (Matter/Zigbee/Z-Wave)",
    localOrCloud: "Local",
    privacy: "Excellent",
    automation: "Advanced",
    price: "Free (Requires Hardware)",
    openSource: "Yes",
    summary: "Home Assistant is the ultimate hub for power users. It runs locally, ensuring your data never leaves your home, and supports virtually every smart device on the market. It requires some technical know-how to set up but offers unmatched flexibility and automation power.",
    pros: ["100% local control", "Massive community and integrations", "Completely open-source"],
    cons: ["Steep learning curve", "Requires your own hardware (e.g., Raspberry Pi)"]
  },
  {
    name: "Samsung SmartThings",
    badge: "Best Mainstream Hub",
    category: "Hub",
    ecosystem: "SmartThings, Matter, Zigbee, Z-Wave",
    localOrCloud: "Hybrid",
    privacy: "Good",
    automation: "Very Good",
    price: "$130",
    openSource: "No",
    summary: "SmartThings remains one of the most accessible hubs for building a robust smart home. It supports a wide variety of protocols including Zigbee and Z-Wave, and its recent updates have pushed more processing locally, reducing reliance on the cloud.",
    pros: ["Easy to set up and use", "Supports many protocols out of the box", "Good balance of local and cloud"],
    cons: ["Not entirely local", "Some advanced automations are limited compared to Home Assistant"]
  },
  {
    name: "Hubitat Elevation",
    badge: "Local Pioneer",
    category: "Hub",
    ecosystem: "Matter, Zigbee, Z-Wave",
    localOrCloud: "Local",
    privacy: "Excellent",
    automation: "Advanced",
    price: "$150",
    openSource: "No",
    summary: "Hubitat is designed from the ground up for local control. If your internet goes down, your smart home keeps working. It's a fantastic middle ground between the user-friendliness of SmartThings and the raw power of Home Assistant.",
    pros: ["Fast local processing", "No cloud dependency for automations", "Strong developer community"],
    cons: ["Interface is a bit dated", "App isn't as polished as competitors"]
  },
  {
    name: "Amazon Echo (4th Gen)",
    badge: "Best Speaker",
    category: "Speaker/Hub",
    ecosystem: "Alexa, Matter, Zigbee",
    localOrCloud: "Cloud",
    privacy: "Moderate",
    automation: "Good",
    price: "$99",
    openSource: "No",
    summary: "The 4th Gen Echo is more than just a speaker; it includes a built-in Zigbee hub and Matter support, making it a great starting point for a smart home. Alexa remains the most widely supported voice assistant.",
    pros: ["Excellent voice recognition", "Built-in Zigbee and Matter hub", "Affordable starting point"],
    cons: ["Heavy reliance on the cloud", "Privacy concerns with Amazon's data collection"]
  },
  {
    name: "Apple HomePod (2nd Gen)",
    badge: "Best for Apple Users",
    category: "Speaker/Hub",
    ecosystem: "HomeKit, Matter",
    localOrCloud: "Local/Hybrid",
    privacy: "Excellent",
    automation: "Good",
    price: "$299",
    openSource: "No",
    summary: "For users deep in the Apple ecosystem, the HomePod offers fantastic sound quality and serves as a secure, privacy-focused HomeKit and Matter hub.",
    pros: ["Superb audio quality", "Strong privacy focus", "Seamless Apple integration"],
    cons: ["Expensive", "Siri is sometimes less capable than Alexa or Google"]
  },
  {
    name: "Google Nest Hub (2nd Gen)",
    badge: "Best Display",
    category: "Display/Hub",
    ecosystem: "Google Assistant, Matter",
    localOrCloud: "Cloud",
    privacy: "Moderate",
    automation: "Good",
    price: "$99",
    openSource: "No",
    summary: "The Nest Hub is an excellent smart display for visual control of your home. It integrates perfectly with Google Assistant and acts as a Matter controller.",
    pros: ["Great visual dashboard for smart home", "Sleep tracking capabilities", "Good value"],
    cons: ["Cloud dependent", "No built-in Zigbee or Z-Wave"]
  },
  {
    name: "Philips Hue",
    badge: "Best Lighting",
    category: "Lights",
    ecosystem: "Matter, Zigbee (via Bridge)",
    localOrCloud: "Local (with Bridge)",
    privacy: "Good",
    automation: "Very Good",
    price: "Varies",
    openSource: "No",
    summary: "Philips Hue remains the undisputed king of smart lighting. While pricey, the reliability, color accuracy, and vast ecosystem of bulbs and accessories are unmatched.",
    pros: ["Incredibly reliable", "Huge variety of bulb types", "Excellent third-party integration"],
    cons: ["Very expensive", "Requires the Hue Bridge for full functionality"]
  },
  {
    name: "LIFX",
    badge: "Brightest Colors",
    category: "Lights",
    ecosystem: "Wi-Fi, Matter (Newer)",
    localOrCloud: "Cloud",
    privacy: "Moderate",
    automation: "Good",
    price: "Varies",
    openSource: "No",
    summary: "LIFX bulbs connect directly to Wi-Fi, eliminating the need for a hub. They are known for their incredibly vibrant and bright colors, often outshining Hue.",
    pros: ["No hub required", "Exceptionally bright and vivid colors", "Good app experience"],
    cons: ["Wi-Fi reliability depends on your router", "Can crowd your local network"]
  },
  {
    name: "Govee",
    badge: "Best Value Lighting",
    category: "Lights",
    ecosystem: "Wi-Fi, Bluetooth",
    localOrCloud: "Cloud",
    privacy: "Moderate",
    automation: "Moderate",
    price: "Varies",
    openSource: "No",
    summary: "Govee offers an affordable alternative to premium brands. They are especially famous for their LED light strips and unique TV backlighting systems.",
    pros: ["Very affordable", "Fun and unique lighting effects", "Huge product range"],
    cons: ["App can be overwhelming", "Mostly cloud-dependent"]
  },
  {
    name: "Nanoleaf",
    badge: "Best Decorative",
    category: "Lights",
    ecosystem: "Matter, Thread, Wi-Fi",
    localOrCloud: "Local (Thread)",
    privacy: "Good",
    automation: "Good",
    price: "Varies",
    openSource: "No",
    summary: "Nanoleaf's modular light panels are essentially interactive wall art. Their newer Essentials line also champions the Thread protocol for fast, local communication.",
    pros: ["Unique modular designs", "Strong support for Thread and Matter", "Great for gaming setups"],
    cons: ["Setup can be tricky", "Adhesive mounting can damage walls if removed incorrectly"]
  },
  {
    name: "Ecobee Smart Thermostat Premium",
    badge: "Best Thermostat",
    category: "Thermostat",
    ecosystem: "Alexa, HomeKit, Google",
    localOrCloud: "Cloud",
    privacy: "Good",
    automation: "Very Good",
    price: "$249",
    openSource: "No",
    summary: "Ecobee stands out with its excellent remote room sensors, ensuring even heating and cooling. It also features built-in Alexa or Siri (with a HomePod) voice control.",
    pros: ["Remote sensors balance home temperature", "Built-in voice assistant", "Excellent HomeKit support"],
    cons: ["Premium price", "Installation requires a C-wire (adapter included)"]
  },
  {
    name: "Google Nest Learning Thermostat",
    badge: "Best Design",
    category: "Thermostat",
    ecosystem: "Google Assistant, Matter",
    localOrCloud: "Cloud",
    privacy: "Moderate",
    automation: "Very Good",
    price: "$249",
    openSource: "No",
    summary: "The pioneer of smart thermostats, the Nest Learning Thermostat learns your schedule and adjusts automatically. Its iconic rotating dial design remains a favorite.",
    pros: ["Learns your routine automatically", "Beautiful physical design", "Energy-saving features"],
    cons: ["Less granular control than Ecobee", "Doesn't work well with HomeKit out of the box"]
  },
  {
    name: "August Wi-Fi Smart Lock",
    badge: "Best Retrofit Lock",
    category: "Lock",
    ecosystem: "Alexa, Google, HomeKit",
    localOrCloud: "Cloud/Bluetooth",
    privacy: "Good",
    automation: "Good",
    price: "$229",
    openSource: "No",
    summary: "The August lock installs over your existing deadbolt on the inside of the door, meaning you can keep your original keys. It features built-in Wi-Fi, so no extra bridge is needed.",
    pros: ["Keeps your existing exterior hardware and keys", "Built-in Wi-Fi", "Auto-unlock feature works well"],
    cons: ["Bulky interior design", "Eats through batteries quickly due to Wi-Fi"]
  },
  {
    name: "Yale Assure Lock 2",
    badge: "Best Full Replacement",
    category: "Lock",
    ecosystem: "Matter, Alexa, Google, HomeKit",
    localOrCloud: "Hybrid",
    privacy: "Good",
    automation: "Good",
    price: "$259",
    openSource: "No",
    summary: "A sleek, full deadbolt replacement that offers multiple ways to unlock: keypad, app, or key (depending on the model). The newer versions support Matter.",
    pros: ["Sleek design", "Multiple entry methods", "Modular communication modules (including Matter)"],
    cons: ["Requires removing existing deadbolt", "Modules cost extra"]
  },
  {
    name: "Schlage Encode Plus",
    badge: "Best for Apple Home Keys",
    category: "Lock",
    ecosystem: "HomeKit, Alexa, Google",
    localOrCloud: "Cloud/Local",
    privacy: "Good",
    automation: "Good",
    price: "$299",
    openSource: "No",
    summary: "This lock is highly sought after by Apple users because it supports Apple Home Keys, allowing you to unlock the door by simply tapping your iPhone or Apple Watch.",
    pros: ["Apple Home Key support", "Very robust hardware", "Built-in Wi-Fi"],
    cons: ["Expensive", "Often out of stock"]
  },
  {
    name: "Ring Video Doorbell Pro 2",
    badge: "Best Doorbell Camera",
    category: "Camera",
    ecosystem: "Alexa",
    localOrCloud: "Cloud",
    privacy: "Moderate",
    automation: "Moderate",
    price: "$249",
    openSource: "No",
    summary: "Ring offers a comprehensive security ecosystem. The Pro 2 provides excellent head-to-toe video, radar-based 3D motion detection, and seamless Alexa integration.",
    pros: ["Excellent video quality and field of view", "Advanced motion detection", "Great Alexa integration"],
    cons: ["Requires a subscription for recording", "No HomeKit or Google Assistant support"]
  },
  {
    name: "Arlo Pro 4",
    badge: "Best Wireless Camera",
    category: "Camera",
    ecosystem: "Alexa, Google, HomeKit",
    localOrCloud: "Cloud",
    privacy: "Good",
    automation: "Good",
    price: "$199",
    openSource: "No",
    summary: "Arlo cameras are known for high-quality wireless video and broad ecosystem support. The Pro 4 connects directly to Wi-Fi without needing a base station.",
    pros: ["Excellent 2K video", "Completely wireless setup", "Supports all major voice assistants"],
    cons: ["Subscription required for most features", "Battery needs periodic recharging"]
  },
  {
    name: "EufyCam 2C",
    badge: "Best Local Storage Camera",
    category: "Camera",
    ecosystem: "HomeKit, Alexa, Google",
    localOrCloud: "Local",
    privacy: "Excellent",
    automation: "Moderate",
    price: "$239 (2-pack)",
    openSource: "No",
    summary: "Eufy's biggest selling point is that it stores video locally on a base station, meaning there are no mandatory monthly fees for cloud storage.",
    pros: ["No monthly subscription fees", "Local video storage", "Long battery life"],
    cons: ["Requires the HomeBase hub", "App interface can be cluttered"]
  },
  {
    name: "Aqara Motion & Window Sensors",
    badge: "Best Sensors",
    category: "Sensors",
    ecosystem: "HomeKit, Alexa, Google",
    localOrCloud: "Local",
    privacy: "Excellent",
    automation: "Excellent",
    price: "$20+",
    openSource: "No",
    summary: "Aqara's Zigbee sensors are the backbone of many advanced smart homes. They are incredibly affordable, local, and respond instantly for triggering automations.",
    pros: ["Very affordable", "Instant local response", "Tiny form factor"],
    cons: ["Requires an Aqara hub or a Zigbee stick", "Setup can be finicky"]
  },
  {
    name: "Kasa Smart Plug with Energy Monitoring",
    badge: "Best Smart Plug",
    category: "Plugs",
    ecosystem: "Matter, HomeKit, Alexa, Google",
    localOrCloud: "Cloud/Local",
    privacy: "Moderate",
    automation: "Good",
    price: "$20 (2-pack)",
    openSource: "No",
    summary: "Kasa (by TP-Link) now offers Matter-certified plugs with energy monitoring, turning any 'dumb' appliance into a smart device instantly.",
    pros: ["Matter certified", "Energy monitoring built-in", "Very reliable"],
    cons: ["Can block adjacent outlets", "App requires an account"]
  }
];

const faqs = [
  {
    q: "What is the difference between local and cloud-based smart home devices?",
    a: "Cloud-based devices require an active internet connection to communicate with their servers to process commands (like asking Alexa to turn on a light). Local devices communicate directly with a hub (like Home Assistant or Hubitat) on your home network. Local control is faster, more private, and works even when your internet is down."
  },
  {
    q: "What is Matter, and why is it important?",
    a: "Matter is a new universal smart home standard created jointly by Apple, Google, Amazon, and others. It ensures that smart devices can communicate locally and seamlessly across different ecosystems. If a device supports Matter, it will work with HomeKit, Alexa, and Google Assistant without needing separate integrations."
  },
  {
    q: "Do I really need a smart home hub?",
    a: "It depends. If you only have a few Wi-Fi devices, you might not need one. However, as your smart home grows, a hub (using protocols like Zigbee, Z-Wave, or Thread) reduces strain on your Wi-Fi router, enables local control, and allows for complex automations between different brands of devices."
  },
  {
    q: "Which smart home ecosystem is best for privacy?",
    a: "Apple's HomeKit and open-source local solutions like Home Assistant are generally considered the best for privacy. HomeKit processes data locally where possible and anonymizes requests, while Home Assistant keeps 100% of your data on your own hardware."
  },
  {
    q: "Can I mix and match different brands in my smart home?",
    a: "Yes, provided you have a way to link them. A hub like SmartThings or Home Assistant can bridge different brands. Alternatively, using devices that support the new Matter standard ensures cross-compatibility out of the box."
  }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best Smart Home Devices 2026",
  "description": "Upgrade your living space. We review the best smart home devices for 2026 across hubs, lighting, security, and more, comparing Home Assistant, Philips Hue, Ecobee, and others.",
  "author": {
    "@type": "Person",
    "name": "Fix It With Duct Tape Editorial Team"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};
---

<SiteLayout
  site="fixitwithducttape"
  title="Best Smart Home Devices 2026 | Fix It With Duct Tape"
  description="Top smart home devices for 2026: hubs, speakers, lights, thermostats, locks, cameras, and sensors compared by ecosystem and privacy."
  canonical="https://fixitwithducttape.photonbuilder.com/best-smart-home-devices"
  schema={[articleSchema, faqSchema]}
>
  <div class="page-content">
    <div class="hero">
      <h1>Best Smart Home Devices of 2026</h1>
      <p>Build a faster, more secure, and highly automated home. We compare top smart hubs, lights, locks, and cameras focusing on local control, privacy, and ecosystem flexibility.</p>
    </div>

    <section class="content-section">
      <p>In 2026, the smart home has matured beyond simple voice commands. The focus has shifted toward robust local control, the universal Matter standard, and true automation that happens seamlessly in the background. Whether you are deeply invested in Apple HomeKit, rely on Alexa, or prefer the ultimate privacy of a local Home Assistant setup, choosing the right hardware is crucial.</p>
      <p>We've tested the leading devices across all major categories (hubs, speakers, lights, thermostats, locks, cameras, sensors, and plugs) to help you build a reliable, interconnected home environment that works even when the internet goes down.</p>

      <h2>Category Winners</h2>
      <div class="winners-grid">
        {categoryWinners.map(w => (
          <div class="winner-card">
            <span class="winner-label">{w.category}</span>
            <strong>{w.pick}</strong>
            <span class="winner-reason">{w.reason}</span>
          </div>
        ))}
      </div>

      <h2>Comparison Table</h2>
      <p>Prices are approximate and subject to change.</p>
      <div class="table-wrapper">
        <table id="comparison-table">
          <thead>
            <tr>
              <th>Device</th>
              <th>Category</th>
              <th>Ecosystem</th>
              <th>Local vs Cloud</th>
              <th>Privacy</th>
              <th>Automation</th>
            </tr>
          </thead>
          <tbody>
            {devices.map(d => (
              <tr>
                <td><strong>{d.name}</strong></td>
                <td>{d.category}</td>
                <td>{d.ecosystem}</td>
                <td>{d.localOrCloud}</td>
                <td>{d.privacy}</td>
                <td>{d.automation}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Detailed Reviews</h2>

      {devices.map((d, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{d.name}</h3>
              {d.badge && <span class="badge">{d.badge}</span>}
            </div>
            <span class="review-price">{d.price}</span>
          </div>

          <p class="review-summary">{d.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Category</span><span class="spec-value">{d.category}</span></div>
            <div class="spec"><span class="spec-label">Ecosystem</span><span class="spec-value">{d.ecosystem}</span></div>
            <div class="spec"><span class="spec-label">Local/Cloud</span><span class="spec-value">{d.localOrCloud}</span></div>
            <div class="spec"><span class="spec-label">Privacy</span><span class="spec-value">{d.privacy}</span></div>
            <div class="spec"><span class="spec-label">Automation</span><span class="spec-value">{d.automation}</span></div>
            <div class="spec"><span class="spec-label">Open Source</span><span class="spec-value">{d.openSource}</span></div>
          </div>

          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{d.pros.map(pro => <li>{pro}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{d.cons.map(con => <li>{con}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

    </section>
  </div>
  <style>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }

    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Winners Grid */
    .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
    .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
    .winner-card strong { font-size: 1.05rem; }
    .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

    /* Comparison Table */
    .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* Review Cards */
    .review-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .review-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
    .review-header > div { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .review-rank { font-size: 1.1rem; font-weight: 800; color: var(--accent-color); }
    .review-header h3 { margin: 0; font-size: 1.25rem; color: var(--text-primary); }
    .badge { background: var(--accent-color); color: #000; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 20px; white-space: nowrap; }
    .review-price { font-size: 1.1rem; font-weight: 800; color: var(--text-primary); }
    .review-summary { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

    .specs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-bottom: 1rem; }
    .spec { display: flex; flex-direction: column; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border-color); }
    .spec-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); font-weight: 600; }
    .spec-value { font-size: 0.95rem; color: var(--text-primary); font-weight: 600; }

    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .pros h4, .cons h4 { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .pros h4 { color: #22c55e; }
    .cons h4 { color: #ef4444; }
    .pros ul, .cons ul { margin: 0; padding-left: 1.2rem; font-size: 0.9rem; }
    .pros li, .cons li { margin-bottom: 0.3rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    :global(td strong) { color: var(--text-primary); }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .pros-cons { grid-template-columns: 1fr; }
      .specs-grid { grid-template-columns: 1fr 1fr; }
      .review-header { flex-direction: column; }
      .winners-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>