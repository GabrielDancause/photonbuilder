---
import SiteLayout from "../../../layouts/SiteLayout.astro";

const chargers = [
  {
    name: "Ugreen 145W Power Bank",
    badge: "Best Laptop Charger",
    capacity: "25,000 mAh",
    outputWatts: "145W",
    ports: "2x USB-C, 1x USB-A",
    sizeWeight: "6.3 x 3.2 x 1.1 in / 1.1 lbs",
    passthrough: "Yes",
    price: 149,
    priceStr: "$149",
    summary: "The Ugreen 145W is an absolute powerhouse capable of fast-charging demanding laptops like the MacBook Pro 16. It features a digital display and massive capacity while remaining surprisingly portable for its output.",
    pros: ["Massive 145W total output", "Charges laptops effortlessly", "Helpful digital display"],
    cons: ["Heavy", "Expensive"]
  },
  {
    name: "Anker PowerCore 10000 Redux",
    badge: "Best Pocket",
    capacity: "10,000 mAh",
    outputWatts: "25W",
    ports: "1x USB-C, 1x USB-A",
    sizeWeight: "4.1 x 2.0 x 1.0 in / 6.8 oz",
    passthrough: "No",
    price: 49,
    priceStr: "$49",
    summary: "The PowerCore 10000 Redux from Anker remains the gold standard for pocketability. It perfectly balances a multi-charge capacity with a form factor that slips easily into a jeans pocket or small purse.",
    pros: ["Incredibly small and light", "Reliable 25W fast charging", "Excellent build quality"],
    cons: ["Only 10,000 mAh capacity", "No passthrough charging"]
  },
  {
    name: "Baseus Blade 100W",
    badge: "Best Standard",
    capacity: "20,000 mAh",
    outputWatts: "100W",
    ports: "2x USB-C, 2x USB-A",
    sizeWeight: "6.4 x 5.6 x 0.7 in / 1.0 lbs",
    passthrough: "Yes",
    price: 99,
    priceStr: "$99",
    summary: "The Baseus Blade revolutionizes the standard 20K power bank with an ultra-thin, flat design that slips into a laptop bag alongside your computer, unlike traditional chunky bricks.",
    pros: ["Unique, ultra-thin flat design", "100W output can handle most laptops", "Clear LCD status screen"],
    cons: ["Wide footprint takes up desk space", "Can get warm during maximum output"]
  },
  {
    name: "RAVPower 30000mAh Power Bank",
    badge: "Best High-Capacity",
    capacity: "30,000 mAh",
    outputWatts: "90W",
    ports: "2x USB-C, 2x USB-A",
    sizeWeight: "5.9 x 3.2 x 1.6 in / 1.2 lbs",
    passthrough: "Yes",
    price: 89,
    priceStr: "$89",
    summary: "When you need enough juice for an entire weekend trip away from the wall, this RAVPower 30K unit delivers. It offers a staggering capacity and enough output to charge a laptop alongside a phone.",
    pros: ["Massive 30,000 mAh capacity", "Excellent value for the power", "Can charge up to 4 devices at once"],
    cons: ["Very bulky and heavy", "Takes a long time to recharge fully"]
  },
  {
    name: "Goal Zero Venture 75",
    badge: "Best Solar",
    capacity: "19,200 mAh",
    outputWatts: "60W",
    ports: "1x USB-C, 2x USB-A",
    sizeWeight: "6.1 x 3.8 x 1.1 in / 1.3 lbs",
    passthrough: "Yes",
    price: 119,
    priceStr: "$119",
    summary: "Built for the outdoors, the Goal Zero Venture 75 is IP67 waterproof and dustproof. It integrates flawlessly with Goal Zero's Nomad solar panels, making it the ultimate off-grid companion.",
    pros: ["Rugged, IP67 waterproof build", "Perfect for solar charging setups", "Built-in 50-lumen flashlight"],
    cons: ["Expensive for the capacity", "Heavy for hiking"]
  },
  {
    name: "Mophie Powerstation Plus",
    capacity: "10,000 mAh",
    outputWatts: "20W",
    ports: "Integrated Lightning & USB-C",
    sizeWeight: "5.8 x 2.8 x 0.7 in / 8.5 oz",
    passthrough: "Yes",
    price: 79,
    priceStr: "$79",
    summary: "The Mophie Powerstation Plus stands out by featuring built-in, stowable cables. You'll never need to worry about remembering to pack a separate cord to charge your devices.",
    pros: ["Built-in charging cables", "Sleek fabric finish", "Supports passthrough charging"],
    cons: ["Lower output wattage", "Cables are short and cannot be easily replaced if broken"]
  },
  {
    name: "Belkin BoostCharge Pro",
    capacity: "10,000 mAh",
    outputWatts: "20W",
    ports: "1x USB-C, MagSafe Wireless",
    sizeWeight: "4.2 x 2.6 x 0.8 in / 7.2 oz",
    passthrough: "Yes",
    price: 59,
    priceStr: "$59",
    summary: "The BoostCharge Pro from Belkin is a fantastic magnetic wireless power bank that snaps directly onto the back of MagSafe-compatible iPhones, offering a seamless, cable-free top-up on the go.",
    pros: ["Convenient MagSafe attachment", "Built-in kickstand", "Compact design"],
    cons: ["Wireless charging is slower than wired", "Blocks the camera on smaller phones like the iPhone Mini"]
  }
];

// Inline sorting logic for Astro build
const sortDirection = { col: -1, asc: true };

const categoryWinners = [
  { category: "Best Laptop Charger", pick: "Ugreen 145W Power Bank", reason: "Unmatched power output that handles high-demand laptops effortlessly." },
  { category: "Best Pocket", pick: "Anker PowerCore 10000 Redux", reason: "The perfect balance of capacity and ultra-compact portability." },
  { category: "Best Standard", pick: "Baseus Blade 100W", reason: "An innovative, slim design that slides perfectly into any laptop bag." },
  { category: "Best High-Capacity", pick: "RAVPower 30000mAh Power Bank", reason: "Massive capacity to keep all your devices powered for days." },
  { category: "Best Solar", pick: "Goal Zero Venture 75", reason: "Rugged, waterproof, and purpose-built for off-grid outdoor adventures." }
];

const faqs = [
  {
    q: "What does mAh mean in a portable charger?",
    a: "mAh stands for milliampere-hour. It is a unit that measures electric power over time and represents the energy capacity of the battery. A higher mAh means the power bank can hold more energy and charge your devices more times before needing to be recharged itself."
  },
  {
    q: "Can a portable charger charge my laptop?",
    a: "Yes, but only if the portable charger supports high wattage output (typically 45W, 65W, or higher) and uses USB-C Power Delivery (PD). Standard power banks intended for phones do not provide enough wattage to charge a laptop."
  },
  {
    q: "What is passthrough charging?",
    a: "Passthrough charging allows you to charge the power bank itself while simultaneously using the power bank to charge another device. This is very useful when you only have one wall outlet available overnight."
  },
  {
    q: "Can I bring a 30,000 mAh power bank on an airplane?",
    a: "Most airlines and the TSA limit lithium-ion batteries in carry-on luggage to 100 Watt-hours (Wh), which is roughly 27,000 mAh. A 30,000 mAh battery typically exceeds this limit and usually requires special airline approval before flying."
  },
  {
    q: "Is it safe to leave a portable charger plugged in all the time?",
    a: "Modern power banks have built-in management systems to prevent overcharging. However, keeping a lithium-ion battery constantly at 100% can degrade its long-term lifespan. It is generally better to unplug it once it is fully charged."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Portable Chargers 2026 — Top 7 Power Banks Compared",
    "description": "Compare 7 of the best portable chargers and power banks. Reviewing Anker, Baseus, Ugreen, RAVPower, and more.",
    "author": {
      "@type": "Organization",
      "name": "Fix It With Duct Tape"
    },
    "datePublished": "2026-06-15",
    "dateModified": "2026-06-15"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({
      "@type": "Question",
      "name": f.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": f.a
      }
    }))
  }
];

export const meta = {
  title: "Best Portable Chargers 2026 — Top 7 Power Banks Compared",
  description: "Compare 7 of the best portable chargers and power banks. Reviewing Anker, Baseus, Ugreen, RAVPower, and more.",
  category: "list",
  published: "2026-06-15",
};
---

<SiteLayout
  site="fixitwithducttape"
  title="Best Portable Chargers 2026 — Top 7 Power Banks Compared"
  description="Compare 7 of the best portable chargers and power banks. Reviewing Anker, Baseus, Ugreen, RAVPower, and more."
  canonical="https://fixitwithducttape.photonbuilder.com/best-portable-chargers"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Best Portable Chargers of 2026</h1>
      <p>We compared 7 of the top power banks available. Find the best option to keep your phones, tablets, and laptops charged on the go.</p>
    </div>

    <section class="content-section">
      <p>Whether you're traveling across the country, spending a weekend off the grid, or just trying to keep your phone alive during a long commute, a reliable portable charger is indispensable. The fear of a dead battery is a thing of the past.</p>
      <p>We've tested the market's leading power banks, from ultra-compact pocket units to massive bricks capable of charging laptops. Our comprehensive guide breaks down capacity, output wattage, and features to help you find the perfect portable charger for your needs.</p>

      <h2>Category Winners</h2>
      <div class="winners-grid">
        {categoryWinners.map(w => (
          <div class="winner-card">
            <span class="winner-label">{w.category}</span>
            <strong>{w.pick}</strong>
            <span class="winner-reason">{w.reason}</span>
          </div>
        ))}
      </div>

      <h2>Comparison Table</h2>
      <p>Click any column header to sort the data. Prices reflect standard retail pricing in USD.</p>
      <div class="table-wrapper">
        <table id="comparison-table">
          <thead>
            <tr>
              <th data-sort="string">Model</th>
              <th data-sort="string">Capacity</th>
              <th data-sort="string">Output Watts</th>
              <th data-sort="string">Ports</th>
              <th data-sort="string">Size/Weight</th>
              <th data-sort="string">Passthrough</th>
              <th data-sort="number">Price</th>
            </tr>
          </thead>
          <tbody>
            {chargers.map(c => (
              <tr>
                <td><strong>{c.name}</strong></td>
                <td>{c.capacity}</td>
                <td>{c.outputWatts}</td>
                <td>{c.ports}</td>
                <td>{c.sizeWeight}</td>
                <td>{c.passthrough}</td>
                <td data-value={c.price}>{c.priceStr}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2>Detailed Reviews</h2>

      {chargers.map((c, i) => (
        <div class="review-card">
          <div class="review-header">
            <div>
              <span class="review-rank">#{i + 1}</span>
              <h3>{c.name}</h3>
              {c.badge && <span class="badge">{c.badge}</span>}
            </div>
            <span class="review-price">{c.priceStr}</span>
          </div>

          <p class="review-summary">{c.summary}</p>

          <div class="specs-grid">
            <div class="spec"><span class="spec-label">Capacity</span><span class="spec-value">{c.capacity}</span></div>
            <div class="spec"><span class="spec-label">Output Watts</span><span class="spec-value">{c.outputWatts}</span></div>
            <div class="spec"><span class="spec-label">Ports</span><span class="spec-value">{c.ports}</span></div>
            <div class="spec"><span class="spec-label">Size/Weight</span><span class="spec-value">{c.sizeWeight}</span></div>
            <div class="spec"><span class="spec-label">Passthrough</span><span class="spec-value">{c.passthrough}</span></div>
          </div>

          <div class="pros-cons">
            <div class="pros">
              <h4>Pros</h4>
              <ul>{c.pros.map(pro => <li>{pro}</li>)}</ul>
            </div>
            <div class="cons">
              <h4>Cons</h4>
              <ul>{c.cons.map(con => <li>{con}</li>)}</ul>
            </div>
          </div>
        </div>
      ))}

      <h2>Frequently Asked Questions</h2>
      {faqs.map(f => (
        <div class="faq-item">
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </div>
      ))}

    </section>
  </div>

  <script is:inline>
    (function() {
      const table = document.getElementById('comparison-table');
      if (!table) return;
      const headers = table.querySelectorAll('th');
      let currentSort = { col: -1, asc: true };

      headers.forEach((th, index) => {
        th.style.cursor = 'pointer';
        th.addEventListener('click', () => {
          const sortType = th.dataset.sort;
          const asc = currentSort.col === index ? !currentSort.asc : true;
          currentSort = { col: index, asc };

          headers.forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
          th.classList.add(asc ? 'sort-asc' : 'sort-desc');

          const tbody = table.querySelector('tbody');
          const rows = Array.from(tbody.querySelectorAll('tr'));

          rows.sort((a, b) => {
            const cellA = a.children[index];
            const cellB = b.children[index];
            let valA, valB;

            if (sortType === 'number') {
              valA = parseFloat(cellA.dataset.value || cellA.textContent.replace(/[^0-9.\-]/g, ''));
              valB = parseFloat(cellB.dataset.value || cellB.textContent.replace(/[^0-9.\-]/g, ''));
              return asc ? valA - valB : valB - valA;
            } else {
              valA = cellA.textContent.trim().toLowerCase();
              valB = cellB.textContent.trim().toLowerCase();
              return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
            }
          });

          rows.forEach(row => tbody.appendChild(row));
        });
      });
    })();
  </script>

  <style>
    .page-content { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--text-primary); }
    .hero p { color: var(--text-secondary); font-size: 1.1rem; max-width: 650px; margin: 0 auto; line-height: 1.5; }

    .content-section { margin-bottom: 3rem; }
    .content-section h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 1rem; margin-top: 2.5rem; }
    .content-section h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 0.5rem; margin-top: 1.5rem; }
    .content-section p { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }
    .content-section ul { color: var(--text-secondary); margin-bottom: 1rem; padding-left: 1.5rem; line-height: 1.6; }
    .content-section li { margin-bottom: 0.5rem; }

    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    strong { color: var(--text-primary); }

    /* Winners Grid */
    .winners-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .winner-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.3rem; }
    .winner-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent-color); font-weight: 700; }
    .winner-card strong { font-size: 1.05rem; }
    .winner-reason { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

    /* Comparison Table */
    .table-wrapper { overflow-x: auto; margin: 1.5rem 0; border: 1px solid var(--border-color); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    th { background: var(--card-bg); padding: 0.75rem 0.6rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); white-space: nowrap; user-select: none; position: relative; }
    th::after { content: '⇅'; margin-left: 0.3rem; opacity: 0.3; font-size: 0.75rem; }
    th.sort-asc::after { content: '↑'; opacity: 0.8; }
    th.sort-desc::after { content: '↓'; opacity: 0.8; }
    td { padding: 0.65rem 0.6rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--card-bg); }

    /* Review Cards */
    .review-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
    .review-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
    .review-header > div { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .review-rank { font-size: 1.1rem; font-weight: 800; color: var(--accent-color); }
    .review-header h3 { margin: 0; font-size: 1.25rem; color: var(--text-primary); }
    .badge { background: var(--accent-color); color: #000; font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 20px; white-space: nowrap; }
    .review-price { font-size: 1.1rem; font-weight: 800; color: var(--text-primary); }
    .review-summary { color: var(--text-secondary); line-height: 1.6; margin-bottom: 1rem; }

    .specs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-bottom: 1rem; }
    .spec { display: flex; flex-direction: column; padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border-color); }
    .spec-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-secondary); font-weight: 600; }
    .spec-value { font-size: 0.95rem; color: var(--text-primary); font-weight: 600; }

    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .pros h4, .cons h4 { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .pros h4 { color: #22c55e; }
    .cons h4 { color: #ef4444; }
    .pros ul, .cons ul { margin: 0; padding-left: 1.2rem; font-size: 0.9rem; }
    .pros li, .cons li { margin-bottom: 0.3rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; padding: 1.2rem 1.5rem; margin: 1rem 0; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); }
    .faq-item p { margin-bottom: 0; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .pros-cons { grid-template-columns: 1fr; }
      .specs-grid { grid-template-columns: 1fr 1fr; }
      .review-header { flex-direction: column; }
      .winners-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>
