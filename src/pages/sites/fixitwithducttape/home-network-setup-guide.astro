    table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
    th { background: var(--card-bg); padding: 0.85rem 1rem; text-align: left; font-weight: 700; color: var(--text-primary); border-bottom: 2px solid var(--border-color); }
    td { padding: 0.85rem 1rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
