  <style is:inline>
    :root {
      --kbd-bg: #f3f4f6;
      --kbd-border: #d1d5db;
      --kbd-text: #1f2937;
      --kbd-highlight: #e74c3c;
      --kbd-highlight-text: #fff;
      --table-border: var(--border-color, #e2e8f0);
    }

    .page-content { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; line-height: 1.6; }
    .hero { text-align: center; padding: 3rem 0 1.5rem; }
    .hero h1 { font-size: 2.4rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.05rem; }

    /* Controls */
    .controls { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1.5rem; }
    .search-box { flex: 1; }
    .search-box input {
      width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border-color); border-radius: 8px;
      background: var(--card-bg); color: var(--text-primary); font-size: 1rem; outline: none;
    }
    .search-box input:focus { border-color: var(--kbd-highlight); box-shadow: 0 0 0 3px rgba(231,76,60,0.15); }
    .quiz-btn {
      padding: 0.75rem 1.25rem; background: var(--kbd-highlight); color: #fff; border: none;
      border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 0.95rem; white-space: nowrap;
    }
    .quiz-btn:hover { opacity: 0.9; }

    /* Tabs */
    .tabs { display: flex; gap: 0.25rem; overflow-x: auto; padding-bottom: 0.5rem; border-bottom: 2px solid var(--border-color); margin-bottom: 1.5rem; }
    .tab-btn {
      padding: 0.6rem 1rem; border: none; background: transparent; cursor: pointer;
      font-weight: 500; color: var(--text-secondary); border-radius: 6px 6px 0 0; font-size: 0.9rem; white-space: nowrap;
    }
    .tab-btn:hover { background: var(--card-bg); color: var(--text-primary); }
    .tab-btn.active { background: var(--card-bg); color: var(--kbd-highlight); border-bottom: 2px solid var(--kbd-highlight); margin-bottom: -2px; font-weight: 700; }

    /* Panels */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .category-block { margin-bottom: 2rem; }
    .category-block h2 { font-size: 1.2rem; margin-bottom: 0.75rem; color: var(--text-primary); border-left: 3px solid var(--kbd-highlight); padding-left: 0.75rem; }

    .shortcuts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 0.5rem; }
    .shortcut-row {
      display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 0.75rem;
      background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px;
      cursor: pointer; transition: border-color 0.15s;
    }
    .shortcut-row:hover { border-color: var(--kbd-highlight); }
    .shortcut-row.hidden { display: none; }
    .key-combo { display: flex; align-items: center; gap: 0.25rem; flex-shrink: 0; }
    .key-sep { color: var(--text-secondary); font-size: 0.8rem; }
    kbd {
      display: inline-block; padding: 0.2rem 0.5rem; background: var(--kbd-bg); border: 1px solid var(--kbd-border);
      border-radius: 4px; font-family: inherit; font-size: 0.8rem; font-weight: 600; color: var(--kbd-text);
      box-shadow: 0 1px 0 var(--kbd-border); min-width: 1.5rem; text-align: center; line-height: 1.4;
    }
    .shortcut-desc { color: var(--text-secondary); font-size: 0.9rem; }

    /* Keyboard Visual */
    .keyboard-visual-section { margin-top: 3rem; }
    .keyboard-visual-section h2 { margin-bottom: 0.25rem; }
    .keyboard-visual {
      background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px;
      padding: 1rem; display: inline-flex; flex-direction: column; gap: 0.35rem; margin-top: 1rem;
      max-width: 100%; overflow-x: auto;
    }
    .kb-row { display: flex; gap: 0.3rem; }
    .kb-key {
      min-width: 2.5rem; height: 2.5rem; display: flex; align-items: center; justify-content: center;
      background: var(--kbd-bg); border: 1px solid var(--kbd-border); border-radius: 5px;
      font-size: 0.72rem; font-weight: 600; color: var(--kbd-text); user-select: none;
      box-shadow: 0 2px 0 var(--kbd-border); transition: background 0.15s, color 0.15s, box-shadow 0.15s;
    }
    .kb-key.highlight { background: var(--kbd-highlight); color: var(--kbd-highlight-text); border-color: var(--kbd-highlight); box-shadow: 0 2px 0 #c0392b; }
    .kb-med { min-width: 3.5rem; }
    .kb-wide { min-width: 5rem; }
    .kb-xl { min-width: 6.5rem; }
    .kb-space { min-width: 16rem; }

    /* Quiz */
    .quiz-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000;
      align-items: center; justify-content: center;
    }
    .quiz-overlay.active { display: flex; }
    .quiz-card {
      background: var(--bg-primary, #fff); border-radius: 16px; padding: 2rem; width: 90%;
      max-width: 500px; position: relative; box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }
    .quiz-close {
      position: absolute; top: 0.75rem; right: 1rem; background: none; border: none;
      font-size: 1.5rem; cursor: pointer; color: var(--text-secondary);
    }
    .quiz-card h2 { margin: 0 0 1rem; }
    .quiz-tab-select { margin-bottom: 1.25rem; display: flex; gap: 0.5rem; align-items: center; }
    .quiz-tab-select select {
      flex: 1; padding: 0.5rem; border: 1px solid var(--border-color); border-radius: 6px;
      background: var(--card-bg); color: var(--text-primary); font-size: 0.9rem;
    }
    .quiz-prompt {
      font-size: 1.15rem; font-weight: 600; text-align: center; padding: 1.5rem 0;
      color: var(--text-primary); min-height: 4rem;
    }
    .quiz-keys {
      display: flex; gap: 0.3rem; justify-content: center; min-height: 2.5rem;
      flex-wrap: wrap; margin-bottom: 1rem;
    }
    .quiz-keys kbd { font-size: 1rem; padding: 0.4rem 0.75rem; }
    .quiz-actions { display: flex; gap: 0.75rem; justify-content: center; }
    .quiz-action-btn {
      padding: 0.6rem 1.5rem; border: 1px solid var(--border-color); border-radius: 8px;
      background: var(--card-bg); color: var(--text-primary); font-weight: 600; cursor: pointer; font-size: 0.9rem;
    }
    .quiz-action-btn:hover { border-color: var(--kbd-highlight); }
    .quiz-score { display: flex; gap: 1.5rem; justify-content: center; margin-top: 1rem; font-size: 0.9rem; color: var(--text-secondary); }

    /* FAQ */
    .faq-section { margin-top: 3rem; }
    .faq-section h2 { margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); outline: none; }
    .faq-section p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); }

    /* Related */
    .related-timers { margin-top: 3rem; }
    .related-timers h2 { margin-bottom: 1rem; }
    .related-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; }
    .related-link {
      padding: 0.5rem 1rem; background: var(--card-bg); border: 1px solid var(--border-color);
      border-radius: 8px; color: var(--text-primary); text-decoration: none; font-size: 0.9rem;
      transition: border-color 0.2s;
    }
    .related-link:hover { border-color: var(--kbd-highlight); text-decoration: none; }

    a { color: var(--kbd-highlight); text-decoration: none; }
    a:hover { text-decoration: underline; }

    @media (max-width: 768px) {
      .shortcuts-grid { grid-template-columns: 1fr; }
      .controls { flex-direction: column; }
      .search-box { width: 100%; }
      .kb-space { min-width: 8rem; }
      .kb-key { min-width: 2rem; height: 2rem; font-size: 0.6rem; }
      .kb-med { min-width: 2.8rem; }
      .kb-wide { min-width: 3.8rem; }
      .kb-xl { min-width: 4.5rem; }
      .hero h1 { font-size: 1.8rem; }
    }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      /* ── Tabs ── */
      const tabBtns = document.querySelectorAll(".tab-btn");
      const panels = document.querySelectorAll(".tab-panel");
      tabBtns.forEach(btn => {
        btn.addEventListener("click", () => {
          tabBtns.forEach(b => b.classList.remove("active"));
          panels.forEach(p => p.classList.remove("active"));
          btn.classList.add("active");
          document.querySelector('[data-panel="' + btn.dataset.tab + '"]').classList.add("active");
        });
      });

      /* ── Search / Filter ── */
      const searchInput = document.getElementById("searchInput");
      searchInput.addEventListener("input", () => {
        const q = searchInput.value.toLowerCase().trim();
        document.querySelectorAll(".shortcut-row").forEach(row => {
          if (!q) { row.classList.remove("hidden"); return; }
          const keys = (row.dataset.keys || "").toLowerCase();
          const desc = (row.dataset.desc || "");
          row.classList.toggle("hidden", !keys.includes(q) && !desc.includes(q));
        });
        // Show all tabs that have visible results
        if (q) {
          panels.forEach(p => {
            const hasVisible = p.querySelector(".shortcut-row:not(.hidden)");
            if (hasVisible) p.style.display = "block";
          });
        } else {
          panels.forEach(p => p.style.display = "");
        }
      });

      /* ── Keyboard Visual ── */
      const kbKeys = document.querySelectorAll(".kb-key");
      const keyMap = {};
      kbKeys.forEach(k => {
        const label = (k.dataset.k || "").toLowerCase();
        if (!keyMap[label]) keyMap[label] = [];
        keyMap[label].push(k);
      });

      // Aliases
      const aliases = {
        "cmd": ["win", "cmd"], "command": ["win", "cmd"], "option": ["alt", "option", "opt"],
        "return": ["enter"], "control": ["ctrl"], "space": ["space"],
        "arrow": ["left", "right", "up", "down"],
        "page up": ["pageup"], "page down": ["pagedown"],
        "home": ["home"], "end": ["end"],
      };

      function highlightKeys(keysStr) {
        kbKeys.forEach(k => k.classList.remove("highlight"));
        const parts = keysStr.split("+").map(s => s.trim().toLowerCase());
        parts.forEach(part => {
          if (keyMap[part]) { keyMap[part].forEach(el => el.classList.add("highlight")); return; }
          // Check aliases
          for (const [alias, targets] of Object.entries(aliases)) {
            if (part === alias || alias === part) {
              targets.forEach(t => { if (keyMap[t]) keyMap[t].forEach(el => el.classList.add("highlight")); });
              return;
            }
          }
          // Try single character match
          if (part.length === 1 && keyMap[part.toUpperCase().toLowerCase()]) {
            const up = part.toUpperCase();
            kbKeys.forEach(k => { if (k.textContent.trim().toUpperCase() === up) k.classList.add("highlight"); });
          }
        });
      }

      document.querySelectorAll(".shortcut-row").forEach(row => {
        row.addEventListener("click", () => {
          highlightKeys(row.dataset.keys || "");
          document.querySelector(".keyboard-visual-section").scrollIntoView({ behavior: "smooth", block: "center" });
        });
      });

      /* ── Quiz Mode ── */
      const overlay = document.getElementById("quizOverlay");
      const quizToggle = document.getElementById("quizToggle");
      const quizClose = document.getElementById("quizClose");
      const quizPrompt = document.getElementById("quizPrompt");
      const quizKeysEl = document.getElementById("quizKeys");
      const quizReveal = document.getElementById("quizReveal");
      const quizNext = document.getElementById("quizNext");
      const quizCorrect = document.getElementById("quizCorrect");
      const quizSeen = document.getElementById("quizSeen");
      const quizTabSelect = document.getElementById("quizTabSelect");

      let allShortcuts = [];
      let correct = 0, seen = 0, currentAnswer = null;

      function buildPool() {
        allShortcuts = [];
        const tab = quizTabSelect.value;
        document.querySelectorAll(tab === "all" ? ".shortcut-row" : '[data-panel="' + tab + '"] .shortcut-row').forEach(row => {
          allShortcuts.push({ keys: row.dataset.keys, desc: row.dataset.desc });
        });
      }

      function nextQuestion() {
        buildPool();
        if (!allShortcuts.length) { quizPrompt.textContent = "No shortcuts in this category."; return; }
        const item = allShortcuts[Math.floor(Math.random() * allShortcuts.length)];
        // Randomly pick mode: show description ask keys, or show keys ask description
        const mode = Math.random() > 0.5 ? "desc2key" : "key2desc";
        if (mode === "desc2key") {
          quizPrompt.textContent = "What shortcut does this?";
          quizPrompt.innerHTML = 'What shortcut performs:<br><em>"' + item.desc + '"</em>';
          currentAnswer = { type: "keys", keys: item.keys, desc: item.desc };
        } else {
          quizPrompt.innerHTML = "What does this shortcut do?";
          quizKeysEl.innerHTML = item.keys.split("+").map(k => '<kbd>' + k + '</kbd>').join('<span class="key-sep" style="margin:0 0.15rem">+</span>');
          currentAnswer = { type: "desc", keys: item.keys, desc: item.desc };
        }
        if (mode === "desc2key") quizKeysEl.innerHTML = "";
        quizReveal.style.display = "";
        seen++;
        quizSeen.textContent = seen;
      }

      quizToggle.addEventListener("click", () => {
        overlay.classList.add("active");
        correct = 0; seen = 0;
        quizCorrect.textContent = "0";
        quizSeen.textContent = "0";
        nextQuestion();
      });
      quizClose.addEventListener("click", () => overlay.classList.remove("active"));
      overlay.addEventListener("click", (e) => { if (e.target === overlay) overlay.classList.remove("active"); });

      quizReveal.addEventListener("click", () => {
        if (!currentAnswer) return;
        if (currentAnswer.type === "keys") {
          quizKeysEl.innerHTML = currentAnswer.keys.split("+").map(k => '<kbd>' + k + '</kbd>').join('<span class="key-sep" style="margin:0 0.15rem">+</span>');
        } else {
          quizPrompt.innerHTML += '<br><br><strong>' + currentAnswer.desc.charAt(0).toUpperCase() + currentAnswer.desc.slice(1) + '</strong>';
        }
        quizReveal.style.display = "none";
      });

      quizNext.addEventListener("click", () => {
        correct++;
        quizCorrect.textContent = correct;
        nextQuestion();
      });

      quizTabSelect.addEventListener("change", () => {
        correct = 0; seen = 0;
        quizCorrect.textContent = "0";
        quizSeen.textContent = "0";
        nextQuestion();
      });
    });
  </script>
</SiteLayout>
