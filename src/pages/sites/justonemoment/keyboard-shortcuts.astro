---

<SiteLayout site="justonemoment" title={meta.title} description={meta.description} canonical="https://justonemoment.photonbuilder.com/keyboard-shortcuts" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Keyboard Shortcut Reference</h1>
      <p class="subtitle">200+ shortcuts for Windows, macOS, VS Code, Chrome, Excel, Google Docs & Terminal. Search, learn, and quiz yourself.</p>
    </div>

    <div class="controls">
      <div class="search-box">
        <input type="text" id="searchInput" placeholder="Search shortcuts... (e.g. copy, tab, undo)" autocomplete="off" />
      </div>
      <button class="quiz-btn" id="quizToggle">Quiz Mode</button>
    </div>

    <div class="tabs" id="tabBar">
      {Object.entries(tabLabels).map(([key, label], i) => (
        <button class={`tab-btn${i === 0 ? " active" : ""}`} data-tab={key}>{label}</button>
      ))}
    </div>

    <div id="shortcutPanels">
      {Object.entries(shortcuts).map(([tabKey, categories], i) => (
        <div class={`tab-panel${i === 0 ? " active" : ""}`} data-panel={tabKey}>
          {Object.entries(categories).map(([catName, items]) => (
            <div class="category-block">
              <h2>{catName}</h2>
              <div class="shortcuts-grid">
                {(items as {keys: string[]; desc: string}[]).map((s) => (
                  <div class="shortcut-row" data-keys={s.keys.join("+")} data-desc={s.desc.toLowerCase()}>
                    <div class="key-combo">
                      {s.keys.map((k, ki) => (
                        <Fragment>
                          {ki > 0 && <span class="key-sep">+</span>}
                          <kbd>{k}</kbd>
                        </Fragment>
                      ))}
                    </div>
                    <span class="shortcut-desc">{s.desc}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>

    <!-- Quiz overlay -->
    <div class="quiz-overlay" id="quizOverlay">
      <div class="quiz-card">
        <button class="quiz-close" id="quizClose" aria-label="Close quiz">&times;</button>
        <h2>Shortcut Quiz</h2>
        <div class="quiz-tab-select">
          <label for="quizTabSelect">Category:</label>
          <select id="quizTabSelect">
            <option value="all">All</option>
            {Object.entries(tabLabels).map(([key, label]) => (
              <option value={key}>{label}</option>
            ))}
          </select>
        </div>
        <div class="quiz-body" id="quizBody">
          <div class="quiz-prompt" id="quizPrompt">Press "Start" to begin</div>
          <div class="quiz-keys" id="quizKeys"></div>
          <div class="quiz-actions">
            <button class="quiz-action-btn" id="quizReveal">Show Answer</button>
            <button class="quiz-action-btn" id="quizNext">Next</button>
          </div>
          <div class="quiz-score" id="quizScore">
            <span>Correct: <strong id="quizCorrect">0</strong></span>
            <span>Seen: <strong id="quizSeen">0</strong></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Keyboard visual -->
    <section class="keyboard-visual-section">
      <h2>Keyboard Visualizer</h2>
      <p class="subtitle">Click any shortcut above to see the keys highlighted on the keyboard.</p>
      <div class="keyboard-visual" id="keyboardVisual">
        <div class="kb-row">
          <div class="kb-key" data-k="Esc">Esc</div>
          <div class="kb-key" data-k="F1">F1</div>
          <div class="kb-key" data-k="F2">F2</div>
          <div class="kb-key" data-k="F3">F3</div>
          <div class="kb-key" data-k="F4">F4</div>
          <div class="kb-key" data-k="F5">F5</div>
          <div class="kb-key" data-k="F6">F6</div>
          <div class="kb-key" data-k="F7">F7</div>
          <div class="kb-key" data-k="F8">F8</div>
          <div class="kb-key" data-k="F9">F9</div>
          <div class="kb-key" data-k="F10">F10</div>
          <div class="kb-key" data-k="F11">F11</div>
          <div class="kb-key" data-k="F12">F12</div>
          <div class="kb-key" data-k="PrtSc">PrtSc</div>
          <div class="kb-key" data-k="Delete">Del</div>
        </div>
        <div class="kb-row">
          <div class="kb-key" data-k="`">`</div>
          <div class="kb-key" data-k="1">1</div>
          <div class="kb-key" data-k="2">2</div>
          <div class="kb-key" data-k="3">3</div>
          <div class="kb-key" data-k="4">4</div>
          <div class="kb-key" data-k="5">5</div>
          <div class="kb-key" data-k="6">6</div>
