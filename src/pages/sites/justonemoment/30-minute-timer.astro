---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "30 Minute Timer — Premium Online Timer",
  description: "Professional 30-minute countdown timer with SVG progress ring, Web Audio alarm, and fullscreen mode. Perfect for Pomodoro, workouts, cooking, and focused work sessions.",
  category: "timer",
  published: "2026-03-28",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "30 Minute Timer",
    "description": meta.description,
    "url": "https://justonemoment.photonbuilder.com/30-minute-timer",
    "applicationCategory": "ProductivityApplication",
    "operatingSystem": "All",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the best uses for a 30-minute timer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "30-minute timers are perfect for Pomodoro work sessions, HIIT workouts, meal preparation, power naps, yoga practice, laundry cycles, and focused study blocks. The duration is ideal for maintaining concentration without mental fatigue."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate is this 30-minute timer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This timer uses Date.now() for millisecond-accurate timing, compensating for browser tab throttling and ensuring precise countdown even when the tab is in the background."
        }
      },
      {
        "@type": "Question",
        "name": "What keyboard shortcuts are available?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Press Space to start/pause the timer, R to reset to 30:00, and F to enter fullscreen mode. These shortcuts work even when other elements are focused."
        }
      },
      {
        "@type": "Question",
        "name": "Will I get a notification when the timer finishes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the timer plays an audio alarm and shows a browser notification (if permissions are granted) when the 30 minutes are complete, even if you're on another tab."
        }
      }
    ]
  }
];
---

<SiteLayout site="justonemoment" title={meta.title} description={meta.description} canonical="https://justonemoment.photonbuilder.com/30-minute-timer" schema={schema}>
  
  <div class="timer-container">
    <!-- Timer App -->
    <div class="timer-app">
      <div class="timer-header">
        <h1>30 Minute Timer</h1>
        <p>Professional countdown timer for focused work and activities</p>
      </div>

      <!-- Preset Buttons -->
      <div class="preset-buttons">
        <button class="preset-btn" data-minutes="10">10 min</button>
        <button class="preset-btn" data-minutes="15">15 min</button>
        <button class="preset-btn" data-minutes="20">20 min</button>
        <button class="preset-btn" data-minutes="25">25 min</button>
        <button class="preset-btn active" data-minutes="30">30 min</button>
        <button class="preset-btn" data-minutes="45">45 min</button>
        <button class="preset-btn" data-minutes="60">60 min</button>
      </div>

      <!-- Main Timer Display -->
      <div class="timer-display">
        <div class="progress-ring-container">
          <svg class="progress-ring" width="280" height="280">
            <circle class="progress-ring__track" cx="140" cy="140" r="130" fill="transparent" stroke="#152040" stroke-width="8"/>
            <circle class="progress-ring__progress" cx="140" cy="140" r="130" fill="transparent" stroke="#F59E0B" stroke-width="8"/>
          </svg>
          <div class="timer-time">
            <span id="timer-display">30:00</span>
          </div>
        </div>
      </div>

      <!-- Control Buttons -->
      <div class="timer-controls">
        <button id="start-pause-btn" class="control-btn primary">
          <span class="btn-text">Start</span>
        </button>
        <button id="reset-btn" class="control-btn">Reset</button>
        <button id="fullscreen-btn" class="control-btn">Fullscreen</button>
      </div>

      <!-- Keyboard Shortcuts -->
      <div class="shortcuts">
        <span><kbd>Space</kbd> Start/Pause</span>
        <span><kbd>R</kbd> Reset</span>
        <span><kbd>F</kbd> Fullscreen</span>
      </div>
    </div>

    <!-- Use Cases Section -->
    <section class="use-cases">
      <h2>Perfect for Every 30-Minute Activity</h2>
      <div class="use-case-grid">
        <div class="use-case-card">
          <h3>🍅 Pomodoro Sessions</h3>
          <p>Extended focus blocks for deep work, coding, writing, or studying. Longer than traditional 25-minute sessions.</p>
        </div>
        <div class="use-case-card">
          <h3>🍳 Lunch Break</h3>
          <p>Perfect timing for a proper lunch break, allowing you to eat mindfully and recharge for the afternoon.</p>
        </div>
        <div class="use-case-card">
          <h3>😴 Power Nap</h3>
          <p>Optimal power nap duration for alertness without grogginess. Wake up refreshed and energized.</p>
        </div>
        <div class="use-case-card">
          <h3>🧘 Yoga Practice</h3>
          <p>Ideal for a complete yoga routine including warm-up, poses, and relaxation without rushing.</p>
        </div>
        <div class="use-case-card">
          <h3>👕 Laundry Cycle</h3>
          <p>Standard quick wash cycle timing. Set the timer when you start the machine.</p>
        </div>
        <div class="use-case-card">
          <h3>🍲 Meal Prep</h3>
          <p>Perfect for focused cooking sessions, from prep to plating. Keeps you efficient in the kitchen.</p>
        </div>
      </div>
    </section>

    <!-- Fun Facts Section -->
    <section class="fun-facts">
      <h2>How Long Is 30 Minutes? Fun Facts</h2>
      <div class="facts-grid">
        <div class="fact-card">
          <div class="fact-number">🌍</div>
          <p>Earth rotates <strong>7.5 degrees</strong> in 30 minutes</p>
        </div>
        <div class="fact-card">
          <div class="fact-number">💨</div>
          <p>You breathe approximately <strong>450 times</strong> in 30 minutes</p>
        </div>
        <div class="fact-card">
          <div class="fact-number">🚗</div>
          <p>Drive <strong>30 miles</strong> at highway speed</p>
        </div>
        <div class="fact-card">
          <div class="fact-number">📺</div>
          <p>Watch a typical <strong>TV episode</strong> including commercials</p>
        </div>
        <div class="fact-card">
          <div class="fact-number">☕</div>
          <p>Brew and enjoy <strong>3 cups</strong> of perfect coffee</p>
        </div>
        <div class="fact-card">
