---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Mortgage Calculator - Estimate Your Monthly House Payment",
  description: "Calculate your monthly mortgage payment including principal, interest, taxes, and insurance (PITI). See how down payments and interest rates affect your home loan.",
  category: "tool",
  published: "2026-03-20",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Mortgage Calculator - Estimate Your Monthly House Payment",
    "description": "A comprehensive mortgage calculator to estimate monthly payments, including taxes, insurance, and PMI.",
    "author": {
      "@type": "Organization",
      "name": "Just One Moment"
    },
    "datePublished": "2026-03-20"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is included in a monthly mortgage payment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A standard monthly mortgage payment, often referred to as PITI, includes Principal (the loan balance), Interest (the cost of borrowing), Taxes (property taxes), and Insurance (homeowners insurance). It may also include Private Mortgage Insurance (PMI) and HOA fees."
        }
      },
      {
        "@type": "Question",
        "name": "How does the down payment affect my mortgage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A larger down payment reduces the principal amount you need to borrow, which lowers your monthly interest and total payment. Additionally, if you put down at least 20%, you can typically avoid paying Private Mortgage Insurance (PMI)."
        }
      },
      {
        "@type": "Question",
        "name": "What is PMI and when do I have to pay it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "PMI stands for Private Mortgage Insurance. It protects the lender if you stop making payments. You are typically required to pay PMI if your down payment is less than 20% of the home's purchase price."
        }
      },
      {
        "@type": "Question",
        "name": "How do interest rates impact the total cost of the loan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Even a small difference in interest rates can cost or save you tens of thousands of dollars over the life of the loan. Higher rates increase your monthly payment and the total interest paid over time."
        }
      },
      {
        "@type": "Question",
        "name": "Should I choose a 15-year or 30-year mortgage term?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 30-year mortgage offers lower monthly payments but higher total interest costs. A 15-year mortgage has higher monthly payments but allows you to pay off the loan faster and save significantly on interest."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="justonemoment"
  title={meta.title}
  description={meta.description}
  canonical="https://justonemoment.photonbuilder.com/mortgage-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Mortgage Calculator</h1>
      <p class="subtitle">Estimate your monthly housing costs with our interactive mortgage tool.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-section">
          <div class="input-group">
            <label for="homePrice">Home Price</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="homePrice" value="400000" step="1000">
            </div>
          </div>

          <div class="input-row">
            <div class="input-group">
              <label for="downPayment">Down Payment</label>
              <div class="input-wrapper">
                <span class="prefix">$</span>
                <input type="number" id="downPayment" value="80000" step="1000">
              </div>
            </div>
            <div class="input-group">
              <label for="downPaymentPercent">Percent</label>
              <div class="input-wrapper">
                <input type="number" id="downPaymentPercent" value="20" step="0.1">
                <span class="suffix">%</span>
              </div>
            </div>
          </div>

          <div class="input-row">
            <div class="input-group">
              <label for="interestRate">Interest Rate</label>
              <div class="input-wrapper">
                <input type="number" id="interestRate" value="6.5" step="0.1">
                <span class="suffix">%</span>
              </div>
            </div>
            <div class="input-group">
              <label for="loanTerm">Loan Term</label>
              <select id="loanTerm">
                <option value="30">30 Years</option>
                <option value="20">20 Years</option>
                <option value="15">15 Years</option>
                <option value="10">10 Years</option>
              </select>
            </div>
          </div>

          <details class="advanced-toggle">
            <summary>Taxes, Insurance & Fees</summary>
            <div class="advanced-inputs">
              <div class="input-group">
                <label for="propertyTax">Property Tax (Annual)</label>
                <div class="input-wrapper">
                  <span class="prefix">$</span>
                  <input type="number" id="propertyTax" value="4800" step="100">
                </div>
              </div>
              <div class="input-group">
                <label for="homeInsurance">Home Insurance (Annual)</label>
                <div class="input-wrapper">
                  <span class="prefix">$</span>
                  <input type="number" id="homeInsurance" value="1200" step="100">
                </div>
              </div>
              <div class="input-group">
                <label for="hoaFees">HOA Fees (Monthly)</label>
                <div class="input-wrapper">
                  <span class="prefix">$</span>
                  <input type="number" id="hoaFees" value="0" step="10">
                </div>
              </div>
            </div>
          </details>
        </div>

        <div class="output-section">
          <div class="result-card highlight">
            <div class="result-label">Monthly Payment</div>
            <div class="result-value" id="monthlyPaymentDisplay">$0</div>
            <div class="result-sub" id="pitiBreakdown">P&I, Taxes, Ins.</div>
          </div>

          <div class="breakdown-list">
            <div class="breakdown-item">
              <span>Principal & Interest</span>
              <span id="piAmount">$0</span>
            </div>
            <div class="breakdown-item">
              <span>Property Taxes</span>
              <span id="taxAmount">$0</span>
            </div>
            <div class="breakdown-item">
              <span>Home Insurance</span>
              <span id="insAmount">$0</span>
            </div>
            <div class="breakdown-item" id="pmiRow">
              <span>PMI</span>
              <span id="pmiAmount">$0</span>
            </div>
            <div class="breakdown-item" id="hoaRow">
              <span>HOA Fees</span>
              <span id="hoaAmount">$0</span>
            </div>
          </div>

          <div class="total-stats">
            <div class="stat-line">
              <span>Total Loan Amount</span>
              <strong id="totalLoanAmount">$0</strong>
            </div>
            <div class="stat-line">
              <span>Total Interest Paid</span>
              <strong id="totalInterest">$0</strong>
            </div>
            <div class="stat-line">
              <span>Total Cost of Loan</span>
              <strong id="totalCost">$0</strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Your Mortgage Payment (PITI)</h2>
      <p>A mortgage payment is more than just paying back the money you borrowed. Most monthly payments consist of four main components, often abbreviated as <strong>PITI</strong>.</p>

      <h3>1. Principal</h3>
      <p>This is the part of your payment that goes toward paying down the actual balance of the loan. In the early years of a mortgage, a smaller portion of your payment goes to principal, while in the later years, more of it does.</p>

      <h3>2. Interest</h3>
      <p>Interest is the cost of borrowing the money. Your interest rate is determined by the lender based on current market conditions and your creditworthiness. Early in the loan, most of your monthly payment goes toward interest.</p>

      <h3>3. Taxes</h3>
      <p>Most lenders collect property taxes as part of your monthly payment and hold them in an <strong>escrow account</strong>. They then pay the taxes to your local government on your behalf when they are due.</p>

      <h3>4. Insurance</h3>
      <p>Like taxes, homeowners insurance is often paid through an escrow account. This ensures that the property—which serves as collateral for the loan—is protected against damage from fire, storms, and other hazards.</p>

      <h3>Other Potential Costs</h3>
      <ul>
        <li><strong>Private Mortgage Insurance (PMI):</strong> If your down payment is less than 20%, lenders usually require PMI to protect themselves in case of default.</li>
        <li><strong>HOA Fees:</strong> If you live in a community with a Homeowners Association, you may have monthly or annual fees for maintenance and amenities.</li>
      </ul>

      <h2>How to Lower Your Monthly Payment</h2>
      <p>If the estimated payment is higher than you'd like, consider these strategies:</p>
      <ul>
        <li><strong>Larger Down Payment:</strong> Putting more money down reduces the loan amount and can eliminate PMI.</li>
        <li><strong>Improve Your Credit Score:</strong> A higher credit score often qualifies you for a lower interest rate.</li>
        <li><strong>Choose a Longer Term:</strong> A 30-year mortgage has lower monthly payments than a 15-year mortgage (though you pay more interest overall).</li>
        <li><strong>Shop for Insurance:</strong> You can often save money by comparing quotes from different insurance providers.</li>
      </ul>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-grid">
        {schema[1].mainEntity.map((item) => (
          <div class="faq-item">
            <h3>{item.name}</h3>
            <p>{item.acceptedAnswer.text}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    // Inputs
    const homePriceInput = document.getElementById('homePrice');
    const downPaymentInput = document.getElementById('downPayment');
    const downPaymentPercentInput = document.getElementById('downPaymentPercent');
    const interestRateInput = document.getElementById('interestRate');
    const loanTermSelect = document.getElementById('loanTerm');
    const propertyTaxInput = document.getElementById('propertyTax');
    const homeInsuranceInput = document.getElementById('homeInsurance');
    const hoaFeesInput = document.getElementById('hoaFees');

    // Outputs
    const monthlyPaymentDisplay = document.getElementById('monthlyPaymentDisplay');
    const piAmountEl = document.getElementById('piAmount');
    const taxAmountEl = document.getElementById('taxAmount');
    const insAmountEl = document.getElementById('insAmount');
    const pmiAmountEl = document.getElementById('pmiAmount');
    const pmiRow = document.getElementById('pmiRow');
    const hoaAmountEl = document.getElementById('hoaAmount');
    const hoaRow = document.getElementById('hoaRow');
    const totalLoanAmountEl = document.getElementById('totalLoanAmount');
    const totalInterestEl = document.getElementById('totalInterest');
    const totalCostEl = document.getElementById('totalCost');

    const formatCurrency = (num) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(num);
    };

    const updateCalculations = (source) => {
      const homePrice = parseFloat(homePriceInput.value) || 0;
      let downPayment = parseFloat(downPaymentInput.value) || 0;
      let downPaymentPercent = parseFloat(downPaymentPercentInput.value) || 0;

      // Sync down payment and percent
      if (source === 'price' || source === 'percent') {
        downPayment = (homePrice * downPaymentPercent) / 100;
        downPaymentInput.value = Math.round(downPayment);
      } else if (source === 'amount') {
        downPaymentPercent = homePrice > 0 ? (downPayment / homePrice) * 100 : 0;
        downPaymentPercentInput.value = downPaymentPercent.toFixed(2);
      }

      const principal = homePrice - downPayment;
      const annualRate = (parseFloat(interestRateInput.value) || 0) / 100;
      const monthlyRate = annualRate / 12;
      const years = parseInt(loanTermSelect.value) || 30;
      const numberOfPayments = years * 12;

      // Monthly P&I
      let monthlyPI = 0;
      if (monthlyRate > 0) {
        monthlyPI = (principal * monthlyRate * Math.pow(1 + monthlyRate, numberOfPayments)) / (Math.pow(1 + monthlyRate, numberOfPayments) - 1);
      } else {
        monthlyPI = principal / numberOfPayments;
      }

      // Other monthly costs
      const monthlyTax = (parseFloat(propertyTaxInput.value) || 0) / 12;
      const monthlyIns = (parseFloat(homeInsuranceInput.value) || 0) / 12;
      const monthlyHOA = parseFloat(hoaFeesInput.value) || 0;

      // PMI (Rough estimate: 0.5% - 1% of loan amount if < 20% down)
      let monthlyPMI = 0;
      if (downPaymentPercent < 20 && principal > 0) {
        monthlyPMI = (principal * 0.0075) / 12; // Using 0.75% as average
        pmiRow.style.display = 'flex';
      } else {
        pmiRow.style.display = 'none';
      }

      const totalMonthly = monthlyPI + monthlyTax + monthlyIns + monthlyPMI + monthlyHOA;

      // Totals
      const totalCost = (monthlyPI * numberOfPayments) + downPayment;
      const totalInterest = (monthlyPI * numberOfPayments) - principal;

      // Update UI
      monthlyPaymentDisplay.textContent = formatCurrency(totalMonthly);
      piAmountEl.textContent = formatCurrency(monthlyPI);
      taxAmountEl.textContent = formatCurrency(monthlyTax);
      insAmountEl.textContent = formatCurrency(monthlyIns);
      pmiAmountEl.textContent = formatCurrency(monthlyPMI);
      hoaAmountEl.textContent = formatCurrency(monthlyHOA);

      totalLoanAmountEl.textContent = formatCurrency(principal);
      totalInterestEl.textContent = formatCurrency(totalInterest);
      totalCostEl.textContent = formatCurrency(totalCost);

      if (monthlyHOA > 0) {
        hoaRow.style.display = 'flex';
      } else {
        hoaRow.style.display = 'none';
      }
    };

    // Event Listeners
    homePriceInput.addEventListener('input', () => updateCalculations('price'));
    downPaymentInput.addEventListener('input', () => updateCalculations('amount'));
    downPaymentPercentInput.addEventListener('input', () => updateCalculations('percent'));
    interestRateInput.addEventListener('input', () => updateCalculations('other'));
    loanTermSelect.addEventListener('change', () => updateCalculations('other'));
    propertyTaxInput.addEventListener('input', () => updateCalculations('other'));
    homeInsuranceInput.addEventListener('input', () => updateCalculations('other'));
    hoaFeesInput.addEventListener('input', () => updateCalculations('other'));

    // Initial run
    updateCalculations('price');
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .calc-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 2.5rem; }
    @media (max-width: 768px) {
      .calc-grid { grid-template-columns: 1fr; gap: 2rem; }
    }

    .input-section { display: flex; flex-direction: column; gap: 1.25rem; }
    .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group label { font-weight: 600; color: var(--text-primary); font-size: 0.9rem; }

    .input-wrapper { position: relative; display: flex; align-items: center; }
    .prefix { position: absolute; left: 0.75rem; color: var(--text-secondary); font-weight: 500; pointer-events: none; }
    .suffix { position: absolute; right: 0.75rem; color: var(--text-secondary); font-weight: 500; pointer-events: none; }

    input[type="number"], select {
      background: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 0.75rem;
      border-radius: 8px;
      width: 100%;
      font-size: 1rem;
      box-sizing: border-box;
      font-family: var(--font-mono);
    }
    input[type="number"] { padding-left: 1.75rem; }
    input#downPaymentPercent, input#interestRate { padding-left: 0.75rem; padding-right: 1.75rem; }

    input:focus, select:focus { outline: none; border-color: var(--accent-color); }

    .advanced-toggle { margin-top: 0.5rem; }
    .advanced-toggle summary { font-size: 0.9rem; color: var(--accent-color); cursor: pointer; font-weight: 600; margin-bottom: 0.5rem; user-select: none; }
    .advanced-inputs { display: flex; flex-direction: column; gap: 1rem; padding: 1rem; background: rgba(0,0,0,0.1); border-radius: 8px; margin-top: 0.5rem; }

    .output-section { display: flex; flex-direction: column; gap: 1.5rem; }
    .result-card { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; }
    .result-card.highlight { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); }
    .result-label { font-size: 0.9rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; margin-bottom: 0.5rem; }
    .result-value { font-size: 3rem; font-weight: 800; color: var(--accent-color); line-height: 1; margin-bottom: 0.5rem; font-family: var(--font-mono); }
    .result-sub { font-size: 0.9rem; color: var(--text-secondary); }

    .breakdown-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .breakdown-item { display: flex; justify-content: space-between; font-size: 0.95rem; color: var(--text-secondary); padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color); }
    .breakdown-item span:last-child { color: var(--text-primary); font-family: var(--font-mono); font-weight: 600; }

    .total-stats { background: rgba(255,255,255,0.03); padding: 1rem; border-radius: 8px; display: flex; flex-direction: column; gap: 0.5rem; }
    .stat-line { display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-secondary); }
    .stat-line strong { color: var(--text-primary); font-family: var(--font-mono); }

    .explainer { margin-top: 3rem; line-height: 1.7; }
    .explainer h2 { font-size: 1.8rem; margin-top: 2rem; color: var(--text-primary); text-align: left; }
    .explainer h3 { font-size: 1.3rem; margin-top: 1.5rem; color: var(--accent-color); }
    .explainer p { color: var(--text-secondary); margin-bottom: 1rem; }
    .explainer ul { padding-left: 1.25rem; }

    .faq-section { margin-top: 4rem; padding-top: 3rem; border-top: 1px solid var(--border-color); }
    .faq-section h2 { margin-bottom: 2rem; }
    .faq-grid { display: grid; gap: 1.5rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); padding: 1.5rem; border-radius: 12px; }
    .faq-item h3 { margin-top: 0; font-size: 1.1rem; color: var(--text-primary); margin-bottom: 0.75rem; }
    .faq-item p { margin-bottom: 0; font-size: 0.95rem; }
  </style>
</SiteLayout>
