---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "1 Minute Timer - Free Online Countdown | Start in One Click",
  description: "The best 1-minute timer online. Start instantly with one click. Perfect for brushing teeth, microwave heating, quick stretches, and speed challenges. Works offline with sound alerts.",
  category: "tool",
  published: "2026-03-28"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "1 Minute Timer",
    "url": "https://justonemoment.photonbuilder.com/1-minute-timer",
    "applicationCategory": "Utility",
    "operatingSystem": "All",
    "description": "Free online 1-minute countdown timer with sound alerts and visual progress indicator."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I set a 1 minute timer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Simply click the big START button. The timer begins immediately at 1:00 and counts down to 0:00 with a sound alert when finished."
        }
      },
      {
        "@type": "Question",
        "name": "Will the timer work if I switch tabs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! The timer uses precise timestamp calculations to stay accurate even when the browser tab is in the background. The tab title also shows the remaining time."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use this timer on my phone?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. The timer is fully responsive and works perfectly on mobile devices. The large display and buttons are touch-friendly."
        }
      },
      {
        "@type": "Question",
        "name": "What happens when the 1 minute timer ends?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "When time reaches 0:00, the timer plays a sound alert, flashes the screen, shows a browser notification (if allowed), and updates the tab title to indicate completion."
        }
      }
    ]
  }
];
---
<SiteLayout site="justonemoment" title={meta.title} description={meta.description} canonical="https://justonemoment.photonbuilder.com/1-minute-timer" schema={schema}>
  <div class="timer-page">
    <!-- Giant Timer Display (Hero) -->
    <div class="timer-hero">
      <div class="timer-container">
        <!-- Progress Circle -->
        <div class="progress-ring-container">
          <svg class="progress-ring" width="280" height="280">
            <circle class="progress-ring-background" cx="140" cy="140" r="120"></circle>
            <circle class="progress-ring-fill" cx="140" cy="140" r="120" id="progress-circle"></circle>
          </svg>
          
          <!-- Timer Display -->
          <div class="timer-display" id="timer-display">1:00</div>
        </div>

        <!-- Main Controls -->
        <div class="main-controls">
          <button id="start-btn" class="start-button">START</button>
          <div class="secondary-controls" id="secondary-controls">
            <button id="pause-btn" class="control-btn pause-btn">PAUSE</button>
            <button id="reset-btn" class="control-btn reset-btn">RESET</button>
            <button id="fullscreen-btn" class="control-btn fullscreen-btn">⛶</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Adjust Buttons -->
    <div class="quick-adjust-section">
      <div class="custom-time-controls">
        <button id="minus-btn" class="adjust-btn">-15s</button>
        <button id="time-input-btn" class="time-input-btn" id="time-display-btn">1:00</button>
        <button id="plus-btn" class="adjust-btn">+15s</button>
      </div>

      <div class="preset-timers">
        <button class="preset-timer" data-seconds="30">30s</button>
        <button class="preset-timer" data-seconds="45">45s</button>
        <span class="preset-timer active">1 min</span>
        <a href="/2-minute-timer" class="preset-timer">2 min</a>
        <a href="/3-minute-timer" class="preset-timer">3 min</a>
        <a href="/5-minute-timer" class="preset-timer">5 min</a>
        <a href="/10-minute-timer" class="preset-timer">10 min</a>
      </div>
    </div>

    <!-- Timer Presets for 1 Minute -->
    <div class="presets-section">
      <h2>Perfect for 1 Minute</h2>
      <div class="presets-grid">
        <div class="preset-card">
          <div class="preset-icon">🪥</div>
          <div class="preset-title">Brushing Teeth</div>
          <div class="preset-desc">Dentist recommended minimum time</div>
        </div>
        <div class="preset-card">
          <div class="preset-icon">🥛</div>
          <div class="preset-title">Microwave Heating</div>
          <div class="preset-desc">Quick food warming</div>
        </div>
        <div class="preset-card">
          <div class="preset-icon">🤸</div>
          <div class="preset-title">Quick Stretch</div>
          <div class="preset-desc">Fast mobility break</div>
        </div>
        <div class="preset-card">
          <div class="preset-icon">🎤</div>
          <div class="preset-title">Elevator Pitch</div>
          <div class="preset-desc">Perfect practice timing</div>
        </div>
        <div class="preset-card">
          <div class="preset-icon">⚡</div>
          <div class="preset-title">Speed Challenge</div>
          <div class="preset-desc">Quick burst activities</div>
        </div>
        <div class="preset-card">
          <div class="preset-icon">☕</div>
          <div class="preset-title">Coffee Brewing</div>
          <div class="preset-desc">AeroPress timing</div>
        </div>
      </div>
    </div>

    <!-- How Long Is 1 Minute? -->
    <div class="content-section">
      <h2>How Long Is 1 Minute?</h2>
      <div class="content-grid">
        <div class="content-card">
          <strong>1 minute = 60 seconds</strong>
          <p>In the time it takes this timer to count down, you could read about 150 words at average reading speed, take 15-20 breaths, or walk roughly 80 meters at a normal pace.</p>
        </div>
        <div class="content-card">
          <strong>Nature's Rhythm</strong>
          <p>A hummingbird's heart beats approximately 1,200 times in one minute, while light travels an incredible 18 million kilometers through space in this same timeframe.</p>
        </div>
        <div class="content-card">
          <strong>Productivity Power</strong>
          <p>One minute is the perfect duration for habits that feel too small to fail. It's long enough to matter but short enough to never feel overwhelming or time-consuming.</p>
        </div>
        <div class="content-card">
          <strong>Physical Perspective</strong>
          <p>Holding a plank position for one full minute is a solid fitness achievement. Meanwhile, most people can hold their breath for 1-2 minutes with practice.</p>
        </div>
      </div>
    </div>

    <!-- Related Timers -->
    <div class="related-section">
      <h2>Related Timers</h2>
      <div class="related-grid">
        <a href="/2-minute-timer" class="related-timer">2 Minute Timer</a>
        <a href="/3-minute-timer" class="related-timer">3 Minute Timer</a>
        <a href="/5-minute-timer" class="related-timer">5 Minute Timer</a>
        <a href="/10-minute-timer" class="related-timer">10 Minute Timer</a>
        <a href="/15-minute-timer" class="related-timer">15 Minute Timer</a>
        <a href="/20-minute-timer" class="related-timer">20 Minute Timer</a>
        <a href="/25-minute-timer" class="related-timer">25 Minute Timer</a>
        <a href="/30-minute-timer" class="related-timer">30 Minute Timer</a>
        <a href="/45-minute-timer" class="related-timer">45 Minute Timer</a>
        <a href="/60-minute-timer" class="related-timer">1 Hour Timer</a>
      </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>How do I set a 1 minute timer?</summary>
          <p>Simply click the big START button. The timer begins immediately at 1:00 and counts down to 0:00 with a sound alert when finished.</p>
        </details>
        
        <details class="faq-item">
          <summary>Will the timer work if I switch tabs?</summary>
          <p>Yes! The timer uses precise timestamp calculations to stay accurate even when the browser tab is in the background. The tab title also shows the remaining time.</p>
        </details>
        
        <details class="faq-item">
          <summary>Can I use this timer on my phone?</summary>
          <p>Absolutely. The timer is fully responsive and works perfectly on mobile devices. The large display and buttons are touch-friendly.</p>
        </details>
        
        <details class="faq-item">
          <summary>What happens when the 1 minute timer ends?</summary>
          <p>When time reaches 0:00, the timer plays a sound alert, flashes the screen, shows a browser notification (if allowed), and updates the tab title to indicate completion.</p>
        </details>
      </div>
    </div>

    <!-- Time Input Modal -->
    <div class="time-input-modal" id="time-input-modal">
      <div class="modal-content">
        <h3>Set Custom Time</h3>
        <div class="time-inputs">
          <label>
            Minutes:
            <input type="number" id="custom-minutes" min="0" max="60" value="1">
          </label>
          <label>
            Seconds:
            <input type="number" id="custom-seconds" min="0" max="59" value="0">
          </label>
        </div>
        <div class="modal-buttons">
          <button id="set-custom-time" class="btn-primary">Set Time</button>
          <button id="cancel-custom-time" class="btn-secondary">Cancel</button>
        </div>
      </div>
    </div>
  </div>

  <style>
    /* Global Reset & Base */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    .timer-page {
      background: #060a12;
      color: #e5e5e5;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
    }

    /* Timer Hero Section */
    .timer-hero {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem 1rem;
      background: #060a12;
      position: relative;
    }

    .timer-container {
      text-align: center;
      max-width: 400px;
      width: 100%;
    }

    /* Progress Ring */
    .progress-ring-container {
      position: relative;
      display: inline-block;
      margin-bottom: 3rem;
    }

    .progress-ring {
      transform: rotate(-90deg);
      filter: drop-shadow(0 0 20px rgba(245, 158, 11, 0.3));
    }

    .progress-ring-background {
      fill: none;
      stroke: #152040;
      stroke-width: 8;
    }

    .progress-ring-fill {
      fill: none;
      stroke: #F59E0B;
      stroke-width: 8;
      stroke-linecap: round;
      stroke-dasharray: 753.98;
      stroke-dashoffset: 0;
      transition: stroke-dashoffset 0.1s ease;
    }

    /* Timer Display */
    .timer-display {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-family: 'JetBrains Mono', 'SF Mono', 'Monaco', 'Cascadia Code', monospace;
      font-size: 4rem;
      font-weight: 800;
      color: #F59E0B;
      text-shadow: 0 0 30px rgba(245, 158, 11, 0.5);
      user-select: none;
      cursor: pointer;
    }

    /* Main Controls */
    .main-controls {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }

    .start-button {
      background: #F59E0B;
      color: #060a12;
      border: none;
      border-radius: 16px;
      padding: 1.5rem 4rem;
      font-size: 1.5rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 2px;
      box-shadow: 0 8px 32px rgba(245, 158, 11, 0.3);
    }

    .start-button:hover {
      background: #D97706;
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(245, 158, 11, 0.4);
    }

    .secondary-controls {
      display: none;
      gap: 1rem;
      align-items: center;
    }

    .secondary-controls.visible {
      display: flex;
    }

    .control-btn {
      background: #0a1020;
      color: #e5e5e5;
      border: 2px solid #152040;
      border-radius: 12px;
      padding: 0.75rem 1.5rem;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .control-btn:hover {
      border-color: #F59E0B;
      background: #152040;
    }

    .fullscreen-btn {
      padding: 0.75rem;
      font-size: 1.2rem;
    }

    /* Quick Adjust Section */
    .quick-adjust-section {
      padding: 3rem 1rem;
      background: #0a1020;
      display: flex;
      flex-direction: column;
      gap: 2rem;
      align-items: center;
    }

    .custom-time-controls {
      display: flex;
      gap: 1rem;
      align-items: center;
    }

    .adjust-btn, .time-input-btn {
      background: #152040;
      color: #e5e5e5;
      border: 2px solid #1e293b;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .time-input-btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.2rem;
      min-width: 80px;
    }

    .adjust-btn:hover, .time-input-btn:hover {
      border-color: #F59E0B;
      background: #1e293b;
    }

    .preset-timers {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .preset-timer {
      background: #152040;
      color: #e5e5e5;
      text-decoration: none;
      border: 2px solid #1e293b;
      border-radius: 8px;
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
      font-weight: 600;
      transition: all 0.2s ease;
      cursor: pointer;
    }

    .preset-timer:hover {
      border-color: #F59E0B;
      background: #1e293b;
    }

    .preset-timer.active {
      background: #F59E0B;
      color: #060a12;
      border-color: #F59E0B;
    }

    /* Presets Section */
    .presets-section {
      padding: 4rem 1rem;
      background: #060a12;
    }

    .presets-section h2 {
      text-align: center;
      font-size: 2rem;
      font-weight: 800;
      color: #F59E0B;
      margin-bottom: 2rem;
    }

    .presets-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .preset-card {
      background: #0a1020;
      border: 2px solid #152040;
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      transition: all 0.2s ease;
    }

    .preset-card:hover {
      border-color: #F59E0B;
      transform: translateY(-2px);
    }

    .preset-icon {
      font-size: 2rem;
      margin-bottom: 0.75rem;
    }

    .preset-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #F59E0B;
      margin-bottom: 0.5rem;
    }

    .preset-desc {
      font-size: 0.9rem;
      color: #9ca3af;
    }

    /* Content Section */
    .content-section {
      padding: 4rem 1rem;
      background: #0a1020;
    }

    .content-section h2 {
      text-align: center;
      font-size: 2rem;
      font-weight: 800;
      color: #F59E0B;
      margin-bottom: 2rem;
    }

    .content-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .content-card {
      background: #152040;
      border-radius: 12px;
      padding: 2rem;
      border: 1px solid #1e293b;
    }

    .content-card strong {
      display: block;
      color: #F59E0B;
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .content-card p {
      color: #d1d5db;
      line-height: 1.6;
    }

    /* Related Section */
    .related-section {
      padding: 4rem 1rem;
      background: #060a12;
    }

    .related-section h2 {
      text-align: center;
      font-size: 2rem;
      font-weight: 800;
      color: #F59E0B;
      margin-bottom: 2rem;
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .related-timer {
      background: #0a1020;
      color: #e5e5e5;
      text-decoration: none;
      border: 2px solid #152040;
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .related-timer:hover {
      border-color: #F59E0B;
      background: #152040;
      color: #F59E0B;
    }

    /* FAQ Section */
    .faq-section {
      padding: 4rem 1rem;
      background: #0a1020;
    }

    .faq-section h2 {
      text-align: center;
      font-size: 2rem;
      font-weight: 800;
      color: #F59E0B;
      margin-bottom: 2rem;
    }

    .faq-grid {
      max-width: 800px;
      margin: 0 auto;
      display: grid;
      gap: 1rem;
    }

    .faq-item {
      background: #152040;
      border: 2px solid #1e293b;
      border-radius: 8px;
      padding: 1.5rem;
      transition: border-color 0.2s ease;
    }

    .faq-item:hover {
      border-color: #F59E0B;
    }

    .faq-item summary {
      font-weight: 700;
      color: #F59E0B;
      cursor: pointer;
      font-size: 1.1rem;
    }

    .faq-item p {
      margin-top: 1rem;
      color: #d1d5db;
      line-height: 1.6;
    }

    /* Time Input Modal */
    .time-input-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.8);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }

    .time-input-modal.visible {
      display: flex;
    }

    .modal-content {
      background: #0a1020;
      border: 2px solid #152040;
      border-radius: 12px;
      padding: 2rem;
      max-width: 400px;
      width: 90%;
    }

    .modal-content h3 {
      color: #F59E0B;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .time-inputs {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .time-inputs label {
      flex: 1;
      color: #e5e5e5;
      font-weight: 600;
    }

    .time-inputs input {
      width: 100%;
      background: #152040;
      border: 2px solid #1e293b;
      color: #e5e5e5;
      border-radius: 6px;
      padding: 0.5rem;
      margin-top: 0.5rem;
      font-size: 1rem;
    }

    .time-inputs input:focus {
      outline: none;
      border-color: #F59E0B;
    }

    .modal-buttons {
      display: flex;
      gap: 1rem;
    }

    .btn-primary, .btn-secondary {
      flex: 1;
      padding: 0.75rem;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .btn-primary {
      background: #F59E0B;
      color: #060a12;
    }

    .btn-secondary {
      background: #152040;
      color: #e5e5e5;
      border: 2px solid #1e293b;
    }

    .btn-primary:hover {
      background: #D97706;
    }

    .btn-secondary:hover {
      border-color: #F59E0B;
    }

    /* Fullscreen Styles */
    .timer-hero.fullscreen {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 999;
      background: #060a12;
    }

    .timer-hero.fullscreen .timer-display {
      font-size: 6rem;
    }

    /* Completion Flash */
    .timer-page.flash {
      animation: completion-flash 0.5s ease;
    }

    @keyframes completion-flash {
      0%, 100% { background: #060a12; }
      50% { background: #F59E0B; }
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .timer-display {
        font-size: 3rem;
      }
      
      .progress-ring {
        width: 240px;
        height: 240px;
      }
      
      .progress-ring-background,
      .progress-ring-fill {
        r: 100;
      }
      
      .start-button {
        padding: 1.25rem 3rem;
        font-size: 1.25rem;
      }
      
      .custom-time-controls {
        flex-wrap: wrap;
      }
      
      .preset-timers {
        gap: 0.25rem;
      }
      
      .preset-timer {
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
      }
    }

    @media (max-width: 480px) {
      .timer-display {
        font-size: 2.5rem;
      }
      
      .progress-ring {
        width: 200px;
        height: 200px;
      }
      
      .progress-ring-background,
      .progress-ring-fill {
        r: 80;
      }
      
      .timer-hero.fullscreen .timer-display {
        font-size: 4rem;
      }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // DOM Elements
      const display = document.getElementById('timer-display');
      const startBtn = document.getElementById('start-btn');
      const pauseBtn = document.getElementById('pause-btn');
      const resetBtn = document.getElementById('reset-btn');
      const fullscreenBtn = document.getElementById('fullscreen-btn');
      const secondaryControls = document.getElementById('secondary-controls');
      const progressCircle = document.getElementById('progress-circle');
      const minusBtn = document.getElementById('minus-btn');
      const plusBtn = document.getElementById('plus-btn');
      const timeInputBtn = document.getElementById('time-input-btn');
      const timeInputModal = document.getElementById('time-input-modal');
      const customMinutes = document.getElementById('custom-minutes');
      const customSeconds = document.getElementById('custom-seconds');
      const setCustomTimeBtn = document.getElementById('set-custom-time');
      const cancelCustomTimeBtn = document.getElementById('cancel-custom-time');
      const timerHero = document.querySelector('.timer-hero');
      const timerPage = document.querySelector('.timer-page');

      // Timer State
      const INITIAL_TIME = 1 * 60; // 1 minute in seconds
      let totalTime = INITIAL_TIME;
      let remainingTime = totalTime;
      let timerInterval = null;
      let endTime = null;
      let isRunning = false;
      let hasInteracted = false;
      let audioContext = null;
      const progressCircleCircumference = 2 * Math.PI * 120; // r=120

      // Audio Setup (Web Audio API)
      function createAudioContext() {
        if (!hasInteracted) return;
        try {
          audioContext = new (window.AudioContext || window.webkitAudioContext)();
        } catch (e) {
          console.log('Web Audio not supported');
        }
      }

      function playAlarmSound() {
        if (!audioContext) return;
        try {
          const oscillator = audioContext.createOscillator();
          const gainNode = audioContext.createGain();
          
          oscillator.connect(gainNode);
          gainNode.connect(audioContext.destination);
          
          oscillator.frequency.setValueAtTime(800, audioContext.currentTime);
          oscillator.frequency.setValueAtTime(600, audioContext.currentTime + 0.5);
          
          gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
          gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 1);
          
          oscillator.start(audioContext.currentTime);
          oscillator.stop(audioContext.currentTime + 1);
          
          // Play again after delay for multiple beeps
          setTimeout(() => {
            const osc2 = audioContext.createOscillator();
            const gain2 = audioContext.createGain();
            osc2.connect(gain2);
            gain2.connect(audioContext.destination);
            osc2.frequency.setValueAtTime(800, audioContext.currentTime);
            gain2.gain.setValueAtTime(0.3, audioContext.currentTime);
            gain2.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
            osc2.start();
            osc2.stop(audioContext.currentTime + 0.5);
          }, 300);
        } catch (e) {
          console.log('Audio playback failed');
        }
      }

      // Enable interaction tracking
      document.addEventListener('click', () => {
        if (!hasInteracted) {
          hasInteracted = true;
          createAudioContext();
        }
      });

      // Notification Permission
      function requestNotificationPermission() {
        if ('Notification' in window && Notification.permission === 'default') {
          Notification.requestPermission();
        }
      }

      function showNotification() {
        if ('Notification' in window && Notification.permission === 'granted') {
          new Notification('⏰ Timer Complete!', {
            body: '1 minute is up!',
            icon: '/favicon.ico',
            tag: 'timer-complete'
          });
        }
      }

      // Time Formatting
      function formatTime(seconds) {
        if (seconds < 0) seconds = 0;
        const m = Math.floor(seconds / 60).toString();
        const s = Math.floor(seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
      }

      // Update Display
      function updateDisplay() {
        const timeText = formatTime(remainingTime);
        display.textContent = timeText;
        timeInputBtn.textContent = formatTime(totalTime);
        
        // Update tab title
        if (isRunning && remainingTime > 0) {
          document.title = `${timeText} — 1 Min Timer`;
        } else if (remainingTime === 0) {
          document.title = 'Done! — 1 Min Timer';
        } else {
          document.title = '1 Minute Timer - Free Online Countdown | Start in One Click';
        }

        // Update progress circle
        const progress = remainingTime / totalTime;
        const offset = progressCircleCircumference * (1 - progress);
        progressCircle.style.strokeDashoffset = offset;

        // Handle completion
        if (remainingTime <= 0 && isRunning) {
          completeTimer();
        }
      }

      // Timer Control Functions
      function startTimer() {
        if (isRunning) return;
        if (remainingTime <= 0) {
          resetTimer();
        }

        isRunning = true;
        endTime = Date.now() + (remainingTime * 1000);
        startBtn.style.display = 'none';
        secondaryControls.classList.add('visible');

        // Request notification permission on first start
        requestNotificationPermission();

        timerInterval = setInterval(() => {
          const now = Date.now();
          const delta = endTime - now;
          remainingTime = Math.max(0, Math.ceil(delta / 1000));
          updateDisplay();
        }, 100);

        updateDisplay();
      }

      function pauseTimer() {
        if (!isRunning) return;
        isRunning = false;
        clearInterval(timerInterval);
        timerInterval = null;
        startBtn.style.display = 'inline-block';
        startBtn.textContent = 'RESUME';
        updateDisplay();
      }

      function resetTimer() {
        isRunning = false;
        clearInterval(timerInterval);
        timerInterval = null;
        remainingTime = totalTime;
        startBtn.style.display = 'inline-block';
        startBtn.textContent = 'START';
        secondaryControls.classList.remove('visible');
        updateDisplay();
      }

      function completeTimer() {
        isRunning = false;
        clearInterval(timerInterval);
        timerInterval = null;
        remainingTime = 0;
        
        // Visual flash
        timerPage.classList.add('flash');
        setTimeout(() => timerPage.classList.remove('flash'), 500);
        
        // Sound alert
        playAlarmSound();
        
        // Notification
        showNotification();
        
        // Reset controls
        startBtn.style.display = 'inline-block';
        startBtn.textContent = 'START';
        secondaryControls.classList.remove('visible');
        
        updateDisplay();
      }

      // Time Adjustment
      function adjustTime(seconds) {
        if (isRunning) return;
        totalTime = Math.max(15, totalTime + seconds); // Minimum 15 seconds
        remainingTime = totalTime;
        updateDisplay();
      }

      // Preset Timer Functions
      function setPresetTime(seconds) {
        if (isRunning) return;
        totalTime = seconds;
        remainingTime = totalTime;
        updateDisplay();
      }

      // Custom Time Input
      function showTimeInput() {
        const currentMinutes = Math.floor(totalTime / 60);
        const currentSeconds = totalTime % 60;
        customMinutes.value = currentMinutes;
        customSeconds.value = currentSeconds;
        timeInputModal.classList.add('visible');
        customMinutes.focus();
      }

      function hideTimeInput() {
        timeInputModal.classList.remove('visible');
      }

      function setCustomTime() {
        const minutes = parseInt(customMinutes.value) || 0;
        const seconds = parseInt(customSeconds.value) || 0;
        const newTime = (minutes * 60) + seconds;
        
        if (newTime > 0) {
          totalTime = newTime;
          remainingTime = totalTime;
          updateDisplay();
        }
        
        hideTimeInput();
      }

      // Fullscreen Toggle
      function toggleFullscreen() {
        timerHero.classList.toggle('fullscreen');
        const isFullscreen = timerHero.classList.contains('fullscreen');
        fullscreenBtn.textContent = isFullscreen ? '⛶' : '⛶';
      }

      // Event Listeners
      startBtn.addEventListener('click', startTimer);
      pauseBtn.addEventListener('click', pauseTimer);
      resetBtn.addEventListener('click', resetTimer);
      fullscreenBtn.addEventListener('click', toggleFullscreen);
      minusBtn.addEventListener('click', () => adjustTime(-15));
      plusBtn.addEventListener('click', () => adjustTime(15));
      timeInputBtn.addEventListener('click', showTimeInput);
      display.addEventListener('click', showTimeInput);
      setCustomTimeBtn.addEventListener('click', setCustomTime);
      cancelCustomTimeBtn.addEventListener('click', hideTimeInput);

      // Preset timer buttons
      document.querySelectorAll('.preset-timer[data-seconds]').forEach(btn => {
        btn.addEventListener('click', () => {
          const seconds = parseInt(btn.dataset.seconds);
          setPresetTime(seconds);
        });
      });

      // Modal handling
      timeInputModal.addEventListener('click', (e) => {
        if (e.target === timeInputModal) hideTimeInput();
      });

      // Keyboard shortcuts
      document.addEventListener('keydown', (e) => {
        if (e.code === 'Space') {
          e.preventDefault();
          isRunning ? pauseTimer() : startTimer();
        } else if (e.code === 'KeyR') {
          e.preventDefault();
          resetTimer();
        } else if (e.code === 'KeyF') {
          e.preventDefault();
          toggleFullscreen();
        } else if (e.code === 'Escape') {
          hideTimeInput();
          if (timerHero.classList.contains('fullscreen')) {
            timerHero.classList.remove('fullscreen');
          }
        }
      });

      // Custom time input enter key
      [customMinutes, customSeconds].forEach(input => {
        input.addEventListener('keydown', (e) => {
          if (e.code === 'Enter') {
            setCustomTime();
          }
        });
      });

      // Handle page visibility change for background accuracy
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden && isRunning && endTime) {
          // Recalculate when tab becomes visible again
          const now = Date.now();
          const delta = endTime - now;
          remainingTime = Math.max(0, Math.ceil(delta / 1000));
          updateDisplay();
        }
      });

      // Initialize
      updateDisplay();
    });
  </script>

