    .explainer a { color: var(--accent-color); text-decoration: none; }
    .explainer a:hover { text-decoration: underline; }
    .formula-box { background: var(--card-bg); border-left: 4px solid var(--accent-color); padding: 1rem 1.5rem; margin: 1.5rem 0; border-radius: 0 8px 8px 0; }
    .formula-box code { font-family: monospace; font-size: 1.1rem; color: var(--text-primary); }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { color: var(--text-primary); margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); font-size: 1.1rem; }
    .faq-section p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>

