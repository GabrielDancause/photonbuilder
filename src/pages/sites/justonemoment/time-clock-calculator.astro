    .summary-card.highlight .summary-value { color: var(--accent-color); }

    .explainer { margin-top: 3rem; line-height: 1.7; color: var(--text-secondary); }
    .explainer h2 { color: var(--text-primary); margin-top: 2.5rem; margin-bottom: 1rem; }
