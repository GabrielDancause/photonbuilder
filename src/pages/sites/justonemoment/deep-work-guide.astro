---
import SiteLayout from "../../../layouts/SiteLayout.astro";


export const meta = {
  title: 'Deep Work Guide: Mastering Focus and Productivity',
  description: 'A comprehensive guide to Cal Newport',
  category: 'guide',
};

const faqs = [
  {
    "q": "What is the difference between deep work and shallow work?",
    "a": "Deep work consists of professional activities performed in a state of distraction-free concentration that push your cognitive capabilities to their limit. Shallow work involves non-cognitively demanding, logistical-style tasks often performed while distracted."
  },
  {
    "q": "How does the time blocking method help with deep work?",
    "a": "Time blocking involves dividing your day into distinct blocks of time, each dedicated to a specific task or deep work session. This prevents context switching and ensures dedicated time for focused effort."
  },
  {
    "q": "What is attention residue?",
    "a": "Attention residue occurs when you switch from one task to another, but a portion of your attention remains stuck on the previous task. This reduces your cognitive capacity for the new task."
  },
  {
    "q": "Why is a shutdown ritual important?",
    "a": "A shutdown ritual signals to your brain that the workday is over. It helps you disconnect completely, preventing work-related thoughts from intruding on your downtime and allowing your mind to recharge for the next day."
  },
  {
    "q": "What is the 4-hour rule for deep work scheduling?",
    "a": "The 4-hour rule suggests that even the most skilled individuals can only sustain true deep work for about four hours a day. Beyond that, cognitive fatigue sets in and returns diminish."
  }
];

