  <script is:inline>
  (function() {
    // --- Configuration ---
    const CIRCUMFERENCE = 2 * Math.PI * 120; // ~753.98

    let config = {
      work: 25 * 60,
      shortBreak: 5 * 60,
      longBreak: 15 * 60,
      cyclesBeforeLong: 4
    };

    let state = {
      mode: 'work',         // 'work' | 'shortBreak' | 'longBreak'
      running: false,
      totalSeconds: config.work,
      remainingMs: config.work * 1000,
      completedPomodoros: 0,
      startTimestamp: null,
      pausedRemaining: null,
      sessions: [],
      currentSessionStart: null,
      animFrame: null
    };

    // --- DOM Elements ---
    const display = document.getElementById('timerDisplay');
    const label = document.getElementById('timerLabel');
    const ring = document.getElementById('progressRing');
    const startPauseBtn = document.getElementById('startPauseBtn');
    const resetBtn = document.getElementById('resetBtn');
    const skipBtn = document.getElementById('skipBtn');
    const sessionCounter = document.getElementById('sessionCounter');
    const sessionLabel = document.getElementById('sessionLabel');
    const settingsToggle = document.getElementById('settingsToggle');
    const settingsPanel = document.getElementById('settingsPanel');
    const applySettings = document.getElementById('applySettings');
    const sessionLog = document.getElementById('sessionLog');
    const logEmpty = document.getElementById('logEmpty');
    const totalFocus = document.getElementById('totalFocus');
    const modeTabs = document.querySelectorAll('.mode-tab');

    // --- Audio ---
    function playBeep() {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        // Three-tone notification
        const times = [0, 0.2, 0.4];
        const freqs = [830, 830, 1050];
        times.forEach((t, i) => {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.connect(gain);
          gain.connect(ctx.destination);
          osc.type = 'sine';
          osc.frequency.value = freqs[i];
          gain.gain.setValueAtTime(0.3, ctx.currentTime + t);
          gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + t + 0.18);
          osc.start(ctx.currentTime + t);
          osc.stop(ctx.currentTime + t + 0.2);
        });
      } catch(e) {}
    }

    // --- Rendering ---
    function formatTime(ms) {
      const totalSec = Math.ceil(ms / 1000);
      const m = Math.floor(totalSec / 60);
      const s = totalSec % 60;
      return String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
    }

    function updateDisplay() {
      display.textContent = formatTime(state.remainingMs);
      const fraction = state.remainingMs / (state.totalSeconds * 1000);
      const offset = CIRCUMFERENCE * (1 - fraction);
      ring.style.strokeDashoffset = offset;
      document.title = formatTime(state.remainingMs) + ' — Pomodoro Timer';
    }

    function updateModeUI() {
      modeTabs.forEach(tab => {
        tab.classList.toggle('active', tab.dataset.mode === state.mode);
      });

      const colors = { work: '#e74c3c', shortBreak: '#27ae60', longBreak: '#2980b9' };
      const labels = { work: 'Focus Time', shortBreak: 'Short Break', longBreak: 'Long Break' };
      ring.style.stroke = colors[state.mode];
      label.textContent = labels[state.mode];
      startPauseBtn.style.background = colors[state.mode];
    }

    function updateSessionCounter() {
      const slots = sessionCounter.querySelectorAll('.tomato-slot');
      // Rebuild slots if cyclesBeforeLong changed
      if (slots.length !== config.cyclesBeforeLong) {
        sessionCounter.innerHTML = '';
        for (let i = 0; i < config.cyclesBeforeLong; i++) {
          const span = document.createElement('span');
          span.className = 'tomato-slot';
          span.innerHTML = '&#127813;';
          sessionCounter.appendChild(span);
        }
      }
      const updatedSlots = sessionCounter.querySelectorAll('.tomato-slot');
      updatedSlots.forEach((slot, i) => {
        slot.classList.toggle('completed', i < (state.completedPomodoros % config.cyclesBeforeLong));
      });
      sessionLabel.textContent = state.completedPomodoros + ' of ' + config.cyclesBeforeLong + ' pomodoros completed';
    }

    function updateLog() {
      if (state.sessions.length === 0) {
        logEmpty.style.display = '';
        totalFocus.textContent = '';
        return;
      }
      logEmpty.style.display = 'none';
      // Remove old entries
      sessionLog.querySelectorAll('.log-entry').forEach(e => e.remove());
      state.sessions.forEach(s => {
        const div = document.createElement('div');
        div.className = 'log-entry';
        div.innerHTML = '<span>&#127813; Pomodoro #' + s.number + '</span><span>' + s.time + ' (' + s.duration + ' min)</span>';
        sessionLog.appendChild(div);
      });
      const totalMin = state.sessions.reduce((sum, s) => sum + s.duration, 0);
      totalFocus.textContent = 'Total focus today: ' + totalMin + ' minutes';
    }

    // --- Timer Logic ---
    function tick() {
      if (!state.running) return;
      const elapsed = Date.now() - state.startTimestamp;
      state.remainingMs = state.pausedRemaining - elapsed;
      if (state.remainingMs <= 0) {
        state.remainingMs = 0;
        updateDisplay();
        onTimerComplete();
        return;
      }
      updateDisplay();
      state.animFrame = requestAnimationFrame(tick);
    }

    function start() {
      if (state.running) return;
      state.running = true;
      state.startTimestamp = Date.now();
      state.pausedRemaining = state.remainingMs;
      if (state.mode === 'work' && !state.currentSessionStart) {
        state.currentSessionStart = new Date();
      }
      startPauseBtn.textContent = 'Pause';
      state.animFrame = requestAnimationFrame(tick);
    }

    function pause() {
      if (!state.running) return;
      state.running = false;
      state.remainingMs = state.pausedRemaining - (Date.now() - state.startTimestamp);
      if (state.remainingMs < 0) state.remainingMs = 0;
      startPauseBtn.textContent = 'Resume';
      cancelAnimationFrame(state.animFrame);
    }

    function reset() {
      state.running = false;
      cancelAnimationFrame(state.animFrame);
      state.currentSessionStart = null;
      const durations = { work: config.work, shortBreak: config.shortBreak, longBreak: config.longBreak };
      state.totalSeconds = durations[state.mode];
      state.remainingMs = state.totalSeconds * 1000;
      state.pausedRemaining = state.remainingMs;
      startPauseBtn.textContent = 'Start';
      updateDisplay();
    }

    function switchMode(mode, autoStart) {
      state.running = false;
      cancelAnimationFrame(state.animFrame);
      state.currentSessionStart = null;
      state.mode = mode;
      const durations = { work: config.work, shortBreak: config.shortBreak, longBreak: config.longBreak };
      state.totalSeconds = durations[mode];
      state.remainingMs = state.totalSeconds * 1000;
      state.pausedRemaining = state.remainingMs;
      startPauseBtn.textContent = 'Start';
      updateModeUI();
      updateDisplay();
      if (autoStart) {
        setTimeout(() => start(), 600);
      }
    }

    function onTimerComplete() {
      state.running = false;
      cancelAnimationFrame(state.animFrame);
      playBeep();

      if (state.mode === 'work') {
        state.completedPomodoros++;
        // Log session
        const now = new Date();
        const timeStr = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
        state.sessions.push({
          number: state.completedPomodoros,
          time: timeStr,
          duration: Math.round(config.work / 60)
        });
        updateSessionCounter();
        updateLog();
        // Decide next mode
        if (state.completedPomodoros % config.cyclesBeforeLong === 0) {
          switchMode('longBreak', true);
        } else {
          switchMode('shortBreak', true);
        }
      } else {
        switchMode('work', true);
      }
    }

    // --- Event Listeners ---
    startPauseBtn.addEventListener('click', () => {
      state.running ? pause() : start();
    });

    resetBtn.addEventListener('click', reset);

    skipBtn.addEventListener('click', () => {
      if (state.mode === 'work' && state.running) {
        // Don't count incomplete pomodoro
      }
      const nextModes = {
        work: (state.completedPomodoros + 1) % config.cyclesBeforeLong === 0 ? 'longBreak' : 'shortBreak',
        shortBreak: 'work',
        longBreak: 'work'
      };
      // If skipping from work while it was running, still count if most of time passed
      if (state.mode === 'work' && state.running) {
        const elapsed = config.work * 1000 - state.remainingMs;
        if (elapsed > config.work * 1000 * 0.8) {
          // Count it if 80%+ done
          state.completedPomodoros++;
          const now = new Date();
          const timeStr = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
          state.sessions.push({ number: state.completedPomodoros, time: timeStr, duration: Math.round(elapsed / 60000) });
          updateSessionCounter();
          updateLog();
        }
      }
      let next = nextModes[state.mode];
      if (state.mode === 'work') {
        next = state.completedPomodoros % config.cyclesBeforeLong === 0 && state.completedPomodoros > 0 ? 'longBreak' : 'shortBreak';
      }
      switchMode(next, false);
    });

    modeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        switchMode(tab.dataset.mode, false);
      });
    });

    settingsToggle.addEventListener('click', () => {
      settingsPanel.style.display = settingsPanel.style.display === 'none' ? '' : 'none';
    });

    applySettings.addEventListener('click', () => {
      const w = parseInt(document.getElementById('workDuration').value) || 25;
      const sb = parseInt(document.getElementById('shortBreakDuration').value) || 5;
      const lb = parseInt(document.getElementById('longBreakDuration').value) || 15;
      const c = parseInt(document.getElementById('cyclesBeforeLong').value) || 4;
      config.work = Math.max(1, Math.min(120, w)) * 60;
      config.shortBreak = Math.max(1, Math.min(30, sb)) * 60;
      config.longBreak = Math.max(1, Math.min(60, lb)) * 60;
      config.cyclesBeforeLong = Math.max(2, Math.min(10, c));
      updateSessionCounter();
      switchMode(state.mode, false);
      settingsPanel.style.display = 'none';
    });

    // Keyboard shortcut: Space to start/pause
    document.addEventListener('keydown', (e) => {
      if (e.target.tagName === 'INPUT') return;
      if (e.code === 'Space') {
        e.preventDefault();
        state.running ? pause() : start();
      }
    });

    // --- Init ---
    ring.style.strokeDasharray = CIRCUMFERENCE;
    updateModeUI();
    updateSessionCounter();
    updateDisplay();
  })();
  </script>
</SiteLayout>
