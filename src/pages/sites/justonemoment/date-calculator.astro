    .form-group input[type="date"]::-webkit-calendar-picker-indicator:hover { opacity: 1; }

    .error-text { color: #e11d48; font-size: 0.85rem; margin-top: 0.5rem; font-weight: 500; display: none; }
    .input-hint { color: var(--text-secondary); font-size: 0.85rem; margin-top: 0.5rem; }

    .checkbox-label { display: flex; align-items: center; gap: 0.75rem; font-weight: 500; color: var(--text-primary); cursor: pointer; user-select: none; margin-bottom: 1.5rem; font-size: 0.95rem; }
    .checkbox-label input[type="checkbox"] { width: 1.2rem; height: 1.2rem; accent-color: var(--accent-color); cursor: pointer; }

    .calc-action-btn { background: var(--text-primary); color: var(--bg-primary); border: none; padding: 1rem; width: 100%; font-size: 1.1rem; font-weight: 600; border-radius: 12px; cursor: pointer; transition: background 0.2s, transform 0.1s; margin-top: 1rem; }
    .calc-action-btn:hover { background: color-mix(in srgb, var(--text-primary) 80%, #000); }
    .calc-action-btn:active { transform: scale(0.98); }

    /* Results Area */
    .result-area { margin-top: 3rem; background: var(--bg-primary); border: 2px solid var(--accent-color); border-radius: 16px; padding: 2.5rem; animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .result-header { text-align: center; margin-bottom: 1.5rem; }
    .result-header h4 { font-size: 1.1rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
    .result-main { text-align: center; margin-bottom: 2rem; }
    .result-primary-value { font-size: 3.5rem; font-weight: 800; color: var(--accent-color); line-height: 1.1; letter-spacing: -0.03em; word-break: break-word; }

    .result-breakdown { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .breakdown-item { background: var(--card-bg); border: 1px solid var(--border-color); padding: 1rem; border-radius: 12px; text-align: center; }
    .bd-value { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); }
    .bd-label { font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; font-weight: 500; margin-top: 0.25rem; }

    .result-message { text-align: center; color: var(--text-secondary); font-size: 1.05rem; line-height: 1.6; background: color-mix(in srgb, var(--accent-color) 5%, transparent); padding: 1rem; border-radius: 8px; border-left: 4px solid var(--accent-color); }

    /* Chart Styles */
    .result-chart-container { margin: 2.5rem 0 2rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; }
    .result-chart-container h5 { font-size: 1rem; color: var(--text-primary); margin-bottom: 1rem; text-align: center; }
    .timeline-chart { position: relative; padding: 2rem 0 1rem; }
    .timeline-bar { height: 12px; background: color-mix(in srgb, var(--border-color) 50%, var(--bg-primary)); border-radius: 6px; overflow: hidden; position: relative; }
    .timeline-progress { position: absolute; left: 0; top: 0; bottom: 0; background: linear-gradient(90deg, color-mix(in srgb, var(--accent-color) 60%, transparent), var(--accent-color)); width: 0%; transition: width 1s ease-out; }
    .timeline-labels { display: flex; justify-content: space-between; margin-top: 0.75rem; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); }
    .timeline-markers { position: absolute; top: 1.5rem; left: 0; width: 100%; height: 100%; pointer-events: none; }
    .t-marker { position: absolute; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; }
    .t-marker::before { content: ''; width: 2px; height: 16px; background: var(--border-color); margin-bottom: 4px; }
    .t-marker span { font-size: 0.75rem; color: var(--text-secondary); background: var(--card-bg); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border-color); white-space: nowrap; }

    /* Educational Section */
    .educational-section { margin-top: 5rem; border-top: 1px solid var(--border-color); padding-top: 4rem; }
    .edu-header { text-align: center; margin-bottom: 3rem; }
    .edu-header h2 { font-size: 2.2rem; font-weight: 800; color: var(--text-primary); margin-bottom: 1rem; }
    .edu-header p { font-size: 1.1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; }
    .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 3rem; }
    .edu-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; padding: 2rem; transition: transform 0.2s, box-shadow 0.2s; }
    .edu-card:hover { transform: translateY(-5px); box-shadow: 0 12px 24px rgba(0,0,0,0.05); }
    .edu-icon { font-size: 2.5rem; margin-bottom: 1.5rem; }
    .edu-card h3 { font-size: 1.3rem; color: var(--text-primary); margin-bottom: 1rem; font-weight: 700; }
    .edu-card p { color: var(--text-secondary); line-height: 1.6; font-size: 0.95rem; }
    .detailed-insight { margin-bottom: 2.5rem; background: var(--bg-primary); padding: 2rem; border-left: 4px solid var(--accent-color); border-radius: 0 12px 12px 0; }
    .detailed-insight h4 { font-size: 1.2rem; color: var(--text-primary); margin-bottom: 1rem; }
    .detailed-insight p { color: var(--text-secondary); line-height: 1.7; margin-bottom: 1rem; font-size: 1rem; }
    .detailed-insight p:last-child { margin-bottom: 0; }


    /* Detailed Insight Cards */
    .detailed-insight-card { background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 2rem; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; }
    .detailed-insight-card:hover { transform: translateY(-3px); box-shadow: 0 8px 16px rgba(0,0,0,0.03); }
    .insight-header { background: color-mix(in srgb, var(--accent-color) 8%, transparent); padding: 1.5rem 2rem; display: flex; align-items: center; gap: 1.5rem; border-bottom: 1px solid var(--border-color); }
    .insight-number { background: var(--accent-color); color: #fff; font-size: 1.2rem; font-weight: 800; padding: 0.5rem 1rem; border-radius: 8px; }
    .insight-header h4 { font-size: 1.3rem; color: var(--text-primary); font-weight: 700; margin: 0; }
    .insight-body { padding: 2rem; }
    .insight-body p { color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem; margin: 0; }

    @media (min-width: 768px) {
       .detailed-insight-card { flex-direction: row; }
       .insight-header { flex: 0 0 300px; flex-direction: column; justify-content: center; align-items: flex-start; text-align: left; border-bottom: none; border-right: 1px solid var(--border-color); }
    }

    /* FAQ Section */
    .faq-section { margin-top: 5rem; padding: 4rem 0; border-top: 1px solid var(--border-color); }
    .faq-section h2 { font-size: 2.2rem; text-align: center; color: var(--text-primary); margin-bottom: 3rem; font-weight: 800; }
    .faq-grid { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 1rem; }
    .faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; }
    .faq-item summary { padding: 1.5rem; font-size: 1.1rem; font-weight: 600; color: var(--text-primary); cursor: pointer; list-style: none; position: relative; padding-right: 3rem; user-select: none; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; position: absolute; right: 1.5rem; top: 50%; transform: translateY(-50%); font-size: 1.5rem; color: var(--accent-color); transition: transform 0.3s; }
    .faq-item[open] summary::after { content: '−'; transform: translateY(-50%) rotate(180deg); }
    .faq-answer { padding: 0 1.5rem 1.5rem; color: var(--text-secondary); line-height: 1.6; font-size: 1rem; border-top: 1px solid transparent; }
    .faq-item[open] .faq-answer { border-top-color: var(--border-color); padding-top: 1.5rem; animation: slideDown 0.3s ease-out; }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

    /* Related Links */
    .related-tools { margin-top: 4rem; text-align: center; background: var(--card-bg); padding: 3rem 2rem; border-radius: 20px; border: 1px solid var(--border-color); }
    .related-tools h2 { font-size: 1.8rem; color: var(--text-primary); margin-bottom: 2rem; font-weight: 700; }
    .related-links { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
    .related-link { background: var(--bg-primary); color: var(--accent-color); text-decoration: none; padding: 0.75rem 1.5rem; border-radius: 30px; font-weight: 600; border: 1px solid var(--border-color); transition: all 0.2s; font-size: 0.95rem; }
    .related-link:hover { background: var(--accent-color); color: #fff; border-color: var(--accent-color); transform: translateY(-2px); box-shadow: 0 4px 12px color-mix(in srgb, var(--accent-color) 30%, transparent); }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Elements Configuration
      const config = {
        tabs: document.querySelectorAll('.calc-tab'),
        sections: {
          diff: document.getElementById('diff-section'),
          add: document.getElementById('add-section'),
          age: document.getElementById('age-section'),
          business: document.getElementById('business-section')
        },
        resultArea: document.getElementById('result-area'),
        resultTitle: document.getElementById('result-title'),
        resultPrimary: document.getElementById('result-primary'),
        resultBreakdown: document.getElementById('result-breakdown'),
        resultMessage: document.getElementById('result-message'),
        chartContainer: document.getElementById('result-chart-container'),
        timelineProgress: document.getElementById('timeline-progress'),
        chartStart: document.getElementById('chart-start-label'),
        chartEnd: document.getElementById('chart-end-label'),
        timelineMarkers: document.getElementById('timeline-markers')
      };

      // Set default dates
      const today = new Date();
      // Format as YYYY-MM-DD
      const formatDateStr = (d) => {
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      };

      const todayStr = formatDateStr(today);

      const nextMonth = new Date(today);
      nextMonth.setMonth(nextMonth.getMonth() + 1);
      const nextMonthStr = formatDateStr(nextMonth);

      // Diff Init
      document.getElementById('diff-start').value = todayStr;
      document.getElementById('diff-end').value = nextMonthStr;

      // Add Init
      document.getElementById('add-base').value = todayStr;

      // Age Init
      const dobInit = new Date(today);
      dobInit.setFullYear(dobInit.getFullYear() - 30);
      document.getElementById('age-dob').value = formatDateStr(dobInit);
      document.getElementById('age-target').value = todayStr;

      // Biz Init
      document.getElementById('biz-start').value = todayStr;
      document.getElementById('biz-end').value = nextMonthStr;

      // Tab Switching Logic
      let currentMode = 'diff';
      config.tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Update active state
          config.tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');

          // Switch sections
          currentMode = tab.dataset.tab;
          Object.values(config.sections).forEach(sec => sec.style.display = 'none');
          config.sections[currentMode].style.display = 'block';

          // Hide result area on switch
          config.resultArea.style.display = 'none';
        });
      });


      // Hero CTA scroll
      const heroCtaBtn = document.getElementById('hero-cta-btn');
      if (heroCtaBtn) {
        heroCtaBtn.addEventListener('click', () => {
          document.getElementById('calculator').scrollIntoView({ behavior: 'smooth' });
        });
      }


      // Extensive List of Global Public Holidays for Business Days Calculation
      const globalHolidays = [
        "2026-01-01", // New Year's Day
        "2026-01-19", // Martin Luther King Jr. Day (US)
        "2026-02-16", // Presidents' Day (US)
        "2026-03-17", // St. Patrick's Day (IE)
        "2026-04-03", // Good Friday
        "2026-04-06", // Easter Monday
        "2026-05-01", // Labor Day (EU)
        "2026-05-25", // Memorial Day (US)
        "2026-07-01", // Canada Day
        "2026-07-04", // Independence Day (US)
        "2026-07-14", // Bastille Day (FR)
        "2026-08-31", // Summer Bank Holiday (UK)
        "2026-09-07", // Labor Day (US)
        "2026-10-12", // Columbus Day / Indigenous Peoples' Day (US)
        "2026-10-31", // Halloween (Not public, but notable)
        "2026-11-11", // Veterans Day (US)
        "2026-11-26", // Thanksgiving (US)
        "2026-12-25", // Christmas Day
        "2026-12-26", // Boxing Day
        // 2027 Projections
        "2027-01-01", // New Year's Day
        "2027-01-18", // Martin Luther King Jr. Day (US)
        "2027-02-15", // Presidents' Day (US)
        "2027-03-26", // Good Friday
        "2027-03-29", // Easter Monday
        "2027-05-01", // Labor Day (EU)
        "2027-05-31", // Memorial Day (US)
        "2027-07-01", // Canada Day
        "2027-07-04", // Independence Day (US)
        "2027-09-06", // Labor Day (US)
        "2027-10-11", // Columbus Day
        "2027-11-11", // Veterans Day (US)
        "2027-11-25", // Thanksgiving (US)
        "2027-12-25", // Christmas Day
        "2027-12-26"  // Boxing Day
      ];

      // Format date for holiday comparison (YYYY-MM-DD)
      const formatForComparison = (d) => {
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      };

      const isHoliday = (dStr) => {
         return globalHolidays.includes(dStr);
      };

      // Utilities
      const parseDate = (dateStr) => {
        if (!dateStr) return null;
        const [y, m, d] = dateStr.split('-');
        return new Date(y, m - 1, d, 0, 0, 0);
      };

      const dateOpts = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
      const formatDisplay = (dateObj) => dateObj.toLocaleDateString(undefined, dateOpts);

      const renderBreakdown = (items) => {
        config.resultBreakdown.innerHTML = items.map(item => `
          <div class="breakdown-item">
            <div class="bd-value">${item.val}</div>
            <div class="bd-label">${item.label}</div>
          </div>
        `).join('');
      };

      const showError = (id, show) => {
        const el = document.getElementById(id);
        if (el) el.style.display = show ? 'block' : 'none';
      };

      // Chart Generation Logic
      const renderChart = (start, end, durationDays, type) => {
        if (durationDays < 1) {
           config.chartContainer.style.display = 'none';
           return;
        }
        config.chartContainer.style.display = 'block';

        // Reset animation
        config.timelineProgress.style.width = '0%';
        setTimeout(() => {
           config.timelineProgress.style.width = '100%';
        }, 100);

        // Sort dates to ensure left-to-right rendering
        let renderStart = start;
        let renderEnd = end;
        if (start.getTime() > end.getTime()) {
           renderStart = end;
           renderEnd = start;
        }

        config.chartStart.textContent = formatDisplay(renderStart);
        config.chartEnd.textContent = formatDisplay(renderEnd);

        // Generate intermediary markers (e.g., halfway point or notable milestones)
        let markersHTML = '';
        if (durationDays > 14) {
           const midPoint = new Date(renderStart.getTime() + ((renderEnd.getTime() - renderStart.getTime()) / 2));
           markersHTML += `
             <div class="t-marker" style="left: 50%;">
               <span>${formatDisplay(midPoint)}</span>
             </div>
           `;
        }

        config.timelineMarkers.innerHTML = markersHTML;
      };

      // Calculators

      // 1. Difference Calculator
      document.getElementById('diff-calc-btn').addEventListener('click', () => {
        const start = parseDate(document.getElementById('diff-start').value);
        const end = parseDate(document.getElementById('diff-end').value);
        const includeEnd = document.getElementById('diff-include-end').checked;

        let hasError = false;
        if (!start || isNaN(start.getTime())) { showError('diff-start-error', true); hasError = true; } else { showError('diff-start-error', false); }
        if (!end || isNaN(end.getTime())) { showError('diff-end-error', true); hasError = true; } else { showError('diff-end-error', false); }
        if (hasError) return;

        const msDiff = end.getTime() - start.getTime();
        let daysDiff = Math.round(msDiff / (1000 * 60 * 60 * 24));
        const isPast = daysDiff < 0;
        daysDiff = Math.abs(daysDiff);

        if (includeEnd) {
          daysDiff += 1;
        }

        const weeks = Math.floor(daysDiff / 7);
        const remainingDays = daysDiff % 7;
        const approxMonths = (daysDiff / 30.44).toFixed(1);
        const approxYears = (daysDiff / 365.25).toFixed(2);

        config.resultTitle.textContent = isPast ? "Time in the Past" : "Time Difference";
        config.resultPrimary.textContent = `${daysDiff.toLocaleString()} Days`;

        renderBreakdown([
          { val: weeks, label: 'Weeks' },
          { val: remainingDays, label: 'Days' },
          { val: approxMonths, label: 'Months (approx)' },
          { val: approxYears, label: 'Years (approx)' }
        ]);

        config.resultMessage.innerHTML = `<strong>From:</strong> ${formatDisplay(start)}<br><strong>To:</strong> ${formatDisplay(end)}`;

        renderChart(start, end, daysDiff, 'diff');
        config.resultArea.style.display = 'block';
        config.resultArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });

      // 2. Add/Subtract Calculator
      document.getElementById('add-calc-btn').addEventListener('click', () => {
        const base = parseDate(document.getElementById('add-base').value);
        const op = document.getElementById('add-operation').value;
        const y = parseInt(document.getElementById('add-years').value) || 0;
        const m = parseInt(document.getElementById('add-months').value) || 0;
        const w = parseInt(document.getElementById('add-weeks').value) || 0;
        const d = parseInt(document.getElementById('add-days').value) || 0;

        if (!base || isNaN(base.getTime())) { showError('add-base-error', true); return; } else { showError('add-base-error', false); }

        const totalDaysToShift = (w * 7) + d;
        const resultDate = new Date(base);

        const sign = op === 'add' ? 1 : -1;

        // Apply Years and Months via Date object mutation (handles leap years inherently)
        resultDate.setFullYear(resultDate.getFullYear() + (y * sign));
        resultDate.setMonth(resultDate.getMonth() + (m * sign));
        // Apply Days
        resultDate.setDate(resultDate.getDate() + (totalDaysToShift * sign));

        config.resultTitle.textContent = "Resulting Date";
        config.resultPrimary.textContent = formatDisplay(resultDate);

        renderBreakdown([
          { val: y, label: 'Years' },
          { val: m, label: 'Months' },
          { val: w, label: 'Weeks' },
          { val: d, label: 'Days' }
        ]);

        config.resultMessage.innerHTML = `Calculated by <strong>${op}ing</strong> the specified time ${op === 'add' ? 'to' : 'from'} ${formatDisplay(base)}.`;

        const totalDaysApprox = (y * 365) + (m * 30) + (w * 7) + d;
        renderChart(base, resultDate, totalDaysApprox, 'add');

        config.resultArea.style.display = 'block';
        config.resultArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });

      // 3. Age Calculator
      document.getElementById('age-calc-btn').addEventListener('click', () => {
        const dob = parseDate(document.getElementById('age-dob').value);
        const target = parseDate(document.getElementById('age-target').value) || new Date(new Date().setHours(0,0,0,0));

        if (!dob || isNaN(dob.getTime())) { showError('age-dob-error', true); return; } else { showError('age-dob-error', false); }

        if (dob.getTime() > target.getTime()) {
           config.resultArea.style.display = 'block';
           config.resultTitle.textContent = "Error";
           config.resultPrimary.textContent = "Not Born Yet!";
           config.resultBreakdown.innerHTML = '';
           config.resultMessage.innerHTML = "Date of birth cannot be after the target date.";
           config.chartContainer.style.display = 'none';
           return;
        }

        let years = target.getFullYear() - dob.getFullYear();
        let months = target.getMonth() - dob.getMonth();
        let days = target.getDate() - dob.getDate();

        // Adjust for negative days or months
        if (days < 0) {
            months--;
            // get days in previous month
            const prevMonth = new Date(target.getFullYear(), target.getMonth(), 0);
            days += prevMonth.getDate();
        }
        if (months < 0) {
            years--;
            months += 12;
        }

        const msDiff = target.getTime() - dob.getTime();
        const totalDays = Math.round(msDiff / (1000 * 60 * 60 * 24));
        const totalWeeks = Math.floor(totalDays / 7);

        // Next birthday logic
        const nextBday = new Date(target.getFullYear(), dob.getMonth(), dob.getDate());
        if (nextBday.getTime() < target.getTime()) {
            nextBday.setFullYear(nextBday.getFullYear() + 1);
        }
        const bdayMs = nextBday.getTime() - target.getTime();
        const daysToBday = Math.round(bdayMs / (1000 * 60 * 60 * 24));

        config.resultTitle.textContent = "Exact Age";
        config.resultPrimary.textContent = `${years} Years Old`;

        renderBreakdown([
          { val: months, label: 'Months' },
          { val: days, label: 'Days' },
          { val: totalDays.toLocaleString(), label: 'Total Days Alive' },
          { val: daysToBday, label: 'Days Until Birthday' }
        ]);

        config.resultMessage.innerHTML = `Age measured on ${formatDisplay(target)}.<br>Your next birthday is on <strong>${formatDisplay(nextBday)}</strong>.`;

        renderChart(dob, target, totalDays, 'age');

        config.resultArea.style.display = 'block';
        config.resultArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });

      // 4. Business Days
      document.getElementById('biz-calc-btn').addEventListener('click', () => {
        const start = parseDate(document.getElementById('biz-start').value);
        const end = parseDate(document.getElementById('biz-end').value);

        let hasError = false;
        if (!start || isNaN(start.getTime())) { showError('biz-start-error', true); hasError = true; } else { showError('biz-start-error', false); }
        if (!end || isNaN(end.getTime())) { showError('biz-end-error', true); hasError = true; } else { showError('biz-end-error', false); }
        if (hasError) return;

        let iter = new Date(start);
        const final = new Date(end);
        let direction = 1;

        if (iter.getTime() > final.getTime()) {
           direction = -1;
        }

        let bizDays = 0;
        let weekends = 0;
        let holidays = 0;
        let totalDays = 0;

        // Optionally user could toggle this, we will apply silently for demonstration
        const includeHolidays = true;

        // Loop through each day and check if it's a weekend or holiday
        // To prevent infinite loop safely, we use < or > based on direction
        // Set hours to 12 PM to avoid DST boundary issues during iteration
        iter.setHours(12, 0, 0, 0);
        final.setHours(12, 0, 0, 0);

        // Safety counter to prevent any browser hangs in edge cases
        let safetyCounter = 0;

        while ((direction > 0 ? iter.getTime() < final.getTime() : iter.getTime() > final.getTime()) && safetyCounter < 36500) {
            const dayOfWeek = iter.getDay(); // 0 is Sun, 6 is Sat
            const dateStr = formatForComparison(iter);

            if (dayOfWeek === 0 || dayOfWeek === 6) {
                weekends++;
            } else if (includeHolidays && isHoliday(dateStr)) {
                holidays++;
            } else {
                bizDays++;
            }

            totalDays++;
            iter.setDate(iter.getDate() + direction);
            safetyCounter++;
        }

        config.resultTitle.textContent = "Business Days Calculation";
        config.resultPrimary.textContent = `${bizDays} Business Days`;

        renderBreakdown([
          { val: totalDays, label: 'Total Calendar Days' },
          { val: weekends, label: 'Weekend Days Excluded' },
          { val: holidays, label: 'Holidays Excluded' }
        ]);

        config.resultMessage.innerHTML = `Calculation counts working days from <strong>${formatDisplay(start)}</strong> to <strong>${formatDisplay(end)}</strong>, excluding Saturdays and Sundays.`;

        renderChart(start, end, totalDays, 'biz');

        config.resultArea.style.display = 'block';
        config.resultArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });

    });
  </script>
</SiteLayout>
