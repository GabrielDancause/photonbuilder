---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Hour Calculator & Timesheet Tracker",
  description: "Accurately calculate hours worked, determine gross pay, and track your daily timesheets with our free, real-time hour calculator.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you calculate total hours worked?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate total hours worked, convert your start and end times to a 24-hour military format. Subtract the start time from the end time. If you took an unpaid break, subtract the break duration from the total time."
      }
    },
    {
      "@type": "Question",
      "name": "How do you convert minutes to decimals?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To convert minutes into a decimal format for payroll purposes, divide the number of minutes by 60. For example, 15 minutes is 15/60 = 0.25 hours; 30 minutes is 30/60 = 0.5 hours; and 45 minutes is 45/60 = 0.75 hours."
      }
    },
    {
      "@type": "Question",
      "name": "What is military time and why use it for payroll?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Military time is a 24-hour clock system (e.g., 1:00 PM is 13:00). It is used in payroll and time tracking because it eliminates the confusion between AM and PM, making mathematical calculations for hours worked straightforward and error-free."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate gross pay from hours worked?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate gross pay, multiply your total hours worked (in decimal format) by your hourly wage. For example, if you worked 8.5 hours at a rate of $20 per hour, your gross pay is 8.5 * 20 = $170."
      }
    },
    {
      "@type": "Question",
      "name": "Do employers have to pay for lunch breaks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In most jurisdictions, employers are not legally required to pay for bona fide meal breaks (usually 30 minutes or more) if the employee is completely relieved from duty. However, shorter rest breaks (usually 5-20 minutes) are generally considered paid working time."
      }
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "author": {
    "@type": "Organization",
    "name": "SiliconBased.dev"
  },
  "publisher": {
    "@type": "Organization",
    "name": "SiliconBased",
    "logo": {
      "@type": "ImageObject",
      "url": "https://photonbuilder.com/justonemoment/logo.png"
    }
  },
  "datePublished": meta.published
};

const combinedSchema = [schema, articleSchema];
---

<SiteLayout
  site="justonemoment"
  title={meta.title}
  description={meta.description}
  canonical="https://photonbuilder.com/justonemoment/hour-calculator"
  schema={combinedSchema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Hour Calculator & Timesheet Tracker</h1>
      <p class="subtitle">Calculate time duration, deduct breaks, and estimate gross pay instantly.</p>
    </div>

    <div class="calculator-container">
      <div class="input-grid">
        <div class="input-group">
          <label for="startTime">Start Time</label>
          <input type="time" id="startTime" value="09:00" />
        </div>
        <div class="input-group">
          <label for="endTime">End Time</label>
          <input type="time" id="endTime" value="17:00" />
        </div>
        <div class="input-group">
          <label for="breakMinutes">Unpaid Break (Minutes)</label>
          <input type="number" id="breakMinutes" min="0" placeholder="e.g., 30" value="30" />
        </div>
        <div class="input-group">
          <label for="hourlyWage">Hourly Wage ($)</label>
          <input type="number" id="hourlyWage" min="0" step="0.01" placeholder="e.g., 25.50" value="25.50" />
        </div>
      </div>
      <div id="errorMsg" class="error-msg-main"></div>

      <div class="results-grid">
        <div class="result-card">
          <div class="calc-result-label">Total Time</div>
          <div class="calc-result-value" id="totalTimeResult">7h 30m</div>
        </div>
        <div class="result-card">
          <div class="calc-result-label">Decimal Hours</div>
          <div class="calc-result-value" id="decimalHoursResult">7.50</div>
        </div>
        <div class="result-card">
          <div class="calc-result-label">Est. Gross Pay</div>
          <div class="calc-result-value" id="grossPayResult">$191.25</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>The Definitive Guide to Calculating Hours and Payroll</h2>

      <p>Whether you are a freelancer billing a client, an employee verifying a paycheck, or an employer managing a team, accurately calculating hours worked is a fundamental necessity. Our Hour Calculator streamlines this process, eliminating the tedious mental math required to convert between clock time, minutes, and payroll decimals.</p>

      <h3>The Challenge of Time Math</h3>
      <p>Time calculation is notoriously tricky because our clocks operate on a base-60 system (60 minutes in an hour) rather than a base-10 decimal system. When subtracting start times from end times, you cannot simply treat the numbers as standard integers. For instance, subtracting 8:45 from 10:15 does not equal 1.70; it requires borrowing hours and converting them into minutes.</p>

      <p>Furthermore, payroll systems generally require time to be submitted in a decimal format (base-10). If you work for 7 hours and 15 minutes, your payroll system needs this logged as 7.25 hours. If you submit it as 7.15, you will be underpaid.</p>

      <h3>How the Hour Calculator Works</h3>
      <p>Our tool simplifies timesheet math using standard chronological calculations:</p>
      <ol>
        <li><strong>Conversion to Military Time:</strong> First, the AM/PM inputs are standardized into a 24-hour format. This prevents calculation errors crossing the noon boundary.</li>
        <li><strong>Duration Calculation:</strong> The calculator determines the total elapsed time in minutes between your start and end times. If the end time is numerically earlier than the start time, the tool assumes you worked a night shift crossing midnight and adjusts the calculation accordingly (adding 24 hours to the end time).</li>
        <li><strong>Break Deductions:</strong> Any unpaid breaks (such as a 30-minute lunch) are subtracted from the total elapsed minutes.</li>
        <li><strong>Decimal Conversion:</strong> Finally, the remaining "Net Minutes" are divided by 60 to produce the standardized decimal hour format required for gross pay calculations.</li>
      </ol>

      <p>The mathematical formula for converting minutes to decimal hours is straightforward:</p>
      <div class="formula-box">
        <code>Decimal Hours = Minutes &divide; 60</code>
      </div>

      <h3>Common Minute-to-Decimal Conversions</h3>
      <p>To help you memorize standard conversions, here is a quick reference for common time increments:</p>
      <ul>
        <li><strong>15 Minutes:</strong> 0.25 Hours</li>
        <li><strong>30 Minutes:</strong> 0.50 Hours</li>
        <li><strong>45 Minutes:</strong> 0.75 Hours</li>
      </ul>
      <p>For more granular tracking, smaller increments translate as follows: 5 minutes is ~0.08 hours, 10 minutes is ~0.17 hours, and 20 minutes is ~0.33 hours.</p>

      <h3>Calculating Gross Pay</h3>
      <p>Once you have determined your true decimal hours worked, calculating your gross pay is a simple matter of multiplication. Gross pay is the amount earned before taxes, benefits, or other deductions are withheld.</p>

      <div class="formula-box">
        <code>Gross Pay = Decimal Hours Worked &times; Hourly Wage</code>
      </div>

      <p>For example, if you work 8 hours and 45 minutes (8.75 decimal hours) at a rate of $20 per hour, your gross pay is 8.75 &times; 20 = $175.00.</p>

      <h3>Night Shifts and Midnight Crossovers</h3>
      <p>A common pain point in manual time calculation is the "graveyard shift." If you start work at 10:00 PM (22:00) and finish at 6:00 AM (06:00), manual subtraction yields a negative number. Our calculator intelligently detects this crossover and automatically adjusts the math to properly calculate the 8-hour duration.</p>

      <p>By relying on automated, mathematically sound tools, you ensure accurate billing, precise payroll processing, and fair compensation for your valuable time.</p>

      <div class="related-tools">
        <h3>Related Tools</h3>
        <ul>
          <li><a href="/instagram-follower-tracker">Instagram Follower Tracker</a> - Measure the return on the time invested in your social media strategy.</li>
        </ul>
      </div>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How do you calculate total hours worked?</summary>
        <p>To calculate total hours worked, convert your start and end times to a 24-hour military format. Subtract the start time from the end time. If you took an unpaid break, subtract the break duration from the total time.</p>
      </details>
      <details>
        <summary>How do you convert minutes to decimals?</summary>
        <p>To convert minutes into a decimal format for payroll purposes, divide the number of minutes by 60. For example, 15 minutes is 15/60 = 0.25 hours; 30 minutes is 30/60 = 0.5 hours; and 45 minutes is 45/60 = 0.75 hours.</p>
      </details>
      <details>
        <summary>What is military time and why use it for payroll?</summary>
        <p>Military time is a 24-hour clock system (e.g., 1:00 PM is 13:00). It is used in payroll and time tracking because it eliminates the confusion between AM and PM, making mathematical calculations for hours worked straightforward and error-free.</p>
      </details>
      <details>
        <summary>How do I calculate gross pay from hours worked?</summary>
        <p>To calculate gross pay, multiply your total hours worked (in decimal format) by your hourly wage. For example, if you worked 8.5 hours at a rate of $20 per hour, your gross pay is 8.5 * 20 = $170.</p>
      </details>
      <details>
        <summary>Do employers have to pay for lunch breaks?</summary>
        <p>In most jurisdictions, employers are not legally required to pay for bona fide meal breaks (usually 30 minutes or more) if the employee is completely relieved from duty. However, shorter rest breaks (usually 5-20 minutes) are generally considered paid working time.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const startInput = document.getElementById('startTime');
      const endInput = document.getElementById('endTime');
      const breakInput = document.getElementById('breakMinutes');
      const wageInput = document.getElementById('hourlyWage');

      const timeResult = document.getElementById('totalTimeResult');
      const decimalResult = document.getElementById('decimalHoursResult');
      const payResult = document.getElementById('grossPayResult');
      const errorMsg = document.getElementById('errorMsg');

      function calculateTime() {
        errorMsg.textContent = '';

        if (!startInput.value || !endInput.value) {
          errorMsg.textContent = 'Please enter both a start time and an end time.';
          resetResults();
          return;
        }

        const [startH, startM] = startInput.value.split(':').map(Number);
        const [endH, endM] = endInput.value.split(':').map(Number);

        let startTotalMinutes = (startH * 60) + startM;
        let endTotalMinutes = (endH * 60) + endM;

        // Handle crossing midnight
        if (endTotalMinutes < startTotalMinutes) {
          endTotalMinutes += (24 * 60);
        }

        let diffMinutes = endTotalMinutes - startTotalMinutes;

        // Subtract break
        const breakMins = parseInt(breakInput.value) || 0;

        if (breakMins < 0) {
            errorMsg.textContent = 'Break minutes cannot be negative.';
            resetResults();
            return;
        }

        if (breakMins >= diffMinutes) {
            errorMsg.textContent = 'Break duration cannot be longer than or equal to the total hours worked.';
            resetResults();
            return;
        }

        diffMinutes -= breakMins;

        // Calculate hours and minutes string
        const finalHours = Math.floor(diffMinutes / 60);
        const finalMinutes = diffMinutes % 60;
        timeResult.textContent = `${finalHours}h ${finalMinutes}m`;

        // Calculate decimal
        const decimalHours = diffMinutes / 60;
        decimalResult.textContent = decimalHours.toFixed(2);

        // Calculate pay
        const wage = parseFloat(wageInput.value) || 0;
        if (wage < 0) {
            errorMsg.textContent = 'Wage cannot be negative.';
            payResult.textContent = '--';
        } else if (wage > 0) {
            const gross = decimalHours * wage;
            payResult.textContent = '$' + gross.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        } else {
            payResult.textContent = '$0.00';
        }
      }

      function resetResults() {
        timeResult.textContent = '--';
        decimalResult.textContent = '--';
        payResult.textContent = '--';
      }

      startInput.addEventListener('input', calculateTime);
      endInput.addEventListener('input', calculateTime);
      breakInput.addEventListener('input', calculateTime);
      wageInput.addEventListener('input', calculateTime);

      // Initial calculate
      calculateTime();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .input-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem; }
    .input-group label { display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-primary); }
    input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; font-family: monospace; }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .error-msg-main { color: #ef4444; font-size: 0.9rem; margin-bottom: 1.5rem; text-align: center; min-height: 1.5em; font-weight: 500; }

    .results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; text-align: center; }
    .calc-result-label { font-size: 0.9rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
    .calc-result-value { font-size: 2rem; font-weight: 800; color: var(--accent-color); }

    .explainer { margin-top: 3rem; line-height: 1.7; }
    .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; color: var(--text-primary); }
    .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 0.75rem; color: var(--text-primary); }
    .explainer p { margin-bottom: 1.25rem; color: var(--text-secondary); }
    .explainer ul, .explainer ol { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .formula-box { background: var(--bg-color); border: 1px solid var(--border-color); border-left: 4px solid var(--accent-color); padding: 1rem; border-radius: 8px; margin: 1.5rem 0; font-family: monospace; }

    .related-tools { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color); }
    .related-tools ul { list-style-type: none; padding: 0; }
    .related-tools li { margin-bottom: 0.5rem; }
    .related-tools a { color: var(--accent-color); text-decoration: none; font-weight: 500; }
    .related-tools a:hover { text-decoration: underline; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; color: var(--text-primary); }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); font-size: 1.1rem; list-style-position: inside; }
    .faq-section details p { margin: 1rem 0 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>