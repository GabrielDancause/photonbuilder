---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: 'Mileage Calculator | Justonemoment',
  description: 'Calculate driving distance, estimated travel time, fuel costs, and IRS mileage deduction rates between top US cities with our free mileage calculator.',
  category: 'tool',
  keywords: ['mileage calculator', 'driving distance calculator', 'travel time calculator', 'gas cost calculator', 'IRS mileage deduction', 'city to city distance']
};

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "justonemoment.photonbuilder.com" },
    "publisher": { "@type": "Organization", "name": "justonemoment.photonbuilder.com" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is the IRS mileage deduction calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The IRS sets a standard mileage rate each year. To calculate your deduction, simply multiply your business miles driven by the current IRS rate (e.g., 67 cents per mile for 2024). Keep a detailed log of your trips for tax purposes."
        }
      },
      {
        "@type": "Question",
        "name": "How do you estimate fuel costs for a road trip?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To estimate fuel costs, divide your total trip distance by your vehicle's average MPG (miles per gallon) to get the gallons needed. Then, multiply the gallons needed by the average price per gallon of gas."
        }
      },
      {
        "@type": "Question",
        "name": "What factors affect driving travel time?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Driving travel time is primarily affected by the total distance, average speed limits, traffic congestion, weather conditions, and the number of stops for rest, fuel, or food."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use this mileage calculator for business expenses?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! Our calculator includes an IRS mileage deduction feature. By entering your total miles and the current standard rate, you can quickly estimate your potential tax deduction for business travel."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate are city-to-city distance calculators?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "City-to-city distance calculators provide highly accurate estimates based on standard highway routing between city centers. However, exact door-to-door distances will vary depending on your specific starting address and destination."
        }
      }
    ]
  }
]);
---

<SiteLayout site="justonemoment" title={meta.title} description={meta.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>

  <div class="page-container">
    <section class="hero-section">
      <div class="hero-content">
        <h1 class="hero-title">Mileage Calculator</h1>
        <p class="hero-subtitle">Plan your road trip, estimate fuel costs, and calculate IRS tax deductions instantly.</p>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">50+</span>
            <span class="stat-label">Cities</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100%</span>
            <span class="stat-label">Free</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">Instant</span>
            <span class="stat-label">Results</span>
          </div>
        </div>
        <button class="cta-button" onclick="document.getElementById('calculator').scrollIntoView({behavior: 'smooth'})">Calculate Now</button>
      </div>
    </section>

    <main class="main-content">
      <section id="calculator" class="calculator-section">
        <div class="calculator-card">
          <div class="calc-grid">

            <div class="input-group">
              <label for="origin" class="input-label">Origin City</label>
              <select id="origin" class="input-field">
                <option value="">Select Origin...</option>
                <!-- JS will populate -->
              </select>
            </div>

            <div class="input-group">
              <label for="destination" class="input-label">Destination City</label>
              <select id="destination" class="input-field">
                <option value="">Select Destination...</option>
                <!-- JS will populate -->
              </select>
            </div>

            <div class="input-group">
              <label for="mpg" class="input-label">Vehicle MPG</label>
              <input type="number" id="mpg" class="input-field" value="25" min="1" step="0.1">
            </div>

            <div class="input-group">
              <label for="gasPrice" class="input-label">Gas Price ($/gal)</label>
              <input type="number" id="gasPrice" class="input-field" value="3.50" min="0.01" step="0.01">
            </div>

             <div class="input-group">
              <label for="irsRate" class="input-label">IRS Rate ($/mile)</label>
              <input type="number" id="irsRate" class="input-field" value="0.67" min="0.01" step="0.01">
              <span class="help-text">2024 Standard Rate: $0.67</span>
            </div>

            <div class="input-group">
               <label for="avgSpeed" class="input-label">Avg Speed (mph)</label>
               <input type="number" id="avgSpeed" class="input-field" value="65" min="10" max="100">
            </div>

          </div>

          <div id="error-msg" class="error-message" style="display: none;"></div>

          <button id="calculate-btn" class="calculate-btn">Calculate Route</button>

          <div id="results" class="results-container" style="display: none;">
            <h3 class="results-title">Trip Summary</h3>

            <div class="results-grid">
              <div class="result-card primary-result">
                <div class="result-label">Distance</div>
                <div class="result-value"><span id="res-distance">0</span> <span class="unit">miles</span></div>
              </div>

              <div class="result-card">
                <div class="result-label">Est. Time</div>
                <div class="result-value" id="res-time">0h 0m</div>
              </div>

              <div class="result-card">
                <div class="result-label">Fuel Cost</div>
                <div class="result-value">$<span id="res-fuel">0.00</span></div>
              </div>

              <div class="result-card highlight-result">
                <div class="result-label">IRS Deduction</div>
                <div class="result-value">$<span id="res-irs">0.00</span></div>
              </div>
            </div>

            <div class="chart-container">
               <h4 class="chart-title">Cost Breakdown Estimate</h4>
               <div class="bar-chart">
                  <div class="bar-group">
                     <div class="bar fuel-bar" id="bar-fuel" style="height: 0%;"></div>
                     <span class="bar-label">Fuel</span>
                  </div>
                  <div class="bar-group">
                     <div class="bar irs-bar" id="bar-irs" style="height: 0%;"></div>
                     <span class="bar-label">IRS Ded.</span>
                  </div>
               </div>
               <p class="chart-note">Note: IRS deduction is intended to cover fuel, maintenance, depreciation, and insurance.</p>
            </div>

          </div>
        </div>
      </section>

      <section class="educational-section">
        <h2>Understanding Mileage & Trip Costs</h2>

        <div class="edu-grid">
          <div class="edu-card">
            <h3>How Fuel Costs Are Calculated</h3>
            <p>Estimating your fuel cost involves straightforward math but is highly dependent on your vehicle's efficiency. The formula used is:</p>
            <div class="formula-box">
              <code>(Distance / MPG) × Price per Gallon</code>
            </div>
            <p>For example, driving 300 miles in a car that gets 25 MPG means you'll need 12 gallons of gas. At $3.50 per gallon, your estimated fuel cost is $42.00.</p>
          </div>

          <div class="edu-card">
            <h3>The IRS Standard Mileage Rate</h3>
            <p>If you use your personal vehicle for business, charity, medical, or moving purposes, you may be eligible for a tax deduction. The IRS sets a standard mileage rate annually.</p>
            <p>This rate (e.g., 67 cents/mile in 2024 for business) is designed to cover not just gas, but wear and tear, maintenance, insurance, and depreciation. Keep a mileage log to support your claims!</p>
          </div>

          <div class="edu-card">
            <h3>Estimating Travel Time</h3>
            <p>Our calculator estimates travel time based on the distance and your input average speed (default 65 mph). It does not account for traffic, weather, or necessary stops.</p>
            <p><strong>Pro Tip:</strong> For trips over 4 hours, experts recommend adding 15-20% to your estimated driving time to account for rest breaks and refueling.</p>
          </div>

           <div class="edu-card">
            <h3>Route Optimization</h3>
            <p>While this tool provides city-to-city straight-line or standard highway approximations, actual driving distance varies. Planning your route to avoid major city centers during rush hour can significantly improve your MPG and reduce travel time.</p>
          </div>
        </div>
      </section>

      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>How is the IRS mileage deduction calculated?</summary>
            <div class="faq-answer">
              <p>The IRS sets a standard mileage rate each year. To calculate your deduction, simply multiply your business miles driven by the current IRS rate (e.g., 67 cents per mile for 2024). Keep a detailed log of your trips for tax purposes.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>How do you estimate fuel costs for a road trip?</summary>
            <div class="faq-answer">
              <p>To estimate fuel costs, divide your total trip distance by your vehicle's average MPG (miles per gallon) to get the gallons needed. Then, multiply the gallons needed by the average price per gallon of gas.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>What factors affect driving travel time?</summary>
            <div class="faq-answer">
              <p>Driving travel time is primarily affected by the total distance, average speed limits, traffic congestion, weather conditions, and the number of stops for rest, fuel, or food.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>Can I use this mileage calculator for business expenses?</summary>
            <div class="faq-answer">
              <p>Yes! Our calculator includes an IRS mileage deduction feature. By entering your total miles and the current standard rate, you can quickly estimate your potential tax deduction for business travel.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary>How accurate are city-to-city distance calculators?</summary>
            <div class="faq-answer">
              <p>City-to-city distance calculators provide highly accurate estimates based on standard highway routing between city centers. However, exact door-to-door distances will vary depending on your specific starting address and destination.</p>
            </div>
          </details>
        </div>
      </section>

      <section class="related-tools">
        <h2>Related Calculators</h2>
        <div class="related-links">
          <a href="/time-calculator" class="related-link">Time Calculator</a>
          <a href="/age-calculator" class="related-link">Age Calculator</a>
          <a href="/work-hours-calculator" class="related-link">Work Hours Calculator</a>
        </div>
      </section>

    </main>
  </div>
</SiteLayout>

<style is:inline>
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
    font-family: system-ui, -apple-system, sans-serif;
    color: var(--text-primary, #333);
  }

  /* Hero Section */
  .hero-section {
    text-align: center;
    padding: 4rem 1rem;
    background: var(--card-bg, #fff);
    border-radius: 16px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    margin-bottom: 3rem;
    border: 1px solid var(--border-color, #eee);
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--accent-color, #2563eb);
    line-height: 1.2;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary, #666);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary, #333);
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-secondary, #666);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cta-button {
    background: var(--accent-color, #2563eb);
    color: white;
    border: none;
    padding: 1rem 2.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    border-radius: 9999px;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  /* Calculator Section */
  .calculator-card {
    background: var(--card-bg, #fff);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    border: 1px solid var(--border-color, #eee);
    margin-bottom: 4rem;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary, #333);
  }

  .input-field {
    padding: 0.875rem;
    border: 1px solid var(--border-color, #ccc);
    border-radius: 8px;
    font-size: 1rem;
    background: var(--bg-primary, #fafafa);
    color: var(--text-primary, #333);
    transition: border-color 0.2s;
  }

  .input-field:focus {
    outline: none;
    border-color: var(--accent-color, #2563eb);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .help-text {
    font-size: 0.75rem;
    color: var(--text-secondary, #666);
  }

  .error-message {
    background: #fee2e2;
    color: #991b1b;
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .calculate-btn {
    width: 100%;
    background: var(--accent-color, #2563eb);
    color: white;
    border: none;
    padding: 1.25rem;
    font-size: 1.25rem;
    font-weight: 700;
    border-radius: 12px;
    cursor: pointer;
    transition: opacity 0.2s;
    margin-bottom: 2rem;
  }

  .calculate-btn:hover {
    opacity: 0.9;
  }

  /* Results */
  .results-container {
    border-top: 2px dashed var(--border-color, #eee);
    padding-top: 2rem;
  }

  .results-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .result-card {
    background: var(--bg-primary, #fafafa);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--border-color, #eee);
    text-align: center;
  }

  .primary-result {
    background: rgba(37, 99, 235, 0.05);
    border-color: var(--accent-color, #2563eb);
  }

  .highlight-result {
    background: rgba(16, 185, 129, 0.05);
    border-color: #10b981;
  }

  .result-label {
    font-size: 0.875rem;
    color: var(--text-secondary, #666);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .result-value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-primary, #333);
  }

  .primary-result .result-value {
    color: var(--accent-color, #2563eb);
  }

  .highlight-result .result-value {
    color: #059669;
  }

  .unit {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary, #666);
  }

  /* Chart */
  .chart-container {
    background: var(--bg-primary, #fafafa);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--border-color, #eee);
  }

  .chart-title {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 1.25rem;
  }

  .bar-chart {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    height: 200px;
    gap: 4rem;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border-color, #ddd);
  }

  .bar-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 60px;
    height: 100%;
    justify-content: flex-end;
  }

  .bar {
    width: 100%;
    border-radius: 6px 6px 0 0;
    transition: height 1s ease-out;
    position: relative;
  }

  .bar::after {
    content: attr(data-val);
    position: absolute;
    top: -25px;
    left: 50%;
    transform: translateX(-50%);
    font-weight: bold;
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  .fuel-bar {
    background: #f59e0b;
  }

  .irs-bar {
    background: #10b981;
  }

  .bar-label {
    margin-top: 0.75rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .chart-note {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-align: center;
    font-style: italic;
  }

  /* Educational Section */
  .educational-section {
    margin-bottom: 4rem;
  }

  .educational-section h2, .faq-section h2, .related-tools h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .edu-card {
    background: var(--card-bg, #fff);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--border-color, #eee);
    box-shadow: 0 4px 6px rgba(0,0,0,0.02);
  }

  .edu-card h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: var(--accent-color, #2563eb);
  }

  .edu-card p {
    line-height: 1.6;
    color: var(--text-secondary, #444);
    margin-bottom: 1rem;
  }

  .formula-box {
    background: var(--bg-primary, #f1f5f9);
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    margin: 1.5rem 0;
    font-family: monospace;
    font-size: 1.1rem;
    color: var(--accent-color, #2563eb);
    border: 1px dashed var(--border-color, #cbd5e1);
  }

  /* FAQ Section */
  .faq-section {
    margin-bottom: 4rem;
  }

  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: var(--card-bg, #fff);
    border: 1px solid var(--border-color, #eee);
    border-radius: 8px;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1.5rem;
    font-weight: 600;
    font-size: 1.1rem;
    cursor: pointer;
    list-style: none;
    position: relative;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: var(--accent-color, #2563eb);
  }

  .faq-item[open] summary::after {
    content: '-';
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem;
    line-height: 1.6;
    color: var(--text-secondary, #444);
  }

  /* Related Tools */
  .related-tools {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color, #eee);
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .related-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--bg-primary, #fafafa);
    color: var(--accent-color, #2563eb);
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 500;
    border: 1px solid var(--border-color, #eee);
    transition: all 0.2s;
  }

  .related-link:hover {
    background: var(--accent-color, #2563eb);
    color: white;
    border-color: var(--accent-color, #2563eb);
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.25rem; }
    .hero-stats { gap: 1.5rem; flex-wrap: wrap; }
    .calc-grid { grid-template-columns: 1fr; }
    .bar-chart { gap: 2rem; }
  }
</style>

