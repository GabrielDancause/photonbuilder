    "Kansas City, MO": [39.0997, -94.5786],
    "Colorado Springs, CO": [38.8339, -104.8214],
    "Miami, FL": [25.7617, -80.1918],
    "Raleigh, NC": [35.7796, -78.6382],
    "Omaha, NE": [41.2565, -95.9345],
    "Long Beach, CA": [33.7701, -118.1937],
    "Virginia Beach, VA": [36.8529, -75.9780],
    "Oakland, CA": [37.8044, -122.2712],
    "Minneapolis, MN": [44.9778, -93.2650],
    "Tulsa, OK": [36.1540, -95.9928],
    "Arlington, TX": [32.7357, -97.1081],
    "Tampa, FL": [27.9506, -82.4572],
    "New Orleans, LA": [29.9511, -90.0715]
  };

  // Populate dropdowns
  document.addEventListener('DOMContentLoaded', () => {
    const originSelect = document.getElementById('origin');
    const destSelect = document.getElementById('destination');

    const sortedCities = Object.keys(cities).sort();

    sortedCities.forEach(city => {
      originSelect.add(new Option(city, city));
      destSelect.add(new Option(city, city));
    });

    // Set some defaults
    originSelect.value = "New York, NY";
    destSelect.value = "Los Angeles, CA";
  });

  // Haversine formula to calculate straight-line distance
  // Multiplying by 1.2 to approximate driving distance (road winding factor)
  function calculateDistance(lat1, lon1, lat2, lon2) {
    const R = 3958.8; // Radius of Earth in miles
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a =
      Math.sin(dLat/2) * Math.sin(dLat/2) +
      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
      Math.sin(dLon/2) * Math.sin(dLon/2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    const straightLine = R * c;
    return straightLine * 1.2; // 20% markup for road distance approximation
  }

  function formatTime(hoursFloat) {
    const hours = Math.floor(hoursFloat);
    const minutes = Math.round((hoursFloat - hours) * 60);
    return `${hours}h ${minutes}m`;
  }

  document.getElementById('calculate-btn').addEventListener('click', () => {
    const origin = document.getElementById('origin').value;
    const dest = document.getElementById('destination').value;
    const mpg = parseFloat(document.getElementById('mpg').value);
    const gasPrice = parseFloat(document.getElementById('gasPrice').value);
    const irsRate = parseFloat(document.getElementById('irsRate').value);
    const avgSpeed = parseFloat(document.getElementById('avgSpeed').value);

    const errorMsg = document.getElementById('error-msg');
    const resultsContainer = document.getElementById('results');

    // Validation
    if (!origin || !dest) {
      errorMsg.textContent = "Please select both origin and destination cities.";
      errorMsg.style.display = 'block';
      resultsContainer.style.display = 'none';
      return;
    }

    if (origin === dest) {
      errorMsg.textContent = "Origin and destination cannot be the same city.";
      errorMsg.style.display = 'block';
      resultsContainer.style.display = 'none';
      return;
    }

    if (isNaN(mpg) || mpg <= 0 || isNaN(gasPrice) || gasPrice <= 0 || isNaN(irsRate) || irsRate <= 0 || isNaN(avgSpeed) || avgSpeed <= 0) {
      errorMsg.textContent = "Please enter valid numbers for MPG, Gas Price, IRS Rate, and Speed.";
      errorMsg.style.display = 'block';
      resultsContainer.style.display = 'none';
      return;
    }

    errorMsg.style.display = 'none';

    // Calculations
    const [lat1, lon1] = cities[origin];
    const [lat2, lon2] = cities[dest];

    const distance = Math.round(calculateDistance(lat1, lon1, lat2, lon2));
    const timeHours = distance / avgSpeed;
    const gallonsNeeded = distance / mpg;
    const fuelCost = gallonsNeeded * gasPrice;
    const irsDeduction = distance * irsRate;

    // Update DOM
    document.getElementById('res-distance').textContent = distance.toLocaleString();
    document.getElementById('res-time').textContent = formatTime(timeHours);
    document.getElementById('res-fuel').textContent = fuelCost.toFixed(2);
    document.getElementById('res-irs').textContent = irsDeduction.toFixed(2);

    // Update Chart
    // Find the max value to scale the chart
    const maxVal = Math.max(fuelCost, irsDeduction, 1); // Ensure no div by zero

    const fuelHeight = (fuelCost / maxVal) * 100;
    const irsHeight = (irsDeduction / maxVal) * 100;

    const fuelBar = document.getElementById('bar-fuel');
    const irsBar = document.getElementById('bar-irs');

    // Small timeout to allow CSS transition to work when display changes
    resultsContainer.style.display = 'block';

    setTimeout(() => {
      fuelBar.style.height = `${Math.max(fuelHeight, 5)}%`; // min 5% for visibility
      fuelBar.setAttribute('data-val', `$${Math.round(fuelCost)}`);

      irsBar.style.height = `${Math.max(irsHeight, 5)}%`;
      irsBar.setAttribute('data-val', `$${Math.round(irsDeduction)}`);
    }, 50);

    // Scroll to results
    setTimeout(() => {
      resultsContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 100);
  });
</script>
