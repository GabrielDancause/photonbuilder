  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const startTimeInput = document.getElementById('startTime');
      const endTimeInput = document.getElementById('endTime');
      const breakMinsInput = document.getElementById('breakMins');
      const hourlyRateInput = document.getElementById('hourlyRate');
      const calcBtn = document.getElementById('calcBtn');
      const errorMsg = document.getElementById('errorMsg');

      const resHours = document.getElementById('resHours');
      const resHoursText = document.getElementById('resHoursText');
      const resPay = document.getElementById('resPay');

      const visStart = document.getElementById('visStart');
      const visEnd = document.getElementById('visEnd');
      const visWork1 = document.getElementById('visWork1');
      const visBreak = document.getElementById('visBreak');
      const visWork2 = document.getElementById('visWork2');

      function parseTime(timeStr) {
        if (!timeStr) return 0;
        const parts = timeStr.split(':');
        return parseInt(parts[0]) * 60 + parseInt(parts[1]);
      }

      function formatTimeAmPm(timeStr) {
        if (!timeStr) return '';
        const parts = timeStr.split(':');
        let h = parseInt(parts[0]);
        let m = parts[1];
        let ampm = h >= 12 ? 'PM' : 'AM';
        h = h % 12;
        if (h === 0) h = 12;
        return `${h}:${m} ${ampm}`;
      }

      function calculate() {
        errorMsg.style.display = 'none';

        let startMins = parseTime(startTimeInput.value);
        let endMins = parseTime(endTimeInput.value);
        let breakMins = parseInt(breakMinsInput.value) || 0;
        let rate = parseFloat(hourlyRateInput.value) || 0;

        if (endMins < startMins) {
          endMins += 24 * 60; // Crosses midnight
        }

        let grossDuration = endMins - startMins;
        let netDuration = grossDuration - breakMins;

        if (netDuration < 0) {
          errorMsg.textContent = "Error: Break duration is longer than the shift duration.";
          errorMsg.style.display = "block";
          resHours.textContent = "0.00";
          resHoursText.textContent = "0 hours, 0 minutes";
          resPay.textContent = "$0.00";
          return;
        }

        let decimalHours = netDuration / 60;
        let hoursWhole = Math.floor(netDuration / 60);
        let minsRemainder = netDuration % 60;

        resHours.textContent = decimalHours.toFixed(2);
        resHoursText.textContent = `${hoursWhole} hours, ${minsRemainder} minutes`;

        let pay = decimalHours * rate;
        resPay.textContent = `$${pay.toFixed(2)}`;

        // Update visualization
        visStart.textContent = formatTimeAmPm(startTimeInput.value);
        visEnd.textContent = formatTimeAmPm(endTimeInput.value);

        if (grossDuration > 0) {
           let breakPercent = (breakMins / grossDuration) * 100;
           let workPercent = ((grossDuration - breakMins) / grossDuration) * 100;

           if (breakPercent > 0) {
             visWork1.style.width = `${workPercent / 2}%`;
             visBreak.style.width = `${breakPercent}%`;
             visWork2.style.width = `${workPercent / 2}%`;
           } else {
             visWork1.style.width = '100%';
             visBreak.style.width = '0%';
             visWork2.style.width = '0%';
           }
        }
      }

      calcBtn.addEventListener('click', calculate);
      startTimeInput.addEventListener('change', calculate);
      endTimeInput.addEventListener('change', calculate);
      breakMinsInput.addEventListener('change', calculate);
      hourlyRateInput.addEventListener('input', calculate);

      calculate(); // Initial calc
    });
  </script>

