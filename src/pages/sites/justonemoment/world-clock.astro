---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "World Clock Dashboard - Live Time Zones & Meeting Planner",
  description: "View current time across 100+ cities worldwide with analog clocks, day/night indicators, DST status, and a meeting planner to find overlapping business hours.",
  category: "tool",
  published: "2025-06-10",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "World Clock Dashboard",
    "description": meta.description,
    "url": "https://justonemoment.photonbuilder.com/world-clock",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "JustOneMoment"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does the World Clock Dashboard update the time?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The dashboard updates every second using your device's system clock and the JavaScript Intl.DateTimeFormat API, which accurately converts your local time into each city's timezone. No internet connection is needed after the page loads."
        }
      },
      {
        "@type": "Question",
        "name": "Does the world clock account for Daylight Saving Time?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The dashboard uses IANA timezone identifiers (like America/New_York) which automatically handle DST transitions. A DST indicator badge appears next to cities currently observing daylight saving time."
        }
      },
      {
        "@type": "Question",
        "name": "How does the meeting planner find overlapping business hours?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The meeting planner compares standard business hours (9 AM to 5 PM) across all selected cities. It highlights the hours where every selected city falls within that 9-to-5 window, making it easy to schedule calls across time zones."
        }
      },
      {
        "@type": "Question",
        "name": "Can I save my favorite cities?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Click the star icon on any city clock to add it to your favorites. Your selections are saved to your browser's localStorage so they persist between visits. You can also use preset groups like US Offices, European Offices, or Asian Offices for quick setup."
        }
      },
      {
        "@type": "Question",
        "name": "What do the day and night indicators mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The sun icon indicates daytime (6 AM to 6 PM local time) and the moon icon indicates nighttime (6 PM to 6 AM local time) in that city. The clock card background also subtly shifts to reflect day or night conditions."
        }
      }
    ]
  }
];
---

<SiteLayout site="justonemoment" title={meta.title} description={meta.description} canonical="https://justonemoment.photonbuilder.com/world-clock" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>World Clock Dashboard</h1>
      <p class="subtitle">Live time across every timezone. Plan meetings, track teams, and never miss a beat.</p>
    </div>

    <section class="controls-bar">
      <div class="search-wrap">
        <input type="text" id="citySearch" placeholder="Search 100+ cities..." autocomplete="off" />
        <div id="searchResults" class="search-results"></div>
      </div>
      <div class="preset-buttons">
        <button class="preset-btn" data-preset="us">US Offices</button>
        <button class="preset-btn" data-preset="eu">European Offices</button>
        <button class="preset-btn" data-preset="asia">Asian Offices</button>
        <button class="preset-btn preset-fav" id="loadFavBtn">★ Favorites</button>
      </div>
    </section>

    <section id="clockGrid" class="clock-grid"></section>

    <section class="meeting-section">
      <h2>Meeting Planner</h2>
      <p class="section-desc">Find overlapping business hours (9 AM – 5 PM) for all displayed cities.</p>
      <div id="meetingPlanner" class="meeting-planner"></div>
      <div id="meetingResult" class="meeting-result"></div>
    </section>

    <section class="content-body">
      <h2>How to Use the World Clock</h2>
      <p>Search for any city from our database of 100+ locations, or use the preset buttons to quickly load common office groups. Each clock card shows an analog clock face with smoothly rotating hands, the digital time, day/night status, DST indicator, and the time difference from your local timezone.</p>
      <p>Click the <strong>★</strong> icon on any clock to save it to your favorites. Your favorites are stored locally in your browser and will appear the next time you visit.</p>

      <h2>Meeting Planner Tips</h2>
      <div class="callout">
        <strong>The Golden Window</strong>
        <p>When scheduling across more than 3 time zones, the overlapping window shrinks fast. For US + Europe calls, aim for 9–11 AM Eastern. For Europe + Asia, try 8–10 AM Central European Time.</p>
      </div>
      <ul>
        <li><strong>Add cities first:</strong> The meeting planner analyzes whichever cities are currently displayed on the dashboard.</li>
        <li><strong>Green blocks</strong> indicate hours where all cities are within 9 AM – 5 PM business hours.</li>
        <li><strong>Hover any block</strong> to see the local time in each city for that hour.</li>
      </ul>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {schema[1].mainEntity.map((faq) => (
        <details>
          <summary>{faq.name}</summary>
          <p>{faq.acceptedAnswer.text}</p>
        </details>
      ))}
    </section>

    <section class="related-timers">
      <h2>Related Tools</h2>
      <div class="related-grid">
        <a href="/sites/justonemoment/pomodoro-timer" class="related-link">Free Online Pomodoro Timer</a>
        <a href="/sites/justonemoment/best-timer-apps" class="related-link">Best Timer Apps Guide</a>
      </div>
    </section>
  </div>

  <style is:inline>
    :root {
      --clock-size: 120px;
      --hand-color: var(--text-primary, #1a202c);
      --clock-border: var(--border-color, #e2e8f0);
      --clock-face: var(--card-bg, #ffffff);
      --night-bg: color-mix(in srgb, var(--card-bg, #f8fafc) 85%, #1a1a3e);
      --day-bg: var(--card-bg, #ffffff);
      --accent: #e74c3c;
      --green: #27ae60;
      --meeting-overlap: #27ae60;
      --meeting-empty: color-mix(in srgb, var(--border-color, #e2e8f0) 60%, transparent);
    }

    .page-content { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; line-height: 1.6; }
    .hero { text-align: center; padding: 3rem 0 1.5rem; }
    .hero h1 { font-size: 2.4rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    /* Controls */
    .controls-bar { display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-start; margin-bottom: 2rem; }
    .search-wrap { position: relative; flex: 1; min-width: 250px; }
    .search-wrap input {
      width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border-color); border-radius: 8px;
      font-size: 1rem; background: var(--card-bg); color: var(--text-primary); outline: none;
      box-sizing: border-box;
    }
    .search-wrap input:focus { border-color: var(--accent); }
    .search-results {
      position: absolute; top: 100%; left: 0; right: 0; background: var(--card-bg);
      border: 1px solid var(--border-color); border-radius: 0 0 8px 8px; max-height: 260px;
      overflow-y: auto; z-index: 100; display: none;
    }
    .search-results.active { display: block; }
    .search-item {
      padding: 0.6rem 1rem; cursor: pointer; font-size: 0.9rem; color: var(--text-primary);
      display: flex; justify-content: space-between;
    }
    .search-item:hover { background: color-mix(in srgb, var(--accent) 10%, transparent); }
    .search-item .tz-label { color: var(--text-secondary); font-size: 0.8rem; }

    .preset-buttons { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .preset-btn {
      padding: 0.5rem 1rem; border: 1px solid var(--border-color); border-radius: 8px;
      background: var(--card-bg); color: var(--text-primary); cursor: pointer; font-size: 0.85rem;
      transition: border-color 0.2s, background 0.2s;
    }
    .preset-btn:hover { border-color: var(--accent); }
    .preset-btn.active { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); }
    .preset-fav { color: #f39c12; font-weight: 600; }

    /* Clock Grid */
    .clock-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.25rem; min-height: 100px; }

    .clock-card {
      background: var(--day-bg); border: 1px solid var(--clock-border); border-radius: 12px;
      padding: 1.25rem; text-align: center; position: relative; transition: background 0.3s;
    }
    .clock-card.night { background: var(--night-bg); }
    .clock-card .fav-btn {
      position: absolute; top: 0.5rem; right: 0.5rem; background: none; border: none;
      font-size: 1.2rem; cursor: pointer; color: var(--border-color); transition: color 0.2s;
      line-height: 1;
    }
    .clock-card .fav-btn.favorited { color: #f39c12; }
    .clock-card .remove-btn {
      position: absolute; top: 0.5rem; left: 0.5rem; background: none; border: none;
      font-size: 1rem; cursor: pointer; color: var(--text-secondary); opacity: 0.4; transition: opacity 0.2s;
      line-height: 1;
    }
    .clock-card .remove-btn:hover { opacity: 1; }

    .city-name { font-weight: 700; font-size: 1rem; margin-bottom: 0.15rem; color: var(--text-primary); }
    .country-label { font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.75rem; }

    /* Analog Clock */
    .analog-clock {
      width: var(--clock-size); height: var(--clock-size); border-radius: 50%;
      border: 2px solid var(--clock-border); margin: 0 auto 0.75rem; position: relative;
      background: var(--clock-face);
    }
    .analog-clock .marker {
      position: absolute; width: 2px; height: 6px; background: var(--text-secondary);
      top: 4px; left: 50%; transform-origin: center calc(var(--clock-size) / 2 - 4px);
    }
    .analog-clock .hand {
      position: absolute; bottom: 50%; left: 50%; transform-origin: bottom center; border-radius: 2px;
    }
    .analog-clock .hour-hand { width: 3px; height: 28px; background: var(--hand-color); margin-left: -1.5px; }
    .analog-clock .minute-hand { width: 2px; height: 38px; background: var(--hand-color); margin-left: -1px; }
    .analog-clock .second-hand { width: 1px; height: 42px; background: var(--accent); margin-left: -0.5px; }
    .analog-clock .center-dot {
      position: absolute; width: 6px; height: 6px; background: var(--accent); border-radius: 50%;
      top: 50%; left: 50%; transform: translate(-50%, -50%);
    }

    .digital-time { font-size: 1.4rem; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--text-primary); }
    .date-line { font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.15rem; }
    .badge-row { display: flex; justify-content: center; gap: 0.4rem; margin-top: 0.5rem; flex-wrap: wrap; }
    .badge {
      font-size: 0.7rem; padding: 0.15rem 0.45rem; border-radius: 4px;
      background: color-mix(in srgb, var(--border-color) 50%, transparent); color: var(--text-secondary);
    }
    .badge.day-badge { background: color-mix(in srgb, #f39c12 15%, transparent); color: #d68910; }
    .badge.night-badge { background: color-mix(in srgb, #5b6abf 15%, transparent); color: #5b6abf; }
    .badge.dst-badge { background: color-mix(in srgb, var(--green) 15%, transparent); color: var(--green); }
    .diff-label { font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.35rem; }

    /* Meeting Planner */
    .meeting-section { margin-top: 3rem; }
    .meeting-section h2 { margin-bottom: 0.5rem; }
    .section-desc { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 1.25rem; }
    .meeting-planner { overflow-x: auto; margin-bottom: 1rem; }
    .meeting-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; min-width: 700px; }
    .meeting-table th, .meeting-table td {
      padding: 0.4rem 0.25rem; text-align: center; border: 1px solid var(--border-color); color: var(--text-primary);
    }
    .meeting-table th { background: var(--card-bg); font-weight: 600; white-space: nowrap; font-size: 0.75rem; }
    .meeting-table td.overlap { background: color-mix(in srgb, var(--meeting-overlap) 20%, transparent); }
    .meeting-table td.no-overlap { background: var(--meeting-empty); color: var(--text-secondary); }
    .meeting-table td.overlap:hover { background: color-mix(in srgb, var(--meeting-overlap) 35%, transparent); }
    .meeting-result { font-size: 0.9rem; color: var(--text-secondary); }
    .meeting-result strong { color: var(--text-primary); }
    .no-clocks-msg { text-align: center; color: var(--text-secondary); padding: 2rem; font-size: 0.95rem; }

    /* Content */
    .content-body { margin-top: 2rem; }
    .content-body h2 { margin-top: 2.5rem; margin-bottom: 1rem; color: var(--text-primary); }
    .content-body p { margin-bottom: 1.25rem; color: var(--text-secondary); }
    .content-body ul { margin-bottom: 1.25rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .content-body li { margin-bottom: 0.5rem; }
    .callout { background: color-mix(in srgb, #e74c3c 10%, transparent); border-left: 4px solid #e74c3c; padding: 1rem 1.5rem; border-radius: 0 8px 8px 0; margin: 1.5rem 0; }

    /* FAQ */
    .faq-section { margin-top: 3rem; }
    .faq-section h2 { margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); outline: none; }
    .faq-section p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); }

    /* Related */
    .related-timers { margin-top: 3rem; }
    .related-timers h2 { margin-bottom: 1rem; }
    .related-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; }
    .related-link {
      padding: 0.5rem 1rem; background: var(--card-bg); border: 1px solid var(--border-color);
      border-radius: 8px; color: var(--text-primary); text-decoration: none; font-size: 0.9rem;
      transition: border-color 0.2s;
    }
    .related-link:hover { border-color: var(--accent); text-decoration: none; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    @media (max-width: 768px) {
      .controls-bar { flex-direction: column; }
      .clock-grid { grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); }
      .hero h1 { font-size: 1.8rem; }
    }
  </style>

