<script is:inline>
class PremiumTimer {
  constructor() {
    this.duration = 20 * 60 * 1000; // 20 minutes in ms
    this.timeLeft = this.duration;
    this.isRunning = false;
    this.startTime = 0;
    this.animationFrame = null;
    this.isFullscreen = false;
    
    this.timerText = document.getElementById('timer-text');
    this.startBtn = document.getElementById('start-btn');
    this.resetBtn = document.getElementById('reset-btn');
    this.fullscreenBtn = document.getElementById('fullscreen-btn');
    this.progressBar = document.querySelector('.progress-ring-bar');
    this.progressCircumference = 754; // 2 * π * 120
    
    this.setupEventListeners();
    this.updateDisplay();
    this.updateProgressRing();
    this.requestNotificationPermission();
  }

  setupEventListeners() {
    // Button clicks
    this.startBtn.addEventListener('click', () => this.toggle());
    this.resetBtn.addEventListener('click', () => this.reset());
    this.fullscreenBtn.addEventListener('click', () => this.toggleFullscreen());
    
    // Preset buttons
    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        if (this.isRunning) return;
        
        document.querySelector('.preset-btn.active').classList.remove('active');
        e.target.classList.add('active');
        
        const minutes = parseInt(e.target.dataset.minutes);
        this.duration = minutes * 60 * 1000;
        this.timeLeft = this.duration;
        this.updateDisplay();
        this.updateProgressRing();
      });
    });
    
    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      if (e.code === 'Space') {
        e.preventDefault();
        this.toggle();
      } else if (e.code === 'KeyR') {
        e.preventDefault();
        this.reset();
      } else if (e.code === 'KeyF') {
        e.preventDefault();
        this.toggleFullscreen();
      }
    });
    
    // Page visibility change
    document.addEventListener('visibilitychange', () => {
      if (this.isRunning) {
        this.tick(); // Update immediately when tab becomes visible
      }
    });
  }

  toggle() {
    if (this.isRunning) {
      this.pause();
    } else {
      this.start();
    }
  }

  start() {
    this.isRunning = true;
    this.startTime = Date.now() - (this.duration - this.timeLeft);
    this.startBtn.textContent = 'Pause';
    this.tick();
  }

  pause() {
    this.isRunning = false;
    this.startBtn.textContent = 'Start';
    if (this.animationFrame) {
      cancelAnimationFrame(this.animationFrame);
    }
  }

  reset() {
    this.pause();
    this.timeLeft = this.duration;
    this.updateDisplay();
    this.updateProgressRing();
    this.updateTitle();
  }

  tick() {
    if (!this.isRunning) return;
    
    const elapsed = Date.now() - this.startTime;
    this.timeLeft = Math.max(0, this.duration - elapsed);
    
    this.updateDisplay();
    this.updateProgressRing();
    this.updateTitle();
    
    if (this.timeLeft === 0) {
      this.onTimerComplete();
      return;
    }
    
    this.animationFrame = requestAnimationFrame(() => this.tick());
  }

  updateDisplay() {
    const minutes = Math.floor(this.timeLeft / 60000);
    const seconds = Math.floor((this.timeLeft % 60000) / 1000);
    const formatted = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
    this.timerText.textContent = formatted;
  }

  updateProgressRing() {
    const progress = (this.duration - this.timeLeft) / this.duration;
    const offset = this.progressCircumference * (1 - progress);
    this.progressBar.style.strokeDashoffset = offset;
  }

  updateTitle() {
    if (this.isRunning && this.timeLeft > 0) {
      const minutes = Math.floor(this.timeLeft / 60000);
      const seconds = Math.floor((this.timeLeft % 60000) / 1000);
      document.title = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')} - Timer`;
    } else {
      document.title = '20 Minute Timer - Perfect for Naps, Workouts & Focus Sessions';
    }
  }

  onTimerComplete() {
    this.pause();
    this.playAlarm();
    this.showNotification();
    this.timeLeft = 0;
    this.updateDisplay();
    this.updateProgressRing();
    this.updateTitle();
  }

  playAlarm() {
    // Generate Web Audio alarm without external files
    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
    
    // Play a pleasant three-note chime
    const frequencies = [523.25, 659.25, 783.99]; // C5, E5, G5
    
    frequencies.forEach((freq, index) => {
      const oscillator = audioContext.createOscillator();
      const gainNode = audioContext.createGain();
      
      oscillator.connect(gainNode);
      gainNode.connect(audioContext.destination);
      
      oscillator.frequency.setValueAtTime(freq, audioContext.currentTime);
      oscillator.type = 'sine';
      
      const startTime = audioContext.currentTime + (index * 0.3);
      gainNode.gain.setValueAtTime(0, startTime);
      gainNode.gain.linearRampToValueAtTime(0.3, startTime + 0.05);
      gainNode.gain.exponentialRampToValueAtTime(0.01, startTime + 0.5);
      
      oscillator.start(startTime);
      oscillator.stop(startTime + 0.5);
    });
  }

  async requestNotificationPermission() {
    if ('Notification' in window && Notification.permission === 'default') {
      await Notification.requestPermission();
    }
  }

  showNotification() {
    if ('Notification' in window && Notification.permission === 'granted') {
      new Notification('Timer Complete!', {
        body: 'Your 20 minute session is finished. Time for a break!',
        icon: '/favicon.ico',
        tag: 'timer-complete'
      });
    }
  }

  toggleFullscreen() {
    const container = document.querySelector('.timer-container');
    
    if (!this.isFullscreen) {
      container.classList.add('fullscreen-mode');
      this.isFullscreen = true;
      this.fullscreenBtn.textContent = '⛶';
    } else {
      container.classList.remove('fullscreen-mode');
      this.isFullscreen = false;
      this.fullscreenBtn.textContent = '⛶';
    }
  }
}

// Initialize timer when DOM is loaded
document.addEventListener('DOMContentLoaded', () => {
  new PremiumTimer();
});
</script>


