---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "20 Minute Timer - Perfect for Naps, Workouts & Focus Sessions",
  description: "Premium 20 minute countdown timer with progress ring, Web Audio alarm, and fullscreen mode. Perfect for power naps (NASA-proven optimal), HIIT workouts, study sprints, and meditation sessions.",
  category: "timer",
  published: "2026-03-28",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "20 Minute Timer",
    "applicationCategory": "Productivity",
    "operatingSystem": "Web",
    "description": "Premium 20 minute countdown timer with progress ring, Web Audio alarm, and fullscreen mode."
  },
  {
    "@context": "https://schema.org", 
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why is 20 minutes the optimal nap duration?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "NASA research found that 20-minute naps improve alertness by 100% and performance by 34%. This duration prevents deep sleep grogginess while maximizing cognitive restoration."
        }
      },
      {
        "@type": "Question", 
        "name": "How accurate is this 20 minute timer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our timer uses Date.now() for millisecond accuracy, immune to browser tab throttling. It remains precise even when the tab is minimized or in the background."
        }
      },
      {
        "@type": "Question",
        "name": "What are the keyboard shortcuts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Press SPACE to start/pause the timer, R to reset to your selected duration, and F to toggle fullscreen mode for distraction-free timing."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use this for HIIT workouts?",
        "acceptedAnswer": {
          "@type": "Answer",
