            <div style="display: flex; align-items: center; gap: 0.5rem;">
              <input type="number" id="pitchInput" placeholder="e.g., 4" min="0" step="any" style="flex: 1;">
              <span style="font-weight: bold; font-size: 1.2rem;">/ 12</span>
            </div>
            <div class="error-message" id="pitchError">Please enter a valid positive number.</div>
          </div>
