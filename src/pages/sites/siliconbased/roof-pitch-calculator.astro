export const meta = {
  title: "Roof Pitch Calculator: Find Rise, Run, Angle & Fraction",
  description: "Accurately calculate your roof's pitch, angle, and rafter length in seconds. Whether you're a DIYer or a pro, get the precise measurements you need now!",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is considered a standard roof pitch?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While 'standard' can vary by region and architectural style, the most common roof pitches for residential homes in the US typically range from 4/12 to 9/12. These pitches offer a good balance of efficient water shedding, walkable safety for roofers, and adequate attic space."
          }
        },
        {
          "@type": "Question",
          "name": "What is the minimum pitch for asphalt shingles?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The standard minimum pitch for installing standard asphalt shingles is 2/12. However, for pitches between 2/12 and 4/12, most manufacturers require special underlayment procedures (like a double layer of felt or ice and water shield) to prevent leaks. Pitches below 2/12 are considered 'low slope' and require different roofing materials entirely."
          }
        },
        {
          "@type": "Question",
          "name": "How do I find the rafter length if I know the pitch?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our calculator provides a 'Multiplier' value. To find your rafter length, simply measure your horizontal run (half the total span of the building) and multiply it by this multiplier. For example, if your run is 10 feet and the multiplier is 1.201, your rafter length (not including the overhang) is 12.01 feet."
          }
        },
        {
          "@type": "Question",
          "name": "Is a 12/12 roof considered steep?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, a 12/12 roof pitch is considered very steep. It means the roof rises 12 inches for every 12 inches of run, creating a 45-degree angle. Roofs of this steepness are not considered 'walkable' and require specialized safety equipment and staging for roofers, which often increases the cost of installation."
          }
        },
        {
          "@type": "Question",
          "name": "Does roof pitch affect solar panel installation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. Solar panels are most efficient when they are angled optimally toward the sun. While panels can be installed on almost any roof, if your pitch is too flat or too steep, installers may need to use special racking systems to tilt the panels to the ideal angle, which can add to the total cost of the solar project."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "SiliconBased",
        "url": "https://siliconbased.dev/"
      }
    }
  ]
};
