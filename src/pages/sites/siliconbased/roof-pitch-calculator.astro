  <script is:inline>

    document.addEventListener('DOMContentLoaded', () => {
      const calcMode = document.getElementById('calcMode');
      const modeRiseRun = document.getElementById('mode-rise-run');
      const modePitch = document.getElementById('mode-pitch');
      const modeAngle = document.getElementById('mode-angle');

      const riseInput = document.getElementById('riseInput');
      const runInput = document.getElementById('runInput');
      const pitchInput = document.getElementById('pitchInput');
      const angleInput = document.getElementById('angleInput');

      const resultsContainer = document.getElementById('resultsContainer');
      const resultPitch = document.getElementById('resultPitch');
      const resultAngle = document.getElementById('resultAngle');
      const resultGrade = document.getElementById('resultGrade');
      const resultMultiplier = document.getElementById('resultMultiplier');

      const inputs = [riseInput, runInput, pitchInput, angleInput];

      function clearErrors() {
        inputs.forEach(input => {
          input.classList.remove('invalid');
          const errorId = input.id.replace('Input', 'Error');
          const errorEl = document.getElementById(errorId);
          if (errorEl) errorEl.style.display = 'none';
        });
      }

      function showError(inputId) {
        document.getElementById(inputId).classList.add('invalid');
        const errorId = inputId.replace('Input', 'Error');
        const errorEl = document.getElementById(errorId);
        if (errorEl) errorEl.style.display = 'block';
      }

      calcMode.addEventListener('change', (e) => {
        modeRiseRun.style.display = 'none';
        modePitch.style.display = 'none';
        modeAngle.style.display = 'none';

        if (e.target.value === 'rise_run') modeRiseRun.style.display = 'block';
        if (e.target.value === 'pitch') modePitch.style.display = 'block';
        if (e.target.value === 'angle') modeAngle.style.display = 'block';

        calculateRoof();
      });

      function calculateRoof() {
        clearErrors();
        let pitchX = 0; // The X in X/12
        const mode = calcMode.value;
        let isValid = false;

        if (mode === 'rise_run') {
          if (riseInput.value === '' && runInput.value === '') {
            resultsContainer.style.display = 'none';
            return;
          }
          const rise = parseFloat(riseInput.value);
          const run = parseFloat(runInput.value);

          if (isNaN(rise) || rise < 0) {
            if (riseInput.value !== '') showError('riseInput');
          } else if (isNaN(run) || run <= 0) {
            if (runInput.value !== '') showError('runInput');
          } else {
            // Standardize to a run of 12
            pitchX = (rise / run) * 12;
            isValid = true;
          }
        } else if (mode === 'pitch') {
          if (pitchInput.value === '') {
            resultsContainer.style.display = 'none';
            return;
          }
          const pitch = parseFloat(pitchInput.value);
          if (isNaN(pitch) || pitch < 0) {
            showError('pitchInput');
          } else {
            pitchX = pitch;
            isValid = true;
          }
        } else if (mode === 'angle') {
          if (angleInput.value === '') {
            resultsContainer.style.display = 'none';
            return;
          }
          const angle = parseFloat(angleInput.value);
          if (isNaN(angle) || angle < 0 || angle >= 90) {
            showError('angleInput');
          } else {
            // angle in degrees to radians
            const radians = angle * (Math.PI / 180);
            pitchX = Math.tan(radians) * 12;
            isValid = true;
          }
        }

        if (!isValid) {
          resultsContainer.style.display = 'none';
          return;
        }

        // Calculations based on Pitch (X/12)
        const radians = Math.atan(pitchX / 12);
        const degrees = radians * (180 / Math.PI);
        const grade = (pitchX / 12) * 100;

        // Pythagorean theorem for multiplier: sqrt(rise^2 + run^2) / run
        const multiplier = Math.sqrt(Math.pow(pitchX, 2) + Math.pow(12, 2)) / 12;

        // Display
        resultPitch.textContent = `${parseFloat(pitchX.toFixed(2))} / 12`;
        resultAngle.textContent = `${degrees.toFixed(2)}°`;
        resultGrade.textContent = `${grade.toFixed(2)}%`;
        resultMultiplier.textContent = multiplier.toFixed(4);

        resultsContainer.style.display = 'block';
      }

      inputs.forEach(input => {
        input.addEventListener('input', calculateRoof);
      });
    });

  </script>

