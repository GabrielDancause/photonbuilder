---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SSL Certificate Checker",
    "url": "https://siliconbased.dev/ssl-checker",
    "description": "Check and decode SSL/TLS certificate details. View issuer, expiry, chain, protocol version, and grade rating.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    }
  }
];
---

<SiteLayout
  site="siliconbased"
  title="SSL Certificate Checker | Parse & Verify PEM"
  description="Check and decode SSL/TLS certificate details. View issuer, expiry, chain, protocol version, and grade rating. Secure, offline-capable, and free."
  canonical="https://siliconbased.dev/ssl-checker"
  schema={schemas}
>
  <style is:global>

* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #0a0b10; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 32px 24px 16px; background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%); }
.hero h1 { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Layout Grid */
.layout { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
@media (max-width: 900px) {
  .layout { grid-template-columns: 1fr; }
}

/* Card */
.tool-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; margin-bottom: 24px; display: flex; flex-direction: column; }
.tool-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; background: #13151d; border-bottom: 1px solid #1e2030; flex-wrap: wrap; gap: 12px; }
.tool-header h3 { font-size: 0.9rem; font-weight: 600; color: #ccc; display: flex; align-items: center; gap: 8px; }
.tool-header .status { font-size: 0.85rem; font-weight: 600; padding: 4px 10px; border-radius: 6px; }
.status.valid { background: rgba(74, 222, 128, 0.1); color: #4ade80; border: 1px solid rgba(74, 222, 128, 0.2); }
.status.invalid { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); }
.status.warning { background: rgba(234, 179, 8, 0.1); color: #eab308; border: 1px solid rgba(234, 179, 8, 0.2); }
.tool-body { padding: 24px; display: flex; flex-direction: column; gap: 20px; flex: 1; }

/* Input/Output Areas */
.textarea-wrapper { position: relative; display: flex; flex-direction: column; gap: 8px; flex: 1; }
.textarea-label { font-size: 0.85rem; font-weight: 600; display: flex; justify-content: space-between; align-items: center; color: #888; }
.textarea-label.primary { color: #818cf8; }

.editable-div {
  width: 100%;
  min-height: 200px;
  background: #0a0b10;
  border: 1px solid #1e2030;
  border-radius: 12px;
  padding: 16px;
  color: #4ade80;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem;
  outline: none;
  transition: border-color 0.2s;
  line-height: 1.5;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-y: auto;
}
.editable-div:empty:before { content: attr(placeholder); color: #444; pointer-events: none; display: block; }
.editable-div:focus { border-color: #818cf8; }

/* Output blocks */
.info-block { width: 100%; background: #0a0b10; border: 1px solid #1e2030; border-radius: 12px; padding: 16px; color: #e0e0e0; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; overflow-x: auto; white-space: pre-wrap; word-break: break-word; }

.key { color: #888; margin-right: 8px; }
.val { color: #e0e0e0; }
.val-green { color: #4ade80; }
.val-red { color: #ef4444; }
.val-yellow { color: #f59e0b; }
.val-blue { color: #818cf8; }

.item-row { margin-bottom: 8px; }
.item-row:last-child { margin-bottom: 0; }
.section-title { font-size: 0.85rem; font-weight: 700; color: #fff; margin: 16px 0 8px; padding-bottom: 4px; border-bottom: 1px solid #1e2030; font-family: 'Inter', sans-serif; }

/* Actions */
.actions-row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-top: 10px; }
.btn { background: #1e2030; border: 1px solid #2a2d40; color: #ccc; padding: 8px 16px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; display: flex; align-items: center; gap: 6px; }
.btn:hover { background: #2a2d40; color: #fff; }

/* SEO Content */
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }

/* Footer */
.footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #555; border-top: 1px solid #151520; margin-top: auto; }
.footer a { color: #818cf8; text-decoration: none; }
.footer a:hover { text-decoration: underline; }

.grade-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 1.1rem;
    font-weight: 800;
    font-family: 'Inter', sans-serif;
}
.grade-A { background: rgba(74, 222, 128, 0.15); color: #4ade80; border: 1px solid rgba(74, 222, 128, 0.3); }
.grade-B { background: rgba(250, 204, 21, 0.15); color: #facc15; border: 1px solid rgba(250, 204, 21, 0.3); }
.grade-C { background: rgba(249, 115, 22, 0.15); color: #f97316; border: 1px solid rgba(249, 115, 22, 0.3); }
.grade-F { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

.chain-item { margin-bottom: 16px; padding: 12px; background: #13151d; border: 1px solid #1e2030; border-radius: 8px; }
.chain-item:last-child { margin-bottom: 0; }

  </style>

<div class="hero">
  <h1>SSL Certificate <span>Checker</span></h1>
  <p>Decode, inspect and verify SSL/TLS certificates (PEM format) securely in your browser.</p>
</div>

<div class="main">

  <div class="layout">
    <!-- Left Column: Input -->
    <div class="column-left">
      <div class="tool-card" style="height: 100%;">
        <div class="tool-header">
          <h3>Certificate Input (PEM)</h3>
        </div>
        <div class="tool-body">
          <div class="textarea-wrapper">
            <div class="textarea-label">Paste a Certificate (or full chain) here</div>
            <div id="certInput" class="editable-div" contenteditable="true" spellcheck="false" placeholder="-----BEGIN CERTIFICATE-----&#10;MII...&#10;-----END CERTIFICATE-----&#10;&#10;Paste a PEM certificate here. You can paste multiple certificates to view the chain."></div>
          </div>
          <div class="actions-row">
             <span id="certCount" style="color: #888; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;">0 certificates found</span>
             <div>
                <button class="btn" id="clearBtn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                  Clear
                </button>
             </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Decoded Output -->
    <div class="column-right">
      <div class="tool-card">
        <div class="tool-header">
          <h3>Decoded Certificate</h3>
          <div style="display: flex; gap: 12px; align-items: center;">
             <span id="validationStatus" class="status" style="display: none;">Status</span>
             <span id="gradeBadge" class="grade-badge" style="display: none;">-</span>
          </div>
        </div>
        <div class="tool-body" id="outputArea">
          <div class="info-block" style="color: #888; text-align: center; padding: 40px 20px;">
             Paste a PEM certificate on the left to view details.
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="seo-content">
    <h2>What is an SSL Certificate?</h2>
    <p>An SSL (Secure Sockets Layer) certificate is a digital certificate that authenticates a website's identity and enables an encrypted connection. It ensures that all data passed between the web server and browsers remain private and integral. Certificates contain the website's public key and identity information, and are issued by a trusted Certificate Authority (CA).</p>

    <h2>How to read PEM Certificates</h2>
    <p>PEM (Privacy-Enhanced Mail) is the most common format for X.509 certificates. They are Base64 encoded ASCII files and have specific header and footer lines, typically starting with <code>-----BEGIN CERTIFICATE-----</code> and ending with <code>-----END CERTIFICATE-----</code>. A single PEM file can contain one certificate or an entire certificate chain (server certificate, intermediate CA certificates, and optionally the root CA certificate).</p>

    <h2>Certificate Grades & Expiry</h2>
    <p>This tool evaluates your certificate validity based on its dates:</p>
    <ul>
      <li><strong>Grade A:</strong> Certificate is valid and has more than 30 days until expiration.</li>
      <li><strong>Grade B:</strong> Certificate is valid but expires in less than 30 days.</li>
      <li><strong>Grade C:</strong> Certificate is valid but expires very soon (less than 7 days).</li>
      <li><strong>Grade F:</strong> Certificate is expired or not yet valid.</li>
    </ul>

    <h2>Client-Side Privacy</h2>
    <p>Our SSL Certificate Checker runs entirely in your browser using JavaScript. When you paste your certificate (which typically only contains public information), it is parsed locally. <strong>No data is sent to any server.</strong> This ensures maximum privacy, speed, and full offline capability.</p>
  </div>

</div>



<script is:inline>
const certInput = document.getElementById('certInput');
const clearBtn = document.getElementById('clearBtn');
const certCountDisplay = document.getElementById('certCount');
const outputArea = document.getElementById('outputArea');
const validationStatus = document.getElementById('validationStatus');
const gradeBadge = document.getElementById('gradeBadge');

// OID to readable string mapping
const oids = {
    '1.2.840.113549.1.1.1': 'RSA',
    '1.2.840.113549.1.1.2': 'MD2 with RSA',
    '1.2.840.113549.1.1.4': 'MD5 with RSA',
    '1.2.840.113549.1.1.5': 'SHA1 with RSA',
    '1.2.840.113549.1.1.11': 'SHA256 with RSA',
    '1.2.840.113549.1.1.12': 'SHA384 with RSA',
    '1.2.840.113549.1.1.13': 'SHA512 with RSA',
    '1.2.840.113549.1.1.10': 'RSASSA-PSS',
    '1.2.840.10045.2.1': 'ECDSA',
    '1.2.840.10045.4.1': 'SHA1 with ECDSA',
    '1.2.840.10045.4.3.2': 'SHA256 with ECDSA',
    '1.2.840.10045.4.3.3': 'SHA384 with ECDSA',
    '1.2.840.10045.4.3.4': 'SHA512 with ECDSA',
    '1.3.101.112': 'Ed25519',
    '1.3.101.113': 'Ed448',
};

function formatOid(oid) {
    return oids[oid] || oid;
}

function escapeHtml(unsafe) {
    if (!unsafe) return '';
    return String(unsafe)
         .replace(/&/g, "&amp;")
         .replace(/</g, "&lt;")
         .replace(/>/g, "&gt;")
         .replace(/"/g, "&quot;")
         .replace(/'/g, "&#039;");
}

function formatAttrs(attributes) {
    if (!attributes || !attributes.length) return '<span class="val">None</span>';

    // Prioritize common fields
    const order = ['CN', 'O', 'OU', 'L', 'ST', 'C'];

    const parts = attributes.map(a => {
        const name = a.shortName || a.name || a.type;
        return { name: escapeHtml(name), value: escapeHtml(a.value) };
    });

    parts.sort((a, b) => {
        let ia = order.indexOf(a.name);
        let ib = order.indexOf(b.name);
        if(ia === -1) ia = 99;
        if(ib === -1) ib = 99;
        return ia - ib;
    });

    return parts.map(p => `<span class="val-blue">${p.name}</span>=<span class="val">${p.value}</span>`).join(', ');
}

function extractCertificates(pemText) {
    const certs = [];
    const lines = pemText.split(/\r?\n/);
    let currentCert = [];
    let inCert = false;
    for (const line of lines) {
        if (line.includes('-----BEGIN CERTIFICATE-----')) {
            inCert = true;
            currentCert = [line];
        } else if (line.includes('-----END CERTIFICATE-----') && inCert) {
            currentCert.push(line);
            certs.push(currentCert.join('\n'));
            inCert = false;
        } else if (inCert) {
            currentCert.push(line);
        }
    }
    return certs;
}

function daysBetween(d1, d2) {
    const diffTime = d2.getTime() - d1.getTime();
    return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
}

function evaluateCertificate(certObj) {
    const now = new Date();
    const notBefore = certObj.validity.notBefore;
    const notAfter = certObj.validity.notAfter;

    const isNotYetValid = now < notBefore;
    const isExpired = now > notAfter;

    let grade = 'A';
    let statusText = 'Valid';
    let isValid = true;

    const daysRemaining = daysBetween(now, notAfter);

    if (isNotYetValid) {
        grade = 'F';
        statusText = 'Not Yet Valid';
        isValid = false;
    } else if (isExpired) {
        grade = 'F';
        statusText = 'Expired';
        isValid = false;
    } else {
        if (daysRemaining < 7) {
            grade = 'C';
        } else if (daysRemaining < 30) {
            grade = 'B';
        } else {
            grade = 'A';
        }
    }

    return { grade, statusText, isValid, daysRemaining, notBefore, notAfter };
}

function formatCertDetails(certObj, evalResult, index, total) {
    const sn = certObj.serialNumber ? certObj.serialNumber.replace(/(.{2})/g, '$1:').slice(0, -1).toUpperCase() : 'N/A';

    let validityHtml = '';
    const dateOpts = { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', timeZoneName: 'short' };

    validityHtml += `<div class="item-row"><span class="key">Valid From:</span> <span class="val">${evalResult.notBefore.toLocaleString(undefined, dateOpts)}</span></div>`;
    validityHtml += `<div class="item-row"><span class="key">Valid To:</span> <span class="val">${evalResult.notAfter.toLocaleString(undefined, dateOpts)}</span></div>`;

    if (!evalResult.isValid) {
        validityHtml += `<div class="item-row"><span class="key">Status:</span> <span class="val-red">${evalResult.statusText}</span></div>`;
    } else {
        const daysColor = evalResult.daysRemaining > 30 ? 'val-green' : (evalResult.daysRemaining > 7 ? 'val-yellow' : 'val-red');
        validityHtml += `<div class="item-row"><span class="key">Expires in:</span> <span class="${daysColor}">${evalResult.daysRemaining} days</span></div>`;
    }

    const title = total > 1 ? (index === 0 ? 'Server Certificate (Leaf)' : (index === total - 1 ? 'Root/Intermediate CA' : 'Intermediate CA')) : 'Certificate Details';

    return `
    <div class="chain-item">
        <div style="font-size:0.95rem;font-weight:700;color:#fff;margin-bottom:12px;display:flex;justify-content:space-between;">
            <span>[${index + 1}] ${title}</span>
            <span style="font-size:0.8rem;color:#888;">Version: v${certObj.version + 1 || 3}</span>
        </div>

        <div class="section-title" style="margin-top:0;">Subject</div>
        <div class="item-row">${formatAttrs(certObj.subject.attributes)}</div>

        <div class="section-title">Issuer</div>
        <div class="item-row">${formatAttrs(certObj.issuer.attributes)}</div>

        <div class="section-title">Validity</div>
        ${validityHtml}

        <div class="section-title">Technical Details</div>
        <div class="item-row"><span class="key">Serial Number:</span> <span class="val" style="font-size:0.8rem;" id="sn-${index}">${sn}</span>
            <button class="btn" style="padding:2px 6px; font-size: 0.7rem; display: inline-flex; margin-left: 8px;" onclick="copyToClipboard('sn-${index}', this)">Copy SN</button>
        </div>
        <div class="item-row"><span class="key">Signature Algorithm:</span> <span class="val">${escapeHtml(formatOid(certObj.signatureOid))}</span></div>
        <div class="item-row"><span class="key">Public Key:</span> <span class="val">RSA (${certObj.publicKey.n ? certObj.publicKey.n.bitLength() : 'Unknown'} bit)</span></div>
    </div>
    `;
}

function processCertificates() {
    let rawText = certInput.innerText || certInput.textContent;
    rawText = rawText.replace(/[\u200B-\u200D\uFEFF]/g, '');

    const pemBlocks = extractCertificates(rawText);
    certCountDisplay.textContent = `${pemBlocks.length} certificate${pemBlocks.length !== 1 ? 's' : ''} found`;

    if (pemBlocks.length === 0) {
        outputArea.innerHTML = `<div class="info-block" style="color: #888; text-align: center; padding: 40px 20px;">Paste a PEM certificate on the left to view details.</div>`;
        validationStatus.style.display = 'none';
        gradeBadge.style.display = 'none';
        return;
    }

    try {
        let outputHtml = '';
        let primaryEval = null;

        // Parse all certs
        for (let i = 0; i < pemBlocks.length; i++) {
            const certObj = forge.pki.certificateFromPem(pemBlocks[i]);
            const evalResult = evaluateCertificate(certObj);

            // Primary evaluation is based on the first cert (Leaf)
            if (i === 0) {
                primaryEval = evalResult;
            }

            outputHtml += formatCertDetails(certObj, evalResult, i, pemBlocks.length);
        }

        outputArea.innerHTML = outputHtml;

        // Update header badges based on primary cert
        if (primaryEval) {
            validationStatus.style.display = 'inline-block';
            validationStatus.textContent = primaryEval.statusText;
            validationStatus.className = 'status ' + (primaryEval.isValid ? 'valid' : 'invalid');

            gradeBadge.style.display = 'inline-flex';
            gradeBadge.textContent = primaryEval.grade;
            gradeBadge.className = 'grade-badge grade-' + primaryEval.grade;
        }

    } catch (e) {
        outputArea.innerHTML = `
        <div class="info-block">
            <div style="color:#ef4444;margin-bottom:8px;font-weight:600;">Error Parsing Certificate</div>
            <div style="color:#e0e0e0;">${e.message || e.toString()}</div>
            <div style="color:#888;margin-top:12px;font-size:0.8rem;">Ensure you have pasted a valid, uncorrupted PEM formatted X.509 certificate.</div>
        </div>`;
        validationStatus.style.display = 'none';
        gradeBadge.style.display = 'none';
    }
}

function copyToClipboard(elementId, btn) {
    const el = document.getElementById(elementId);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent).then(() => {
        const originalText = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => {
            btn.textContent = originalText;
        }, 2000);
    }).catch(err => {
        console.error('Failed to copy', err);
    });
}

// Event Listeners
certInput.addEventListener('input', () => {
    // Only process immediately if pasting/deleting a lot, otherwise debounce could be used.
    // For simplicity, process on input
    processCertificates();
});

certInput.addEventListener('paste', (e) => {
    e.preventDefault();
    let text = (e.originalEvent || e).clipboardData.getData('text/plain');
    document.execCommand('insertText', false, text);
    processCertificates();
});

clearBtn.addEventListener('click', () => {
    certInput.innerHTML = '';
    processCertificates();
    certInput.focus();
});

// Initial process
processCertificates();
</script>
</SiteLayout>
