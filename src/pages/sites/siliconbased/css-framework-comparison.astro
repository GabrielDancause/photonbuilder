<SiteLayout
  site="siliconbased"
  title="CSS Framework Comparison: Top 10 Frameworks"
  description="A detailed comparison of Tailwind CSS, Bootstrap 5, Bulma, Foundation, Materialize, Pico CSS, Open Props, Water.css, Skeleton, and Pure CSS."
  canonical="https://siliconbased.dev/css-framework-comparison"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
    // Table sorting logic
    document.addEventListener('DOMContentLoaded', () => {
      const table = document.getElementById('frameworkTable');
      const headers = table.querySelectorAll('th[data-sort]');

      headers.forEach(header => {
        header.addEventListener('click', () => {
          const tbody = table.querySelector('tbody');
          const rows = Array.from(tbody.querySelectorAll('tr'));
          const sortKey = header.dataset.sort;
          const sortType = header.dataset.type || 'string';
          const isAscending = header.classList.contains('asc');

          // Clear all classes
          headers.forEach(h => {
            h.classList.remove('asc', 'desc');
            h.querySelector('.sort-icon').textContent = '↕';
          });

          // Toggle sort direction
          header.classList.add(isAscending ? 'desc' : 'asc');
          header.querySelector('.sort-icon').textContent = isAscending ? '↓' : '↑';

          const index = Array.from(header.parentElement.children).indexOf(header);

          rows.sort((a, b) => {
            const cellA = a.children[index];
            const cellB = b.children[index];

            let valA = cellA.dataset.value || cellA.textContent.trim();
            let valB = cellB.dataset.value || cellB.textContent.trim();

            if (sortType === 'number') {
              valA = parseFloat(valA.replace(/[^0-9.-]+/g,""));
              valB = parseFloat(valB.replace(/[^0-9.-]+/g,""));
              if (isNaN(valA)) valA = 0;
              if (isNaN(valB)) valB = 0;
              return isAscending ? valB - valA : valA - valB;
            }

            return isAscending ? valB.localeCompare(valA) : valA.localeCompare(valB);
          });

          rows.forEach(row => tbody.appendChild(row));
        });
      });

      // Code tabs logic
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabContents = document.querySelectorAll('.tab-content');

      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.dataset.target;

          tabBtns.forEach(b => b.classList.remove('active'));
          tabContents.forEach(c => c.classList.remove('active'));

          btn.classList.add('active');
          document.getElementById(targetId).classList.add('active');
        });
      });
    });
  </script>

