---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Chmod Calculator — Linux File Permissions Made Easy",
      "url": "https://siliconbased.dev/chmod-calculator",
      "description": "Free chmod calculator and Linux file permissions tool. Set owner, group, and other permissions with an interactive checkbox grid, get numeric and symbolic notation, and look up common permission presets like 755, 644, and 777.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does chmod 777 mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "chmod 777 sets read, write, and execute permissions for the owner, group, and all other users. Each 7 is the sum of read (4) + write (2) + execute (1). This is the most permissive setting and is generally considered a security risk on production systems because any user on the system can read, modify, or execute the file."
          }
        },
        {
          "@type": "Question",
          "name": "What is the chmod command in Linux?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "chmod (change mode) is a Linux and Unix command that changes the access permissions of files and directories. It accepts permissions in numeric notation (e.g., chmod 755 file.txt) or symbolic notation (e.g., chmod u+rwx,g+rx,o+rx file.txt). The command controls who can read, write, and execute a file."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between chmod 755 and 644?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "chmod 755 (rwxr-xr-x) gives the owner full permissions and lets the group and others read and execute. It is commonly used for directories and executable scripts. chmod 644 (rw-r--r--) gives the owner read and write access while the group and others can only read. It is the standard permission for regular files like HTML, CSS, and configuration files."
          }
        },
        {
          "@type": "Question",
          "name": "How do Linux file permissions work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Linux file permissions are divided into three categories: owner (user who owns the file), group (users in the file's group), and others (everyone else). Each category can have read (r), write (w), and execute (x) permissions. In numeric notation, read = 4, write = 2, execute = 1. The three digits represent owner, group, and others respectively. For example, 750 means owner can read/write/execute (7), group can read/execute (5), and others have no permissions (0)."
          }
        },
        {
          "@type": "Question",
          "name": "What are setuid, setgid, and sticky bit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "These are special permissions in Linux. Setuid (4) makes an executable run with the file owner's privileges instead of the user running it — commonly used for commands like passwd. Setgid (2) on a file runs it with the group's privileges; on a directory, new files inherit the directory's group. Sticky bit (1) on a directory prevents users from deleting files they don't own — the /tmp directory uses this. They are represented as a fourth octal digit prepended to the standard three (e.g., 1755)."
          }
        },
        {
          "@type": "Question",
          "name": "What permissions should I use for web server files?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For web server files: use 644 (rw-r--r--) for regular files like HTML, CSS, JavaScript, and images. Use 755 (rwxr-xr-x) for directories and executable scripts like CGI or PHP files. Use 600 (rw-------) for sensitive configuration files containing passwords or API keys. Avoid 777 in production as it allows any user to modify your files."
          }
        },
        {
          "@type": "Question",
          "name": "Is this chmod calculator free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this chmod calculator is completely free and runs entirely in your browser. No data is sent to any server. You can use it to calculate permissions, look up common presets, and learn about Linux file permissions without creating an account or installing anything."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Chmod Calculator — Linux File Permissions Made Easy",
      "description": "Free chmod calculator with interactive permission grid, numeric and symbolic output, common presets, and special permission support.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Chmod Calculator</h1>
  <p>Calculate Linux file permissions visually. Toggle checkboxes, get numeric &amp; symbolic notation instantly. No data leaves your browser.</p>
</div>

<div class="main">

  <!-- Live Output Bar -->
  <div class="output-bar">
    <div class="output-group">
      <label class="output-label">Numeric</label>
      <div class="output-value" id="numericOut">0755</div>
    </div>
    <div class="output-group">
      <label class="output-label">Symbolic</label>
      <div class="output-value" id="symbolicOut">rwxr-xr-x</div>
    </div>
    <div class="output-group">
      <label class="output-label">Command</label>
      <div class="output-value cmd" id="commandOut">chmod 755 filename</div>
    </div>
    <button class="copy-btn" id="copyBtn">Copy</button>
  </div>

  <!-- Reverse Input -->
  <div class="reverse-section">
    <div class="reverse-bar">
      <input type="text" id="reverseInput" class="reverse-input" placeholder="Enter numeric (e.g. 755 or 0755 or 1755)" maxlength="4" spellcheck="false" />
      <button class="action-btn" id="reverseBtn">Apply</button>
    </div>
  </div>

  <!-- Presets -->
  <div class="presets-section">
    <div class="input-header"><div class="header-title">Common Presets</div></div>
    <div class="presets-row">
      <button class="preset-btn" data-mode="777"><span class="preset-num">777</span><span class="preset-desc">Full access (all)</span></button>
      <button class="preset-btn active" data-mode="755"><span class="preset-num">755</span><span class="preset-desc">Owner full, others r+x</span></button>
      <button class="preset-btn" data-mode="644"><span class="preset-num">644</span><span class="preset-desc">Owner rw, others read</span></button>
      <button class="preset-btn" data-mode="600"><span class="preset-num">600</span><span class="preset-desc">Owner rw only</span></button>
      <button class="preset-btn" data-mode="400"><span class="preset-num">400</span><span class="preset-desc">Owner read only</span></button>
      <button class="preset-btn" data-mode="775"><span class="preset-num">775</span><span class="preset-desc">Owner+group full, others r+x</span></button>
    </div>
  </div>

  <!-- Permission Grid -->
  <div class="perm-grid">
    <div class="grid-header">
      <div class="grid-cell corner"></div>
      <div class="grid-cell col-head">Read (4)</div>
      <div class="grid-cell col-head">Write (2)</div>
      <div class="grid-cell col-head">Execute (1)</div>
    </div>
    <div class="grid-row" data-who="owner">
      <div class="grid-cell row-head">Owner (u)</div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="owner" data-perm="read" checked /><span class="cb-visual"></span></label></div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="owner" data-perm="write" checked /><span class="cb-visual"></span></label></div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="owner" data-perm="execute" checked /><span class="cb-visual"></span></label></div>
    </div>
    <div class="grid-row" data-who="group">
      <div class="grid-cell row-head">Group (g)</div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="group" data-perm="read" checked /><span class="cb-visual"></span></label></div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="group" data-perm="write" /><span class="cb-visual"></span></label></div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="group" data-perm="execute" checked /><span class="cb-visual"></span></label></div>
    </div>
    <div class="grid-row" data-who="other">
      <div class="grid-cell row-head">Others (o)</div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="other" data-perm="read" checked /><span class="cb-visual"></span></label></div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="other" data-perm="write" /><span class="cb-visual"></span></label></div>
      <div class="grid-cell"><label class="cb-wrap"><input type="checkbox" data-who="other" data-perm="execute" checked /><span class="cb-visual"></span></label></div>
    </div>
  </div>

  <!-- Special Permissions -->
  <div class="special-perms">
    <div class="input-header"><div class="header-title">Special Permissions</div></div>
    <div class="special-grid">
      <label class="special-item">
        <input type="checkbox" id="setuid" data-special="setuid" />
        <span class="cb-visual"></span>
        <div class="special-info">
          <strong>Setuid (4)</strong>
          <span>Execute as file owner</span>
        </div>
      </label>
      <label class="special-item">
        <input type="checkbox" id="setgid" data-special="setgid" />
        <span class="cb-visual"></span>
        <div class="special-info">
          <strong>Setgid (2)</strong>
          <span>Execute as group / inherit group on dirs</span>
        </div>
      </label>
      <label class="special-item">
        <input type="checkbox" id="sticky" data-special="sticky" />
        <span class="cb-visual"></span>
        <div class="special-info">
          <strong>Sticky Bit (1)</strong>
          <span>Only owner can delete files in directory</span>
        </div>
      </label>
    </div>
  </div>

  <!-- Permission Reference Table -->
  <div class="perm-ref">
    <div class="input-header"><div class="header-title">Permission Reference</div></div>
    <div class="ref-table-wrap">
      <table class="ref-table">
        <thead>
          <tr>
            <th>Numeric</th>
            <th>Symbolic</th>
            <th>Description</th>
            <th>Common Use</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><code>777</code></td><td><code>rwxrwxrwx</code></td><td>Full access for everyone</td><td>Temporary dev, never production</td></tr>
          <tr><td><code>755</code></td><td><code>rwxr-xr-x</code></td><td>Owner full, others read+execute</td><td>Directories, scripts, executables</td></tr>
          <tr><td><code>750</code></td><td><code>rwxr-x---</code></td><td>Owner full, group read+execute, others none</td><td>Group-accessible programs</td></tr>
          <tr><td><code>700</code></td><td><code>rwx------</code></td><td>Owner full, no access for others</td><td>Private scripts, home directories</td></tr>
          <tr><td><code>644</code></td><td><code>rw-r--r--</code></td><td>Owner read+write, others read</td><td>HTML, CSS, JS, config files</td></tr>
          <tr><td><code>640</code></td><td><code>rw-r-----</code></td><td>Owner read+write, group read</td><td>Log files, shared configs</td></tr>
          <tr><td><code>600</code></td><td><code>rw-------</code></td><td>Owner read+write only</td><td>SSH keys, .env, credentials</td></tr>
          <tr><td><code>400</code></td><td><code>r--------</code></td><td>Owner read only</td><td>Certificates, immutable configs</td></tr>
          <tr><td><code>775</code></td><td><code>rwxrwxr-x</code></td><td>Owner+group full, others read+execute</td><td>Shared group directories</td></tr>
          <tr><td><code>664</code></td><td><code>rw-rw-r--</code></td><td>Owner+group read+write, others read</td><td>Shared group files</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What Is the chmod Command?</h2>
    <p>The <code>chmod</code> (change mode) command is used on Linux and Unix systems to set or modify the access permissions of files and directories. Every file on a Linux system has three permission categories — owner, group, and others — and each category can independently be granted read, write, and execute access. The chmod command accepts permissions in numeric (octal) notation like <code>chmod 755 file.txt</code> or symbolic notation like <code>chmod u+rwx,g+rx,o+rx file.txt</code>.</p>

    <h2>Understanding Numeric (Octal) Permissions</h2>
    <p>In numeric notation, each permission has a value: <strong>read = 4</strong>, <strong>write = 2</strong>, <strong>execute = 1</strong>. You add these values together for each category to get a single digit. Three digits represent owner, group, and others. For example:</p>
    <pre class="syntax-block">  Permission    Value
  ─────────────────────
  Read    (r)     4
  Write   (w)     2
  Execute (x)     1
  ─────────────────────

  Example: 755
  Owner:  4+2+1 = 7 (rwx)
  Group:  4+0+1 = 5 (r-x)
  Others: 4+0+1 = 5 (r-x)</pre>

    <h2>Symbolic Permission Notation</h2>
    <p>Symbolic notation uses letters to represent permissions: <code>r</code> (read), <code>w</code> (write), <code>x</code> (execute). The permission string has nine characters arranged as three groups of three: <code>rwxr-xr-x</code>. A dash (<code>-</code>) indicates the permission is not set. When displayed by <code>ls -l</code>, an additional leading character shows the file type (<code>d</code> for directory, <code>-</code> for regular file, <code>l</code> for symlink).</p>

    <h2>Special Permissions: Setuid, Setgid &amp; Sticky Bit</h2>
    <p>Beyond the standard read, write, and execute permissions, Linux supports three special permission bits:</p>
    <ul>
      <li><strong>Setuid (4xxx):</strong> When set on an executable, the process runs with the file owner's privileges. For example, <code>/usr/bin/passwd</code> uses setuid to let regular users change their own passwords. Set with <code>chmod u+s</code> or <code>chmod 4755</code>.</li>
      <li><strong>Setgid (2xxx):</strong> On an executable, the process runs with the file's group. On a directory, new files automatically inherit the directory's group, which is useful for shared folders. Set with <code>chmod g+s</code> or <code>chmod 2755</code>.</li>
      <li><strong>Sticky Bit (1xxx):</strong> On a directory, only the file owner (or root) can delete or rename files within it. The classic example is <code>/tmp</code>, which has mode <code>1777</code>. Set with <code>chmod +t</code> or <code>chmod 1777</code>.</li>
    </ul>

    <h2>Common Permission Scenarios</h2>
    <ul>
      <li><strong>Web server files (HTML, CSS, JS):</strong> <code>644</code> — owner can edit, everyone can read.</li>
      <li><strong>Web server directories:</strong> <code>755</code> — owner can manage, others can list and traverse.</li>
      <li><strong>CGI / PHP scripts:</strong> <code>755</code> — must be executable by the web server.</li>
      <li><strong>SSH private keys:</strong> <code>600</code> — SSH refuses to use keys with broader permissions.</li>
      <li><strong>Shared project directory:</strong> <code>2775</code> — group can write, setgid ensures new files inherit group.</li>
      <li><strong>Temporary directory:</strong> <code>1777</code> — world-writable with sticky bit to prevent deletion by others.</li>
    </ul>

    <h2>chmod vs. chown vs. chgrp</h2>
    <p><code>chmod</code> changes <em>what</em> actions can be performed on a file. <code>chown</code> changes <em>who</em> owns the file (user and/or group). <code>chgrp</code> changes only the group. Together, these three commands control all aspects of file access on Linux. For example, <code>chown www-data:www-data file.html && chmod 644 file.html</code> gives the web server ownership with standard read/write permissions.</p>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does chmod 777 mean?</h3>
      <p style="margin-bottom: 16px;">chmod 777 sets read, write, and execute permissions for the owner, group, and all other users. Each 7 is the sum of read (4) + write (2) + execute (1). This is the most permissive setting and is generally considered a security risk on production systems because any user on the system can read, modify, or execute the file.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the chmod command in Linux?</h3>
      <p style="margin-bottom: 16px;">chmod (change mode) is a Linux and Unix command that changes the access permissions of files and directories. It accepts permissions in numeric notation (e.g., chmod 755 file.txt) or symbolic notation (e.g., chmod u+rwx,g+rx,o+rx file.txt). The command controls who can read, write, and execute a file.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between chmod 755 and 644?</h3>
      <p style="margin-bottom: 16px;">chmod 755 (rwxr-xr-x) gives the owner full permissions and lets the group and others read and execute. It is commonly used for directories and executable scripts. chmod 644 (rw-r--r--) gives the owner read and write access while the group and others can only read. It is the standard permission for regular files like HTML, CSS, and configuration files.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do Linux file permissions work?</h3>
      <p style="margin-bottom: 16px;">Linux file permissions are divided into three categories: owner (user who owns the file), group (users in the file's group), and others (everyone else). Each category can have read (r), write (w), and execute (x) permissions. In numeric notation, read = 4, write = 2, execute = 1. The three digits represent owner, group, and others respectively.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What are setuid, setgid, and sticky bit?</h3>
      <p style="margin-bottom: 16px;">These are special permissions in Linux. Setuid (4) makes an executable run with the file owner's privileges. Setgid (2) on a file runs it with the group's privileges; on a directory, new files inherit the directory's group. Sticky bit (1) on a directory prevents users from deleting files they don't own. They are represented as a fourth octal digit prepended to the standard three (e.g., 1755).</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What permissions should I use for web server files?</h3>
      <p style="margin-bottom: 16px;">For web server files: use 644 (rw-r--r--) for regular files like HTML, CSS, JavaScript, and images. Use 755 (rwxr-xr-x) for directories and executable scripts like CGI or PHP files. Use 600 (rw-------) for sensitive configuration files containing passwords or API keys. Avoid 777 in production as it allows any user to modify your files.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is this chmod calculator free to use?</h3>
      <p style="margin-bottom: 16px;">Yes, this chmod calculator is completely free and runs entirely in your browser. No data is sent to any server. You can use it to calculate permissions, look up common presets, and learn about Linux file permissions without creating an account or installing anything.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/cron-job-generator">Cron Job Generator</a> — Build cron expressions visually with presets and run time preview.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions online with real-time highlighting.</li>
      <li><a href="/base64">Base64 Encoder / Decoder</a> — Encode and decode Base64 strings.</li>
      <li><a href="/hash-generator">Hash Generator</a> — Generate MD5, SHA-1, SHA-256, and other hashes.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "Chmod Calculator — Linux File Permissions Made Easy",
  description: "Free chmod calculator and Linux file permissions tool. Interactive checkbox grid for owner, group, and other permissions with numeric, symbolic, and command output.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="Chmod Calculator — Linux File Permissions Made Easy"
  description="Free chmod calculator and Linux file permissions tool. Interactive checkbox grid for owner, group, and other permissions with numeric, symbolic, and command output."
  canonical="https://siliconbased.dev/chmod-calculator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const numericOut = document.getElementById('numericOut');
const symbolicOut = document.getElementById('symbolicOut');
const commandOut = document.getElementById('commandOut');
const copyBtn = document.getElementById('copyBtn');
const reverseInput = document.getElementById('reverseInput');
const reverseBtn = document.getElementById('reverseBtn');

const checkboxes = document.querySelectorAll('.perm-grid input[type="checkbox"]');
const specialCheckboxes = document.querySelectorAll('input[data-special]');

const PERM_VALUES = { read: 4, write: 2, execute: 1 };
const SPECIAL_VALUES = { setuid: 4, setgid: 2, sticky: 1 };

function init() {
  checkboxes.forEach(function(cb) { cb.addEventListener('change', updateFromCheckboxes); });
  specialCheckboxes.forEach(function(cb) { cb.addEventListener('change', updateFromCheckboxes); });

  // Presets
  document.querySelectorAll('.preset-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      applyNumeric(btn.dataset.mode);
      highlightPreset(btn.dataset.mode);
    });
  });

  // Copy
  copyBtn.addEventListener('click', function() {
    var cmd = 'chmod ' + getNumericString() + ' filename';
    navigator.clipboard.writeText(cmd).then(function() {
      copyBtn.textContent = '\u2713 Copied';
      setTimeout(function() { copyBtn.textContent = 'Copy'; }, 1500);
    });
  });

  // Reverse input
  reverseBtn.addEventListener('click', applyFromInput);
  reverseInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') applyFromInput();
  });

  updateFromCheckboxes();
}

function getPermValue(who) {
  var val = 0;
  checkboxes.forEach(function(cb) {
    if (cb.dataset.who === who && cb.checked) {
      val += PERM_VALUES[cb.dataset.perm];
    }
  });
  return val;
}

function getSpecialValue() {
  var val = 0;
  specialCheckboxes.forEach(function(cb) {
    if (cb.checked) val += SPECIAL_VALUES[cb.dataset.special];
  });
  return val;
}

function getNumericString() {
  var special = getSpecialValue();
  var owner = getPermValue('owner');
  var group = getPermValue('group');
  var other = getPermValue('other');
  if (special > 0) return '' + special + owner + group + other;
  return '' + owner + group + other;
}

function getSymbolic() {
  var mapWho = function(who) {
    var s = '';
    checkboxes.forEach(function(cb) {
      if (cb.dataset.who === who) {
        if (cb.dataset.perm === 'read') s += cb.checked ? 'r' : '-';
        if (cb.dataset.perm === 'write') s += cb.checked ? 'w' : '-';
        if (cb.dataset.perm === 'execute') s += cb.checked ? 'x' : '-';
      }
    });
    return s;
  };
  var sym = mapWho('owner') + mapWho('group') + mapWho('other');

  // Apply special bits to symbolic display
  var setuid = document.getElementById('setuid').checked;
  var setgid = document.getElementById('setgid').checked;
  var sticky = document.getElementById('sticky').checked;

  var chars = sym.split('');
  if (setuid) {
    chars[2] = chars[2] === 'x' ? 's' : 'S';
  }
  if (setgid) {
    chars[5] = chars[5] === 'x' ? 's' : 'S';
  }
  if (sticky) {
    chars[8] = chars[8] === 'x' ? 't' : 'T';
  }

  return chars.join('');
}

function updateFromCheckboxes() {
  var numStr = getNumericString();
  var sym = getSymbolic();
  var baseNum = numStr.length === 4 ? numStr.slice(1) : numStr;

  numericOut.textContent = numStr.length === 4 ? numStr : '0' + numStr;
  symbolicOut.textContent = sym;
  commandOut.textContent = 'chmod ' + numStr + ' filename';

  highlightPreset(baseNum);
}

function highlightPreset(mode) {
  document.querySelectorAll('.preset-btn').forEach(function(b) {
    b.classList.toggle('active', b.dataset.mode === mode);
  });
}

function applyNumeric(mode) {
  var digits;
  if (mode.length === 4) {
    var special = parseInt(mode[0]);
    document.getElementById('setuid').checked = !!(special & 4);
    document.getElementById('setgid').checked = !!(special & 2);
    document.getElementById('sticky').checked = !!(special & 1);
    digits = mode.slice(1);
  } else if (mode.length === 3) {
    document.getElementById('setuid').checked = false;
    document.getElementById('setgid').checked = false;
    document.getElementById('sticky').checked = false;
    digits = mode;
  } else {
    return;
  }

  var categories = ['owner', 'group', 'other'];
  for (var i = 0; i < 3; i++) {
    var val = parseInt(digits[i]);
    if (isNaN(val) || val < 0 || val > 7) return;
    checkboxes.forEach(function(cb) {
      if (cb.dataset.who === categories[i]) {
        if (cb.dataset.perm === 'read') cb.checked = !!(val & 4);
        if (cb.dataset.perm === 'write') cb.checked = !!(val & 2);
        if (cb.dataset.perm === 'execute') cb.checked = !!(val & 1);
      }
    });
  }

  updateFromCheckboxes();
}

function applyFromInput() {
  var val = reverseInput.value.trim();
  if (/^[0-7]{3,4}$/.test(val)) {
    applyNumeric(val);
  }
}

init();
</script>

