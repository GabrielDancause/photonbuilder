---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Best Color Tools for Designers",
    "url": "https://siliconbased.dev/list-color-tools",
    "description": "Interactive, filterable comparison of the best color tools, palette generators, and contrast checkers.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Color Tools for Designers",
    "description": "A curated guide comparing the top free color palette generators, gradient makers, and contrast checkers for designers and developers.",
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    }
  }
];

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Best Color Tools <span>for Designers</span></h1>
  <p>Curated palette generators, contrast checkers, and gradient makers.</p>
</div>

<div class="main">

  <div class="controls-section">
    <div class="filters" id="filterContainer">
      <button class="filter-btn active" data-filter="all">All Tools</button>
      <button class="filter-btn" data-filter="palette">Palette Generators</button>
      <button class="filter-btn" data-filter="contrast">Contrast Checkers</button>
      <button class="filter-btn" data-filter="gradient">Gradients</button>
      <button class="filter-btn" data-filter="picker">Color Pickers</button>
    </div>
    <select class="sort-select" id="sortSelect">
      <option value="rating-desc">Sort by: Rating (High to Low)</option>
      <option value="name-asc">Sort by: Name (A-Z)</option>
    </select>
  </div>

  <div class="grid-container" id="toolsGrid">
    <!-- Cards injected via JS -->
  </div>

  <div class="seo-content">
    <h2>Why do you need specialized color tools?</h2>
    <p>Choosing the right color palette is crucial for any design project. It affects readability, user experience, and brand perception. While most design software includes basic color pickers, specialized color tools provide advanced features like algorithmic palette generation, accessibility checking, and trend analysis.</p>

    <h2>Key features to look for</h2>
    <ul>
      <li><strong>Accessibility checking:</strong> Ensuring your text meets WCAG contrast ratios is non-negotiable for modern web design.</li>
      <li><strong>Export options:</strong> The best tools allow you to easily export palettes as CSS variables, SCSS, JSON, or SVG.</li>
      <li><strong>Color harmony algorithms:</strong> Tools that use mathematical relationships (analogous, complementary, triadic) often produce more reliable results.</li>
      <li><strong>Preview capabilities:</strong> Being able to see how colors look on mock UI elements helps visualize the final result.</li>
    </ul>

    <h2>Free vs. Paid Color Tools</h2>
    <p>The vast majority of excellent color tools available today are completely free or offer very generous free tiers. Open-source tools like Colorbox and Happy Hues provide immense value without a subscription. Paid tools often focus on team collaboration, extensive cloud saving, or integration with specific software ecosystems.</p>
  </div>

</div>

      <div class="card-body">
        <ul class="features-list">
          \${featuresHtml}
        </ul>
        <div class="pros-cons">
          <div>
            <h4>Pros</h4>
            \${prosHtml}
          </div>
          <div>
            <h4>Cons</h4>
            \${consHtml}
          </div>
        </div>
      </div>
      <div class="card-footer">
        <span class="pricing-tag">\${tool.pricing}</span>
        <a href="\${tool.url}" target="_blank" rel="noopener noreferrer" class="visit-btn">
          Visit Site \${extLinkIcon}
        </a>
      </div>
    \`;
    grid.appendChild(card);
  });
}

function filterAndSortTools() {
  const activeFilter = document.querySelector('.filter-btn.active').dataset.filter;
  const sortValue = document.getElementById('sortSelect').value;

  let filtered = [...colorTools];

  if (activeFilter !== 'all') {
    filtered = filtered.filter(t => t.category === activeFilter);
  }

  filtered.sort((a, b) => {
    if (sortValue === 'rating-desc') {
      return b.rating - a.rating;
    } else if (sortValue === 'name-asc') {
      return a.name.localeCompare(b.name);
    }
    return 0;
  });

  renderTools(filtered);
}

// Event Listeners
document.getElementById('filterContainer').addEventListener('click', (e) => {
  if (e.target.classList.contains('filter-btn')) {
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    e.target.classList.add('active');
    filterAndSortTools();
  }
});

document.getElementById('sortSelect').addEventListener('change', filterAndSortTools);

// Initialize immediately since script is at the bottom
filterAndSortTools();
</script>
</div>`
---

<SiteLayout
  site="siliconbased"
  title="Best Color Tools for Designers | Palette Generators &"
  description="Curated list of the best free and open-source color tools for designers. Compare palette generators, contrast checkers, gradient makers, and color pickers."
  canonical="https://siliconbased.dev/list-color-tools"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #0a0b10; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }

.hero { text-align: center; padding: 32px 24px 16px; background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%); }
.hero h1 { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #888; font-size: 0.95rem; }

.main { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Filters & Sorting */
.controls-section { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; background: #111318; padding: 16px; border-radius: 12px; border: 1px solid #1e2030; }
@media (min-width: 768px) {
  .controls-section { flex-direction: row; justify-content: space-between; align-items: center; }
}
.filters { display: flex; flex-wrap: wrap; gap: 8px; }
.filter-btn { background: #1a1c26; border: 1px solid #2a2d40; color: #888; padding: 6px 14px; border-radius: 20px; font-size: 0.85rem; font-family: 'Inter', sans-serif; cursor: pointer; transition: all 0.2s; }
.filter-btn:hover { border-color: #818cf8; color: #e0e0e0; }
.filter-btn.active { background: rgba(129, 140, 248, 0.1); border-color: #818cf8; color: #818cf8; font-weight: 500; }
.sort-select { background: #1a1c26; border: 1px solid #2a2d40; color: #e0e0e0; padding: 8px 12px; border-radius: 8px; font-size: 0.9rem; font-family: 'Inter', sans-serif; cursor: pointer; outline: none; }
.sort-select:focus { border-color: #818cf8; }

/* Grid Layout */
.grid-container { display: grid; grid-template-columns: 1fr; gap: 24px; }
@media (min-width: 768px) {
  .grid-container { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .grid-container { grid-template-columns: repeat(3, 1fr); }
}

/* Card Styling */
.tool-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; position: relative; }
.tool-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4); border-color: #2a2d40; }
.card-header { padding: 20px; border-bottom: 1px solid #1e2030; display: flex; justify-content: space-between; align-items: flex-start; }
.tool-title { font-size: 1.25rem; font-weight: 700; color: #fff; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
.tool-link { color: #fff; text-decoration: none; }
.tool-link:hover { color: #818cf8; }
.tool-tagline { font-size: 0.85rem; color: #888; }
.tool-category { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #818cf8; font-weight: 600; background: rgba(129, 140, 248, 0.1); padding: 2px 8px; border-radius: 4px; display: inline-block; margin-bottom: 8px; }

/* Rating Visuals */
.rating { display: flex; align-items: center; gap: 4px; }
.star { width: 16px; height: 16px; fill: none; stroke: #4b5563; stroke-width: 2; }
.star.filled { fill: #fbbf24; stroke: #fbbf24; }

/* Metrics & Features */
.card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 16px; }
.features-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.features-list li { font-size: 0.9rem; color: #ccc; display: flex; align-items: flex-start; gap: 8px; line-height: 1.4; }
.features-list li svg { width: 16px; height: 16px; color: #4ade80; flex-shrink: 0; margin-top: 2px; }

.pros-cons { display: grid; grid-template-columns: 1fr; gap: 12px; background: #0a0b10; border-radius: 8px; padding: 12px; border: 1px solid #1e2030; }
.pros-cons h4 { font-size: 0.8rem; color: #888; text-transform: uppercase; margin-bottom: 6px; letter-spacing: 0.05em; }
.pro-item, .con-item { font-size: 0.85rem; line-height: 1.3; margin-bottom: 4px; display: flex; gap: 6px; }
.pro-item::before { content: '+'; color: #4ade80; font-family: 'JetBrains Mono', monospace; font-weight: bold; }
.con-item::before { content: '-'; color: #f87171; font-family: 'JetBrains Mono', monospace; font-weight: bold; }

.card-footer { padding: 16px 20px; border-top: 1px solid #1e2030; background: #0a0b10; display: flex; justify-content: space-between; align-items: center; }
.visit-btn { background: #818cf8; color: #fff; text-decoration: none; padding: 6px 14px; border-radius: 6px; font-size: 0.85rem; font-weight: 500; transition: background 0.2s; display: inline-flex; align-items: center; gap: 6px; }
.visit-btn:hover { background: #6366f1; }
.visit-btn svg { width: 14px; height: 14px; }
.pricing-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #9ca3af; background: #1e2030; padding: 2px 6px; border-radius: 4px; }

.empty-state { grid-column: 1 / -1; padding: 48px 24px; text-align: center; color: #666; font-size: 1rem; background: #111318; border: 1px dashed #2a2d40; border-radius: 12px; }

/* SEO Content */
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }

/* Footer */
.footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #555; border-top: 1px solid #151520; margin-top: auto; }
.footer a { color: #818cf8; text-decoration: none; }
.footer a:hover { text-decoration: underline; }

</style>
</SiteLayout>
