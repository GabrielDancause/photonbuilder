---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Concrete Calculator",
  description: "Stop guessing how much concrete you need. Calculate exact cubic yards and bags required for your next slab, footing, or column project.",
  category: "tool",
  published: "2024-01-20",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.published,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How many bags of concrete make a cubic yard?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on the bag size. You need approximately forty-five 80 lb bags or sixty 60 lb bags of concrete to make one cubic yard."
        }
      },
      {
        "@type": "Question",
        "name": "What is the standard concrete bag size?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most common bag sizes found at hardware stores are 60 lb and 80 lb. An 80 lb bag yields about 0.60 cubic feet, while a 60 lb bag yields about 0.45 cubic feet."
        }
      },
      {
        "@type": "Question",
        "name": "How do I calculate cubic yards of concrete?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Multiply length (in feet) by width (in feet) by depth (in feet) to get cubic feet. Then divide that number by 27, because there are 27 cubic feet in one cubic yard."
        }
      },
      {
        "@type": "Question",
        "name": "Why should I add 10% extra concrete?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Subgrades are rarely perfectly level, forms might bow slightly, and spills happen during pouring. Adding 10% to your calculation ensures you don't run out of concrete halfway through your project."
        }
      },
      {
        "@type": "Question",
        "name": "Is it cheaper to mix bags or buy ready-mix concrete?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For small projects under 1 or 2 cubic yards, mixing bags is usually cheaper and more practical. For projects requiring more than 2 cubic yards, ordering a ready-mix truck is often cheaper, significantly faster, and ensures a more consistent mix."
        }
      }
    ]
  }
];
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/concrete-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Concrete Calculator</h1>
      <p class="subtitle">Calculate exact cubic yards and bags required for your project.</p>
    </div>

    <div class="calculator-container">
      <div style="margin-bottom: 1.5rem;">
        <label for="shape" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Project Shape</label>
        <select id="shape" style="max-width: 300px;">
          <option value="slab" selected>Slab / Square Footing</option>
          <option value="hole">Hole / Column / Round Footing</option>
        </select>
      </div>

      <!-- Slab Inputs -->
      <div id="slab-inputs" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
        <div>
          <label for="length" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Length (ft)</label>
          <input type="number" id="length" min="0" step="0.1" value="10" placeholder="e.g., 10">
          <div id="length-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 0.25rem; display: none;">Enter a valid length.</div>
        </div>
        <div>
          <label for="width" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Width (ft)</label>
          <input type="number" id="width" min="0" step="0.1" value="10" placeholder="e.g., 10">
          <div id="width-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 0.25rem; display: none;">Enter a valid width.</div>
        </div>
        <div>
          <label for="thickness" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Thickness / Depth (inches)</label>
          <input type="number" id="thickness" min="0" step="0.1" value="4" placeholder="e.g., 4">
          <div id="thickness-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 0.25rem; display: none;">Enter a valid thickness.</div>
        </div>
      </div>

      <!-- Hole Inputs -->
      <div id="hole-inputs" style="display: none; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
        <div>
          <label for="diameter" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Diameter (inches)</label>
          <input type="number" id="diameter" min="0" step="0.1" value="12" placeholder="e.g., 12">
          <div id="diameter-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 0.25rem; display: none;">Enter a valid diameter.</div>
        </div>
        <div>
          <label for="depth" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Depth (ft)</label>
          <input type="number" id="depth" min="0" step="0.1" value="4" placeholder="e.g., 4">
          <div id="depth-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 0.25rem; display: none;">Enter a valid depth.</div>
        </div>
        <div>
          <label for="quantity" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Quantity (number of holes)</label>
          <input type="number" id="quantity" min="1" step="1" value="1" placeholder="e.g., 1">
          <div id="quantity-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 0.25rem; display: none;">Enter a valid quantity.</div>
        </div>
      </div>

      <div class="result-card">
        <div style="font-size: 1.2rem; font-weight: 600; margin-bottom: 0.5rem;">Total Volume Required</div>
        <div class="result-value" id="volume-result">0.00</div>
        <div style="color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 1.5rem;">Cubic Yards</div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem; text-align: left;">
          <div style="background: var(--bg-color); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
            <div style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.25rem;">80 lb Bags Needed</div>
            <div id="bags-80" style="font-size: 1.8rem; font-weight: 700; color: var(--text-primary);">0</div>
          </div>
          <div style="background: var(--bg-color); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color);">
            <div style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.25rem;">60 lb Bags Needed</div>
            <div id="bags-60" style="font-size: 1.8rem; font-weight: 700; color: var(--text-primary);">0</div>
          </div>
        </div>
        <div style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 1rem; text-align: left;">
          * Results automatically include a 10% overage allowance to account for uneven subgrades and spillage.
        </div>
      </div>

      <div style="text-align: center; margin-top: 1.5rem;">
        <p style="font-size: 0.9rem; color: var(--text-secondary);">Waiting to pour because of winter weather? Check our <a href="/snow-day-calculator" style="color: var(--accent-color); text-decoration: underline;">Snow Day Calculator</a>.</p>
      </div>
    </div>

    <div class="explainer">
      <h2>How the Concrete Calculator Works</h2>
      <p>Whether you are pouring a massive driveway or setting a single fence post, buying the correct amount of concrete is crucial. Buy too little, and you ruin the structural integrity of your pour by introducing cold joints. Buy too much, and you've wasted money on bags that will eventually turn into useless solid blocks in your garage. Our <strong>Concrete Calculator</strong> takes the guesswork out of the process.</p>

      <h3>The Core Methodology: Cubic Yards</h3>
      <p>In the United States, bulk concrete is ordered and measured in <strong>cubic yards</strong>. A cubic yard is a block of material that measures 3 feet long by 3 feet wide by 3 feet deep. Because there are 27 cubic feet in a cubic yard (3 x 3 x 3 = 27), all volume calculations eventually divide by 27.</p>

      <p>Our calculator first determines the volume of your project in cubic feet. For a rectangular slab, it converts the thickness (entered in inches) to feet, then multiplies Length &times; Width &times; Thickness. It then divides that total by 27 to find the exact cubic yardage.</p>

      <h3>Slab vs. Column Calculations</h3>
      <p>The math changes depending on the shape of your project:</p>
      <ul>
        <li><strong>Slabs and Square Footings:</strong> Uses standard rectangular volume. Volume = Length (ft) &times; Width (ft) &times; Depth (ft).</li>
        <li><strong>Holes and Columns (Cylinders):</strong> Uses the formula for the volume of a cylinder. Volume = &pi; &times; radius&sup2; &times; height. The calculator converts your diameter in inches to a radius in feet, squares it, multiplies by Pi, and then multiplies by the depth in feet. It then multiplies by the total quantity of holes you are digging.</li>
      </ul>

      <h3>Why We Add 10% Overage</h3>
      <p>If you look at the raw mathematical output of our formulas compared to the final result on the screen, you will notice the final result is slightly higher. This is intentional. In the concrete industry, adding a <strong>10% waste factor</strong> is a standard best practice. Why? Because the real world is rarely geometrically perfect.</p>
      <p>When you dig a trench for a footing, the bottom is never perfectly flat. When you build wood forms for a slab, the wood might bow outward slightly under the immense pressure of wet concrete. Spillage occurs when moving material from a wheelbarrow to the form. If you calculate the exact mathematical volume without overage, you will almost certainly run out of concrete before finishing the job.</p>

      <h3>Converting Yards to Bags</h3>
      <p>If you are mixing concrete yourself rather than ordering a ready-mix truck, you need to translate cubic yards into physical bags. Bagged concrete mix is sold by weight, but yields a specific volume when mixed with water:</p>
      <ul>
        <li><strong>80 lb bag:</strong> Yields approximately 0.60 cubic feet of wet concrete. It takes 45 bags to equal one cubic yard.</li>
        <li><strong>60 lb bag:</strong> Yields approximately 0.45 cubic feet of wet concrete. It takes 60 bags to equal one cubic yard.</li>
      </ul>
      <p>Our calculator divides your total cubic feet (including the 10% overage) by these yield numbers, and then rounds up to the nearest whole bag, ensuring you head to the hardware store with an exact shopping list.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>How many bags of concrete make a cubic yard?</summary>
        <p>It depends on the bag size. You need approximately forty-five 80 lb bags or sixty 60 lb bags of concrete to make one cubic yard.</p>
      </details>

      <details>
        <summary>What is the standard concrete bag size?</summary>
        <p>The most common bag sizes found at hardware stores are 60 lb and 80 lb. An 80 lb bag yields about 0.60 cubic feet, while a 60 lb bag yields about 0.45 cubic feet.</p>
      </details>

      <details>
        <summary>How do I calculate cubic yards of concrete?</summary>
        <p>Multiply length (in feet) by width (in feet) by depth (in feet) to get cubic feet. Then divide that number by 27, because there are 27 cubic feet in one cubic yard.</p>
      </details>

      <details>
        <summary>Why should I add 10% extra concrete?</summary>
        <p>Subgrades are rarely perfectly level, forms might bow slightly, and spills happen during pouring. Adding 10% to your calculation ensures you don't run out of concrete halfway through your project.</p>
      </details>

      <details>
        <summary>Is it cheaper to mix bags or buy ready-mix concrete?</summary>
        <p>For small projects under 1 or 2 cubic yards, mixing bags is usually cheaper and more practical. For projects requiring more than 2 cubic yards, ordering a ready-mix truck is often cheaper, significantly faster, and ensures a more consistent mix.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    function toggleInputs() {
      const shape = document.getElementById('shape').value;
      if (shape === 'slab') {
        document.getElementById('slab-inputs').style.display = 'grid';
        document.getElementById('hole-inputs').style.display = 'none';
      } else {
        document.getElementById('slab-inputs').style.display = 'none';
        document.getElementById('hole-inputs').style.display = 'grid';
      }
      calculateConcrete();
    }

    function calculateConcrete() {
      const shape = document.getElementById('shape').value;
      let cubicFeet = 0;
      let hasError = false;

      if (shape === 'slab') {
        const lInput = document.getElementById('length');
        const wInput = document.getElementById('width');
        const tInput = document.getElementById('thickness');

        const l = parseFloat(lInput.value);
        const w = parseFloat(wInput.value);
        const t = parseFloat(tInput.value); // inches

        if (isNaN(l) || l <= 0) { document.getElementById('length-error').style.display = 'block'; hasError = true; }
        else { document.getElementById('length-error').style.display = 'none'; }

        if (isNaN(w) || w <= 0) { document.getElementById('width-error').style.display = 'block'; hasError = true; }
        else { document.getElementById('width-error').style.display = 'none'; }

        if (isNaN(t) || t <= 0) { document.getElementById('thickness-error').style.display = 'block'; hasError = true; }
        else { document.getElementById('thickness-error').style.display = 'none'; }

        if (!hasError) {
          cubicFeet = l * w * (t / 12);
        }
      } else {
        const diaInput = document.getElementById('diameter');
        const dInput = document.getElementById('depth');
        const qInput = document.getElementById('quantity');

        const dia = parseFloat(diaInput.value); // inches
        const d = parseFloat(dInput.value); // feet
        const q = parseInt(qInput.value);

        if (isNaN(dia) || dia <= 0) { document.getElementById('diameter-error').style.display = 'block'; hasError = true; }
        else { document.getElementById('diameter-error').style.display = 'none'; }

        if (isNaN(d) || d <= 0) { document.getElementById('depth-error').style.display = 'block'; hasError = true; }
        else { document.getElementById('depth-error').style.display = 'none'; }

        if (isNaN(q) || q <= 0) { document.getElementById('quantity-error').style.display = 'block'; hasError = true; }
        else { document.getElementById('quantity-error').style.display = 'none'; }

        if (!hasError) {
          const radiusFeet = (dia / 2) / 12;
          cubicFeet = Math.PI * (radiusFeet * radiusFeet) * d * q;
        }
      }

      if (hasError) {
        document.getElementById('volume-result').innerText = "0.00";
        document.getElementById('bags-80').innerText = "0";
        document.getElementById('bags-60').innerText = "0";
        return;
      }

      // Add 10% overage
      const totalCubicFeet = cubicFeet * 1.10;
      const cubicYards = totalCubicFeet / 27;

      // Yield constants
      const bag80Yield = 0.60;
      const bag60Yield = 0.45;

      const bags80 = Math.ceil(totalCubicFeet / bag80Yield);
      const bags60 = Math.ceil(totalCubicFeet / bag60Yield);

      document.getElementById('volume-result').innerText = cubicYards.toFixed(2);
      document.getElementById('bags-80').innerText = bags80;
      document.getElementById('bags-60').innerText = bags60;
    }

    // Attach event listeners
    document.getElementById('shape').addEventListener('change', toggleInputs);

    const slabInputs = ['length', 'width', 'thickness'];
    slabInputs.forEach(id => {
      document.getElementById(id).addEventListener('input', calculateConcrete);
      document.getElementById(id).addEventListener('change', calculateConcrete);
    });

    const holeInputs = ['diameter', 'depth', 'quantity'];
    holeInputs.forEach(id => {
      document.getElementById(id).addEventListener('input', calculateConcrete);
      document.getElementById(id).addEventListener('change', calculateConcrete);
    });

    // Initial calc
    calculateConcrete();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; box-sizing: border-box; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 3rem; font-weight: 800; color: var(--accent-color); line-height: 1; margin-top: 0.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .explainer { line-height: 1.6; margin: 3rem 0; }
    .explainer h2 { font-size: 1.8rem; margin-bottom: 1rem; }
    .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 0.75rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer ul { margin-left: 1.5rem; color: var(--text-secondary); margin-bottom: 1rem; }
    .explainer li { margin-bottom: 0.5rem; }
  </style>
</SiteLayout>
