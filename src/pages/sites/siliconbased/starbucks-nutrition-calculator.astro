---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Starbucks Nutrition Calculator",
  description: "Calculate calories, sugar, and caffeine for your custom Starbucks order. Understand the nutritional impact of different milks and syrups instantly.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Starbucks Nutrition Calculator",
    "description": "Calculate calories, sugar, and caffeine for your custom Starbucks order. Understand the nutritional impact of different milks and syrups instantly.",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "datePublished": "2026-03-15"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which milk option has the lowest calories?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Almondmilk is typically the lowest-calorie milk option available at most major coffee chains, usually coming in at around 60-80 calories per cup (8 oz), compared to 120-130 calories for 2% milk or Oatmilk."
        }
      },
      {
        "@type": "Question",
        "name": "How much sugar is in one pump of syrup?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A standard pump of thin syrup (like Vanilla or Caramel) contains approximately 5 grams of sugar and 20 calories. Thicker sauces (like Mocha or White Mocha) contain significantly more, often ranging from 25 to 60 calories per pump."
        }
      },
      {
        "@type": "Question",
        "name": "Does a Venti have more espresso than a Grande?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on if the drink is hot or iced. A hot Venti (20 oz) and a hot Grande (16 oz) both typically contain two shots of espresso. However, an iced Venti (24 oz) generally contains three shots of espresso."
        }
      },
      {
        "@type": "Question",
        "name": "Why is Cold Brew so high in caffeine?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cold brew is made by steeping coffee grounds in cold water for 12 to 24 hours. This extended extraction process pulls significantly more caffeine from the beans compared to a rapid hot water extraction used in standard drip coffee or espresso."
        }
      },
      {
        "@type": "Question",
        "name": "Are these nutritional numbers exact?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, they are estimations. Because café drinks are handcrafted by human baristas, the exact amount of milk poured, ice used, and syrup dispensed will vary slightly from drink to drink. These numbers are based on standard recipe protocols."
        }
      }
    ]
  }
];
---

<SiteLayout site="siliconbased" title="Starbucks Nutrition Calculator" description="Calculate calories, sugar, and caffeine for your custom Starbucks order. Understand the nutritional impact of different milks and syrups instantly." canonical="https://siliconbased.dev/starbucks-nutrition-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Starbucks Nutrition Calculator</h1>
      <p class="subtitle">Estimate calories, sugar, and caffeine for custom coffee orders</p>
    </div>

    <div class="calculator-container" id="calculator">
      <div style="display: grid; gap: 1.5rem; margin-bottom: 2rem;">

        <!-- Drink Type -->
        <div>
          <label for="drink-type" style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Drink Base</label>
          <select id="drink-type">
            <option value="" disabled selected>Select a base drink...</option>
            <option value="latte">Latte / Macchiato</option>
            <option value="mocha">Mocha</option>
            <option value="americano">Americano / Brewed Coffee</option>
            <option value="coldbrew">Cold Brew</option>
            <option value="frappuccino">Frappuccino (Coffee Base)</option>
            <option value="tea">Iced Tea / Refresher (No Milk)</option>
          </select>
        </div>

        <!-- Size -->
        <div>
          <label for="drink-size" style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Size</label>
          <select id="drink-size" disabled>
            <option value="" disabled selected>Select a size...</option>
            <option value="tall">Tall (12 oz)</option>
            <option value="grande">Grande (16 oz)</option>
            <option value="venti_hot">Venti Hot (20 oz)</option>
            <option value="venti_iced">Venti Iced (24 oz)</option>
            <option value="trenta">Trenta (30 oz - Iced Only)</option>
          </select>
        </div>

        <!-- Milk Option -->
        <div id="milk-container">
          <label for="milk-type" style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Milk Type</label>
          <select id="milk-type" disabled>
            <option value="2percent">2% Milk (Default)</option>
            <option value="whole">Whole Milk</option>
            <option value="nonfat">Nonfat Milk</option>
            <option value="oat">Oatmilk</option>
            <option value="almond">Almondmilk</option>
            <option value="soy">Soymilk</option>
            <option value="coconut">Coconutmilk</option>
            <option value="none">No Milk</option>
          </select>
        </div>

        <!-- Syrups -->
        <div>
          <label for="syrup-pumps" style="display: block; font-weight: 600; margin-bottom: 0.5rem;">Syrup Pumps (Regular)</label>
          <div style="display: flex; align-items: center; gap: 1rem;">
            <input type="range" id="syrup-pumps" min="0" max="15" value="0" style="flex: 1; cursor: pointer;" disabled />
            <span id="syrup-value" style="font-weight: 600; width: 40px; text-align: right;">0</span>
          </div>
          <p style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 0.5rem;">Standard pumps (Vanilla, Caramel, Classic, etc.). Excludes thick sauces like Mocha.</p>
        </div>

      </div>

      <div id="error-message" class="error-message">Please select both a Drink Base and a Size to calculate nutrition.</div>

      <div class="result-card" id="result-container" style="display: none; text-align: left;">
        <h3 style="margin-top: 0; margin-bottom: 1.5rem; text-align: center;">Estimated Nutrition</h3>

        <div class="stats-grid">
          <div class="stat-box">
            <div class="stat-label">Calories</div>
            <div class="stat-value" id="res-calories">--</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.25rem;">kcal</div>
          </div>
          <div class="stat-box">
            <div class="stat-label">Sugar</div>
            <div class="stat-value" id="res-sugar">--</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.25rem;">grams</div>
          </div>
          <div class="stat-box">
            <div class="stat-label">Caffeine</div>
            <div class="stat-value" id="res-caffeine">--</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.25rem;">mg</div>
          </div>
        </div>

        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 1.5rem; text-align: center; font-style: italic;">
          *Estimations based on standard barista build protocols and published nutritional averages. Actual values may vary based on specific location and barista pouring technique.
        </p>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Starbucks Nutritional Metrics</h2>
      <p>Customizing a coffee order is a staple of the modern café experience, but those customizations can drastically alter the nutritional profile of your drink. A standard "healthy" coffee can quickly transform into a high-calorie dessert depending on the milk choice, syrup additions, and drink size. This calculator uses standard barista build protocols to estimate the calories, sugar, and caffeine content of your customized beverage.</p>

      <h3>The Impact of Milk Choices</h3>
      <p>The foundation of most espresso-based drinks, like lattes and mochas, is milk. The type of milk you choose plays the largest role in the overall caloric and sugar content of your beverage.</p>

      <p>By default, standard café lattes are made with 2% milk, which offers a balance of creaminess and calorie control. Switching to whole milk significantly increases the fat and calorie content, providing a richer texture. Conversely, nonfat milk reduces the calories significantly but contains roughly the same amount of naturally occurring milk sugar (lactose) as 2% and whole milk.</p>

      <p>Alternative milks have gained massive popularity, but their nutritional profiles vary wildly. Almondmilk is typically the lowest in calories and sugar, making it a favorite for those tracking macros. Oatmilk, while creamy and delicious, is surprisingly high in carbohydrates and calories—often matching or exceeding 2% milk. Soymilk usually contains added vanilla flavoring and sugar unless specified otherwise, contributing to a sweeter profile.</p>

      <h3>Syrups and Sweeteners</h3>
      <p>Standard liquid syrups (like Vanilla, Caramel, Hazelnut, and Classic) are the primary source of added sugars in café drinks. A standard "pump" of these thin syrups generally contains around 20 calories and 5 grams of sugar. Depending on the size of your drink, the number of default pumps varies:</p>

      <ul>
        <li style="margin-bottom: 0.5rem; margin-left: 1.5rem;"><strong>Tall (12 oz):</strong> 3 pumps</li>
        <li style="margin-bottom: 0.5rem; margin-left: 1.5rem;"><strong>Grande (16 oz):</strong> 4 pumps</li>
        <li style="margin-bottom: 0.5rem; margin-left: 1.5rem;"><strong>Venti Hot (20 oz):</strong> 5 pumps</li>
        <li style="margin-bottom: 0.5rem; margin-left: 1.5rem;"><strong>Venti Iced (24 oz):</strong> 6 pumps</li>
      </ul>

      <p>It is important to differentiate between thin syrups and thick sauces. Mocha, White Mocha, and Pumpkin Spice are considered "sauces." Because they contain dairy and thicker ingredients, they are significantly more calorically dense, often coming in at 25 to 60 calories per pump. If you are trying to cut sugar, asking for half the number of standard pumps is an easy way to drastically reduce the caloric load without sacrificing all the flavor.</p>

      <h3>Calculating Caffeine Content</h3>
      <p>Caffeine levels in coffee drinks are primarily dictated by the number of espresso shots or the brewing method used. A standard single shot of espresso contains roughly 75 milligrams of caffeine. Standard hot espresso drinks follow a predictable pattern: Tall gets one shot, while Grande and Venti Hot both get two shots. Interestingly, a Venti Iced drink typically receives three shots, making it significantly more caffeinated than its hot counterpart.</p>

      <p>Brewed coffees and cold brews follow different rules. Because the coffee grounds are steeped for an extended period, cold brew concentrates are highly caffeinated. A Grande Cold Brew can easily exceed 200 milligrams of caffeine, making it one of the strongest options on the menu. If you are sensitive to caffeine, substituting decaf espresso or opting for a shaken iced tea (which averages 25-50mg of caffeine) is recommended.</p>

      <h3>Methodology and Limitations</h3>
      <p>This calculator provides estimations based on standard recipe builds and published nutritional data. To use it, simply select your drink base, size, milk preference, and any added syrups. The JavaScript engine instantly cross-references these inputs against known nutritional constants to generate a live estimation.</p>

      <p>However, it is vital to acknowledge the limitations of programmatic estimation in a manual food-service environment. Baristas free-pour milk and manually pump syrups. A "splash" of milk can range from one to three ounces depending on who is making the drink. Furthermore, seasonal ingredients, limited-time toppings (like cold foams or cookie crumbles), and regional ingredient sourcing can all cause slight variations in the final nutritional values. Always consult official corporate nutritional guides for strict dietary or medical requirements.</p>

      <p>If you're interested in comparing the exact mathematical variance between two different drink builds, you can plug the resulting calorie numbers into our <a href="/percent-difference-calculator" style="color: var(--accent-color); text-decoration: underline;">Percent Difference Calculator</a> to see exactly how much your customizations are changing the baseline order.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>Which milk option has the lowest calories?</summary>
        <p>Almondmilk is typically the lowest-calorie milk option available at most major coffee chains, usually coming in at around 60-80 calories per cup (8 oz), compared to 120-130 calories for 2% milk or Oatmilk.</p>
      </details>
      <details>
        <summary>How much sugar is in one pump of syrup?</summary>
        <p>A standard pump of thin syrup (like Vanilla or Caramel) contains approximately 5 grams of sugar and 20 calories. Thicker sauces (like Mocha or White Mocha) contain significantly more, often ranging from 25 to 60 calories per pump.</p>
      </details>
      <details>
        <summary>Does a Venti have more espresso than a Grande?</summary>
        <p>It depends on if the drink is hot or iced. A hot Venti (20 oz) and a hot Grande (16 oz) both typically contain two shots of espresso. However, an iced Venti (24 oz) generally contains three shots of espresso.</p>
      </details>
      <details>
        <summary>Why is Cold Brew so high in caffeine?</summary>
        <p>Cold brew is made by steeping coffee grounds in cold water for 12 to 24 hours. This extended extraction process pulls significantly more caffeine from the beans compared to a rapid hot water extraction used in standard drip coffee or espresso.</p>
      </details>
      <details>
        <summary>Are these nutritional numbers exact?</summary>
        <p>No, they are estimations. Because café drinks are handcrafted by human baristas, the exact amount of milk poured, ice used, and syrup dispensed will vary slightly from drink to drink. These numbers are based on standard recipe protocols.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // DOM Elements
      const drinkType = document.getElementById('drink-type');
      const drinkSize = document.getElementById('drink-size');
      const milkType = document.getElementById('milk-type');
      const syrupPumps = document.getElementById('syrup-pumps');
      const syrupValue = document.getElementById('syrup-value');

      const resultContainer = document.getElementById('result-container');
      const errorMsg = document.getElementById('error-message');

      const resCalories = document.getElementById('res-calories');
      const resSugar = document.getElementById('res-sugar');
      const resCaffeine = document.getElementById('res-caffeine');

      // Constants for calculations
      // Milk estimates per ounce (approximate standard values)
      const milkStats = {
        '2percent': { cal: 15, sugar: 1.5 },
        'whole': { cal: 18.75, sugar: 1.375 },
        'nonfat': { cal: 11.25, sugar: 1.5 },
        'oat': { cal: 17.5, sugar: 0.875 }, // Varies heavily by brand (Oatly)
        'almond': { cal: 7.5, sugar: 0.375 },
        'soy': { cal: 16.25, sugar: 1.0 }, // Vanilla flavored soy
        'coconut': { cal: 10, sugar: 1.0 },
        'none': { cal: 0, sugar: 0 }
      };

      // Syrup estimates per standard pump
      const syrupStats = { cal: 20, sugar: 5 };

      // Espresso shots per size
      const espressoShots = {
        'tall': 1,
        'grande': 2,
        'venti_hot': 2,
        'venti_iced': 3,
        'trenta': 0 // Usually not applicable for espresso
      };
      const caffeinePerShot = 75; // Approx mg per standard shot

      // Update UI state based on selections
      const updateUI = () => {
        const type = drinkType.value;

        if (type) {
            drinkSize.disabled = false;

            // Handle Trenta logic (only certain iced drinks)
            const trentaOption = Array.from(drinkSize.options).find(o => o.value === 'trenta');
            if (type === 'americano' || type === 'latte' || type === 'mocha' || type === 'frappuccino') {
                if (drinkSize.value === 'trenta') drinkSize.value = '';
                trentaOption.disabled = true;
            } else {
                trentaOption.disabled = false;
            }

            if (drinkSize.value) {
                syrupPumps.disabled = false;

                // Disable milk for non-milk drinks unless specifically requested
                if (type === 'americano' || type === 'coldbrew' || type === 'tea') {
                    // Just a splash, but we'll allow selection and calculate a small amount
                    milkType.disabled = false;
                } else {
                    milkType.disabled = false;
                }
            }
        }

        syrupValue.textContent = syrupPumps.value;
      };

      // Main calculation logic
      const calculate = () => {
        updateUI();

        const type = drinkType.value;
        const size = drinkSize.value;

        if (!type || !size) {
            resultContainer.style.display = 'none';
            errorMsg.style.display = 'block';
            return;
        }

        let totalCal = 0;
        let totalSugar = 0;
        let totalCaffeine = 0;

        const milk = milkType.value;
        const pumps = parseInt(syrupPumps.value, 10);

        // Calculate volumes
        let milkOunces = 0;

        // Base Drink Logic
        if (type === 'latte' || type === 'mocha') {
            // Lattes are mostly milk. Subtract 1oz per shot of espresso.
            const shots = espressoShots[size] || 2;
            totalCaffeine = shots * caffeinePerShot;

            let totalOunces = 16;
            if (size === 'tall') totalOunces = 12;
            if (size === 'venti_hot') totalOunces = 20;
            if (size === 'venti_iced') totalOunces = 24;

            milkOunces = totalOunces - shots;

            if (type === 'mocha') {
                // Base mocha sauce (approx 25 cal, 6g sugar per pump, usually 3-5 pumps depending on size)
                let mochaPumps = size === 'tall' ? 3 : (size === 'grande' ? 4 : 5);
                totalCal += (mochaPumps * 25);
                totalSugar += (mochaPumps * 6);
                totalCaffeine += 10; // Mocha sauce has a tiny bit of caffeine
            }
        }
        else if (type === 'americano') {
            const shots = espressoShots[size] || 2;
            totalCaffeine = shots * caffeinePerShot;
            totalCal += 5; // Espresso trace calories
            milkOunces = milk === 'none' ? 0 : 2; // Splash of milk is ~2oz
        }
        else if (type === 'coldbrew') {
            // Cold brew base caffeine is high
            if (size === 'tall') totalCaffeine = 155;
            if (size === 'grande') totalCaffeine = 205;
            if (size === 'venti_iced') totalCaffeine = 275;
            if (size === 'trenta') totalCaffeine = 360;

            totalCal += 5;
            milkOunces = milk === 'none' ? 0 : 2; // Splash
        }
        else if (type === 'tea') {
            // Shaken iced teas
            if (size === 'tall') totalCaffeine = 25;
            if (size === 'grande') totalCaffeine = 40;
            if (size === 'venti_iced') totalCaffeine = 50;
            if (size === 'trenta') totalCaffeine = 65;
            milkOunces = 0; // Usually no milk
        }
        else if (type === 'frappuccino') {
            // Frapps are complex (Base syrup, whole milk default, frap roast)
            // Baseline approximations for Coffee Frappuccino
            if (size === 'tall') { totalCal = 160; totalSugar = 34; totalCaffeine = 65; milkOunces = 4; }
            if (size === 'grande') { totalCal = 230; totalSugar = 45; totalCaffeine = 95; milkOunces = 6; }
            if (size === 'venti_iced') { totalCal = 310; totalSugar = 63; totalCaffeine = 130; milkOunces = 8; }
            // If they change milk, we must adjust from whole milk baseline
            if (milk !== 'whole' && milk !== 'none') {
                const milkDiffCal = (milkStats[milk].cal - milkStats['whole'].cal) * milkOunces;
                const milkDiffSugar = (milkStats[milk].sugar - milkStats['whole'].sugar) * milkOunces;
                totalCal += milkDiffCal;
                totalSugar += milkDiffSugar;
            }
            if(milk === 'none') {
                 totalCal -= milkStats['whole'].cal * milkOunces;
                 totalSugar -= milkStats['whole'].sugar * milkOunces;
            }
        }

        // Add milk nutrition (for non-frapps, as frapps handled above)
        if (type !== 'frappuccino' && milk !== 'none') {
            totalCal += milkOunces * milkStats[milk].cal;
            totalSugar += milkOunces * milkStats[milk].sugar;
        }

        // Add syrups
        totalCal += pumps * syrupStats.cal;
        totalSugar += pumps * syrupStats.sugar;

        // Display results
        resultContainer.style.display = 'block';
        errorMsg.style.display = 'none';

        // Animate numbers (simple instantaneous update for now)
        resCalories.textContent = Math.max(0, Math.round(totalCal));
        resSugar.textContent = Math.max(0, Math.round(totalSugar));
        resCaffeine.textContent = Math.max(0, Math.round(totalCaffeine));
      };

      // Event Listeners
      drinkType.addEventListener('change', calculate);
      drinkSize.addEventListener('change', calculate);
      milkType.addEventListener('change', calculate);
      syrupPumps.addEventListener('input', calculate);

    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
