    .back-link:hover { text-decoration: underline; }

    .article-body { font-size: 1.1rem; line-height: 1.6; color: var(--text-primary); }
    .article-body h2 { margin-top: 2.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; color: var(--accent-color); }
    .article-body h3 { margin-top: 2rem; }
    .article-body p { margin-bottom: 1.5rem; }
    .article-body ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
