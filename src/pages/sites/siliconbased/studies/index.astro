---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const contentPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/siliconbased_studies.html');
const htmlContent = fs.readFileSync(contentPath, 'utf-8');

const cssPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/siliconbased_studies.css');
let cssContent = '';
try { cssContent = fs.readFileSync(cssPath, 'utf-8'); } catch {}
---

<SiteLayout
  site="siliconbased"
  title="Original Research & Studies | siliconbased.dev"
  description="Original research studies with real data. Security headers, page weight, CSS frameworks, API benchmarks, and more."
  canonical="https://{}/studies/"
>
  <Fragment set:html={htmlContent} />
  {cssContent && <style is:inline set:html={cssContent} />}
</SiteLayout>
