        }
      },
      {
        "@type": "Question",
        "name": "What is a two-sided marketplace in software architecture?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A two-sided marketplace is an application architecture designed to serve two distinct user personas (e.g., buyers and sellers, or homeowners and contractors) requiring distinct interfaces, permissions, and workflows."
        }
      },
      {
        "@type": "Question",
        "name": "How do you calculate average ratings efficiently in a database?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Instead of dynamically calculating averages on every read request, platforms use denormalization. They store the average rating directly on the provider's profile row and update it via background jobs or triggers when new reviews arrive."
        }
      },
      {
        "@type": "Question",
        "name": "How are geographic searches handled in backend systems?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Backend systems utilize spatial databases (like PostGIS for PostgreSQL) or search engines (like Elasticsearch) that support specialized geospatial index types to calculate distance and bounding boxes efficiently."
        }
