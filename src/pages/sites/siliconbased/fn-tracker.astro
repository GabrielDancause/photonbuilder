---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "FN Tracker - Fortnite Sensitivity & eDPI Calculator",
  description: "Why is your aim inconsistent? Use our free FN Tracker to calculate your true eDPI, optimize your Fortnite sensitivity, and compare your stats against top pros.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "FN Tracker - Fortnite Sensitivity & eDPI Calculator",
      "description": "Why is your aim inconsistent? Use our free FN Tracker to calculate your true eDPI, optimize your Fortnite sensitivity, and compare your stats against top pros.",
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      },
      "publisher": {
        "@type": "Organization",
        "name": "SiliconBased",
        "logo": {
          "@type": "ImageObject",
          "url": "https://siliconbased.dev/logo.png"
        }
      },
      "datePublished": "2026-03-15"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does eDPI mean in Fortnite?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "eDPI stands for 'Effective Dots Per Inch.' It is a standardized metric used to compare sensitivities across different hardware by multiplying your mouse DPI by your in-game sensitivity. For example, 800 DPI at 5% sensitivity yields an eDPI of 40."
          }
        },
        {
          "@type": "Question",
          "name": "What is the best eDPI for Fortnite?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There is no single 'best' eDPI, as it relies heavily on personal preference and mousepad size. However, the vast majority of professional Fortnite players use an eDPI ranging from 36 to 72. This range offers a sweet spot between the precise aim needed for shooting and the speed needed for building and editing."
          }
        },
        {
          "@type": "Question",
          "name": "What does cm/360 mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "cm/360 (Centimeters per 360) is the physical distance you must move your mouse across your mousepad to perform a complete 360-degree turn in-game. It is an objective measurement of your sensitivity that is independent of game settings or screen resolution."
          }
        },
        {
          "@type": "Question",
          "name": "Should my Targeting Sensitivity be 100%?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Many players lower their Targeting (ADS) sensitivity to between 30% and 60%. Lowering this setting allows you to have a fast general sensitivity for building and editing, while automatically slowing down your crosshair when you aim down sights for precise AR shots."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my aim inconsistent in Fortnite?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Inconsistent aim is often caused by an eDPI that is too high, leading to over-flicking or 'shaky' crosshair tracking. Using our FN Tracker to lower your eDPI into the 40-60 range, ensuring 'Enhance Pointer Precision' is disabled in Windows, and practicing in aim trainers can quickly resolve inconsistency."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/fn-tracker" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>FN Tracker: Sensitivity & eDPI Calculator</h1>
      <p class="subtitle">Calculate your effective DPI (eDPI) to dial in your Fortnite aim and track your sensitivity metrics.</p>
    </div>

    <div class="calculator-container">
      <div class="input-group">
        <label for="mouseDpi">Mouse DPI</label>
        <input type="number" id="mouseDpi" placeholder="e.g. 800" min="100" step="50" value="800">
        <div class="error-msg" id="dpiError">Please enter a valid Mouse DPI (e.g. 400, 800).</div>
      </div>

      <div class="input-group">
        <label for="inGameSens">In-Game Sensitivity (%)</label>
        <input type="number" id="inGameSens" placeholder="e.g. 7.5" min="0.1" step="0.1" value="7.5">
        <div class="error-msg" id="sensError">Please enter a valid in-game sensitivity percentage.</div>
      </div>

      <div class="input-group">
        <label for="targetingSens">Targeting/ADS Sensitivity (%)</label>
        <input type="number" id="targetingSens" placeholder="e.g. 50" min="1" step="1" value="50">
        <div class="error-msg" id="targetingError">Please enter a valid ADS sensitivity percentage.</div>
      </div>

      <div class="result-card" id="resultCard">
        <div style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Your Fortnite eDPI</div>
        <div class="result-value" id="resultEdpi">60.0</div>

        <div class="metric-grid">
          <div class="metric-box">
            <div class="metric-title">Targeting eDPI</div>
            <div class="metric-val" id="targetingEdpi">30.0</div>
          </div>
          <div class="metric-box">
            <div class="metric-title">cm / 360°</div>
            <div class="metric-val" id="cmPer360">27.3</div>
          </div>
        </div>

        <div style="margin-top: 1.5rem; text-align: left; background: var(--bg-color); padding: 1rem; border-radius: 8px;">
          <strong style="color: var(--text-primary); display: block; margin-bottom: 0.5rem;">Pro Analysis:</strong>
          <span id="proAnalysis" style="color: var(--text-secondary); font-size: 0.95rem;"></span>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Mastering Your Fortnite Aim: The Ultimate FN Tracker & eDPI Guide</h2>
      <p>
        In Fortnite, building and editing are only half the battle. If you cannot hit your shotgun flicks or track an opponent gliding through the air with your Assault Rifle, you will struggle to secure Victory Royales or perform well in competitive arenas. Finding the perfect sensitivity is the first, and arguably most crucial, step in mastering Fortnite mechanics. Our FN Tracker is designed to help you decode your sensitivity, calculate your true effective DPI (eDPI), and objectively compare your settings against the best professional players in the world.
      </p>
      <p>
        Whether you are a casual player looking to improve consistency, or an aspiring competitive player trying to mimic the mechanics of World Cup champions, understanding your raw sensitivity metrics is essential. Too many players endlessly copy and paste sensitivities from their favorite streamers without understanding the underlying math, leading to a destroyed muscle memory and erratic, unpredictable crosshair placement.
      </p>

      <h3>What is eDPI and Why Does it Matter?</h3>
      <p>
        If you ask a friend what their Fortnite sensitivity is, they might say "I play on 8%." But 8% means absolutely nothing without knowing their mouse DPI (Dots Per Inch). A player using 8% sensitivity on a 400 DPI mouse is playing on a drastically slower setup than someone using 8% on a 1600 DPI mouse. Without combining the two metrics, comparing numbers is completely useless.
      </p>
      <p>
        <strong>eDPI (Effective Dots Per Inch)</strong> is the great equalizer. It is a standardized mathematical formula used across all PC games to normalize sensitivity regardless of hardware. The formula is incredibly simple and serves as the backbone of our FN Tracker tool:
      </p>
      <div style="background: rgba(129, 140, 248, 0.1); padding: 1rem; border-radius: 8px; border-left: 4px solid var(--accent-color); margin: 1.5rem 0; font-family: monospace; font-size: 1.1rem;">
        eDPI = Mouse DPI &times; In-Game Sensitivity (as a decimal)
      </div>
      <p>
        For instance, if you use 800 DPI and a 5.0% in-game sensitivity, your calculation is <code>800 &times; 0.05 = 40 eDPI</code>. Alternatively, if you use 400 DPI and a 10.0% sensitivity, your eDPI is exactly the same (40 eDPI), meaning the in-game feel is identical. Knowing your eDPI allows you to instantly compare your setup with pros like Bugha (who hovers around 40 eDPI) or MrSavage (who is known for playing on incredibly high sensitivities).
      </p>

      <h3>The "Golden Zone" of Fortnite Sensitivity</h3>
      <p>
        Fortnite presents a unique challenge for PC gamers. Traditional tactical shooters like Valorant or CS:GO require extremely low sensitivities because the gameplay revolves around holding angles, slow peeking, and precise micro-adjustments on tiny targets. Arena shooters like Overwatch or Quake require high sensitivities for rapid 180-degree turns to track highly mobile targets.
      </p>
      <p>
        Fortnite requires <em>both</em>. You need low sensitivity for long-range AR tracking and consistent, perfectly placed shotgun flicks, but you desperately need high sensitivity to quickly box up, do 90s, and perform complex edit courses without throwing your arm out of its socket. Striking this balance is the holy grail of Fortnite mechanics.
      </p>
      <p>
        After analyzing hundreds of professional Fortnite players, a "Golden Zone" has emerged. The vast majority of top-tier pros use an eDPI between <strong>36 and 72</strong>.
      </p>
      <ul>
        <li><strong>Low-End (36 - 48 eDPI):</strong> Favors incredible crosshair placement and consistent shotgun aim. Players here use their entire arm to aim and build. You will need an XL or XXL mousepad to use this range effectively, and your arm may get tired during long sessions of intense creative building.</li>
        <li><strong>Mid-Range (48 - 60 eDPI):</strong> The absolute sweet spot for most players. It offers enough speed to build effortlessly with wrist and forearm movements while retaining solid AR tracking. This is the safest range to start in if you are trying to find your perfect sensitivity.</li>
        <li><strong>High-End (60 - 72+ eDPI):</strong> Highly mechanical players who favor lightning-fast piece control and editing often play here. Aiming requires high precision wrist control, as tiny movements translate to large crosshair shifts in-game. Be warned: it takes hundreds of hours of aim training to hit pump shots consistently at this eDPI.</li>
      </ul>

      <h3>Understanding the cm/360° Metric</h3>
      <p>
        While eDPI is a great metric specifically for Fortnite, our FN Tracker also calculates your <strong>cm/360°</strong>. This metric stands for "Centimeters per 360 degrees." It represents the physical, real-world distance you have to move your mouse across your desk to perform one complete rotation in the game. It is the gold standard for aiming nerds.
      </p>
      <p>
        cm/360 is the ultimate universal sensitivity tracker. It removes game-specific engine math entirely. If you play multiple games (e.g., you switch between Fortnite, Apex Legends, and Valorant), knowing your cm/360 allows you to translate your exact feel across different gaming engines. If your Fortnite cm/360 is 30cm, you can use sensitivity converters to ensure your Apex Legends sensitivity is also exactly 30cm per 360, preserving your muscle memory perfectly across titles.
      </p>

      <h3>Targeting (ADS) and Scope Sensitivity Optimization</h3>
      <p>
        Fortnite features an independent multiplier for Targeting (Aiming Down Sights). When you hold right-click to aim your Assault Rifle or SMG, your sensitivity automatically changes based on a percentage of your base sensitivity.
      </p>
      <p>
        Most professionals keep their Targeting sensitivity between <strong>30% and 60%</strong>. This is a brilliant mechanical strategy because it allows you to have a fast base eDPI for editing and building quickly with wrist flicks, but the moment you ADS, your crosshair slows down drastically. This gives you the low-sensitivity precision needed for long-range laser accuracy and tracking players out of the sky.
      </p>
      <p>
        Our FN tracker automatically calculates your effective Targeting eDPI so you can fine-tune this specific phase. If you notice your AR tracking is constantly trailing behind moving targets, you likely need to raise your Targeting sensitivity. Conversely, if you constantly over-flick and miss shots in front of the target, you should lower it. Use the calculator to slowly dial in the number until your tracking becomes smooth and effortless.
      </p>
    </div>

    <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; margin: 2rem 0; text-align: center;">
      <h3 style="margin-top: 0;">Explore Our Other Tools</h3>
      <p style="margin-bottom: 0;">Are you a service member optimizing your housing budget? Use our <a href="/bah-calculator" style="color: var(--accent-color); font-weight: 600; text-decoration: none;">2026 BAH Calculator</a> to accurately estimate your military housing allowance.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>What does eDPI mean in Fortnite?</summary>
        <p>eDPI stands for "Effective Dots Per Inch." It is a standardized metric used to compare sensitivities across different hardware by multiplying your mouse DPI by your in-game sensitivity. For example, 800 DPI at 5% sensitivity yields an eDPI of 40.</p>
      </details>

      <details>
        <summary>What is the best eDPI for Fortnite?</summary>
        <p>There is no single "best" eDPI, as it relies heavily on personal preference and mousepad size. However, the vast majority of professional Fortnite players use an eDPI ranging from 36 to 72. This range offers a sweet spot between the precise aim needed for shooting and the speed needed for building and editing.</p>
      </details>

      <details>
        <summary>What does cm/360 mean?</summary>
        <p>cm/360 (Centimeters per 360) is the physical distance you must move your mouse across your mousepad to perform a complete 360-degree turn in-game. It is an objective measurement of your sensitivity that is independent of game settings or screen resolution.</p>
      </details>

      <details>
        <summary>Should my Targeting Sensitivity be 100%?</summary>
        <p>Many players lower their Targeting (ADS) sensitivity to between 30% and 60%. Lowering this setting allows you to have a fast general sensitivity for building and editing, while automatically slowing down your crosshair when you aim down sights for precise AR shots.</p>
      </details>

      <details>
        <summary>Why is my aim inconsistent in Fortnite?</summary>
        <p>Inconsistent aim is often caused by an eDPI that is too high, leading to over-flicking or "shaky" crosshair tracking. Using our FN Tracker to lower your eDPI into the 40-60 range, ensuring "Enhance Pointer Precision" is disabled in Windows, and practicing in aim trainers can quickly resolve inconsistency.</p>
      </details>
    </section>

  </div>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .input-group { margin-bottom: 1.5rem; }
    .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .metric-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem; }
    .metric-box { background: var(--bg-color); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); text-align: center; }
    .metric-title { font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; }
    .metric-val { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .error-msg { color: #ef4444; font-size: 0.875rem; margin-top: 0.5rem; display: none; }
    input.invalid { border-color: #ef4444; }
  </style>

  <script is:inline>
    const mouseDpiInput = document.getElementById('mouseDpi');
    const inGameSensInput = document.getElementById('inGameSens');
    const targetingSensInput = document.getElementById('targetingSens');

    const dpiError = document.getElementById('dpiError');
    const sensError = document.getElementById('sensError');
    const targetingError = document.getElementById('targetingError');

    const resultEdpi = document.getElementById('resultEdpi');
    const targetingEdpi = document.getElementById('targetingEdpi');
    const cmPer360 = document.getElementById('cmPer360');
    const proAnalysis = document.getElementById('proAnalysis');

    function calculate() {
      const dpiStr = mouseDpiInput.value;
      const sensStr = inGameSensInput.value;
      const targetingStr = targetingSensInput.value;

      let isValid = true;
      const dpi = parseFloat(dpiStr);
      const sens = parseFloat(sensStr);
      const targeting = parseFloat(targetingStr);

      if (isNaN(dpi) || dpi <= 0) {
        isValid = false;
        mouseDpiInput.classList.add('invalid');
        dpiError.style.display = 'block';
      } else {
        mouseDpiInput.classList.remove('invalid');
        dpiError.style.display = 'none';
      }

      if (isNaN(sens) || sens <= 0) {
        isValid = false;
        inGameSensInput.classList.add('invalid');
        sensError.style.display = 'block';
      } else {
        inGameSensInput.classList.remove('invalid');
        sensError.style.display = 'none';
      }

      if (isNaN(targeting) || targeting <= 0) {
        isValid = false;
        targetingSensInput.classList.add('invalid');
        targetingError.style.display = 'block';
      } else {
        targetingSensInput.classList.remove('invalid');
        targetingError.style.display = 'none';
      }

      if (isValid) {
        // eDPI = DPI * (Sensitivity / 100)  -- however in Fortnite community it's commonly calculated as DPI * Sensitivity (as a raw number, i.e. 800 * 0.075)
        // Since input is percentage e.g. 7.5% -> multiplier is 0.075
        const edpi = dpi * (sens / 100);
        const tgtEdpi = edpi * (targeting / 100);

        // Fortnite specific yaw formula: degrees per dot = 0.005539
        // 360 / (DPI * (Sens/100) * 0.005539 * 2.54)
        // Correct approx: 1636.3636 / eDPI = cm/360
        const cm360 = 1636.3636 / edpi;

        resultEdpi.textContent = edpi.toFixed(1);
        targetingEdpi.textContent = tgtEdpi.toFixed(1);
        cmPer360.textContent = cm360.toFixed(1);

        let analysisText = "";
        if (edpi < 36) {
          analysisText = "Your eDPI is exceptionally low. This provides extreme accuracy for AR tracking but makes building and quick 180-degree turns very difficult. You likely need a massive mousepad.";
        } else if (edpi >= 36 && edpi <= 72) {
          analysisText = "This is the 'Golden Zone' for Fortnite. The vast majority of top-tier pros (like Bugha, Mongraal, and Peterbot) play within this eDPI range. It offers a perfect balance between precise aiming and fast building/editing mechanics.";
        } else if (edpi > 72 && edpi <= 120) {
          analysisText = "Your eDPI is on the higher side. This is great for fast tunneling and editing without much arm movement, but may result in shaky crosshair placement during long-range AR engagements. (Players like MrSavage use high sensitivities successfully).";
        } else {
          analysisText = "Your eDPI is extremely high. While you can build with tiny wrist movements, consistency in shotgun fights and AR tracking will be incredibly difficult to master.";
        }

        proAnalysis.textContent = analysisText;
      }
    }

    [mouseDpiInput, inGameSensInput, targetingSensInput].forEach(el => {
      el.addEventListener('input', calculate);
      el.addEventListener('change', calculate);
    });

    // Initial calculation
    calculate();
  </script>
</SiteLayout>
