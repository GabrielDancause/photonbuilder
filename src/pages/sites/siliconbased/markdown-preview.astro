---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Markdown Editor — Live Markdown Preview Online",
      "url": "https://siliconbased.dev/markdown-preview",
      "description": "Free online markdown editor with live preview, toolbar formatting, GFM support, full-screen mode, and HTML export. Write and preview markdown instantly in your browser.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a markdown editor?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A markdown editor is a tool that lets you write text using Markdown syntax and see the formatted output in real time. Markdown is a lightweight markup language that uses simple characters like # for headings, ** for bold, and - for lists to format text without HTML. This editor shows a live preview of your Markdown as rendered HTML side by side."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use this live markdown preview?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Type or paste Markdown into the left editor panel. The right panel instantly renders a live HTML preview. Use the toolbar buttons to insert formatting like bold, italic, headings, links, images, code blocks, lists, blockquotes, tables, and horizontal rules. You can also copy the rendered HTML or download your Markdown as a .md file."
          }
        },
        {
          "@type": "Question",
          "name": "What is GitHub Flavored Markdown (GFM)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "GitHub Flavored Markdown (GFM) extends standard Markdown with features used on GitHub: tables with pipe syntax, strikethrough with ~~tildes~~, task lists with [ ] checkboxes, and fenced code blocks with language labels for syntax highlighting. This editor fully supports all GFM features."
          }
        },
        {
          "@type": "Question",
          "name": "Can I export the output as HTML?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Click the 'Copy HTML' button to copy the rendered HTML to your clipboard. You can also download the raw Markdown as a .md file using the 'Download .md' button. Both options make it easy to use your content in websites, documentation, or other platforms."
          }
        },
        {
          "@type": "Question",
          "name": "Does this editor support code blocks with syntax highlighting?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Use fenced code blocks with triple backticks and an optional language identifier (e.g., ```javascript). The preview renders code blocks with a language label and monospace formatting. This is especially useful for writing technical documentation and README files."
          }
        },
        {
          "@type": "Question",
          "name": "Is my data safe in this markdown editor?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. This markdown editor runs entirely in your browser using JavaScript. No data is sent to any server. Your content never leaves your device, making it completely safe for editing private or sensitive documents."
          }
        },
        {
          "@type": "Question",
          "name": "What markdown syntax does this editor support?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This editor supports the full CommonMark specification plus GitHub Flavored Markdown extensions: headings (# to ######), bold (**text**), italic (*text*), strikethrough (~~text~~), links, images, ordered and unordered lists, task lists, blockquotes, code blocks, inline code, tables, and horizontal rules."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Markdown Editor — Live Markdown Preview Online",
      "description": "Free online markdown editor with live preview, toolbar formatting, GFM support, and HTML export.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Markdown Editor</h1>
  <p>Write markdown and see a live HTML preview instantly. GFM support, toolbar formatting, full-screen mode — all in your browser.</p>
</div>

<div class="main">

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="toolbar-left">
      <button class="tb-btn" id="tbBold" title="Bold (Ctrl+B)"><strong>B</strong></button>
      <button class="tb-btn" id="tbItalic" title="Italic (Ctrl+I)"><em>I</em></button>
      <button class="tb-btn" id="tbStrike" title="Strikethrough"><s>S</s></button>
      <span class="tb-sep"></span>
      <button class="tb-btn" id="tbH1" title="Heading 1">H1</button>
      <button class="tb-btn" id="tbH2" title="Heading 2">H2</button>
      <button class="tb-btn" id="tbH3" title="Heading 3">H3</button>
      <span class="tb-sep"></span>
      <button class="tb-btn" id="tbLink" title="Link">&#128279;</button>
      <button class="tb-btn" id="tbImage" title="Image">&#128247;</button>
      <button class="tb-btn" id="tbCode" title="Inline code">&lt;/&gt;</button>
      <button class="tb-btn" id="tbCodeBlock" title="Code block">{ }</button>
      <span class="tb-sep"></span>
      <button class="tb-btn" id="tbUl" title="Unordered list">&#8226; List</button>
      <button class="tb-btn" id="tbOl" title="Ordered list">1. List</button>
      <button class="tb-btn" id="tbTask" title="Task list">&#9744;</button>
      <button class="tb-btn" id="tbQuote" title="Blockquote">&gt;</button>
      <button class="tb-btn" id="tbTable" title="Table">&#9638;</button>
      <button class="tb-btn" id="tbHr" title="Horizontal rule">&#8212;</button>
    </div>
    <div class="toolbar-right">
      <button class="action-btn" id="sampleBtn">Sample</button>
      <button class="action-btn" id="clearBtn">Clear</button>
      <button class="action-btn" id="fullscreenBtn">&#9974; Fullscreen</button>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="stats-bar">
    <span id="wordCount">0 words</span>
    <span class="stats-sep">|</span>
    <span id="charCount">0 characters</span>
    <div class="stats-right">
      <button class="export-btn" id="copyHtmlBtn">Copy HTML</button>
      <button class="export-btn" id="downloadMdBtn">Download .md</button>
    </div>
  </div>

  <!-- Split pane -->
  <div class="split-pane" id="splitPane">
    <div class="pane editor-pane">
      <div class="pane-header">
        <div class="header-title">Markdown</div>
      </div>
      <textarea id="mdInput" class="md-input" spellcheck="false" placeholder="Type your markdown here..."></textarea>
    </div>
    <div class="pane preview-pane">
      <div class="pane-header">
        <div class="header-title">Preview</div>
      </div>
      <div id="preview" class="preview-area"></div>
    </div>
  </div>

  <!-- Markdown Cheatsheet -->
  <div class="ref-section">
    <div class="pane-header">
      <div class="header-title">Markdown Cheatsheet</div>
    </div>
    <div class="ref-grid">
      <div class="ref-card">
        <div class="ref-card-title">Headings</div>
        <code># Heading 1</code>
        <code>## Heading 2</code>
        <code>### Heading 3</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Emphasis</div>
        <code>**bold**</code>
        <code>*italic*</code>
        <code>~~strikethrough~~</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Links &amp; Images</div>
        <code>[text](url)</code>
        <code>![alt](src)</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Lists</div>
        <code>- unordered item</code>
        <code>1. ordered item</code>
        <code>- [x] task item</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Code</div>
        <code>\`inline code\`</code>
        <code>\`\`\`lang ... \`\`\`</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Other</div>
        <code>&gt; blockquote</code>
        <code>--- (horizontal rule)</code>
        <code>| table | cols |</code>
      </div>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a Markdown Editor?</h2>
    <p>A markdown editor is an online tool for writing and previewing Markdown — the lightweight markup language created by John Gruber. Markdown lets you format text using simple characters: # for headings, ** for bold, * for italic, - for lists, and more. This live markdown preview editor shows you the rendered HTML output as you type, making it easy to write README files, documentation, blog posts, and notes.</p>

    <h2>Why Use a Live Markdown Preview?</h2>
    <ul>
      <li><strong>Instant feedback:</strong> See your formatted output in real time as you type, catching formatting errors immediately.</li>
      <li><strong>No installation:</strong> Runs entirely in your browser — no extensions, plugins, or desktop apps required.</li>
      <li><strong>GitHub-ready:</strong> Full GFM (GitHub Flavored Markdown) support including tables, task lists, strikethrough, and fenced code blocks.</li>
      <li><strong>Export options:</strong> Copy rendered HTML for pasting into websites or download your content as a .md file for use anywhere.</li>
      <li><strong>Private &amp; secure:</strong> All processing happens client-side. Your content never leaves your device.</li>
    </ul>

    <h2>Supported Markdown Syntax</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Syntax</th>
          <th>Output</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <tr><td><code># Heading</code></td><td>Heading 1</td><td>Supports h1 through h6</td></tr>
        <tr><td><code>**bold**</code></td><td><strong>bold</strong></td><td>Double asterisks</td></tr>
        <tr><td><code>*italic*</code></td><td><em>italic</em></td><td>Single asterisks</td></tr>
        <tr><td><code>~~strike~~</code></td><td><del>strike</del></td><td>GFM strikethrough</td></tr>
        <tr><td><code>[text](url)</code></td><td>Link</td><td>Inline link format</td></tr>
        <tr><td><code>![alt](src)</code></td><td>Image</td><td>Inline image format</td></tr>
        <tr><td><code>- item</code></td><td>Unordered list</td><td>Also supports * and +</td></tr>
        <tr><td><code>1. item</code></td><td>Ordered list</td><td>Numbered list items</td></tr>
        <tr><td><code>- [x] task</code></td><td>Task list</td><td>GFM task checkboxes</td></tr>
        <tr><td><code>\`code\`</code></td><td><code>code</code></td><td>Inline code</td></tr>
        <tr><td><code>\`\`\`js ... \`\`\`</code></td><td>Code block</td><td>Fenced with language label</td></tr>
        <tr><td><code>&gt; quote</code></td><td>Blockquote</td><td>Nested blockquotes supported</td></tr>
        <tr><td><code>| a | b |</code></td><td>Table</td><td>GFM pipe tables</td></tr>
        <tr><td><code>---</code></td><td>Horizontal rule</td><td>Three or more dashes</td></tr>
      </tbody>
    </table>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a markdown editor?</h3>
      <p style="margin-bottom: 16px;">A markdown editor is a tool that lets you write text using Markdown syntax and see the formatted output in real time. Markdown is a lightweight markup language that uses simple characters like # for headings, ** for bold, and - for lists to format text without HTML. This editor shows a live preview of your Markdown as rendered HTML side by side.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I use this live markdown preview?</h3>
      <p style="margin-bottom: 16px;">Type or paste Markdown into the left editor panel. The right panel instantly renders a live HTML preview. Use the toolbar buttons to insert formatting like bold, italic, headings, links, images, code blocks, lists, blockquotes, tables, and horizontal rules. You can also copy the rendered HTML or download your Markdown as a .md file.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is GitHub Flavored Markdown (GFM)?</h3>
      <p style="margin-bottom: 16px;">GitHub Flavored Markdown (GFM) extends standard Markdown with features used on GitHub: tables with pipe syntax, strikethrough with ~~tildes~~, task lists with [ ] checkboxes, and fenced code blocks with language labels for syntax highlighting. This editor fully supports all GFM features.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I export the output as HTML?</h3>
      <p style="margin-bottom: 16px;">Yes. Click the 'Copy HTML' button to copy the rendered HTML to your clipboard. You can also download the raw Markdown as a .md file using the 'Download .md' button. Both options make it easy to use your content in websites, documentation, or other platforms.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Does this editor support code blocks with syntax highlighting?</h3>
      <p style="margin-bottom: 16px;">Yes. Use fenced code blocks with triple backticks and an optional language identifier (e.g., \`\`\`javascript). The preview renders code blocks with a language label and monospace formatting. This is especially useful for writing technical documentation and README files.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is my data safe in this markdown editor?</h3>
      <p style="margin-bottom: 16px;">Absolutely. This markdown editor runs entirely in your browser using JavaScript. No data is sent to any server. Your content never leaves your device, making it completely safe for editing private or sensitive documents.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What markdown syntax does this editor support?</h3>
      <p style="margin-bottom: 16px;">This editor supports the full CommonMark specification plus GitHub Flavored Markdown extensions: headings (# to ######), bold (**text**), italic (*text*), strikethrough (~~text~~), links, images, ordered and unordered lists, task lists, blockquotes, code blocks, inline code, tables, and horizontal rules.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/html-to-markdown-converter">HTML to Markdown Converter</a> — Convert HTML markup to clean Markdown syntax with live preview.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions online with real-time highlighting.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "Markdown Editor — Live Markdown Preview Online",
  description: "Free online markdown editor with live preview, toolbar formatting, GFM support, full-screen mode, and HTML export. Write and preview markdown instantly in your browser.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="Markdown Editor — Live Markdown Preview Online"
  description="Free online markdown editor with live preview, toolbar formatting, GFM support, full-screen mode, and HTML export. Write and preview markdown instantly in your browser."
  canonical="https://siliconbased.dev/markdown-preview"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const mdInput = document.getElementById('mdInput');
const preview = document.getElementById('preview');
const splitPane = document.getElementById('splitPane');
const wordCountEl = document.getElementById('wordCount');
const charCountEl = document.getElementById('charCount');

/* ── Toolbar actions ── */
const tbActions = {
  tbBold: { prefix: '**', suffix: '**', placeholder: 'bold text' },
  tbItalic: { prefix: '*', suffix: '*', placeholder: 'italic text' },
  tbStrike: { prefix: '~~', suffix: '~~', placeholder: 'strikethrough' },
  tbH1: { prefix: '# ', suffix: '', placeholder: 'Heading 1', line: true },
  tbH2: { prefix: '## ', suffix: '', placeholder: 'Heading 2', line: true },
  tbH3: { prefix: '### ', suffix: '', placeholder: 'Heading 3', line: true },
  tbLink: { prefix: '[', suffix: '](url)', placeholder: 'link text' },
  tbImage: { prefix: '![', suffix: '](url)', placeholder: 'alt text' },
  tbCode: { prefix: '`', suffix: '`', placeholder: 'code' },
  tbCodeBlock: { prefix: '```\n', suffix: '\n```', placeholder: 'code block', line: true },
  tbUl: { prefix: '- ', suffix: '', placeholder: 'list item', line: true },
  tbOl: { prefix: '1. ', suffix: '', placeholder: 'list item', line: true },
  tbTask: { prefix: '- [ ] ', suffix: '', placeholder: 'task', line: true },
  tbQuote: { prefix: '> ', suffix: '', placeholder: 'quote', line: true },
  tbTable: { prefix: '| Column 1 | Column 2 | Column 3 |\n| --- | --- | --- |\n| ', suffix: ' | data | data |', placeholder: 'data', line: true },
  tbHr: { prefix: '\n---\n', suffix: '', placeholder: '', line: true },
};

Object.keys(tbActions).forEach(function(id) {
  var btn = document.getElementById(id);
  if (!btn) return;
  btn.addEventListener('click', function() {
    var act = tbActions[id];
    insertAtCursor(act.prefix, act.suffix, act.placeholder, act.line);
  });
});

function insertAtCursor(prefix, suffix, placeholder, lineStart) {
  mdInput.focus();
  var start = mdInput.selectionStart;
  var end = mdInput.selectionEnd;
  var text = mdInput.value;
  var selected = text.substring(start, end);
  var insert = selected || placeholder;
  var before = text.substring(0, start);
  if (lineStart && before.length > 0 && before[before.length - 1] !== '\n') {
    before += '\n';
  }
  var newText = before + prefix + insert + suffix + text.substring(end);
  mdInput.value = newText;
  var cursorStart = before.length + prefix.length;
  var cursorEnd = cursorStart + insert.length;
  mdInput.setSelectionRange(cursorStart, cursorEnd);
  renderPreview();
}

/* ── Keyboard shortcuts ── */
mdInput.addEventListener('keydown', function(e) {
  if ((e.ctrlKey || e.metaKey) && e.key === 'b') {
    e.preventDefault();
    document.getElementById('tbBold').click();
  } else if ((e.ctrlKey || e.metaKey) && e.key === 'i') {
    e.preventDefault();
    document.getElementById('tbItalic').click();
  } else if (e.key === 'Tab') {
    e.preventDefault();
    var s = this.selectionStart;
    var en = this.selectionEnd;
    this.value = this.value.substring(0, s) + '  ' + this.value.substring(en);
    this.selectionStart = this.selectionEnd = s + 2;
    renderPreview();
  }
});

/* ── Sample markdown ── */
var sampleMd = '# Welcome to the Markdown Editor\n\nThis is a **live markdown preview** editor with full *GFM support*.\n\n## Features\n\n- **Bold**, *italic*, and ~~strikethrough~~ text\n- [Links](https://example.com) and images\n- Code blocks with language labels\n- Tables, task lists, and blockquotes\n\n## Code Example\n\n```javascript\nfunction greet(name) {\n  return `Hello, ${name}!`;\n}\n\nconsole.log(greet("World"));\n```\n\nYou can also use `inline code` in your text.\n\n## Task List\n\n- [x] Write markdown\n- [x] See live preview\n- [ ] Copy HTML output\n- [ ] Download .md file\n\n## Blockquote\n\n> The best way to predict the future is to invent it.\n> — Alan Kay\n\n## Table\n\n| Feature | Status | Notes |\n| --- | --- | --- |\n| Bold & Italic | Supported | Standard markdown |\n| Tables | Supported | GFM extension |\n| Task Lists | Supported | GFM extension |\n| Code Blocks | Supported | With language labels |\n\n---\n\n*Made with the [siliconbased.dev](https://siliconbased.dev) markdown editor.*';

document.getElementById('sampleBtn').addEventListener('click', function() {
  mdInput.value = sampleMd;
  renderPreview();
  mdInput.focus();
});

document.getElementById('clearBtn').addEventListener('click', function() {
  mdInput.value = '';
  preview.innerHTML = '';
  updateStats();
  mdInput.focus();
});

/* ── Fullscreen ── */
var isFullscreen = false;
document.getElementById('fullscreenBtn').addEventListener('click', function() {
  isFullscreen = !isFullscreen;
  splitPane.classList.toggle('fullscreen', isFullscreen);
  document.body.style.overflow = isFullscreen ? 'hidden' : '';
  this.textContent = isFullscreen ? '\u2716 Exit' : '\u2696 Fullscreen';
});

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && isFullscreen) {
    isFullscreen = false;
    splitPane.classList.remove('fullscreen');
    document.body.style.overflow = '';
    document.getElementById('fullscreenBtn').textContent = '\u2696 Fullscreen';
  }
});

/* ── Copy HTML ── */
document.getElementById('copyHtmlBtn').addEventListener('click', function() {
  var html = preview.innerHTML;
  if (!html) return;
  var btn = this;
  navigator.clipboard.writeText(html).then(function() {
    btn.textContent = '\u2713 Copied';
    setTimeout(function() { btn.textContent = 'Copy HTML'; }, 1500);
  });
});

/* ── Download .md ── */
document.getElementById('downloadMdBtn').addEventListener('click', function() {
  var text = mdInput.value;
  if (!text) return;
  var blob = new Blob([text], { type: 'text/markdown' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'document.md';
  a.click();
  URL.revokeObjectURL(url);
});

/* ── Word/character count ── */
function updateStats() {
  var text = mdInput.value;
  var chars = text.length;
  var words = text.trim() === '' ? 0 : text.trim().split(/\s+/).length;
  wordCountEl.textContent = words + ' word' + (words !== 1 ? 's' : '');
  charCountEl.textContent = chars + ' character' + (chars !== 1 ? 's' : '');
}

/* ── Markdown → HTML rendering ── */
function renderPreview() {
  preview.innerHTML = markdownToHtml(mdInput.value);
  updateStats();
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function markdownToHtml(md) {
  if (!md.trim()) return '';
  var html = md;

  // Fenced code blocks — extract and replace with placeholders
  var codeBlocks = [];
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, function(_, lang, code) {
    var escaped = escapeHtml(code.replace(/\n$/, ''));
    var label = lang ? '<div class="code-lang">' + escapeHtml(lang) + '</div>' : '';
    var block = label + '<pre><code class="' + (lang ? 'language-' + lang : '') + '">' + escaped + '</code></pre>';
    codeBlocks.push(block);
    return '\x00CODEBLOCK' + (codeBlocks.length - 1) + '\x00';
  });

  // Inline code — protect from other transforms
  var inlineCodes = [];
  html = html.replace(/`([^`]+)`/g, function(_, code) {
    inlineCodes.push('<code>' + escapeHtml(code) + '</code>');
    return '\x00INLINE' + (inlineCodes.length - 1) + '\x00';
  });

  // Blockquotes
  html = html.replace(/^((?:>.*\n?)+)/gm, function(block) {
    var inner = block.replace(/^>\s?/gm, '').trim();
    return '<blockquote>' + inner.split('\n').map(function(l) { return '<p>' + l + '</p>'; }).join('') + '</blockquote>\n';
  });

  // Tables (GFM)
  html = html.replace(/^(\|.+\|)\n(\|[\s:|-]+\|)\n((?:\|.+\|\n?)*)/gm, function(_, headerRow, _sep, bodyRows) {
    var headers = headerRow.split('|').filter(function(c) { return c.trim(); }).map(function(c) { return '<th>' + c.trim() + '</th>'; }).join('');
    var body = '';
    if (bodyRows.trim()) {
      bodyRows.trim().split('\n').forEach(function(row) {
        var cells = row.split('|').filter(function(c) { return c.trim(); }).map(function(c) { return '<td>' + c.trim() + '</td>'; }).join('');
        body += '<tr>' + cells + '</tr>';
      });
    }
    return '<table><thead><tr>' + headers + '</tr></thead><tbody>' + body + '</tbody></table>\n';
  });

  // Headings
  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');

  // HR
  html = html.replace(/^---$/gm, '<hr>');

  // Task lists (GFM) — must come before regular lists
  html = html.replace(/^(?:[-*+]\s+\[[ xX]\]\s+.+\n?)+/gm, function(block) {
    var items = block.trim().split('\n').map(function(l) {
      var checked = /\[[xX]\]/.test(l);
      var text = l.replace(/^[-*+]\s+\[[ xX]\]\s+/, '');
      return '<li class="task-item"><input type="checkbox" disabled' + (checked ? ' checked' : '') + '> ' + text + '</li>';
    }).join('');
    return '<ul class="task-list">' + items + '</ul>\n';
  });

  // Unordered lists
  html = html.replace(/^(?:[-*+]\s+.+\n?)+/gm, function(block) {
    var items = block.trim().split('\n').map(function(l) { return '<li>' + l.replace(/^[-*+]\s+/, '') + '</li>'; }).join('');
    return '<ul>' + items + '</ul>\n';
  });

  // Ordered lists
  html = html.replace(/^(?:\d+\.\s+.+\n?)+/gm, function(block) {
    var items = block.trim().split('\n').map(function(l) { return '<li>' + l.replace(/^\d+\.\s+/, '') + '</li>'; }).join('');
    return '<ol>' + items + '</ol>\n';
  });

  // Images (before links)
  html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" />');

  // Links
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');

  // Bold + italic combined
  html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');

  // Bold
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

  // Italic
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

  // Strikethrough
  html = html.replace(/~~(.+?)~~/g, '<del>$1</del>');

  // Paragraphs — wrap remaining non-empty, non-tag lines
  html = html.replace(/^(?!<[a-z/]|$|\x00)(.+)$/gm, '<p>$1</p>');

  // Clean up empty paragraphs
  html = html.replace(/<p>\s*<\/p>/g, '');

  // Restore code blocks and inline codes
  html = html.replace(/\x00CODEBLOCK(\d+)\x00/g, function(_, i) { return codeBlocks[parseInt(i)]; });
  html = html.replace(/\x00INLINE(\d+)\x00/g, function(_, i) { return inlineCodes[parseInt(i)]; });

  return html.trim();
}

/* ── Init ── */
mdInput.addEventListener('input', renderPreview);
mdInput.value = sampleMd;
renderPreview();
</script>

