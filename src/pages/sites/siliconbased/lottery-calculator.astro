export const meta = {
  title: "Lottery Odds Calculator",
  description: "Ever wondered what it truly takes to win the jackpot? Calculate the exact mathematical probability of winning popular lotteries and discover the surprising truth behind the numbers.",
  category: "tool",
  published: "2026-03-15",
