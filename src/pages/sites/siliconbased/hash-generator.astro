    'sha-256': { name: 'SHA-256', warn: false },
    'sha-384': { name: 'SHA-384', warn: false },
    'sha-512': { name: 'SHA-512', warn: false }
  };
  container.innerHTML = '';
  var keys = Object.keys(hashes);
  for (var k = 0; k < keys.length; k++) {
    var key = keys[k];
    var val = hashes[key];
    var info = labels[key];
    var row = document.createElement('div');
    row.className = 'hash-row';
    row.innerHTML =
      '<div class="hash-row-label">' +
        '<span class="hash-algo-name">' + info.name + '</span>' +
        (info.warn ? '<span class="hash-warn">deprecated</span>' : '') +
      '</div>' +
      '<div class="hash-row-value">' +
        '<code class="hash-hex">' + applyCase(val) + '</code>' +
        '<button class="copy-btn hash-copy-btn" data-hash="' + applyCase(val) + '">Copy</button>' +
      '</div>';
    container.appendChild(row);
  }
  container.style.display = 'block';
  // Attach copy handlers
  container.querySelectorAll('.hash-copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var hash = this.getAttribute('data-hash');
      var self = this;
      navigator.clipboard.writeText(hash).then(function() {
        self.textContent = '\u2713 Copied';
        setTimeout(function() { self.textContent = 'Copy'; }, 1500);
      });
    });
  });
}

// --- Uppercase toggle ---
var useUppercase = false;
function applyCase(hex) {
  return useUppercase ? hex.toUpperCase() : hex.toLowerCase();
}

// --- DOM refs ---
var inputArea = document.getElementById('inputArea');
var inputCount = document.getElementById('inputCount');
var clearBtn = document.getElementById('clearBtn');
var uppercaseToggle = document.getElementById('uppercaseToggle');
var hashResults = document.getElementById('hashResults');
var hashResultsList = document.getElementById('hashResultsList');
var fileInput = document.getElementById('fileInput');
var fileDropZone = document.getElementById('fileDropZone');
var fileInfo = document.getElementById('fileInfo');
var fileHashResults = document.getElementById('fileHashResults');
var fileProgress = document.getElementById('fileProgress');
var progressFill = document.getElementById('progressFill');
var progressText = document.getElementById('progressText');
var hash1 = document.getElementById('hash1');
var hash2 = document.getElementById('hash2');
var compareResult = document.getElementById('compareResult');

var debounceTimer = null;

// --- Text input hashing ---
inputArea.addEventListener('input', function() {
  var len = inputArea.value.length;
  inputCount.textContent = len.toLocaleString() + ' character' + (len !== 1 ? 's' : '');
  clearTimeout(debounceTimer);
  if (!inputArea.value) {
    hashResults.style.display = 'none';
    return;
  }
  debounceTimer = setTimeout(function() {
    hashText(inputArea.value).then(function(hashes) {
      hashResults.style.display = 'block';
      renderHashes(hashResultsList, hashes);
    });
  }, 200);
});

// --- Clear ---
clearBtn.addEventListener('click', function() {
  inputArea.value = '';
  inputCount.textContent = '0 characters';
  hashResults.style.display = 'none';
  inputArea.focus();
});

// --- Uppercase toggle ---
uppercaseToggle.addEventListener('change', function() {
  useUppercase = uppercaseToggle.checked;
  // Re-render text hashes if present
  if (inputArea.value) {
    hashText(inputArea.value).then(function(hashes) {
      hashResults.style.display = 'block';
      renderHashes(hashResultsList, hashes);
    });
  }
  // Re-apply case to file hash results if visible
  var fileHexEls = fileHashResults.querySelectorAll('.hash-hex');
  fileHexEls.forEach(function(el) {
    el.textContent = useUppercase ? el.textContent.toUpperCase() : el.textContent.toLowerCase();
  });
  fileHashResults.querySelectorAll('.hash-copy-btn').forEach(function(btn) {
    var h = btn.getAttribute('data-hash');
    btn.setAttribute('data-hash', useUppercase ? h.toUpperCase() : h.toLowerCase());
  });
});

// --- File handling ---
function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / 1048576).toFixed(1) + ' MB';
}

function processFile(file) {
  fileInfo.textContent = file.name + ' (' + formatSize(file.size) + ')';
  fileInfo.style.display = 'block';
  fileHashResults.style.display = 'none';
  fileProgress.style.display = 'block';
  progressFill.style.width = '0%';
  progressText.textContent = 'Reading file...';

  var reader = new FileReader();
  reader.onprogress = function(e) {
    if (e.lengthComputable) {
      var pct = Math.round((e.loaded / e.total) * 50);
      progressFill.style.width = pct + '%';
    }
  };
  reader.onload = function(e) {
    progressFill.style.width = '50%';
    progressText.textContent = 'Computing hashes...';
    hashFile(e.target.result).then(function(hashes) {
      progressFill.style.width = '100%';
      progressText.textContent = 'Done';
      setTimeout(function() { fileProgress.style.display = 'none'; }, 600);
      renderHashes(fileHashResults, hashes);
    });
  };
  reader.readAsArrayBuffer(file);
}

fileInput.addEventListener('change', function(e) {
  if (e.target.files.length > 0) {
    processFile(e.target.files[0]);
    e.target.value = '';
  }
});

fileDropZone.addEventListener('dragover', function(e) {
  e.preventDefault();
  fileDropZone.classList.add('drag-over');
});
fileDropZone.addEventListener('dragleave', function() {
  fileDropZone.classList.remove('drag-over');
});
fileDropZone.addEventListener('drop', function(e) {
  e.preventDefault();
  fileDropZone.classList.remove('drag-over');
  if (e.dataTransfer.files.length > 0) {
    processFile(e.dataTransfer.files[0]);
  }
});

// --- Hash comparison ---
function compareHashes() {
  var a = hash1.value.trim();
  var b = hash2.value.trim();
  if (!a || !b) {
    compareResult.innerHTML = '';
    compareResult.className = 'compare-result';
    return;
  }
  if (a.toLowerCase() === b.toLowerCase()) {
    compareResult.innerHTML = '\u2705 Hashes match';
    compareResult.className = 'compare-result match';
  } else {
    compareResult.innerHTML = '\u274C Hashes do not match';
    compareResult.className = 'compare-result no-match';
  }
}
hash1.addEventListener('input', compareHashes);
hash2.addEventListener('input', compareHashes);
</script>

