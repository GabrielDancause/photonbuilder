const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Hash Generator &amp; Checksum Calculator</h1>
  <p>Free MD5 hash generator, SHA256 generator, and checksum calculator. Generate MD5, SHA-1, SHA-256, SHA-384, and SHA-512 hashes from text or files &mdash; all in your browser.</p>
</div>

<div class="main">

