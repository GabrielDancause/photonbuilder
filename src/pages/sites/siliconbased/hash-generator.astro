// --- Web Crypto hash helper ---
async function cryptoHash(algorithm, data) {
  var hashBuffer = await crypto.subtle.digest(algorithm, data);
  var hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
}

// --- Hash text ---
async function hashText(text) {
  var encoder = new TextEncoder();
  var data = encoder.encode(text);
  var results = await Promise.all([
    cryptoHash('SHA-1', data),
    cryptoHash('SHA-256', data),
    cryptoHash('SHA-384', data),
    cryptoHash('SHA-512', data)
  ]);
  return { md5: MD5(text), 'sha-1': results[0], 'sha-256': results[1], 'sha-384': results[2], 'sha-512': results[3] };
}

// --- Hash file (ArrayBuffer) ---
async function hashFile(buffer) {
  var data = new Uint8Array(buffer);
  var results = await Promise.all([
    cryptoHash('SHA-1', data),
    cryptoHash('SHA-256', data),
    cryptoHash('SHA-384', data),
    cryptoHash('SHA-512', data)
  ]);
  return { md5: MD5(new Uint8Array(buffer)), 'sha-1': results[0], 'sha-256': results[1], 'sha-384': results[2], 'sha-512': results[3] };
}

// --- Render hash results into a container ---
function renderHashes(container, hashes) {
