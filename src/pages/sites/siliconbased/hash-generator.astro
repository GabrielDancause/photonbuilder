    </div>
    <div id="fileInfo" class="file-info" style="display:none;"></div>
    <div class="file-progress" id="fileProgress" style="display:none;">
      <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
      <div class="progress-text" id="progressText">Hashing...</div>
    </div>
    <div class="hash-results-list" id="fileHashResults" style="display:none;"></div>
  </div>

  <!-- Hash Comparison -->
  <div class="section-card">
    <div class="section-header">
      <div class="header-title">Hash Comparison</div>
    </div>
    <p class="section-desc">Paste two hashes below to check if they match (case-insensitive).</p>
    <div class="compare-grid">
      <div class="compare-col">
        <label class="compare-label" for="hash1">Hash 1</label>
