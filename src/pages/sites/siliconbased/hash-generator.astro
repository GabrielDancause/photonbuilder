            <td>384 bits (96 hex)</td>
            <td><span class="status-badge secure">Secure</span></td>
            <td>Moderate</td>
            <td>TLS 1.3, certificate chains</td>
          </tr>
          <tr>
            <td><code>SHA-512</code></td>
            <td>512 bits (128 hex)</td>
            <td><span class="status-badge secure">Secure</span></td>
