---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = {
  title: 'Days Calculator | Siliconbased',
  description: 'Calculate the exact number of days, business days, weeks, and months between two dates. Free online date calculator for project planning.',
  category: 'tool',
  keywords: ['days calculator', 'date calculator', 'business days calculator', 'days between dates', 'add days to date', 'subtract days from date']
};
const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "siliconbased.dev" },
    "publisher": { "@type": "Organization", "name": "siliconbased.dev" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How do you calculate days between two dates?", "acceptedAnswer": { "@type": "Answer", "text": "To calculate the days between two dates, you find the difference in milliseconds between them and divide by the number of milliseconds in a day (86,400,000)." } },
      { "@type": "Question", "name": "How do I calculate 90 days from today?", "acceptedAnswer": { "@type": "Answer", "text": "You can use our calculator by selecting the 'Add/Subtract' mode, entering today's date, and adding 90 days. The result will account for varying month lengths." } },
      { "@type": "Question", "name": "Does this calculator include business days?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, our calculator includes a business days option that automatically excludes weekends (Saturdays and Sundays) from the total count." } },
      { "@type": "Question", "name": "Are leap years accounted for?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, leap years are automatically accounted for. The standard Gregorian calendar rules are applied to all date calculations." } },
      { "@type": "Question", "name": "How many days are in 6 months?", "acceptedAnswer": { "@type": "Answer", "text": "Six months is roughly 182 or 183 days depending on the specific months and if a leap year is involved." } }
    ]
  }
]);
---
<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/days-calculator">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schema} />
  </Fragment>
  <div class="page-content">
    <div class="hero">
      <h1>Days Calculator 📅</h1>
      <p>Instantly calculate the exact duration between dates or add/subtract days.</p>
    </div>
    <div class="main">
      <div class="calc-tabs">
        <button class="tab-btn active" id="tab-between">Difference Between Dates</button>
        <button class="tab-btn" id="tab-add">Add/Subtract Days</button>
      </div>
      <div class="calc-card" id="mode-between">
        <div class="input-row">
          <div class="input-group">
            <label for="startDate1">Start Date</label>
            <input type="date" id="startDate1" class="date-input">
          </div>
          <div class="input-group">
            <label for="endDate1">End Date</label>
            <input type="date" id="endDate1" class="date-input">
          </div>
        </div>
        <div class="options-row">
          <label class="checkbox-label"><input type="checkbox" id="includeEndDay"> Include end day (+1 day)</label>
          <label class="checkbox-label"><input type="checkbox" id="businessDaysOnly"> Business days only (Skip weekends)</label>
        </div>
      </div>
      <div class="calc-card hidden" id="mode-add">
        <div class="input-row">
          <div class="input-group">
            <label for="startDate2">Start Date</label>
            <input type="date" id="startDate2" class="date-input">
          </div>
          <div class="input-group">
            <label for="operation">Operation</label>
            <select id="operation" class="select-input"><option value="add">Add (+)</option><option value="sub">Subtract (-)</option></select>
          </div>
          <div class="input-group">
            <label for="daysAmount">Amount</label>
            <div class="multi-input">
              <input type="number" id="daysAmount" class="num-input" value="30" min="0">
              <select id="timeUnit" class="select-input small"><option value="days">Days</option><option value="weeks">Weeks</option><option value="months">Months</option><option value="years">Years</option></select>
            </div>
          </div>
        </div>
        <div class="options-row">
          <label class="checkbox-label"><input type="checkbox" id="businessDaysAdd"> Only count business days</label>
        </div>
      </div>
      <div class="result-card" id="result-container">
        <div class="result-header">Calculation Result</div>
        <div class="result-value" id="main-result">--</div>
        <div class="result-sub" id="sub-result">Please enter dates to calculate</div>
        <div class="breakdown-grid" id="breakdown-grid">
          <div class="breakdown-item"><div class="bd-label">Total Days</div><div class="bd-value" id="bd-days">--</div></div>
          <div class="breakdown-item"><div class="bd-label">Business Days</div><div class="bd-value" id="bd-biz">--</div></div>
          <div class="breakdown-item"><div class="bd-label">Weeks</div><div class="bd-value" id="bd-weeks">--</div></div>
          <div class="breakdown-item"><div class="bd-label">Months (Approx)</div><div class="bd-value" id="bd-months">--</div></div>
          <div class="breakdown-item"><div class="bd-label">Years (Approx)</div><div class="bd-value" id="bd-years">--</div></div>
        </div>
        <div class="timeline-vis hidden" id="timeline-vis">
          <div class="tl-labels"><span id="tl-start">Start</span><span id="tl-end">End</span></div>
          <div class="tl-bar"><div class="tl-progress" id="tl-progress"></div></div>
          <div class="tl-stats" id="tl-stats">-- days</div>
        </div>
      </div>
      <div class="trivia-card hidden" id="trivia-card">
        <h3>📅 On This Day in History</h3>
        <p id="trivia-text"></p>
      </div>
      <div class="quick-links">
        <h3>Common Calculations</h3>
        <div class="ql-grid">
          <button class="ql-btn" data-days="30">30 Days From Now</button>
          <button class="ql-btn" data-days="60">60 Days From Now</button>
          <button class="ql-btn" data-days="90">90 Days From Now</button>
          <button class="ql-btn" data-days="180">180 Days From Now</button>
        </div>
      </div>
      <div class="edu-content">
        <h2>Understanding Date Calculations</h2>
        <div class="edu-card"><h3>The Gregorian Calendar</h3><p>Most of the world uses the Gregorian calendar, introduced in 1582. It features 365 days in a standard year and 366 in a leap year. Our calculator strictly adheres to these rules, ensuring precise duration measurements across centuries.</p></div>
        <div class="edu-card"><h3>Business Days vs. Calendar Days</h3><p>When tracking project deadlines, <strong>business days</strong> are crucial. They typically exclude Saturdays and Sundays. While calculating business days programmatically, one must account for the specific day of the week a date falls on to accurately subtract weekend days across a given span.</p></div>
        <div class="edu-card"><h3>Leap Year Rules</h3><p>A leap year occurs every 4 years to keep our calendar aligned with the Earth's revolutions around the Sun. The rule is: a year is a leap year if it is divisible by 4, except for end-of-century years, which must be divisible by 400. This calculator automatically adjusts for February 29th.</p></div>
      </div>
      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item"><h3>How do you calculate days between two dates?</h3><p>To calculate the days between two dates, you find the difference in milliseconds between them and divide by the number of milliseconds in a day (86,400,000).</p></div>
        <div class="faq-item"><h3>How do I calculate 90 days from today?</h3><p>You can use our calculator by selecting the 'Add/Subtract' mode, entering today's date, and adding 90 days. The result will account for varying month lengths.</p></div>
        <div class="faq-item"><h3>Does this calculator include business days?</h3><p>Yes, our calculator includes a business days option that automatically excludes weekends (Saturdays and Sundays) from the total count.</p></div>
        <div class="faq-item"><h3>Are leap years accounted for?</h3><p>Yes, leap years are automatically accounted for. The standard Gregorian calendar rules are applied to all date calculations.</p></div>
        <div class="faq-item"><h3>How many days are in 6 months?</h3><p>Six months is roughly 182 or 183 days depending on the specific months and if a leap year is involved.</p></div>
      </div>
      <div class="related-tools">
        <h3>Related Tools</h3>
        <ul>
          <li><a href="/cron-generator">Cron Expression Generator</a></li>
          <li><a href="/birthday-calculator">Birthday Calculator</a></li>
          <li><a href="/bottleneck-calculator">Bottleneck Calculator</a></li>
          <li><a href="/base64-encoder-decoder">Base64 Encoder/Decoder</a></li>
        </ul>
      </div>
    </div>
  </div>
  <script is:inline>
    const modeBetween = document.getElementById('mode-between');
    const modeAdd = document.getElementById('mode-add');
    const tabBetween = document.getElementById('tab-between');
    const tabAdd = document.getElementById('tab-add');
    const startDate1 = document.getElementById('startDate1');
    const endDate1 = document.getElementById('endDate1');
    const includeEndDay = document.getElementById('includeEndDay');
    const businessDaysOnly = document.getElementById('businessDaysOnly');
    const startDate2 = document.getElementById('startDate2');
    const operation = document.getElementById('operation');
    const daysAmount = document.getElementById('daysAmount');
    const timeUnit = document.getElementById('timeUnit');
    const businessDaysAdd = document.getElementById('businessDaysAdd');
