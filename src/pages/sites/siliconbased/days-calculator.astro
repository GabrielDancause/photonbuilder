    [startDate2, operation, daysAmount, timeUnit, businessDaysAdd].forEach(el => el.addEventListener('input', calculateAdd));
    qlBtns.forEach(btn => btn.addEventListener('click', (e) => { switchTab('add'); startDate2.value = todayStr; operation.value = 'add'; daysAmount.value = e.target.getAttribute('data-days'); timeUnit.value = 'days'; businessDaysAdd.checked = false; calculateAdd(); }));
    function switchTab(tab) { if (tab === 'between') { modeBetween.classList.remove('hidden'); modeAdd.classList.add('hidden'); tabBetween.classList.add('active'); tabAdd.classList.remove('active'); calculateBetween(); } else { modeBetween.classList.add('hidden'); modeAdd.classList.remove('hidden'); tabBetween.classList.remove('active'); tabAdd.classList.add('active'); calculateAdd(); } }
    function getBusinessDays(startDate, endDate) { let count = 0; let curDate = new Date(startDate.getTime()); curDate.setHours(0,0,0,0); let end = new Date(endDate.getTime()); end.setHours(0,0,0,0); if (curDate > end) return 0; while (curDate <= end) { const dayOfWeek = curDate.getDay(); if (dayOfWeek !== 0 && dayOfWeek !== 6) count++; curDate.setDate(curDate.getDate() + 1); } return count; }
    function addBusinessDays(startDate, amount) { let curDate = new Date(startDate.getTime()); let added = 0; let direction = amount >= 0 ? 1 : -1; let absAmount = Math.abs(amount); while (added < absAmount) { curDate.setDate(curDate.getDate() + direction); const dayOfWeek = curDate.getDay(); if (dayOfWeek !== 0 && dayOfWeek !== 6) { added++; } } return curDate; }
    function calculateBetween() { if (!startDate1.value || !endDate1.value) return; const d1 = new Date(startDate1.value + 'T00:00:00'); const d2 = new Date(endDate1.value + 'T00:00:00'); let isReversed = false; let start = d1; let end = d2; if (d1 > d2) { start = d2; end = d1; isReversed = true; } const timeDiff = end.getTime() - start.getTime(); let daysDiff = Math.round(timeDiff / (1000 * 3600 * 24)); if (includeEndDay.checked) { daysDiff += 1; } const bizDays = getBusinessDays(start, includeEndDay.checked ? end : new Date(end.getTime() - 86400000)); let displayResult = daysDiff; if (businessDaysOnly.checked) displayResult = bizDays; mainResult.textContent = displayResult + (displayResult === 1 ? ' Day' : ' Days'); subResult.textContent = isReversed ? 'End date is before start date' : `From ${start.toLocaleDateString()} to ${end.toLocaleDateString()}`; bdDays.textContent = daysDiff; bdBiz.textContent = bizDays; bdWeeks.textContent = (daysDiff / 7).toFixed(1); bdMonths.textContent = (daysDiff / 30.44).toFixed(1); bdYears.textContent = (daysDiff / 365.25).toFixed(1); updateTimeline(start, end, displayResult, 'days'); displayTrivia(end); }
    function calculateAdd() { if (!startDate2.value || !daysAmount.value) return; const start = new Date(startDate2.value + 'T00:00:00'); const amount = parseFloat(daysAmount.value) || 0; const unit = timeUnit.value; const isSub = operation.value === 'sub'; let resultDate = new Date(start.getTime()); let sign = isSub ? -1 : 1; let totalDaysAdded = 0; if (businessDaysAdd.checked && unit === 'days') { resultDate = addBusinessDays(start, amount * sign); totalDaysAdded = Math.round((resultDate.getTime() - start.getTime()) / (1000 * 3600 * 24)) * sign; } else { if (unit === 'days') { resultDate.setDate(resultDate.getDate() + (amount * sign)); totalDaysAdded = amount; } else if (unit === 'weeks') { resultDate.setDate(resultDate.getDate() + (amount * 7 * sign)); totalDaysAdded = amount * 7; } else if (unit === 'months') { resultDate.setMonth(resultDate.getMonth() + (amount * sign)); totalDaysAdded = Math.round(Math.abs((resultDate.getTime() - start.getTime()) / (1000 * 3600 * 24))); } else if (unit === 'years') { resultDate.setFullYear(resultDate.getFullYear() + (amount * sign)); totalDaysAdded = Math.round(Math.abs((resultDate.getTime() - start.getTime()) / (1000 * 3600 * 24))); } } mainResult.textContent = resultDate.toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }); subResult.textContent = `${isSub ? 'Subtracting' : 'Adding'} ${amount} ${unit} ${businessDaysAdd.checked ? '(Business Days)' : ''} to ${start.toLocaleDateString()}`; const actualDaysDiff = Math.abs(Math.round((resultDate.getTime() - start.getTime()) / (1000 * 3600 * 24))); let calcStart = isSub ? resultDate : start; let calcEnd = isSub ? start : resultDate; bdDays.textContent = actualDaysDiff; bdBiz.textContent = getBusinessDays(calcStart, new Date(calcEnd.getTime() - 86400000)); bdWeeks.textContent = (actualDaysDiff / 7).toFixed(1); bdMonths.textContent = (actualDaysDiff / 30.44).toFixed(1); bdYears.textContent = (actualDaysDiff / 365.25).toFixed(1); updateTimeline(calcStart, calcEnd, actualDaysDiff, 'days span'); displayTrivia(resultDate); }
    function updateTimeline(start, end, val, label) { timelineVis.classList.remove('hidden'); tlStart.textContent = start.toLocaleDateString(undefined, {month:'short', day:'numeric'}); tlEnd.textContent = end.toLocaleDateString(undefined, {month:'short', day:'numeric'}); tlStats.textContent = val + ' ' + label; tlProgress.style.width = '0%'; setTimeout(() => { tlProgress.style.width = '100%'; }, 50); }
    const triviaData = {
