    .api-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .meta-tag { font-size: 0.8rem; padding: 0.3rem 0.7rem; background: rgba(129,140,248,0.1); border: 1px solid var(--border-color); border-radius: 20px; color: var(--text-secondary); }
    .api-link { margin-top: 0.5rem; }
