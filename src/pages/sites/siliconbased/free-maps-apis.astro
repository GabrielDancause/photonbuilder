    .cta-box { background: linear-gradient(135deg, rgba(129,140,248,0.1), rgba(0,212,255,0.05)); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 2rem 0; text-align: center; }
