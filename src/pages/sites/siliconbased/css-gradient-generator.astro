---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "CSS Gradient Generator — Create Beautiful Gradients",
      "url": "https://siliconbased.dev/css-gradient-generator",
      "description": "Free CSS gradient generator with linear, radial, and conic gradients. Add color stops, pick angles, preview live, copy CSS or Tailwind classes, and export as PNG.",
      "applicationCategory": "DesignApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a CSS gradient generator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A CSS gradient generator is a visual tool that lets you create CSS gradients by picking colors, adjusting positions, and choosing gradient types (linear, radial, conic). It outputs ready-to-use CSS code you can paste directly into your stylesheets."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between linear, radial, and conic gradients?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A linear gradient transitions colors along a straight line at a specified angle. A radial gradient transitions colors outward from a center point in a circular or elliptical shape. A conic gradient transitions colors around a center point like a color wheel, sweeping through angles."
          }
        },
        {
          "@type": "Question",
          "name": "How do color stops work in CSS gradients?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Color stops define the colors in a gradient and their positions along the gradient line. Each stop has a color value and an optional position (as a percentage or length). The browser interpolates between stops to create smooth transitions. You can add multiple stops to create complex multi-color gradients."
          }
        },
        {
          "@type": "Question",
          "name": "Can I use CSS gradients as backgrounds?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, CSS gradients are most commonly used as background images via the background or background-image property. They can also be used anywhere an image is accepted, including border-image, list-style-image, and even mask-image for advanced effects."
          }
        },
        {
          "@type": "Question",
          "name": "How do I set the angle of a linear gradient?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Linear gradient angles are set in degrees (e.g., 90deg for left-to-right, 180deg for top-to-bottom) or with direction keywords like 'to right', 'to bottom left'. In this tool, you can drag the angle picker or type a value directly to set the gradient direction."
          }
        },
        {
          "@type": "Question",
          "name": "Are CSS gradients supported in all browsers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Linear and radial gradients are supported in all modern browsers (Chrome, Firefox, Safari, Edge) without vendor prefixes. Conic gradients have broad support in modern browsers as well. For older browser support, you can add a solid color fallback."
          }
        },
        {
          "@type": "Question",
          "name": "Is this gradient generator free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this CSS gradient generator is completely free. It runs entirely in your browser with no sign-up required. All gradient generation and exports happen client-side — no data is sent to any server."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "CSS Gradient Generator — Create Beautiful Gradients Online",
      "description": "Free CSS gradient generator with linear, radial, and conic gradients. Live preview, color stops, angle picker, and export to CSS, Tailwind, or PNG.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>CSS Gradient Generator</h1>
  <p>Create beautiful CSS gradients with live preview. Pick colors, adjust stops, choose angles, and export to CSS, Tailwind, or PNG.</p>
</div>

<div class="main">

  <!-- Controls -->
  <div class="controls-bar">
    <div class="type-select">
      <label>Type</label>
      <select id="gradientType">
        <option value="linear">Linear</option>
        <option value="radial">Radial</option>
        <option value="conic">Conic</option>
      </select>
    </div>
    <div class="angle-control" id="angleControl">
      <label>Angle</label>
      <input type="number" id="angleInput" value="135" min="0" max="360" step="1">
      <span class="angle-unit">deg</span>
      <div class="angle-wheel" id="angleWheel">
        <div class="angle-needle" id="angleNeedle"></div>
      </div>
    </div>
    <button class="action-btn" id="randomBtn" title="Random gradient">Random</button>
  </div>

  <!-- Live Preview -->
  <div class="preview-section">
    <div class="preview-box" id="previewBox"></div>
  </div>

  <!-- Color Stops -->
  <div class="section-block">
    <div class="section-header">
      <h2>Color Stops</h2>
      <button class="add-stop-btn" id="addStopBtn">+ Add Stop</button>
    </div>
    <div class="stops-list" id="stopsList"></div>
  </div>

  <!-- CSS Output -->
  <div class="section-block">
    <div class="section-header">
      <h2>CSS Output</h2>
      <label class="prefix-toggle"><input type="checkbox" id="prefixToggle"> Include -webkit- prefix</label>
    </div>
    <div class="export-tabs">
      <button class="export-tab active" data-format="css">CSS</button>
      <button class="export-tab" data-format="tailwind">Tailwind</button>
      <button class="export-tab" data-format="png">Download PNG</button>
    </div>
    <div class="export-output-wrap" id="exportOutputWrap">
      <pre class="export-output" id="exportOutput"></pre>
      <button class="copy-btn" id="exportCopyBtn">Copy</button>
    </div>
    <canvas id="exportCanvas" style="display:none;"></canvas>
  </div>

  <!-- Preset Gradients -->
  <div class="section-block">
    <div class="section-header">
      <h2>Preset Gradients</h2>
      <p class="section-desc">Click any preset to load it into the editor.</p>
    </div>
    <div class="presets-grid" id="presetsGrid"></div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a CSS Gradient Generator?</h2>
    <p>A CSS gradient generator is a visual design tool that helps you create smooth color transitions for use as backgrounds, overlays, and decorative elements on web pages. Instead of writing gradient syntax by hand, you can visually pick colors, position color stops, set angles, and instantly see the result. The tool outputs standard CSS code that works in all modern browsers.</p>

    <h2>Understanding CSS Gradient Types</h2>
    <p>CSS supports three gradient functions, each producing a different visual pattern:</p>
    <ul>
      <li><strong>Linear Gradient:</strong> Colors transition along a straight line at a specified angle. Use <code>linear-gradient()</code> with an angle (e.g., 90deg) or direction keyword (e.g., to right). Perfect for hero sections, banners, and button backgrounds.</li>
      <li><strong>Radial Gradient:</strong> Colors radiate outward from a center point in a circular or elliptical shape. Use <code>radial-gradient()</code> for spotlight effects, glowing elements, and circular UI components.</li>
      <li><strong>Conic Gradient:</strong> Colors sweep around a center point like a pie chart or color wheel. Use <code>conic-gradient()</code> for pie charts, progress indicators, and decorative backgrounds.</li>
    </ul>

    <h2>Working with Color Stops</h2>
    <p>Color stops are the building blocks of any gradient. Each stop specifies a color and its position along the gradient axis as a percentage. The browser interpolates between adjacent stops to produce smooth transitions. Adding more stops lets you create complex multi-color effects — from simple two-tone fades to vibrant rainbow gradients. You can drag stops to reposition them or click to edit their colors.</p>

    <h2>Gradient Angles and Directions</h2>
    <p>For linear gradients, the angle determines the direction of the color transition. An angle of 0deg points upward, 90deg points right, 180deg points down, and 270deg points left. You can also use keyword directions like <code>to top right</code>. This tool provides both a numeric input and a visual angle wheel for precise control over your gradient direction.</p>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a CSS gradient generator?</h3>
      <p style="margin-bottom: 16px;">A CSS gradient generator is a visual tool that lets you create CSS gradients by picking colors, adjusting positions, and choosing gradient types (linear, radial, conic). It outputs ready-to-use CSS code you can paste directly into your stylesheets.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between linear, radial, and conic gradients?</h3>
      <p style="margin-bottom: 16px;">A linear gradient transitions colors along a straight line at a specified angle. A radial gradient transitions colors outward from a center point in a circular or elliptical shape. A conic gradient transitions colors around a center point like a color wheel, sweeping through angles.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do color stops work in CSS gradients?</h3>
      <p style="margin-bottom: 16px;">Color stops define the colors in a gradient and their positions along the gradient line. Each stop has a color value and an optional position (as a percentage). The browser interpolates between stops to create smooth transitions.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I use CSS gradients as backgrounds?</h3>
      <p style="margin-bottom: 16px;">Yes, CSS gradients are most commonly used as background images via the background or background-image property. They can also be used anywhere an image is accepted, including border-image, list-style-image, and mask-image.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I set the angle of a linear gradient?</h3>
      <p style="margin-bottom: 16px;">Linear gradient angles are set in degrees (e.g., 90deg for left-to-right, 180deg for top-to-bottom) or with direction keywords like 'to right', 'to bottom left'. Use the angle picker in this tool to visually set the direction.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Are CSS gradients supported in all browsers?</h3>
      <p style="margin-bottom: 16px;">Linear and radial gradients are supported in all modern browsers without vendor prefixes. Conic gradients also have broad modern browser support. For older browsers, add a solid color fallback.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is this gradient generator free to use?</h3>
      <p style="margin-bottom: 16px;">Yes, this CSS gradient generator is completely free. It runs entirely in your browser with no sign-up required. All gradient generation and exports happen client-side — no data is sent to any server.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/color-palette-generator">Color Palette Generator</a> — Create beautiful color schemes with harmony modes and contrast checking.</li>
      <li><a href="/css-framework-comparison">CSS Framework Comparison</a> — Compare popular CSS frameworks side by side.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "CSS Gradient Generator — Beautiful Gradients",
  description: "Free CSS gradient generator with linear, radial, and conic gradients. Add color stops, pick angles, preview live, and export to CSS, Tailwind, or PNG.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="CSS Gradient Generator — Beautiful Gradients"
  description="Free CSS gradient generator with linear, radial, and conic gradients. Add color stops, pick angles, preview live, and export to CSS, Tailwind, or PNG."
  canonical="https://siliconbased.dev/css-gradient-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const gradientType = document.getElementById('gradientType');
const angleInput = document.getElementById('angleInput');
const angleControl = document.getElementById('angleControl');
const angleWheel = document.getElementById('angleWheel');
const angleNeedle = document.getElementById('angleNeedle');
const previewBox = document.getElementById('previewBox');
const stopsList = document.getElementById('stopsList');
const addStopBtn = document.getElementById('addStopBtn');
const randomBtn = document.getElementById('randomBtn');
const exportOutput = document.getElementById('exportOutput');
const exportCopyBtn = document.getElementById('exportCopyBtn');
const exportCanvas = document.getElementById('exportCanvas');
const presetsGrid = document.getElementById('presetsGrid');
const prefixToggle = document.getElementById('prefixToggle');

let stops = [
  { color: '#667eea', position: 0 },
  { color: '#764ba2', position: 100 }
];
let angle = 135;
let currentExportFormat = 'css';

// --- Presets ---
const presets = [
  { name: 'Sunset', stops: [{color:'#f12711',position:0},{color:'#f5af19',position:100}], type:'linear', angle:135 },
  { name: 'Ocean Blue', stops: [{color:'#2E3192',position:0},{color:'#1BFFFF',position:100}], type:'linear', angle:135 },
  { name: 'Purple Love', stops: [{color:'#cc2b5e',position:0},{color:'#753a88',position:100}], type:'linear', angle:135 },
  { name: 'Cool Blues', stops: [{color:'#2193b0',position:0},{color:'#6dd5ed',position:100}], type:'linear', angle:135 },
  { name: 'Emerald', stops: [{color:'#348F50',position:0},{color:'#56B4D3',position:100}], type:'linear', angle:135 },
  { name: 'Flare', stops: [{color:'#f12711',position:0},{color:'#f5af19',position:50},{color:'#f12711',position:100}], type:'linear', angle:90 },
  { name: 'Peachy', stops: [{color:'#ffecd2',position:0},{color:'#fcb69f',position:100}], type:'linear', angle:135 },
  { name: 'Midnight', stops: [{color:'#232526',position:0},{color:'#414345',position:100}], type:'linear', angle:180 },
  { name: 'Northern Lights', stops: [{color:'#43cea2',position:0},{color:'#185a9d',position:100}], type:'linear', angle:135 },
  { name: 'Candy', stops: [{color:'#d53369',position:0},{color:'#daae51',position:100}], type:'linear', angle:135 },
  { name: 'Cosmic', stops: [{color:'#ff00cc',position:0},{color:'#333399',position:100}], type:'linear', angle:135 },
  { name: 'Fresh Air', stops: [{color:'#a8edea',position:0},{color:'#fed6e3',position:100}], type:'linear', angle:135 },
  { name: 'Rainbow', stops: [{color:'#ff0000',position:0},{color:'#ffff00',position:25},{color:'#00ff00',position:50},{color:'#0088ff',position:75},{color:'#8800ff',position:100}], type:'linear', angle:90 },
  { name: 'Deep Space', stops: [{color:'#000000',position:0},{color:'#434343',position:100}], type:'radial', angle:0 },
  { name: 'Mango', stops: [{color:'#ffe259',position:0},{color:'#ffa751',position:100}], type:'linear', angle:135 },
  { name: 'Berry Smoothie', stops: [{color:'#8e2de2',position:0},{color:'#4a00e0',position:100}], type:'linear', angle:135 },
  { name: 'Conic Pastel', stops: [{color:'#fbc2eb',position:0},{color:'#a6c1ee',position:33},{color:'#c2e9fb',position:66},{color:'#fbc2eb',position:100}], type:'conic', angle:0 },
  { name: 'Citrus', stops: [{color:'#f7971e',position:0},{color:'#ffd200',position:100}], type:'linear', angle:90 },
  { name: 'Aqua Splash', stops: [{color:'#13547a',position:0},{color:'#80d0c7',position:100}], type:'linear', angle:135 },
  { name: 'Lavender Haze', stops: [{color:'#c471f5',position:0},{color:'#fa71cd',position:100}], type:'radial', angle:0 }
];

// --- Gradient string builder ---
function buildGradientCSS() {
  const sortedStops = [...stops].sort((a, b) => a.position - b.position);
  const stopsStr = sortedStops.map(s => s.color + ' ' + s.position + '%').join(', ');
  const type = gradientType.value;
  if (type === 'linear') return 'linear-gradient(' + angle + 'deg, ' + stopsStr + ')';
  if (type === 'radial') return 'radial-gradient(circle, ' + stopsStr + ')';
  return 'conic-gradient(from ' + angle + 'deg, ' + stopsStr + ')';
}

// --- Render ---
function render() {
  updatePreview();
  renderStops();
  renderExport();
  updateAngleNeedle();
  angleControl.style.display = gradientType.value === 'radial' ? 'none' : '';
  addStopBtn.disabled = stops.length >= 5;
  addStopBtn.style.opacity = stops.length >= 5 ? '0.4' : '';
}

function updatePreview() {
  previewBox.style.background = buildGradientCSS();
}

function updateAngleNeedle() {
  angleNeedle.style.transform = 'rotate(' + angle + 'deg)';
}

function renderStops() {
  stopsList.innerHTML = '';
  stops.forEach(function(stop, i) {
    var row = document.createElement('div');
    row.className = 'stop-row';
    row.innerHTML =
      '<input type="color" class="stop-color" value="' + stop.color + '" data-i="' + i + '">' +
      '<input type="range" class="stop-range" min="0" max="100" value="' + stop.position + '" data-i="' + i + '">' +
      '<input type="number" class="stop-pos" min="0" max="100" value="' + stop.position + '" data-i="' + i + '">' +
      '<span class="stop-pct">%</span>' +
      '<span class="stop-hex">' + stop.color.toUpperCase() + '</span>' +
      (stops.length > 2 ? '<button class="stop-remove" data-i="' + i + '" title="Remove stop">&times;</button>' : '');
    stopsList.appendChild(row);
  });

  stopsList.querySelectorAll('.stop-color').forEach(function(el) {
    el.addEventListener('input', function() {
      stops[parseInt(el.dataset.i)].color = el.value;
      render();
    });
  });
  stopsList.querySelectorAll('.stop-range').forEach(function(el) {
    el.addEventListener('input', function() {
      var i = parseInt(el.dataset.i);
      stops[i].position = parseInt(el.value);
      render();
    });
  });
  stopsList.querySelectorAll('.stop-pos').forEach(function(el) {
    el.addEventListener('input', function() {
      var i = parseInt(el.dataset.i);
      stops[i].position = Math.max(0, Math.min(100, parseInt(el.value) || 0));
      render();
    });
  });
  stopsList.querySelectorAll('.stop-remove').forEach(function(el) {
    el.addEventListener('click', function() {
      stops.splice(parseInt(el.dataset.i), 1);
      render();
    });
  });
}

// --- Export ---
function renderExport() {
  var copyBtn = exportOutput.parentElement.querySelector('.copy-btn');
  if (currentExportFormat === 'png') {
    copyBtn.style.display = 'none';
    exportOutput.textContent = 'Click "Download PNG" above to save your gradient as an image.';
    return;
  }
  copyBtn.style.display = '';

  var css = buildGradientCSS();
  if (currentExportFormat === 'css') {
    var lines = '';
    if (prefixToggle.checked && gradientType.value !== 'conic') {
      var sortedStops = [...stops].sort(function(a, b) { return a.position - b.position; });
      var stopsStr = sortedStops.map(function(s) { return s.color + ' ' + s.position + '%'; }).join(', ');
      var webkitGrad;
      if (gradientType.value === 'linear') webkitGrad = '-webkit-linear-gradient(' + angle + 'deg, ' + stopsStr + ')';
      else webkitGrad = '-webkit-radial-gradient(circle, ' + stopsStr + ')';
      lines = 'background: ' + webkitGrad + ';\n';
    }
    lines += 'background: ' + css + ';';
    exportOutput.textContent = lines;
  } else if (currentExportFormat === 'tailwind') {
    // Build Tailwind arbitrary value class
    var twVal = css.replace(/\s+/g, '_');
    exportOutput.textContent = '/* Tailwind arbitrary value */\nclass="bg-[' + twVal + ']"\n\n/* Or in tailwind.config.js */\nmodule.exports = {\n  theme: {\n    extend: {\n      backgroundImage: {\n        \'custom-gradient\': \'' + css + '\',\n      },\n    },\n  },\n};';
  }
}

function downloadPNG() {
  var w = 1200, h = 630;
  exportCanvas.width = w;
  exportCanvas.height = h;
  var ctx = exportCanvas.getContext('2d');
  var sortedStops = [...stops].sort(function(a, b) { return a.position - b.position; });
  var type = gradientType.value;
  var grad;

  if (type === 'linear') {
    var rad = (angle - 90) * Math.PI / 180;
    var cx = w / 2, cy = h / 2;
    var len = Math.max(w, h);
    var x1 = cx - Math.cos(rad) * len / 2;
    var y1 = cy - Math.sin(rad) * len / 2;
    var x2 = cx + Math.cos(rad) * len / 2;
    var y2 = cy + Math.sin(rad) * len / 2;
    grad = ctx.createLinearGradient(x1, y1, x2, y2);
  } else if (type === 'radial') {
    grad = ctx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, Math.max(w, h) / 2);
  } else {
    grad = ctx.createConicGradient((angle - 90) * Math.PI / 180, w / 2, h / 2);
  }

  sortedStops.forEach(function(s) {
    grad.addColorStop(s.position / 100, s.color);
  });

  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, w, h);

  var link = document.createElement('a');
  link.download = 'gradient.png';
  link.href = exportCanvas.toDataURL('image/png');
  link.click();
}

// --- Angle wheel interaction ---
function setAngleFromEvent(e) {
  var rect = angleWheel.getBoundingClientRect();
  var cx = rect.left + rect.width / 2;
  var cy = rect.top + rect.height / 2;
  var dx = e.clientX - cx;
  var dy = e.clientY - cy;
  var deg = Math.round(Math.atan2(dy, dx) * 180 / Math.PI + 90);
  if (deg < 0) deg += 360;
  angle = deg;
  angleInput.value = deg;
  render();
}

var wheelDragging = false;
angleWheel.addEventListener('mousedown', function(e) {
  wheelDragging = true;
  setAngleFromEvent(e);
});
document.addEventListener('mousemove', function(e) {
  if (wheelDragging) setAngleFromEvent(e);
});
document.addEventListener('mouseup', function() { wheelDragging = false; });

angleWheel.addEventListener('touchstart', function(e) {
  wheelDragging = true;
  setAngleFromEvent(e.touches[0]);
  e.preventDefault();
}, { passive: false });
document.addEventListener('touchmove', function(e) {
  if (wheelDragging) setAngleFromEvent(e.touches[0]);
});
document.addEventListener('touchend', function() { wheelDragging = false; });

// --- Event listeners ---
gradientType.addEventListener('change', render);
angleInput.addEventListener('input', function() {
  angle = Math.max(0, Math.min(360, parseInt(angleInput.value) || 0));
  render();
});

addStopBtn.addEventListener('click', function() {
  if (stops.length >= 5) return;
  var sorted = [...stops].sort(function(a, b) { return a.position - b.position; });
  var pos = 50;
  if (sorted.length >= 2) {
    var last = sorted[sorted.length - 1].position;
    var secondLast = sorted[sorted.length - 2].position;
    pos = Math.round((last + secondLast) / 2);
  }
  var randomColor = '#' + Math.floor(Math.random() * 16777215).toString(16).padStart(6, '0');
  stops.push({ color: randomColor, position: pos });
  render();
});

prefixToggle.addEventListener('change', function() { renderExport(); });

randomBtn.addEventListener('click', function() {
  var numStops = 2 + Math.floor(Math.random() * 3);
  stops = [];
  for (var i = 0; i < numStops; i++) {
    stops.push({
      color: '#' + Math.floor(Math.random() * 16777215).toString(16).padStart(6, '0'),
      position: Math.round(i / (numStops - 1) * 100)
    });
  }
  angle = Math.floor(Math.random() * 360);
  angleInput.value = angle;
  var types = ['linear', 'radial', 'conic'];
  gradientType.value = types[Math.floor(Math.random() * 3)];
  render();
});

document.querySelectorAll('.export-tab').forEach(function(tab) {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.export-tab').forEach(function(t) { t.classList.remove('active'); });
    tab.classList.add('active');
    var fmt = tab.dataset.format;
    if (fmt === 'png') {
      downloadPNG();
    } else {
      currentExportFormat = fmt;
      renderExport();
    }
  });
});

exportCopyBtn.addEventListener('click', function() {
  var text = exportOutput.textContent;
  if (!text) return;
  navigator.clipboard.writeText(text).then(function() {
    exportCopyBtn.textContent = 'Copied!';
    setTimeout(function() { exportCopyBtn.textContent = 'Copy'; }, 1500);
  });
});

// --- Presets ---
function renderPresets() {
  presetsGrid.innerHTML = '';
  presets.forEach(function(preset, i) {
    var card = document.createElement('div');
    card.className = 'preset-card';
    var sortedStops = [...preset.stops].sort(function(a, b) { return a.position - b.position; });
    var stopsStr = sortedStops.map(function(s) { return s.color + ' ' + s.position + '%'; }).join(', ');
    var bg;
    if (preset.type === 'linear') bg = 'linear-gradient(' + preset.angle + 'deg, ' + stopsStr + ')';
    else if (preset.type === 'radial') bg = 'radial-gradient(circle, ' + stopsStr + ')';
    else bg = 'conic-gradient(from ' + preset.angle + 'deg, ' + stopsStr + ')';
    card.innerHTML = '<div class="preset-swatch" style="background:' + bg + ';"></div><div class="preset-name">' + preset.name + '</div>';
    card.addEventListener('click', function() {
      stops = preset.stops.map(function(s) { return { color: s.color, position: s.position }; });
      angle = preset.angle;
      angleInput.value = angle;
      gradientType.value = preset.type;
      render();
    });
    presetsGrid.appendChild(card);
  });
}

// --- Init ---
renderPresets();
render();
</script>

