---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "CSS Grid Generator — Visual Grid Layout Builder",
      "url": "https://siliconbased.dev/css-grid-generator",
      "description": "Free visual CSS Grid layout builder. Set columns, rows, gaps, and sizing units. Add grid items with span controls, use layout presets, and export clean CSS code.",
      "applicationCategory": "DesignApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is CSS Grid Layout?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CSS Grid Layout is a two-dimensional layout system built into CSS that lets you arrange content in rows and columns simultaneously. Unlike Flexbox which works in one dimension, Grid gives you precise control over both axes, making it ideal for full page layouts, dashboards, and complex component arrangements."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between fr, px, and auto in CSS Grid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 'fr' unit represents a fraction of the available space in the grid container — 1fr 2fr means the second column gets twice the space. 'px' sets a fixed pixel width or height. 'auto' sizes the track to fit its content. You can also use minmax(min, max) to set flexible ranges."
          }
        },
        {
          "@type": "Question",
          "name": "How do grid-column and grid-row spanning work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Grid items can span multiple columns or rows using grid-column and grid-row properties with the 'span' keyword. For example, grid-column: span 2 makes an item occupy two columns. You can also use explicit start/end lines like grid-column: 1 / 3 to place items precisely on the grid."
          }
        },
        {
          "@type": "Question",
          "name": "What is the Holy Grail layout in CSS Grid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Holy Grail layout is a classic web design pattern with a header, footer, main content area, and two sidebars. CSS Grid makes this layout trivial with grid-template-areas, allowing you to define named regions and place items into them declaratively."
          }
        },
        {
          "@type": "Question",
          "name": "Is this CSS Grid generator free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this CSS Grid generator is completely free. It runs entirely in your browser with no sign-up required. All grid generation and code export happens client-side — no data is sent to any server."
          }
        }
      ]
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>CSS Grid Generator</h1>
  <p>Visual CSS Grid layout builder. Define columns, rows, gaps, add items with span controls, and export clean CSS.</p>
</div>

<div class="main">

  <!-- Grid Settings -->
  <div class="controls-bar">
    <div class="control-group">
      <label>Columns</label>
      <input type="number" id="colCount" value="3" min="1" max="12" step="1">
    </div>
    <div class="control-group">
      <label>Rows</label>
      <input type="number" id="rowCount" value="3" min="1" max="12" step="1">
    </div>
    <div class="control-group">
      <label>Gap</label>
      <input type="number" id="gapValue" value="16" min="0" max="100" step="1">
      <span class="unit-label">px</span>
    </div>
    <button class="action-btn" id="addItemBtn">+ Add Item</button>
  </div>

  <!-- Column / Row Size Editors -->
  <div class="size-editors">
    <div class="size-editor" id="colSizeEditor">
      <h3>Column Sizes</h3>
      <div class="size-inputs" id="colSizeInputs"></div>
    </div>
    <div class="size-editor" id="rowSizeEditor">
      <h3>Row Sizes</h3>
      <div class="size-inputs" id="rowSizeInputs"></div>
    </div>
  </div>

  <!-- Presets -->
  <div class="presets-bar">
    <label>Presets</label>
    <div class="preset-btns" id="presetBtns">
      <button class="preset-btn" data-preset="holy-grail">Holy Grail</button>
      <button class="preset-btn" data-preset="dashboard">Dashboard</button>
      <button class="preset-btn" data-preset="gallery">Gallery</button>
      <button class="preset-btn" data-preset="sidebar">Sidebar Layout</button>
    </div>
  </div>

  <!-- Live Preview -->
  <div class="preview-section">
    <div class="section-header">
      <h2>Live Preview</h2>
      <span class="grid-dims" id="gridDims">3 &times; 3</span>
    </div>
    <div class="preview-container" id="previewContainer">
      <div class="preview-grid" id="previewGrid"></div>
    </div>
  </div>

  <!-- Grid Items -->
  <div class="section-block">
    <div class="section-header">
      <h2>Grid Items</h2>
      <button class="reset-btn" id="resetItemsBtn">Reset Items</button>
    </div>
    <div class="items-list" id="itemsList"></div>
  </div>

  <!-- CSS Output -->
  <div class="section-block">
    <div class="section-header">
      <h2>CSS Output</h2>
      <label class="shorthand-toggle"><input type="checkbox" id="shorthandToggle" checked> Use shorthand</label>
    </div>
    <div class="export-output-wrap" id="exportOutputWrap">
      <pre class="export-output" id="exportOutput"></pre>
      <button class="copy-btn" id="exportCopyBtn">Copy</button>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is CSS Grid Layout?</h2>
    <p>CSS Grid Layout is a powerful two-dimensional layout system that lets you define rows and columns simultaneously. Unlike Flexbox, which works along a single axis, CSS Grid gives you full control over both horizontal and vertical placement of elements. It is the foundation of modern web layouts, enabling complex designs like dashboards, galleries, and multi-column pages with minimal code.</p>

    <h2>Understanding Grid Track Sizing</h2>
    <p>Grid tracks (columns and rows) can be sized using several units:</p>
    <ul>
      <li><strong>fr (fraction):</strong> Distributes available space proportionally. <code>1fr 2fr</code> gives the second track twice the space of the first.</li>
      <li><strong>px (pixels):</strong> Sets a fixed track size. Ideal for sidebars or fixed-width columns.</li>
      <li><strong>auto:</strong> Sizes the track to fit its content. Useful for content-driven layouts.</li>
      <li><strong>minmax(min, max):</strong> Defines a size range, e.g. <code>minmax(200px, 1fr)</code> for responsive tracks that never shrink below 200px.</li>
    </ul>

    <h2>Grid Item Placement and Spanning</h2>
    <p>Grid items can span multiple columns or rows using the <code>grid-column</code> and <code>grid-row</code> properties. The <code>span</code> keyword tells an item to occupy a specific number of tracks. For example, <code>grid-column: span 2</code> makes the item stretch across two columns. You can also use explicit line numbers like <code>grid-column: 1 / 3</code> for precise placement.</p>

    <h2>Common Grid Layout Patterns</h2>
    <p>Several layout patterns appear frequently in web design and are easily built with CSS Grid:</p>
    <ul>
      <li><strong>Holy Grail:</strong> Header, footer, main content area with two sidebars — the classic web layout made trivial with Grid.</li>
      <li><strong>Dashboard:</strong> Multiple cards arranged in a responsive grid with varying sizes for key metrics and charts.</li>
      <li><strong>Gallery:</strong> Equal-sized cells for images or media, often using <code>repeat(auto-fill, minmax(...))</code> for responsiveness.</li>
      <li><strong>Sidebar Layout:</strong> A fixed or flexible sidebar alongside a main content area using <code>250px 1fr</code> column sizing.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is CSS Grid Layout?</h3>
      <p style="margin-bottom: 16px;">CSS Grid Layout is a two-dimensional layout system built into CSS that lets you arrange content in rows and columns simultaneously. Unlike Flexbox which works in one dimension, Grid gives you precise control over both axes, making it ideal for full page layouts, dashboards, and complex component arrangements.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between fr, px, and auto in CSS Grid?</h3>
      <p style="margin-bottom: 16px;">The 'fr' unit represents a fraction of the available space in the grid container — 1fr 2fr means the second column gets twice the space. 'px' sets a fixed pixel width or height. 'auto' sizes the track to fit its content. You can also use minmax(min, max) to set flexible ranges.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do grid-column and grid-row spanning work?</h3>
      <p style="margin-bottom: 16px;">Grid items can span multiple columns or rows using grid-column and grid-row properties with the 'span' keyword. For example, grid-column: span 2 makes an item occupy two columns. You can also use explicit start/end lines like grid-column: 1 / 3 to place items precisely.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the Holy Grail layout in CSS Grid?</h3>
      <p style="margin-bottom: 16px;">The Holy Grail layout is a classic web design pattern with a header, footer, main content area, and two sidebars. CSS Grid makes this layout trivial with grid-template-areas, allowing you to define named regions and place items declaratively.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is this CSS Grid generator free to use?</h3>
      <p style="margin-bottom: 16px;">Yes, this CSS Grid generator is completely free. It runs entirely in your browser with no sign-up required. All grid generation and code export happens client-side — no data is sent to any server.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/css-gradient-generator">CSS Gradient Generator</a> — Create beautiful CSS gradients with live preview and export.</li>
      <li><a href="/css-framework-comparison">CSS Framework Comparison</a> — Compare popular CSS frameworks side by side.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "CSS Grid Generator — Visual Grid Layout Builder",
  description: "Free visual CSS Grid layout builder. Set columns, rows, gaps, sizing units (fr, px, auto, minmax). Add items with span controls, use presets, and export clean CSS.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="CSS Grid Generator — Visual Grid Layout Builder"
  description="Free visual CSS Grid layout builder. Set columns, rows, gaps, sizing units (fr, px, auto, minmax). Add items with span controls, use presets, and export clean CSS."
  canonical="https://siliconbased.dev/css-grid-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
var colCountEl = document.getElementById('colCount');
var rowCountEl = document.getElementById('rowCount');
var gapValueEl = document.getElementById('gapValue');
var addItemBtn = document.getElementById('addItemBtn');
var resetItemsBtn = document.getElementById('resetItemsBtn');
var previewGrid = document.getElementById('previewGrid');
var gridDimsEl = document.getElementById('gridDims');
var itemsList = document.getElementById('itemsList');
var exportOutput = document.getElementById('exportOutput');
var exportCopyBtn = document.getElementById('exportCopyBtn');
var shorthandToggle = document.getElementById('shorthandToggle');
var colSizeInputs = document.getElementById('colSizeInputs');
var rowSizeInputs = document.getElementById('rowSizeInputs');

var colSizes = ['1fr', '1fr', '1fr'];
var rowSizes = ['1fr', '1fr', '1fr'];
var gridItems = [];
var nextItemId = 1;

var sizeUnits = ['fr', 'px', 'auto', 'minmax'];

// --- Presets ---
var presets = {
  'holy-grail': {
    cols: 3, rows: 3,
    colSizes: ['200px', '1fr', '200px'],
    rowSizes: ['auto', '1fr', 'auto'],
    gap: 16,
    items: [
      { name: 'Header', colSpan: 3, rowSpan: 1 },
      { name: 'Sidebar L', colSpan: 1, rowSpan: 1 },
      { name: 'Main', colSpan: 1, rowSpan: 1 },
      { name: 'Sidebar R', colSpan: 1, rowSpan: 1 },
      { name: 'Footer', colSpan: 3, rowSpan: 1 }
    ]
  },
  'dashboard': {
    cols: 4, rows: 3,
    colSizes: ['1fr', '1fr', '1fr', '1fr'],
    rowSizes: ['auto', '1fr', '1fr'],
    gap: 16,
    items: [
      { name: 'Stats', colSpan: 4, rowSpan: 1 },
      { name: 'Chart', colSpan: 2, rowSpan: 2 },
      { name: 'Table', colSpan: 2, rowSpan: 1 },
      { name: 'Activity', colSpan: 2, rowSpan: 1 }
    ]
  },
  'gallery': {
    cols: 3, rows: 3,
    colSizes: ['1fr', '1fr', '1fr'],
    rowSizes: ['1fr', '1fr', '1fr'],
    gap: 12,
    items: [
      { name: 'Featured', colSpan: 2, rowSpan: 2 },
      { name: 'Img 2', colSpan: 1, rowSpan: 1 },
      { name: 'Img 3', colSpan: 1, rowSpan: 1 },
      { name: 'Img 4', colSpan: 1, rowSpan: 1 },
      { name: 'Img 5', colSpan: 1, rowSpan: 1 },
      { name: 'Img 6', colSpan: 1, rowSpan: 1 }
    ]
  },
  'sidebar': {
    cols: 2, rows: 3,
    colSizes: ['250px', '1fr'],
    rowSizes: ['auto', '1fr', 'auto'],
    gap: 16,
    items: [
      { name: 'Header', colSpan: 2, rowSpan: 1 },
      { name: 'Sidebar', colSpan: 1, rowSpan: 1 },
      { name: 'Content', colSpan: 1, rowSpan: 1 },
      { name: 'Footer', colSpan: 2, rowSpan: 1 }
    ]
  }
};

var itemColors = [
  '#818cf8', '#f472b6', '#34d399', '#fbbf24', '#60a5fa',
  '#a78bfa', '#fb923c', '#2dd4bf', '#e879f9', '#f87171',
  '#38bdf8', '#4ade80'
];

function getItemColor(index) {
  return itemColors[index % itemColors.length];
}

// --- Size editor ---
function renderSizeInputs(container, sizes, type) {
  container.innerHTML = '';
  sizes.forEach(function(size, i) {
    var wrap = document.createElement('div');
    wrap.className = 'size-input-wrap';

    var label = document.createElement('span');
    label.className = 'size-label';
    label.textContent = (type === 'col' ? 'C' : 'R') + (i + 1);

    var input = document.createElement('input');
    input.type = 'text';
    input.className = 'size-value-input';
    input.value = size;
    input.dataset.index = i;
    input.dataset.type = type;
    input.addEventListener('change', function() {
      var val = input.value.trim() || '1fr';
      if (type === 'col') { colSizes[i] = val; }
      else { rowSizes[i] = val; }
      render();
    });

    wrap.appendChild(label);
    wrap.appendChild(input);
    container.appendChild(wrap);
  });
}

// --- Sync sizes with count ---
function syncSizes() {
  var cols = parseInt(colCountEl.value) || 3;
  var rows = parseInt(rowCountEl.value) || 3;
  while (colSizes.length < cols) colSizes.push('1fr');
  while (colSizes.length > cols) colSizes.pop();
  while (rowSizes.length < rows) rowSizes.push('1fr');
  while (rowSizes.length > rows) rowSizes.pop();
}

// --- Build grid template strings ---
function getColTemplate() {
  return colSizes.join(' ');
}
function getRowTemplate() {
  return rowSizes.join(' ');
}

// --- Render preview ---
function renderPreview() {
  var cols = parseInt(colCountEl.value) || 3;
  var rows = parseInt(rowCountEl.value) || 3;
  var gap = parseInt(gapValueEl.value) || 0;

  previewGrid.style.gridTemplateColumns = getColTemplate();
  previewGrid.style.gridTemplateRows = getRowTemplate();
  previewGrid.style.gap = gap + 'px';

  previewGrid.innerHTML = '';
  gridDimsEl.innerHTML = cols + ' &times; ' + rows;

  if (gridItems.length === 0) {
    // Show numbered cells for empty grid
    var total = cols * rows;
    for (var i = 0; i < total; i++) {
      var cell = document.createElement('div');
      cell.className = 'grid-cell empty-cell';
      cell.textContent = i + 1;
      previewGrid.appendChild(cell);
    }
  } else {
    gridItems.forEach(function(item, idx) {
      var cell = document.createElement('div');
      cell.className = 'grid-cell item-cell';
      cell.style.gridColumn = 'span ' + item.colSpan;
      cell.style.gridRow = 'span ' + item.rowSpan;
      cell.style.setProperty('--item-color', getItemColor(idx));
      cell.textContent = item.name;
      previewGrid.appendChild(cell);
    });
  }
}

// --- Render items list ---
function renderItems() {
  itemsList.innerHTML = '';
  if (gridItems.length === 0) {
    itemsList.innerHTML = '<p class="no-items">No grid items added. The preview shows numbered cells. Click "+ Add Item" to create grid items with span controls.</p>';
    return;
  }
  gridItems.forEach(function(item, idx) {
    var row = document.createElement('div');
    row.className = 'item-row';
    row.style.setProperty('--item-color', getItemColor(idx));

    var cols = parseInt(colCountEl.value) || 3;
    var rows = parseInt(rowCountEl.value) || 3;

    row.innerHTML =
      '<div class="item-color-dot"></div>' +
      '<input type="text" class="item-name-input" value="' + escapeAttr(item.name) + '" data-i="' + idx + '">' +
      '<div class="span-ctrl">' +
        '<label>Col span</label>' +
        '<input type="number" class="item-col-span" value="' + item.colSpan + '" min="1" max="' + cols + '" data-i="' + idx + '">' +
      '</div>' +
      '<div class="span-ctrl">' +
        '<label>Row span</label>' +
        '<input type="number" class="item-row-span" value="' + item.rowSpan + '" min="1" max="' + rows + '" data-i="' + idx + '">' +
      '</div>' +
      '<button class="stop-remove item-remove" data-i="' + idx + '" title="Remove item">&times;</button>';

    itemsList.appendChild(row);
  });

  itemsList.querySelectorAll('.item-name-input').forEach(function(el) {
    el.addEventListener('input', function() {
      gridItems[parseInt(el.dataset.i)].name = el.value;
      renderPreview();
    });
  });
  itemsList.querySelectorAll('.item-col-span').forEach(function(el) {
    el.addEventListener('input', function() {
      gridItems[parseInt(el.dataset.i)].colSpan = Math.max(1, parseInt(el.value) || 1);
      renderPreview();
      renderExport();
    });
  });
  itemsList.querySelectorAll('.item-row-span').forEach(function(el) {
    el.addEventListener('input', function() {
      gridItems[parseInt(el.dataset.i)].rowSpan = Math.max(1, parseInt(el.value) || 1);
      renderPreview();
      renderExport();
    });
  });
  itemsList.querySelectorAll('.item-remove').forEach(function(el) {
    el.addEventListener('click', function() {
      gridItems.splice(parseInt(el.dataset.i), 1);
      render();
    });
  });
}

function escapeAttr(str) {
  return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// --- Export CSS ---
function renderExport() {
  var gap = parseInt(gapValueEl.value) || 0;
  var useShorthand = shorthandToggle.checked;
  var lines = '';

  lines += '.grid-container {\n';
  lines += '  display: grid;\n';

  if (useShorthand) {
    lines += '  grid-template-columns: ' + getColTemplate() + ';\n';
    lines += '  grid-template-rows: ' + getRowTemplate() + ';\n';
  } else {
    // Explicit repeat notation where possible
    var colT = getColTemplate();
    var rowT = getRowTemplate();
    var allColsSame = colSizes.every(function(s) { return s === colSizes[0]; });
    var allRowsSame = rowSizes.every(function(s) { return s === rowSizes[0]; });
    if (allColsSame && colSizes.length > 1) {
      lines += '  grid-template-columns: repeat(' + colSizes.length + ', ' + colSizes[0] + ');\n';
    } else {
      lines += '  grid-template-columns: ' + colT + ';\n';
    }
    if (allRowsSame && rowSizes.length > 1) {
      lines += '  grid-template-rows: repeat(' + rowSizes.length + ', ' + rowSizes[0] + ');\n';
    } else {
      lines += '  grid-template-rows: ' + rowT + ';\n';
    }
  }

  lines += '  gap: ' + gap + 'px;\n';
  lines += '}';

  if (gridItems.length > 0) {
    lines += '\n';
    gridItems.forEach(function(item, idx) {
      var cls = '.item-' + (idx + 1);
      var hasSpan = item.colSpan > 1 || item.rowSpan > 1;
      if (hasSpan) {
        lines += '\n' + cls + ' {';
        if (item.colSpan > 1) lines += '\n  grid-column: span ' + item.colSpan + ';';
        if (item.rowSpan > 1) lines += '\n  grid-row: span ' + item.rowSpan + ';';
        lines += '\n}';
      }
    });
  }

  exportOutput.textContent = lines;
}

// --- Main render ---
function render() {
  syncSizes();
  renderSizeInputs(colSizeInputs, colSizes, 'col');
  renderSizeInputs(rowSizeInputs, rowSizes, 'row');
  renderPreview();
  renderItems();
  renderExport();
}

// --- Event listeners ---
colCountEl.addEventListener('input', render);
rowCountEl.addEventListener('input', render);
gapValueEl.addEventListener('input', function() {
  renderPreview();
  renderExport();
});
shorthandToggle.addEventListener('change', renderExport);

addItemBtn.addEventListener('click', function() {
  gridItems.push({ name: 'Item ' + nextItemId, colSpan: 1, rowSpan: 1 });
  nextItemId++;
  render();
});

resetItemsBtn.addEventListener('click', function() {
  gridItems = [];
  nextItemId = 1;
  render();
});

// --- Presets ---
document.querySelectorAll('.preset-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var key = btn.dataset.preset;
    var p = presets[key];
    if (!p) return;

    colCountEl.value = p.cols;
    rowCountEl.value = p.rows;
    gapValueEl.value = p.gap;
    colSizes = p.colSizes.slice();
    rowSizes = p.rowSizes.slice();

    gridItems = [];
    nextItemId = 1;
    p.items.forEach(function(item) {
      gridItems.push({ name: item.name, colSpan: item.colSpan, rowSpan: item.rowSpan });
      nextItemId++;
    });

    document.querySelectorAll('.preset-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');

    render();
  });
});

exportCopyBtn.addEventListener('click', function() {
  var text = exportOutput.textContent;
  if (!text) return;
  navigator.clipboard.writeText(text).then(function() {
    exportCopyBtn.textContent = 'Copied!';
    setTimeout(function() { exportCopyBtn.textContent = 'Copy'; }, 1500);
  });
});

// --- Init ---
render();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #0f1729 0%, #060a12 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1000px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Controls */
.controls-bar { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
.control-group { display: flex; align-items: center; gap: 8px; }
.control-group label { font-size: 0.8rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
.control-group input[type="number"] { background: #0a1020; border: 2px solid #152040; color: #e0e0e0; padding: 8px 10px; border-radius: 8px; font-size: 0.88rem; font-family: 'JetBrains Mono', monospace; outline: none; width: 70px; text-align: center; }
