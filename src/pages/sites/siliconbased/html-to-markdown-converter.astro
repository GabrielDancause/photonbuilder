---

<SiteLayout
  site="siliconbased"
  title="HTML to Markdown Converter — Convert HTML to MD Online"
  description="Free online HTML to Markdown converter with live preview, GitHub Flavored Markdown support, reverse mode, and table conversion. No data leaves your browser."
  canonical="https://siliconbased.dev/html-to-markdown-converter"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const inputArea = document.getElementById('inputArea');
const outputArea = document.getElementById('outputArea');
const inputLabel = document.getElementById('inputLabel');
const outputLabel = document.getElementById('outputLabel');
const gfmToggle = document.getElementById('gfmToggle');
const altTextToggle = document.getElementById('altTextToggle');
const lineBreakToggle = document.getElementById('lineBreakToggle');
const btnHtmlToMd = document.getElementById('btnHtmlToMd');
const btnMdToHtml = document.getElementById('btnMdToHtml');
const sampleBtn = document.getElementById('sampleBtn');
const clearBtn = document.getElementById('clearBtn');
const copyBtn = document.getElementById('copyBtn');

let mode = 'html2md';

const sampleHtml = `<h1>Welcome to My Blog</h1>
<p>This is a <strong>sample article</strong> with <em>various</em> HTML elements.</p>

<h2>Features</h2>
<ul>
  <li>Fast and <strong>reliable</strong></li>
  <li>Easy to use</li>
  <li>Supports <a href="https://github.com">GitHub</a> Flavored Markdown</li>
</ul>

<h2>Code Example</h2>
<pre><code>function greet(name) {
  return \`Hello, \${name}!\`;
}</code></pre>

<p>You can also use <code>inline code</code> in paragraphs.</p>

<h2>A Quote</h2>
<blockquote>
  <p>The best way to predict the future is to invent it.</p>
  <p>— Alan Kay</p>
</blockquote>

<h2>Comparison Table</h2>
<table>
  <thead>
    <tr>
      <th>Feature</th>
      <th>HTML</th>
      <th>Markdown</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>Readability</td>
      <td>Low</td>
      <td>High</td>
    </tr>
    <tr>
      <td>Portability</td>
      <td>Medium</td>
      <td>High</td>
    </tr>
  </tbody>
</table>

<h2>Images</h2>
<img src="https://example.com/photo.jpg" alt="A beautiful sunset" />

<hr>

<h3>Ordered Steps</h3>
<ol>
  <li>Paste your HTML</li>
  <li>Review the Markdown output</li>
  <li>Copy and use anywhere</li>
</ol>

<p>Visit <a href="https://siliconbased.dev">siliconbased.dev</a> for more tools.</p>`;

function init() {
  inputArea.addEventListener('input', convert);
  gfmToggle.addEventListener('change', convert);
  altTextToggle.addEventListener('change', convert);
  lineBreakToggle.addEventListener('change', convert);

  btnHtmlToMd.addEventListener('click', () => setMode('html2md'));
  btnMdToHtml.addEventListener('click', () => setMode('md2html'));

  sampleBtn.addEventListener('click', () => {
    if (mode === 'html2md') {
      inputArea.value = sampleHtml;
    } else {
      inputArea.value = '# Hello World\\n\\nThis is **bold** and *italic* text.\\n\\n- Item 1\\n- Item 2\\n\\n> A blockquote\\n\\n```js\\nconsole.log("hello");\\n```\\n\\n| Col A | Col B |\\n|-------|-------|\\n| 1     | 2     |';
    }
    convert();
    inputArea.focus();
  });

  clearBtn.addEventListener('click', () => {
    inputArea.value = '';
    outputArea.value = '';
    inputArea.focus();
  });

  copyBtn.addEventListener('click', () => {
    const text = outputArea.value;
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      copyBtn.textContent = '✓ Copied';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
    });
  });

  // Load sample on start
  inputArea.value = sampleHtml;
  convert();
}

function setMode(m) {
  mode = m;
  btnHtmlToMd.classList.toggle('active', m === 'html2md');
  btnMdToHtml.classList.toggle('active', m === 'md2html');
  inputLabel.textContent = m === 'html2md' ? 'HTML Input' : 'Markdown Input';
  outputLabel.textContent = m === 'html2md' ? 'Markdown Output' : 'HTML Output';
  inputArea.placeholder = m === 'html2md' ? 'Paste your HTML here...' : 'Paste your Markdown here...';
  outputArea.placeholder = m === 'html2md' ? 'Markdown output will appear here...' : 'HTML output will appear here...';
  inputArea.value = '';
  outputArea.value = '';
}

function convert() {
  const input = inputArea.value;
  if (!input.trim()) { outputArea.value = ''; return; }
  try {
    outputArea.value = mode === 'html2md' ? htmlToMarkdown(input) : markdownToHtml(input);
  } catch (e) {
    outputArea.value = 'Error: ' + e.message;
  }
}

/* ── HTML → Markdown ── */
function htmlToMarkdown(html) {
  const parser = new DOMParser();
  const doc = parser.parseFromString(html, 'text/html');
  const gfm = gfmToggle.checked;
  const includeAlt = altTextToggle.checked;
  const preserveBr = lineBreakToggle.checked;
  return processNode(doc.body, { gfm, includeAlt, preserveBr }).replace(/\n{3,}/g, '\n\n').trim();
}

function processNode(node, opts) {
  let result = '';
  for (const child of node.childNodes) {
    result += convertNode(child, opts);
  }
  return result;
}

function getTextContent(node, opts) {
  let text = '';
  for (const child of node.childNodes) {
    text += convertNode(child, opts);
  }
  return text;
}

function convertNode(node, opts) {
  if (node.nodeType === 3) {
    return node.textContent;
  }
  if (node.nodeType !== 1) return '';

  const tag = node.tagName.toLowerCase();
  const inner = () => getTextContent(node, opts);

  switch (tag) {
    case 'h1': case 'h2': case 'h3': case 'h4': case 'h5': case 'h6': {
      const level = parseInt(tag[1]);
      return '\n\n' + '#'.repeat(level) + ' ' + inner().trim() + '\n\n';
    }
    case 'p':
      return '\n\n' + inner().trim() + '\n\n';
    case 'br':
      return opts.preserveBr ? '  \n' : '\n';
    case 'strong': case 'b':
      return '**' + inner().trim() + '**';
    case 'em': case 'i':
      return '*' + inner().trim() + '*';
    case 'del': case 's':
      return opts.gfm ? '~~' + inner().trim() + '~~' : inner();
    case 'a': {
      const href = node.getAttribute('href') || '';
      const text = inner().trim();
      return '[' + text + '](' + href + ')';
    }
    case 'img': {
      const src = node.getAttribute('src') || '';
      const alt = opts.includeAlt ? (node.getAttribute('alt') || '') : '';
      return '![' + alt + '](' + src + ')';
    }
    case 'code': {
      if (node.parentElement && node.parentElement.tagName.toLowerCase() === 'pre') {
        return node.textContent;
      }
      return '`' + node.textContent + '`';
    }
    case 'pre': {
      const codeEl = node.querySelector('code');
      const code = codeEl ? codeEl.textContent : node.textContent;
      const lang = codeEl ? (codeEl.className.match(/language-(\w+)/) || [])[1] || '' : '';
      return '\n\n```' + lang + '\n' + code.replace(/\n$/, '') + '\n```\n\n';
    }
    case 'blockquote': {
      const content = inner().trim();
      const lines = content.split('\n');
      return '\n\n' + lines.map(l => '> ' + l).join('\n') + '\n\n';
    }
    case 'ul': {
      return '\n\n' + processListItems(node, opts, false) + '\n\n';
    }
    case 'ol': {
      return '\n\n' + processListItems(node, opts, true) + '\n\n';
    }
    case 'li': {
      return inner();
    }
    case 'hr':
      return '\n\n---\n\n';
    case 'table':
      return opts.gfm ? '\n\n' + convertTable(node, opts) + '\n\n' : inner();
    case 'thead': case 'tbody': case 'tfoot': case 'tr': case 'th': case 'td':
      return inner();
    case 'div': case 'section': case 'article': case 'main': case 'header': case 'footer': case 'nav': case 'aside':
      return '\n\n' + inner() + '\n\n';
    case 'span':
      return inner();
    case 'script': case 'style':
      return '';
    default:
      return inner();
  }
}

function processListItems(listNode, opts, ordered) {
  const items = [];
  let index = 1;
  for (const child of listNode.children) {
    if (child.tagName.toLowerCase() === 'li') {
      const prefix = ordered ? (index + '. ') : '- ';
      let content = '';
      let subList = '';
      for (const liChild of child.childNodes) {
        if (liChild.nodeType === 1 && (liChild.tagName.toLowerCase() === 'ul' || liChild.tagName.toLowerCase() === 'ol')) {
          const isOrdered = liChild.tagName.toLowerCase() === 'ol';
          const sub = processListItems(liChild, opts, isOrdered);
          subList += '\n' + sub.split('\n').map(l => '  ' + l).join('\n');
        } else {
          content += convertNode(liChild, opts);
        }
      }
      items.push(prefix + content.trim() + subList);
      index++;
    }
  }
  return items.join('\n');
}

function convertTable(tableNode, opts) {
  const rows = [];
  const allRows = tableNode.querySelectorAll('tr');
  allRows.forEach(tr => {
    const cells = [];
    tr.querySelectorAll('th, td').forEach(cell => {
      cells.push(getTextContent(cell, opts).trim().replace(/\|/g, '\\|'));
    });
    rows.push(cells);
  });
  if (rows.length === 0) return '';

  const colCount = Math.max(...rows.map(r => r.length));
  // Pad rows
  rows.forEach(r => { while (r.length < colCount) r.push(''); });

  const lines = [];
  lines.push('| ' + rows[0].join(' | ') + ' |');
  lines.push('| ' + rows[0].map(() => '---').join(' | ') + ' |');
  for (let i = 1; i < rows.length; i++) {
    lines.push('| ' + rows[i].join(' | ') + ' |');
  }
  return lines.join('\n');
}

/* ── Markdown → HTML (reverse mode) ── */
function markdownToHtml(md) {
  let html = md;

  // Fenced code blocks
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, function(_, lang, code) {
    const escaped = escapeHtml(code.replace(/\n$/, ''));
    return lang ? '<pre><code class="language-' + lang + '">' + escaped + '</code></pre>' : '<pre><code>' + escaped + '</code></pre>';
  });

  // Blockquotes
  html = html.replace(/^((?:>.*\n?)+)/gm, function(block) {
    const inner = block.replace(/^>\s?/gm, '').trim();
    return '<blockquote><p>' + inner + '</p></blockquote>';
  });

  // Tables (GFM)
  html = html.replace(/^(\|.+\|)\n(\|[\s:|-]+\|)\n((?:\|.+\|\n?)*)/gm, function(_, headerRow, _sep, bodyRows) {
    const headers = headerRow.split('|').filter(c => c.trim()).map(c => '<th>' + c.trim() + '</th>').join('');
    let body = '';
    bodyRows.trim().split('\n').forEach(row => {
      const cells = row.split('|').filter(c => c.trim()).map(c => '<td>' + c.trim() + '</td>').join('');
      body += '<tr>' + cells + '</tr>';
    });
    return '<table><thead><tr>' + headers + '</tr></thead><tbody>' + body + '</tbody></table>';
  });

  // Headings
  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');

  // HR
  html = html.replace(/^---$/gm, '<hr>');

  // Unordered lists
  html = html.replace(/^(?:[-*+]\s+.+\n?)+/gm, function(block) {
    const items = block.trim().split('\n').map(l => '<li>' + l.replace(/^[-*+]\s+/, '') + '</li>').join('');
    return '<ul>' + items + '</ul>';
  });

  // Ordered lists
  html = html.replace(/^(?:\d+\.\s+.+\n?)+/gm, function(block) {
    const items = block.trim().split('\n').map(l => '<li>' + l.replace(/^\d+\.\s+/, '') + '</li>').join('');
    return '<ol>' + items + '</ol>';
  });

  // Images
  html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" />');

  // Links
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');

  // Bold + italic combined
  html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');

  // Bold
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

  // Italic
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

  // Strikethrough
  html = html.replace(/~~(.+?)~~/g, '<del>$1</del>');

  // Inline code
  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

  // Paragraphs — wrap remaining lines
  html = html.replace(/^(?!<[a-z]|$)(.+)$/gm, '<p>$1</p>');

  // Clean up empty paragraphs
  html = html.replace(/<p>\s*<\/p>/g, '');

  return html.trim();
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

init();
</script>

