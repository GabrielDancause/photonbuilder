    }
  },
  {
    "@type": "FAQPage",
    "mainEntity": [

      {
        "@type": "Question",
        "name": "What is the best free serverless database?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Supabase (PostgreSQL) and Neon are currently top choices for free serverless relational databases."
        }
      },

      {
        "@type": "Question",
        "name": "Does MongoDB have a free tier?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, MongoDB Atlas offers an M0 Free Cluster providing 512MB of storage indefinitely."
        }
      },

      {
        "@type": "Question",
        "name": "Is PlanetScale still free?",
        "acceptedAnswer": {
          "@type": "Answer",
