---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Filofax Planner Capacity Calculator",
  description: "Calculate exactly how many inserts your Filofax planner ring size can hold. Don't overstuff your binder—find your perfect setup.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How many pages can a Personal size Filofax hold?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A standard Personal size Filofax with 23mm rings typically holds about 150-180 inserts of standard 80gsm paper, plus some dividers."
          }
        },
        {
          "@type": "Question",
          "name": "What is the ring size of an A5 Filofax?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most A5 Filofax planners come with 25mm or 30mm rings. The 30mm rings can comfortably hold over 200 standard paper inserts."
          }
        },
        {
          "@type": "Question",
          "name": "Does paper weight (gsm) affect how many inserts fit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, significantly. Thicker paper (like 100gsm or 120gsm) takes up more space than standard 80gsm paper, reducing the total number of inserts you can fit in your rings."
          }
        },
        {
          "@type": "Question",
          "name": "Can I overstuff my Filofax planner?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While possible, overstuffing is not recommended as it makes turning pages difficult, damages the holes in the inserts, and puts excessive strain on the ring mechanism which can cause gaps."
          }
        },
        {
          "@type": "Question",
          "name": "How much space should I leave for dividers and dashboards?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dividers, dashboards, and dashboard pockets are typically much thicker than regular paper. You should account for about 1-2mm of ring space for a set of 6 standard cardstock dividers."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": "Filofax Planner Capacity Calculator",
      "description": "Calculate exactly how many inserts your Filofax planner ring size can hold. Don't overstuff your binder—find your perfect setup.",
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      }
    }
  ]
};
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/filofax-planner" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Filofax Planner Capacity Calculator</h1>
      <p class="subtitle">Calculate exactly how many inserts your ring planner can comfortably hold based on ring size and paper weight.</p>
    </div>

    <div class="calculator-container">
      <div class="input-group">
        <label for="plannerSize">Planner / Ring Size</label>
        <select id="plannerSize">
          <option value="">Select a planner size...</option>
          <option value="11">Pocket Slimline / Mini (11mm-13mm)</option>
          <option value="15">Pocket / Personal Slim (15mm)</option>
          <option value="19">Compact (19mm)</option>
          <option value="23">Standard Personal / A5 Compact (23mm)</option>
          <option value="25">A5 Standard (25mm)</option>
          <option value="30">A5 Large / Deskfax (30mm)</option>
        </select>
        <div id="sizeError" class="error-msg" style="display: none; color: #ef4444; font-size: 0.875rem; margin-top: 0.25rem;">Please select a planner size.</div>
      </div>

      <div class="input-group" style="margin-top: 1rem;">
        <label for="paperWeight">Paper Weight (GSM)</label>
        <select id="paperWeight">
          <option value="0.09">Standard Thin (80 gsm)</option>
          <option value="0.11" selected>Quality Standard (100 gsm)</option>
          <option value="0.14">Premium Thick (120 gsm)</option>
          <option value="0.18">Cardstock / Heavy (160+ gsm)</option>
        </select>
      </div>

      <div class="input-group" style="margin-top: 1rem;">
        <label for="dividersCount">Number of Thick Dividers / Dashboards</label>
        <input type="number" id="dividersCount" min="0" max="50" value="6" placeholder="e.g., 6">
        <div id="dividersError" class="error-msg" style="display: none; color: #ef4444; font-size: 0.875rem; margin-top: 0.25rem;">Please enter a valid number of dividers (0 or more).</div>
      </div>

      <div id="resultContainer" style="display: none;">
        <div class="result-card">
          <div>Estimated Capacity</div>
          <div id="resultValue" class="result-value">--</div>
          <div style="font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.5rem;">Double-sided pages (leaves) you can comfortably fit.</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>How the Filofax Planner Capacity Calculator Works</h2>
      <p>Whether you are a seasoned planner enthusiast or setting up your very first ring-bound system, one of the most common challenges is figuring out exactly how many inserts your binder can actually hold. Planners like the iconic Filofax come in a wide variety of sizes, from the diminutive Mini and Pocket sizes to the expansive A5 and Deskfax options. Crucially, even within the same named size (like "Personal" or "A5"), the internal ring mechanisms can vary significantly in diameter.</p>

      <p>This calculator is designed to remove the guesswork from your planner setup process. By taking into account the three most important variables—the diameter of your planner's rings, the thickness or weight of your chosen paper, and the number of bulky dividers or dashboards you intend to use—this tool provides a highly accurate estimate of your maximum comfortable page capacity. It prevents the frustrating experience of ordering a year's worth of daily inserts only to discover they won't all fit, or worse, overstuffing your planner and causing permanent damage to the rings.</p>

      <h3>The Mathematics of Ring Capacity</h3>
      <p>The core methodology behind this calculator relies on basic geometry, specifically the calculation of usable internal space within a circular ring mechanism, combined with the physical thickness profiles of standard paper weights.</p>

      <p>First, it is important to understand that the stated ring size of a Filofax (e.g., 23mm or 30mm) typically refers to the external or sometimes internal diameter of the rings. However, you cannot fill a ring to 100% of its diameter. If you do, turning the pages becomes impossible without the paper binding, catching, or tearing at the punched holes. Therefore, our calculator applies a "comfortable usability factor" of approximately 75% to 80% of the total ring diameter. This represents the maximum usable thickness stack of paper that allows pages to turn smoothly over the arch of the rings.</p>

      <p>Once the usable thickness capacity is determined in millimeters, the calculator must deduct the space taken up by non-paper items. The most common space-invaders are dividers, dashboards, page lifters, and zipped pockets. A standard plastic or thick cardstock divider typically takes up about 0.3mm to 0.4mm of space. So, a standard set of 6 dividers will immediately consume about 2mm to 2.5mm of your precious ring real estate before you have even added a single piece of writing paper.</p>

      <h3>The Impact of Paper Weight (GSM)</h3>
      <p>Perhaps the most critical and often overlooked factor in planner capacity is the paper weight, usually measured in GSM (grams per square meter). While standard printer paper is around 80gsm, many modern planner inserts, especially those favored by the fountain pen community, use thicker paper like 100gsm, 120gsm, or even 160gsm to prevent ink bleeding and ghosting.</p>

      <p>Our methodology uses average caliper measurements (thickness) for these common paper weights. For example, a single sheet of standard 80gsm paper is approximately 0.09mm to 0.10mm thick. In contrast, premium 120gsm paper is often around 0.14mm to 0.15mm thick. While a difference of a few hundredths of a millimeter sounds negligible, it compounds dramatically when you are stacking hundreds of pages. If your usable ring space is 18mm, you could fit roughly 180-200 sheets of 80gsm paper, but only about 120-130 sheets of 120gsm paper. The calculator handles these conversions seamlessly based on the paper type you select from the dropdown.</p>

      <h3>Why Overstuffing is Detrimental</h3>
      <p>The temptation to fit "just a few more pages" into a Filofax is strong, especially when trying to squeeze a full year of daily inserts into a personal-sized binder. However, pushing your planner beyond the recommended capacity calculated here has several negative consequences. Firstly, it creates significant friction when turning pages. The paper will rub tightly against the ring mechanism, eventually elongating or tearing the punched holes, ruining your inserts.</p>

      <p>More importantly, overstuffing puts constant, outward pressure on the ring mechanism itself, especially when the binder is closed. Over time, this pressure can warp the metal spine and cause the rings to separate, leading to the dreaded "ring gap." Once rings develop a gap, pages will snag and fall out every time you turn them, and the mechanism is very difficult to repair. By adhering to the estimates provided by this Filofax capacity calculator, you ensure the longevity of both your expensive leather binder and your carefully curated planner inserts.</p>

      <h3>Using the Results for Your Setup</h3>
      <p>When you receive your estimated capacity, keep in mind that this number represents individual "leaves" (sheets of paper), which translates to double the number of "pages" (front and back). If the calculator says your capacity is 150 leaves, that means 300 usable pages.</p>
      <p>If you find that your ideal setup exceeds your planner's capacity, you have a few options: you can upgrade to a planner with larger rings (like moving from a Personal to an A5, or finding a rare 30mm Personal size), you can switch to thinner paper (like Tomoe River paper, which is incredibly thin at 52gsm or 68gsm but highly fountain pen friendly), or you can split your setup. Many people choose to keep only 3-6 months of daily pages in their active planner, archiving older pages in a storage binder to keep their daily carry lightweight and manageable.</p>
      <p>For more tools related to planning and tracking, be sure to check out our <a href="/erin-hurricane-tracker">Erin Hurricane Tracker</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How many pages can a Personal size Filofax hold?</summary>
        <p>A standard Personal size Filofax with 23mm rings typically holds about 150-180 inserts of standard 80gsm paper, plus some dividers.</p>
      </details>
      <details>
        <summary>What is the ring size of an A5 Filofax?</summary>
        <p>Most A5 Filofax planners come with 25mm or 30mm rings. The 30mm rings can comfortably hold over 200 standard paper inserts.</p>
      </details>
      <details>
        <summary>Does paper weight (gsm) affect how many inserts fit?</summary>
        <p>Yes, significantly. Thicker paper (like 100gsm or 120gsm) takes up more space than standard 80gsm paper, reducing the total number of inserts you can fit in your rings.</p>
      </details>
      <details>
        <summary>Can I overstuff my Filofax planner?</summary>
        <p>While possible, overstuffing is not recommended as it makes turning pages difficult, damages the holes in the inserts, and puts excessive strain on the ring mechanism which can cause gaps.</p>
      </details>
      <details>
        <summary>How much space should I leave for dividers and dashboards?</summary>
        <p>Dividers, dashboards, and dashboard pockets are typically much thicker than regular paper. You should account for about 1-2mm of ring space for a set of 6 standard cardstock dividers.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const plannerSizeSelect = document.getElementById('plannerSize');
      const paperWeightSelect = document.getElementById('paperWeight');
      const dividersCountInput = document.getElementById('dividersCount');

      const sizeError = document.getElementById('sizeError');
      const dividersError = document.getElementById('dividersError');

      const resultContainer = document.getElementById('resultContainer');
      const resultValue = document.getElementById('resultValue');

      function calculateCapacity() {
        const ringSizeRaw = plannerSizeSelect.value;
        const paperThicknessRaw = paperWeightSelect.value;
        const dividersRaw = dividersCountInput.value;

        // Reset errors
        sizeError.style.display = 'none';
        dividersError.style.display = 'none';

        if (ringSizeRaw === '') {
          sizeError.style.display = 'block';
          resultContainer.style.display = 'none';
          return;
        }

        const ringSize = parseFloat(ringSizeRaw);
        const paperThickness = parseFloat(paperThicknessRaw);
        const dividersCount = parseInt(dividersRaw, 10);

        if (isNaN(dividersCount) || dividersCount < 0) {
          dividersError.style.display = 'block';
          resultContainer.style.display = 'none';
          return;
        }

        // Usable space is approx 75% of ring diameter to allow pages to turn
        const usableRingSpace = ringSize * 0.75;

        // Assume each thick divider takes 0.35mm
        const dividerSpace = dividersCount * 0.35;

        let availableSpaceForPaper = usableRingSpace - dividerSpace;

        if (availableSpaceForPaper < 0) {
          availableSpaceForPaper = 0;
        }

        const numberOfInserts = Math.floor(availableSpaceForPaper / paperThickness);

        if (numberOfInserts <= 0) {
          resultValue.textContent = '0 Inserts';
        } else {
          resultValue.textContent = numberOfInserts + ' Inserts';
        }

        resultContainer.style.display = 'block';
      }

      plannerSizeSelect.addEventListener('change', calculateCapacity);

      paperWeightSelect.addEventListener('change', calculateCapacity);

      dividersCountInput.addEventListener('input', () => {
        if (dividersCountInput.value === '') {
           dividersError.style.display = 'none';
           resultContainer.style.display = 'none';
           return;
        }
        calculateCapacity();
      });
    });
  </script>

  <style is:inline>
