---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Scientific Calculator — Free Online Developer Tool",
  description: "A full-featured scientific calculator for developers and students. Perform complex mathematical calculations, trigonometry, and logarithms instantly in your browser.",
  category: "tool",
  date: "2025-05-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a scientific calculator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A scientific calculator is a type of electronic calculator, usually but not always handheld, designed to calculate problems in science, engineering, and mathematics. They have completely replaced slide rules in traditional applications, and are widely used in both education and professional settings."
        }
      },
      {
        "@type": "Question",
        "name": "How do I use the memory functions (MC, MR, M+, M-)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "MC clears the memory. MR recalls the value currently in memory. M+ adds the current display value to the memory. M- subtracts the current display value from the memory. These are useful for performing multi-step calculations where you need to store intermediate results."
        }
      },
      {
        "@type": "Question",
        "name": "Does this calculator support order of operations?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, this scientific calculator follows the standard mathematical order of operations (PEMDAS/BODMAS). It prioritizes parentheses, then exponents and roots, followed by multiplication and division, and finally addition and subtraction."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use this calculator for trigonometry?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. This tool includes standard trigonometric functions like sine (sin), cosine (cos), and tangent (tan), as well as their inverses. You can toggle between degree and radian modes for these calculations."
        }
      },
      {
        "@type": "Question",
        "name": "Is this calculator free to use offline?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, this calculator is completely free. Once the page is loaded, the logic runs entirely in your browser (client-side), meaning you can continue to use it even if you lose your internet connection."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Scientific Calculator — Free Online Developer Tool",
    "description": "Perform complex mathematical calculations with our free online scientific calculator. Features include trigonometry, logarithms, and memory functions.",
    "author": {
      "@type": "Organization",
      "name": "Silicon Based",
      "url": "https://siliconbased.dev"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Silicon Based",
      "url": "https://siliconbased.dev"
    },
    "datePublished": "2025-05-15"
  }
];
---

<SiteLayout
  site="siliconbased"
  title={meta.title}
  description={meta.description}
  canonical="https://siliconbased.dev/calculator"
  schema={schema}
>
  <div class="calculator-page-container">
    <div class="hero">
      <h1>Scientific Calculator</h1>
      <p class="subtitle">Advanced mathematical calculations for developers and engineers.</p>
    </div>

    <div class="calculator-wrapper">
      <div class="calculator">
        <div class="display">
          <div class="history" id="calc-history"></div>
          <div class="main-display" id="calc-display">0</div>
        </div>
        <div class="controls">
          <div class="mode-toggle-row">
            <button class="mode-btn active" id="deg-btn">DEG</button>
            <button class="mode-btn" id="rad-btn">RAD</button>
            <div class="memory-indicator" id="mem-indicator">M</div>
          </div>
          <div class="row">
            <button class="btn secondary" data-action="clear-all">AC</button>
            <button class="btn secondary" data-action="delete">DEL</button>
            <button class="btn secondary" data-op="(">(</button>
            <button class="btn secondary" data-op=")">)</button>
            <button class="btn operator" data-op="/">÷</button>
          </div>
          <div class="row">
            <button class="btn func" data-func="sin">sin</button>
            <button class="btn func" data-func="cos">cos</button>
            <button class="btn func" data-func="tan">tan</button>
            <button class="btn func" data-func="log">log</button>
            <button class="btn operator" data-op="*">×</button>
          </div>
          <div class="row">
            <button class="btn func" data-func="sqrt">√</button>
            <button class="btn func" data-func="pow">xʸ</button>
            <button class="btn func" data-func="exp">eˣ</button>
            <button class="btn func" data-func="pi">π</button>
            <button class="btn operator" data-op="-">−</button>
          </div>
          <div class="row">
            <button class="btn num">7</button>
            <button class="btn num">8</button>
            <button class="btn num">9</button>
            <button class="btn memory" data-action="m-plus">M+</button>
            <button class="btn operator" data-op="+">+</button>
          </div>
          <div class="row">
            <button class="btn num">4</button>
            <button class="btn num">5</button>
            <button class="btn num">6</button>
            <button class="btn memory" data-action="m-minus">M-</button>
            <button class="btn memory" data-action="m-recall">MR</button>
          </div>
          <div class="row">
            <button class="btn num">1</button>
            <button class="btn num">2</button>
            <button class="btn num">3</button>
            <button class="btn memory" data-action="m-clear">MC</button>
            <button class="btn func" data-func="abs">abs</button>
          </div>
          <div class="row">
            <button class="btn num zero">0</button>
            <button class="btn num">.</button>
            <button class="btn action equal" data-action="calculate">=</button>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding the Scientific Calculator</h2>
      <p>
        Calculators have come a long way since the invention of the abacus. Today, scientific calculators are essential tools for anyone working in fields like engineering, physics, and computer science. Unlike basic calculators that only perform addition, subtraction, multiplication, and division, scientific calculators include advanced functions for trigonometry, logarithms, and powers.
      </p>

      <h3>Core Features and Functions</h3>
      <ul>
        <li><strong>Trigonometry:</strong> Functions like <code>sin</code>, <code>cos</code>, and <code>tan</code> allow for the calculation of angles and sides of triangles. This calculator supports both Degree and Radian modes.</li>
        <li><strong>Logarithms:</strong> Useful for solving equations where the unknown appears as an exponent, common in measuring sound intensity (decibels) or earthquake magnitude (Richter scale).</li>
        <li><strong>Memory Functions:</strong> Tools like <code>M+</code> and <code>MR</code> allow you to store values and recall them later, which is invaluable for complex, multi-step problems.</li>
        <li><strong>Constants:</strong> Built-in values for <code>π</code> (pi) and <code>e</code> (Euler's number) ensure high precision in circular and exponential calculations.</li>
      </ul>

      <h3>Why Use an Online Scientific Calculator?</h3>
      <p>
        While physical calculators are still used in classrooms, online versions offer several advantages for developers. They are always accessible within your IDE or browser, they provide a larger display for history, and they run on the same high-performance JavaScript engines that power the modern web. This specific calculator is designed to be lightweight, mobile-responsive, and privacy-focused—no data ever leaves your device.
      </p>

      <h3>Advanced Mathematical Operations</h3>
      <p>
        Beyond simple arithmetic, this calculator supports exponents (<code>xʸ</code>), roots (<code>√</code>), and absolute values (<code>abs</code>). It uses a standard expression parser to ensure that it respects the mathematical order of operations. Whether you're debugging a layout calculation or working through a physics problem, these functions provide the precision and flexibility needed for professional work.
      </p>
    </div>

    <div class="related-tools">
        <h3>More Developer Utilities</h3>
        <ul>
            <li><a href="/chmod-calculator">Chmod Calculator</a> — Visual Linux permissions tool.</li>
            <li><a href="/cron-generator">Cron Expression Generator</a> — Build and test cron schedules.</li>
            <li><a href="/number-base">Number Base Converter</a> — Convert between Binary, Hex, and Decimal.</li>
        </ul>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faqs-container">
        {schema[0].mainEntity.map(faq => (
          <details>
            <summary>{faq.name}</summary>
            <p>{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    (function() {
      const display = document.getElementById('calc-display');
      const history = document.getElementById('calc-history');
      const memIndicator = document.getElementById('mem-indicator');
      const degBtn = document.getElementById('deg-btn');
      const radBtn = document.getElementById('rad-btn');

      let currentInput = '0';
      let expression = '';
      let memory = 0;
      let lastResult = null;
      let angleMode = 'DEG'; // 'DEG' or 'RAD'

      function updateDisplay() {
        display.textContent = currentInput;
        history.textContent = expression;
        memIndicator.style.opacity = memory !== 0 ? '1' : '0';
      }

      function handleNum(num) {
        if (lastResult !== null) {
          currentInput = num;
          expression = '';
          lastResult = null;
        } else {
          if (currentInput === '0' && num !== '.') {
            currentInput = num;
          } else {
            if (num === '.' && currentInput.includes('.')) return;
            currentInput += num;
          }
        }
        updateDisplay();
      }

      function handleOperator(op) {
        if (lastResult !== null) {
          expression = lastResult + ' ' + op + ' ';
          lastResult = null;
        } else {
          expression += currentInput + ' ' + op + ' ';
        }
        currentInput = '0';
        updateDisplay();
      }

      function handleParens(p) {
        if (lastResult !== null) {
          expression = p;
          lastResult = null;
        } else {
          if (currentInput !== '0') {
            expression += currentInput + ' ' + p + ' ';
          } else {
            expression += p + ' ';
          }
        }
        currentInput = '0';
        updateDisplay();
      }

      function toRadians(angle) {
        return angleMode === 'DEG' ? (angle * Math.PI) / 180 : angle;
      }

      function handleFunc(func) {
        let val = parseFloat(currentInput);
        let res = 0;

        switch(func) {
          case 'sin': res = Math.sin(toRadians(val)); break;
          case 'cos': res = Math.cos(toRadians(val)); break;
          case 'tan': res = Math.tan(toRadians(val)); break;
          case 'log': res = Math.log10(val); break;
          case 'sqrt': res = Math.sqrt(val); break;
          case 'abs': res = Math.abs(val); break;
          case 'exp': res = Math.exp(val); break;
          case 'pi': res = Math.PI; break;
          case 'pow':
            expression += currentInput + ' ^ ';
            currentInput = '0';
            updateDisplay();
            return;
        }

        currentInput = parseFloat(res.toFixed(10)).toString();
        updateDisplay();
      }

      function calculate() {
        let fullExpression = expression;
        if (currentInput !== '0' || !expression.trim().endsWith(')')) {
          fullExpression += currentInput;
        }

        // Basic sanitization and conversion for eval
        let toEval = fullExpression.replace(/÷/g, '/').replace(/×/g, '*').replace(/xʸ/g, '**').replace(/\^/g, '**');

        try {
          // Use Function instead of eval for slight safety boost in math context
          let result = new Function('return ' + toEval)();

          if (isNaN(result) || !isFinite(result)) {
            throw new Error('Invalid Result');
          }

          history.textContent = fullExpression + ' =';
          currentInput = parseFloat(result.toFixed(10)).toString();
          lastResult = currentInput;
          expression = '';
          updateDisplay();
        } catch (e) {
          console.error(e);
          currentInput = 'Error';
          expression = '';
          updateDisplay();
          setTimeout(() => { currentInput = '0'; updateDisplay(); }, 1500);
        }
      }

      function handleAction(action) {
        switch(action) {
          case 'clear-all':
            currentInput = '0';
            expression = '';
            lastResult = null;
            break;
          case 'delete':
            if (currentInput.length > 1) {
              currentInput = currentInput.slice(0, -1);
            } else {
              currentInput = '0';
            }
            break;
          case 'calculate':
            calculate();
            break;
          case 'm-plus':
            memory += parseFloat(currentInput);
            break;
          case 'm-minus':
            memory -= parseFloat(currentInput);
            break;
          case 'm-recall':
            currentInput = memory.toString();
            break;
          case 'm-clear':
            memory = 0;
            break;
        }
        updateDisplay();
      }

      degBtn.addEventListener('click', () => {
        angleMode = 'DEG';
        degBtn.classList.add('active');
        radBtn.classList.remove('active');
      });

      radBtn.addEventListener('click', () => {
        angleMode = 'RAD';
        radBtn.classList.add('active');
        degBtn.classList.remove('active');
      });

      document.querySelectorAll('.btn').forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.classList.contains('num')) {
            handleNum(btn.textContent);
          } else if (btn.classList.contains('operator')) {
            handleOperator(btn.dataset.op);
          } else if (btn.classList.contains('func')) {
            handleFunc(btn.dataset.func);
          } else if (btn.classList.contains('action') || btn.classList.contains('secondary') || btn.classList.contains('memory')) {
            handleAction(btn.dataset.action || btn.dataset.op);
          } else if (btn.dataset.op === '(' || btn.dataset.op === ')') {
              handleParens(btn.dataset.op);
          }
        });
      });
    })();
  </script>

  <style is:inline>
    .calculator-page-container { max-width: 900px; margin: 0 auto; padding: 6rem 1.5rem 2rem; }
    .hero { text-align: center; padding: 1rem 0 2rem; position: relative; z-index: 10; }
    .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    /* Calculator Styles */
    .calculator-wrapper { display: flex; justify-content: center; margin: 1rem 0 3rem; position: relative; z-index: 10; }
    .calculator {
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 20px;
      padding: 1.5rem;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    .display {
      background: #0f172a;
      border: 1px solid #334155;
      border-radius: 12px;
      padding: 1rem;
      margin-bottom: 1rem;
      text-align: right;
      min-height: 110px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }

    .history { color: #94a3b8; font-family: var(--font-mono); font-size: 0.9rem; min-height: 1.2rem; margin-bottom: 0.5rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .main-display { color: #f8fafc; font-family: var(--font-mono); font-size: 2.2rem; font-weight: 700; overflow: hidden; text-overflow: ellipsis; }

    .mode-toggle-row { display: flex; gap: 0.5rem; margin-bottom: 1rem; align-items: center; }
    .mode-btn { background: #334155; border: none; border-radius: 6px; color: #94a3b8; font-size: 0.75rem; font-weight: 700; padding: 4px 10px; cursor: pointer; transition: all 0.2s; }
    .mode-btn.active { background: #818cf8; color: #fff; }
    .memory-indicator { margin-left: auto; color: #818cf8; font-weight: 800; font-size: 0.8rem; opacity: 0; transition: opacity 0.2s; }

    .controls { display: grid; gap: 0.75rem; }
    .row { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem; }

    .btn {
      background: #334155;
      border: none;
      border-radius: 12px;
      color: #f8fafc;
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: 1.1rem;
      font-weight: 600;
      height: 52px;
      transition: all 0.15s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      user-select: none;
    }

    .btn:hover { background: #475569; transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }

    .btn.operator { background: #4338ca; color: #fff; }
    .btn.operator:hover { background: #4f46e5; }

    .btn.equal { background: #818cf8; color: #fff; grid-column: span 2; }
    .btn.equal:hover { background: #6366f1; }

    .btn.num.zero { grid-column: span 2; }

    .btn.secondary { background: #475569; color: #cbd5e1; }
    .btn.secondary:hover { background: #64748b; }

    .btn.func { background: #1e293b; border: 1px solid #334155; color: #818cf8; font-size: 0.95rem; }
    .btn.func:hover { border-color: #818cf8; background: rgba(129, 140, 248, 0.1); }

    .btn.memory { background: #0f172a; color: #94a3b8; font-size: 0.85rem; border: 1px solid #1e293b; }

    /* Explainer & Content */
    .explainer { margin-top: 4rem; line-height: 1.7; position: relative; z-index: 10; }
    .explainer h2 { font-size: 1.8rem; margin-bottom: 1.5rem; color: #818cf8; }
    .explainer h3 { font-size: 1.4rem; margin: 2rem 0 1rem; }
    .explainer p { margin-bottom: 1.2rem; color: var(--text-secondary); }
    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer code { background: rgba(129, 140, 248, 0.1); color: #818cf8; padding: 0.2rem 0.4rem; border-radius: 4px; }

    .related-tools { margin: 3rem 0; padding: 2rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; position: relative; z-index: 10; }
    .related-tools h3 { margin-top: 0; margin-bottom: 1rem; }
    .related-tools ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .related-tools a { color: #818cf8; text-decoration: none; font-weight: 500; }
    .related-tools a:hover { text-decoration: underline; }

    .faq-section { margin-top: 4rem; position: relative; z-index: 10; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 2rem; text-align: center; }
    .faq-section details { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 1rem; padding: 1rem; cursor: pointer; }
    .faq-section summary { font-weight: 600; font-size: 1.1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .faq-section summary::after { content: '+'; font-size: 1.5rem; color: #818cf8; }
    .faq-section details[open] summary::after { content: '−'; }
    .faq-section p { margin-top: 1rem; color: var(--text-secondary); line-height: 1.6; }

    /* Sticky Nav overlap fix */
    .sticky-nav { z-index: 100 !important; }

    @media (max-width: 600px) {
      .row { gap: 0.5rem; }
      .btn { height: 48px; font-size: 1rem; border-radius: 8px; }
      .main-display { font-size: 1.8rem; }
      .calculator { padding: 1rem; }
      .hero h1 { font-size: 2rem; }
    }
  </style>
</SiteLayout>
