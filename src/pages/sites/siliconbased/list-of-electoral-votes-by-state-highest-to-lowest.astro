      }
    },
    {
      "@type": "Question",
      "name": "What happens if a state loses electoral votes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When a state loses electoral votes after a census, it means its population growth was slower compared to other states. This triggers congressional redistricting, where the state must redraw its district maps to account for the reduced number of House seats."
      }
    },
    {
      "@type": "Question",
      "name": "How many electoral votes are needed to win the presidency?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A candidate must secure an absolute majority of the Electoral College to win the presidency. With a total of 538 electoral votes available, the magic number required to win is 270 electoral votes."
