  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const m11Input = document.getElementById("m11");
      const m12Input = document.getElementById("m12");
      const m21Input = document.getElementById("m21");
      const m22Input = document.getElementById("m22");
      const errorMsg = document.getElementById("error-message");
      const resultsDiv = document.getElementById("results");

      const charPolyEl = document.getElementById("char-poly");
      const eigenvaluesEl = document.getElementById("eigenvalues");
      const eigenvectorsEl = document.getElementById("eigenvectors");

      const inputs = [m11Input, m12Input, m21Input, m22Input];

      function formatNumber(num) {
        if (Math.abs(num - Math.round(num)) < 1e-10) {
          return Math.round(num).toString();
        }
        return num.toFixed(4).replace(/\.?0+$/, "");
      }

      function formatComplex(real, imag) {
        if (Math.abs(imag) < 1e-10) return formatNumber(real);
        const sign = imag < 0 ? "-" : "+";
        const val = Math.abs(imag) === 1 ? "i" : formatNumber(Math.abs(imag)) + "i";
        if (Math.abs(real) < 1e-10) return sign === "-" ? "-" + val : val;
        return `${formatNumber(real)} ${sign} ${val}`;
      }

      function calculate() {
        const vals = inputs.map(i => i.value.trim());
        if (vals.some(v => v === "")) {
          resultsDiv.style.display = "none";
          errorMsg.style.display = "none";
          return;
        }

        const nums = vals.map(v => parseFloat(v));
        if (nums.some(n => isNaN(n))) {
          resultsDiv.style.display = "none";
          errorMsg.textContent = "Please enter valid numbers in all fields.";
          errorMsg.style.display = "block";
          return;
        }

        errorMsg.style.display = "none";

        const a = nums[0], b = nums[1], c = nums[2], d = nums[3];
        const trace = a + d;
        const det = a * d - b * c;

        const signT = trace < 0 ? "+" : "-";
        const signD = det < 0 ? "-" : "+";
        const strT = Math.abs(trace) === 1 ? "" : formatNumber(Math.abs(trace));
        const strD = formatNumber(Math.abs(det));

        let poly = "λ² ";
        if (Math.abs(trace) > 1e-10) poly += `${signT} ${strT}λ `;
        if (Math.abs(det) > 1e-10) poly += `${signD} ${strD}`;
        if (Math.abs(trace) <= 1e-10 && Math.abs(det) <= 1e-10) poly = "λ²";
        poly += " = 0";
        charPolyEl.textContent = poly;

        const discriminant = trace * trace - 4 * det;

        let e1, e2, isComplex = false;

        if (discriminant >= 0) {
          e1 = (trace + Math.sqrt(discriminant)) / 2;
          e2 = (trace - Math.sqrt(discriminant)) / 2;

          if (Math.abs(e1 - e2) < 1e-10) {
            eigenvaluesEl.innerHTML = `λ = ${formatNumber(e1)} (Multiplicity 2)`;
          } else {
            eigenvaluesEl.innerHTML = `λ₁ = ${formatNumber(e1)}<br>λ₂ = ${formatNumber(e2)}`;
          }
        } else {
          isComplex = true;
          const real = trace / 2;
          const imag = Math.sqrt(-discriminant) / 2;
          e1 = { r: real, i: imag };
          e2 = { r: real, i: -imag };
          eigenvaluesEl.innerHTML = `λ₁ = ${formatComplex(real, imag)}<br>λ₂ = ${formatComplex(real, -imag)}`;
        }

        // Calculate Eigenvectors
        eigenvectorsEl.innerHTML = "";

        if (isComplex) {
          eigenvectorsEl.innerHTML = "<em>Complex eigenvectors shown in simplified form.</em><br>";

          const lambda1 = e1;
          if (Math.abs(b) > 1e-10) {
            const y_real = (lambda1.r - a) / b;
            const y_imag = lambda1.i / b;
            eigenvectorsEl.innerHTML += `v₁ ≈ [ 1, ${formatComplex(y_real, y_imag)} ]ᵀ<br>`;
            eigenvectorsEl.innerHTML += `v₂ ≈ [ 1, ${formatComplex(y_real, -y_imag)} ]ᵀ`;
          } else if (Math.abs(c) > 1e-10) {
            const x_real = (lambda1.r - d) / c;
            const x_imag = lambda1.i / c;
            eigenvectorsEl.innerHTML += `v₁ ≈ [ ${formatComplex(x_real, x_imag)}, 1 ]ᵀ<br>`;
            eigenvectorsEl.innerHTML += `v₂ ≈ [ ${formatComplex(x_real, -x_imag)}, 1 ]ᵀ`;
          } else {
            eigenvectorsEl.innerHTML += `v₁ = [ 1, 0 ]ᵀ<br>v₂ = [ 0, 1 ]ᵀ`;
          }
        } else {
          const vals = Math.abs(e1 - e2) < 1e-10 ? [e1] : [e1, e2];

          vals.forEach((lambda, index) => {
            let vx, vy;
            if (Math.abs(b) > 1e-10) {
              vx = b;
              vy = lambda - a;
            } else if (Math.abs(c) > 1e-10) {
              vy = c;
              vx = lambda - d;
            } else {
              if (Math.abs(a - lambda) < 1e-10 && Math.abs(d - lambda) < 1e-10) {
                 vx = 1; vy = 0;
                 eigenvectorsEl.innerHTML += `v₁ = [ 1, 0 ]ᵀ<br>v₂ = [ 0, 1 ]ᵀ<br>`;
                 return;
              } else if (Math.abs(a - lambda) < 1e-10) {
                 vx = 1; vy = 0;
              } else {
                 vx = 0; vy = 1;
              }
            }

            const maxVal = Math.max(Math.abs(vx), Math.abs(vy));
            if (maxVal > 0) {
              vx /= maxVal;
              vy /= maxVal;
            }

            if (Math.abs(vx) > 1e-10 && Math.abs(vy) > 1e-10) {
              const ratio = Math.abs(vx / vy);
              if (Math.abs(Math.round(ratio) - ratio) < 1e-5) {
                if (Math.abs(vx) < Math.abs(vy)) {
                   vy /= vx; vx = 1;
                } else {
                   vx /= vy; vy = 1;
                }
              }
            }

            if (vals.length === 1 && Math.abs(a - lambda) > 1e-10) {
               eigenvectorsEl.innerHTML += `v = [ ${formatNumber(vx)}, ${formatNumber(vy)} ]ᵀ<br>`;
               eigenvectorsEl.innerHTML += `<em>Defective matrix (only 1 linearly independent eigenvector).</em><br>`;
            } else if (vals.length > 1 || (Math.abs(b) <= 1e-10 && Math.abs(c) <= 1e-10 && index===0)) {
               if (!(vals.length === 1 && Math.abs(a-lambda) < 1e-10 && Math.abs(d-lambda) < 1e-10)) {
                  eigenvectorsEl.innerHTML += `v${index + 1} = [ ${formatNumber(vx)}, ${formatNumber(vy)} ]ᵀ<br>`;
               }
            }
          });
        }

        resultsDiv.style.display = "block";
      }

      inputs.forEach(input => {
        input.addEventListener("input", calculate);
      });

      calculate();
    });
  </script>

