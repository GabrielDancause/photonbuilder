        </div>
        <div class="matrix-row">
          <div class="input-group">
            <label for="m21">c (2,1)</label>
            <input type="number" id="m21" placeholder="e.g. 2" step="any" />
          </div>
          <div class="input-group">
            <label for="m22">d (2,2)</label>
            <input type="number" id="m22" placeholder="e.g. 3" step="any" />
          </div>
