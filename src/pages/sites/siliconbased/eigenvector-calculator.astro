>
  <div class="page-content">
    <div class="hero">
      <h1>Eigenvector & Eigenvalue Calculator</h1>
      <p class="subtitle">Instantly compute characteristic polynomials, eigenvalues, and eigenvectors for 2x2 matrices.</p>
    </div>

    <div class="calculator-container">
      <div class="matrix-input-grid">
        <div class="matrix-row">
          <div class="input-group">
            <label for="m11">a (1,1)</label>
            <input type="number" id="m11" placeholder="e.g. 4" step="any" />
          </div>
