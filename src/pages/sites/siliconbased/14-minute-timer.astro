<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/14-minute-timer" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Online 14 Minute Timer</h1>
