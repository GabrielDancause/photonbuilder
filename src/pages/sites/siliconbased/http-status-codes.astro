<SiteLayout
  site="siliconbased"
  title="HTTP Status Codes Reference — Complete List with Explanations"
  description="Complete HTTP status codes list. Searchable reference of all HTTP response codes (1xx–5xx) with descriptions, common causes, and fixes. Look up 404 meaning, 500 error, and more."
  canonical="https://siliconbased.dev/http-status-codes"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
var STATUS_CODES = [
  // 1xx Informational
  { code: 100, name: 'Continue', cat: '1', desc: 'The server received the request headers and the client should proceed to send the request body.', causes: 'Client sent Expect: 100-continue header.', fix: '' },
  { code: 101, name: 'Switching Protocols', cat: '1', desc: 'The server is switching protocols as requested by the client (e.g., upgrading to WebSocket).', causes: 'Client requested protocol upgrade via Upgrade header.', fix: '' },
  { code: 102, name: 'Processing', cat: '1', desc: 'The server has received and is processing the request, but no response is available yet (WebDAV).', causes: 'Long-running WebDAV operations.', fix: '' },
  { code: 103, name: 'Early Hints', cat: '1', desc: 'Used to return some response headers before the final HTTP message, allowing the browser to preload resources.', causes: 'Server sends Link headers early for performance optimization.', fix: '' },

  // 2xx Success
  { code: 200, name: 'OK', cat: '2', desc: 'The request succeeded. The meaning depends on the HTTP method: GET returns the resource, POST returns the result of the action.', causes: '', fix: '' },
  { code: 201, name: 'Created', cat: '2', desc: 'The request succeeded and a new resource was created. Typically returned after POST or PUT requests.', causes: '', fix: '' },
  { code: 202, name: 'Accepted', cat: '2', desc: 'The request has been accepted for processing, but the processing has not been completed. Used for async operations.', causes: '', fix: '' },
  { code: 203, name: 'Non-Authoritative Information', cat: '2', desc: 'The returned metadata is not exactly the same as available from the origin server. A transforming proxy modified the headers.', causes: '', fix: '' },
  { code: 204, name: 'No Content', cat: '2', desc: 'The request succeeded but there is no content to return. Commonly used for DELETE requests and form submissions that don\'t navigate.', causes: '', fix: '' },
  { code: 205, name: 'Reset Content', cat: '2', desc: 'The server successfully processed the request and asks the client to reset the document view (e.g., clear a form).', causes: '', fix: '' },
  { code: 206, name: 'Partial Content', cat: '2', desc: 'The server is delivering only part of the resource due to a Range header sent by the client. Used for resumable downloads and video streaming.', causes: '', fix: '' },
  { code: 207, name: 'Multi-Status', cat: '2', desc: 'Conveys information about multiple resources where multiple status codes might be appropriate (WebDAV).', causes: '', fix: '' },
  { code: 208, name: 'Already Reported', cat: '2', desc: 'Members of a DAV binding have already been enumerated in a preceding part of the multistatus response (WebDAV).', causes: '', fix: '' },
  { code: 226, name: 'IM Used', cat: '2', desc: 'The server has fulfilled a GET request and the response represents the result of instance-manipulations applied.', causes: '', fix: '' },

  // 3xx Redirection
  { code: 300, name: 'Multiple Choices', cat: '3', desc: 'The request has more than one possible response. The user or user agent should choose one of them.', causes: '', fix: '' },
  { code: 301, name: 'Moved Permanently', cat: '3', desc: 'The resource has been permanently moved to a new URL. Browsers and search engines will use the new URL going forward.', causes: 'URL restructure, domain migration, HTTP to HTTPS.', fix: 'Update bookmarks and internal links to the new URL.' },
  { code: 302, name: 'Found', cat: '3', desc: 'The resource is temporarily located at a different URL. The original URL should still be used for future requests.', causes: 'Temporary redirects, A/B tests, geo-routing.', fix: 'Follow the redirect. If you own the server, consider whether 301 is more appropriate.' },
  { code: 303, name: 'See Other', cat: '3', desc: 'The response to the request can be found at another URL using a GET method. Often used after POST to redirect to a results page.', causes: 'POST/redirect/GET pattern.', fix: '' },
  { code: 304, name: 'Not Modified', cat: '3', desc: 'The resource has not been modified since the last request. The client can use its cached version. No body is returned.', causes: 'Client sent If-None-Match or If-Modified-Since and the resource hasn\'t changed.', fix: '' },
  { code: 307, name: 'Temporary Redirect', cat: '3', desc: 'The resource is temporarily at a different URL. Unlike 302, the HTTP method must not change (POST stays POST).', causes: 'HSTS redirects, load balancer routing.', fix: '' },
  { code: 308, name: 'Permanent Redirect', cat: '3', desc: 'The resource has been permanently moved. Unlike 301, the HTTP method must not change (POST stays POST).', causes: 'API endpoint migration where method preservation matters.', fix: '' },

  // 4xx Client Error
  { code: 400, name: 'Bad Request', cat: '4', desc: 'The server cannot process the request due to malformed syntax, invalid request framing, or deceptive request routing.', causes: 'Malformed JSON/XML, missing required fields, invalid query parameters, oversized request body.', fix: 'Check the request body format, validate required fields, and ensure Content-Type matches the body.' },
  { code: 401, name: 'Unauthorized', cat: '4', desc: 'The request requires authentication. The client must provide valid credentials (API key, token, username/password).', causes: 'Missing or expired auth token, invalid API key, session timeout.', fix: 'Include valid authentication credentials. Check that your token hasn\'t expired and the API key is correct.' },
  { code: 403, name: 'Forbidden', cat: '4', desc: 'The server understood the request but refuses to authorize it. Unlike 401, re-authenticating will not help.', causes: 'Insufficient permissions, IP blocking, CORS policy violation, directory listing disabled.', fix: 'Verify you have the correct permissions. Check IP allowlists, CORS configuration, and file/directory permissions.' },
  { code: 404, name: 'Not Found', cat: '4', desc: 'The server cannot find the requested resource. The URL may be wrong, or the resource may have been deleted.', causes: 'Mistyped URL, deleted resource, broken link, missing route handler.', fix: 'Check the URL for typos. Set up 301 redirects for moved pages. Create a custom 404 page.' },
  { code: 405, name: 'Method Not Allowed', cat: '4', desc: 'The HTTP method (GET, POST, PUT, DELETE, etc.) is not supported for the requested resource.', causes: 'Using POST on a GET-only endpoint, sending DELETE to a read-only resource.', fix: 'Check API docs for supported methods. The response includes an Allow header listing valid methods.' },
  { code: 406, name: 'Not Acceptable', cat: '4', desc: 'The server cannot produce a response matching the Accept headers sent by the client.', causes: 'Client requested a content type the server doesn\'t support (e.g., Accept: application/xml on JSON-only API).', fix: 'Adjust the Accept header to a format the server supports.' },
  { code: 407, name: 'Proxy Authentication Required', cat: '4', desc: 'The client must first authenticate with the proxy server.', causes: 'Corporate proxy requires authentication.', fix: 'Configure proxy authentication credentials.' },
  { code: 408, name: 'Request Timeout', cat: '4', desc: 'The server timed out waiting for the request. The client took too long to send the complete request.', causes: 'Slow network connection, large file upload on unstable connection.', fix: 'Retry the request. Check network connectivity. For large uploads, consider chunked transfer encoding.' },
  { code: 409, name: 'Conflict', cat: '4', desc: 'The request conflicts with the current state of the target resource. Often used for duplicate resource creation or edit conflicts.', causes: 'Creating a resource that already exists, concurrent edit conflicts, version mismatch.', fix: 'Fetch the current resource state and retry. Use optimistic locking (ETags) for concurrent edits.' },
  { code: 410, name: 'Gone', cat: '4', desc: 'The resource is permanently gone and will not be available again. Unlike 404, this is intentional and permanent.', causes: 'Intentionally removed content, deprecated API endpoint.', fix: 'The resource is intentionally removed. Update links. Search engines de-index faster than with 404.' },
  { code: 411, name: 'Length Required', cat: '4', desc: 'The server requires a Content-Length header in the request.', causes: 'Missing Content-Length header on a request with a body.', fix: 'Add a Content-Length header to the request.' },
  { code: 412, name: 'Precondition Failed', cat: '4', desc: 'One or more conditions in the request headers (If-Match, If-Unmodified-Since) evaluated to false.', causes: 'ETag mismatch in conditional request, resource was modified since the specified date.', fix: 'Fetch the latest version of the resource and retry with updated precondition headers.' },
  { code: 413, name: 'Content Too Large', cat: '4', desc: 'The request body is larger than the server is willing or able to process.', causes: 'File upload exceeds size limit, JSON payload too large.', fix: 'Reduce request body size. Check server upload limits (e.g., client_max_body_size in Nginx).' },
  { code: 414, name: 'URI Too Long', cat: '4', desc: 'The request URI is longer than the server is willing to interpret.', causes: 'Extremely long query strings, large data encoded in the URL.', fix: 'Use POST with a request body instead of encoding data in the URL.' },
  { code: 415, name: 'Unsupported Media Type', cat: '4', desc: 'The server does not support the media type of the request body.', causes: 'Sending JSON with Content-Type: text/plain, or uploading an unsupported file format.', fix: 'Set the correct Content-Type header (e.g., application/json for JSON data).' },
  { code: 416, name: 'Range Not Satisfiable', cat: '4', desc: 'The Range header field specifies a range that the server cannot satisfy.', causes: 'Requesting bytes beyond the end of a file.', fix: 'Check the Content-Length of the resource and adjust the Range header.' },
  { code: 418, name: "I'm a Teapot", cat: '4', desc: 'Any attempt to brew coffee with a teapot should result in this error. Defined in RFC 2324 as an April Fools\' joke.', causes: 'Attempting to brew coffee with a teapot.', fix: 'Use a coffee pot instead. Or just enjoy the joke.' },
  { code: 422, name: 'Unprocessable Content', cat: '4', desc: 'The request is well-formed but contains semantic errors. The server understands the syntax but cannot process the instructions.', causes: 'Validation errors: invalid email format, negative quantity, date in the past, business rule violations.', fix: 'Check the response body for specific validation errors and fix the request data accordingly.' },
  { code: 429, name: 'Too Many Requests', cat: '4', desc: 'The user has sent too many requests in a given time window (rate limiting).', causes: 'Exceeding API rate limits, aggressive scraping, missing request throttling in client code.', fix: 'Implement exponential backoff. Check the Retry-After header. Cache responses to reduce request volume.' },
  { code: 451, name: 'Unavailable For Legal Reasons', cat: '4', desc: 'The server is denying access to the resource as a consequence of a legal demand.', causes: 'Government censorship, court order, DMCA takedown.', fix: 'The resource is legally restricted in your jurisdiction.' },

  // 5xx Server Error
  { code: 500, name: 'Internal Server Error', cat: '5', desc: 'A generic server-side error. The server encountered an unexpected condition that prevented it from fulfilling the request.', causes: 'Unhandled exceptions, syntax errors, null pointer errors, misconfigured server, failed database queries.', fix: 'Check server error logs. Review recent deployments. Test the failing endpoint in isolation. Verify database connectivity.' },
  { code: 501, name: 'Not Implemented', cat: '5', desc: 'The server does not support the functionality required to fulfill the request (e.g., an unrecognized HTTP method).', causes: 'Using a method the server doesn\'t support, feature not yet built.', fix: 'Use a supported HTTP method. Check server documentation for available features.' },
  { code: 502, name: 'Bad Gateway', cat: '5', desc: 'The server acting as a gateway or proxy received an invalid response from the upstream server.', causes: 'Upstream server crashed, network issues between servers, misconfigured reverse proxy, upstream timeout.', fix: 'Check if the upstream server is running. Review proxy config (Nginx, Apache, load balancer). Check for network issues.' },
  { code: 503, name: 'Service Unavailable', cat: '5', desc: 'The server is currently unable to handle the request due to temporary overloading or scheduled maintenance.', causes: 'Server overloaded, planned maintenance, deployment in progress, resource exhaustion (CPU, memory, connections).', fix: 'Wait and retry (check Retry-After header). Scale server resources. Implement request queuing or load balancing.' },
  { code: 504, name: 'Gateway Timeout', cat: '5', desc: 'The server acting as a gateway or proxy did not receive a timely response from the upstream server.', causes: 'Upstream server too slow, network latency, long-running database queries, insufficient timeout config.', fix: 'Increase proxy timeout settings. Optimize slow upstream operations. Check for network bottlenecks.' },
  { code: 505, name: 'HTTP Version Not Supported', cat: '5', desc: 'The server does not support the HTTP protocol version used in the request.', causes: 'Client using an unsupported HTTP version.', fix: 'Use a supported HTTP version (typically HTTP/1.1 or HTTP/2).' },
  { code: 507, name: 'Insufficient Storage', cat: '5', desc: 'The server cannot store the representation needed to complete the request (WebDAV).', causes: 'Server disk full, storage quota exceeded.', fix: 'Free up server disk space or increase storage quota.' },
  { code: 508, name: 'Loop Detected', cat: '5', desc: 'The server detected an infinite loop while processing the request (WebDAV).', causes: 'Circular references in WebDAV bindings.', fix: 'Check for circular references in the resource structure.' },
  { code: 511, name: 'Network Authentication Required', cat: '5', desc: 'The client needs to authenticate to gain network access (captive portal).', causes: 'Hotel/airport Wi-Fi captive portal, corporate network login.', fix: 'Open a browser and complete the network login page.' }
];

var COMMON_CODES = [200, 201, 301, 302, 304, 400, 401, 403, 404, 405, 422, 429, 500, 502, 503, 504];

var CAT_LABELS = { '1': '1xx \u2014 Informational', '2': '2xx \u2014 Success', '3': '3xx \u2014 Redirection', '4': '4xx \u2014 Client Error', '5': '5xx \u2014 Server Error' };
var CAT_ORDER = ['1', '2', '3', '4', '5'];

var searchInput = document.getElementById('searchInput');
var codeList = document.getElementById('codeList');
var filterChips = document.getElementById('filterChips');
var activeFilter = 'all';

function init() {
  renderCodes('', 'all');

  searchInput.addEventListener('input', function() {
    renderCodes(searchInput.value.trim().toLowerCase(), activeFilter);
  });

  filterChips.addEventListener('click', function(e) {
    var btn = e.target.closest('.chip');
    if (!btn) return;
    activeFilter = btn.dataset.filter;
    filterChips.querySelectorAll('.chip').forEach(function(c) { c.classList.remove('active'); });
    btn.classList.add('active');
    renderCodes(searchInput.value.trim().toLowerCase(), activeFilter);
  });
}

function renderCodes(query, filter) {
  var filtered = STATUS_CODES.filter(function(s) {
    if (filter !== 'all' && s.cat !== filter) return false;
    if (!query) return true;
    var haystack = (s.code + ' ' + s.name + ' ' + s.desc).toLowerCase();
    return haystack.indexOf(query) !== -1;
  });

  if (filtered.length === 0) {
    codeList.innerHTML = '<div class="empty-state">No status codes match your search.</div>';
    return;
  }

  var groups = {};
  filtered.forEach(function(s) {
    if (!groups[s.cat]) groups[s.cat] = [];
    groups[s.cat].push(s);
  });

  var html = '';
  CAT_ORDER.forEach(function(cat) {
    if (!groups[cat]) return;
    html += '<div class="code-category">';
    html += '<div class="cat-header cat-' + cat + 'xx">' + CAT_LABELS[cat] + '</div>';
    groups[cat].forEach(function(s) {
      var isCommon = COMMON_CODES.indexOf(s.code) !== -1;
      html += '<div class="code-card code-' + s.cat + 'xx' + (isCommon ? ' common' : '') + '">';
      html += '<div class="code-main">';
      html += '<div class="code-number">' + s.code + '</div>';
      html += '<div class="code-info">';
      html += '<div class="code-name">' + s.name + (isCommon ? '<span class="common-badge">Common</span>' : '') + '</div>';
      html += '<div class="code-desc">' + s.desc + '</div>';
      if (s.causes || s.fix) {
        html += '<div class="code-details">';
        if (s.causes) html += '<div class="code-detail"><strong>Common causes:</strong> ' + s.causes + '</div>';
        if (s.fix) html += '<div class="code-detail"><strong>How to fix:</strong> ' + s.fix + '</div>';
        html += '</div>';
      }
      html += '</div></div></div>';
    });
    html += '</div>';
  });

  codeList.innerHTML = html;

  codeList.querySelectorAll('.code-card').forEach(function(card) {
    card.addEventListener('click', function() {
      card.classList.toggle('expanded');
    });
  });
}

init();
</script>

