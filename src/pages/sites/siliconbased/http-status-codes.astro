---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the difference between 401 and 403 HTTP status codes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "401 Unauthorized means the client has not provided valid authentication credentials — the server doesn't know who you are. 403 Forbidden means the server knows who you are (you're authenticated) but you don't have permission to access the requested resource. Use 401 when login is needed, and 403 when the user is logged in but lacks the required role or permissions."
          }
        },
        {
          "@type": "Question",
          "name": "When should I use 200 OK vs 201 Created vs 204 No Content?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use 200 OK for successful GET, PUT, or PATCH requests that return data. Use 201 Created when a POST request successfully creates a new resource — include a Location header pointing to the new resource. Use 204 No Content for successful DELETE requests or updates where no response body is needed. The choice signals to API consumers exactly what happened."
          }
        },
        {
          "@type": "Question",
          "name": "What does a 502 Bad Gateway error mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 502 Bad Gateway means an intermediary server (like a reverse proxy, load balancer, or CDN) received an invalid response from the upstream server it was forwarding the request to. Common causes include the upstream server being down, timing out, or returning a malformed response. Check your origin server's health, logs, and connectivity to resolve this."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between 301 and 302 redirects?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "301 Moved Permanently tells clients and search engines that the resource has permanently moved to a new URL — browsers and crawlers will cache this and update their references. 302 Found indicates a temporary redirect — the original URL is still valid and clients should continue using it for future requests. Use 301 for URL migrations and 302 for temporary maintenance or A/B testing."
          }
        },
        {
          "@type": "Question",
          "name": "What HTTP status code should I return for validation errors?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Return 400 Bad Request for validation errors in API requests. This covers malformed JSON, missing required fields, invalid field values, and type mismatches. Include a descriptive error body with details about which fields failed validation and why. Some APIs use 422 Unprocessable Entity specifically for semantic validation errors where the syntax is correct but the values are invalid."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "HTTP Status Codes Reference",
      "description": "Complete HTTP status code reference for developers. All codes from 1xx to 5xx with descriptions, use cases, and a decision tree for choosing the right status code for your API.",
      "url": "https://siliconbased.dev/http-status-codes",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev/"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
    <h1>HTTP Status Codes Reference</h1>
<main>

        <div class="search-container">
            <input type="text" id="searchInput" placeholder="Search by code number or keyword (e.g. 404, redirect, cache, auth)" autocomplete="off" spellcheck="false">
            <div class="filter-buttons">
                <button class="filter-btn active" data-filter="all" onclick="filterCodes('all')">All</button>
                <button class="filter-btn cat-1xx" data-filter="1" onclick="filterCodes('1')">1xx</button>
                <button class="filter-btn cat-2xx" data-filter="2" onclick="filterCodes('2')">2xx</button>
                <button class="filter-btn cat-3xx" data-filter="3" onclick="filterCodes('3')">3xx</button>
                <button class="filter-btn cat-4xx" data-filter="4" onclick="filterCodes('4')">4xx</button>
                <button class="filter-btn cat-5xx" data-filter="5" onclick="filterCodes('5')">5xx</button>
            </div>
        </div>

        <div id="matchCount" class="match-count"></div>
        <div id="codesContainer"></div>

        <div class="content-section decision-tree-section">
            <h2>Which Status Code Should I Return?</h2>
            <p>Use this decision tree for common REST API scenarios. Click any answer to jump to its full reference.</p>

            <div class="decision-tree">
                <div class="dt-node dt-question">Did the request succeed?</div>
                <div class="dt-branch">
                    <div class="dt-path">
                        <span class="dt-label dt-label-yes">YES</span>
                        <div class="dt-node dt-question">Did it create a new resource?</div>
                        <div class="dt-branch">
                            <div class="dt-path">
                                <span class="dt-label dt-label-yes">YES</span>
                                <div class="dt-node dt-answer cat-2xx-bg" onclick="scrollToCode(201)"><code>201</code> Created</div>
                            </div>
                            <div class="dt-path">
                                <span class="dt-label dt-label-no">NO</span>
                                <div class="dt-node dt-question">Is there a response body?</div>
                                <div class="dt-branch">
                                    <div class="dt-path">
                                        <span class="dt-label dt-label-yes">YES</span>
                                        <div class="dt-node dt-answer cat-2xx-bg" onclick="scrollToCode(200)"><code>200</code> OK</div>
                                    </div>
                                    <div class="dt-path">
                                        <span class="dt-label dt-label-no">NO</span>
                                        <div class="dt-node dt-answer cat-2xx-bg" onclick="scrollToCode(204)"><code>204</code> No Content</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="dt-path">
                        <span class="dt-label dt-label-no">NO</span>
                        <div class="dt-node dt-question">Is it the client's fault?</div>
                        <div class="dt-branch">
                            <div class="dt-path">
                                <span class="dt-label dt-label-yes">YES</span>
                                <div class="dt-node dt-question">Is the user authenticated?</div>
                                <div class="dt-branch">
                                    <div class="dt-path">
                                        <span class="dt-label dt-label-no">NO</span>
                                        <div class="dt-node dt-answer cat-4xx-bg" onclick="scrollToCode(401)"><code>401</code> Unauthorized</div>
                                    </div>
                                    <div class="dt-path">
                                        <span class="dt-label dt-label-yes">YES</span>
                                        <div class="dt-node dt-question">Do they have permission?</div>
                                        <div class="dt-branch">
                                            <div class="dt-path">
                                                <span class="dt-label dt-label-no">NO</span>
                                                <div class="dt-node dt-answer cat-4xx-bg" onclick="scrollToCode(403)"><code>403</code> Forbidden</div>
                                            </div>
                                            <div class="dt-path">
                                                <span class="dt-label dt-label-yes">YES</span>
                                                <div class="dt-node dt-question">Does the resource exist?</div>
                                                <div class="dt-branch">
                                                    <div class="dt-path">
                                                        <span class="dt-label dt-label-no">NO</span>
                                                        <div class="dt-node dt-answer cat-4xx-bg" onclick="scrollToCode(404)"><code>404</code> Not Found</div>
                                                    </div>
                                                    <div class="dt-path">
                                                        <span class="dt-label dt-label-yes">YES</span>
                                                        <div class="dt-node dt-question">Is the request body valid?</div>
                                                        <div class="dt-branch">
                                                            <div class="dt-path">
                                                                <span class="dt-label dt-label-no">NO</span>
                                                                <div class="dt-node dt-answer cat-4xx-bg" onclick="scrollToCode(400)"><code>400</code> Bad Request</div>
                                                            </div>
                                                            <div class="dt-path">
                                                                <span class="dt-label dt-label-yes">YES</span>
                                                                <div class="dt-node dt-question">Rate limited?</div>
                                                                <div class="dt-branch">
                                                                    <div class="dt-path">
                                                                        <span class="dt-label dt-label-yes">YES</span>
                                                                        <div class="dt-node dt-answer cat-4xx-bg" onclick="scrollToCode(429)"><code>429</code> Too Many Requests</div>
                                                                    </div>
                                                                    <div class="dt-path">
                                                                        <span class="dt-label dt-label-no">NO</span>
                                                                        <div class="dt-node dt-answer cat-4xx-bg" onclick="scrollToCode(409)"><code>409</code> Conflict</div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="dt-path">
                                <span class="dt-label dt-label-no">NO &mdash; Server error</span>
                                <div class="dt-node dt-question">Is it a known, temporary issue?</div>
                                <div class="dt-branch">
                                    <div class="dt-path">
                                        <span class="dt-label dt-label-yes">YES</span>
                                        <div class="dt-node dt-answer cat-5xx-bg" onclick="scrollToCode(503)"><code>503</code> Service Unavailable</div>
                                    </div>
                                    <div class="dt-path">
                                        <span class="dt-label dt-label-no">NO</span>
                                        <div class="dt-node dt-answer cat-5xx-bg" onclick="scrollToCode(500)"><code>500</code> Internal Server Error</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-section">
            <h2>How to Use This Reference</h2>
            <p>This reference covers every standard HTTP status code defined in <strong>RFC 9110</strong> and common extensions. Each entry includes the official name, a developer-friendly description, when to use it in your API, common causes, and an example response.</p>
            <p>Use the search bar to filter by code number (e.g., <code>404</code>) or keyword (e.g., <code>redirect</code>, <code>cache</code>, <code>auth</code>). Click the category buttons to filter by class. Click the copy button on any code to copy its number and name to your clipboard.</p>
            <p>The decision tree above helps you choose the correct status code for common REST API scenarios &mdash; start at the top and follow the yes/no branches to find the right code.</p>
        </div>

        <div class="content-section">
            <h2>Frequently Asked Questions</h2>

            <div class="faq-item">
                <div class="faq-question">What is the difference between 401 and 403 HTTP status codes?</div>
                <div class="faq-answer">401 Unauthorized means the client has not provided valid authentication credentials &mdash; the server doesn't know who you are. 403 Forbidden means the server knows who you are (you're authenticated) but you don't have permission to access the requested resource. Use 401 when login is needed, and 403 when the user is logged in but lacks the required role or permissions.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">When should I use 200 OK vs 201 Created vs 204 No Content?</div>
                <div class="faq-answer">Use 200 OK for successful GET, PUT, or PATCH requests that return data. Use 201 Created when a POST request successfully creates a new resource &mdash; include a Location header pointing to the new resource. Use 204 No Content for successful DELETE requests or updates where no response body is needed.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">What does a 502 Bad Gateway error mean?</div>
                <div class="faq-answer">A 502 Bad Gateway means an intermediary server (like a reverse proxy, load balancer, or CDN) received an invalid response from the upstream server. Common causes include the upstream server being down, timing out, or returning a malformed response. Check your origin server's health and logs to resolve this.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">What is the difference between 301 and 302 redirects?</div>
                <div class="faq-answer">301 Moved Permanently tells clients and search engines that the resource has permanently moved &mdash; browsers and crawlers will cache this and update their references. 302 Found indicates a temporary redirect &mdash; the original URL is still valid and clients should continue using it for future requests. Use 301 for URL migrations and 302 for temporary maintenance.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">What HTTP status code should I return for validation errors?</div>
                <div class="faq-answer">Return 400 Bad Request for validation errors in API requests. This covers malformed JSON, missing required fields, invalid field values, and type mismatches. Include a descriptive error body with details about which fields failed. Some APIs use 422 Unprocessable Entity specifically for semantic validation errors where the syntax is correct but the values are invalid.</div>
            </div>
        </div>

    </main>
    </div>`

export const meta = {
  title: "HTTP Status Codes Reference — Complete REST API Guide (1xx–5xx)",
  description: "Complete HTTP status code reference for developers. All codes from 1xx to 5xx with descriptions, use cases, common causes, example responses, and a decision tree for choosing the right status code.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="HTTP Status Codes Reference — Complete REST API Guide (1xx–5xx)"
  description="Complete HTTP status code reference for developers. All codes from 1xx to 5xx with descriptions, use cases, common causes, example responses, and a decision tree for choosing the right status code."
  canonical="https://siliconbased.dev/http-status-codes"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
        var STATUS_CODES = [
            { code: 100, name: 'Continue', cat: 1, desc: 'The server has received the request headers and the client should proceed to send the request body.', when: 'Used with large request bodies. The client sends Expect: 100-continue, and the server responds with 100 before the client sends the body, saving bandwidth if the server would reject it.', causes: 'Client sends Expect: 100-continue header with a POST/PUT request.', example: 'HTTP/1.1 100 Continue' },
            { code: 101, name: 'Switching Protocols', cat: 1, desc: 'The server is switching to the protocol requested by the client via the Upgrade header.', when: 'Used when upgrading from HTTP to WebSocket. The client sends an Upgrade: websocket header, and the server agrees to switch protocols.', causes: 'WebSocket handshake, HTTP/2 upgrade from HTTP/1.1.', example: 'HTTP/1.1 101 Switching Protocols\\nUpgrade: websocket\\nConnection: Upgrade' },
            { code: 102, name: 'Processing', cat: 1, desc: 'The server has received and is processing the request, but no response is available yet.', when: 'Used for long-running operations to prevent client timeouts. Tells the client the request was received and is being worked on.', causes: 'WebDAV operations, long-running server-side processing.', example: 'HTTP/1.1 102 Processing' },
            { code: 103, name: 'Early Hints', cat: 1, desc: 'Used to return some response headers before the final HTTP message, allowing the browser to preload resources.', when: 'Send Link headers early so the browser can start loading CSS, JS, or fonts while the server is still generating the full response.', causes: 'Server optimization for resource preloading.', example: 'HTTP/1.1 103 Early Hints\\nLink: </style.css>; rel=preload; as=style' },

            { code: 200, name: 'OK', cat: 2, desc: 'The request succeeded. The response body contains the requested resource or the result of the action.', when: 'Default success response for GET requests returning data, PUT/PATCH updates that return the updated resource, and any successful action that has a response body.', causes: 'Successful request processing.', example: 'HTTP/1.1 200 OK\\nContent-Type: application/json\\n\\n{\"id\": 1, \"name\": \"Example\"}' },
            { code: 201, name: 'Created', cat: 2, desc: 'The request succeeded and a new resource was created as a result.', when: 'Return after successful POST requests that create a new resource. Include a Location header with the URL of the new resource.', causes: 'Successful resource creation via POST.', example: 'HTTP/1.1 201 Created\\nLocation: /api/users/42\\n\\n{\"id\": 42}' },
            { code: 202, name: 'Accepted', cat: 2, desc: 'The request has been accepted for processing, but the processing has not been completed.', when: 'Return when you queue a request for async processing. The client should poll or use webhooks to check the result later.', causes: 'Asynchronous job queues, batch processing, long-running operations.', example: 'HTTP/1.1 202 Accepted\\n\\n{\"jobId\": \"abc-123\", \"status\": \"queued\"}' },
            { code: 203, name: 'Non-Authoritative Information', cat: 2, desc: 'The response has been modified by a transforming proxy and differs from the origin server\'s 200 response.', when: 'Rarely used directly. Returned by proxies that have modified the origin response (e.g., content filtering).', causes: 'Transforming proxy middleware.', example: 'HTTP/1.1 203 Non-Authoritative Information' },
            { code: 204, name: 'No Content', cat: 2, desc: 'The request succeeded but there is no content to send in the response body.', when: 'Return for successful DELETE requests, PUT/PATCH updates when you don\'t need to return the updated resource, or any action with no meaningful response body.', causes: 'Successful DELETE, successful update with no body needed.', example: 'HTTP/1.1 204 No Content' },
            { code: 205, name: 'Reset Content', cat: 2, desc: 'The server has fulfilled the request and the client should reset the document view (e.g., clear a form).', when: 'Return after a form submission when you want the client to clear the form fields and reset to their default values.', causes: 'Successful form submission requiring UI reset.', example: 'HTTP/1.1 205 Reset Content' },
            { code: 206, name: 'Partial Content', cat: 2, desc: 'The server is delivering only part of the resource due to a Range header sent by the client.', when: 'Return when the client requests a specific byte range of a resource. Include Content-Range header indicating which bytes are being sent.', causes: 'Video/audio streaming, resumable downloads, PDF byte-range requests.', example: 'HTTP/1.1 206 Partial Content\\nContent-Range: bytes 0-999/5000' },
            { code: 207, name: 'Multi-Status', cat: 2, desc: 'Conveys information about multiple resources where multiple status codes might be appropriate.', when: 'Return when a single request affects multiple resources and each may have a different result. Common in WebDAV and batch operations.', causes: 'WebDAV operations, batch API requests.', example: 'HTTP/1.1 207 Multi-Status\\nContent-Type: application/xml' },
            { code: 208, name: 'Already Reported', cat: 2, desc: 'Used inside a DAV: propstat response to avoid enumerating the same resource multiple times.', when: 'Used in WebDAV to indicate that members of a DAV binding have already been listed in a previous part of the multi-status response.', causes: 'WebDAV binding operations.', example: 'HTTP/1.1 208 Already Reported' },
            { code: 226, name: 'IM Used', cat: 2, desc: 'The server has fulfilled a GET request and the response is a representation of instance-manipulations applied to the current instance.', when: 'Used with delta encoding. The server returns the changes (delta) rather than the full resource, reducing bandwidth.', causes: 'Delta encoding with If-None-Match and IM headers.', example: 'HTTP/1.1 226 IM Used\\nIM: delta' },

            { code: 300, name: 'Multiple Choices', cat: 3, desc: 'The request has more than one possible response and the client should choose one.', when: 'Return when a resource is available in multiple formats (e.g., different languages or media types) and the server can\'t determine which one the client wants.', causes: 'Content negotiation with multiple representations.', example: 'HTTP/1.1 300 Multiple Choices' },
            { code: 301, name: 'Moved Permanently', cat: 3, desc: 'The resource has been permanently moved to a new URL. All future requests should use the new URL.', when: 'Use for permanent URL changes: domain migrations, URL restructuring, removing www prefix. Search engines will transfer SEO value to the new URL.', causes: 'URL restructuring, domain migration, HTTPS enforcement.', example: 'HTTP/1.1 301 Moved Permanently\\nLocation: https://new-domain.com/page' },
            { code: 302, name: 'Found', cat: 3, desc: 'The resource has been temporarily moved to a different URL. Future requests should still use the original URL.', when: 'Use for temporary redirects: maintenance pages, A/B testing, temporary content relocation. Clients will continue using the original URL.', causes: 'Temporary maintenance, A/B testing, login redirects.', example: 'HTTP/1.1 302 Found\\nLocation: /maintenance' },
            { code: 303, name: 'See Other', cat: 3, desc: 'The response to the request can be found at a different URL using a GET request.', when: 'Return after a POST request to redirect the client to a confirmation page or the created resource via GET. Prevents form resubmission on refresh.', causes: 'Post/Redirect/Get pattern, form submissions.', example: 'HTTP/1.1 303 See Other\\nLocation: /orders/42/confirmation' },
            { code: 304, name: 'Not Modified', cat: 3, desc: 'The resource has not been modified since the version specified by the request\'s conditional headers.', when: 'Return when the client sends If-None-Match or If-Modified-Since and the resource hasn\'t changed. Saves bandwidth by telling the client to use its cached copy.', causes: 'Conditional GET with ETag or Last-Modified matching.', example: 'HTTP/1.1 304 Not Modified\\nETag: \"abc123\"' },
            { code: 307, name: 'Temporary Redirect', cat: 3, desc: 'The resource is temporarily at a different URL. Unlike 302, the HTTP method must not change in the redirected request.', when: 'Use when you need a temporary redirect that strictly preserves the HTTP method. A POST to URL A redirected to URL B will remain a POST.', causes: 'API versioning, temporary routing changes, load balancing.', example: 'HTTP/1.1 307 Temporary Redirect\\nLocation: /api/v2/resource' },
            { code: 308, name: 'Permanent Redirect', cat: 3, desc: 'The resource has permanently moved. Unlike 301, the HTTP method must not change in the redirected request.', when: 'Use for permanent URL changes where the HTTP method must be preserved. A POST redirect will remain a POST at the new URL.', causes: 'API endpoint migration, permanent URL changes for non-GET methods.', example: 'HTTP/1.1 308 Permanent Redirect\\nLocation: /api/v2/resource' },

            { code: 400, name: 'Bad Request', cat: 4, desc: 'The server cannot process the request due to something perceived to be a client error (malformed syntax, invalid data).', when: 'Return for malformed JSON, missing required fields, invalid field values, type mismatches, or any request that violates the API contract.', causes: 'Malformed request body, missing parameters, invalid Content-Type, validation errors.', example: 'HTTP/1.1 400 Bad Request\\n\\n{\"error\": \"Validation failed\", \"details\": [{\"field\": \"email\", \"message\": \"Invalid format\"}]}' },
            { code: 401, name: 'Unauthorized', cat: 4, desc: 'The request lacks valid authentication credentials. The client must authenticate to get the requested response.', when: 'Return when the request has no auth token, an expired token, or invalid credentials. Include a WWW-Authenticate header indicating the auth scheme.', causes: 'Missing Authorization header, expired JWT, invalid API key, revoked token.', example: 'HTTP/1.1 401 Unauthorized\\nWWW-Authenticate: Bearer realm=\"api\"' },
            { code: 402, name: 'Payment Required', cat: 4, desc: 'Reserved for future use. Sometimes used to indicate that payment is needed to access the resource.', when: 'Used by some APIs to indicate a feature requires a paid subscription or the account has exceeded its billing limits.', causes: 'Subscription expired, billing limit exceeded, premium feature access.', example: 'HTTP/1.1 402 Payment Required\\n\\n{\"error\": \"Upgrade to Pro to access this feature\"}' },
            { code: 403, name: 'Forbidden', cat: 4, desc: 'The server understood the request but refuses to authorize it. Authentication will not help — the user lacks permission.', when: 'Return when the user is authenticated but doesn\'t have the required role or permission. Unlike 401, re-authenticating won\'t help.', causes: 'Insufficient role/permissions, IP blocklist, CORS policy, resource restricted to specific users.', example: 'HTTP/1.1 403 Forbidden\\n\\n{\"error\": \"Admin role required\"}' },
            { code: 404, name: 'Not Found', cat: 4, desc: 'The server cannot find the requested resource. The URL is not recognized or the resource does not exist.', when: 'Return when the requested resource doesn\'t exist. Can also be used to hide the existence of a resource from unauthorized users (instead of 403).', causes: 'Typo in URL, deleted resource, incorrect API endpoint, wrong resource ID.', example: 'HTTP/1.1 404 Not Found\\n\\n{\"error\": \"User not found\", \"id\": 999}' },
            { code: 405, name: 'Method Not Allowed', cat: 4, desc: 'The HTTP method used is not supported for the requested resource.', when: 'Return when the endpoint exists but doesn\'t support the HTTP method used (e.g., POST to a read-only endpoint). Include an Allow header listing valid methods.', causes: 'Using POST on a GET-only endpoint, DELETE on a non-deletable resource.', example: 'HTTP/1.1 405 Method Not Allowed\\nAllow: GET, HEAD' },
            { code: 406, name: 'Not Acceptable', cat: 4, desc: 'The server cannot produce a response matching the Accept headers sent by the client.', when: 'Return when the client requests a content type you don\'t support (e.g., Accept: application/xml when you only serve JSON).', causes: 'Unsupported Accept header, content negotiation failure.', example: 'HTTP/1.1 406 Not Acceptable' },
            { code: 407, name: 'Proxy Authentication Required', cat: 4, desc: 'The client must authenticate with the proxy before the request can be fulfilled.', when: 'Returned by proxy servers that require authentication. Similar to 401 but for proxy-level auth.', causes: 'Corporate proxy requires credentials, unauthenticated proxy access.', example: 'HTTP/1.1 407 Proxy Authentication Required\\nProxy-Authenticate: Basic realm=\"proxy\"' },
            { code: 408, name: 'Request Timeout', cat: 4, desc: 'The server timed out waiting for the request from the client.', when: 'Return when the client takes too long to send the complete request. The server gave up waiting.', causes: 'Slow client connection, incomplete request, network issues.', example: 'HTTP/1.1 408 Request Timeout' },
            { code: 409, name: 'Conflict', cat: 4, desc: 'The request conflicts with the current state of the server resource.', when: 'Return for write conflicts: duplicate unique fields, optimistic locking version mismatches, or state transition violations (e.g., trying to publish an already-published post).', causes: 'Duplicate key violation, version conflict, state machine violation.', example: 'HTTP/1.1 409 Conflict\\n\\n{\"error\": \"Email already exists\"}' },
            { code: 410, name: 'Gone', cat: 4, desc: 'The resource existed but has been permanently deleted and will not be available again.', when: 'Return when a resource has been intentionally and permanently removed. Unlike 404, this tells clients the resource definitely existed and is gone forever.', causes: 'Permanently deleted content, deprecated API versions, deactivated accounts.', example: 'HTTP/1.1 410 Gone' },
            { code: 411, name: 'Length Required', cat: 4, desc: 'The server requires a Content-Length header that the client did not send.', when: 'Return when your server requires Content-Length for request bodies and the client used chunked transfer encoding instead.', causes: 'Missing Content-Length header on POST/PUT request.', example: 'HTTP/1.1 411 Length Required' },
            { code: 412, name: 'Precondition Failed', cat: 4, desc: 'One or more conditions in the request headers evaluated to false on the server.', when: 'Return when conditional headers (If-Match, If-Unmodified-Since) fail. Used for optimistic concurrency control.', causes: 'ETag mismatch with If-Match, resource modified since If-Unmodified-Since.', example: 'HTTP/1.1 412 Precondition Failed' },
            { code: 413, name: 'Content Too Large', cat: 4, desc: 'The request body is larger than the server is willing or able to process.', when: 'Return when an upload exceeds your size limits. Include a Retry-After header if the condition is temporary.', causes: 'File upload exceeds limit, request body too large, JSON payload too big.', example: 'HTTP/1.1 413 Content Too Large\\n\\n{\"error\": \"Max upload size is 10MB\"}' },
            { code: 414, name: 'URI Too Long', cat: 4, desc: 'The URI requested by the client is longer than the server is willing to interpret.', when: 'Return when the URL (including query string) exceeds your server\'s limit. Suggest the client use POST with a request body instead.', causes: 'Excessively long query strings, encoded data in URL.', example: 'HTTP/1.1 414 URI Too Long' },
