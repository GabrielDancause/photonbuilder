            -webkit-text-fill-color: transparent;
        }

        .search-container {
            max-width: 900px;
            margin: 0 auto 2rem;
            background: var(--card-bg);
            padding: 1rem;
            border-radius: 0.75rem;
            border: 1px solid var(--border-color);
        }

        input[type="text"] {
            width: 100%;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-main);
