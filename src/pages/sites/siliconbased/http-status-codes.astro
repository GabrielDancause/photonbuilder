const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "HTTP Status Codes Reference — Complete List with Explanations",
      "url": "https://siliconbased.dev/http-status-codes",
      "description": "Complete HTTP status codes reference. Searchable list of all standard HTTP response codes grouped by category (1xx–5xx) with descriptions, common causes, and fixes for error codes.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does a 404 error mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 404 Not Found error means the server cannot find the requested resource. The URL may be misspelled, the page may have been deleted or moved, or the link pointing to it may be outdated. To fix a 404, check the URL for typos, set up proper redirects (301) for moved pages, and create a custom 404 page to help users navigate your site."
          }
        },
        {
          "@type": "Question",
          "name": "What does a 500 error mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 500 Internal Server Error means the server encountered an unexpected condition that prevented it from fulfilling the request. Common causes include syntax errors in server-side code, misconfigured .htaccess files, exhausted memory or resource limits, database connection failures, and incompatible plugin or module updates. Check server error logs for the specific cause."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between 401 and 403 status codes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "401 Unauthorized means the request lacks valid authentication credentials — the user needs to log in or provide an API key. 403 Forbidden means the server understood the request and the user may be authenticated, but they do not have permission to access the resource. In short: 401 = 'who are you?', 403 = 'I know who you are, but you can't access this.'"
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between 301 and 302 redirects?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 301 Moved Permanently tells browsers and search engines that the resource has permanently moved to a new URL. Search engines transfer link equity (SEO value) to the new URL. A 302 Found indicates a temporary redirect — the original URL should still be indexed. Use 301 for permanent URL changes (rebrands, HTTPS migration) and 302 for temporary situations (A/B tests, maintenance pages)."
          }
        },
        {
          "@type": "Question",
          "name": "Which HTTP status code should my API return?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For successful operations: 200 OK for GET requests, 201 Created for POST that creates a resource, 204 No Content for DELETE. For client errors: 400 Bad Request for malformed input, 401 for missing auth, 403 for insufficient permissions, 404 for unknown resources, 409 Conflict for duplicate resources, 422 for valid syntax but semantic errors, 429 for rate limiting. For server errors: 500 for unexpected failures, 503 for planned maintenance."
          }
        },
        {
          "@type": "Question",
          "name": "What does 429 Too Many Requests mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 429 Too Many Requests status code means the user has sent too many requests in a given time window (rate limiting). The server typically includes a Retry-After header indicating how long to wait before making another request. To handle 429 errors, implement exponential backoff in your client code, cache responses to reduce request volume, and respect the API's rate limit documentation."
          }
        },
        {
          "@type": "Question",
          "name": "Is this HTTP status codes reference free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this HTTP status codes reference is completely free. It includes all standard HTTP response codes grouped by category, searchable by code number or name, with detailed descriptions, common causes, and fixes for error codes. No account or installation required."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "HTTP Status Codes Reference — Complete List with Explanations",
      "description": "Complete HTTP status codes list with descriptions, common causes, and fixes. Searchable reference for 1xx, 2xx, 3xx, 4xx, and 5xx response codes.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>HTTP Status Codes</h1>
  <p>Complete reference of all standard HTTP response codes. Search by number or name, grouped by category with descriptions, causes, and fixes.</p>
</div>

<div class="main">

  <!-- Search / Filter -->
  <div class="search-bar">
    <input type="text" id="searchInput" class="search-input" placeholder="Search by code or name (e.g. 404, not found, redirect)..." spellcheck="false" />
    <div class="filter-chips" id="filterChips">
      <button class="chip active" data-filter="all">All</button>
      <button class="chip" data-filter="1">1xx</button>
      <button class="chip" data-filter="2">2xx</button>
      <button class="chip" data-filter="3">3xx</button>
      <button class="chip" data-filter="4">4xx</button>
      <button class="chip" data-filter="5">5xx</button>
    </div>
  </div>

  <!-- Status Code List -->
  <div id="codeList"></div>

  <!-- Decision Flowchart -->
  <div class="flowchart-section">
    <div class="input-header"><div class="header-title">Which Status Code Should I Return?</div></div>
    <div class="flowchart">
      <div class="flow-node flow-start">Did the request succeed?</div>
      <div class="flow-branches">
        <div class="flow-branch">
          <div class="flow-arrow flow-yes">Yes</div>
          <div class="flow-node flow-q">Created a new resource?</div>
          <div class="flow-branches">
            <div class="flow-branch">
              <div class="flow-arrow flow-yes">Yes</div>
              <div class="flow-node flow-answer code-2xx">201 Created</div>
            </div>
            <div class="flow-branch">
              <div class="flow-arrow flow-no">No</div>
              <div class="flow-node flow-q">Returning content?</div>
              <div class="flow-branches">
                <div class="flow-branch">
                  <div class="flow-arrow flow-yes">Yes</div>
                  <div class="flow-node flow-answer code-2xx">200 OK</div>
                </div>
                <div class="flow-branch">
                  <div class="flow-arrow flow-no">No</div>
                  <div class="flow-node flow-answer code-2xx">204 No Content</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="flow-branch">
          <div class="flow-arrow flow-no">No</div>
          <div class="flow-node flow-q">Client's fault?</div>
          <div class="flow-branches">
            <div class="flow-branch">
              <div class="flow-arrow flow-yes">Yes</div>
              <div class="flow-node flow-q">Auth problem?</div>
              <div class="flow-branches">
                <div class="flow-branch">
                  <div class="flow-arrow flow-yes">Yes</div>
                  <div class="flow-node flow-q">Needs to log in?</div>
                  <div class="flow-branches">
                    <div class="flow-branch">
                      <div class="flow-arrow flow-yes">Yes</div>
                      <div class="flow-node flow-answer code-4xx">401 Unauthorized</div>
                    </div>
                    <div class="flow-branch">
                      <div class="flow-arrow flow-no">No</div>
                      <div class="flow-node flow-answer code-4xx">403 Forbidden</div>
                    </div>
                  </div>
                </div>
                <div class="flow-branch">
                  <div class="flow-arrow flow-no">No</div>
                  <div class="flow-node flow-q">Resource exists?</div>
                  <div class="flow-branches">
                    <div class="flow-branch">
                      <div class="flow-arrow flow-no">No</div>
                      <div class="flow-node flow-answer code-4xx">404 Not Found</div>
                    </div>
                    <div class="flow-branch">
                      <div class="flow-arrow flow-yes">Yes</div>
                      <div class="flow-node flow-q">Bad input data?</div>
                      <div class="flow-branches">
                        <div class="flow-branch">
                          <div class="flow-arrow flow-yes">Yes</div>
                          <div class="flow-node flow-answer code-4xx">400 Bad Request</div>
                        </div>
                        <div class="flow-branch">
                          <div class="flow-arrow flow-no">No</div>
                          <div class="flow-node flow-answer code-4xx">429 Too Many Requests</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="flow-branch">
              <div class="flow-arrow flow-no">No &mdash; Server's fault</div>
              <div class="flow-node flow-q">Temporarily down?</div>
              <div class="flow-branches">
                <div class="flow-branch">
                  <div class="flow-arrow flow-yes">Yes</div>
                  <div class="flow-node flow-answer code-5xx">503 Service Unavailable</div>
                </div>
                <div class="flow-branch">
                  <div class="flow-arrow flow-no">No</div>
                  <div class="flow-node flow-answer code-5xx">500 Internal Server Error</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What Are HTTP Status Codes?</h2>
    <p>HTTP status codes are three-digit numbers returned by a web server in response to a client&rsquo;s request. They indicate whether a request was successful, redirected, or resulted in an error. Every time your browser loads a page, makes an API call, or fetches an image, the server responds with a status code. Understanding these codes is essential for web development, API design, SEO, and debugging.</p>

    <h2>HTTP Status Code Categories</h2>
    <p>Status codes are grouped into five categories based on their first digit:</p>
    <ul>
      <li><strong>1xx Informational:</strong> The request was received and the server is continuing to process it. These are rarely seen in practice but are used in protocols like WebSocket upgrades (101) and early hints (103).</li>
      <li><strong>2xx Success:</strong> The request was successfully received, understood, and accepted. The most common is 200 OK. APIs frequently use 201 Created and 204 No Content.</li>
      <li><strong>3xx Redirection:</strong> Further action is needed to complete the request. The client is usually redirected to a different URL. 301 and 302 are the most common. Proper use of redirects is critical for SEO.</li>
      <li><strong>4xx Client Error:</strong> The request contains bad syntax or cannot be fulfilled. The client needs to modify the request. 400, 401, 403, 404, and 429 are the most frequently encountered.</li>
      <li><strong>5xx Server Error:</strong> The server failed to fulfill a valid request. These indicate bugs, misconfigurations, or overloaded servers. 500, 502, and 503 are the most common.</li>
    </ul>

    <h2>Most Common HTTP Status Codes</h2>

    <h3>200 OK</h3>
    <p>The request succeeded. For GET requests, the response contains the requested resource. For POST requests, it means the action was completed successfully. This is the standard response for successful HTTP requests.</p>

    <h3>301 Moved Permanently</h3>
    <p>The requested resource has been permanently moved to a new URL. Search engines will transfer ranking signals (link equity) to the new URL. Use 301 redirects when changing URL structures, migrating domains, or switching from HTTP to HTTPS.</p>

    <h3>404 Not Found</h3>
    <p>The server cannot find the requested resource. This is one of the most recognized HTTP status codes. Common causes include mistyped URLs, deleted pages, and broken links. Always create a helpful custom 404 page and set up redirects for moved content.</p>

    <h3>500 Internal Server Error</h3>
    <p>A generic server-side error. The server encountered an unexpected condition that prevented it from fulfilling the request. Common causes include application bugs, misconfigured servers, database failures, and exhausted resources. Always check server error logs when debugging 500 errors.</p>

    <h2>HTTP Status Codes for API Design</h2>
    <p>When building REST APIs, choosing the right status code makes your API predictable and easier to consume:</p>
    <pre class="syntax-block">  GET    /users/123      &rarr; 200 OK (found) or 404 (not found)
  POST   /users          &rarr; 201 Created (success) or 409 Conflict (duplicate)
  PUT    /users/123      &rarr; 200 OK (updated) or 404 (not found)
  PATCH  /users/123      &rarr; 200 OK (patched) or 422 (invalid data)
  DELETE /users/123      &rarr; 204 No Content (deleted) or 404 (not found)

  Auth errors:  401 (not logged in) or 403 (insufficient permissions)
  Rate limits:  429 Too Many Requests + Retry-After header
  Server bugs:  500 Internal Server Error</pre>

    <h2>Status Codes and SEO</h2>
    <p>HTTP status codes directly affect search engine crawling and indexing:</p>
    <ul>
      <li><strong>200:</strong> Content is indexed normally.</li>
      <li><strong>301:</strong> Link equity passes to the new URL. Use for permanent URL changes.</li>
      <li><strong>302:</strong> Temporary redirect. The original URL stays in the index.</li>
      <li><strong>404:</strong> Pages are eventually removed from the index. Excessive 404s may indicate crawl issues.</li>
      <li><strong>410 Gone:</strong> Tells search engines the page is intentionally removed &mdash; faster de-indexing than 404.</li>
      <li><strong>503:</strong> Tells crawlers to come back later. Use during maintenance to avoid losing rankings.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does a 404 error mean?</h3>
      <p style="margin-bottom: 16px;">A 404 Not Found error means the server cannot find the requested resource. The URL may be misspelled, the page may have been deleted or moved, or the link pointing to it may be outdated. To fix a 404, check the URL for typos, set up proper redirects (301) for moved pages, and create a custom 404 page to help users navigate your site.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does a 500 error mean?</h3>
      <p style="margin-bottom: 16px;">A 500 Internal Server Error means the server encountered an unexpected condition that prevented it from fulfilling the request. Common causes include syntax errors in server-side code, misconfigured .htaccess files, exhausted memory or resource limits, database connection failures, and incompatible plugin or module updates. Check server error logs for the specific cause.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between 401 and 403 status codes?</h3>
      <p style="margin-bottom: 16px;">401 Unauthorized means the request lacks valid authentication credentials &mdash; the user needs to log in or provide an API key. 403 Forbidden means the server understood the request and the user may be authenticated, but they do not have permission to access the resource. In short: 401 = &ldquo;who are you?&rdquo;, 403 = &ldquo;I know who you are, but you can&rsquo;t access this.&rdquo;</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between 301 and 302 redirects?</h3>
      <p style="margin-bottom: 16px;">A 301 Moved Permanently tells browsers and search engines that the resource has permanently moved to a new URL. Search engines transfer link equity (SEO value) to the new URL. A 302 Found indicates a temporary redirect &mdash; the original URL should still be indexed. Use 301 for permanent URL changes and 302 for temporary situations like A/B tests or maintenance pages.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Which HTTP status code should my API return?</h3>
      <p style="margin-bottom: 16px;">For successful operations: 200 OK for GET requests, 201 Created for POST that creates a resource, 204 No Content for DELETE. For client errors: 400 Bad Request for malformed input, 401 for missing auth, 403 for insufficient permissions, 404 for unknown resources, 422 for semantic errors, 429 for rate limiting. For server errors: 500 for unexpected failures, 503 for planned maintenance.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does 429 Too Many Requests mean?</h3>
      <p style="margin-bottom: 16px;">A 429 status code means the user has sent too many requests in a given time window (rate limiting). The server typically includes a Retry-After header indicating how long to wait. To handle 429 errors, implement exponential backoff, cache responses to reduce request volume, and respect the API&rsquo;s rate limit documentation.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is this HTTP status codes reference free?</h3>
      <p style="margin-bottom: 16px;">Yes, this HTTP status codes reference is completely free. It includes all standard HTTP response codes grouped by category, searchable by code number or name, with detailed descriptions, common causes, and fixes for error codes. No account or installation required.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/regex-tester">Regex Tester</a> &mdash; Test and debug regular expressions online with real-time highlighting.</li>
      <li><a href="/jwt-decoder">JWT Decoder</a> &mdash; Decode and inspect JSON Web Tokens instantly.</li>
      <li><a href="/json-formatter">JSON Formatter</a> &mdash; Format, validate, and minify JSON data.</li>
      <li><a href="/curl-converter">cURL Converter</a> &mdash; Convert cURL commands to code in any language.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "HTTP Status Codes Reference — Complete List with Explanations",
