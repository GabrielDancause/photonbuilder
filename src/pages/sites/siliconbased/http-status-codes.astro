        var CAT_NAMES = { 1: 'Informational', 2: 'Success', 3: 'Redirection', 4: 'Client Error', 5: 'Server Error' };
        var currentFilter = 'all';
        var currentSearch = '';

        function init() {
            renderCodes();
            document.getElementById('searchInput').addEventListener('input', function(e) {
                currentSearch = e.target.value.trim().toLowerCase();
                renderCodes();
            });
        }

        function filterCodes(filter) {
            currentFilter = filter;
            var btns = document.querySelectorAll('.filter-btn');
            btns.forEach(function(b) { b.classList.remove('active'); });
            document.querySelector('[data-filter="' + filter + '"]').classList.add('active');
            renderCodes();
        }

        function getFiltered() {
            return STATUS_CODES.filter(function(sc) {
                if (currentFilter !== 'all' && String(sc.cat) !== currentFilter) return false;
                if (currentSearch) {
                    var s = currentSearch;
                    var haystack = (sc.code + ' ' + sc.name + ' ' + sc.desc + ' ' + sc.when + ' ' + sc.causes).toLowerCase();
                    return haystack.indexOf(s) !== -1;
                }
                return true;
            });
        }

        function renderCodes() {
            var filtered = getFiltered();
            var container = document.getElementById('codesContainer');
            var countEl = document.getElementById('matchCount');

            if (currentSearch || currentFilter !== 'all') {
                countEl.textContent = filtered.length + ' status code' + (filtered.length !== 1 ? 's' : '') + ' found';
                countEl.style.display = 'block';
            } else {
                countEl.style.display = 'none';
            }

            var html = '';
            var lastCat = 0;

            filtered.forEach(function(sc) {
                if (sc.cat !== lastCat) {
                    if (lastCat !== 0) html += '</div>';
                    html += '<div class="category-section"><div class="category-header cat-' + sc.cat + 'xx-header"><h2>' + sc.cat + 'xx &mdash; ' + CAT_NAMES[sc.cat] + '</h2></div>';
                    lastCat = sc.cat;
                }
                var eName = sc.name.replace(/'/g, "\\'");
                html += '<div class="status-card" id="code-' + sc.code + '">';
                html += '<div class="card-header">';
                html += '<span class="status-code cat-' + sc.cat + 'xx-text">' + sc.code + '</span>';
                html += '<span class="status-name">' + sc.name + '</span>';
                html += '<button class="copy-btn" onclick="copyCode(' + sc.code + ', \'' + eName + '\')" title="Copy code + name">';
                html += '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
                html += '</button>';
                html += '</div>';
                html += '<p class="card-desc">' + sc.desc + '</p>';
                html += '<div class="card-details">';
                html += '<div class="detail-block"><div class="detail-label">When to use</div><div class="detail-text">' + sc.when + '</div></div>';
                html += '<div class="detail-block"><div class="detail-label">Common causes</div><div class="detail-text">' + sc.causes + '</div></div>';
                html += '<div class="detail-block"><div class="detail-label">Example response</div><pre class="example-pre">' + sc.example.replace(/\\n/g, '\n') + '</pre></div>';
                html += '</div></div>';
            });

            if (lastCat !== 0) html += '</div>';
            if (filtered.length === 0) {
                html = '<div class="no-results">No status codes match your search.</div>';
            }

            container.innerHTML = html;
        }

        function copyCode(code, name) {
            var text = code + ' ' + name;
            navigator.clipboard.writeText(text).then(function() {
                var btn = document.querySelector('#code-' + code + ' .copy-btn');
                if (!btn) return;
                btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>';
                setTimeout(function() {
                    btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
                }, 1500);
            });
        }

        function scrollToCode(code) {
            currentFilter = 'all';
            currentSearch = '';
            document.getElementById('searchInput').value = '';
            var btns = document.querySelectorAll('.filter-btn');
            btns.forEach(function(b) { b.classList.remove('active'); });
            document.querySelector('[data-filter="all"]').classList.add('active');
            renderCodes();
            setTimeout(function() {
                var el = document.getElementById('code-' + code);
                if (el) {
                    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    el.classList.add('highlight');
                    setTimeout(function() { el.classList.remove('highlight'); }, 2000);
                }
            }, 50);
        }

        init();
    </script>

  <style is:inline>

        .page-content {
            --bg-color: #060a12;
