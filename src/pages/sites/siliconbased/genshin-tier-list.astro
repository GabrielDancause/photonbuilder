      text-shadow: 1px 1px 0px rgba(255,255,255,0.5);
    }
    .tier-label.ss { background-color: #ff7f7f; }
    .tier-label.s { background-color: #ffbf7f; }
    .tier-label.a { background-color: #ffff7f; }
    .tier-label.b { background-color: #bfff7f; }
    .tier-label.c { background-color: #7fff7f; }

    .tier-content {
      padding: 1rem;
      flex: 1;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      background: var(--card-bg);
    }

    .char-badge {
      padding: 0.25rem 0.75rem;
      border-radius: 4px;
