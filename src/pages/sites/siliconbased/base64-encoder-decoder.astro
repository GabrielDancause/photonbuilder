---

<SiteLayout
  site="siliconbased"
  title="Base64 Encoder Decoder — Encode & Decode Base64 Online"
  description="Free online Base64 encoder and decoder with live conversion, file upload, image preview, and URL-safe Base64 mode. No data leaves your browser."
  canonical="https://siliconbased.dev/base64-encoder-decoder"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const inputArea = document.getElementById('inputArea');
const outputArea = document.getElementById('outputArea');
const inputLabel = document.getElementById('inputLabel');
const outputLabel = document.getElementById('outputLabel');
const inputCount = document.getElementById('inputCount');
const outputCount = document.getElementById('outputCount');
const urlSafeToggle = document.getElementById('urlSafeToggle');
const btnEncode = document.getElementById('btnEncode');
const btnDecode = document.getElementById('btnDecode');
const clearBtn = document.getElementById('clearBtn');
const copyBtn = document.getElementById('copyBtn');
const fileInput = document.getElementById('fileInput');
const dropOverlay = document.getElementById('dropOverlay');
const imagePreviewSection = document.getElementById('imagePreviewSection');
const imagePreview = document.getElementById('imagePreview');

let mode = 'encode';
let fileBase64 = null;

function init() {
  inputArea.addEventListener('input', () => { fileBase64 = null; convert(); });
  urlSafeToggle.addEventListener('change', convert);

  btnEncode.addEventListener('click', () => setMode('encode'));
  btnDecode.addEventListener('click', () => setMode('decode'));

  clearBtn.addEventListener('click', () => {
    inputArea.value = '';
    outputArea.value = '';
    fileBase64 = null;
    updateCounts();
    hideImagePreview();
    inputArea.focus();
  });

  copyBtn.addEventListener('click', () => {
    const text = outputArea.value;
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      copyBtn.textContent = '\u2713 Copied';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
    });
  });

  // File upload
  fileInput.addEventListener('change', handleFileSelect);

  // Drag & drop
  const mainEl = document.querySelector('.main');
  mainEl.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropOverlay.style.display = 'flex';
  });
  mainEl.addEventListener('dragleave', (e) => {
    if (!mainEl.contains(e.relatedTarget)) {
      dropOverlay.style.display = 'none';
    }
  });
  mainEl.addEventListener('drop', (e) => {
    e.preventDefault();
    dropOverlay.style.display = 'none';
    if (e.dataTransfer.files.length > 0) {
      setMode('encode');
      processFile(e.dataTransfer.files[0]);
    }
  });

  updateCounts();
}

function setMode(m) {
  mode = m;
  fileBase64 = null;
  btnEncode.classList.toggle('active', m === 'encode');
  btnDecode.classList.toggle('active', m === 'decode');
  inputLabel.textContent = m === 'encode' ? 'Text Input' : 'Base64 Input';
  outputLabel.textContent = m === 'encode' ? 'Base64 Output' : 'Decoded Output';
  inputArea.placeholder = m === 'encode' ? 'Type or paste text here, or drag & drop a file...' : 'Paste Base64 string here...';
  outputArea.placeholder = m === 'encode' ? 'Base64 output will appear here...' : 'Decoded text will appear here...';
  inputArea.value = '';
  outputArea.value = '';
  updateCounts();
  hideImagePreview();
}

function handleFileSelect(e) {
  if (e.target.files.length > 0) {
    setMode('encode');
    processFile(e.target.files[0]);
    e.target.value = '';
  }
}

function processFile(file) {
  const reader = new FileReader();
  reader.onload = function(e) {
    const dataUrl = e.target.result;
    const base64 = dataUrl.split(',')[1] || '';
    fileBase64 = base64;
    inputArea.value = '[File: ' + file.name + ' (' + formatSize(file.size) + ')]';
    convert();
  };
  reader.readAsDataURL(file);
}

function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / 1048576).toFixed(1) + ' MB';
}

function convert() {
  const urlSafe = urlSafeToggle.checked;
  hideImagePreview();

  if (mode === 'encode') {
    let b64;
    if (fileBase64) {
      b64 = fileBase64;
    } else {
      const input = inputArea.value;
      if (!input) { outputArea.value = ''; updateCounts(); return; }
      try {
        const bytes = new TextEncoder().encode(input);
        let binary = '';
        for (let i = 0; i < bytes.length; i++) {
          binary += String.fromCharCode(bytes[i]);
        }
        b64 = btoa(binary);
      } catch (e) {
        outputArea.value = 'Error: ' + e.message;
        updateCounts();
        return;
      }
    }
    if (urlSafe) {
      b64 = b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
    }
    outputArea.value = b64;
  } else {
    let input = inputArea.value.trim();
    if (!input) { outputArea.value = ''; updateCounts(); return; }
    try {
      // Convert URL-safe back to standard if needed
      if (urlSafe || /[-_]/.test(input)) {
        input = input.replace(/-/g, '+').replace(/_/g, '/');
        while (input.length % 4 !== 0) input += '=';
      }
      const binary = atob(input);
      const bytes = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) {
        bytes[i] = binary.charCodeAt(i);
      }
      const decoded = new TextDecoder('utf-8', { fatal: false }).decode(bytes);
      outputArea.value = decoded;

      // Check if decoded data is an image
      tryImagePreview(input);
    } catch (e) {
      outputArea.value = 'Error: Invalid Base64 string';
    }
  }
  updateCounts();
}

function tryImagePreview(b64) {
  try {
    const binary = atob(b64.substring(0, 16));
    const bytes = [];
    for (let i = 0; i < binary.length; i++) bytes.push(binary.charCodeAt(i));

    let mime = null;
    if (bytes[0] === 0x89 && bytes[1] === 0x50 && bytes[2] === 0x4E && bytes[3] === 0x47) mime = 'image/png';
    else if (bytes[0] === 0xFF && bytes[1] === 0xD8 && bytes[2] === 0xFF) mime = 'image/jpeg';
    else if (bytes[0] === 0x47 && bytes[1] === 0x49 && bytes[2] === 0x46) mime = 'image/gif';
    else if (bytes[0] === 0x52 && bytes[1] === 0x49 && bytes[2] === 0x46 && bytes[3] === 0x46) mime = 'image/webp';
    else if (bytes[0] === 0x3C) mime = 'image/svg+xml';

    if (mime) {
      imagePreview.src = 'data:' + mime + ';base64,' + b64;
      imagePreviewSection.style.display = 'block';
      imagePreview.onerror = function() { hideImagePreview(); };
    }
  } catch (e) {
    // Not an image
  }
}

function hideImagePreview() {
  imagePreviewSection.style.display = 'none';
  imagePreview.src = '';
}

function updateCounts() {
  const ic = inputArea.value.length;
  const oc = outputArea.value.length;
  inputCount.textContent = ic.toLocaleString() + ' character' + (ic !== 1 ? 's' : '');
  outputCount.textContent = oc.toLocaleString() + ' character' + (oc !== 1 ? 's' : '');
}

init();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
