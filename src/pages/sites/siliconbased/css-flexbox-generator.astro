---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "CSS Flexbox Generator — Visual Flexbox Playground",
      "url": "https://siliconbased.dev/css-flexbox-generator",
      "description": "Free CSS flexbox generator and playground. Visually build flex layouts with container and item controls, preset layouts, live preview, and copy-ready CSS code.",
      "applicationCategory": "DesignApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is CSS Flexbox?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CSS Flexbox (Flexible Box Layout) is a one-dimensional layout model that distributes space among items in a container and aligns them. It makes it easy to design responsive layouts without using floats or positioning hacks."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between justify-content and align-items?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "justify-content controls alignment along the main axis (horizontal by default), while align-items controls alignment along the cross axis (vertical by default). When flex-direction is column, these axes swap."
          }
        },
        {
          "@type": "Question",
          "name": "What does flex-wrap do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "flex-wrap controls whether flex items are forced onto a single line or can wrap onto multiple lines. By default (nowrap), all items stay on one line and may shrink. Setting wrap allows items to flow onto the next line when the container runs out of space."
          }
        },
        {
          "@type": "Question",
          "name": "How do flex-grow, flex-shrink, and flex-basis work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "flex-grow defines how much an item should grow relative to other items when extra space is available. flex-shrink defines how much an item should shrink when space is insufficient. flex-basis sets the initial size of an item before growing or shrinking. Together they form the shorthand: flex: grow shrink basis."
          }
        },
        {
          "@type": "Question",
          "name": "What is the order property in Flexbox?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The order property controls the visual order of flex items without changing the HTML source order. Items are laid out in ascending order values. All items default to order: 0, so setting a negative value moves an item before others, and a positive value moves it after."
          }
        },
        {
          "@type": "Question",
          "name": "When should I use Flexbox vs CSS Grid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Flexbox is best for one-dimensional layouts — arranging items in a single row or column. CSS Grid is best for two-dimensional layouts — controlling both rows and columns simultaneously. Many layouts benefit from using both: Grid for the overall page structure and Flexbox for components within grid areas."
          }
        },
        {
          "@type": "Question",
          "name": "Is this flexbox generator free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this CSS flexbox generator is completely free. It runs entirely in your browser with no sign-up required. All layout generation happens client-side — no data is sent to any server."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "CSS Flexbox Generator — Visual Flexbox Layout Playground",
      "description": "Free CSS flexbox generator and playground. Build flex layouts visually with container and item controls, preset layouts, live preview, and copy-ready CSS.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>CSS Flexbox Generator</h1>
  <p>Visual flexbox playground — configure container and item properties, preview layouts live, and copy the generated CSS.</p>
</div>

<div class="main">

  <!-- Container Controls -->
  <div class="section-block" style="border-top:none;padding-top:0;">
    <div class="section-header">
      <h2>Container Properties</h2>
    </div>
    <div class="controls-grid">
      <div class="ctrl-group">
        <label>flex-direction</label>
        <select id="ctrlDirection">
          <option value="row">row</option>
          <option value="row-reverse">row-reverse</option>
          <option value="column">column</option>
          <option value="column-reverse">column-reverse</option>
        </select>
      </div>
      <div class="ctrl-group">
        <label>justify-content</label>
        <select id="ctrlJustify">
          <option value="flex-start">flex-start</option>
          <option value="flex-end">flex-end</option>
          <option value="center">center</option>
          <option value="space-between">space-between</option>
          <option value="space-around">space-around</option>
          <option value="space-evenly">space-evenly</option>
        </select>
      </div>
      <div class="ctrl-group">
        <label>align-items</label>
        <select id="ctrlAlign">
          <option value="stretch">stretch</option>
          <option value="flex-start">flex-start</option>
          <option value="flex-end">flex-end</option>
          <option value="center">center</option>
          <option value="baseline">baseline</option>
        </select>
      </div>
      <div class="ctrl-group">
        <label>flex-wrap</label>
        <select id="ctrlWrap">
          <option value="nowrap">nowrap</option>
          <option value="wrap">wrap</option>
          <option value="wrap-reverse">wrap-reverse</option>
        </select>
      </div>
      <div class="ctrl-group">
        <label>gap</label>
        <div class="input-with-unit">
          <input type="number" id="ctrlGap" value="10" min="0" max="100" step="1">
          <span class="unit">px</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Live Preview -->
  <div class="section-block">
    <div class="section-header">
      <h2>Live Preview</h2>
      <div class="item-actions">
        <button class="add-item-btn" id="addItemBtn">+ Add Item</button>
        <button class="remove-item-btn" id="removeItemBtn">&minus; Remove Item</button>
      </div>
    </div>
    <div class="preview-container" id="previewContainer"></div>
  </div>

  <!-- Item Controls -->
  <div class="section-block">
    <div class="section-header">
      <h2>Item Properties</h2>
      <p class="section-desc">Click an item in the preview to select it, then adjust its properties below.</p>
    </div>
    <div class="item-selector">
      <label>Selected Item:</label>
      <select id="itemSelector"></select>
    </div>
    <div class="controls-grid">
      <div class="ctrl-group">
        <label>flex-grow</label>
        <input type="number" id="itemGrow" value="0" min="0" max="10" step="1">
      </div>
      <div class="ctrl-group">
        <label>flex-shrink</label>
        <input type="number" id="itemShrink" value="1" min="0" max="10" step="1">
      </div>
      <div class="ctrl-group">
        <label>flex-basis</label>
        <div class="input-with-unit">
          <input type="text" id="itemBasis" value="auto" style="width:80px;">
        </div>
      </div>
      <div class="ctrl-group">
        <label>align-self</label>
        <select id="itemAlignSelf">
          <option value="auto">auto</option>
          <option value="flex-start">flex-start</option>
          <option value="flex-end">flex-end</option>
          <option value="center">center</option>
          <option value="stretch">stretch</option>
          <option value="baseline">baseline</option>
        </select>
      </div>
      <div class="ctrl-group">
        <label>order</label>
        <input type="number" id="itemOrder" value="0" min="-10" max="10" step="1">
      </div>
    </div>
  </div>

  <!-- CSS Output -->
  <div class="section-block">
    <div class="section-header">
      <h2>Generated CSS</h2>
    </div>
    <div class="export-output-wrap">
      <pre class="export-output" id="cssOutput"></pre>
      <button class="copy-btn" id="copyCssBtn">Copy</button>
    </div>
  </div>

  <!-- Preset Layouts -->
  <div class="section-block">
    <div class="section-header">
      <h2>Preset Layouts</h2>
      <p class="section-desc">Click a preset to load it into the playground.</p>
    </div>
    <div class="presets-grid" id="presetsGrid"></div>
  </div>

  <!-- Cheat Sheet -->
  <div class="section-block">
    <div class="section-header">
      <h2>Flexbox Cheat Sheet</h2>
    </div>
    <div class="cheat-sheet" id="cheatSheet"></div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a CSS Flexbox Generator?</h2>
    <p>A CSS flexbox generator is a visual tool that lets you experiment with all flexbox container and item properties without writing code by hand. You configure direction, alignment, wrapping, gaps, and per-item properties like flex-grow and order, then copy the generated CSS directly into your project. This tool serves as both a flexbox playground for learning and a layout generator for production use.</p>

    <h2>Understanding Flexbox Container Properties</h2>
    <p>The flex container is the parent element with <code>display: flex</code>. Its properties control how child items are laid out:</p>
    <ul>
      <li><strong>flex-direction:</strong> Sets the main axis — <code>row</code> (horizontal, default), <code>column</code> (vertical), or their reverse variants.</li>
      <li><strong>justify-content:</strong> Distributes items along the main axis — <code>flex-start</code>, <code>center</code>, <code>space-between</code>, <code>space-around</code>, or <code>space-evenly</code>.</li>
      <li><strong>align-items:</strong> Aligns items along the cross axis — <code>stretch</code> (default), <code>flex-start</code>, <code>center</code>, <code>flex-end</code>, or <code>baseline</code>.</li>
      <li><strong>flex-wrap:</strong> Controls whether items wrap to new lines — <code>nowrap</code> (default) keeps everything on one line, <code>wrap</code> allows wrapping.</li>
      <li><strong>gap:</strong> Sets the spacing between flex items without using margins.</li>
    </ul>

    <h2>Understanding Flexbox Item Properties</h2>
    <p>Individual flex items can override the container's alignment and control their own sizing behavior:</p>
    <ul>
      <li><strong>flex-grow:</strong> How much an item grows relative to siblings when extra space is available. Default is 0 (no growth).</li>
      <li><strong>flex-shrink:</strong> How much an item shrinks relative to siblings when space is tight. Default is 1.</li>
      <li><strong>flex-basis:</strong> The initial size before growing or shrinking. Can be a length (<code>200px</code>), percentage (<code>25%</code>), or <code>auto</code>.</li>
      <li><strong>align-self:</strong> Overrides <code>align-items</code> for a single item.</li>
      <li><strong>order:</strong> Changes the visual order without modifying the DOM. Default is 0.</li>
    </ul>

    <h2>Common Flexbox Layout Patterns</h2>
    <p>Flexbox excels at common UI patterns that were historically difficult with CSS. A <strong>holy grail layout</strong> uses a flex container with a fixed-width sidebar, flexible main content, and another sidebar. A <strong>sticky footer</strong> uses <code>flex-grow: 1</code> on the main content to push the footer to the bottom. <strong>Centering</strong> is trivially achieved with <code>justify-content: center</code> and <code>align-items: center</code>. Navigation bars, card grids with wrapping, and equal-height columns are all natural flexbox use cases.</p>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is CSS Flexbox?</h3>
      <p style="margin-bottom: 16px;">CSS Flexbox (Flexible Box Layout) is a one-dimensional layout model that distributes space among items in a container and aligns them. It makes it easy to design responsive layouts without using floats or positioning hacks.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between justify-content and align-items?</h3>
      <p style="margin-bottom: 16px;">justify-content controls alignment along the main axis (horizontal by default), while align-items controls alignment along the cross axis (vertical by default). When flex-direction is column, these axes swap.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does flex-wrap do?</h3>
      <p style="margin-bottom: 16px;">flex-wrap controls whether flex items are forced onto a single line or can wrap onto multiple lines. By default (nowrap), all items stay on one line and may shrink. Setting wrap allows items to flow onto the next line when the container runs out of space.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do flex-grow, flex-shrink, and flex-basis work?</h3>
      <p style="margin-bottom: 16px;">flex-grow defines how much an item should grow relative to other items when extra space is available. flex-shrink defines how much an item should shrink when space is insufficient. flex-basis sets the initial size of an item before growing or shrinking. Together they form the shorthand: flex: grow shrink basis.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the order property in Flexbox?</h3>
      <p style="margin-bottom: 16px;">The order property controls the visual order of flex items without changing the HTML source order. Items are laid out in ascending order values. All items default to order: 0.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">When should I use Flexbox vs CSS Grid?</h3>
      <p style="margin-bottom: 16px;">Flexbox is best for one-dimensional layouts — arranging items in a single row or column. CSS Grid is best for two-dimensional layouts — controlling both rows and columns simultaneously. Many layouts benefit from using both.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is this flexbox generator free to use?</h3>
      <p style="margin-bottom: 16px;">Yes, this CSS flexbox generator is completely free. It runs entirely in your browser with no sign-up required. All layout generation happens client-side — no data is sent to any server.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/css-gradient-generator">CSS Gradient Generator</a> — Create beautiful CSS gradients with live preview and export.</li>
      <li><a href="/css-box-shadow-generator">CSS Box Shadow Generator</a> — Design box shadows visually and copy the CSS.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "CSS Flexbox Generator — Visual Layout Builder",
  description: "Free CSS flexbox generator and playground. Build flex layouts visually with container and item controls, preset layouts, cheat sheet, live preview, and copy-ready CSS.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="CSS Flexbox Generator — Visual Layout Builder"
  description="Free CSS flexbox generator and playground. Build flex layouts visually with container and item controls, preset layouts, cheat sheet, live preview, and copy-ready CSS."
  canonical="https://siliconbased.dev/css-flexbox-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
// --- State ---
var items = [
  { grow: 0, shrink: 1, basis: 'auto', alignSelf: 'auto', order: 0 },
  { grow: 0, shrink: 1, basis: 'auto', alignSelf: 'auto', order: 0 },
  { grow: 0, shrink: 1, basis: 'auto', alignSelf: 'auto', order: 0 },
  { grow: 0, shrink: 1, basis: 'auto', alignSelf: 'auto', order: 0 }
];
var selectedItem = 0;
var itemColors = ['#818cf8','#f472b6','#34d399','#fbbf24','#f87171','#a78bfa'];

// --- DOM refs ---
var ctrlDirection = document.getElementById('ctrlDirection');
var ctrlJustify = document.getElementById('ctrlJustify');
var ctrlAlign = document.getElementById('ctrlAlign');
var ctrlWrap = document.getElementById('ctrlWrap');
var ctrlGap = document.getElementById('ctrlGap');
var previewContainer = document.getElementById('previewContainer');
var addItemBtn = document.getElementById('addItemBtn');
var removeItemBtn = document.getElementById('removeItemBtn');
var itemSelector = document.getElementById('itemSelector');
var itemGrow = document.getElementById('itemGrow');
var itemShrink = document.getElementById('itemShrink');
var itemBasis = document.getElementById('itemBasis');
var itemAlignSelf = document.getElementById('itemAlignSelf');
var itemOrder = document.getElementById('itemOrder');
var cssOutput = document.getElementById('cssOutput');
var copyCssBtn = document.getElementById('copyCssBtn');
var presetsGrid = document.getElementById('presetsGrid');
var cheatSheet = document.getElementById('cheatSheet');

// --- Presets ---
var presets = [
  {
    name: 'Holy Grail',
    desc: 'Sidebar + main + sidebar',
    container: { direction:'row', justify:'flex-start', align:'stretch', wrap:'nowrap', gap:0 },
    items: [
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 },
      { grow:1, shrink:1, basis:'auto', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 }
    ]
  },
  {
    name: 'Sidebar Layout',
    desc: 'Fixed sidebar + flexible content',
    container: { direction:'row', justify:'flex-start', align:'stretch', wrap:'nowrap', gap:0 },
    items: [
      { grow:0, shrink:0, basis:'250px', alignSelf:'auto', order:0 },
      { grow:1, shrink:1, basis:'auto', alignSelf:'auto', order:0 }
    ]
  },
  {
    name: 'Cards Grid',
    desc: 'Wrapping card layout',
    container: { direction:'row', justify:'flex-start', align:'stretch', wrap:'wrap', gap:16 },
    items: [
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'200px', alignSelf:'auto', order:0 }
    ]
  },
  {
    name: 'Centered',
    desc: 'Perfectly centered content',
    container: { direction:'row', justify:'center', align:'center', wrap:'nowrap', gap:16 },
    items: [
      { grow:0, shrink:1, basis:'auto', alignSelf:'auto', order:0 }
    ]
  },
  {
    name: 'Navbar',
    desc: 'Logo left, nav items right',
    container: { direction:'row', justify:'space-between', align:'center', wrap:'nowrap', gap:10 },
    items: [
      { grow:0, shrink:0, basis:'auto', alignSelf:'auto', order:0 },
      { grow:1, shrink:1, basis:'auto', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'auto', alignSelf:'auto', order:0 },
      { grow:0, shrink:0, basis:'auto', alignSelf:'auto', order:0 }
    ]
  },
  {
    name: 'Footer',
    desc: 'Equal columns footer',
    container: { direction:'row', justify:'space-evenly', align:'flex-start', wrap:'wrap', gap:20 },
    items: [
      { grow:1, shrink:1, basis:'150px', alignSelf:'auto', order:0 },
      { grow:1, shrink:1, basis:'150px', alignSelf:'auto', order:0 },
      { grow:1, shrink:1, basis:'150px', alignSelf:'auto', order:0 },
      { grow:1, shrink:1, basis:'150px', alignSelf:'auto', order:0 }
    ]
  }
];

// --- Cheat sheet data ---
var cheatData = [
  {
    title: 'flex-direction',
    desc: 'Sets the main axis direction.',
    values: [
      { val: 'row', note: 'Left to right (default)' },
      { val: 'row-reverse', note: 'Right to left' },
      { val: 'column', note: 'Top to bottom' },
      { val: 'column-reverse', note: 'Bottom to top' }
    ]
  },
  {
    title: 'justify-content',
    desc: 'Aligns items along the main axis.',
    values: [
      { val: 'flex-start', note: 'Pack to start' },
      { val: 'flex-end', note: 'Pack to end' },
      { val: 'center', note: 'Center items' },
      { val: 'space-between', note: 'Even space, no edge gaps' },
      { val: 'space-around', note: 'Even space, half-size edge gaps' },
      { val: 'space-evenly', note: 'Even space, equal edge gaps' }
    ]
  },
  {
    title: 'align-items',
    desc: 'Aligns items along the cross axis.',
    values: [
      { val: 'stretch', note: 'Fill the container height (default)' },
      { val: 'flex-start', note: 'Align to top/start' },
      { val: 'flex-end', note: 'Align to bottom/end' },
      { val: 'center', note: 'Center vertically' },
      { val: 'baseline', note: 'Align text baselines' }
    ]
  },
  {
    title: 'flex-wrap',
    desc: 'Controls item wrapping.',
    values: [
      { val: 'nowrap', note: 'Single line (default)' },
      { val: 'wrap', note: 'Wrap to new lines' },
      { val: 'wrap-reverse', note: 'Wrap in reverse order' }
    ]
  },
  {
    title: 'flex-grow',
    desc: 'How much an item grows to fill space.',
    values: [
      { val: '0', note: 'Don\'t grow (default)' },
      { val: '1', note: 'Grow equally with siblings' },
      { val: '2', note: 'Grow twice as much as grow:1 items' }
    ]
  },
  {
    title: 'flex-shrink',
    desc: 'How much an item shrinks when space is tight.',
    values: [
      { val: '0', note: 'Don\'t shrink' },
      { val: '1', note: 'Shrink equally (default)' }
    ]
  },
  {
    title: 'flex-basis',
    desc: 'Initial size before growing/shrinking.',
    values: [
      { val: 'auto', note: 'Use item\'s content size (default)' },
      { val: '0', note: 'Start from zero, grow fills space' },
      { val: '200px', note: 'Fixed starting width' },
      { val: '25%', note: 'Percentage of container' }
    ]
  },
  {
    title: 'align-self',
    desc: 'Overrides align-items for one item.',
    values: [
      { val: 'auto', note: 'Inherit from container (default)' },
      { val: 'flex-start', note: 'Align this item to start' },
      { val: 'center', note: 'Center this item' },
      { val: 'flex-end', note: 'Align this item to end' },
      { val: 'stretch', note: 'Stretch this item' }
    ]
  },
  {
    title: 'order',
    desc: 'Changes visual order without changing DOM.',
    values: [
      { val: '0', note: 'Default position' },
      { val: '-1', note: 'Move before default items' },
      { val: '1', note: 'Move after default items' }
    ]
  },
  {
    title: 'gap',
    desc: 'Spacing between flex items.',
    values: [
      { val: '0', note: 'No gap (default)' },
      { val: '10px', note: 'Fixed pixel gap' },
      { val: '1rem', note: 'Relative gap' }
    ]
  }
];

// --- Render functions ---
function render() {
  renderPreview();
  renderItemSelector();
  loadItemControls();
  renderCSS();
  updateBtnStates();
}

function updateBtnStates() {
  addItemBtn.disabled = items.length >= 6;
  addItemBtn.style.opacity = items.length >= 6 ? '0.4' : '';
  removeItemBtn.disabled = items.length <= 1;
  removeItemBtn.style.opacity = items.length <= 1 ? '0.4' : '';
}

function renderPreview() {
  previewContainer.style.flexDirection = ctrlDirection.value;
  previewContainer.style.justifyContent = ctrlJustify.value;
  previewContainer.style.alignItems = ctrlAlign.value;
  previewContainer.style.flexWrap = ctrlWrap.value;
  previewContainer.style.gap = ctrlGap.value + 'px';

  previewContainer.innerHTML = '';
  items.forEach(function(item, i) {
    var el = document.createElement('div');
    el.className = 'preview-item' + (i === selectedItem ? ' selected' : '');
    el.style.flexGrow = item.grow;
    el.style.flexShrink = item.shrink;
    el.style.flexBasis = item.basis;
    el.style.alignSelf = item.alignSelf;
    el.style.order = item.order;
    el.style.background = itemColors[i % itemColors.length];
    el.textContent = (i + 1);
    el.dataset.index = i;
    el.addEventListener('click', function() {
      selectedItem = i;
      itemSelector.value = i;
      render();
    });
    previewContainer.appendChild(el);
  });
}

function renderItemSelector() {
  var val = itemSelector.value;
  itemSelector.innerHTML = '';
  items.forEach(function(_, i) {
    var opt = document.createElement('option');
    opt.value = i;
    opt.textContent = 'Item ' + (i + 1);
    itemSelector.appendChild(opt);
  });
  if (selectedItem >= items.length) selectedItem = items.length - 1;
  itemSelector.value = selectedItem;
}

function loadItemControls() {
  var item = items[selectedItem];
  if (!item) return;
  itemGrow.value = item.grow;
  itemShrink.value = item.shrink;
  itemBasis.value = item.basis;
  itemAlignSelf.value = item.alignSelf;
  itemOrder.value = item.order;
}

function renderCSS() {
  var lines = '.container {\n  display: flex;';
  if (ctrlDirection.value !== 'row') lines += '\n  flex-direction: ' + ctrlDirection.value + ';';
  if (ctrlJustify.value !== 'flex-start') lines += '\n  justify-content: ' + ctrlJustify.value + ';';
  if (ctrlAlign.value !== 'stretch') lines += '\n  align-items: ' + ctrlAlign.value + ';';
  if (ctrlWrap.value !== 'nowrap') lines += '\n  flex-wrap: ' + ctrlWrap.value + ';';
  if (parseInt(ctrlGap.value) > 0) lines += '\n  gap: ' + ctrlGap.value + 'px;';
  lines += '\n}';

  var hasItemStyles = false;
  items.forEach(function(item, i) {
    var itemLines = '';
    if (item.grow != 0) itemLines += '\n  flex-grow: ' + item.grow + ';';
    if (item.shrink != 1) itemLines += '\n  flex-shrink: ' + item.shrink + ';';
    if (item.basis !== 'auto') itemLines += '\n  flex-basis: ' + item.basis + ';';
    if (item.alignSelf !== 'auto') itemLines += '\n  align-self: ' + item.alignSelf + ';';
    if (item.order != 0) itemLines += '\n  order: ' + item.order + ';';
    if (itemLines) {
      hasItemStyles = true;
      lines += '\n\n.item-' + (i + 1) + ' {' + itemLines + '\n}';
    }
  });

  cssOutput.textContent = lines;
}

function renderPresets() {
  presetsGrid.innerHTML = '';
  presets.forEach(function(preset) {
    var card = document.createElement('div');
    card.className = 'preset-card';
    card.innerHTML = '<div class="preset-preview" data-preset="' + preset.name + '"></div><div class="preset-name">' + preset.name + '</div><div class="preset-desc">' + preset.desc + '</div>';
    // Build a mini preview
    var previewEl = card.querySelector('.preset-preview');
    previewEl.style.display = 'flex';
    previewEl.style.flexDirection = preset.container.direction;
    previewEl.style.justifyContent = preset.container.justify;
    previewEl.style.alignItems = preset.container.align;
    previewEl.style.flexWrap = preset.container.wrap;
    previewEl.style.gap = preset.container.gap + 'px';
    previewEl.style.padding = '8px';
    preset.items.forEach(function(item, j) {
      var box = document.createElement('div');
      box.style.background = itemColors[j % itemColors.length];
      box.style.borderRadius = '3px';
      box.style.minWidth = '16px';
      box.style.minHeight = '12px';
      box.style.flexGrow = item.grow;
      box.style.flexShrink = item.shrink;
      box.style.flexBasis = item.basis === 'auto' ? 'auto' : (parseInt(item.basis) ? Math.min(parseInt(item.basis) / 5, 40) + 'px' : item.basis);
      box.style.opacity = '0.85';
      previewEl.appendChild(box);
    });
    card.addEventListener('click', function() {
      ctrlDirection.value = preset.container.direction;
      ctrlJustify.value = preset.container.justify;
      ctrlAlign.value = preset.container.align;
      ctrlWrap.value = preset.container.wrap;
      ctrlGap.value = preset.container.gap;
      items = preset.items.map(function(it) { return { grow:it.grow, shrink:it.shrink, basis:it.basis, alignSelf:it.alignSelf, order:it.order }; });
      selectedItem = 0;
      render();
    });
    presetsGrid.appendChild(card);
  });
}

function renderCheatSheet() {
  cheatSheet.innerHTML = '';
  cheatData.forEach(function(prop) {
    var card = document.createElement('div');
    card.className = 'cheat-card';
    var valuesHtml = prop.values.map(function(v) {
      return '<div class="cheat-val"><code>' + v.val + '</code><span>' + v.note + '</span></div>';
    }).join('');
    card.innerHTML = '<h3>' + prop.title + '</h3><p>' + prop.desc + '</p><div class="cheat-vals">' + valuesHtml + '</div>';
    cheatSheet.appendChild(card);
  });
}

// --- Event listeners ---
ctrlDirection.addEventListener('change', render);
ctrlJustify.addEventListener('change', render);
ctrlAlign.addEventListener('change', render);
ctrlWrap.addEventListener('change', render);
ctrlGap.addEventListener('input', render);

itemSelector.addEventListener('change', function() {
  selectedItem = parseInt(itemSelector.value);
  render();
});

itemGrow.addEventListener('input', function() {
  items[selectedItem].grow = Math.max(0, parseInt(itemGrow.value) || 0);
  render();
});
itemShrink.addEventListener('input', function() {
  items[selectedItem].shrink = Math.max(0, parseInt(itemShrink.value) || 0);
  render();
});
itemBasis.addEventListener('input', function() {
  items[selectedItem].basis = itemBasis.value || 'auto';
  render();
});
itemAlignSelf.addEventListener('change', function() {
  items[selectedItem].alignSelf = itemAlignSelf.value;
  render();
});
itemOrder.addEventListener('input', function() {
  items[selectedItem].order = parseInt(itemOrder.value) || 0;
  render();
});

addItemBtn.addEventListener('click', function() {
  if (items.length >= 6) return;
  items.push({ grow:0, shrink:1, basis:'auto', alignSelf:'auto', order:0 });
  render();
});
removeItemBtn.addEventListener('click', function() {
  if (items.length <= 1) return;
  items.pop();
  if (selectedItem >= items.length) selectedItem = items.length - 1;
  render();
});

copyCssBtn.addEventListener('click', function() {
  var text = cssOutput.textContent;
  if (!text) return;
  navigator.clipboard.writeText(text).then(function() {
    copyCssBtn.textContent = 'Copied!';
    setTimeout(function() { copyCssBtn.textContent = 'Copy'; }, 1500);
  });
});

// --- Init ---
renderPresets();
renderCheatSheet();
render();
</script>

