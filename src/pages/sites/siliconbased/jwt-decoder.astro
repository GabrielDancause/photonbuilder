---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "JWT Decoder — Decode & Debug JSON Web Tokens Online",
      "url": "https://siliconbased.dev/jwt-decoder",
      "description": "Free online JWT decoder and debugger. Paste a JSON Web Token to instantly view the header, payload claims, and signature. Check expiration, copy decoded JSON — all in your browser.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a JWT token?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A JSON Web Token (JWT) is a compact, URL-safe token format defined in RFC 7519. It consists of three Base64URL-encoded parts separated by dots: a header (algorithm and token type), a payload (claims like issuer, subject, and expiration), and a cryptographic signature. JWTs are widely used for authentication, authorization, and secure information exchange between services."
          }
        },
        {
          "@type": "Question",
          "name": "How do I decode a JWT token?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your JWT token into the input field on this page. The header and payload are Base64URL-encoded JSON, so they can be decoded without the secret key. The tool instantly parses and displays the header (algorithm, type), all payload claims with descriptions, and the signature in hexadecimal format."
          }
        },
        {
          "@type": "Question",
          "name": "Can I verify a JWT signature with this tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This tool decodes and inspects JWTs but does not verify signatures, as that requires the secret key or public key. The signature is displayed in hexadecimal format so you can inspect it. For signature verification, you need the signing key and a JWT library in your application code."
          }
        },
        {
          "@type": "Question",
          "name": "Is it safe to paste my JWT token here?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All decoding happens entirely in your browser using JavaScript. No data is sent to any server. Your token never leaves your device. However, remember that JWT payloads are only encoded, not encrypted — anyone with the token can read the claims."
          }
        },
        {
          "@type": "Question",
          "name": "What are standard JWT claims?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Standard (registered) JWT claims defined in RFC 7519 include: iss (issuer), sub (subject), aud (audience), exp (expiration time), nbf (not before), iat (issued at), and jti (JWT ID). These claims are optional but provide interoperable metadata about the token's purpose and validity."
          }
        },
        {
          "@type": "Question",
          "name": "How do I check if a JWT token is expired?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This tool automatically checks the exp (expiration) claim in the payload. If the token has expired, it shows how long ago it expired. If it's still valid, it shows a countdown to expiration. The expiration status is displayed prominently with color coding — green for valid, red for expired."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between JWT decoding and JWT verification?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Decoding a JWT means reading the header and payload by Base64URL-decoding them — no secret key is needed. Verification means checking that the signature is valid using the secret key (HMAC) or public key (RSA/ECDSA). Decoding tells you what the token says; verification tells you if it's trustworthy."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "JWT Decoder — Decode & Debug JSON Web Tokens Online",
      "description": "Free online JWT decoder and debugger. Paste a token to instantly view header, payload claims, signature, and expiration status.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>JWT Decoder & Debugger</h1>
  <p>Decode JSON Web Tokens instantly. View header, payload claims, signature, and expiration status — all in your browser.</p>
</div>

<div class="main">

  <!-- Input Section -->
  <div class="input-section">
    <div class="input-header">
      <div class="header-title">Paste JWT Token</div>
      <div class="header-actions">
        <button class="action-btn" id="sampleBtn">Sample JWT</button>
        <button class="action-btn" id="clearBtn">Clear</button>
      </div>
    </div>
    <textarea id="jwtInput" class="jwt-input" spellcheck="false" placeholder="Paste your JWT token here (eyJhbGciOiJIUzI1NiIs...)"></textarea>
  </div>

  <!-- Expiration Banner -->
  <div class="expiry-banner" id="expiryBanner" style="display:none;">
    <div class="expiry-icon" id="expiryIcon"></div>
    <div class="expiry-text" id="expiryText"></div>
  </div>

  <!-- Decoded Panels -->
  <div class="decoded-grid">
    <!-- Header -->
    <div class="decoded-panel panel-header">
      <div class="panel-top">
        <div class="panel-label"><span class="dot dot-header"></span> Header</div>
        <button class="copy-btn" data-target="headerJson">Copy</button>
      </div>
      <pre class="panel-code" id="headerJson"></pre>
    </div>

    <!-- Payload -->
    <div class="decoded-panel panel-payload">
      <div class="panel-top">
        <div class="panel-label"><span class="dot dot-payload"></span> Payload</div>
        <button class="copy-btn" data-target="payloadJson">Copy</button>
      </div>
      <pre class="panel-code" id="payloadJson"></pre>
    </div>

    <!-- Signature -->
    <div class="decoded-panel panel-signature">
      <div class="panel-top">
        <div class="panel-label"><span class="dot dot-signature"></span> Signature</div>
        <button class="copy-btn" data-target="signatureHex">Copy</button>
      </div>
      <pre class="panel-code" id="signatureHex"></pre>
    </div>
  </div>

  <!-- Claims Table -->
  <div class="claims-section" id="claimsSection" style="display:none;">
    <div class="input-header">
      <div class="header-title">Payload Claims</div>
    </div>
    <div class="claims-table-wrap">
      <table class="claims-table">
        <thead>
          <tr>
            <th>Claim</th>
            <th>Value</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody id="claimsBody"></tbody>
      </table>
    </div>
  </div>

  <!-- JWT Structure Reference -->
  <div class="ref-section">
    <div class="input-header">
      <div class="header-title">JWT Structure Reference</div>
    </div>
    <div class="ref-grid">
      <div class="ref-card">
        <div class="ref-card-title">Header</div>
        <code>Algorithm (alg)</code>
        <code>Token type (typ)</code>
        <code>Key ID (kid)</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Registered Claims</div>
        <code>iss &mdash; Issuer</code>
        <code>sub &mdash; Subject</code>
        <code>aud &mdash; Audience</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Time Claims</div>
        <code>exp &mdash; Expiration</code>
        <code>iat &mdash; Issued At</code>
        <code>nbf &mdash; Not Before</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Common Algorithms</div>
        <code>HS256 &mdash; HMAC SHA-256</code>
        <code>RS256 &mdash; RSA SHA-256</code>
        <code>ES256 &mdash; ECDSA P-256</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Token Format</div>
        <code>header.payload.signature</code>
        <code>Base64URL encoded</code>
        <code>Dot-separated parts</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Common Uses</div>
        <code>API authentication</code>
        <code>OAuth 2.0 / OIDC</code>
        <code>Stateless sessions</code>
      </div>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a JSON Web Token (JWT)?</h2>
    <p>A JSON Web Token (JWT, pronounced "jot") is a compact, URL-safe token format defined in <strong>RFC 7519</strong>. It enables secure information exchange between two parties as a JSON object that is digitally signed. JWTs are commonly used for authentication and authorization in web applications, APIs, and microservices architectures.</p>

    <h2>JWT Token Structure</h2>
    <p>Every JWT consists of three parts separated by dots (<code>.</code>):</p>
    <ul>
      <li><strong>Header:</strong> Contains the signing algorithm (e.g., HS256, RS256) and token type (JWT). It's Base64URL-encoded JSON.</li>
      <li><strong>Payload:</strong> Contains claims — statements about the user or entity, plus metadata like expiration time. Also Base64URL-encoded JSON.</li>
      <li><strong>Signature:</strong> Created by signing the encoded header and payload with a secret key (HMAC) or private key (RSA/ECDSA). Used to verify the token hasn't been tampered with.</li>
    </ul>

    <h2>Standard JWT Claims</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Claim</th>
          <th>Name</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr><td><code>iss</code></td><td>Issuer</td><td>Identifies who issued the JWT</td></tr>
        <tr><td><code>sub</code></td><td>Subject</td><td>Identifies the subject (usually a user ID)</td></tr>
        <tr><td><code>aud</code></td><td>Audience</td><td>Identifies the intended recipient(s)</td></tr>
        <tr><td><code>exp</code></td><td>Expiration</td><td>Unix timestamp after which the token is invalid</td></tr>
        <tr><td><code>nbf</code></td><td>Not Before</td><td>Unix timestamp before which the token is not valid</td></tr>
        <tr><td><code>iat</code></td><td>Issued At</td><td>Unix timestamp when the token was created</td></tr>
        <tr><td><code>jti</code></td><td>JWT ID</td><td>Unique identifier to prevent token replay</td></tr>
      </tbody>
    </table>

    <h2>Decoding vs Verifying a JWT</h2>
    <p><strong>Decoding</strong> simply means reading the header and payload by Base64URL-decoding them. No secret key is required — anyone with the token can read the claims. <strong>Verifying</strong> means checking the signature against the secret or public key to confirm the token hasn't been altered. Always verify JWTs on the server side before trusting their claims.</p>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a JWT token?</h3>
      <p style="margin-bottom: 16px;">A JSON Web Token (JWT) is a compact, URL-safe token format defined in RFC 7519. It consists of three Base64URL-encoded parts separated by dots: a header (algorithm and token type), a payload (claims like issuer, subject, and expiration), and a cryptographic signature. JWTs are widely used for authentication, authorization, and secure information exchange between services.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I decode a JWT token?</h3>
      <p style="margin-bottom: 16px;">Paste your JWT token into the input field on this page. The header and payload are Base64URL-encoded JSON, so they can be decoded without the secret key. The tool instantly parses and displays the header (algorithm, type), all payload claims with descriptions, and the signature in hexadecimal format.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I verify a JWT signature with this tool?</h3>
      <p style="margin-bottom: 16px;">This tool decodes and inspects JWTs but does not verify signatures, as that requires the secret key or public key. The signature is displayed in hexadecimal format so you can inspect it. For signature verification, you need the signing key and a JWT library in your application code.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is it safe to paste my JWT token here?</h3>
      <p style="margin-bottom: 16px;">Yes. All decoding happens entirely in your browser using JavaScript. No data is sent to any server. Your token never leaves your device. However, remember that JWT payloads are only encoded, not encrypted — anyone with the token can read the claims.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What are standard JWT claims?</h3>
      <p style="margin-bottom: 16px;">Standard (registered) JWT claims defined in RFC 7519 include: iss (issuer), sub (subject), aud (audience), exp (expiration time), nbf (not before), iat (issued at), and jti (JWT ID). These claims are optional but provide interoperable metadata about the token's purpose and validity.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I check if a JWT token is expired?</h3>
      <p style="margin-bottom: 16px;">This tool automatically checks the exp (expiration) claim in the payload. If the token has expired, it shows how long ago it expired. If it's still valid, it shows a countdown to expiration. The expiration status is displayed prominently with color coding — green for valid, red for expired.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between JWT decoding and JWT verification?</h3>
      <p style="margin-bottom: 16px;">Decoding a JWT means reading the header and payload by Base64URL-decoding them — no secret key is needed. Verification means checking that the signature is valid using the secret key (HMAC) or public key (RSA/ECDSA). Decoding tells you what the token says; verification tells you if it's trustworthy.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/base64-encoder-decoder">Base64 Encoder & Decoder</a> — Encode and decode Base64 strings with file upload and URL-safe mode.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions online with real-time highlighting.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "JWT Decoder — Decode & Debug JSON Web Tokens Online",
  description: "Free online JWT decoder and debugger. Paste a JSON Web Token to instantly decode the header, payload claims, signature, and check expiration. No data leaves your browser.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="JWT Decoder — Decode & Debug JSON Web Tokens Online"
  description="Free online JWT decoder and debugger. Paste a JSON Web Token to instantly decode the header, payload claims, signature, and check expiration. No data leaves your browser."
  canonical="https://siliconbased.dev/jwt-decoder"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const jwtInput = document.getElementById('jwtInput');
const sampleBtn = document.getElementById('sampleBtn');
const clearBtn = document.getElementById('clearBtn');
const headerJson = document.getElementById('headerJson');
const payloadJson = document.getElementById('payloadJson');
const signatureHex = document.getElementById('signatureHex');
const expiryBanner = document.getElementById('expiryBanner');
const expiryIcon = document.getElementById('expiryIcon');
const expiryText = document.getElementById('expiryText');
const claimsSection = document.getElementById('claimsSection');
const claimsBody = document.getElementById('claimsBody');

const CLAIM_DESCRIPTIONS = {
  iss: 'Issuer \u2014 who issued this token',
  sub: 'Subject \u2014 the user or entity this token represents',
  aud: 'Audience \u2014 intended recipient(s) of the token',
  exp: 'Expiration Time \u2014 when this token expires (Unix timestamp)',
  nbf: 'Not Before \u2014 token is not valid before this time (Unix timestamp)',
  iat: 'Issued At \u2014 when this token was created (Unix timestamp)',
  jti: 'JWT ID \u2014 unique identifier for this token',
  name: 'Full name of the user',
  email: 'Email address of the user',
  email_verified: 'Whether the email address has been verified',
  azp: 'Authorized Party \u2014 the party to which the token was issued',
  nonce: 'Nonce \u2014 value used to associate a session with a token',
  auth_time: 'Authentication Time \u2014 when the user last authenticated',
  at_hash: 'Access Token Hash \u2014 hash of the access token',
  c_hash: 'Code Hash \u2014 hash of the authorization code',
  acr: 'Authentication Context Class Reference',
  amr: 'Authentication Methods References',
  scope: 'Scopes \u2014 permissions granted by this token',
  roles: 'Roles \u2014 roles assigned to the user',
  permissions: 'Permissions \u2014 specific permissions granted',
  typ: 'Token Type',
  sid: 'Session ID'
};

function base64UrlDecode(str) {
  str = str.replace(/-/g, '+').replace(/_/g, '/');
  while (str.length % 4 !== 0) str += '=';
  return atob(str);
}

function base64UrlToHex(str) {
  var raw = base64UrlDecode(str);
  var hex = '';
  for (var i = 0; i < raw.length; i++) {
    hex += raw.charCodeAt(i).toString(16).padStart(2, '0');
  }
  return hex;
}

function formatTimestamp(ts) {
  try {
    var d = new Date(ts * 1000);
    return d.toLocaleString() + ' (Unix: ' + ts + ')';
  } catch (e) {
    return String(ts);
  }
}

function timeDiff(ts) {
  var now = Math.floor(Date.now() / 1000);
  var diff = Math.abs(ts - now);
  var days = Math.floor(diff / 86400); diff %= 86400;
  var hours = Math.floor(diff / 3600); diff %= 3600;
  var minutes = Math.floor(diff / 60);
  var seconds = diff % 60;
  var parts = [];
  if (days > 0) parts.push(days + 'd');
  if (hours > 0) parts.push(hours + 'h');
  if (minutes > 0) parts.push(minutes + 'm');
  parts.push(seconds + 's');
  return parts.join(' ');
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function decodeJwt() {
  var token = jwtInput.value.trim();
  headerJson.textContent = '';
  payloadJson.textContent = '';
  signatureHex.textContent = '';
  expiryBanner.style.display = 'none';
  claimsSection.style.display = 'none';
  claimsBody.innerHTML = '';

  if (!token) return;

  var parts = token.split('.');
  if (parts.length !== 3) {
    headerJson.textContent = 'Invalid JWT: expected 3 dot-separated parts, got ' + parts.length;
    return;
  }

  // Decode header
  var header;
  try {
    header = JSON.parse(base64UrlDecode(parts[0]));
    headerJson.textContent = JSON.stringify(header, null, 2);
  } catch (e) {
    headerJson.textContent = 'Error decoding header: ' + e.message;
    return;
  }

  // Decode payload
  var payload;
  try {
    payload = JSON.parse(base64UrlDecode(parts[1]));
    payloadJson.textContent = JSON.stringify(payload, null, 2);
  } catch (e) {
    payloadJson.textContent = 'Error decoding payload: ' + e.message;
    return;
  }

  // Decode signature
  try {
    signatureHex.textContent = base64UrlToHex(parts[2]);
  } catch (e) {
    signatureHex.textContent = 'Error decoding signature: ' + e.message;
  }

  // Expiration check
  if (payload.exp !== undefined) {
    var now = Math.floor(Date.now() / 1000);
    var isExpired = now >= payload.exp;
    expiryBanner.style.display = 'flex';
    expiryBanner.className = 'expiry-banner ' + (isExpired ? 'expired' : 'valid');
    expiryIcon.textContent = isExpired ? '\u2718' : '\u2714';
    expiryText.innerHTML = isExpired
      ? 'Token <strong>expired</strong> ' + escapeHtml(timeDiff(payload.exp)) + ' ago (' + escapeHtml(new Date(payload.exp * 1000).toLocaleString()) + ')'
      : 'Token <strong>valid</strong> \u2014 expires in ' + escapeHtml(timeDiff(payload.exp)) + ' (' + escapeHtml(new Date(payload.exp * 1000).toLocaleString()) + ')';
  }

  // Claims table
  var keys = Object.keys(payload);
  if (keys.length > 0) {
    claimsSection.style.display = 'block';
    keys.forEach(function(key) {
      var tr = document.createElement('tr');
      var tdKey = document.createElement('td');
      var tdVal = document.createElement('td');
      var tdDesc = document.createElement('td');

      tdKey.innerHTML = '<code>' + escapeHtml(key) + '</code>';

      var val = payload[key];
      if ((key === 'exp' || key === 'iat' || key === 'nbf' || key === 'auth_time') && typeof val === 'number') {
        tdVal.textContent = formatTimestamp(val);
      } else if (typeof val === 'object') {
        tdVal.textContent = JSON.stringify(val);
      } else {
        tdVal.textContent = String(val);
      }

      tdDesc.textContent = CLAIM_DESCRIPTIONS[key] || 'Custom claim';

      tr.appendChild(tdKey);
      tr.appendChild(tdVal);
      tr.appendChild(tdDesc);
      claimsBody.appendChild(tr);
    });
  }
}

function generateSampleJwt() {
  var header = { alg: 'HS256', typ: 'JWT' };
  var now = Math.floor(Date.now() / 1000);
  var payload = {
    iss: 'https://auth.example.com',
    sub: '1234567890',
    aud: 'https://api.example.com',
    name: 'Jane Doe',
    email: 'jane@example.com',
    roles: ['admin', 'user'],
    iat: now,
    exp: now + 3600,
    jti: 'tok_' + Math.random().toString(36).substring(2, 10)
  };

  function b64url(obj) {
    var json = JSON.stringify(obj);
    var bytes = new TextEncoder().encode(json);
    var binary = '';
    for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
    return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
  }

  // Fake signature (32 random bytes)
  var sigBytes = '';
  for (var i = 0; i < 32; i++) sigBytes += String.fromCharCode(Math.floor(Math.random() * 256));
  var sig = btoa(sigBytes).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');

  return b64url(header) + '.' + b64url(payload) + '.' + sig;
}

function init() {
  jwtInput.addEventListener('input', decodeJwt);

  sampleBtn.addEventListener('click', function() {
    jwtInput.value = generateSampleJwt();
    decodeJwt();
  });

  clearBtn.addEventListener('click', function() {
    jwtInput.value = '';
    decodeJwt();
    jwtInput.focus();
  });

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var targetId = btn.getAttribute('data-target');
      var el = document.getElementById(targetId);
      if (!el || !el.textContent) return;
      navigator.clipboard.writeText(el.textContent).then(function() {
        btn.textContent = '\u2713 Copied';
        setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
      });
    });
  });

  // Auto-refresh expiry every second
  setInterval(function() {
    if (jwtInput.value.trim()) decodeJwt();
  }, 1000);
}

init();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #0f1729 0%, #060a12 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1100px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Input section */
.input-section { margin-bottom: 24px; }
.input-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.header-title { font-size: 0.85rem; font-weight: 600; color: #ccc; text-transform: uppercase; letter-spacing: 0.5px; }
.header-actions { display: flex; gap: 8px; }
.action-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 6px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.15s; }
.action-btn:hover { background: #2a2d40; color: #ccc; }

