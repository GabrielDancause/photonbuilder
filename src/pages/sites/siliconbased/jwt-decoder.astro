---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "JWT Decoder — Decode & Debug JSON Web Tokens Online",
      "url": "https://siliconbased.dev/jwt-decoder",
      "description": "Free online JWT decoder and debugger. Paste a JSON Web Token to instantly decode the header, payload, and verify claims. Color-coded output — runs entirely in your browser.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a JWT token?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A JSON Web Token (JWT) is a compact, URL-safe token format defined in RFC 7519. It consists of three Base64URL-encoded parts separated by dots: a header (specifying the algorithm and token type), a payload (containing claims like issuer, subject, and expiration), and a signature (used to verify the token hasn't been tampered with). JWTs are widely used for authentication, authorization, and secure information exchange between services."
          }
        },
        {
          "@type": "Question",
          "name": "How do I decode a JWT token?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your JWT token into the input field at the top of the page. The decoder instantly splits the token into its three parts and Base64URL-decodes the header and payload, displaying them as formatted JSON. The header, payload, and signature are color-coded red, purple, and blue respectively for easy identification."
          }
        },
        {
          "@type": "Question",
          "name": "Is it safe to decode JWT tokens in this tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All decoding happens entirely in your browser using JavaScript. No data is sent to any server. Your tokens never leave your device. However, you should never share JWT tokens publicly as they may contain sensitive claims."
          }
        },
        {
          "@type": "Question",
          "name": "What are JWT claims?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Claims are statements about an entity (typically the user) and additional metadata. Registered claims include iss (issuer), sub (subject), aud (audience), exp (expiration time), nbf (not before), iat (issued at), and jti (JWT ID). Custom claims can contain any application-specific data like user roles, permissions, or profile information."
          }
        },
        {
          "@type": "Question",
          "name": "Can this tool verify JWT signatures?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This tool decodes and displays the JWT header, payload, and signature. It shows the algorithm used and whether the token structure is valid. Full cryptographic signature verification requires the secret key or public key, which should never be shared in a client-side tool. For signature verification, use a server-side library in your application."
          }
        },
        {
          "@type": "Question",
          "name": "What does it mean when a JWT is expired?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A JWT is expired when the current time is past the exp (expiration time) claim. Expired tokens should be rejected by servers. This decoder shows the expiration time in a human-readable format and includes a live countdown timer so you can see exactly when a token expires or how long ago it expired."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between HS256 and RS256?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "HS256 (HMAC-SHA256) is a symmetric algorithm where the same secret key is used to both sign and verify the token. RS256 (RSA-SHA256) is an asymmetric algorithm that uses a private key to sign and a public key to verify. RS256 is preferred for distributed systems where multiple services need to verify tokens without sharing a secret."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "JWT Decoder — Decode & Debug JSON Web Tokens Online",
      "description": "Free online JWT decoder and debugger. Paste a token to decode header, payload, and claims instantly.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>JWT Decoder & Debugger</h1>
  <p>Decode JSON Web Tokens instantly. View header, payload, and claims with color-coded output — all in your browser.</p>
</div>

<div class="main">

  <!-- Token Input -->
  <div class="token-input-section">
    <div class="input-header">
      <div class="header-title">Paste JWT Token</div>
      <div class="header-actions">
        <button class="action-btn" id="sampleBtn">Load Sample</button>
        <button class="action-btn" id="clearBtn">Clear</button>
      </div>
    </div>
    <textarea id="tokenInput" class="token-area" spellcheck="false" placeholder="Paste your JWT token here (eyJhbGciOiJIUzI1NiIs...)"></textarea>
    <div class="token-color-bar" id="tokenColorBar"></div>
  </div>

  <!-- Token Status -->
  <div class="token-status" id="tokenStatus" style="display:none;">
    <div class="status-badges" id="statusBadges"></div>
  </div>

  <!-- Decoded Panels -->
  <div class="decoded-grid">
    <!-- Header -->
    <div class="decoded-pane header-pane">
      <div class="pane-header">
        <div class="pane-dot header-dot"></div>
        <div class="header-title">Header</div>
        <button class="copy-btn" id="copyHeader">Copy</button>
      </div>
      <pre class="decoded-json" id="headerJson"><span class="placeholder-text">Header will appear here...</span></pre>
    </div>

    <!-- Payload -->
    <div class="decoded-pane payload-pane">
      <div class="pane-header">
        <div class="pane-dot payload-dot"></div>
        <div class="header-title">Payload</div>
        <button class="copy-btn" id="copyPayload">Copy</button>
      </div>
      <pre class="decoded-json" id="payloadJson"><span class="placeholder-text">Payload will appear here...</span></pre>
    </div>
  </div>

  <!-- Signature -->
  <div class="signature-section" id="signatureSection" style="display:none;">
    <div class="pane-header">
      <div class="pane-dot signature-dot"></div>
      <div class="header-title">Signature</div>
    </div>
    <div class="signature-box" id="signatureBox"></div>
  </div>

  <!-- Token Info -->
  <div class="token-info-section" id="tokenInfoSection" style="display:none;">
    <div class="input-header">
      <div class="header-title">Token Information</div>
    </div>
    <div class="info-grid" id="infoGrid"></div>
    <div class="expiry-countdown" id="expiryCountdown" style="display:none;">
      <div class="countdown-label" id="countdownLabel">Expires in</div>
      <div class="countdown-value" id="countdownValue"></div>
    </div>
  </div>

  <!-- Common Claims Reference -->
  <div class="ref-section">
    <div class="input-header">
      <div class="header-title">Common JWT Claims Reference</div>
    </div>
    <div class="claims-table-wrapper">
      <table class="claims-table">
        <thead>
          <tr>
            <th>Claim</th>
            <th>Name</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><code>iss</code></td><td>Issuer</td><td>Entity that issued the token</td></tr>
          <tr><td><code>sub</code></td><td>Subject</td><td>Principal that is the subject of the JWT</td></tr>
          <tr><td><code>aud</code></td><td>Audience</td><td>Recipients the token is intended for</td></tr>
          <tr><td><code>exp</code></td><td>Expiration Time</td><td>Time after which the token is invalid (Unix timestamp)</td></tr>
          <tr><td><code>nbf</code></td><td>Not Before</td><td>Time before which the token is not valid (Unix timestamp)</td></tr>
          <tr><td><code>iat</code></td><td>Issued At</td><td>Time at which the token was issued (Unix timestamp)</td></tr>
          <tr><td><code>jti</code></td><td>JWT ID</td><td>Unique identifier for the token</td></tr>
          <tr><td><code>name</code></td><td>Full Name</td><td>User's full name (OpenID Connect)</td></tr>
          <tr><td><code>email</code></td><td>Email</td><td>User's email address (OpenID Connect)</td></tr>
          <tr><td><code>roles</code></td><td>Roles</td><td>User roles or permissions (custom claim)</td></tr>
          <tr><td><code>scope</code></td><td>Scope</td><td>OAuth 2.0 scopes granted to the token</td></tr>
          <tr><td><code>azp</code></td><td>Authorized Party</td><td>Party to which the token was issued (OpenID Connect)</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a JSON Web Token (JWT)?</h2>
    <p>A JSON Web Token (JWT, pronounced "jot") is a compact, URL-safe token format defined in <strong>RFC 7519</strong>. JWTs are widely used for authentication and authorization in modern web applications, APIs, and microservices. A JWT consists of three parts separated by dots (<code>.</code>):</p>
    <ul>
      <li><strong>Header:</strong> Contains the signing algorithm (e.g., HS256, RS256) and token type (JWT). Encoded as Base64URL.</li>
      <li><strong>Payload:</strong> Contains claims — statements about the user and metadata like issuer, expiration, and custom data. Encoded as Base64URL.</li>
      <li><strong>Signature:</strong> Created by signing the encoded header and payload with a secret key or private key. Used to verify token integrity.</li>
    </ul>

    <h2>How JWT Authentication Works</h2>
    <p>When a user logs in, the server creates a JWT containing user claims and signs it with a secret. The token is sent to the client, which includes it in the <code>Authorization: Bearer &lt;token&gt;</code> header of subsequent requests. The server verifies the signature and extracts claims without needing to query a database, making JWTs ideal for stateless authentication in distributed systems.</p>

    <h2>JWT Signing Algorithms</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Algorithm</th>
          <th>Type</th>
          <th>Key</th>
          <th>Use Case</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>HS256</td><td>Symmetric (HMAC)</td><td>Shared secret</td><td>Single-service apps, simple setups</td></tr>
        <tr><td>HS384</td><td>Symmetric (HMAC)</td><td>Shared secret</td><td>Higher security requirement</td></tr>
        <tr><td>HS512</td><td>Symmetric (HMAC)</td><td>Shared secret</td><td>Maximum HMAC security</td></tr>
        <tr><td>RS256</td><td>Asymmetric (RSA)</td><td>Public/private key pair</td><td>Distributed systems, microservices</td></tr>
        <tr><td>RS384</td><td>Asymmetric (RSA)</td><td>Public/private key pair</td><td>Higher security RSA</td></tr>
        <tr><td>RS512</td><td>Asymmetric (RSA)</td><td>Public/private key pair</td><td>Maximum RSA security</td></tr>
        <tr><td>ES256</td><td>Asymmetric (ECDSA)</td><td>Elliptic curve key pair</td><td>Compact tokens, mobile apps</td></tr>
        <tr><td>PS256</td><td>Asymmetric (RSA-PSS)</td><td>Public/private key pair</td><td>Modern RSA with PSS padding</td></tr>
      </tbody>
    </table>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a JWT token?</h3>
      <p style="margin-bottom: 16px;">A JSON Web Token (JWT) is a compact, URL-safe token format defined in RFC 7519. It consists of three Base64URL-encoded parts separated by dots: a header (specifying the algorithm and token type), a payload (containing claims like issuer, subject, and expiration), and a signature (used to verify the token hasn't been tampered with). JWTs are widely used for authentication, authorization, and secure information exchange between services.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I decode a JWT token?</h3>
      <p style="margin-bottom: 16px;">Paste your JWT token into the input field at the top of the page. The decoder instantly splits the token into its three parts and Base64URL-decodes the header and payload, displaying them as formatted JSON. The header, payload, and signature are color-coded red, purple, and blue respectively for easy identification.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is it safe to decode JWT tokens in this tool?</h3>
      <p style="margin-bottom: 16px;">Yes. All decoding happens entirely in your browser using JavaScript. No data is sent to any server. Your tokens never leave your device. However, you should never share JWT tokens publicly as they may contain sensitive claims.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What are JWT claims?</h3>
      <p style="margin-bottom: 16px;">Claims are statements about an entity (typically the user) and additional metadata. Registered claims include iss (issuer), sub (subject), aud (audience), exp (expiration time), nbf (not before), iat (issued at), and jti (JWT ID). Custom claims can contain any application-specific data like user roles, permissions, or profile information.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can this tool verify JWT signatures?</h3>
      <p style="margin-bottom: 16px;">This tool decodes and displays the JWT header, payload, and signature. It shows the algorithm used and whether the token structure is valid. Full cryptographic signature verification requires the secret key or public key, which should never be shared in a client-side tool. For signature verification, use a server-side library in your application.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does it mean when a JWT is expired?</h3>
      <p style="margin-bottom: 16px;">A JWT is expired when the current time is past the exp (expiration time) claim. Expired tokens should be rejected by servers. This decoder shows the expiration time in a human-readable format and includes a live countdown timer so you can see exactly when a token expires or how long ago it expired.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between HS256 and RS256?</h3>
      <p style="margin-bottom: 16px;">HS256 (HMAC-SHA256) is a symmetric algorithm where the same secret key is used to both sign and verify the token. RS256 (RSA-SHA256) is an asymmetric algorithm that uses a private key to sign and a public key to verify. RS256 is preferred for distributed systems where multiple services need to verify tokens without sharing a secret.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/base64-encoder-decoder">Base64 Encoder & Decoder</a> — Encode and decode Base64 strings with file upload and URL-safe mode.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions online with real-time highlighting.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "JWT Decoder — Decode & Debug JSON Web Tokens Online",
  description: "Free online JWT decoder and debugger. Paste a JSON Web Token to instantly decode the header, payload, and claims with color-coded output. No data leaves your browser.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="JWT Decoder — Decode & Debug JSON Web Tokens Online"
  description="Free online JWT decoder and debugger. Paste a JSON Web Token to instantly decode the header, payload, and claims with color-coded output. No data leaves your browser."
  canonical="https://siliconbased.dev/jwt-decoder"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const tokenInput = document.getElementById('tokenInput');
const tokenColorBar = document.getElementById('tokenColorBar');
const tokenStatus = document.getElementById('tokenStatus');
const statusBadges = document.getElementById('statusBadges');
const headerJson = document.getElementById('headerJson');
const payloadJson = document.getElementById('payloadJson');
const signatureSection = document.getElementById('signatureSection');
const signatureBox = document.getElementById('signatureBox');
const tokenInfoSection = document.getElementById('tokenInfoSection');
const infoGrid = document.getElementById('infoGrid');
const expiryCountdown = document.getElementById('expiryCountdown');
const countdownLabel = document.getElementById('countdownLabel');
const countdownValue = document.getElementById('countdownValue');
const clearBtn = document.getElementById('clearBtn');
const sampleBtn = document.getElementById('sampleBtn');
const copyHeader = document.getElementById('copyHeader');
const copyPayload = document.getElementById('copyPayload');

let countdownInterval = null;
let decodedHeaderObj = null;
let decodedPayloadObj = null;

function init() {
  tokenInput.addEventListener('input', decode);
  clearBtn.addEventListener('click', clearAll);
  sampleBtn.addEventListener('click', loadSample);
  copyHeader.addEventListener('click', function() { copyJson('header'); });
  copyPayload.addEventListener('click', function() { copyJson('payload'); });
  decode();
}

function base64UrlDecode(str) {
  str = str.replace(/-/g, '+').replace(/_/g, '/');
  while (str.length % 4 !== 0) str += '=';
  try {
    var binary = atob(str);
    var bytes = new Uint8Array(binary.length);
    for (var i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
    return new TextDecoder().decode(bytes);
  } catch (e) {
    return null;
  }
}

function decode() {
  var token = tokenInput.value.trim();
  if (!token) { resetUI(); return; }

  var parts = token.split('.');
  if (parts.length !== 3) {
    showError('Invalid JWT: expected 3 parts separated by dots, found ' + parts.length);
    return;
  }

  renderColorBar(parts);

  var headerStr = base64UrlDecode(parts[0]);
  if (!headerStr) { showError('Invalid JWT: cannot decode header'); return; }
  var header;
  try { header = JSON.parse(headerStr); } catch (e) { showError('Invalid JWT: header is not valid JSON'); return; }

  var payloadStr = base64UrlDecode(parts[1]);
  if (!payloadStr) { showError('Invalid JWT: cannot decode payload'); return; }
  var payload;
  try { payload = JSON.parse(payloadStr); } catch (e) { showError('Invalid JWT: payload is not valid JSON'); return; }

  decodedHeaderObj = header;
  decodedPayloadObj = payload;

  headerJson.innerHTML = syntaxHighlight(JSON.stringify(header, null, 2));
  payloadJson.innerHTML = formatPayload(payload);

  signatureSection.style.display = 'block';
  var sigHex = base64UrlToHex(parts[2]);
  signatureBox.innerHTML =
    '<div class="sig-algo">Algorithm: <strong>' + escapeHtml(header.alg || 'none') + '</strong> &nbsp;|&nbsp; Type: <strong>' + escapeHtml(header.typ || 'JWT') + '</strong></div>' +
    '<div class="sig-hex"><code>' + sigHex + '</code></div>';

  renderTokenInfo(header, payload);
  renderStatus(header, payload);
}

function renderColorBar(parts) {
  var total = parts.join('.').length;
  var hp = (parts[0].length / total * 100).toFixed(1);
  var pp = ((parts[0].length + 1 + parts[1].length) / total * 100).toFixed(1);
  tokenColorBar.innerHTML =
    '<div class="color-segment header-seg" style="width:' + hp + '%"></div>' +
    '<div class="color-dot"></div>' +
    '<div class="color-segment payload-seg" style="width:' + (pp - hp) + '%"></div>' +
    '<div class="color-dot"></div>' +
    '<div class="color-segment signature-seg" style="flex:1"></div>';
  tokenColorBar.style.display = 'flex';
}

function renderStatus(header, payload) {
  tokenStatus.style.display = 'block';
  var badges = '';
  badges += '<span class="badge badge-algo">' + escapeHtml(header.alg || 'none') + '</span>';
  badges += '<span class="badge badge-type">' + escapeHtml(header.typ || 'JWT') + '</span>';

  var now = Math.floor(Date.now() / 1000);
  if (payload.exp) {
    if (now > payload.exp) {
      badges += '<span class="badge badge-expired">Expired</span>';
    } else {
      badges += '<span class="badge badge-valid">Not Expired</span>';
    }
  }
  if (payload.nbf && now < payload.nbf) {
    badges += '<span class="badge badge-warn">Not Yet Valid</span>';
  }
  statusBadges.innerHTML = badges;
}

function formatPayload(payload) {
  var timeClaims = ['iat', 'exp', 'nbf', 'auth_time'];
  var lines = JSON.stringify(payload, null, 2).split('\n');
  var result = '';
  for (var li = 0; li < lines.length; li++) {
    var line = lines[li];
    var annotated = syntaxHighlightLine(line);
    for (var ci = 0; ci < timeClaims.length; ci++) {
      var claim = timeClaims[ci];
      var regex = new RegExp('"' + claim + '":\\s*(\\d{9,11})');
      var match = line.match(regex);
      if (match) {
        var ts = parseInt(match[1]);
        var date = new Date(ts * 1000);
        annotated += '<span class="date-annotation"> // ' + date.toUTCString() + '</span>';
      }
    }
    result += annotated + '\n';
  }
  return result;
}

function syntaxHighlight(json) {
  return json.split('\n').map(syntaxHighlightLine).join('\n');
}

function syntaxHighlightLine(line) {
  return escapeHtml(line)
    .replace(/"([^"]+)":/g, '<span class="json-key">"$1"</span>:')
    .replace(/: "([^"]*)"(,?)$/gm, ': <span class="json-string">"$1"</span>$2')
    .replace(/: (\d+)(,?)$/gm, ': <span class="json-number">$1</span>$2')
    .replace(/: (true|false)(,?)$/gm, ': <span class="json-bool">$1</span>$2')
    .replace(/: (null)(,?)$/gm, ': <span class="json-null">$1</span>$2');
}

function renderTokenInfo(header, payload) {
  tokenInfoSection.style.display = 'block';
  var html = '';
  var infoItems = [];
  if (payload.iss) infoItems.push({ label: 'Issuer (iss)', value: payload.iss });
  if (payload.sub) infoItems.push({ label: 'Subject (sub)', value: payload.sub });
  if (payload.aud) infoItems.push({ label: 'Audience (aud)', value: Array.isArray(payload.aud) ? payload.aud.join(', ') : payload.aud });
  if (payload.iat) infoItems.push({ label: 'Issued At (iat)', value: formatTimestamp(payload.iat) });
  if (payload.exp) infoItems.push({ label: 'Expires At (exp)', value: formatTimestamp(payload.exp) });
  if (payload.nbf) infoItems.push({ label: 'Not Before (nbf)', value: formatTimestamp(payload.nbf) });
  if (payload.jti) infoItems.push({ label: 'JWT ID (jti)', value: payload.jti });
  if (payload.name) infoItems.push({ label: 'Name', value: payload.name });
  if (payload.email) infoItems.push({ label: 'Email', value: payload.email });
  if (payload.scope) infoItems.push({ label: 'Scope', value: payload.scope });
  if (payload.roles) infoItems.push({ label: 'Roles', value: Array.isArray(payload.roles) ? payload.roles.join(', ') : payload.roles });
  infoItems.push({ label: 'Algorithm', value: header.alg || 'none' });

  for (var i = 0; i < infoItems.length; i++) {
    var item = infoItems[i];
    html += '<div class="info-card"><div class="info-label">' + escapeHtml(item.label) + '</div><div class="info-value">' + escapeHtml(String(item.value)) + '</div></div>';
  }
  infoGrid.innerHTML = html;

  if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
  if (payload.exp) {
    expiryCountdown.style.display = 'block';
    updateCountdown(payload.exp);
    countdownInterval = setInterval(function() { updateCountdown(payload.exp); }, 1000);
  } else {
    expiryCountdown.style.display = 'none';
  }
}

function updateCountdown(exp) {
  var now = Math.floor(Date.now() / 1000);
  var diff = exp - now;
  if (diff > 0) {
    countdownLabel.textContent = 'Expires in';
    countdownLabel.className = 'countdown-label valid';
    countdownValue.textContent = formatDuration(diff);
    countdownValue.className = 'countdown-value valid';
  } else {
    countdownLabel.textContent = 'Expired';
    countdownLabel.className = 'countdown-label expired';
    countdownValue.textContent = formatDuration(Math.abs(diff)) + ' ago';
    countdownValue.className = 'countdown-value expired';
  }
}

function formatDuration(seconds) {
  var d = Math.floor(seconds / 86400);
  var h = Math.floor((seconds % 86400) / 3600);
  var m = Math.floor((seconds % 3600) / 60);
  var s = seconds % 60;
  var parts = [];
  if (d > 0) parts.push(d + 'd');
  if (h > 0) parts.push(h + 'h');
  if (m > 0) parts.push(m + 'm');
  parts.push(s + 's');
  return parts.join(' ');
}

function formatTimestamp(ts) {
  var d = new Date(ts * 1000);
  return d.toUTCString() + ' (Unix: ' + ts + ')';
}

function base64UrlToHex(str) {
  try {
    str = str.replace(/-/g, '+').replace(/_/g, '/');
    while (str.length % 4 !== 0) str += '=';
    var binary = atob(str);
    var hex = '';
    for (var i = 0; i < binary.length; i++) {
      hex += binary.charCodeAt(i).toString(16).padStart(2, '0');
    }
    return hex;
  } catch (e) {
    return '(cannot decode)';
  }
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function showError(msg) {
  headerJson.innerHTML = '<span class="error-text">' + escapeHtml(msg) + '</span>';
  payloadJson.innerHTML = '<span class="placeholder-text">Payload will appear here...</span>';
  signatureSection.style.display = 'none';
  tokenInfoSection.style.display = 'none';
  tokenStatus.style.display = 'none';
  tokenColorBar.style.display = 'none';
  decodedHeaderObj = null;
  decodedPayloadObj = null;
  if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
}

function resetUI() {
  headerJson.innerHTML = '<span class="placeholder-text">Header will appear here...</span>';
  payloadJson.innerHTML = '<span class="placeholder-text">Payload will appear here...</span>';
  signatureSection.style.display = 'none';
  tokenInfoSection.style.display = 'none';
  tokenStatus.style.display = 'none';
  tokenColorBar.style.display = 'none';
  expiryCountdown.style.display = 'none';
  decodedHeaderObj = null;
  decodedPayloadObj = null;
  if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
}

function clearAll() {
  tokenInput.value = '';
  resetUI();
  tokenInput.focus();
}

function loadSample() {
  var now = Math.floor(Date.now() / 1000);
  var header = { alg: 'HS256', typ: 'JWT' };
  var payload = {
    sub: '1234567890',
    name: 'Jane Developer',
    email: 'jane@example.com',
    iss: 'https://auth.example.com',
    aud: 'https://api.example.com',
    iat: now,
    exp: now + 3600,
    nbf: now,
    roles: ['admin', 'user'],
    jti: 'a1b2c3d4-e5f6-7890-abcd-ef1234567890'
  };
  var h = btoa(JSON.stringify(header)).replace(/=/g, '').replace(/\+/g, '-').replace(/\//g, '_');
  var p = btoa(JSON.stringify(payload)).replace(/=/g, '').replace(/\+/g, '-').replace(/\//g, '_');
  var fakeSig = btoa('sample-signature-not-valid').replace(/=/g, '').replace(/\+/g, '-').replace(/\//g, '_');
  tokenInput.value = h + '.' + p + '.' + fakeSig;
  decode();
}

function copyJson(which) {
  var obj = which === 'header' ? decodedHeaderObj : decodedPayloadObj;
  var btn = which === 'header' ? copyHeader : copyPayload;
  if (!obj) return;
  var text = JSON.stringify(obj, null, 2);
  navigator.clipboard.writeText(text).then(function() {
    btn.textContent = '\u2713 Copied';
    setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
  });
}

init();
</script>

