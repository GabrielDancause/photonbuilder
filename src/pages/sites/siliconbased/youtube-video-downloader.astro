  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does a YouTube video downloader work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A YouTube video downloader works by parsing the webpage's source code or interacting with the site's internal API to find the direct URLs to the underlying video and audio streams. It then downloads these streams (which are often separate) and uses a tool like FFmpeg to combine them into a single, playable file like an MP4."
        }
      },
      {
        "@type": "Question",
        "name": "Is using a YouTube video downloader 2025 legal?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Downloading videos from YouTube generally violates their Terms of Service. However, legality depends on your jurisdiction and the concept of 'fair use'. Downloading copyright-free content, public domain videos, or your own content for archival purposes is usually considered acceptable, whereas downloading copyrighted music or movies for redistribution is illegal."
        }
      },
      {
        "@type": "Question",
        "name": "What is yt-dlp?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "yt-dlp is a popular, open-source command-line program that downloads videos from YouTube and thousands of other sites. It is a fork of the original youtube-dl project, offering faster updates, better format selection, and advanced features for bypassing geo-restrictions and throttling."
        }
      },
      {
        "@type": "Question",
        "name": "Why do some downloaders only offer 720p?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "YouTube uses Adaptive Bitrate Streaming (DASH), which separates video and audio tracks for resolutions of 1080p and higher. To offer 1080p or 4K, a downloader must pull both tracks and stitch them together (multiplexing) using a server-side tool. Many simple web-based downloaders only pull the pre-combined 720p streams to save server resources."
        }
      },
      {
        "@type": "Question",
        "name": "Can I download just the audio from a YouTube video?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Most advanced downloaders allow you to specifically request the audio stream (usually in M4A or WebM format) and ignore the video track. Tools like yt-dlp can then automatically convert that raw audio stream into an MP3 file."
        }
