<SiteLayout
  site="siliconbased"
  title="Cron Job Generator — Build Cron Expressions Visually"
  description="Free cron job generator and crontab expression builder. Create cron schedules visually with presets, human-readable descriptions, and next run time preview."
  canonical="https://siliconbased.dev/cron-job-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const MONTHS = ['','January','February','March','April','May','June','July','August','September','October','November','December'];
const DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

const exprFields = {
  min: document.getElementById('exprMin'),
  hour: document.getElementById('exprHour'),
  dom: document.getElementById('exprDom'),
  month: document.getElementById('exprMonth'),
  dow: document.getElementById('exprDow'),
};
const humanDesc = document.getElementById('humanDesc');
const runsList = document.getElementById('runsList');
const copyExprBtn = document.getElementById('copyExprBtn');
const reverseInput = document.getElementById('reverseInput');
const reverseBtn = document.getElementById('reverseBtn');
const reverseResult = document.getElementById('reverseResult');

// Builder elements
const fields = {
  min: { type: document.getElementById('minType'), val: document.getElementById('minVal'), step: document.getElementById('minStep'), rs: document.getElementById('minRangeStart'), re: document.getElementById('minRangeEnd') },
  hour: { type: document.getElementById('hourType'), val: document.getElementById('hourVal'), step: document.getElementById('hourStep'), rs: document.getElementById('hourRangeStart'), re: document.getElementById('hourRangeEnd') },
  dom: { type: document.getElementById('domType'), val: document.getElementById('domVal'), step: document.getElementById('domStep'), rs: document.getElementById('domRangeStart'), re: document.getElementById('domRangeEnd') },
  month: { type: document.getElementById('monthType'), val: document.getElementById('monthVal'), step: null, rs: document.getElementById('monthRangeStart'), re: document.getElementById('monthRangeEnd') },
  dow: { type: document.getElementById('dowType'), val: document.getElementById('dowVal'), step: null, rs: document.getElementById('dowRangeStart'), re: document.getElementById('dowRangeEnd') },
};

function init() {
  // Builder type changes
  Object.keys(fields).forEach(key => {
    const f = fields[key];
    f.type.addEventListener('change', () => { updateFieldInputs(key); buildExpression(); });
    if (f.val) f.val.addEventListener('input', buildExpression);
    if (f.step) f.step.addEventListener('input', buildExpression);
    if (f.rs) f.rs.addEventListener('input', buildExpression);
    if (f.re) f.re.addEventListener('input', buildExpression);
  });

  // Presets
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyExpression(btn.dataset.expr);
    });
  });

  // Copy
  copyExprBtn.addEventListener('click', () => {
    const expr = getExpression();
    navigator.clipboard.writeText(expr).then(() => {
      copyExprBtn.textContent = '\u2713 Copied';
      setTimeout(() => { copyExprBtn.textContent = 'Copy'; }, 1500);
    });
  });

  // Reverse parser
  reverseBtn.addEventListener('click', reverseParseFromInput);
  reverseInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') reverseParseFromInput();
  });

  buildExpression();
}

function updateFieldInputs(key) {
  const f = fields[key];
  const type = f.type.value;
  if (f.val) f.val.style.display = type === 'specific' ? 'block' : 'none';
  if (f.step) f.step.style.display = type === 'step' ? 'block' : 'none';
  if (f.rs) f.rs.style.display = type === 'range' ? 'block' : 'none';
  if (f.re) f.re.style.display = type === 'range' ? 'block' : 'none';
}

function getFieldValue(key) {
  const f = fields[key];
  const type = f.type.value;
  if (type === '*') return '*';
  if (type === 'specific') return f.val.value || '0';
  if (type === 'step') return '*/' + (f.step.value || '1');
  if (type === 'range') return (f.rs.value || '0') + '-' + (f.re.value || '0');
  return '*';
}

function getExpression() {
  return [getFieldValue('min'), getFieldValue('hour'), getFieldValue('dom'), getFieldValue('month'), getFieldValue('dow')].join(' ');
}

function buildExpression() {
  const parts = [getFieldValue('min'), getFieldValue('hour'), getFieldValue('dom'), getFieldValue('month'), getFieldValue('dow')];
  exprFields.min.textContent = parts[0];
  exprFields.hour.textContent = parts[1];
  exprFields.dom.textContent = parts[2];
  exprFields.month.textContent = parts[3];
  exprFields.dow.textContent = parts[4];

  const expr = parts.join(' ');
  humanDesc.textContent = describeExpression(expr);
  renderNextRuns(expr);

  // Update preset highlights
  document.querySelectorAll('.preset-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.expr === expr);
  });
}

function applyExpression(expr) {
  const parts = expr.split(/\s+/);
  if (parts.length !== 5) return;

  const keys = ['min', 'hour', 'dom', 'month', 'dow'];
  parts.forEach((part, i) => {
    const key = keys[i];
    const f = fields[key];
    if (part === '*') {
      f.type.value = '*';
    } else if (part.startsWith('*/')) {
      if (f.step) {
        f.type.value = 'step';
        f.step.value = part.slice(2);
      } else {
        f.type.value = '*';
      }
    } else if (part.includes('-') && !part.includes('/')) {
      f.type.value = 'range';
      const rp = part.split('-');
      if (f.rs) f.rs.value = rp[0];
      if (f.re) f.re.value = rp[1];
    } else if (/^\d+$/.test(part)) {
      f.type.value = 'specific';
      if (f.val) f.val.value = part;
    } else {
      f.type.value = '*';
    }
    updateFieldInputs(key);
  });

  buildExpression();
}

function describeExpression(expr) {
  const parts = expr.split(/\s+/);
  if (parts.length !== 5) return 'Invalid expression';
  const [min, hour, dom, month, dow] = parts;

  const pieces = [];

  // Minute
  if (min === '*') {
    pieces.push('Every minute');
  } else if (min.startsWith('*/')) {
    pieces.push('Every ' + min.slice(2) + ' minutes');
  } else if (min.includes('-')) {
    pieces.push('Minutes ' + min);
  } else {
    pieces.push('At minute ' + min);
  }

  // Hour
  if (hour === '*') {
    if (min !== '*' && !min.startsWith('*/')) pieces.push('of every hour');
  } else if (hour.startsWith('*/')) {
    pieces.push('every ' + hour.slice(2) + ' hours');
  } else if (hour.includes('-')) {
    pieces.push('during hours ' + hour);
  } else {
    const h = parseInt(hour);
    const ampm = h >= 12 ? 'PM' : 'AM';
    const h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
    const m = min === '*' || min.startsWith('*/') ? '' : ':' + min.padStart(2, '0');
    pieces.length = 0;
    pieces.push('At ' + h12 + m + ' ' + ampm);
  }

  // DOM
  if (dom !== '*') {
    if (dom.startsWith('*/')) {
      pieces.push('every ' + dom.slice(2) + ' days');
    } else if (dom.includes('-')) {
      pieces.push('on days ' + dom);
    } else {
      pieces.push('on day ' + dom + ' of the month');
    }
  }

  // Month
  if (month !== '*') {
    if (month.includes('-')) {
      const mp = month.split('-');
      pieces.push('in ' + (MONTHS[parseInt(mp[0])] || mp[0]) + ' through ' + (MONTHS[parseInt(mp[1])] || mp[1]));
    } else {
      pieces.push('in ' + (MONTHS[parseInt(month)] || month));
    }
  }

  // DOW
  if (dow !== '*') {
    if (dow.includes('-')) {
      const dp = dow.split('-');
      pieces.push('on ' + (DAYS[parseInt(dp[0])] || dp[0]) + ' through ' + (DAYS[parseInt(dp[1])] || dp[1]));
    } else {
      pieces.push('on ' + (DAYS[parseInt(dow)] || dow));
    }
  }

  return pieces.join(' ');
}

function parseField(field, min, max) {
  const values = new Set();
  field.split(',').forEach(part => {
    if (part === '*') {
      for (let i = min; i <= max; i++) values.add(i);
    } else if (part.includes('/')) {
      const [range, stepStr] = part.split('/');
      const step = parseInt(stepStr) || 1;
      let start = min;
      let end = max;
      if (range !== '*') {
        if (range.includes('-')) {
          const rp = range.split('-');
          start = parseInt(rp[0]);
          end = parseInt(rp[1]);
        } else {
          start = parseInt(range);
        }
      }
      for (let i = start; i <= end; i += step) values.add(i);
    } else if (part.includes('-')) {
      const rp = part.split('-');
      const start = parseInt(rp[0]);
      const end = parseInt(rp[1]);
      for (let i = start; i <= end; i++) values.add(i);
    } else {
      values.add(parseInt(part));
    }
  });
  return Array.from(values).filter(v => v >= min && v <= max).sort((a, b) => a - b);
}

function getNextRuns(expr, count) {
  const parts = expr.split(/\s+/);
  if (parts.length !== 5) return [];

  const minutes = parseField(parts[0], 0, 59);
  const hours = parseField(parts[1], 0, 23);
  const doms = parseField(parts[2], 1, 31);
  const months = parseField(parts[3], 1, 12);
  const dows = parseField(parts[4], 0, 6);

  if (!minutes.length || !hours.length || !doms.length || !months.length || !dows.length) return [];

  const results = [];
  const now = new Date();
  const cursor = new Date(now.getFullYear(), now.getMonth(), now.getDate(), now.getHours(), now.getMinutes() + 1, 0, 0);
  const limit = new Date(now.getTime() + 366 * 24 * 60 * 60 * 1000);

  const domIsWild = parts[2] === '*';
  const dowIsWild = parts[4] === '*';

  while (results.length < count && cursor < limit) {
    const mo = cursor.getMonth() + 1;
    if (!months.includes(mo)) {
      cursor.setMonth(cursor.getMonth() + 1, 1);
      cursor.setHours(0, 0, 0, 0);
      continue;
    }

    const d = cursor.getDate();
    const wd = cursor.getDay();
    const domMatch = doms.includes(d);
    const dowMatch = dows.includes(wd);
    let dayOk;
    if (domIsWild && dowIsWild) dayOk = true;
    else if (domIsWild) dayOk = dowMatch;
    else if (dowIsWild) dayOk = domMatch;
    else dayOk = domMatch || dowMatch;

    if (!dayOk) {
      cursor.setDate(d + 1);
      cursor.setHours(0, 0, 0, 0);
      continue;
    }

    const h = cursor.getHours();
    if (!hours.includes(h)) {
      const nextH = hours.find(v => v > h);
      if (nextH !== undefined) {
        cursor.setHours(nextH, minutes[0], 0, 0);
      } else {
        cursor.setDate(d + 1);
        cursor.setHours(0, 0, 0, 0);
      }
      continue;
    }

    const m = cursor.getMinutes();
    if (!minutes.includes(m)) {
      const nextM = minutes.find(v => v > m);
      if (nextM !== undefined) {
        cursor.setMinutes(nextM, 0, 0);
      } else {
        const nextH = hours.find(v => v > h);
        if (nextH !== undefined) {
          cursor.setHours(nextH, minutes[0], 0, 0);
        } else {
          cursor.setDate(d + 1);
          cursor.setHours(0, 0, 0, 0);
        }
      }
      continue;
    }

    results.push(new Date(cursor));
    // Advance to next minute candidate
    const nextM = minutes.find(v => v > m);
    if (nextM !== undefined) {
      cursor.setMinutes(nextM, 0, 0);
    } else {
      const nextH = hours.find(v => v > h);
      if (nextH !== undefined) {
        cursor.setHours(nextH, minutes[0], 0, 0);
      } else {
        cursor.setDate(d + 1);
        cursor.setHours(0, 0, 0, 0);
      }
    }
  }

  return results;
}

function formatDate(d) {
  const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const day = days[d.getDay()];
  const mon = months[d.getMonth()];
  const date = d.getDate();
  const year = d.getFullYear();
  const h = d.getHours();
  const m = String(d.getMinutes()).padStart(2, '0');
  const ampm = h >= 12 ? 'PM' : 'AM';
  const h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
  return day + ', ' + mon + ' ' + date + ', ' + year + ' at ' + h12 + ':' + m + ' ' + ampm;
}

function renderNextRuns(expr) {
  const runs = getNextRuns(expr, 10);
  if (runs.length === 0) {
    runsList.innerHTML = '<div class="no-runs">No upcoming runs found within the next year</div>';
    return;
  }
  let html = '';
  runs.forEach((r, i) => {
    html += '<div class="run-item"><span class="run-num">' + (i + 1) + '</span><span class="run-date">' + formatDate(r) + '</span></div>';
  });
  runsList.innerHTML = html;
}

function reverseParseFromInput() {
  const expr = reverseInput.value.trim();
  if (!expr) {
    reverseResult.innerHTML = '<div class="reverse-empty">Enter a cron expression above</div>';
    return;
  }
  const parts = expr.split(/\s+/);
  if (parts.length !== 5) {
    reverseResult.innerHTML = '<div class="reverse-error">Invalid cron expression. Expected 5 fields separated by spaces.</div>';
    return;
  }
  // Validate each field
  const valid = /^(\*|(\d+(-\d+)?(,\d+(-\d+)?)*))(\/\d+)?$/;
  for (let i = 0; i < 5; i++) {
    if (!valid.test(parts[i])) {
      reverseResult.innerHTML = '<div class="reverse-error">Invalid field: ' + escapeHtml(parts[i]) + '</div>';
      return;
    }
  }

  const desc = describeExpression(expr);
  const runs = getNextRuns(expr, 10);
  let html = '<div class="reverse-desc">' + escapeHtml(desc) + '</div>';
  if (runs.length > 0) {
    html += '<div class="reverse-runs-title">Next 10 runs:</div>';
    runs.forEach((r, i) => {
      html += '<div class="run-item"><span class="run-num">' + (i + 1) + '</span><span class="run-date">' + formatDate(r) + '</span></div>';
    });
  }
  reverseResult.innerHTML = html;
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

init();
</script>

