      </select>
      <div class="builder-inputs" id="dowInputs">
        <select id="dowVal" class="builder-select" style="display:none;">
          <option value="0">Sunday</option><option value="1">Monday</option><option value="2">Tuesday</option>
          <option value="3">Wednesday</option><option value="4">Thursday</option><option value="5">Friday</option>
          <option value="6">Saturday</option>
        </select>
        <input type="number" id="dowRangeStart" class="builder-num" min="0" max="6" value="1" placeholder="start" style="display:none;" />
        <input type="number" id="dowRangeEnd" class="builder-num" min="0" max="6" value="5" placeholder="end" style="display:none;" />
      </div>
    </div>
  </div>

  <!-- Next Run Times -->
  <div class="next-runs">
    <div class="input-header">
      <div class="header-title">Next 10 Run Times</div>
    </div>
