      <select id="domType" class="builder-select">
        <option value="*">Every day (*)</option>
        <option value="specific">Specific day</option>
        <option value="step">Every N days (*/N)</option>
        <option value="range">Range (start-end)</option>
      </select>
      <div class="builder-inputs" id="domInputs">
        <input type="number" id="domVal" class="builder-num" min="1" max="31" value="1" placeholder="1" style="display:none;" />
        <input type="number" id="domStep" class="builder-num" min="1" max="31" value="2" placeholder="step" style="display:none;" />
        <input type="number" id="domRangeStart" class="builder-num" min="1" max="31" value="1" placeholder="start" style="display:none;" />
        <input type="number" id="domRangeEnd" class="builder-num" min="1" max="31" value="15" placeholder="end" style="display:none;" />
      </div>
    </div>

    <div class="builder-field">
      <label class="builder-label">Month <span class="builder-range">(1-12)</span></label>
      <select id="monthType" class="builder-select">
