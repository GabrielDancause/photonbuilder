---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Cron Job Generator — Build Cron Expressions Visually",
      "url": "https://siliconbased.dev/cron-job-generator",
      "description": "Free cron job generator and crontab expression builder. Create cron schedules visually, see human-readable descriptions, preview next run times, and reverse-parse existing expressions.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a cron expression?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A cron expression is a string of five fields separated by spaces that defines a schedule for recurring tasks. The five fields represent minute (0-59), hour (0-23), day of month (1-31), month (1-12), and day of week (0-6, where 0 is Sunday). Special characters like * (any), / (step), , (list), and - (range) let you build complex schedules."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use a cron job generator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use the visual builder to select values for each field (minute, hour, day of month, month, day of week) or pick a preset like 'every hour' or 'daily at midnight'. The tool generates the cron expression in real time, shows a human-readable description, and previews the next 10 scheduled run times."
          }
        },
        {
          "@type": "Question",
          "name": "What does */5 mean in a cron expression?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The */5 syntax means 'every 5th unit'. In the minute field, */5 means every 5 minutes (0, 5, 10, 15, ...). In the hour field, */5 means every 5 hours. The * represents all possible values and /5 is the step interval."
          }
        },
        {
          "@type": "Question",
          "name": "How do I schedule a cron job to run daily at midnight?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use the expression 0 0 * * * to run a job at midnight every day. The first 0 sets the minute to 0, the second 0 sets the hour to 0 (midnight), and the three asterisks mean every day of the month, every month, and every day of the week."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between cron and crontab?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Cron is the daemon (background service) that runs scheduled tasks on Unix/Linux systems. Crontab (cron table) is the file where you define those scheduled tasks. The command 'crontab -e' opens your personal crontab for editing. Each line in a crontab contains a cron expression followed by the command to run."
          }
        },
        {
          "@type": "Question",
          "name": "Can I reverse-parse an existing cron expression?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Paste any standard 5-field cron expression into the reverse parser input and the tool will display a plain-English description of what schedule it represents, along with the next 10 run times. This is useful for understanding cron expressions you find in existing configuration files."
          }
        },
        {
          "@type": "Question",
          "name": "Is this cron generator free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this cron job generator is completely free and runs entirely in your browser. No data is sent to any server. You can use it to build, test, and understand cron expressions without creating an account or installing anything."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Cron Job Generator — Build Cron Expressions Visually",
      "description": "Free cron expression builder with visual controls, presets, human-readable descriptions, and next run time preview.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Cron Job Generator</h1>
  <p>Build cron expressions visually, preview run times, and decode existing schedules. No data leaves your browser.</p>
</div>

<div class="main">

  <!-- Live Expression Output -->
  <div class="expression-bar">
    <div class="expr-fields">
      <span class="expr-field" id="exprMin" title="Minute">*</span>
      <span class="expr-field" id="exprHour" title="Hour">*</span>
      <span class="expr-field" id="exprDom" title="Day of Month">*</span>
      <span class="expr-field" id="exprMonth" title="Month">*</span>
      <span class="expr-field" id="exprDow" title="Day of Week">*</span>
    </div>
    <button class="copy-btn" id="copyExprBtn">Copy</button>
  </div>
  <div class="human-desc" id="humanDesc">Every minute</div>

  <!-- Presets -->
  <div class="presets-row">
    <button class="preset-btn active" data-expr="* * * * *">Every Minute</button>
    <button class="preset-btn" data-expr="0 * * * *">Hourly</button>
    <button class="preset-btn" data-expr="0 0 * * *">Daily (Midnight)</button>
    <button class="preset-btn" data-expr="0 0 * * 1">Weekly (Mon)</button>
    <button class="preset-btn" data-expr="0 0 1 * *">Monthly (1st)</button>
    <button class="preset-btn" data-expr="0 0 1 1 *">Yearly (Jan 1)</button>
    <button class="preset-btn" data-expr="*/5 * * * *">Every 5 Min</button>
    <button class="preset-btn" data-expr="*/15 * * * *">Every 15 Min</button>
    <button class="preset-btn" data-expr="0 */6 * * *">Every 6 Hours</button>
    <button class="preset-btn" data-expr="0 9-17 * * 1-5">Weekdays 9-5</button>
  </div>

  <!-- Visual Builder -->
  <div class="builder-grid">
    <div class="builder-field">
      <label class="builder-label">Minute <span class="builder-range">(0-59)</span></label>
      <select id="minType" class="builder-select">
        <option value="*">Every minute (*)</option>
        <option value="specific">Specific minute</option>
        <option value="step">Every N minutes (*/N)</option>
        <option value="range">Range (start-end)</option>
      </select>
      <div class="builder-inputs" id="minInputs">
        <input type="number" id="minVal" class="builder-num" min="0" max="59" value="0" placeholder="0" style="display:none;" />
        <input type="number" id="minStep" class="builder-num" min="1" max="59" value="5" placeholder="step" style="display:none;" />
        <input type="number" id="minRangeStart" class="builder-num" min="0" max="59" value="0" placeholder="start" style="display:none;" />
        <input type="number" id="minRangeEnd" class="builder-num" min="0" max="59" value="30" placeholder="end" style="display:none;" />
      </div>
    </div>

    <div class="builder-field">
      <label class="builder-label">Hour <span class="builder-range">(0-23)</span></label>
      <select id="hourType" class="builder-select">
        <option value="*">Every hour (*)</option>
        <option value="specific">Specific hour</option>
        <option value="step">Every N hours (*/N)</option>
        <option value="range">Range (start-end)</option>
      </select>
      <div class="builder-inputs" id="hourInputs">
        <input type="number" id="hourVal" class="builder-num" min="0" max="23" value="0" placeholder="0" style="display:none;" />
        <input type="number" id="hourStep" class="builder-num" min="1" max="23" value="2" placeholder="step" style="display:none;" />
        <input type="number" id="hourRangeStart" class="builder-num" min="0" max="23" value="9" placeholder="start" style="display:none;" />
        <input type="number" id="hourRangeEnd" class="builder-num" min="0" max="23" value="17" placeholder="end" style="display:none;" />
      </div>
    </div>

    <div class="builder-field">
