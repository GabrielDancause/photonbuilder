---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "siliconbased.dev — Developer Tools & Research",
  "url": "https://siliconbased.dev/",
  "description": "Free developer tools and original research. JSON, JWT, regex, cron, colors, timestamps, security studies, and performance analysis."
};
---

<SiteLayout
  site="siliconbased"
  title="siliconbased.dev — Developer Tools & Research"
  description="Free developer tools and original research. JSON, JWT, regex, cron, colors, timestamps, security studies, and performance analysis."
  canonical="https://siliconbased.dev/"
  schema={schema}
>
  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Developer Tools & Research</div>
      <h1>siliconbased.dev</h1>
      <p>Free developer tools and original research. JSON, JWT, regex, cron, colors, timestamps, security studies, and performance analysis.</p>
    </div>
  </div>

  <!-- Tools Section -->
  <div class="section-container">
    <div class="section-header">
      <span class="section-tag">🛠️ TOOLS</span>
      <h2 class="section-title">Developer Tools</h2>
      <p class="section-sub">Free, client-side, no signup. Built for devs who ship fast.</p>
      <a href="/tools/" class="view-all">View all 71 tools →</a>
    </div>
    <div class="tools-grid">
      <a class="tool-card" href="/devbox"><span class="tool-emoji">⚡</span><h3 class="tool-name">DevBox</h3><p class="tool-desc">Auto-detect dev strings — JSON, JWT, base64, timestamps, colors, regex, cron, URLs</p></a>
      <a class="tool-card" href="/chmod-calculator"><span class="tool-emoji">⚙️</span><h3 class="tool-name">chmod Calculator</h3><p class="tool-desc">Visual Linux file permission editor with octal &amp; symbolic notation</p></a>
      <a class="tool-card" href="/base64"><span class="tool-emoji">🔤</span><h3 class="tool-name">Base64 Encoder/Decoder</h3><p class="tool-desc">Encode/decode Base64. Supports files, images, URL-safe mode</p></a>
      <a class="tool-card" href="/cron-generator"><span class="tool-emoji">⏰</span><h3 class="tool-name">Cron Expression Generator</h3><p class="tool-desc">Build cron expressions visually with schedule preview</p></a>
      <a class="tool-card" href="/json-formatter"><span class="tool-emoji">📋</span><h3 class="tool-name">JSON Formatter &amp; Validator</h3><p class="tool-desc">Format, validate, minify JSON with syntax highlighting</p></a>
      <a class="tool-card" href="/utm-builder"><span class="tool-emoji">🔗</span><h3 class="tool-name">UTM Builder</h3><p class="tool-desc">Generate UTM-tagged URLs for campaign tracking</p></a>
      <a class="tool-card" href="/color-converter"><span class="tool-emoji">🎨</span><h3 class="tool-name">Color Converter</h3><p class="tool-desc">Convert HEX, RGB, HSL, CMYK with visual picker</p></a>
      <a class="tool-card" href="/regex-tester"><span class="tool-emoji">🔍</span><h3 class="tool-name">Regex Tester</h3><p class="tool-desc">Test regex patterns with real-time highlighting</p></a>
      <a class="tool-card" href="/hash-generator"><span class="tool-emoji">🔐</span><h3 class="tool-name">Hash Generator</h3><p class="tool-desc">Generate MD5, SHA-1, SHA-256, SHA-512 hashes</p></a>
      <a class="tool-card" href="/html-entities"><span class="tool-emoji">🏷️</span><h3 class="tool-name">HTML Entities Encoder</h3><p class="tool-desc">Encode/decode special characters to HTML entities</p></a>
      <a class="tool-card" href="/js-minifier"><span class="tool-emoji">📦</span><h3 class="tool-name">JavaScript Minifier</h3><p class="tool-desc">Minify JS code for production builds</p></a>
      <a class="tool-card" href="/csv-json"><span class="tool-emoji">🔄</span><h3 class="tool-name">CSV ↔ JSON Converter</h3><p class="tool-desc">Convert between CSV and JSON with file support</p></a>
      <a class="tool-card" href="/password-generator"><span class="tool-emoji">🔑</span><h3 class="tool-name">Password Generator</h3><p class="tool-desc">Generate strong passwords with custom criteria</p></a>
      <a class="tool-card" href="/meta-tag-generator"><span class="tool-emoji">🏗️</span><h3 class="tool-name">Meta Tag Generator</h3><p class="tool-desc">Generate SEO meta tags &amp; Open Graph preview</p></a>
      <a class="tool-card" href="/url-encoder"><span class="tool-emoji">🌐</span><h3 class="tool-name">URL Encoder/Decoder</h3><p class="tool-desc">Encode/decode URLs and query parameters</p></a>
      <a class="tool-card" href="/sql-formatter"><span class="tool-emoji">🗄️</span><h3 class="tool-name">SQL Formatter</h3><p class="tool-desc">Format SQL queries with proper indentation</p></a>
      <a class="tool-card" href="/markdown-preview"><span class="tool-emoji">📄</span><h3 class="tool-name">Markdown Live Preview</h3><p class="tool-desc">Write Markdown with real-time HTML preview</p></a>
      <a class="tool-card" href="/yaml-json"><span class="tool-emoji">🔄</span><h3 class="tool-name">YAML ↔ JSON Converter</h3><p class="tool-desc">Convert between YAML and JSON with validation</p></a>
      <a class="tool-card" href="/lorem-ipsum"><span class="tool-emoji">📝</span><h3 class="tool-name">Lorem Ipsum Generator</h3><p class="tool-desc">Generate placeholder text in paragraphs or words</p></a>
      <a class="tool-card" href="/uuid-generator"><span class="tool-emoji">🆔</span><h3 class="tool-name">UUID Generator</h3><p class="tool-desc">Generate UUID v1, v4, v7. Parse and validate UUIDs</p></a>
      <a class="tool-card" href="/qr-generator"><span class="tool-emoji">📱</span><h3 class="tool-name">QR Code Generator</h3><p class="tool-desc">Generate QR codes with size/color customization</p></a>
      <a class="tool-card" href="/css-minifier"><span class="tool-emoji">🎨</span><h3 class="tool-name">CSS Minifier</h3><p class="tool-desc">Minify CSS for production builds</p></a>
      <a class="tool-card" href="/og-preview"><span class="tool-emoji">👁️</span><h3 class="tool-name">Open Graph Preview</h3><p class="tool-desc">Preview URL sharing on Facebook, Twitter, LinkedIn</p></a>
      <a class="tool-card" href="/xml-json"><span class="tool-emoji">🔄</span><h3 class="tool-name">XML ↔ JSON Converter</h3><p class="tool-desc">Convert XML to JSON with attribute handling</p></a>
      <a class="tool-card" href="/robots-txt"><span class="tool-emoji">🤖</span><h3 class="tool-name">robots.txt Generator</h3><p class="tool-desc">Build robots.txt with user agents &amp; sitemaps</p></a>
      <a class="tool-card" href="/diff-checker"><span class="tool-emoji">📋</span><h3 class="tool-name">Text Diff Checker</h3><p class="tool-desc">Compare texts with line-by-line diff highlighting</p></a>
      <a class="tool-card" href="/word-counter"><span class="tool-emoji">🔢</span><h3 class="tool-name">Word &amp; Character Counter</h3><p class="tool-desc">Count words, chars, sentences with reading time</p></a>
      <a class="tool-card" href="/subnet-calculator"><span class="tool-emoji">🌐</span><h3 class="tool-name">Subnet Calculator</h3><p class="tool-desc">Calculate subnet masks, network &amp; broadcast addresses</p></a>
      <a class="tool-card" href="/escape-unescape"><span class="tool-emoji">🔓</span><h3 class="tool-name">String Escape/Unescape</h3><p class="tool-desc">Escape strings for JSON, HTML, XML, URL, JavaScript</p></a>
      <a class="tool-card" href="/html-markdown"><span class="tool-emoji">🔄</span><h3 class="tool-name">HTML ↔ Markdown Converter</h3><p class="tool-desc">Convert between HTML and Markdown formats</p></a>
      <a class="tool-card" href="/timestamp-converter"><span class="tool-emoji">⏱️</span><h3 class="tool-name">Timestamp Converter</h3><p class="tool-desc">Convert Unix timestamps with timezone support</p></a>
      <a class="tool-card" href="/number-base"><span class="tool-emoji">🔢</span><h3 class="tool-name">Number Base Converter</h3><p class="tool-desc">Convert binary, octal, decimal, hexadecimal</p></a>
      <a class="tool-card" href="/ascii-table"><span class="tool-emoji">📟</span><h3 class="tool-name">ASCII Reference Table</h3><p class="tool-desc">Interactive ASCII &amp; Unicode character lookup</p></a>
      <a class="tool-card" href="/gradient-generator"><span class="tool-emoji">🌈</span><h3 class="tool-name">CSS Gradient Generator</h3><p class="tool-desc">Create gradients visually with preset gallery</p></a>
      <a class="tool-card" href="/box-shadow"><span class="tool-emoji">🖼️</span><h3 class="tool-name">Box Shadow Generator</h3><p class="tool-desc">Design CSS box shadows with multi-layer support</p></a>
      <a class="tool-card" href="/flexbox-playground"><span class="tool-emoji">📐</span><h3 class="tool-name">Flexbox Playground</h3><p class="tool-desc">Interactive CSS Flexbox layout builder</p></a>
      <a class="tool-card" href="/grid-generator"><span class="tool-emoji">📐</span><h3 class="tool-name">CSS Grid Generator</h3><p class="tool-desc">Visual CSS Grid designer with template areas</p></a>
      <a class="tool-card" href="/slug-generator"><span class="tool-emoji">🔗</span><h3 class="tool-name">URL Slug Generator</h3><p class="tool-desc">Convert text to URL slugs with Unicode support</p></a>
      <a class="tool-card" href="/schema-generator"><span class="tool-emoji">📋</span><h3 class="tool-name">Schema Markup Generator</h3><p class="tool-desc">Generate JSON-LD structured data</p></a>
      <a class="tool-card" href="/jwt-debugger"><span class="tool-emoji">🔑</span><h3 class="tool-name">JWT Debugger</h3><p class="tool-desc">Decode JWT tokens &amp; validate expiration</p></a>
      <a class="tool-card" href="/csp-generator"><span class="tool-emoji">🛡️</span><h3 class="tool-name">CSP Header Generator</h3><p class="tool-desc">Build Content Security Policy headers visually</p></a>
      <a class="tool-card" href="/http-status"><span class="tool-emoji">📡</span><h3 class="tool-name">HTTP Status Code Reference</h3><p class="tool-desc">Interactive status code lookup with examples</p></a>
      <a class="tool-card" href="/json-path"><span class="tool-emoji">🎯</span><h3 class="tool-name">JSON Path Tester</h3><p class="tool-desc">Test JSONPath expressions with live results</p></a>
      <a class="tool-card" href="/toml-converter"><span class="tool-emoji">🔄</span><h3 class="tool-name">TOML Converter</h3><p class="tool-desc">Convert TOML, JSON, YAML with validation</p></a>
      <a class="tool-card" href="/sitemap-generator"><span class="tool-emoji">🗺️</span><h3 class="tool-name">XML Sitemap Generator</h3><p class="tool-desc">Create XML sitemaps with priority &amp; frequency</p></a>
      <a class="tool-card" href="/crontab-guru"><span class="tool-emoji">⏰</span><h3 class="tool-name">Crontab Guru</h3><p class="tool-desc">Explain cron expressions in plain English</p></a>
      <a class="tool-card" href="/dns-lookup"><span class="tool-emoji">🌐</span><h3 class="tool-name">DNS Lookup Tool</h3><p class="tool-desc">Query DNS records: A, AAAA, MX, NS, TXT, CNAME</p></a>
      <a class="tool-card" href="/whois-lookup"><span class="tool-emoji">🔍</span><h3 class="tool-name">WHOIS Lookup</h3><p class="tool-desc">Check domain registration &amp; nameserver details</p></a>
      <a class="tool-card" href="/email-validator"><span class="tool-emoji">📧</span><h3 class="tool-name">Email Address Validator</h3><p class="tool-desc">Validate email format, MX records, syntax</p></a>
      <a class="tool-card" href="/ip-lookup"><span class="tool-emoji">📍</span><h3 class="tool-name">IP Address Lookup</h3><p class="tool-desc">IP geolocation, ISP, ASN &amp; reverse DNS lookup</p></a>
      <a class="tool-card" href="/user-agent-parser"><span class="tool-emoji">🌐</span><h3 class="tool-name">User Agent Parser</h3><p class="tool-desc">Parse browser, OS, device from user agent strings</p></a>
      <a class="tool-card" href="/ssl-checker"><span class="tool-emoji">🔒</span><h3 class="tool-name">SSL Certificate Checker</h3><p class="tool-desc">Check SSL certificate details &amp; validity</p></a>
      <a class="tool-card" href="/border-radius"><span class="tool-emoji">⬜</span><h3 class="tool-name">Border Radius Generator</h3><p class="tool-desc">Design CSS border-radius visually</p></a>
      <a class="tool-card" href="/text-transform"><span class="tool-emoji">🔠</span><h3 class="tool-name">Text Transform Tool</h3><p class="tool-desc">Transform text case: camelCase, snake_case, etc</p></a>
      <a class="tool-card" href="/nginx-config"><span class="tool-emoji">⚙️</span><h3 class="tool-name">Nginx Config Generator</h3><p class="tool-desc">Generate Nginx server blocks &amp; redirects</p></a>
      <a class="tool-card" href="/docker-compose"><span class="tool-emoji">🐳</span><h3 class="tool-name">Docker Compose Generator</h3><p class="tool-desc">Build docker-compose.yml files visually</p></a>
      <a class="tool-card" href="/readme-generator"><span class="tool-emoji">📖</span><h3 class="tool-name">README Generator</h3><p class="tool-desc">Generate professional README.md with preview</p></a>
      <a class="tool-card" href="/privacy-policy"><span class="tool-emoji">🔏</span><h3 class="tool-name">Privacy Policy Generator</h3><p class="tool-desc">GDPR/CCPA compliant privacy policy generator</p></a>
      <a class="tool-card" href="/terms-generator"><span class="tool-emoji">📜</span><h3 class="tool-name">Terms of Service Generator</h3><p class="tool-desc">Generate customizable Terms of Service</p></a>
      <a class="tool-card" href="/gitignore-generator"><span class="tool-emoji">🙈</span><h3 class="tool-name">Gitignore Generator</h3><p class="tool-desc">Generate .gitignore for any language/framework</p></a>
      <a class="tool-card" href="/license-picker"><span class="tool-emoji">⚖️</span><h3 class="tool-name">License Picker</h3><p class="tool-desc">Compare open source licenses &amp; generate LICENSE file</p></a>
      <a class="tool-card" href="/htaccess-generator"><span class="tool-emoji">⚙️</span><h3 class="tool-name">.htaccess Generator</h3><p class="tool-desc">Generate Apache .htaccess rules &amp; redirects</p></a>
      <a class="tool-card" href="/font-size-converter"><span class="tool-emoji">🔤</span><h3 class="tool-name">Font Size Converter</h3><p class="tool-desc">Convert px, rem, em, pt, vw units</p></a>
      <a class="tool-card" href="/tailwind-converter"><span class="tool-emoji">🎨</span><h3 class="tool-name">Tailwind CSS Converter</h3><p class="tool-desc">Convert vanilla CSS to Tailwind utility classes</p></a>
      <a class="tool-card" href="/cors-tester"><span class="tool-emoji">🌐</span><h3 class="tool-name">CORS Tester</h3><p class="tool-desc">Test CORS headers on any URL</p></a>
      <a class="tool-card" href="/chmod-recursive"><span class="tool-emoji">📂</span><h3 class="tool-name">Recursive chmod Generator</h3><p class="tool-desc">Generate recursive chmod commands for directories</p></a>
      <a class="tool-card" href="/svg-optimizer"><span class="tool-emoji">✨</span><h3 class="tool-name">SVG Optimizer</h3><p class="tool-desc">Optimize SVG files by removing metadata</p></a>
      <a class="tool-card" href="/image-to-base64"><span class="tool-emoji">🖼️</span><h3 class="tool-name">Image to Base64</h3><p class="tool-desc">Convert images to Base64 data URIs</p></a>
      <a class="tool-card" href="/aspect-ratio-calc"><span class="tool-emoji">📐</span><h3 class="tool-name">Aspect Ratio Calculator</h3><p class="tool-desc">Calculate image/video aspect ratios</p></a>
      <a class="tool-card" href="/em-calculator"><span class="tool-emoji">🔢</span><h3 class="tool-name">Em Calculator</h3><p class="tool-desc">Convert em, rem, px with custom base sizes</p></a>
      <a class="tool-card" href="/og-image-preview"><span class="tool-emoji">🖼️</span><h3 class="tool-name">OG Image Preview</h3><p class="tool-desc">Preview Open Graph images for social sharing</p></a>
      <a class="tool-card" href="/core-web-vitals-checker"><span class="tool-emoji">📈</span><h3 class="tool-name">Core Web Vitals Checker</h3><p class="tool-desc">Analyze how code affects LCP, INP, and CLS</p></a>
      <a class="tool-card" href="/javascript-bundle-analyzer"><span class="tool-emoji">📦</span><h3 class="tool-name">JS Bundle Analyzer</h3><p class="tool-desc">Compare bundle size to industry benchmarks</p></a>
      <a class="tool-card" href="/performance-budget-calculator"><span class="tool-emoji">🧮</span><h3 class="tool-name">Performance Budget Calculator</h3><p class="tool-desc">Allocate weight across HTML, CSS, JS, images</p></a>
    </div>
  </div>

  <!-- Studies Section -->
  <div class="section-container">
    <div class="section-header">
      <span class="section-tag">🔬 RESEARCH</span>
      <h2 class="section-title">Original Studies</h2>
      <p class="section-sub">Real data nobody else has packaged. Crawled, measured, analyzed.</p>
      <a href="/studies/" class="view-all">View all 6 studies →</a>
    </div>
    <div class="studies-grid">
      <a class="study-card" href="/javascript-frameworks-2026">
        <span class="study-emoji">🌐</span>
        <div class="study-stat">
          <span class="stat-number">9</span>
          <span class="stat-label">Frameworks Compared</span>
        </div>
        <h3 class="study-name">The Complete JavaScript Framework Landscape 2026</h3>
        <p class="study-desc">A massive 2000+ word analysis of React, Vue, Svelte, Angular, Solid, Astro, Next.js, and Nuxt. The definitive guide to choosing your stack.</p>
      </a>
      <a class="study-card" href="/api-response-times">
        <span class="study-emoji">📊</span>
        <div class="study-stat">
          <span class="stat-number">18ms</span>
          <span class="stat-label">Fastest API Avg</span>
        </div>
        <h3 class="study-name">API Response Time Benchmark 2026</h3>
        <p class="study-desc">We measured the response times of 30 popular public APIs. Hacker News was the fastest at 18ms, while the overall average was 172ms.</p>
      </a>
      <a class="study-card" href="/hosting-pricing">
        <span class="study-emoji">🔬</span>
        <div class="study-stat">
          <span class="stat-number">10</span>
          <span class="stat-label">Platforms Analyzed</span>
        </div>
        <h3 class="study-name">Cloud Hosting Price Comparison 2026: AWS vs Vercel vs Netlify vs Cloudflare</h3>
        <p class="study-desc">We analyzed the pricing models of major cloud hosting platforms for static sites and serverless. Cloudflare leads in free bandwidth while Render excels in paid tier value.</p>
      </a>
      <a class="study-card" href="/security-headers-study">
        <span class="study-emoji">🔒</span>
        <div class="study-stat">
          <span class="stat-number">Only 13%</span>
          <span class="stat-label">score an A grade</span>
        </div>
        <h3 class="study-name">HTTP Security Headers Study 2026</h3>
        <p class="study-desc">85 top websites analyzed for 10 critical HTTP security headers</p>
      </a>
      <a class="study-card" href="/css-framework-sizes">
        <span class="study-emoji">🎨</span>
        <div class="study-stat">
          <span class="stat-number">30</span>
          <span class="stat-label">frameworks compared</span>
        </div>
        <h3 class="study-name">CSS Framework File Size Comparison</h3>
        <p class="study-desc">30 frameworks measured — Bootstrap to Bulma file size analysis</p>
      </a>
      <a class="study-card" href="/page-weight-study">
        <span class="study-emoji">⚖️</span>
        <div class="study-stat">
          <span class="stat-number">2.2 MB</span>
          <span class="stat-label">average page weight</span>
        </div>
        <h3 class="study-name">Web Page Weight Study 2026</h3>
        <p class="study-desc">Full resource breakdown of 100 top websites</p>
      </a>
      <a class="study-card" href="/js-framework-sizes">
        <span class="study-emoji">📦</span>
        <div class="study-stat">
          <span class="stat-number">7.42KB</span>
          <span class="stat-label">Smallest Core</span>
        </div>
        <h3 class="study-name">JavaScript Framework Bundle Size Comparison 2026</h3>
        <p class="study-desc">Analyzed 8 modern JavaScript frameworks. Compared minified sizes, GitHub stars, and npm downloads.</p>
      </a>
      <a class="study-card" href="/framework-performance-benchmark">
        <span class="study-emoji">⚡</span>
        <div class="study-stat">
          <span class="stat-number">5</span>
          <span class="stat-label">Metrics Analyzed</span>
        </div>
        <h3 class="study-name">Framework Performance Benchmark 2026</h3>
        <p class="study-desc">Compare bundle size, memory usage, DOM manipulation speed, and Lighthouse scores across the top frameworks.</p>
      </a>
    </div>
  </div>

  <!-- Guides Section -->
  <div class="section-container">
    <div class="section-header">
      <span class="section-tag">📚 GUIDES</span>
      <h2 class="section-title">Developer Guides</h2>
      <p class="section-sub">Cheat sheets and references for common dev tasks.</p>
      <a href="/guides/" class="view-all">View all 12 guides →</a>
    </div>
    <div class="guides-grid">
      <a class="guide-card" href="/website-launch-checklist"><span class="guide-emoji">🚀</span><h3 class="guide-name">Website Launch Checklist</h3><p class="guide-desc">40-step pre-launch checklist covering SEO, performance, security, and more</p></a>
      <a class="guide-card" href="/seo-checklist"><span class="guide-emoji">🔍</span><h3 class="guide-name">SEO Launch Checklist</h3><p class="guide-desc">Meta tags, sitemaps, structured data, and canonicals</p></a>
      <a class="guide-card" href="/performance-checklist"><span class="guide-emoji">⚡</span><h3 class="guide-name">Performance Checklist</h3><p class="guide-desc">Crushing Core Web Vitals, image optimization, and caching</p></a>
      <a class="guide-card" href="/security-checklist"><span class="guide-emoji">🔒</span><h3 class="guide-name">Web Security Checklist</h3><p class="guide-desc">HTTPS enforcement, CSP configuration, and XSS prevention</p></a>
      <a class="guide-card" href="/accessibility-checklist"><span class="guide-emoji">♿</span><h3 class="guide-name">Accessibility Checklist</h3><p class="guide-desc">WCAG 2.1 AA compliance, screen readers, and keyboard navigation</p></a>
      <a class="guide-card" href="/analytics-setup-guide"><span class="guide-emoji">📊</span><h3 class="guide-name">Analytics Setup Guide</h3><p class="guide-desc">Google Analytics 4, Search Console, and custom event tracking</p></a>
      <a class="guide-card" href="/legal-compliance-guide"><span class="guide-emoji">⚖️</span><h3 class="guide-name">Legal Compliance Guide</h3><p class="guide-desc">Privacy Policies, Terms of Service, GDPR, and CCPA requirements</p></a>
      <a class="guide-card" href="/cross-browser-testing-guide"><span class="guide-emoji">📱</span><h3 class="guide-name">Cross-Browser Testing</h3><p class="guide-desc">Ensuring consistent layouts across Chrome, Safari, Firefox, and mobile</p></a>
      <a class="guide-card" href="/monitoring-setup-guide"><span class="guide-emoji">📡</span><h3 class="guide-name">Monitoring Setup Guide</h3><p class="guide-desc">Uptime alerts, frontend error tracking, APM, and server log management</p></a>
      <a class="guide-card" href="/react-vs-vue"><span class="guide-emoji">⚔️</span><h3 class="guide-name">React vs Vue in 2026</h3><p class="guide-desc">Syntax, reactivity, ecosystem maturity, and job market demand</p></a>
