  category: "tool",
  published: "2026-03-15"
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "5 Minute Timer",
    "url": "https://siliconbased.dev/timer-5-minutes",
    "applicationCategory": "Utility",
    "operatingSystem": "All"
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
