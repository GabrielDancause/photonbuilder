        }
      },
      {
        "@type": "Question",
        "name": "Does the timer continue to run if I switch tabs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, our background interval logic calculates the remaining time based on the exact start timestamp, ensuring absolute accuracy even when the tab is inactive."
        }
      },
      {
        "@type": "Question",
        "name": "Is there an alarm when the 5 minutes are up?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "When the time expires, the timer provides a visual alert by changing color and blinking, making it ideal for quiet office or study environments."
        }
      },
      {
        "@type": "Question",
        "name": "Does this 5 minute timer work on mobile?",
        "acceptedAnswer": {
