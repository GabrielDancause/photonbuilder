    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I use the 5 minute timer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Click the 'Start' button to begin the 5-minute countdown. You can pause the timer if needed, or click 'Reset' to return the clock to exactly 5 minutes."
        }
      },
      {
        "@type": "Question",
        "name": "What are common uses for a 5 minute timer?",
