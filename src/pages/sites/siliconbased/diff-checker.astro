---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Text Diff Checker",
  "url": "https://siliconbased.dev/diff-checker",
  "description": "Compare two texts side by side. Free online tool to find line and character-level differences instantly.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "GAB Ventures",
    "url": "https://gab.ae"
  }
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Text Diff Checker</h1>
  <p>Compare two texts to find line and character-level differences instantly.</p>
</div>

<div class="main">

  <div class="tool-card">
    <div class="tool-header">
      <h3>Compare Texts</h3>
      <div class="options-group">
        <label class="option-label" title="Ignore leading and trailing whitespace">
          <input type="checkbox" id="trimOpt"> Trim whitespace
        </label>
        <label class="option-label" title="Ignore case differences">
          <input type="checkbox" id="caseOpt"> Ignore case
        </label>
      </div>
    </div>

    <div class="tool-body">
      <div class="split-pane">
        <div class="pane">
          <div class="textarea-wrapper">
            <div class="textarea-label">
              <span>Original Text</span>
              <span class="char-count" id="originalCount">0 chars</span>
            </div>
            <textarea class="input-area" id="originalText" placeholder="Paste the original text here..." spellcheck="false"></textarea>
          </div>
        </div>

        <div class="pane">
          <div class="textarea-wrapper">
            <div class="textarea-label">
              <span>Modified Text</span>
              <span class="char-count" id="modifiedCount">0 chars</span>
            </div>
            <textarea class="input-area" id="modifiedText" placeholder="Paste the modified text here..." spellcheck="false"></textarea>
          </div>
        </div>
      </div>

      <div class="actions-row">
        <button class="btn btn-primary" id="compareBtn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
          Compare Texts
        </button>
        <button class="btn" id="swapBtn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2.1l4 4-4 4"/><path d="M3 12.2v-2a4 4 0 0 1 4-4h14"/><path d="M7 21.9l-4-4 4-4"/><path d="M21 11.8v2a4 4 0 0 1-4 4H3"/></svg>
          Swap
        </button>
        <button class="btn" id="clearBtn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
          Clear
        </button>
      </div>
    </div>
  </div>

  <div class="diff-output-card" id="outputCard" style="display: none;">
    <div class="tool-header">
      <h3>Diff Result</h3>
    </div>
    <div class="diff-output" id="diffOutput">
      <!-- Output gets generated here -->
    </div>
  </div>

  <div class="seo-content">
    <h2>What is a Text Diff Checker?</h2>
    <p>A text diff (difference) checker is a utility that compares two pieces of text and highlights the exact changes made between them. Whether you're comparing code, reviewing an edited document, or trying to find a tiny typo in a configuration file, a diff tool highlights exactly what was added, removed, or modified.</p>
    <p>This tool performs a line-by-line comparison and further breaks down modified lines to show character-level differences, making it incredibly easy to spot subtle changes.</p>

    <h2>How does it work?</h2>
    <p>Our Diff Checker uses an advanced algorithm derived from the classic Longest Common Subsequence (LCS) approach. When you click "Compare", the tool:</p>
    <ul>
      <li>Splits both the original and modified texts into individual lines.</li>
      <li>Identifies lines that have been added (green) or removed (red).</li>
      <li>For lines that share similarities but are not exact matches, it runs a secondary character-level comparison to highlight exactly which letters or words changed.</li>
    </ul>

    <h2>Features of this Tool</h2>
    <ul>
      <li><strong>Side-by-Side View:</strong> Displays the original text on the left and the modified text on the right (stacked on mobile).</li>
      <li><strong>Character-Level Diffing:</strong> Highlights the exact words or characters that changed within a modified line, not just the whole line.</li>
      <li><strong>Ignore Options:</strong> Toggle options to ignore leading/trailing whitespace and case sensitivity to focus only on meaningful structural changes.</li>
      <li><strong>Client-Side Processing:</strong> All diff computations run entirely in your web browser. No data is sent to a server, ensuring complete privacy and offline functionality.</li>
    </ul>
  </div>

</div>

    \`;
  }
  html += '</div>';

  // Right Side (Modified)
  html += '<div class="diff-split-half">';
  for (const row of alignedRows) {
    let rowClass = 'diff-line';
    if (row.type === 'added' || row.type === 'modified') rowClass += ' added';

    html += \`
      <div class="\${rowClass}">
        <div class="diff-line-number">\${row.modLineNum}</div>
        <div class="diff-line-content">\${row.modContent || (row.type === 'removed' ? ' ' : '')}</div>
      </div>
    \`;
  }
  html += '</div>';

  html += '</div>';

  diffOutput.innerHTML = html;
  outputCard.style.display = 'block';

  // Scroll to output
  outputCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
});

// Init
updateCounts();
</script>
</div>`
---

<SiteLayout
  site="siliconbased"
  title="Text Diff Checker | Compare Text Online"
  description="Compare two texts side by side. Free online tool to find line and character-level differences instantly. Works offline."
  canonical="https://siliconbased.dev/diff-checker"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #0a0b10; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 32px 24px 16px; background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%); }
.hero h1 { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Card */
.tool-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; margin-bottom: 40px; }
.tool-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; background: #13151d; border-bottom: 1px solid #1e2030; flex-wrap: wrap; gap: 12px; }
.tool-header h3 { font-size: 0.9rem; font-weight: 600; color: #ccc; display: flex; align-items: center; gap: 8px; }

/* Options */
.options-group { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
.option-label { display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: #888; cursor: pointer; user-select: none; }
.option-label input[type="checkbox"] { accent-color: #818cf8; width: 16px; height: 16px; cursor: pointer; }

/* Inputs/Outputs */
.tool-body { padding: 24px; display: flex; flex-direction: column; gap: 20px; }
.split-pane { display: flex; gap: 20px; flex-wrap: wrap; }
.pane { flex: 1; min-width: 280px; display: flex; flex-direction: column; gap: 8px; }
.textarea-wrapper { position: relative; display: flex; flex-direction: column; gap: 8px; flex: 1; }
.textarea-label { font-size: 0.85rem; font-weight: 600; color: #818cf8; display: flex; justify-content: space-between; }
.char-count { color: #666; font-weight: 400; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; }

.input-area { width: 100%; min-height: 200px; height: 100%; background: #0a0b10; border: 1px solid #1e2030; border-radius: 12px; padding: 16px; color: #e0e0e0; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; resize: vertical; outline: none; transition: border-color 0.2s; line-height: 1.5; white-space: pre; overflow-wrap: normal; overflow-x: auto; }
.input-area:focus { border-color: #818cf8; }
.input-area::placeholder { color: #444; }

/* Actions */
.actions-row { display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap; padding: 10px 0; }
.btn { background: #1e2030; border: 1px solid #2a2d40; color: #ccc; padding: 10px 20px; border-radius: 10px; font-size: 0.9rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; display: flex; align-items: center; gap: 8px; }
.btn:hover { background: #2a2d40; color: #fff; }
.btn-primary { background: #818cf8; color: #fff; border-color: #818cf8; }
.btn-primary:hover { background: #6366f1; border-color: #6366f1; }
.btn.copied { background: #1a3a1a; color: #4ade80; border-color: #2d5a2d; }

/* Diff Output */
.diff-output-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; margin-bottom: 40px; }
.diff-output { display: flex; flex-direction: column; background: #0a0b10; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; line-height: 1.5; overflow-x: auto; min-height: 100px; }

.diff-split { display: flex; width: 100%; min-width: max-content; }
.diff-split-half { flex: 1; min-width: 50%; border-right: 1px solid #1e2030; }
.diff-split-half:last-child { border-right: none; }

.diff-line { display: flex; padding: 0 8px; width: 100%; box-sizing: border-box; }
.diff-line-number { user-select: none; color: #555; text-align: right; padding-right: 12px; min-width: 40px; font-size: 0.85rem; }
.diff-line-content { white-space: pre-wrap; word-break: break-all; flex: 1; }

.diff-line.added { background-color: rgba(46, 160, 67, 0.15); }
.diff-line.removed { background-color: rgba(248, 81, 73, 0.15); }
.diff-line.added .diff-line-number { color: #3fb950; }
.diff-line.removed .diff-line-number { color: #ff7b72; }

.char-added { background-color: rgba(46, 160, 67, 0.4); border-radius: 2px; }
.char-removed { background-color: rgba(248, 81, 73, 0.4); border-radius: 2px; }

/* SEO Content */
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }

/* Footer */
.footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #555; border-top: 1px solid #151520; margin-top: auto; }
.footer a { color: #818cf8; text-decoration: none; }
.footer a:hover { text-decoration: underline; }

/* Responsive */
@media (max-width: 768px) {
  .actions-row { flex-direction: column; align-items: stretch; }
  .btn { justify-content: center; }
  .tool-header { flex-direction: column; align-items: flex-start; }
  .options-group { width: 100%; justify-content: flex-start; }
  .split-pane { flex-direction: column; }
  .diff-split { flex-direction: column; min-width: auto; }
  .diff-split-half { min-width: 100%; border-right: none; border-bottom: 1px solid #1e2030; }
  .diff-split-half:last-child { border-bottom: none; }
}

</style>
</SiteLayout>
