---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Diff Checker — Compare Text & Find Differences Online",
      "url": "https://siliconbased.dev/diff-checker",
      "description": "Free online diff checker and text compare tool. Paste two text blocks to instantly see differences highlighted — line-by-line or word-level. Split and unified views, ignore whitespace or case, copy diff output.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a diff checker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A diff checker compares two blocks of text and highlights the differences between them. Added lines are shown in green, removed lines in red, and modified lines in yellow with word-level highlighting. It is essential for code review, document comparison, and tracking changes between file versions."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between split view and unified view?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Split view shows the original and modified text side by side with line numbers, making it easy to compare corresponding lines. Unified view combines both texts into a single column with removed lines prefixed by '-' and added lines prefixed by '+', similar to git diff output. Split view is ideal for wide screens, while unified view works well on narrower screens."
          }
        },
        {
          "@type": "Question",
          "name": "What does 'ignore whitespace' do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The ignore whitespace option treats lines as identical even if they differ only in spaces, tabs, or trailing whitespace. This is useful when comparing code that may have been reformatted or when indentation style differs between versions, letting you focus on meaningful content changes."
          }
        },
        {
          "@type": "Question",
          "name": "Is my data safe when using this diff tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All comparison happens entirely in your browser using JavaScript. No text is sent to any server. Your data never leaves your device, making it safe to compare sensitive code, configuration files, and private documents."
          }
        },
        {
          "@type": "Question",
          "name": "Can I compare code files with this tool?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely. This diff checker works with any plain text including source code in any programming language, configuration files, JSON, XML, Markdown, and more. It provides line numbers and word-level highlighting within modified lines to pinpoint exact changes."
          }
        }
      ]
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Diff Checker</h1>
  <p>Compare two text blocks side by side and see every difference highlighted instantly. All processing happens in your browser.</p>
</div>

<div class="main">

  <!-- Options Bar -->
  <div class="options-bar">
    <div class="options-left">
      <button class="action-btn active" id="splitViewBtn">Split View</button>
      <button class="action-btn" id="unifiedViewBtn">Unified View</button>
    </div>
    <div class="options-right">
      <label class="option-label"><input type="checkbox" id="ignoreWhitespace"> Ignore Whitespace</label>
      <label class="option-label"><input type="checkbox" id="ignoreCase"> Ignore Case</label>
      <button class="action-btn" id="swapBtn">\u21C4 Swap</button>
    </div>
  </div>

  <!-- Input Section -->
  <div class="input-grid">
    <div class="input-panel">
      <div class="input-header">
        <div class="header-title">Original</div>
        <div class="header-actions">
          <button class="action-btn" id="sampleBtn">Sample</button>
          <button class="action-btn" id="clearLeftBtn">Clear</button>
        </div>
      </div>
      <textarea id="leftInput" class="text-input" spellcheck="false" placeholder="Paste original text here..."></textarea>
    </div>
    <div class="input-panel">
      <div class="input-header">
        <div class="header-title">Modified</div>
        <div class="header-actions">
          <button class="action-btn" id="clearRightBtn">Clear</button>
        </div>
      </div>
      <textarea id="rightInput" class="text-input" spellcheck="false" placeholder="Paste modified text here..."></textarea>
    </div>
  </div>

  <!-- Compare Button -->
  <div class="compare-row">
    <button class="compare-btn" id="compareBtn">Compare</button>
    <span class="hint">Ctrl+Enter to compare</span>
  </div>

  <!-- Stats Bar -->
  <div class="stats-bar" id="statsBar" style="display:none;">
    <div class="stat"><span class="stat-label">Added</span><span class="stat-value stat-added" id="statAdded">0</span></div>
    <div class="stat"><span class="stat-label">Removed</span><span class="stat-value stat-removed" id="statRemoved">0</span></div>
    <div class="stat"><span class="stat-label">Modified</span><span class="stat-value stat-modified" id="statModified">0</span></div>
    <div class="stat"><span class="stat-label">Unchanged</span><span class="stat-value" id="statUnchanged">0</span></div>
  </div>

  <!-- Action Bar -->
  <div class="action-bar" id="actionBar" style="display:none;">
    <div style="flex:1;"></div>
    <button class="action-btn" id="copyDiffBtn">Copy Diff</button>
  </div>

  <!-- Output Section -->
  <div class="output-section" id="outputSection" style="display:none;">
    <div class="diff-split" id="diffSplit">
      <div class="diff-pane" id="diffLeft"></div>
      <div class="diff-pane" id="diffRight"></div>
    </div>
    <div class="diff-unified" id="diffUnified" style="display:none;"></div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a Diff Checker?</h2>
    <p>A diff checker (also called a text compare tool) compares two blocks of text and visually highlights the differences. It identifies lines that have been <strong>added</strong>, <strong>removed</strong>, or <strong>modified</strong> between the two versions. Diff checking is fundamental to software development, document editing, and any workflow that involves tracking changes over time.</p>

    <h2>How Does Text Comparison Work?</h2>
    <p>This tool uses the <strong>longest common subsequence (LCS)</strong> algorithm to find the optimal alignment between two texts. It compares the input line by line, identifies matching and differing lines, and then performs word-level comparison within modified lines to pinpoint the exact changes. The result is a clear, color-coded view of every difference.</p>

    <h2>Split View vs Unified View</h2>
    <p><strong>Split view</strong> displays the original and modified text side by side, with corresponding lines aligned and line numbers shown. This is ideal for wide screens and makes it easy to see how specific lines changed. <strong>Unified view</strong> combines both texts into a single column, with removed lines prefixed by <code>-</code> and added lines prefixed by <code>+</code>. Unified view is the format used by <code>git diff</code> and works well on narrower screens.</p>

    <h2>Comparison Options</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Option</th>
          <th>What It Does</th>
          <th>When to Use</th>
        </tr>
      </thead>
      <tbody>
        <tr><td><strong>Ignore Whitespace</strong></td><td>Treats lines as equal if they differ only in spaces or tabs</td><td>Comparing reformatted code or varying indentation styles</td></tr>
        <tr><td><strong>Ignore Case</strong></td><td>Treats uppercase and lowercase letters as identical</td><td>Comparing case-insensitive data like SQL or HTML tags</td></tr>
        <tr><td><strong>Swap Sides</strong></td><td>Exchanges the original and modified inputs</td><td>Quickly reversing the comparison direction</td></tr>
        <tr><td><strong>Inline Diff</strong></td><td>Highlights word-level changes within modified lines</td><td>Pinpointing exact edits within long lines</td></tr>
      </tbody>
    </table>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a diff checker?</h3>
      <p style="margin-bottom: 16px;">A diff checker compares two blocks of text and highlights the differences between them. Added lines are shown in green, removed lines in red, and modified lines in yellow with word-level highlighting. It is essential for code review, document comparison, and tracking changes between file versions.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between split view and unified view?</h3>
      <p style="margin-bottom: 16px;">Split view shows the original and modified text side by side with line numbers, making it easy to compare corresponding lines. Unified view combines both texts into a single column with removed lines prefixed by '-' and added lines prefixed by '+', similar to git diff output. Split view is ideal for wide screens, while unified view works well on narrower screens.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does 'ignore whitespace' do?</h3>
      <p style="margin-bottom: 16px;">The ignore whitespace option treats lines as identical even if they differ only in spaces, tabs, or trailing whitespace. This is useful when comparing code that may have been reformatted or when indentation style differs between versions, letting you focus on meaningful content changes.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is my data safe when using this diff tool?</h3>
      <p style="margin-bottom: 16px;">Yes. All comparison happens entirely in your browser using JavaScript. No text is sent to any server. Your data never leaves your device, making it safe to compare sensitive code, configuration files, and private documents.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I compare code files with this tool?</h3>
      <p style="margin-bottom: 16px;">Absolutely. This diff checker works with any plain text including source code in any programming language, configuration files, JSON, XML, Markdown, and more. It provides line numbers and word-level highlighting within modified lines to pinpoint exact changes.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/json-formatter">JSON Formatter</a> — Format, validate, and minify JSON online.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions with real-time highlighting.</li>
      <li><a href="#">Base64 Encoder/Decoder</a> — Encode and decode Base64 strings online.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "Diff Checker — Compare Text & Find Differences Online",
  description: "Free online diff checker and text compare tool. Paste two text blocks to instantly see differences highlighted line-by-line or word-level. Split and unified views, ignore whitespace or case. No data leaves your browser.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="Diff Checker — Compare Text & Find Differences Online"
  description="Free online diff checker and text compare tool. Paste two text blocks to instantly see differences highlighted line-by-line or word-level. Split and unified views, ignore whitespace or case. No data leaves your browser."
  canonical="https://siliconbased.dev/diff-checker"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
var leftInput = document.getElementById('leftInput');
var rightInput = document.getElementById('rightInput');
var splitViewBtn = document.getElementById('splitViewBtn');
var unifiedViewBtn = document.getElementById('unifiedViewBtn');
var ignoreWhitespace = document.getElementById('ignoreWhitespace');
var ignoreCase = document.getElementById('ignoreCase');
var swapBtn = document.getElementById('swapBtn');
var sampleBtn = document.getElementById('sampleBtn');
var clearLeftBtn = document.getElementById('clearLeftBtn');
var clearRightBtn = document.getElementById('clearRightBtn');
var compareBtn = document.getElementById('compareBtn');
var statsBar = document.getElementById('statsBar');
var statAdded = document.getElementById('statAdded');
var statRemoved = document.getElementById('statRemoved');
var statModified = document.getElementById('statModified');
var statUnchanged = document.getElementById('statUnchanged');
var actionBar = document.getElementById('actionBar');
var copyDiffBtn = document.getElementById('copyDiffBtn');
var outputSection = document.getElementById('outputSection');
var diffSplit = document.getElementById('diffSplit');
var diffUnified = document.getElementById('diffUnified');
var diffLeft = document.getElementById('diffLeft');
var diffRight = document.getElementById('diffRight');

var viewMode = 'split';
var lastDiff = null;

function escapeHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function normalizeLine(line) {
  var result = line;
  if (ignoreWhitespace.checked) result = result.replace(/\s+/g, ' ').trim();
  if (ignoreCase.checked) result = result.toLowerCase();
  return result;
}

// LCS-based diff algorithm
function computeDiff(aLines, bLines) {
  var m = aLines.length;
  var n = bLines.length;
  var dp = [];
  for (var i = 0; i <= m; i++) {
    dp[i] = [];
    for (var j = 0; j <= n; j++) dp[i][j] = 0;
  }
  for (var i = 1; i <= m; i++) {
    for (var j = 1; j <= n; j++) {
      if (normalizeLine(aLines[i - 1]) === normalizeLine(bLines[j - 1])) {
        dp[i][j] = dp[i - 1][j - 1] + 1;
      } else {
        dp[i][j] = Math.max(dp[i - 1][j], dp[i][j - 1]);
      }
    }
  }

  var ops = [];
  var i = m, j = n;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && normalizeLine(aLines[i - 1]) === normalizeLine(bLines[j - 1])) {
      ops.unshift({ type: 'equal', left: aLines[i - 1], right: bLines[j - 1], leftNum: i, rightNum: j });
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {
      ops.unshift({ type: 'add', right: bLines[j - 1], rightNum: j });
      j--;
    } else {
      ops.unshift({ type: 'remove', left: aLines[i - 1], leftNum: i });
      i--;
    }
  }

  // Merge adjacent remove+add into modify
  var merged = [];
  var idx = 0;
  while (idx < ops.length) {
    if (idx < ops.length - 1 && ops[idx].type === 'remove' && ops[idx + 1].type === 'add') {
      merged.push({ type: 'modify', left: ops[idx].left, right: ops[idx + 1].right, leftNum: ops[idx].leftNum, rightNum: ops[idx + 1].rightNum });
      idx += 2;
    } else {
      merged.push(ops[idx]);
      idx++;
    }
  }
  return merged;
}

// Word-level inline diff for modified lines
function inlineDiff(oldLine, newLine) {
  var oldWords = oldLine.split(/(\s+)/);
  var newWords = newLine.split(/(\s+)/);
  var om = oldWords.length, nm = newWords.length;
  var dp = [];
  for (var i = 0; i <= om; i++) {
    dp[i] = [];
    for (var j = 0; j <= nm; j++) dp[i][j] = 0;
  }
  for (var i = 1; i <= om; i++) {
    for (var j = 1; j <= nm; j++) {
      if (oldWords[i - 1] === newWords[j - 1]) dp[i][j] = dp[i - 1][j - 1] + 1;
      else dp[i][j] = Math.max(dp[i - 1][j], dp[i][j - 1]);
    }
  }

  var oldParts = [], newParts = [];
  var i = om, j = nm;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && oldWords[i - 1] === newWords[j - 1]) {
      oldParts.unshift({ text: escapeHtml(oldWords[i - 1]), type: 'equal' });
      newParts.unshift({ text: escapeHtml(newWords[j - 1]), type: 'equal' });
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {
      newParts.unshift({ text: escapeHtml(newWords[j - 1]), type: 'added' });
      j--;
    } else {
      oldParts.unshift({ text: escapeHtml(oldWords[i - 1]), type: 'removed' });
      i--;
    }
  }

  var oldHtml = '', newHtml = '';
  for (var k = 0; k < oldParts.length; k++) {
    if (oldParts[k].type === 'removed') oldHtml += '<span class="word-removed">' + oldParts[k].text + '</span>';
    else oldHtml += oldParts[k].text;
  }
  for (var k = 0; k < newParts.length; k++) {
    if (newParts[k].type === 'added') newHtml += '<span class="word-added">' + newParts[k].text + '</span>';
    else newHtml += newParts[k].text;
  }
  return { oldHtml: oldHtml, newHtml: newHtml };
}

function renderDiff() {
  if (!lastDiff) return;
  if (viewMode === 'split') renderSplitView();
  else renderUnifiedView();
}

function renderSplitView() {
  diffSplit.style.display = 'grid';
  diffUnified.style.display = 'none';

  var leftHtml = '', rightHtml = '';
  for (var i = 0; i < lastDiff.length; i++) {
    var op = lastDiff[i];
    if (op.type === 'equal') {
      leftHtml += '<div class="diff-line diff-equal"><span class="line-num">' + op.leftNum + '</span><span class="line-text">' + escapeHtml(op.left) + '</span></div>';
      rightHtml += '<div class="diff-line diff-equal"><span class="line-num">' + op.rightNum + '</span><span class="line-text">' + escapeHtml(op.right) + '</span></div>';
    } else if (op.type === 'remove') {
      leftHtml += '<div class="diff-line diff-removed"><span class="line-num">' + op.leftNum + '</span><span class="line-text">' + escapeHtml(op.left) + '</span></div>';
      rightHtml += '<div class="diff-line diff-empty"><span class="line-num"></span><span class="line-text"></span></div>';
    } else if (op.type === 'add') {
      leftHtml += '<div class="diff-line diff-empty"><span class="line-num"></span><span class="line-text"></span></div>';
      rightHtml += '<div class="diff-line diff-added"><span class="line-num">' + op.rightNum + '</span><span class="line-text">' + escapeHtml(op.right) + '</span></div>';
    } else if (op.type === 'modify') {
      var inline = inlineDiff(op.left, op.right);
      leftHtml += '<div class="diff-line diff-modified"><span class="line-num">' + op.leftNum + '</span><span class="line-text">' + inline.oldHtml + '</span></div>';
      rightHtml += '<div class="diff-line diff-modified"><span class="line-num">' + op.rightNum + '</span><span class="line-text">' + inline.newHtml + '</span></div>';
    }
  }
  diffLeft.innerHTML = leftHtml;
  diffRight.innerHTML = rightHtml;

  // Sync scroll
  diffLeft.onscroll = function() { diffRight.scrollTop = diffLeft.scrollTop; diffRight.scrollLeft = diffLeft.scrollLeft; };
  diffRight.onscroll = function() { diffLeft.scrollTop = diffRight.scrollTop; diffLeft.scrollLeft = diffRight.scrollLeft; };
}

function renderUnifiedView() {
  diffSplit.style.display = 'none';
  diffUnified.style.display = 'block';

  var html = '';
  for (var i = 0; i < lastDiff.length; i++) {
    var op = lastDiff[i];
    if (op.type === 'equal') {
      html += '<div class="diff-line diff-equal"><span class="line-num">' + op.leftNum + '</span><span class="line-num">' + op.rightNum + '</span><span class="line-prefix"> </span><span class="line-text">' + escapeHtml(op.left) + '</span></div>';
    } else if (op.type === 'remove') {
      html += '<div class="diff-line diff-removed"><span class="line-num">' + op.leftNum + '</span><span class="line-num"></span><span class="line-prefix">-</span><span class="line-text">' + escapeHtml(op.left) + '</span></div>';
    } else if (op.type === 'add') {
      html += '<div class="diff-line diff-added"><span class="line-num"></span><span class="line-num">' + op.rightNum + '</span><span class="line-prefix">+</span><span class="line-text">' + escapeHtml(op.right) + '</span></div>';
    } else if (op.type === 'modify') {
      var inline = inlineDiff(op.left, op.right);
      html += '<div class="diff-line diff-removed"><span class="line-num">' + op.leftNum + '</span><span class="line-num"></span><span class="line-prefix">-</span><span class="line-text">' + inline.oldHtml + '</span></div>';
      html += '<div class="diff-line diff-added"><span class="line-num"></span><span class="line-num">' + op.rightNum + '</span><span class="line-prefix">+</span><span class="line-text">' + inline.newHtml + '</span></div>';
    }
  }
  diffUnified.innerHTML = html;
}

function runCompare() {
  var leftText = leftInput.value;
  var rightText = rightInput.value;

  if (!leftText && !rightText) {
    statsBar.style.display = 'none';
    actionBar.style.display = 'none';
    outputSection.style.display = 'none';
    return;
  }

  var aLines = leftText.split('\n');
  var bLines = rightText.split('\n');
  lastDiff = computeDiff(aLines, bLines);

  var added = 0, removed = 0, modified = 0, unchanged = 0;
  for (var i = 0; i < lastDiff.length; i++) {
    switch (lastDiff[i].type) {
      case 'add': added++; break;
      case 'remove': removed++; break;
      case 'modify': modified++; break;
      case 'equal': unchanged++; break;
    }
  }

  statAdded.textContent = added;
  statRemoved.textContent = removed;
  statModified.textContent = modified;
  statUnchanged.textContent = unchanged;

  statsBar.style.display = 'flex';
  actionBar.style.display = 'flex';
  outputSection.style.display = 'block';
  renderDiff();
}

function generateDiffText() {
  if (!lastDiff) return '';
  var lines = [];
  for (var i = 0; i < lastDiff.length; i++) {
    var op = lastDiff[i];
    if (op.type === 'equal') lines.push('  ' + op.left);
    else if (op.type === 'remove') lines.push('- ' + op.left);
    else if (op.type === 'add') lines.push('+ ' + op.right);
    else if (op.type === 'modify') {
      lines.push('- ' + op.left);
      lines.push('+ ' + op.right);
    }
  }
  return lines.join('\n');
}

function init() {
  compareBtn.addEventListener('click', runCompare);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
      e.preventDefault();
      runCompare();
    }
  });

  splitViewBtn.addEventListener('click', function() {
    viewMode = 'split';
    splitViewBtn.classList.add('active');
    unifiedViewBtn.classList.remove('active');
    renderDiff();
  });

  unifiedViewBtn.addEventListener('click', function() {
    viewMode = 'unified';
    unifiedViewBtn.classList.add('active');
    splitViewBtn.classList.remove('active');
    renderDiff();
  });

  ignoreWhitespace.addEventListener('change', function() { if (lastDiff) runCompare(); });
  ignoreCase.addEventListener('change', function() { if (lastDiff) runCompare(); });

  swapBtn.addEventListener('click', function() {
    var tmp = leftInput.value;
    leftInput.value = rightInput.value;
    rightInput.value = tmp;
    if (lastDiff) runCompare();
  });

  sampleBtn.addEventListener('click', function() {
    leftInput.value = 'function greet(name) {\n  console.log("Hello, " + name);\n  return true;\n}\n\nconst users = ["Alice", "Bob", "Charlie"];\n\nfor (let i = 0; i < users.length; i++) {\n  greet(users[i]);\n}\n\nconsole.log("Done!");';
    rightInput.value = 'function greet(name, greeting) {\n  console.log(greeting + ", " + name + "!");\n  return true;\n}\n\nconst users = ["Alice", "Bob", "Charlie", "Diana"];\n\nfor (const user of users) {\n  greet(user, "Hi");\n}\n\nconsole.log("All done!");';
    runCompare();
  });

  clearLeftBtn.addEventListener('click', function() {
    leftInput.value = '';
    leftInput.focus();
  });

  clearRightBtn.addEventListener('click', function() {
    rightInput.value = '';
    rightInput.focus();
  });

  copyDiffBtn.addEventListener('click', function() {
    var text = generateDiffText();
    navigator.clipboard.writeText(text).then(function() {
      copyDiffBtn.textContent = '\u2713 Copied';
      setTimeout(function() { copyDiffBtn.textContent = 'Copy Diff'; }, 1500);
    });
  });
}

init();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #0f1729 0%, #060a12 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Options Bar */
.options-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding: 14px 18px; background: var(--card-bg, #0a1020); border: 2px solid var(--border-color, #152040); border-radius: 12px; flex-wrap: wrap; gap: 12px; }
.options-left, .options-right { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.option-label { font-size: 0.78rem; color: #888; display: flex; align-items: center; gap: 6px; cursor: pointer; user-select: none; }
.option-label input[type="checkbox"] { accent-color: var(--accent-color, #818cf8); }

/* Action buttons */
.action-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 6px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.15s; }
.action-btn:hover { background: #2a2d40; color: #ccc; }
.action-btn.active { background: var(--accent-color, #818cf8); color: #fff; border-color: var(--accent-color, #818cf8); }

/* Input Grid */
.input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.input-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.header-title { font-size: 0.85rem; font-weight: 600; color: #ccc; text-transform: uppercase; letter-spacing: 0.5px; }
.header-actions { display: flex; gap: 8px; }

.text-input { width: 100%; min-height: 200px; background: var(--card-bg, #0a1020); border: 2px solid var(--border-color, #152040); border-radius: 12px; padding: 16px; color: #e0e0e0; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; line-height: 1.6; resize: vertical; outline: none; transition: border-color 0.2s; tab-size: 2; }
.text-input:focus { border-color: var(--accent-color, #818cf8); }
.text-input::placeholder { color: #555; }

/* Compare Row */
.compare-row { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
.compare-btn { background: var(--accent-color, #818cf8); color: #fff; border: none; padding: 10px 32px; border-radius: 10px; font-size: 0.9rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.15s; }
.compare-btn:hover { opacity: 0.9; transform: translateY(-1px); }
.hint { font-size: 0.72rem; color: var(--text-secondary, #555); }

/* Stats Bar */
.stats-bar { display: flex; gap: 16px; flex-wrap: wrap; padding: 14px 18px; background: var(--card-bg, #0a1020); border: 1px solid var(--border-color, #152040); border-radius: 12px; margin-bottom: 16px; }
.stat { display: flex; flex-direction: column; align-items: center; gap: 2px; min-width: 60px; }
.stat-label { font-size: 0.68rem; font-weight: 600; color: var(--text-secondary, #666); text-transform: uppercase; letter-spacing: 0.5px; }
.stat-value { font-size: 1rem; font-weight: 700; color: var(--accent-color, #818cf8); font-family: 'JetBrains Mono', monospace; }
.stat-added { color: #4ade80; }
.stat-removed { color: #f87171; }
.stat-modified { color: #fbbf24; }

/* Action Bar */
.action-bar { display: flex; gap: 8px; align-items: center; margin-bottom: 16px; flex-wrap: wrap; }

/* Output Section */
.output-section { margin-bottom: 40px; }

/* Split View */
.diff-split { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 2px solid var(--border-color, #152040); border-radius: 12px; overflow: hidden; }
.diff-pane { overflow: auto; max-height: 600px; background: var(--card-bg, #0a1020); }
.diff-pane:first-child { border-right: 1px solid var(--border-color, #152040); }

/* Unified View */
.diff-unified { background: var(--card-bg, #0a1020); border: 2px solid var(--border-color, #152040); border-radius: 12px; overflow: auto; max-height: 600px; }

/* Diff Lines */
.diff-line { display: flex; align-items: stretch; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; line-height: 1.7; min-height: 1.7em; }
.diff-line .line-num { min-width: 40px; padding: 0 8px; text-align: right; color: #555; user-select: none; flex-shrink: 0; background: rgba(255,255,255,0.02); }
.diff-line .line-prefix { min-width: 20px; padding: 0 4px; text-align: center; color: #888; user-select: none; flex-shrink: 0; font-weight: 700; }
.diff-line .line-text { padding: 0 12px; white-space: pre; flex: 1; }

/* Diff line types */
.diff-equal { background: transparent; }
.diff-added { background: rgba(74, 222, 128, 0.08); }
.diff-added .line-num { background: rgba(74, 222, 128, 0.12); color: #4ade80; }
.diff-added .line-prefix { color: #4ade80; }
.diff-removed { background: rgba(248, 113, 113, 0.08); }
.diff-removed .line-num { background: rgba(248, 113, 113, 0.12); color: #f87171; }
.diff-removed .line-prefix { color: #f87171; }
.diff-modified { background: rgba(251, 191, 36, 0.06); }
.diff-modified .line-num { background: rgba(251, 191, 36, 0.1); color: #fbbf24; }
.diff-empty { background: rgba(255,255,255,0.02); }
.diff-empty .line-num { background: rgba(255,255,255,0.02); }

/* Word-level highlights */
.word-added { background: rgba(74, 222, 128, 0.25); border-radius: 2px; padding: 0 1px; }
.word-removed { background: rgba(248, 113, 113, 0.25); border-radius: 2px; padding: 0 1px; }

/* SEO Content */
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }
.seo-content a { color: var(--accent-color, #818cf8); text-decoration: none; }
.seo-content a:hover { text-decoration: underline; }
.seo-content code { background: var(--card-bg, #0a1020); padding: 2px 6px; border-radius: 4px; color: var(--accent-color, #818cf8); font-size: 0.85em; }
.seo-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 0.9rem; }
.seo-table th { text-align: left; padding: 10px 14px; border-bottom: 2px solid #2a2d4e; color: #ccc; font-weight: 600; background: var(--card-bg, #0a1020); }
.seo-table td { padding: 10px 14px; border-bottom: 1px solid var(--border-color, #152040); color: #aaa; }
.seo-table tr:hover td { background: var(--card-bg, #0a1020); }

/* Responsive */
@media (max-width: 800px) {
  .input-grid { grid-template-columns: 1fr; }
  .diff-split { grid-template-columns: 1fr; }
  .diff-pane:first-child { border-right: none; border-bottom: 1px solid var(--border-color, #152040); }
  .stats-bar { gap: 12px; }
}
@media (max-width: 500px) {
  .hero h1 { font-size: 1.8rem; }
  .stats-bar { gap: 8px; }
  .stat { min-width: 50px; }
  .options-bar { flex-direction: column; align-items: flex-start; }
}

</style>
</SiteLayout>
