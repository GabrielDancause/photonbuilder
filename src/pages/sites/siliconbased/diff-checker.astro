---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Diff Checker — Compare Two Texts Online",
      "url": "https://siliconbased.dev/diff-checker",
      "description": "Free online diff checker to compare two texts side by side. Highlights additions, deletions, and changes with line-by-line or word-by-word diff modes. Runs in your browser.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a diff checker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A diff checker is an online tool that compares two blocks of text and highlights the differences between them. It shows additions (new text), deletions (removed text), and unchanged lines — making it easy to spot changes between two versions of a document, code file, or any text content."
          }
        },
        {
          "@type": "Question",
          "name": "How do I compare two texts online?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your original text in the left panel and the modified text in the right panel, then click the Compare button. The tool instantly highlights additions in green and deletions in red. You can switch between line-by-line and word-by-word diff modes for different levels of detail."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between line-by-line and word-by-word diff?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Line-by-line diff compares entire lines and marks whole lines as added, removed, or unchanged. Word-by-word diff goes deeper — it compares individual words within changed lines, highlighting exactly which words were added or removed. Word-by-word mode is better for spotting small edits within longer lines."
          }
        },
        {
          "@type": "Question",
          "name": "Can I ignore whitespace or case differences?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Enable the 'Ignore whitespace' option to skip differences caused by spaces, tabs, or trailing whitespace. Enable 'Ignore case' to treat uppercase and lowercase letters as identical. These options help you focus on meaningful content changes."
          }
        },
        {
          "@type": "Question",
          "name": "Is my data safe when using this diff checker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This diff checker runs entirely in your browser using JavaScript. No data is sent to any server. Your text content never leaves your device, making it completely safe for comparing sensitive code, documents, or proprietary content."
          }
        },
        {
          "@type": "Question",
          "name": "What is similarity percentage?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The similarity percentage shows how much of the original text remains unchanged. It is calculated as the ratio of unchanged lines to total lines. A 100% similarity means the texts are identical, while 0% means they share no common lines."
          }
        },
        {
          "@type": "Question",
          "name": "How does this compare to tools like DiffNow or Diffchecker.com?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This tool provides the same core text comparison as tools like DiffNow or Diffchecker.com, but runs entirely in the browser with no sign-up required. It includes line-by-line and word-by-word diff modes, ignore whitespace/case options, stats, and a clean side-by-side view — all without uploading your data."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Diff Checker — Compare Two Texts Online",
      "description": "Free online diff checker to compare two texts side by side with line-by-line and word-by-word diff modes.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Diff Checker</h1>
  <p>Compare two texts side by side and instantly see additions, deletions, and changes. Runs entirely in your browser.</p>
</div>

<div class="main">

  <!-- Options Bar -->
  <div class="options-bar">
    <div class="options-left">
      <label class="toggle-label">
        <input type="checkbox" id="ignoreWhitespace" />
        <span class="toggle-text">Ignore whitespace</span>
      </label>
      <label class="toggle-label">
        <input type="checkbox" id="ignoreCase" />
        <span class="toggle-text">Ignore case</span>
      </label>
    </div>
    <div class="options-right">
      <button class="mode-btn active" id="btnLineDiff">Line diff</button>
      <button class="mode-btn" id="btnWordDiff">Word diff</button>
      <button class="action-btn" id="swapBtn">⇄ Swap</button>
      <button class="action-btn primary" id="compareBtn">Compare</button>
    </div>
  </div>

  <!-- Two-panel layout -->
  <div class="tool-grid">
    <!-- Original -->
    <div class="pane">
      <div class="input-header">
        <div class="header-title">Original Text</div>
        <div class="header-actions">
          <button class="action-btn" id="sampleBtn">Sample</button>
          <button class="action-btn" id="clearBtn">Clear All</button>
        </div>
      </div>
      <textarea id="originalArea" class="code-area" spellcheck="false" placeholder="Paste original text here..."></textarea>
    </div>

    <!-- Modified -->
    <div class="pane">
      <div class="input-header">
        <div class="header-title">Modified Text</div>
        <div class="header-actions">
          <button class="action-btn" id="clearModifiedBtn">Clear</button>
        </div>
      </div>
      <textarea id="modifiedArea" class="code-area" spellcheck="false" placeholder="Paste modified text here..."></textarea>
    </div>
  </div>

  <!-- Stats -->
  <div id="statsBar" class="stats-bar" style="display:none;">
    <div class="stat"><span class="stat-num added" id="statAdded">0</span><span class="stat-label">Added</span></div>
    <div class="stat"><span class="stat-num removed" id="statRemoved">0</span><span class="stat-label">Removed</span></div>
    <div class="stat"><span class="stat-num unchanged" id="statUnchanged">0</span><span class="stat-label">Unchanged</span></div>
    <div class="stat"><span class="stat-num similarity" id="statSimilarity">0%</span><span class="stat-label">Similarity</span></div>
  </div>

  <!-- Diff Output -->
  <div id="diffOutput" class="diff-output" style="display:none;">
    <div class="output-header">
      <div class="header-title">Diff Result</div>
      <div class="header-actions">
        <button class="copy-btn" id="copyDiffBtn">Copy Diff</button>
      </div>
    </div>
    <div id="diffContent" class="diff-content"></div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a Diff Checker?</h2>
    <p>A diff checker (also called a text compare tool or diff tool) compares two blocks of text and highlights the differences between them. It is an essential tool for developers, writers, and anyone who needs to track changes between two versions of a document, configuration file, code snippet, or any text content. This online diff checker processes everything in your browser — no data is ever sent to a server.</p>

    <h2>How to Use This Text Compare Tool</h2>
    <ul>
      <li><strong>Paste your texts:</strong> Put the original text in the left panel and the modified text in the right panel.</li>
      <li><strong>Click Compare:</strong> The tool highlights additions (green), deletions (red), and unchanged lines (no highlight).</li>
      <li><strong>Switch diff modes:</strong> Use line-by-line diff for a high-level overview, or word-by-word diff to see exactly which words changed within each line.</li>
      <li><strong>Use options:</strong> Toggle "Ignore whitespace" to skip spacing differences, or "Ignore case" to treat upper and lowercase as identical.</li>
      <li><strong>Swap texts:</strong> Click the Swap button to reverse the original and modified panels.</li>
      <li><strong>Copy the diff:</strong> Use the Copy Diff button to copy the unified diff output to your clipboard.</li>
    </ul>

    <h2>Diff Modes Explained</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Mode</th>
          <th>Compares</th>
          <th>Best For</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Line-by-line</td><td>Entire lines</td><td>Spotting added, removed, or moved lines in code or config files</td></tr>
        <tr><td>Word-by-word</td><td>Individual words within lines</td><td>Finding small edits, typo fixes, or wording changes in prose</td></tr>
      </tbody>
    </table>

    <h2>Common Use Cases</h2>
    <ul>
      <li><strong>Code review:</strong> Compare two versions of a function or config file to see what changed.</li>
      <li><strong>Document editing:</strong> Track revisions between drafts of an article, contract, or email.</li>
      <li><strong>Configuration auditing:</strong> Diff server configs, .env files, or YAML/JSON to catch unintended changes.</li>
      <li><strong>Content QA:</strong> Verify that a copied or migrated text matches the original.</li>
      <li><strong>Learning:</strong> Understand what changed between two versions of any text.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a diff checker?</h3>
      <p style="margin-bottom: 16px;">A diff checker is an online tool that compares two blocks of text and highlights the differences between them. It shows additions (new text), deletions (removed text), and unchanged lines — making it easy to spot changes between two versions of a document, code file, or any text content.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I compare two texts online?</h3>
      <p style="margin-bottom: 16px;">Paste your original text in the left panel and the modified text in the right panel, then click the Compare button. The tool instantly highlights additions in green and deletions in red. You can switch between line-by-line and word-by-word diff modes for different levels of detail.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between line-by-line and word-by-word diff?</h3>
      <p style="margin-bottom: 16px;">Line-by-line diff compares entire lines and marks whole lines as added, removed, or unchanged. Word-by-word diff goes deeper — it compares individual words within changed lines, highlighting exactly which words were added or removed. Word-by-word mode is better for spotting small edits within longer lines.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I ignore whitespace or case differences?</h3>
      <p style="margin-bottom: 16px;">Yes. Enable the 'Ignore whitespace' option to skip differences caused by spaces, tabs, or trailing whitespace. Enable 'Ignore case' to treat uppercase and lowercase letters as identical. These options help you focus on meaningful content changes.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is my data safe when using this diff checker?</h3>
      <p style="margin-bottom: 16px;">This diff checker runs entirely in your browser using JavaScript. No data is sent to any server. Your text content never leaves your device, making it completely safe for comparing sensitive code, documents, or proprietary content.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is similarity percentage?</h3>
      <p style="margin-bottom: 16px;">The similarity percentage shows how much of the original text remains unchanged. It is calculated as the ratio of unchanged lines to total lines. A 100% similarity means the texts are identical, while 0% means they share no common lines.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How does this compare to tools like DiffNow or Diffchecker.com?</h3>
      <p style="margin-bottom: 16px;">This tool provides the same core text comparison as tools like DiffNow or Diffchecker.com, but runs entirely in the browser with no sign-up required. It includes line-by-line and word-by-word diff modes, ignore whitespace/case options, stats, and a clean side-by-side view — all without uploading your data.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/html-to-markdown-converter">HTML to Markdown Converter</a> — Convert HTML to clean Markdown syntax instantly.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions online with real-time highlighting.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "Diff Checker — Compare Two Texts Online",
  description: "Free online diff checker to compare two texts side by side. Highlights additions and deletions with line-by-line or word-by-word diff modes. No data leaves your browser.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="Diff Checker — Compare Two Texts Online"
  description="Free online diff checker to compare two texts side by side. Highlights additions and deletions with line-by-line or word-by-word diff modes. No data leaves your browser."
  canonical="https://siliconbased.dev/diff-checker"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const originalArea = document.getElementById('originalArea');
const modifiedArea = document.getElementById('modifiedArea');
const ignoreWhitespace = document.getElementById('ignoreWhitespace');
const ignoreCase = document.getElementById('ignoreCase');
const btnLineDiff = document.getElementById('btnLineDiff');
const btnWordDiff = document.getElementById('btnWordDiff');
const swapBtn = document.getElementById('swapBtn');
const compareBtn = document.getElementById('compareBtn');
const sampleBtn = document.getElementById('sampleBtn');
const clearBtn = document.getElementById('clearBtn');
const clearModifiedBtn = document.getElementById('clearModifiedBtn');
const copyDiffBtn = document.getElementById('copyDiffBtn');
const statsBar = document.getElementById('statsBar');
const diffOutput = document.getElementById('diffOutput');
const diffContent = document.getElementById('diffContent');
const statAdded = document.getElementById('statAdded');
const statRemoved = document.getElementById('statRemoved');
const statUnchanged = document.getElementById('statUnchanged');
const statSimilarity = document.getElementById('statSimilarity');

let diffMode = 'line';

const sampleOriginal = `function calculateTotal(items) {
  let total = 0;
  for (let i = 0; i < items.length; i++) {
    total += items[i].price;
  }
  return total;
}

function formatCurrency(amount) {
  return "$" + amount.toFixed(2);
}

// Display the result
const items = getItems();
const total = calculateTotal(items);
console.log(formatCurrency(total));`;

const sampleModified = `function calculateTotal(items, taxRate = 0) {
  let total = 0;
  for (const item of items) {
    total += item.price * item.quantity;
  }
  return total * (1 + taxRate);
}

function formatCurrency(amount, currency = "USD") {
  const symbols = { USD: "$", EUR: "\\u20ac", GBP: "\\u00a3" };
  const symbol = symbols[currency] || "$";
  return symbol + amount.toFixed(2);
}

// Display the result with tax
const items = getItems();
const total = calculateTotal(items, 0.08);
console.log(formatCurrency(total, "USD"));`;

function init() {
  compareBtn.addEventListener('click', runDiff);
  btnLineDiff.addEventListener('click', () => { diffMode = 'line'; btnLineDiff.classList.add('active'); btnWordDiff.classList.remove('active'); runDiff(); });
  btnWordDiff.addEventListener('click', () => { diffMode = 'word'; btnWordDiff.classList.add('active'); btnLineDiff.classList.remove('active'); runDiff(); });

  swapBtn.addEventListener('click', () => {
    const tmp = originalArea.value;
    originalArea.value = modifiedArea.value;
    modifiedArea.value = tmp;
  });

  sampleBtn.addEventListener('click', () => {
    originalArea.value = sampleOriginal;
    modifiedArea.value = sampleModified;
    runDiff();
  });

  clearBtn.addEventListener('click', () => {
    originalArea.value = '';
    modifiedArea.value = '';
    statsBar.style.display = 'none';
    diffOutput.style.display = 'none';
  });

  clearModifiedBtn.addEventListener('click', () => {
    modifiedArea.value = '';
  });

  copyDiffBtn.addEventListener('click', () => {
    const text = buildUnifiedDiff();
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      copyDiffBtn.textContent = '\u2713 Copied';
      setTimeout(() => { copyDiffBtn.textContent = 'Copy Diff'; }, 1500);
    });
  });
}

function normalize(line) {
  let l = line;
  if (ignoreCase.checked) l = l.toLowerCase();
  if (ignoreWhitespace.checked) l = l.replace(/\s+/g, ' ').trim();
  return l;
}

/* ── LCS-based diff ── */
function lcs(a, b) {
  const m = a.length, n = b.length;
  const dp = Array.from({ length: m + 1 }, () => new Array(n + 1).fill(0));
  for (let i = 1; i <= m; i++) {
    for (let j = 1; j <= n; j++) {
      if (a[i - 1] === b[j - 1]) dp[i][j] = dp[i - 1][j - 1] + 1;
      else dp[i][j] = Math.max(dp[i - 1][j], dp[i][j - 1]);
    }
  }
  const result = [];
  let i = m, j = n;
  while (i > 0 && j > 0) {
    if (a[i - 1] === b[j - 1]) { result.unshift({ type: 'equal', aIdx: i - 1, bIdx: j - 1 }); i--; j--; }
    else if (dp[i - 1][j] >= dp[i][j - 1]) { i--; }
    else { j--; }
  }
  return result;
}

function computeDiff(aLines, bLines) {
  const aNorm = aLines.map(normalize);
  const bNorm = bLines.map(normalize);
  const common = lcs(aNorm, bNorm);

  const ops = [];
  let ai = 0, bi = 0, ci = 0;
  while (ci < common.length) {
    const c = common[ci];
    while (ai < c.aIdx) { ops.push({ type: 'removed', line: aLines[ai], lineNum: ai + 1 }); ai++; }
    while (bi < c.bIdx) { ops.push({ type: 'added', line: bLines[bi], lineNum: bi + 1 }); bi++; }
    ops.push({ type: 'equal', lineA: aLines[ai], lineB: bLines[bi], lineNumA: ai + 1, lineNumB: bi + 1 });
    ai++; bi++; ci++;
  }
  while (ai < aLines.length) { ops.push({ type: 'removed', line: aLines[ai], lineNum: ai + 1 }); ai++; }
  while (bi < bLines.length) { ops.push({ type: 'added', line: bLines[bi], lineNum: bi + 1 }); bi++; }
  return ops;
}

function escHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function wordDiffLine(oldLine, newLine) {
  const aWords = oldLine.split(/(\s+)/);
  const bWords = newLine.split(/(\s+)/);
  const aNorm = aWords.map(w => { let r = w; if (ignoreCase.checked) r = r.toLowerCase(); return r; });
  const bNorm = bWords.map(w => { let r = w; if (ignoreCase.checked) r = r.toLowerCase(); return r; });
  const common = lcs(aNorm, bNorm);

  let oldHtml = '', newHtml = '';
  let ai = 0, bi = 0, ci = 0;
  while (ci < common.length) {
    const c = common[ci];
    while (ai < c.aIdx) { oldHtml += '<span class="wd-removed">' + escHtml(aWords[ai]) + '</span>'; ai++; }
    while (bi < c.bIdx) { newHtml += '<span class="wd-added">' + escHtml(bWords[bi]) + '</span>'; bi++; }
    oldHtml += escHtml(aWords[ai]);
    newHtml += escHtml(bWords[bi]);
    ai++; bi++; ci++;
  }
  while (ai < aWords.length) { oldHtml += '<span class="wd-removed">' + escHtml(aWords[ai]) + '</span>'; ai++; }
  while (bi < bWords.length) { newHtml += '<span class="wd-added">' + escHtml(bWords[bi]) + '</span>'; bi++; }
  return { oldHtml, newHtml };
}

function runDiff() {
  const a = originalArea.value;
  const b = modifiedArea.value;
  if (!a && !b) { statsBar.style.display = 'none'; diffOutput.style.display = 'none'; return; }

  const aLines = a.split('\n');
  const bLines = b.split('\n');
  const ops = computeDiff(aLines, bLines);

  let added = 0, removed = 0, unchanged = 0;
  ops.forEach(op => { if (op.type === 'added') added++; else if (op.type === 'removed') removed++; else unchanged++; });

  const total = added + removed + unchanged;
  const sim = total > 0 ? Math.round((unchanged / Math.max(aLines.length, bLines.length)) * 100) : 100;

  statAdded.textContent = added;
  statRemoved.textContent = removed;
  statUnchanged.textContent = unchanged;
  statSimilarity.textContent = sim + '%';
  statsBar.style.display = 'flex';

  let html = '';
  if (diffMode === 'line') {
    ops.forEach(op => {
      if (op.type === 'equal') {
        html += '<div class="diff-line equal"><span class="diff-prefix"> </span><span class="diff-text">' + escHtml(op.lineA) + '</span></div>';
      } else if (op.type === 'removed') {
        html += '<div class="diff-line removed"><span class="diff-prefix">-</span><span class="diff-text">' + escHtml(op.line) + '</span></div>';
      } else {
        html += '<div class="diff-line added"><span class="diff-prefix">+</span><span class="diff-text">' + escHtml(op.line) + '</span></div>';
      }
    });
  } else {
    // Word diff: group removed+added pairs for inline word highlighting
    let i = 0;
    while (i < ops.length) {
      const op = ops[i];
      if (op.type === 'equal') {
        html += '<div class="diff-line equal"><span class="diff-prefix"> </span><span class="diff-text">' + escHtml(op.lineA) + '</span></div>';
        i++;
      } else if (op.type === 'removed' && i + 1 < ops.length && ops[i + 1].type === 'added') {
        const wd = wordDiffLine(op.line, ops[i + 1].line);
        html += '<div class="diff-line removed"><span class="diff-prefix">-</span><span class="diff-text">' + wd.oldHtml + '</span></div>';
        html += '<div class="diff-line added"><span class="diff-prefix">+</span><span class="diff-text">' + wd.newHtml + '</span></div>';
        i += 2;
      } else if (op.type === 'removed') {
        html += '<div class="diff-line removed"><span class="diff-prefix">-</span><span class="diff-text">' + escHtml(op.line) + '</span></div>';
        i++;
      } else {
        html += '<div class="diff-line added"><span class="diff-prefix">+</span><span class="diff-text">' + escHtml(op.line) + '</span></div>';
        i++;
      }
    }
  }

  diffContent.innerHTML = html;
  diffOutput.style.display = 'block';
}

function buildUnifiedDiff() {
  const a = originalArea.value;
  const b = modifiedArea.value;
  if (!a && !b) return '';
  const aLines = a.split('\n');
  const bLines = b.split('\n');
  const ops = computeDiff(aLines, bLines);
  let out = '--- original\n+++ modified\n';
  ops.forEach(op => {
    if (op.type === 'equal') out += ' ' + op.lineA + '\n';
    else if (op.type === 'removed') out += '-' + op.line + '\n';
    else out += '+' + op.line + '\n';
  });
  return out;
}

init();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #0f1729 0%, #060a12 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1100px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Options Bar */
.options-bar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; margin-bottom: 20px; padding: 14px 18px; background: #0a1020; border: 2px solid #152040; border-radius: 12px; }
.options-left { display: flex; flex-wrap: wrap; gap: 18px; }
.options-right { display: flex; gap: 8px; align-items: center; }
.toggle-label { display: flex; align-items: center; gap: 8px; cursor: pointer; user-select: none; }
.toggle-label input[type="checkbox"] { width: 16px; height: 16px; accent-color: #818cf8; cursor: pointer; }
.toggle-text { font-size: 0.82rem; color: #aaa; font-weight: 500; }

/* Mode buttons */
.mode-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 6px 16px; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.15s; }
.mode-btn:hover { background: #2a2d40; color: #ccc; }
.mode-btn.active { background: #818cf8; color: #fff; border-color: #818cf8; }

/* Tool grid */
.tool-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; align-items: stretch; }
.pane { display: flex; flex-direction: column; }
.input-header, .output-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.header-title { font-size: 0.85rem; font-weight: 600; color: #ccc; text-transform: uppercase; letter-spacing: 0.5px; }
.header-actions { display: flex; gap: 8px; }
.action-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 6px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.15s; }
.action-btn:hover { background: #2a2d40; color: #ccc; }
.action-btn.primary { background: #818cf8; color: #fff; border-color: #818cf8; font-weight: 600; }
.action-btn.primary:hover { background: #6366f1; }
.copy-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 6px 14px; border-radius: 8px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.15s; }
.copy-btn:hover { background: #2a2d40; color: #ccc; }

/* Code areas */
.code-area { width: 100%; min-height: 300px; background: #0a1020; border: 2px solid #152040; border-radius: 12px; padding: 16px; color: #e0e0e0; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; line-height: 1.6; resize: vertical; outline: none; transition: border-color 0.2s; white-space: pre-wrap; word-wrap: break-word; }
.code-area:focus { border-color: #818cf8; }
.code-area::placeholder { color: #555; }

/* Stats bar */
.stats-bar { display: flex; gap: 24px; justify-content: center; padding: 16px 20px; background: #0a1020; border: 2px solid #152040; border-radius: 12px; margin-bottom: 24px; flex-wrap: wrap; }
.stat { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.stat-num { font-size: 1.4rem; font-weight: 800; font-family: 'JetBrains Mono', monospace; }
.stat-num.added { color: #4ade80; }
.stat-num.removed { color: #f87171; }
.stat-num.unchanged { color: #888; }
.stat-num.similarity { color: #818cf8; }
.stat-label { font-size: 0.72rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }

/* Diff output */
.diff-output { margin-bottom: 40px; }
.diff-content { background: #0a1020; border: 2px solid #152040; border-radius: 12px; padding: 8px 0; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; line-height: 1.7; }
.diff-line { display: flex; padding: 1px 16px; }
.diff-line.added { background: rgba(74, 222, 128, 0.08); }
.diff-line.removed { background: rgba(248, 113, 113, 0.08); }
.diff-prefix { width: 20px; flex-shrink: 0; color: #555; user-select: none; }
.diff-line.added .diff-prefix { color: #4ade80; }
.diff-line.removed .diff-prefix { color: #f87171; }
.diff-text { white-space: pre-wrap; word-break: break-word; }
.diff-line.added .diff-text { color: #4ade80; }
.diff-line.removed .diff-text { color: #f87171; }
.diff-line.equal .diff-text { color: #888; }

/* Word-level highlights */
.wd-added { background: rgba(74, 222, 128, 0.25); border-radius: 2px; padding: 0 1px; }
.wd-removed { background: rgba(248, 113, 113, 0.25); border-radius: 2px; padding: 0 1px; }

/* SEO Content */
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }
.seo-content a { color: #818cf8; text-decoration: none; }
.seo-content a:hover { text-decoration: underline; }
.seo-content code { background: #0a1020; padding: 2px 6px; border-radius: 4px; color: #818cf8; font-size: 0.85em; }
.seo-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 0.9rem; }
.seo-table th { text-align: left; padding: 10px 14px; border-bottom: 2px solid #2a2d4e; color: #ccc; font-weight: 600; background: #0a1020; }
.seo-table td { padding: 10px 14px; border-bottom: 1px solid #152040; color: #aaa; }
.seo-table tr:hover td { background: #0a1020; }

/* Responsive */
@media (max-width: 800px) {
  .tool-grid { grid-template-columns: 1fr; }
  .options-bar { flex-direction: column; align-items: flex-start; }
  .code-area { min-height: 200px; }
}

</style>
</SiteLayout>
