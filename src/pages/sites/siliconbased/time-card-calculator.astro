---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Time Card & Payroll Calculator",
  description: "Are you being underpaid for your overtime? Calculate your exact hours and earnings instantly...",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is overtime pay calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Overtime pay is typically calculated as 'time and a half' (1.5 times the regular hourly rate) for any hours worked over 40 hours in a single workweek, as mandated by the Fair Labor Standards Act (FLSA) in the US."
        }
      },
      {
        "@type": "Question",
        "name": "Are unpaid breaks deducted from my total hours?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, unpaid breaks (like a 30-minute or 1-hour lunch) are deducted from your total shift time. However, short rest breaks (usually 5 to 20 minutes) are typically considered paid work time."
        }
      },
      {
        "@type": "Question",
        "name": "How do you calculate decimal hours for payroll?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To convert minutes to decimal hours, divide the minutes by 60. For example, 15 minutes is 15/60 = 0.25 hours, 30 minutes is 0.5 hours, and 45 minutes is 0.75 hours."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between gross pay and net pay?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Gross pay is the total amount of money you earn before any deductions (like taxes, insurance, or retirement contributions) are taken out. Net pay is your 'take-home' pay after all deductions."
        }
      },
      {
        "@type": "Question",
        "name": "Does this calculator account for daily overtime rules?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This standard calculator computes overtime based on the weekly 40-hour threshold. If you live in a state like California, where overtime is also calculated for hours worked beyond 8 hours in a single day, you may need to adjust your inputs accordingly."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Time Card & Payroll Calculator",
    "description": "Calculate total hours worked, deduct breaks, and compute gross pay including overtime.",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SiliconBased"
    }
  }
];
---
<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/time-card-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Time Card Calculator</h1>
      <p class="subtitle">Calculate hours worked, overtime, and gross pay instantly.</p>
    </div>

    <div class="calculator-container">
      <div style="display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
        <div class="input-group">
          <label for="hourlyRate">Hourly Rate ($)</label>
          <input type="number" id="hourlyRate" value="15.00" min="0" step="0.50" />
        </div>
        <div class="input-group">
          <label for="overtimeRate">Overtime Multiplier</label>
          <select id="overtimeRate">
            <option value="1.5">1.5x (Time and a half)</option>
            <option value="2.0">2.0x (Double time)</option>
            <option value="1.0">1.0x (No overtime rate)</option>
          </select>
        </div>
      </div>

      <div style="background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; margin-bottom: 2rem;">
        <h3 style="margin-top: 0; margin-bottom: 1rem; font-size: 1.1rem; color: var(--text-primary);">Add Shift</h3>
        <div style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); align-items: end;">
          <div class="input-group" style="margin-bottom: 0;">
            <label for="startTime">Start Time</label>
            <input type="time" id="startTime" value="09:00" required />
          </div>
          <div class="input-group" style="margin-bottom: 0;">
            <label for="endTime">End Time</label>
            <input type="time" id="endTime" value="17:00" required />
          </div>
          <div class="input-group" style="margin-bottom: 0;">
            <label for="breakMinutes">Break (Minutes)</label>
            <input type="number" id="breakMinutes" value="30" min="0" step="5" />
          </div>
          <button id="addShiftBtn" style="width: 100%;">Add Shift</button>
        </div>
        <div id="shiftError" class="error-msg" style="display: none; color: #ef4444; font-size: 0.85rem; margin-top: 0.5rem;">End time must be after start time.</div>
      </div>

      <div id="shiftsContainer" style="margin-bottom: 2rem;">
        <!-- Shifts will be rendered here -->
      </div>

      <div id="results" style="display: none;">
        <div style="display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
          <div class="result-card" style="margin: 0;">
            <div style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Total Hours</div>
            <div id="totalHours" style="font-size: 2rem; font-weight: 800; color: var(--text-primary);">0.00</div>
          </div>
          <div class="result-card" style="margin: 0;">
            <div style="font-size: 0.95rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Overtime Hours</div>
            <div id="overtimeHours" style="font-size: 2rem; font-weight: 800; color: #f59e0b;">0.00</div>
          </div>
        </div>

        <div class="result-card">
          <div style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Gross Pay (Estimated)</div>
          <div id="grossPay" class="result-value">$0.00</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Payroll and Time Card Calculations</h2>
      <p>Whether you are an hourly employee trying to ensure your paycheck is accurate, or a small business owner manually processing payroll, understanding the mechanics of time card calculation is crucial. Discrepancies in time tracking can lead to significant financial losses for employees or legal compliance issues for employers.</p>

      <p>Our time card calculator simplifies this process by converting your hours and minutes into standard payroll decimals, deducting unpaid breaks, and automatically applying overtime rules based on standard weekly thresholds.</p>

      <h3>Converting Minutes to Decimals</h3>
      <p>The most common source of confusion in payroll calculation is the conversion of time to decimal format. While clocks measure time in a base-60 system (60 minutes in an hour), payroll systems process money using a base-10 decimal system.</p>

      <p>You cannot simply place a decimal point between the hours and minutes. For example, working 8 hours and 30 minutes is <strong>not</strong> 8.30 hours. Because 30 minutes is half of an hour, the correct decimal format is <strong>8.50 hours</strong>.</p>

      <p>The formula for this conversion is straightforward:<br>
      <code>Decimal Hours = Minutes ÷ 60</code></p>

      <ul>
        <li>15 minutes = 15 ÷ 60 = <strong>0.25</strong> hours</li>
        <li>30 minutes = 30 ÷ 60 = <strong>0.50</strong> hours</li>
        <li>45 minutes = 45 ÷ 60 = <strong>0.75</strong> hours</li>
      </ul>

      <p>To calculate the total shift duration, you first convert the start and end times to a 24-hour format, subtract the start time from the end time to get total minutes, subtract any unpaid break minutes, and finally convert the resulting total minutes into decimal hours.</p>

      <h3>Handling Breaks and Meal Periods</h3>
      <p>Under the Fair Labor Standards Act (FLSA) in the United States, employers are not strictly required by federal law to provide meal or rest breaks. However, when they do, the law distinguishes between paid and unpaid breaks:</p>

      <ul>
        <li><strong>Rest Breaks:</strong> Short breaks (usually lasting about 5 to 20 minutes) are generally considered compensable work hours. This means you must be paid for this time, and it counts toward your total hours worked for the week.</li>
        <li><strong>Meal Periods:</strong> Bona fide meal periods (typically lasting 30 minutes or more) are usually unpaid. For these periods to be unpaid, the employee must be completely relieved from duty for the purpose of eating regular meals. If you are required to answer phones or perform any tasks during lunch, you must be paid for that time.</li>
      </ul>
      <p>When using our calculator, only enter <em>unpaid</em> break times in the break field to ensure they are properly deducted from your total shift time.</p>

      <h3>Calculating Overtime Pay</h3>
      <p>The FLSA mandates that non-exempt employees must receive overtime pay for hours worked over 40 per workweek. The standard federal overtime rate is <strong>"time and a half"</strong>, which means 1.5 times the employee's regular hourly rate.</p>

      <p>The calculation is split into two parts:</p>
      <ol>
        <li><strong>Regular Pay:</strong> The first 40 hours worked are multiplied by the standard hourly rate.</li>
        <li><strong>Overtime Pay:</strong> Any hours beyond 40 are multiplied by the overtime rate (Regular Rate × 1.5).</li>
      </ol>

      <p>For example, if an employee makes $20/hour and works 45 hours in a week:</p>
      <ul>
        <li>Regular Pay: 40 hours × $20/hr = $800</li>
        <li>Overtime Pay: 5 hours × ($20/hr × 1.5) = 5 hours × $30/hr = $150</li>
        <li><strong>Total Gross Pay:</strong> $800 + $150 = $950</li>
      </ul>

      <h3>State-Specific Overtime Variations</h3>
      <p>It is important to note that while this calculator uses the federal 40-hour weekly threshold, some states have more generous overtime laws. For instance, California requires overtime pay for any hours worked beyond 8 hours in a <em>single workday</em>, and double time (2.0x) for hours worked beyond 12 hours in a single day.</p>

      <p>If you are calculating payroll in a state with daily overtime rules, you will need to manually adjust your inputs or calculate shifts individually using the appropriate multiplier.</p>

      <h3>Gross Pay vs. Net Pay</h3>
      <p>This calculator outputs <strong>Gross Pay</strong>. Gross pay is the total amount of money you have earned before any deductions are made. Your actual paycheck will represent your <strong>Net Pay</strong>, which is your gross pay minus federal, state, and local taxes, Social Security and Medicare (FICA), health insurance premiums, retirement contributions, and any other garnishments.</p>

      <p>Looking for health tracking tools instead? Check out our <a href="/ovulation-calculator">Ovulation Calculator</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How is overtime pay calculated?</summary>
        <p>Overtime pay is typically calculated as "time and a half" (1.5 times the regular hourly rate) for any hours worked over 40 hours in a single workweek, as mandated by the Fair Labor Standards Act (FLSA) in the US. Some states also have daily overtime limits (e.g., working more than 8 hours in a day).</p>
      </details>
      <details>
        <summary>Are unpaid breaks deducted from my total hours?</summary>
        <p>Yes, unpaid breaks (like a 30-minute or 1-hour lunch) are deducted from your total shift time. However, short rest breaks (usually 5 to 20 minutes) are typically considered paid work time and should not be deducted.</p>
      </details>
      <details>
        <summary>How do you calculate decimal hours for payroll?</summary>
        <p>To convert minutes to decimal hours, divide the minutes by 60. For example, 15 minutes is 15/60 = 0.25 hours, 30 minutes is 0.5 hours, and 45 minutes is 0.75 hours. 8 hours and 30 minutes is written as 8.50 on a payroll sheet.</p>
      </details>
      <details>
        <summary>What is the difference between gross pay and net pay?</summary>
        <p>Gross pay is the total amount of money you earn before any deductions are taken out. Net pay is your "take-home" pay—the actual amount deposited into your bank account after taxes, insurance, and retirement contributions have been deducted.</p>
      </details>
      <details>
        <summary>Does this calculator account for daily overtime rules?</summary>
        <p>This standard calculator computes overtime based on the federal weekly 40-hour threshold. If you live in a state like California, where overtime is also calculated for hours worked beyond 8 hours in a single day, you may need to adjust your multiplier manually or calculate daily shifts individually.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      let shifts = [];

      const hourlyRateInput = document.getElementById('hourlyRate');
      const overtimeRateSelect = document.getElementById('overtimeRate');
      const startTimeInput = document.getElementById('startTime');
      const endTimeInput = document.getElementById('endTime');
      const breakMinutesInput = document.getElementById('breakMinutes');
      const addShiftBtn = document.getElementById('addShiftBtn');
      const shiftError = document.getElementById('shiftError');
      const shiftsContainer = document.getElementById('shiftsContainer');
      const resultsDiv = document.getElementById('results');

      const totalHoursEl = document.getElementById('totalHours');
      const overtimeHoursEl = document.getElementById('overtimeHours');
      const grossPayEl = document.getElementById('grossPay');

      function calculateShifts() {
        const rate = parseFloat(hourlyRateInput.value) || 0;
        const otMultiplier = parseFloat(overtimeRateSelect.value) || 1.5;

        let totalDecimalHours = 0;

        shifts.forEach(shift => {
          const start = shift.start.split(':').map(Number);
          const end = shift.end.split(':').map(Number);

          let startMinutes = (start[0] * 60) + start[1];
          let endMinutes = (end[0] * 60) + end[1];

          // Handle overnight shifts (end time is smaller than start time)
          if (endMinutes < startMinutes) {
            endMinutes += 24 * 60;
          }

          let shiftMinutes = endMinutes - startMinutes;
          shiftMinutes -= (parseInt(shift.break) || 0);

          if (shiftMinutes > 0) {
            totalDecimalHours += (shiftMinutes / 60);
          }
        });

        if (shifts.length === 0) {
          resultsDiv.style.display = 'none';
          return;
        }

        let regularHours = totalDecimalHours;
        let otHours = 0;

        if (totalDecimalHours > 40) {
          regularHours = 40;
          otHours = totalDecimalHours - 40;
        }

        const regularPay = regularHours * rate;
        const otPay = otHours * (rate * otMultiplier);
        const totalPay = regularPay + otPay;

        totalHoursEl.textContent = totalDecimalHours.toFixed(2);
        overtimeHoursEl.textContent = otHours.toFixed(2);
        grossPayEl.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(totalPay);

        resultsDiv.style.display = 'block';
      }

      function renderShifts() {
        shiftsContainer.innerHTML = '';
        shifts.forEach((shift, index) => {
          const shiftDiv = document.createElement('div');
          shiftDiv.style.display = 'flex';
          shiftDiv.style.justifyContent = 'space-between';
          shiftDiv.style.alignItems = 'center';
          shiftDiv.style.background = 'var(--card-bg)';
          shiftDiv.style.border = '1px solid var(--border-color)';
          shiftDiv.style.padding = '1rem';
          shiftDiv.style.borderRadius = '8px';
          shiftDiv.style.marginBottom = '0.5rem';

          // Format time for display
          const t1 = formatTime(shift.start);
          const t2 = formatTime(shift.end);

          shiftDiv.innerHTML = `
            <div>
              <span style="font-weight: 600; color: var(--text-primary);">Shift ${index + 1}:</span>
              <span style="color: var(--text-secondary); margin-left: 0.5rem;">${t1} - ${t2} (${shift.break}m break)</span>
            </div>
            <button class="remove-btn" data-index="${index}" style="background: transparent; color: #ef4444; border: 1px solid #ef4444; padding: 0.25rem 0.75rem;">Remove</button>
          `;
          shiftsContainer.appendChild(shiftDiv);
        });

        // Add event listeners to remove buttons
        document.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const index = parseInt(e.target.getAttribute('data-index'));
            shifts.splice(index, 1);
            renderShifts();
            calculateShifts();
          });
        });
      }

      function formatTime(timeStr) {
        const [h, m] = timeStr.split(':');
        let hours = parseInt(h, 10);
        const ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        return `${hours}:${m} ${ampm}`;
      }

      addShiftBtn.addEventListener('click', () => {
        const start = startTimeInput.value;
        const end = endTimeInput.value;
        const breakMins = breakMinutesInput.value;

        if (!start || !end) {
          shiftError.textContent = "Please provide both start and end times.";
          shiftError.style.display = 'block';
          return;
        }

        shiftError.style.display = 'none';

        shifts.push({
          start: start,
          end: end,
          break: breakMins || 0
        });

        // Reset inputs to default after adding
        startTimeInput.value = '09:00';
        endTimeInput.value = '17:00';
        breakMinutesInput.value = '30';

        renderShifts();
        calculateShifts();
      });

      hourlyRateInput.addEventListener('input', calculateShifts);
      overtimeRateSelect.addEventListener('change', calculateShifts);
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .explainer { margin-top: 3rem; }
    .explainer h2 { margin-top: 2rem; margin-bottom: 1rem; color: var(--text-primary); }
    .explainer h3 { margin-top: 1.5rem; margin-bottom: 0.75rem; color: var(--text-primary); }
    .explainer p { margin-bottom: 1rem; line-height: 1.6; color: var(--text-secondary); }
    .explainer ul, .explainer ol { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); line-height: 1.6; }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer code { background: var(--bg-color); border: 1px solid var(--border-color); padding: 0.2rem 0.4rem; border-radius: 4px; font-family: monospace; }
  </style>
</SiteLayout>