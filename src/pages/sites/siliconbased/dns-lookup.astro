---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "what is a DNS lookup",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A DNS lookup is the process of translating a human-readable domain name (like example.com) into its associated DNS records, including IP addresses, mail servers, name servers, and other configuration data stored in the Domain Name System."
          }
        },
        {
          "@type": "Question",
          "name": "what are DNS record types",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DNS record types include A (IPv4 address), AAAA (IPv6 address), CNAME (canonical name alias), MX (mail exchange server), TXT (text data, often used for SPF/DKIM), NS (name server), and SOA (start of authority with zone metadata). Each serves a different purpose in domain configuration."
          }
        },
        {
          "@type": "Question",
          "name": "what is DNS over HTTPS",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DNS over HTTPS (DoH) is a protocol that encrypts DNS queries using HTTPS, preventing eavesdropping and manipulation of DNS data. This tool uses Cloudflare's DoH endpoint (1.1.1.1) to perform lookups securely from your browser without exposing your queries to network intermediaries."
          }
        },
        {
          "@type": "Question",
          "name": "what is TTL in DNS",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TTL (Time To Live) is a value in DNS records that tells resolvers how long to cache a record before requesting a fresh copy. A TTL of 300 means the record can be cached for 300 seconds (5 minutes). Lower TTLs allow faster propagation of changes but increase query load on authoritative servers."
          }
        },
        {
          "@type": "Question",
          "name": "how long does DNS propagation take",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DNS propagation typically takes anywhere from a few minutes to 48 hours, depending on the TTL values of the old records and caching behavior of ISP resolvers worldwide. Most changes propagate within 1-4 hours. You can check propagation by querying different DNS resolvers like Cloudflare (1.1.1.1) and Google (8.8.8.8)."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "DNS Lookup Tool",
      "description": "Free online DNS lookup tool. Query A, AAAA, CNAME, MX, TXT, NS, and SOA records for any domain using Cloudflare DNS-over-HTTPS.",
      "url": "https://siliconbased.dev/dns-lookup",
      "applicationCategory": "NetworkingApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev/"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
    <h1>DNS Lookup Tool</h1>
<main>

        <div class="search-container">
            <input type="text" id="domainInput" placeholder="Enter a domain name (e.g., example.com)" autocomplete="off" spellcheck="false">
            <button onclick="lookupDns()" id="lookupBtn">
                <span id="btnText">Lookup DNS</span>
                <div class="loader" id="btnLoader"></div>
            </button>
        </div>

        <div class="error-message" id="errorMsg"></div>

        <div id="resultsArea" style="display:none;">

            <div class="record-section" id="sectionA">
                <h2>A Records (IPv4)</h2>
                <p class="record-desc">Maps a domain to one or more IPv4 addresses. This is the most fundamental DNS record — it tells browsers which server to connect to.</p>
                <div class="records-table" id="tableA">
                    <div class="table-header"><span>Value</span><span>TTL</span></div>
                </div>
            </div>

            <div class="record-section" id="sectionAAAA">
                <h2>AAAA Records (IPv6)</h2>
                <p class="record-desc">Maps a domain to IPv6 addresses. Functions identically to A records but uses the newer 128-bit address format for the expanding internet.</p>
                <div class="records-table" id="tableAAAA">
                    <div class="table-header"><span>Value</span><span>TTL</span></div>
                </div>
            </div>

            <div class="record-section" id="sectionCNAME">
                <h2>CNAME Records (Alias)</h2>
                <p class="record-desc">Creates an alias from one domain to another. For example, www.example.com might be a CNAME pointing to example.com. Cannot coexist with other record types on the same name.</p>
                <div class="records-table" id="tableCNAME">
                    <div class="table-header"><span>Value</span><span>TTL</span></div>
                </div>
            </div>

            <div class="record-section" id="sectionMX">
                <h2>MX Records (Mail)</h2>
                <p class="record-desc">Specifies which mail servers accept email for the domain and their priority. Lower priority numbers are tried first. Essential for email delivery.</p>
                <div class="records-table" id="tableMX">
                    <div class="table-header"><span>Priority</span><span>Mail Server</span><span>TTL</span></div>
                </div>
            </div>

            <div class="record-section" id="sectionTXT">
                <h2>TXT Records</h2>
                <p class="record-desc">Holds arbitrary text data. Commonly used for SPF (email sender verification), DKIM (email signing), DMARC (email policy), and domain ownership verification.</p>
                <div class="records-table" id="tableTXT">
                    <div class="table-header"><span>Value</span><span>TTL</span></div>
                </div>
            </div>

            <div class="record-section" id="sectionNS">
                <h2>NS Records (Name Servers)</h2>
                <p class="record-desc">Identifies the authoritative name servers for the domain. These are the servers that hold the actual DNS records and respond to queries for your domain.</p>
                <div class="records-table" id="tableNS">
                    <div class="table-header"><span>Name Server</span><span>TTL</span></div>
                </div>
            </div>

            <div class="record-section" id="sectionSOA">
                <h2>SOA Record (Start of Authority)</h2>
                <p class="record-desc">Contains zone metadata: the primary name server, admin email, serial number, and timing values for zone transfers and caching. Every DNS zone has exactly one SOA record.</p>
                <div class="records-table" id="tableSOA">
                    <div class="table-header"><span>Field</span><span>Value</span></div>
                </div>
            </div>

        </div>

        <div class="content-section">
            <h2>DNS Record Types Comparison</h2>
            <div class="comparison-table">
                <div class="comp-row comp-header">
                    <span>Type</span><span>Purpose</span><span>Example Value</span>
                </div>
                <div class="comp-row">
                    <span class="comp-type">A</span><span>Points domain to IPv4 address</span><span class="comp-mono">93.184.216.34</span>
                </div>
                <div class="comp-row">
                    <span class="comp-type">AAAA</span><span>Points domain to IPv6 address</span><span class="comp-mono">2606:2800:220:1:248:1893:25c8:1946</span>
                </div>
                <div class="comp-row">
                    <span class="comp-type">CNAME</span><span>Alias to another domain</span><span class="comp-mono">www.example.com &rarr; example.com</span>
                </div>
                <div class="comp-row">
                    <span class="comp-type">MX</span><span>Mail server with priority</span><span class="comp-mono">10 mail.example.com</span>
                </div>
                <div class="comp-row">
                    <span class="comp-type">TXT</span><span>Text data (SPF, DKIM, verification)</span><span class="comp-mono">v=spf1 include:_spf.google.com ~all</span>
                </div>
                <div class="comp-row">
                    <span class="comp-type">NS</span><span>Authoritative name servers</span><span class="comp-mono">ns1.example.com</span>
                </div>
                <div class="comp-row">
                    <span class="comp-type">SOA</span><span>Zone authority &amp; serial info</span><span class="comp-mono">ns1.example.com admin.example.com 2024010101</span>
                </div>
            </div>
        </div>

        <div class="content-section">
            <h2>How This Tool Works</h2>
            <p>This DNS lookup tool performs queries entirely in your browser using <strong>DNS-over-HTTPS (DoH)</strong>. When you enter a domain, your browser sends encrypted HTTPS requests to Cloudflare's public resolver at <code>1.1.1.1</code>, which returns DNS records in JSON format.</p>
            <p>Because queries happen client-side, your domain lookups never pass through our servers. The DNS-over-HTTPS protocol also prevents your ISP or network operator from seeing which domains you query through this tool.</p>
            <p>We query all major record types (A, AAAA, CNAME, MX, TXT, NS, SOA) in parallel, so results appear almost instantly. Each record includes its TTL (Time To Live), which tells you how long resolvers will cache that record before fetching a fresh copy.</p>
        </div>

        <div class="content-section">
            <h2>Frequently Asked Questions</h2>

            <div class="faq-item">
                <div class="faq-question">What is a DNS lookup?</div>
                <div class="faq-answer">A DNS lookup is the process of translating a human-readable domain name (like example.com) into its associated DNS records, including IP addresses, mail servers, name servers, and other configuration data stored in the Domain Name System.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">What are DNS record types?</div>
                <div class="faq-answer">DNS record types include A (IPv4 address), AAAA (IPv6 address), CNAME (canonical name alias), MX (mail exchange server), TXT (text data, often used for SPF/DKIM), NS (name server), and SOA (start of authority with zone metadata). Each serves a different purpose in domain configuration.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">What is DNS over HTTPS?</div>
                <div class="faq-answer">DNS over HTTPS (DoH) is a protocol that encrypts DNS queries using HTTPS, preventing eavesdropping and manipulation of DNS data. This tool uses Cloudflare's DoH endpoint (1.1.1.1) to perform lookups securely from your browser without exposing your queries to network intermediaries.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">What is TTL in DNS?</div>
                <div class="faq-answer">TTL (Time To Live) is a value in DNS records that tells resolvers how long to cache a record before requesting a fresh copy. A TTL of 300 means the record can be cached for 300 seconds (5 minutes). Lower TTLs allow faster propagation of changes but increase query load on authoritative servers.</div>
            </div>

            <div class="faq-item">
                <div class="faq-question">How long does DNS propagation take?</div>
                <div class="faq-answer">DNS propagation typically takes anywhere from a few minutes to 48 hours, depending on the TTL values of the old records and caching behavior of ISP resolvers worldwide. Most changes propagate within 1-4 hours. You can check propagation by querying different DNS resolvers like Cloudflare (1.1.1.1) and Google (8.8.8.8).</div>
            </div>
        </div>

    </main>
    </div>`

export const meta = {
  title: "DNS Lookup Tool — Query A, AAAA, MX, TXT, NS, CNAME, SOA Records",
  description: "Free online DNS lookup tool. Query A, AAAA, CNAME, MX, TXT, NS, and SOA records for any domain using Cloudflare DNS-over-HTTPS. Client-side, private, instant.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="DNS Lookup Tool — Query A, AAAA, MX, TXT, NS, CNAME, SOA Records"
  description="Free online DNS lookup tool. Query A, AAAA, CNAME, MX, TXT, NS, and SOA records for any domain using Cloudflare DNS-over-HTTPS. Client-side, private, instant."
  canonical="https://siliconbased.dev/dns-lookup"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
        var RECORD_TYPES = ['A', 'AAAA', 'CNAME', 'MX', 'TXT', 'NS', 'SOA'];
        var TYPE_MAP = { A: 1, AAAA: 28, CNAME: 5, MX: 15, TXT: 16, NS: 2, SOA: 6 };

        document.getElementById('domainInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') lookupDns();
        });

        function formatTTL(seconds) {
            if (seconds < 60) return seconds + 's';
            if (seconds < 3600) return Math.floor(seconds / 60) + 'm ' + (seconds % 60) + 's';
            var h = Math.floor(seconds / 3600);
            var m = Math.floor((seconds % 3600) / 60);
            return h + 'h ' + m + 'm';
        }

        function stripTrailingDot(s) {
            return s && s.endsWith('.') ? s.slice(0, -1) : s;
        }

        async function queryDNS(domain, type) {
            var url = 'https://cloudflare-dns.com/dns-query?name=' + encodeURIComponent(domain) + '&type=' + type;
            var resp = await fetch(url, {
                headers: { 'Accept': 'application/dns-json' }
            });
            if (!resp.ok) throw new Error('DNS query failed for ' + type);
            return resp.json();
        }

        function renderRows(containerId, records, renderer) {
            var container = document.getElementById(containerId);
            var rows = container.querySelectorAll('.table-row');
            rows.forEach(function(r) { r.remove(); });

            if (!records || records.length === 0) {
                var row = document.createElement('div');
                row.className = 'table-row empty-row';
                row.innerHTML = '<span style="color:var(--text-muted);grid-column:1/-1;">No records found</span>';
                container.appendChild(row);
                return;
            }

            records.forEach(function(rec) {
                var row = document.createElement('div');
                row.className = 'table-row';
                row.innerHTML = renderer(rec);
                container.appendChild(row);
            });
        }

        async function lookupDns() {
            var domain = document.getElementById('domainInput').value.trim();
            var btnText = document.getElementById('btnText');
            var btnLoader = document.getElementById('btnLoader');
            var errorMsg = document.getElementById('errorMsg');
            var resultsArea = document.getElementById('resultsArea');

            // Strip protocol, path, port
            domain = domain.replace(/^https?:\/\//, '').replace(/\/.*$/, '').replace(/:\d+$/, '');

            if (!domain || !/^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?(\.[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$/.test(domain)) {
                errorMsg.innerText = 'Please enter a valid domain name (e.g., example.com).';
                errorMsg.style.display = 'block';
                return;
            }

            document.getElementById('domainInput').value = domain;

            // Loading state
            btnText.style.display = 'none';
            btnLoader.style.display = 'block';
            errorMsg.style.display = 'none';
            resultsArea.style.display = 'none';

            try {
                var results = await Promise.allSettled(
                    RECORD_TYPES.map(function(type) { return queryDNS(domain, type); })
                );

                var data = {};
                RECORD_TYPES.forEach(function(type, i) {
                    if (results[i].status === 'fulfilled') {
                        data[type] = results[i].value.Answer || [];
                    } else {
                        data[type] = [];
                    }
                });

                // Filter to matching type only
                RECORD_TYPES.forEach(function(type) {
                    data[type] = data[type].filter(function(r) { return r.type === TYPE_MAP[type]; });
                });

                // A records
                renderRows('tableA', data.A, function(r) {
                    return '<span class="mono-val">' + r.data + '</span><span class="ttl-val">' + formatTTL(r.TTL) + '</span>';
                });

                // AAAA records
                renderRows('tableAAAA', data.AAAA, function(r) {
                    return '<span class="mono-val">' + r.data + '</span><span class="ttl-val">' + formatTTL(r.TTL) + '</span>';
                });

                // CNAME records
                renderRows('tableCNAME', data.CNAME, function(r) {
                    return '<span class="mono-val">' + stripTrailingDot(r.data) + '</span><span class="ttl-val">' + formatTTL(r.TTL) + '</span>';
                });

                // MX records
                renderRows('tableMX', data.MX, function(r) {
                    var parts = r.data.split(' ');
                    var priority = parts[0];
                    var server = stripTrailingDot(parts.slice(1).join(' '));
                    return '<span class="mono-val">' + priority + '</span><span class="mono-val">' + server + '</span><span class="ttl-val">' + formatTTL(r.TTL) + '</span>';
                });

                // TXT records
                renderRows('tableTXT', data.TXT, function(r) {
                    var val = r.data;
                    if (val.startsWith('"') && val.endsWith('"')) val = val.slice(1, -1);
                    return '<span class="mono-val txt-val">' + val.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span><span class="ttl-val">' + formatTTL(r.TTL) + '</span>';
                });

                // NS records
                renderRows('tableNS', data.NS, function(r) {
                    return '<span class="mono-val">' + stripTrailingDot(r.data) + '</span><span class="ttl-val">' + formatTTL(r.TTL) + '</span>';
                });

                // SOA record
                if (data.SOA.length > 0) {
                    var soa = data.SOA[0].data.split(' ');
                    var soaFields = [
                        { label: 'Primary NS', value: stripTrailingDot(soa[0]) },
                        { label: 'Admin Email', value: stripTrailingDot(soa[1]) },
                        { label: 'Serial', value: soa[2] },
                        { label: 'Refresh', value: formatTTL(parseInt(soa[3])) },
                        { label: 'Retry', value: formatTTL(parseInt(soa[4])) },
                        { label: 'Expire', value: formatTTL(parseInt(soa[5])) },
                        { label: 'Min TTL', value: formatTTL(parseInt(soa[6])) }
                    ];
                    var container = document.getElementById('tableSOA');
                    var rows = container.querySelectorAll('.table-row');
                    rows.forEach(function(r) { r.remove(); });
                    soaFields.forEach(function(f) {
                        var row = document.createElement('div');
                        row.className = 'table-row';
                        row.innerHTML = '<span class="soa-label">' + f.label + '</span><span class="mono-val">' + f.value + '</span>';
                        container.appendChild(row);
                    });
                } else {
                    renderRows('tableSOA', [], function() { return ''; });
                }

                resultsArea.style.display = 'block';

            } catch (error) {
                errorMsg.innerText = error.message || 'DNS lookup failed. Please try again.';
                errorMsg.style.display = 'block';
            } finally {
                btnText.style.display = 'block';
                btnLoader.style.display = 'none';
            }
        }
    </script>

  <style is:inline>

        .page-content {
            --bg-color: #060a12;
            --card-bg: #0a1020;
            --border-color: #152040;
            --accent-color: #818cf8;
            --text-main: #e2e8f0;
            --text-muted: #94a3b8;
            --success: #10b981;
            --error: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        .page-content {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem;
            width: 100%;
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            background: linear-gradient(to right, #fff, var(--accent-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Search Section */
        .search-container {
            max-width: 800px;
            margin: 0 auto 3rem;
            display: flex;
            gap: 1rem;
            background: var(--card-bg);
            padding: 1rem;
            border-radius: 0.75rem;
            border: 1px solid var(--border-color);
        }

        input[type="text"] {
            flex: 1;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 1rem;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        button {
            background: var(--accent-color);
            color: #fff;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        button:hover {
            opacity: 0.9;
        }

        /* Record Sections */
        .record-section {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 0.75rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .record-section h2 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
            color: var(--accent-color);
        }

        .record-desc {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        .records-table {
            width: 100%;
        }

        .table-header {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 1rem;
            padding: 0.5rem 0.75rem;
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border-color);
        }

        #tableMX .table-header {
            grid-template-columns: 80px 1fr auto;
        }

        #tableSOA .table-header {
            grid-template-columns: 140px 1fr;
        }

        .table-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 1rem;
            padding: 0.65rem 0.75rem;
            border-bottom: 1px solid var(--border-color);
            align-items: center;
        }

        .table-row:last-child {
            border-bottom: none;
        }

        #tableMX .table-row {
            grid-template-columns: 80px 1fr auto;
        }

        #tableSOA .table-row {
            grid-template-columns: 140px 1fr;
        }

        .mono-val {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
            word-break: break-all;
        }

        .txt-val {
            font-size: 0.8rem;
        }

        .ttl-val {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            color: var(--text-muted);
            white-space: nowrap;
        }

        .soa-label {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .empty-row {
            display: block;
            padding: 0.75rem;
        }

        /* Comparison Table */
        .comparison-table {
            width: 100%;
            margin-top: 1rem;
        }

        .comp-row {
            display: grid;
            grid-template-columns: 80px 1fr 1fr;
            gap: 1rem;
            padding: 0.75rem;
            border-bottom: 1px solid var(--border-color);
            align-items: center;
        }

        .comp-row:last-child {
            border-bottom: none;
        }

        .comp-header {
            font-size: 0.8rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .comp-type {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            color: var(--accent-color);
        }

        .comp-mono {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            word-break: break-all;
            color: var(--text-muted);
        }

        /* Content Sections */
        .content-section {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 0.75rem;
            padding: 2rem;
            margin-bottom: 3rem;
        }

        .content-section h2 {
            font-size: 1.75rem;
            margin-bottom: 1.5rem;
            color: #fff;
        }

        .content-section p {
            margin-bottom: 1rem;
            color: var(--text-muted);
        }

        .content-section code {
            background: rgba(129, 140, 248, 0.15);
            color: var(--accent-color);
            padding: 0.15rem 0.4rem;
            border-radius: 0.25rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
        }

        /* FAQ Section */
        .faq-item {
            margin-bottom: 1.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }

        .faq-item:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
        }

        .faq-question {
            font-size: 1.1rem;
            font-weight: 600;
