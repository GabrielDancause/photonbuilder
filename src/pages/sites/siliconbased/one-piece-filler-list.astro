    .article-body h3 { margin-top: 1.5rem; margin-bottom: 0.75rem; color: var(--text-primary); }
    .article-body p { margin-bottom: 1.2rem; line-height: 1.7; color: var(--text-secondary); }
    .article-body ul, .article-body ol { margin-bottom: 1.2rem; padding-left: 2rem; color: var(--text-secondary); }
    .article-body li { margin-bottom: 0.5rem; line-height: 1.6; }
    .article-body pre { margin: 0; padding: 1rem; border-radius: 4px; background: #1a1a2e; color: #a9b1d6; overflow-x: auto; }
    .article-body code { font-family: monospace; font-size: 0.9em; }
