      {
        "@type": "Question",
        "name": "Can your primary love language change over time?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, love languages can evolve. Major life events, trauma, aging, or significant changes in your environment or relationship dynamics can shift your primary emotional needs."
        }
      },
      {
        "@type": "Question",
        "name": "Is it possible to have more than one love language?",
        "acceptedAnswer": {
          "@type": "Answer",
