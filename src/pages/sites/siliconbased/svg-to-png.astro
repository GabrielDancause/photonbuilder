---

<SiteLayout
  site="siliconbased"
  title="SVG to PNG Converter — Convert SVG to PNG Online"
  description="Free online SVG to PNG converter with custom dimensions, retina scaling, transparent backgrounds, and Base64 data URL output. No data leaves your browser."
  canonical="https://siliconbased.dev/svg-to-png"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const inputArea = document.getElementById('inputArea');
const inputCount = document.getElementById('inputCount');
const clearBtn = document.getElementById('clearBtn');
const fileInput = document.getElementById('fileInput');
const dropOverlay = document.getElementById('dropOverlay');
const transparentToggle = document.getElementById('transparentToggle');
const lockRatioToggle = document.getElementById('lockRatioToggle');
const bgColorInput = document.getElementById('bgColorInput');
const bgColorLabel = document.getElementById('bgColorLabel');
const colorPickWrap = document.getElementById('colorPickWrap');
const widthInput = document.getElementById('widthInput');
const heightInput = document.getElementById('heightInput');
const dimInfo = document.getElementById('dimInfo');
const previewBox = document.getElementById('previewBox');
const previewPlaceholder = document.getElementById('previewPlaceholder');
const previewCanvas = document.getElementById('previewCanvas');
const previewImg = document.getElementById('previewImg');
const downloadBtn = document.getElementById('downloadBtn');
const copyDataUrlBtn = document.getElementById('copyDataUrlBtn');
const sizeCompare = document.getElementById('sizeCompare');
const svgSizeEl = document.getElementById('svgSize');
const pngSizeEl = document.getElementById('pngSize');
const sizeRatioEl = document.getElementById('sizeRatio');
const scaleBtns = document.querySelectorAll('.scale-btn');

let scale = 1;
let svgNaturalW = 0;
let svgNaturalH = 0;
let lastPngDataUrl = '';
let lastPngBlob = null;

function init() {
  inputArea.addEventListener('input', debounce(convert, 300));

  clearBtn.addEventListener('click', () => {
    inputArea.value = '';
    resetPreview();
    inputArea.focus();
  });

  transparentToggle.addEventListener('change', () => {
    colorPickWrap.style.display = transparentToggle.checked ? 'none' : 'flex';
    convert();
  });

  bgColorInput.addEventListener('input', () => {
    bgColorLabel.textContent = bgColorInput.value;
    convert();
  });

  lockRatioToggle.addEventListener('change', () => {});

  widthInput.addEventListener('input', () => {
    if (lockRatioToggle.checked && svgNaturalW > 0 && svgNaturalH > 0) {
      const w = parseInt(widthInput.value);
      if (w > 0) heightInput.value = Math.round(w * (svgNaturalH / svgNaturalW));
    }
    convert();
  });

  heightInput.addEventListener('input', () => {
    if (lockRatioToggle.checked && svgNaturalW > 0 && svgNaturalH > 0) {
      const h = parseInt(heightInput.value);
      if (h > 0) widthInput.value = Math.round(h * (svgNaturalW / svgNaturalH));
    }
    convert();
  });

  scaleBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      scaleBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      scale = parseInt(btn.dataset.scale);
      convert();
    });
  });

  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      const reader = new FileReader();
      reader.onload = (ev) => {
        inputArea.value = ev.target.result;
        convert();
      };
      reader.readAsText(e.target.files[0]);
      e.target.value = '';
    }
  });

  downloadBtn.addEventListener('click', () => {
    if (!lastPngBlob) return;
    const url = URL.createObjectURL(lastPngBlob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'converted.png';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  copyDataUrlBtn.addEventListener('click', () => {
    if (!lastPngDataUrl) return;
    navigator.clipboard.writeText(lastPngDataUrl).then(() => {
      copyDataUrlBtn.textContent = '\u2713 Copied';
      setTimeout(() => { copyDataUrlBtn.textContent = 'Copy Data URL'; }, 1500);
    });
  });

  // Drag & drop
  const mainEl = document.querySelector('.main');
  mainEl.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropOverlay.style.display = 'flex';
  });
  mainEl.addEventListener('dragleave', (e) => {
    if (!mainEl.contains(e.relatedTarget)) {
      dropOverlay.style.display = 'none';
    }
  });
  mainEl.addEventListener('drop', (e) => {
    e.preventDefault();
    dropOverlay.style.display = 'none';
    if (e.dataTransfer.files.length > 0) {
      const file = e.dataTransfer.files[0];
      if (file.type === 'image/svg+xml' || file.name.endsWith('.svg')) {
        const reader = new FileReader();
        reader.onload = (ev) => {
          inputArea.value = ev.target.result;
          convert();
        };
        reader.readAsText(file);
      }
    }
  });

  updateInputCount();
}

function debounce(fn, ms) {
  let t;
  return function() {
    clearTimeout(t);
    t = setTimeout(fn, ms);
  };
}

function resetPreview() {
  previewPlaceholder.style.display = 'block';
  previewImg.style.display = 'none';
  previewCanvas.style.display = 'none';
  sizeCompare.style.display = 'none';
  lastPngDataUrl = '';
  lastPngBlob = null;
  svgNaturalW = 0;
  svgNaturalH = 0;
  dimInfo.textContent = 'Detected: \u2014 \u00d7 \u2014';
  updateInputCount();
}

function updateInputCount() {
  const c = inputArea.value.length;
  inputCount.textContent = c.toLocaleString() + ' character' + (c !== 1 ? 's' : '');
}

function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / 1048576).toFixed(1) + ' MB';
}

function convert() {
  updateInputCount();
  const svgText = inputArea.value.trim();
  if (!svgText) { resetPreview(); return; }

  // Validate it looks like SVG
  if (!svgText.includes('<svg')) {
    resetPreview();
    previewPlaceholder.textContent = 'Invalid SVG: no <svg> element found';
    previewPlaceholder.style.display = 'block';
    return;
  }

  const svgBytes = new Blob([svgText], { type: 'image/svg+xml' }).size;
  const svgUrl = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svgText);

  const img = new Image();
  img.onload = function() {
    svgNaturalW = img.naturalWidth || img.width || 300;
    svgNaturalH = img.naturalHeight || img.height || 150;

    dimInfo.textContent = 'Detected: ' + svgNaturalW + ' \u00d7 ' + svgNaturalH;

    let outW = parseInt(widthInput.value) || svgNaturalW;
    let outH = parseInt(heightInput.value) || svgNaturalH;

    // If neither dimension was user-set, use natural
    if (!widthInput.value && !heightInput.value) {
      outW = svgNaturalW;
      outH = svgNaturalH;
    }

    const canvasW = outW * scale;
    const canvasH = outH * scale;

    const canvas = document.createElement('canvas');
    canvas.width = canvasW;
    canvas.height = canvasH;
    const ctx = canvas.getContext('2d');

    // Background
    if (!transparentToggle.checked) {
      ctx.fillStyle = bgColorInput.value;
      ctx.fillRect(0, 0, canvasW, canvasH);
    }

    ctx.drawImage(img, 0, 0, canvasW, canvasH);

    canvas.toBlob(function(blob) {
      if (!blob) return;
      lastPngBlob = blob;
      lastPngDataUrl = canvas.toDataURL('image/png');

      // Show preview
      previewPlaceholder.style.display = 'none';
      previewImg.src = lastPngDataUrl;
      previewImg.style.display = 'block';

      // Size comparison
      svgSizeEl.textContent = formatSize(svgBytes);
      pngSizeEl.textContent = formatSize(blob.size);
      const ratio = blob.size / svgBytes;
      sizeRatioEl.textContent = ratio > 1
        ? (ratio.toFixed(1) + 'x larger')
        : ((1 / ratio).toFixed(1) + 'x smaller');
      sizeCompare.style.display = 'flex';
    }, 'image/png');
  };

  img.onerror = function() {
    resetPreview();
    previewPlaceholder.textContent = 'Error rendering SVG';
    previewPlaceholder.style.display = 'block';
  };

  img.src = svgUrl;
}

init();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
