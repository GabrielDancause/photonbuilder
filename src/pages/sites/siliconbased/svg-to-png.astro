---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "SVG to PNG Converter — Convert SVG to PNG Online",
      "url": "https://siliconbased.dev/svg-to-png",
      "description": "Free online SVG to PNG converter with custom dimensions, retina scaling, transparent backgrounds, and Base64 data URL output. Runs entirely in your browser.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I convert SVG to PNG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your SVG code into the input area or drag and drop an SVG file. The tool renders the SVG on a hidden canvas and converts it to a PNG image. You can set custom width and height, choose a scale factor for retina displays, and pick a transparent or solid background color before downloading."
          }
        },
        {
          "@type": "Question",
          "name": "What are the scale options (1x, 2x, 3x, 4x)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Scale options multiply the output resolution. A 100x100 SVG at 2x produces a 200x200 PNG, which looks crisp on retina displays. 1x gives standard resolution, 2x is ideal for most high-DPI screens, 3x for mobile retina, and 4x for print or very high resolution needs."
          }
        },
        {
          "@type": "Question",
          "name": "Can I set a transparent background?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. By default the converter uses a transparent background. You can toggle this off and pick any custom background color using the color picker. The transparency is preserved in the PNG output since PNG supports an alpha channel."
          }
        },
        {
          "@type": "Question",
          "name": "Is my SVG data sent to a server?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. All conversion happens entirely in your browser using the Canvas API and JavaScript. Your SVG code and the generated PNG never leave your device. No data is uploaded to any server."
          }
        },
        {
          "@type": "Question",
          "name": "Can I get a Base64 data URL of the PNG?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. After conversion, click the 'Copy Data URL' button to copy the PNG as a Base64-encoded data URI. This is useful for embedding the image directly in HTML or CSS without a separate file."
          }
        }
      ]
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>SVG to PNG Converter</h1>
  <p>Convert SVG to high-quality PNG with custom dimensions, retina scaling, and transparent backgrounds — all in your browser.</p>
</div>

<div class="main">

  <!-- Options Bar -->
  <div class="options-bar">
    <div class="options-left">
      <label class="toggle-label">
        <input type="checkbox" id="transparentToggle" checked />
        <span class="toggle-text">Transparent Background</span>
      </label>
      <label class="toggle-label">
        <input type="checkbox" id="lockRatioToggle" checked />
        <span class="toggle-text">Lock Aspect Ratio</span>
      </label>
      <div class="color-pick" id="colorPickWrap" style="display:none;">
        <input type="color" id="bgColorInput" value="#ffffff" />
        <span class="toggle-text" id="bgColorLabel">#ffffff</span>
      </div>
    </div>
    <div class="options-right">
      <button class="scale-btn active" data-scale="1">1x</button>
      <button class="scale-btn" data-scale="2">2x</button>
      <button class="scale-btn" data-scale="3">3x</button>
      <button class="scale-btn" data-scale="4">4x</button>
    </div>
  </div>

  <!-- Dimensions Bar -->
  <div class="dims-bar">
    <div class="dim-group">
      <label class="dim-label" for="widthInput">Width</label>
      <input type="number" id="widthInput" class="dim-input" min="1" max="8192" placeholder="auto" />
    </div>
    <span class="dim-x">&times;</span>
    <div class="dim-group">
      <label class="dim-label" for="heightInput">Height</label>
      <input type="number" id="heightInput" class="dim-input" min="1" max="8192" placeholder="auto" />
    </div>
    <div class="dim-info" id="dimInfo">Detected: — &times; —</div>
  </div>

  <!-- Two-panel layout -->
  <div class="tool-grid">
    <!-- Input -->
    <div class="pane">
      <div class="input-header">
        <div class="header-title">SVG Input</div>
        <div class="header-actions">
          <label class="action-btn upload-label">
            Upload SVG
            <input type="file" id="fileInput" accept=".svg,image/svg+xml" hidden />
          </label>
          <button class="action-btn" id="clearBtn">Clear</button>
        </div>
      </div>
      <textarea id="inputArea" class="code-area" spellcheck="false" placeholder="Paste SVG code here, or drag & drop an SVG file..."></textarea>
      <div class="char-count" id="inputCount">0 characters</div>
    </div>

    <!-- Preview -->
    <div class="pane">
      <div class="output-header">
        <div class="header-title">Preview</div>
        <div class="header-actions">
          <button class="copy-btn" id="copyDataUrlBtn">Copy Data URL</button>
          <button class="copy-btn primary-btn" id="downloadBtn">Download PNG</button>
        </div>
      </div>
      <div class="preview-box" id="previewBox">
        <div class="preview-placeholder" id="previewPlaceholder">PNG preview will appear here...</div>
        <canvas id="previewCanvas" style="display:none;"></canvas>
        <img id="previewImg" style="display:none;" alt="PNG preview" />
      </div>
      <div class="size-compare" id="sizeCompare" style="display:none;">
        <span class="size-tag">SVG: <strong id="svgSize">—</strong></span>
        <span class="size-arrow">&rarr;</span>
        <span class="size-tag">PNG: <strong id="pngSize">—</strong></span>
        <span class="size-tag ratio-tag" id="sizeRatio"></span>
      </div>
    </div>
  </div>

  <!-- Drop overlay -->
  <div class="drop-overlay" id="dropOverlay">
    <div class="drop-overlay-text">Drop SVG file to convert</div>
  </div>

  <!-- Reference section -->
  <div class="ref-section">
    <div class="input-header">
      <div class="header-title">SVG to PNG Quick Reference</div>
    </div>
    <div class="ref-grid">
      <div class="ref-card">
        <div class="ref-card-title">SVG Format</div>
        <code>Vector-based (scalable)</code>
        <code>XML markup language</code>
        <code>Editable with code</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">PNG Format</div>
        <code>Raster-based (pixels)</code>
        <code>Lossless compression</code>
        <code>Supports transparency</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Retina Scaling</div>
        <code>1x &mdash; standard (72 dpi)</code>
        <code>2x &mdash; retina (144 dpi)</code>
        <code>4x &mdash; print (288 dpi)</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">When to Use PNG</div>
        <code>Social media sharing</code>
        <code>App icons & favicons</code>
        <code>Email & documents</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Canvas API</div>
        <code>drawImage() for render</code>
        <code>toDataURL('image/png')</code>
        <code>toBlob() for download</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Data URI Output</div>
        <code>data:image/png;base64,...</code>
        <code>Embed in img src</code>
        <code>Embed in CSS url()</code>
      </div>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is SVG to PNG Conversion?</h2>
    <p>SVG (Scalable Vector Graphics) is a vector image format that uses XML to describe shapes, paths, and text. While SVGs are perfect for web development — they scale infinitely and have small file sizes — many platforms require raster images like PNG. This tool rasterizes your SVG at any resolution using the browser's Canvas API, producing a high-quality PNG with optional transparency.</p>

    <h2>When to Convert SVG to PNG</h2>
    <ul>
      <li><strong>Social media:</strong> Platforms like Twitter, LinkedIn, and Facebook require raster images for post previews and thumbnails.</li>
      <li><strong>App icons:</strong> iOS and Android app stores require PNG icons at specific pixel dimensions.</li>
      <li><strong>Email:</strong> Most email clients don't render SVG. PNG ensures your images display everywhere.</li>
      <li><strong>Print:</strong> Use 4x scale to generate high-DPI PNGs suitable for print materials.</li>
      <li><strong>Legacy compatibility:</strong> Older browsers and applications may not support SVG rendering.</li>
    </ul>

    <h2>SVG vs PNG Comparison</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Feature</th>
          <th>SVG</th>
          <th>PNG</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Type</td><td>Vector (scalable)</td><td>Raster (fixed pixels)</td></tr>
        <tr><td>Transparency</td><td>Yes</td><td>Yes (alpha channel)</td></tr>
        <tr><td>Animation</td><td>Yes (SMIL, CSS)</td><td>No (use APNG)</td></tr>
        <tr><td>Editable</td><td>Text editor / code</td><td>Image editor only</td></tr>
        <tr><td>Best for</td><td>Icons, logos, UI</td><td>Photos, screenshots</td></tr>
      </tbody>
    </table>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I convert SVG to PNG?</h3>
      <p style="margin-bottom: 16px;">Paste your SVG code into the input area or drag and drop an SVG file. The tool renders the SVG on a hidden canvas and converts it to a PNG image. You can set custom width and height, choose a scale factor for retina displays, and pick a transparent or solid background color before downloading.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What are the scale options (1x, 2x, 3x, 4x)?</h3>
      <p style="margin-bottom: 16px;">Scale options multiply the output resolution. A 100x100 SVG at 2x produces a 200x200 PNG, which looks crisp on retina displays. 1x gives standard resolution, 2x is ideal for most high-DPI screens, 3x for mobile retina, and 4x for print or very high resolution needs.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I set a transparent background?</h3>
      <p style="margin-bottom: 16px;">Yes. By default the converter uses a transparent background. You can toggle this off and pick any custom background color using the color picker. The transparency is preserved in the PNG output since PNG supports an alpha channel.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is my SVG data sent to a server?</h3>
      <p style="margin-bottom: 16px;">No. All conversion happens entirely in your browser using the Canvas API and JavaScript. Your SVG code and the generated PNG never leave your device. No data is uploaded to any server.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I get a Base64 data URL of the PNG?</h3>
      <p style="margin-bottom: 16px;">Yes. After conversion, click the 'Copy Data URL' button to copy the PNG as a Base64-encoded data URI. This is useful for embedding the image directly in HTML or CSS without a separate file.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/base64-encoder-decoder">Base64 Encoder Decoder</a> — Encode and decode Base64 strings with file upload and image preview.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions online with real-time highlighting.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "SVG to PNG Converter — Convert SVG to PNG Online",
