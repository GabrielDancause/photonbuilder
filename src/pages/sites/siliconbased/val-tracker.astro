---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Valorant RR Tracker & Calculator",
  description: "Stop guessing your rank progress. Instantly calculate your net RR, win rate, and games needed to rank up in Valorant.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "siliconbased.dev"
    },
    "publisher": {
      "@type": "Organization",
      "name": "siliconbased.dev"
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is RR calculated in Valorant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Rank Rating (RR) in Valorant is primarily determined by match outcomes (win or loss) and your hidden Matchmaking Rating (MMR) compared to the lobby average. Individual performance (combat score, round differential) also plays a factor, especially in lower ranks, to help players reach their true rank faster."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I dodge a game in Valorant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dodging a match in the agent select screen incurs a -3 RR penalty. Repeated dodges increase this penalty and may result in queue restrictions. Notably, dodging affects your RR but does not affect your hidden MMR."
        }
      },
      {
        "@type": "Question",
        "name": "Why am I losing more RR than I gain?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you are losing more Rank Rating (RR) than you gain for a win, it indicates your visible rank is currently higher than your hidden Matchmaking Rating (MMR). The system is trying to pull your visible rank down to match your actual skill level. You need to string together consistent wins against higher MMR opponents to fix this."
        }
      },
      {
        "@type": "Question",
        "name": "How many games do I need to reach Radiant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Reaching Radiant requires hitting Immortal 3 and then exceeding the regional RR threshold (often 400-500+ RR, depending on the server and act). The exact number of games depends heavily on your current rank, win rate, and average RR gained per win."
        }
      },
      {
        "@type": "Question",
        "name": "Does my combat score affect RR?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Average Combat Score (ACS) and personal performance can provide performance bonuses (indicated by a star) resulting in extra RR gains. This is most impactful below Immortal rank. Once in Immortal, RR gains are strictly win/loss and round differential based."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="siliconbased"
  title={meta.title}
  description={meta.description}
  canonical="https://siliconbased.dev/val-tracker"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Valorant RR Tracker & Calculator</h1>
      <p class="subtitle">Calculate your path to the next rank. Plan your grind based on real RR metrics.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-group">
          <label for="currentRank">Current Rank</label>
          <select id="currentRank">
            <option value="100">Iron 1</option>
            <option value="200">Iron 2</option>
            <option value="300">Iron 3</option>
            <option value="400">Bronze 1</option>
            <option value="500">Bronze 2</option>
            <option value="600">Bronze 3</option>
            <option value="700">Silver 1</option>
            <option value="800">Silver 2</option>
            <option value="900" selected>Silver 3</option>
            <option value="1000">Gold 1</option>
            <option value="1100">Gold 2</option>
            <option value="1200">Gold 3</option>
            <option value="1300">Platinum 1</option>
            <option value="1400">Platinum 2</option>
            <option value="1500">Platinum 3</option>
            <option value="1600">Diamond 1</option>
            <option value="1700">Diamond 2</option>
            <option value="1800">Diamond 3</option>
            <option value="1900">Ascendant 1</option>
            <option value="2000">Ascendant 2</option>
            <option value="2100">Ascendant 3</option>
            <option value="2200">Immortal 1</option>
            <option value="2300">Immortal 2</option>
            <option value="2400">Immortal 3</option>
            <option value="2500">Radiant</option>
          </select>
        </div>
        <div class="input-group">
          <label for="currentRR">Current RR (0-100)</label>
          <input type="number" id="currentRR" value="45" min="0" max="100" />
        </div>

        <div class="input-group">
          <label for="targetRank">Target Rank</label>
          <select id="targetRank">
            <option value="100">Iron 1</option>
            <option value="200">Iron 2</option>
            <option value="300">Iron 3</option>
            <option value="400">Bronze 1</option>
            <option value="500">Bronze 2</option>
            <option value="600">Bronze 3</option>
            <option value="700">Silver 1</option>
            <option value="800">Silver 2</option>
            <option value="900">Silver 3</option>
            <option value="1000">Gold 1</option>
            <option value="1100">Gold 2</option>
            <option value="1200">Gold 3</option>
            <option value="1300" selected>Platinum 1</option>
            <option value="1400">Platinum 2</option>
            <option value="1500">Platinum 3</option>
            <option value="1600">Diamond 1</option>
            <option value="1700">Diamond 2</option>
            <option value="1800">Diamond 3</option>
            <option value="1900">Ascendant 1</option>
            <option value="2000">Ascendant 2</option>
            <option value="2100">Ascendant 3</option>
            <option value="2200">Immortal 1</option>
            <option value="2300">Immortal 2</option>
            <option value="2400">Immortal 3</option>
            <option value="2500">Radiant</option>
          </select>
        </div>
        <div class="input-group">
          <label for="targetRR">Target RR (Optional)</label>
          <input type="number" id="targetRR" value="0" min="0" />
        </div>

        <div class="input-group">
          <label for="avgWin">Avg RR per Win</label>
          <input type="number" id="avgWin" value="18" min="10" max="50" />
        </div>
        <div class="input-group">
          <label for="avgLoss">Avg RR per Loss</label>
          <input type="number" id="avgLoss" value="15" min="10" max="50" />
        </div>

        <div class="input-group" style="grid-column: 1 / -1;">
          <label for="winRate">Expected Win Rate (%)</label>
          <input type="range" id="winRate" value="55" min="40" max="100" step="1" />
          <div class="range-display" id="winRateDisplay">55%</div>
        </div>
      </div>

      <div class="error-message" id="errorState" style="display: none;">
        Target rank must be higher than current rank.
      </div>

      <div class="result-card" id="resultCard">
        <p>Total Net RR Needed</p>
        <div class="result-value" id="totalNetRR">355</div>
        <div class="stats-grid">
          <div class="stat-box">
            <span class="stat-label">Est. Games Needed</span>
            <span class="stat-number" id="estGames">113</span>
          </div>
          <div class="stat-box">
            <span class="stat-label">Net RR per Game</span>
            <span class="stat-number" id="netRRPerGame">+3.15</span>
          </div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Valorant Rank Rating (RR) and MMR</h2>

      <p>Valorant's competitive system relies on two distinct numbers: your visible <strong>Rank Rating (RR)</strong> and your hidden <strong>Matchmaking Rating (MMR)</strong>. While your visible rank is what you see on your profile (e.g., Gold 2, 45 RR), your MMR is what Riot Games actually uses to find matches for you.</p>

      <h3>How the RR Tracker Calculator Works</h3>
      <p>Our RR Tracker Calculator uses a mathematical approach to estimate how long your ranked grind will take. It calculates the total absolute RR difference between your current standing and your goal. For the purposes of this tool, each tier (e.g., Silver 1 to Silver 2) is exactly 100 RR.</p>

      <p>The core formula for estimating the number of games required based on a projected win rate is:</p>

      <pre><code>Net RR per Game = (Win Rate * Avg Win RR) - ((1 - Win Rate) * Avg Loss RR)
Games Needed = Total RR Needed / Net RR per Game</code></pre>

      <p>If your calculated "Net RR per Game" is negative, it means at your current win rate and RR gains/losses, you are statistically projected to de-rank rather than rank up. You must either improve your win rate or improve your hidden MMR (which shifts your RR gains/losses to be more favorable).</p>

      <h3>The Relationship Between Visible Rank and Hidden MMR</h3>
      <p>If you have ever won a game and gained 25 RR, and then lost the next game and only lost 12 RR, this is the MMR system at work. This discrepancy occurs because your hidden MMR is higher than your visible rank. The system recognizes that you are playing against better players or performing exceptionally well, and it is actively "pulling" your visible rank upwards to match your true skill level.</p>

      <p>Conversely, if you gain 13 RR on a win but lose 28 RR on a loss, the system believes your visible rank is inflated. You might have been carried in previous games, or you are consistently underperforming against players of your visible rank. To fix a "broken" MMR, you simply have to consistently win games. There is no shortcut.</p>

      <h3>Rank Tiers and Distribution</h3>
      <p>Valorant features 9 rank tiers: Iron, Bronze, Silver, Gold, Platinum, Diamond, Ascendant, Immortal, and Radiant. Every tier from Iron to Immortal contains 3 sub-ranks (e.g., Diamond 1, Diamond 2, Diamond 3). Radiant is reserved for the top 500 players in a region.</p>

      <p>Most of the player base resides between Silver and Platinum. The competitive distribution roughly follows a bell curve, though Riot occasionally tweaks the distribution thresholds between Episodes to prevent rank inflation or deflation.</p>

      <p>Are you playing multiple games and tracking your hours? Check out our <a href="/timecard-calculator">Timecard Calculator</a> to manage your actual working hours and productivity outside of the game.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How is RR calculated in Valorant?</summary>
        <p>Rank Rating (RR) in Valorant is primarily determined by match outcomes (win or loss) and your hidden Matchmaking Rating (MMR) compared to the lobby average. Individual performance (combat score, round differential) also plays a factor, especially in lower ranks, to help players reach their true rank faster.</p>
      </details>
      <details>
        <summary>What happens if I dodge a game in Valorant?</summary>
        <p>Dodging a match in the agent select screen incurs a -3 RR penalty. Repeated dodges increase this penalty and may result in queue restrictions. Notably, dodging affects your RR but does not affect your hidden MMR.</p>
      </details>
      <details>
        <summary>Why am I losing more RR than I gain?</summary>
        <p>If you are losing more Rank Rating (RR) than you gain for a win, it indicates your visible rank is currently higher than your hidden Matchmaking Rating (MMR). The system is trying to pull your visible rank down to match your actual skill level. You need to string together consistent wins against higher MMR opponents to fix this.</p>
      </details>
      <details>
        <summary>How many games do I need to reach Radiant?</summary>
        <p>Reaching Radiant requires hitting Immortal 3 and then exceeding the regional RR threshold (often 400-500+ RR, depending on the server and act). The exact number of games depends heavily on your current rank, win rate, and average RR gained per win.</p>
      </details>
      <details>
        <summary>Does my combat score affect RR?</summary>
        <p>Yes, Average Combat Score (ACS) and personal performance can provide performance bonuses (indicated by a star) resulting in extra RR gains. This is most impactful below Immortal rank. Once in Immortal, RR gains are strictly win/loss and round differential based.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = {
        currentRank: document.getElementById('currentRank'),
        currentRR: document.getElementById('currentRR'),
        targetRank: document.getElementById('targetRank'),
        targetRR: document.getElementById('targetRR'),
        avgWin: document.getElementById('avgWin'),
        avgLoss: document.getElementById('avgLoss'),
        winRate: document.getElementById('winRate')
      };

      const displays = {
        winRateDisplay: document.getElementById('winRateDisplay'),
        totalNetRR: document.getElementById('totalNetRR'),
        estGames: document.getElementById('estGames'),
        netRRPerGame: document.getElementById('netRRPerGame'),
        errorState: document.getElementById('errorState'),
        resultCard: document.getElementById('resultCard')
      };

      function calculate() {
        const cRank = parseInt(inputs.currentRank.value, 10);
        const cRR = parseInt(inputs.currentRR.value, 10) || 0;
        const tRank = parseInt(inputs.targetRank.value, 10);
        const tRR = parseInt(inputs.targetRR.value, 10) || 0;

        const winRR = parseInt(inputs.avgWin.value, 10) || 18;
        const lossRR = parseInt(inputs.avgLoss.value, 10) || 15;
        const wRate = parseInt(inputs.winRate.value, 10) / 100;

        displays.winRateDisplay.textContent = `${inputs.winRate.value}%`;

        // Validation
        const totalCurrentScore = cRank + cRR;
        const totalTargetScore = tRank + tRR;

        const rrNeeded = totalTargetScore - totalCurrentScore;

        if (rrNeeded <= 0) {
          displays.errorState.style.display = 'block';
          displays.resultCard.style.opacity = '0.5';
          displays.totalNetRR.textContent = '0';
          displays.estGames.textContent = '-';
          displays.netRRPerGame.textContent = '-';
          return;
        } else {
          displays.errorState.style.display = 'none';
          displays.resultCard.style.opacity = '1';
        }

        displays.totalNetRR.textContent = rrNeeded;

        // Calculate expected net RR per game played
        const expectedNetPerGame = (wRate * winRR) - ((1 - wRate) * lossRR);

        const formattedNetPerGame = expectedNetPerGame > 0 ?
          `+${expectedNetPerGame.toFixed(2)}` :
          expectedNetPerGame.toFixed(2);

        displays.netRRPerGame.textContent = formattedNetPerGame;

        if (expectedNetPerGame <= 0) {
          displays.estGames.textContent = "Never (De-ranking)";
          displays.netRRPerGame.style.color = "#ef4444"; // red
        } else {
          const gamesRequired = Math.ceil(rrNeeded / expectedNetPerGame);
          displays.estGames.textContent = gamesRequired.toLocaleString();
          displays.netRRPerGame.style.color = "inherit";
        }
      }

      // Attach event listeners
      Object.values(inputs).forEach(input => {
        input.addEventListener('input', calculate);
        input.addEventListener('change', calculate);
      });

      // Initial calc
      calculate();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 600px) { .calc-grid { grid-template-columns: 1fr; } }

    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    label { font-weight: 600; font-size: 0.95rem; color: var(--text-primary); }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    input[type=range] { padding: 0; }
    .range-display { text-align: right; font-weight: 700; color: var(--accent-color); font-size: 1.2rem; }

    .error-message { background: color-mix(in srgb, #ef4444 15%, transparent); color: #ef4444; padding: 1rem; border-radius: 8px; margin-top: 1.5rem; border: 1px solid #ef4444; font-weight: 600; text-align: center; }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0 0; text-align: center; transition: opacity 0.3s; }
    .result-card p { margin: 0 0 0.5rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; font-size: 0.85rem; }
    .result-value { font-size: 3rem; font-weight: 800; color: var(--accent-color); line-height: 1; margin-bottom: 1.5rem; }

    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; border-top: 1px solid color-mix(in srgb, var(--accent-color) 30%, transparent); padding-top: 1.5rem; }
    .stat-box { display: flex; flex-direction: column; gap: 0.25rem; }
    .stat-label { font-size: 0.85rem; color: var(--text-secondary); }
    .stat-number { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); }

    .explainer { margin-top: 3rem; line-height: 1.7; }
    .explainer h2 { margin-top: 2rem; font-size: 1.8rem; }
    .explainer h3 { margin-top: 1.5rem; font-size: 1.3rem; }
    .explainer pre { background: var(--card-bg); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); overflow-x: auto; font-family: monospace; }
    .explainer a { color: var(--accent-color); text-decoration: none; font-weight: 600; }
    .explainer a:hover { text-decoration: underline; }

    .faq-section { margin-top: 3rem; }
    .faq-section h2 { margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; }
    .faq-section p { margin: 1rem 0 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
