---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Hobonichi Planner Setup & Layout Calculator",
  description: "Find the perfect Hobonichi Techo layout for your workflow. Enter your daily planning needs and our calculator will recommend the ideal size, book, and accessories.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Hobonichi Planner Setup Calculator: Find Your Perfect Techo",
    "description": "Overwhelmed by Hobonichi sizes and layouts? Use our interactive calculator to find the perfect Hobonichi Techo, Weeks, or Cousin setup for your journaling style.",
    "author": {
      "@type": "Organization",
      "name": "Silicon Based"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Silicon Based",
      "logo": {
        "@type": "ImageObject",
        "url": "https://siliconbased.dev/logo.png"
      }
    },
    "datePublished": "2026-03-15",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://siliconbased.dev/hobonichi-planner"
    }
  },
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between the Hobonichi Cousin and Original?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Hobonichi Cousin is A5 size and features a vertical weekly layout in addition to daily pages, making it ideal for detailed scheduling. The Original is A6 size, more portable, and only features monthly and daily pages without the vertical weekly section."
      }
    },
    {
      "@type": "Question",
      "name": "What type of paper is used in Hobonichi planners?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hobonichi planners historically used Tomoe River paper. Recently, they transitioned to Sanzen Tomoe River S paper, which remains ultra-thin, lightweight, and highly resistant to fountain pen bleed-through."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Hobonichi Weeks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Hobonichi Weeks is a slim, wallet-sized planner. It features a horizontal week-at-a-glance layout on the left page and blank grid paper on the right, perfect for minimalist planning and carrying on the go."
      }
    },
    {
      "@type": "Question",
      "name": "Does the Hobonichi Techo come in English?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, Hobonichi offers English versions of their most popular planners, including the Original (A6), Cousin (A5), and Weeks. The Japanese versions remain available and are beloved for their daily quotes."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Avec version of the Hobonichi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Avec is a version of the Hobonichi Original or Cousin that is split into two six-month books (Jan-Jun and Jul-Dec). This reduces the bulk and weight of carrying a full year's planner at once."
      }
    }
  ]
}];
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/hobonichi-planner" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Hobonichi Planner Setup Calculator</h1>
      <p class="subtitle">Discover the ideal Hobonichi Techo size, layout, and accessory combination based on your unique planning style.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-section">
          <h3>Tell us about your workflow</h3>

          <div class="input-group">
            <label for="writing-volume">Daily Writing Volume</label>
            <select id="writing-volume">
              <option value="minimal">Minimal (Brief to-dos, quick notes)</option>
              <option value="moderate" selected>Moderate (Schedule + journaling + tasks)</option>
              <option value="heavy">Heavy (Extensive journaling, scrapbooking, brain dumps)</option>
            </select>
          </div>

          <div class="input-group">
            <label for="schedule-type">Scheduling Needs</label>
            <select id="schedule-type">
              <option value="none">Monthly view only is fine</option>
              <option value="horizontal">Horizontal weekly overview</option>
              <option value="vertical" selected>Detailed vertical timeline (hourly tracking)</option>
              <option value="daily">One full page per day</option>
            </select>
          </div>

          <div class="input-group">
            <label for="portability">Portability Preference</label>
            <select id="portability">
              <option value="pocket">Must fit in a small bag/purse</option>
              <option value="medium" selected>Will carry in a backpack/tote</option>
              <option value="desk">Mostly stays on my desk</option>
            </select>
          </div>

          <div class="input-group">
            <label>Do you prefer to carry a lighter book?</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="split-book" value="yes"> Yes, I prefer splitting the year (Avec)
              </label>
              <label class="radio-label">
                <input type="radio" name="split-book" value="no" checked> No, I want the full year in one book
              </label>
            </div>
          </div>
        </div>

        <div class="result-section">
          <div class="result-card main-result">
            <span class="result-label">Your Recommended Setup</span>
            <div class="result-value" id="recommended-book">Hobonichi Cousin (A5)</div>
            <p id="recommended-desc" style="margin-top: 1rem; color: var(--text-primary); font-size: 1.05rem;">The A5 Cousin provides ample space for moderate to heavy writing and includes the vertical weekly layout necessary for detailed scheduling.</p>
          </div>

          <div class="breakdown">
            <h3>Setup Specifications</h3>
            <div class="breakdown-item">
              <span>Size</span>
              <span id="spec-size" class="spec-value">A5 (148 x 210 mm)</span>
            </div>
            <div class="breakdown-item">
              <span>Format</span>
              <span id="spec-format" class="spec-value">Full Year Book</span>
            </div>
            <div class="breakdown-item">
              <span>Key Layouts</span>
              <span id="spec-layouts" class="spec-value">Monthly, Vertical Weekly, Daily Pages</span>
            </div>
            <div class="breakdown-item">
              <span>Estimated Weight</span>
              <span id="spec-weight" class="spec-value">~482g</span>
            </div>
            <div class="breakdown-item total">
              <span>Suggested Cover</span>
              <span id="spec-cover" class="spec-value" style="color: var(--accent-color);">A5 Zipper or Butterfly Stopper</span>
            </div>
          </div>
        </div>
      </div>

      <div class="internal-links" style="margin-top: 2rem; font-size: 0.9rem; text-align: center;">
        <p>Planning your budget alongside your daily schedule? Try our <a href="/sites/siliconbased/florida-paycheck-calculator" style="color: var(--accent-color); text-decoration: underline;">Florida Paycheck Calculator</a>.</p>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding the Hobonichi Techo System</h2>
      <p>The Hobonichi Techo (pronounced "tetch-oh," meaning planner or notebook in Japanese) is far more than a simple calendar. It is a highly customizable, meticulously designed system that adapts to almost any workflow. Because of the sheer variety of books, sizes, and layouts available, choosing the correct Hobonichi can be an overwhelming experience for newcomers. Our calculator evaluates your specific needs—writing volume, scheduling style, and portability requirements—to recommend the ideal structural foundation for your planning routine.</p>

      <h3>The Core Layouts: Matching Book to Workflow</h3>
      <p>The Hobonichi lineup is broadly categorized by size and internal layout. Understanding these distinctions is crucial to finding a planner you will actually use consistently.</p>

      <h4>Hobonichi Techo Original (A6 Size)</h4>
      <p>The Original is the foundational book of the Hobonichi brand. It is A6 size (approximately 4.1" x 5.8"), making it highly portable. Its defining feature is the "one page per day" layout. It includes a monthly calendar but <strong>lacks a weekly view</strong>. This makes the Original perfect for those who write moderate daily notes, journal, or track to-dos, but who do not need to visualize a busy hourly schedule across an entire week.</p>

      <h4>Hobonichi Techo Cousin (A5 Size)</h4>
      <p>The Cousin is the larger sibling to the Original. At A5 size (approximately 5.8" x 8.3"), it offers double the page space. Most importantly, the Cousin introduces a <strong>vertical weekly layout</strong> in addition to the monthly and daily pages. This vertical layout features hourly timelines from 5:00 AM to 4:00 AM the next day. The Cousin is the ultimate workhorse for professionals, students, or anyone who needs detailed time-blocking alongside extensive daily journaling or meeting notes.</p>

      <h4>Hobonichi Weeks (Wallet Size)</h4>
      <p>The Weeks breaks away from the daily page format. It is a long, slim planner (roughly the height of an A6 but narrower). It features a horizontal week-at-a-glance on the left page and blank grid paper on the right. This format is heavily favored by minimalists, financial trackers, and those who prioritize portability above all else. Because it lacks daily pages, it cannot accommodate heavy daily journaling, but it excels at task management and high-level scheduling.</p>

      <h4>Hobonichi Day-Free</h4>
      <p>Available in A6 and A5, the Day-Free includes monthly calendars followed entirely by blank grid pages (no dated daily pages). This is ideal for those whose daily writing volume fluctuates wildly—some days requiring three pages, other days requiring none. It removes the guilt of "blank dated pages."</p>

      <h3>The "Avec" System: Managing Bulk</h3>
      <p>One of the primary concerns with the Original and Cousin models is their thickness. Because they contain a full page for every day of the year, plus monthly and weekly (for Cousin) layouts, they can become quite thick, especially if you add stickers, washi tape, or photos (a process affectionately known as "chunking" the planner).</p>
      <p>To combat this, Hobonichi offers the <strong>Avec</strong> versions. The Avec takes the Original or Cousin and splits it into two separate, six-month books: Book 1 covers January through June, and Book 2 covers July through December. By only carrying half the year at a time, you significantly reduce the weight and bulk of your everyday carry. Our calculator automatically suggests the Avec if you indicate a preference for a lighter book combined with heavy writing needs.</p>

      <h3>The Magic of Tomoe River Paper</h3>
      <p>No discussion of the Hobonichi system is complete without mentioning its paper. Historically, Hobonichi utilized Tomoe River paper, a legendary Japanese paper renowned for being incredibly thin (allowing a 400-page book to remain manageable) while simultaneously being highly resistant to ink bleed-through. It is a favorite among fountain pen enthusiasts.</p>
      <p>Recently, production shifted to the new Sanzen Tomoe River S paper. While slightly different in texture, it maintains the core properties that make Hobonichi planners unique: it is lightweight, durable, and handles a variety of inks and watercolors beautifully. Because the paper is so thin, "ghosting" (seeing the shadow of writing on the reverse side of the page) is normal and often embraced by the community, but actual bleed-through is rare unless heavy, wet markers are used.</p>

      <h3>Accessories and Covers</h3>
      <p>The final layer of the Hobonichi system is the cover. Hobonichi books are sold as bare, cardstock-bound volumes intended to be slipped into a reusable cover. The covers range from simple solid colors to elaborate collaborations with artists, fashion brands, and video games (like Nintendo). The standard covers feature "butterfly stoppers"—two pen loops that, when a pen is threaded through both, keep the book securely closed. For those who carry loose papers, receipts, or need maximum protection, zipper covers are also highly recommended.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is the difference between the Hobonichi Cousin and Original?</summary>
        <p>The Hobonichi Cousin is A5 size and features a vertical weekly layout in addition to daily pages, making it ideal for detailed scheduling. The Original is A6 size, more portable, and only features monthly and daily pages without the vertical weekly section.</p>
      </details>
      <details>
        <summary>What type of paper is used in Hobonichi planners?</summary>
        <p>Hobonichi planners historically used Tomoe River paper. Recently, they transitioned to Sanzen Tomoe River S paper, which remains ultra-thin, lightweight, and highly resistant to fountain pen bleed-through.</p>
      </details>
      <details>
        <summary>What is the Hobonichi Weeks?</summary>
        <p>The Hobonichi Weeks is a slim, wallet-sized planner. It features a horizontal week-at-a-glance layout on the left page and blank grid paper on the right, perfect for minimalist planning and carrying on the go.</p>
      </details>
      <details>
        <summary>Does the Hobonichi Techo come in English?</summary>
        <p>Yes, Hobonichi offers English versions of their most popular planners, including the Original (A6), Cousin (A5), and Weeks. The Japanese versions remain available and are beloved for their daily quotes.</p>
      </details>
      <details>
        <summary>What is the Avec version of the Hobonichi?</summary>
        <p>The Avec is a version of the Hobonichi Original or Cousin that is split into two six-month books (Jan-Jun and Jul-Dec). This reduces the bulk and weight of carrying a full year's planner at once.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    // Planner Database
    const planners = {
      cousin: {
        name: "Hobonichi Cousin",
        size: "A5 (148 x 210 mm)",
        layouts: "Monthly, Vertical Weekly, Daily",
        weight: "~482g",
        desc: "The A5 Cousin provides ample space for moderate to heavy writing and includes the vertical weekly layout necessary for detailed scheduling.",
        cover: "A5 Butterfly Stopper or Zipper"
      },
      cousinAvec: {
        name: "Hobonichi Cousin Avec (2-Book Set)",
        size: "A5 (148 x 210 mm)",
        layouts: "Monthly, Vertical Weekly, Daily",
        weight: "~278g per book",
        desc: "The Cousin Avec offers all the space and vertical scheduling of the A5 size, but splits the year into two lighter books to reduce bulk.",
        cover: "A5 Butterfly Stopper or Zipper"
      },
      original: {
        name: "Hobonichi Original",
        size: "A6 (105 x 148 mm)",
        layouts: "Monthly, Daily",
        weight: "~208g",
        desc: "The A6 Original is highly portable while still offering a full page per day for journaling or daily tasks. It lacks a weekly view.",
        cover: "A6 Butterfly Stopper"
      },
      originalAvec: {
        name: "Hobonichi Original Avec (2-Book Set)",
        size: "A6 (105 x 148 mm)",
        layouts: "Monthly, Daily",
        weight: "~117g per book",
        desc: "The most portable daily option. The A6 Avec splits the year into two extremely light, pocketable books while retaining daily pages.",
        cover: "A6 Butterfly Stopper"
      },
      weeks: {
        name: "Hobonichi Weeks",
        size: "Wallet Size (94 x 188 mm)",
        layouts: "Monthly, Horizontal Weekly + Memo",
        weight: "~130g - 140g",
        desc: "The Weeks is the ultimate portable planner. Perfect for high-level overviews and task management without the pressure of daily pages.",
        cover: "Clear Cover or Weeks Zipper"
      },
      dayFreeA5: {
        name: "Hobonichi Day-Free (A5)",
        size: "A5 (148 x 210 mm)",
        layouts: "Monthly, Blank Grid Pages",
        weight: "~230g",
        desc: "Ideal if your daily writing volume fluctuates wildly. It offers a monthly calendar followed by undated grid pages to use as needed.",
        cover: "A5 Butterfly Stopper"
      },
      dayFreeA6: {
        name: "Hobonichi Day-Free (A6)",
        size: "A6 (105 x 148 mm)",
        layouts: "Monthly, Blank Grid Pages",
        weight: "~110g",
        desc: "A highly portable notebook with a calendar upfront. Use the undated pages for notes, sketches, or inconsistent journaling.",
        cover: "A6 Butterfly Stopper"
      }
    };

    function calculateRecommendation() {
      const volume = document.getElementById('writing-volume').value;
      const schedule = document.getElementById('schedule-type').value;
      const portability = document.getElementById('portability').value;
      const splitBook = document.querySelector('input[name="split-book"]:checked').value;

      let recommendation = 'cousin'; // Default fallback

      // Logic Tree
      if (schedule === 'vertical') {
        recommendation = splitBook === 'yes' ? 'cousinAvec' : 'cousin';
      } else if (schedule === 'horizontal') {
        recommendation = 'weeks';
      } else if (schedule === 'daily' || volume === 'heavy') {
        if (portability === 'pocket') {
          recommendation = splitBook === 'yes' ? 'originalAvec' : 'original';
        } else {
          recommendation = splitBook === 'yes' ? 'cousinAvec' : 'cousin';
        }
      } else if (volume === 'minimal' && schedule === 'none') {
        recommendation = portability === 'pocket' ? 'dayFreeA6' : 'dayFreeA5';
      } else if (volume === 'moderate') {
        if (portability === 'pocket') {
           recommendation = splitBook === 'yes' ? 'originalAvec' : 'original';
        } else {
           // If they want daily pages but moderate writing, original or cousin depends on desk vs carry
           recommendation = portability === 'desk' ? 'cousin' : 'original';
           if (splitBook === 'yes') {
               recommendation = recommendation === 'cousin' ? 'cousinAvec' : 'originalAvec';
           }
        }
      } else {
         // Catch all for general moderate use
         recommendation = portability === 'pocket' ? 'weeks' : 'original';
      }

      // Update UI
      const plan = planners[recommendation];

      document.getElementById('recommended-book').textContent = plan.name;
      document.getElementById('recommended-desc').textContent = plan.desc;

      document.getElementById('spec-size').textContent = plan.size;

      let formatText = "Full Year Book";
      if (recommendation.includes('Avec')) formatText = "Half-Year Books (Avec)";
      if (recommendation.includes('dayFree')) formatText = "Undated Notebook Style";
      document.getElementById('spec-format').textContent = formatText;

      document.getElementById('spec-layouts').textContent = plan.layouts;
      document.getElementById('spec-weight').textContent = plan.weight;
      document.getElementById('spec-cover').textContent = plan.cover;
    }

    // Event Listeners
    document.getElementById('writing-volume').addEventListener('change', calculateRecommendation);
    document.getElementById('schedule-type').addEventListener('change', calculateRecommendation);
    document.getElementById('portability').addEventListener('change', calculateRecommendation);

    const radios = document.querySelectorAll('input[name="split-book"]');
    radios.forEach(radio => radio.addEventListener('change', calculateRecommendation));

    // Initial calculation
    calculateRecommendation();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      margin: 2rem 0;
    }

    .calc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    @media (max-width: 768px) {
      .calc-grid { grid-template-columns: 1fr; }
    }

    .input-section, .result-section {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .input-section h3 {
      margin-top: 0;
      color: var(--accent-color);
      font-size: 1.25rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    .input-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 600;
      color: var(--text-primary);
    }

    select {
      background: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1rem;
      border-radius: 8px;
      width: 100%;
      font-size: 1rem;
      cursor: pointer;
    }

    select:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .radio-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .radio-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: normal;
      cursor: pointer;
    }

    .result-card {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border: 1px solid var(--accent-color);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }

    .result-label {
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      font-size: 0.9rem;
      letter-spacing: 0.5px;
    }

    .result-value {
      font-size: 1.8rem;
      font-weight: 800;
      color: var(--accent-color);
      margin-top: 0.5rem;
      line-height: 1.2;
    }

    .breakdown {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
    }

    .breakdown h3 {
      margin-top: 0;
      margin-bottom: 1rem;
      font-size: 1.1rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
    }

    .breakdown-item {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      font-size: 0.95rem;
      align-items: center;
    }

    .spec-value {
      font-weight: 600;
      text-align: right;
      max-width: 60%;
    }

    .breakdown-item.total {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px dashed var(--border-color);
      font-weight: 700;
      font-size: 1.05rem;
    }

    .explainer {
      margin-top: 3rem;
    }

    .explainer h2 { color: var(--accent-color); margin-top: 2rem; margin-bottom: 1rem; }
    .explainer h3 { margin-top: 1.5rem; margin-bottom: 0.75rem; }
    .explainer h4 { margin-top: 1.2rem; margin-bottom: 0.5rem; color: var(--text-primary); font-size: 1.1rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); line-height: 1.7; }

    .faq-section { margin-top: 3rem; }
    .faq-section h2 { margin-bottom: 1.5rem; color: var(--accent-color); }
    .faq-section details {
      margin: 1rem 0;
      padding: 1rem;
      background: var(--card-bg);
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }
    .faq-section summary {
      font-weight: 600;
      cursor: pointer;
      color: var(--text-primary);
    }
    .faq-section details p {
      margin-top: 1rem;
      margin-bottom: 0;
      color: var(--text-secondary);
    }
  </style>
</SiteLayout>
