import SiteLayout from "../../../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "What is GraphQL? GraphQL vs REST",
    "description": "An in-depth guide to GraphQL architecture, how it compares to REST, understanding queries, mutations, and designing robust schemas.",
    "author": {
      "@type": "Organization",
      "name": "siliconbased.dev"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is GraphQL different from REST?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In REST, you make requests to multiple endpoints to gather different data types, which often leads to over-fetching or under-fetching. In GraphQL, there is a single endpoint, and the client dictates exactly what data structure it wants to receive."
        }
      },
      {
        "@type": "Question",
        "name": "What is the N+1 problem in GraphQL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The N+1 problem occurs when a query fetches a list of N items, and then the server makes N additional database queries to resolve a nested field for each item. This is typically solved using DataLoader to batch and cache database requests."
        }
      },
      {
        "@type": "Question",
        "name": "Can you mutate data with GraphQL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. While REST uses POST, PUT, and DELETE methods to modify data, GraphQL uses a specialized operation type called a Mutation. A mutation acts similarly to a query but is explicitly designated for operations that cause side effects on the server."
        }
      }
    ]
  }
];

export const meta = {
  title: "What is GraphQL? REST vs GraphQL & Schema Design",
  description: "An in-depth guide to GraphQL architecture, how it compares to REST, understanding queries, mutations, and designing robust schemas.",
  category: "guide",
