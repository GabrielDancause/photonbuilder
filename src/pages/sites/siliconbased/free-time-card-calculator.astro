---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Time Card Calculator: Track Work Hours & Pay",
  description: "Calculate your work hours, breaks, and total pay instantly with our free time card calculator. Perfect for hourly employees and freelancers tracking their time.",
  category: "tool",
  published: "2026-03-15"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published
    },
    {
      "@type": "FAQPage",
      "mainEntity": [

        {
                "@type": "Question",
                "name": "How do you calculate total hours worked?",
                "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "To calculate total hours worked, subtract your start time from your end time. If you took an unpaid break, subtract the duration of that break from the total. For example, working from 9:00 AM to 5:00 PM is 8 hours. Subtracting a 30-minute unpaid lunch break leaves 7 hours and 30 minutes, or 7.5 decimal hours."
                }
        },
        {
                "@type": "Question",
                "name": "Why does the calculator use decimal hours?",
                "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Payroll systems process wages using decimal hours rather than minutes because it makes multiplication easier. For instance, 30 minutes is half an hour, so it becomes 0.5 in decimal form. You cannot simply multiply your hourly rate by '8 hours and 15 minutes'; you must convert it to 8.25 decimal hours first to get an accurate gross pay."
                }
        },
        {
                "@type": "Question",
                "name": "Are breaks paid or unpaid?",
                "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Under US federal law, short breaks (usually lasting about 5 to 20 minutes) must be paid and included in your total work hours. However, bona fide meal periods (typically lasting 30 minutes or longer) do not need to be compensated if the employee is completely relieved from duty. Check your state's specific labor laws, as regulations can vary significantly."
                }
        },
        {
                "@type": "Question",
                "name": "Does this time card calculator handle overnight shifts?",
                "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, our time card calculator is designed to seamlessly handle overnight shifts. If your entered end time is chronologically earlier than your start time (for example, starting at 10:00 PM and ending at 6:00 AM), the calculator automatically recognizes that the shift crossed midnight and adds 24 hours to the end time to calculate the correct duration."
                }
        },
        {
                "@type": "Question",
                "name": "What is the difference between gross pay and net pay?",
                "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "This calculator estimates your gross pay, which is the total amount of money you earned before any deductions are taken out. Net pay, often called 'take-home pay,' is the amount you actually receive in your paycheck after federal, state, and local taxes, as well as benefits, retirement contributions, and other deductions have been subtracted."
                }
        }

      ]
    }
  ]
};
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/free-time-card-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Free Time Card Calculator</h1>
      <p class="subtitle">Calculate your daily and weekly work hours, breaks, and gross pay.</p>
    </div>

    <div class="calculator-container">

      <div class="pay-rate-group">
        <label for="hourlyRate">Hourly Rate ($):</label>
        <input type="number" id="hourlyRate" min="0" step="0.25" value="15.00" placeholder="e.g., 15.00">
      </div>

      <div class="controls">
        <button class="clear-btn" onclick="clearTimecard()">Clear All Rows</button>
      </div>

      <table id="timecardTable">
        <thead>
          <tr>
            <th>Day</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Break (Minutes)</th>
            <th>Total Hours</th>
          </tr>
        </thead>
        <tbody>
          <!-- Rows will be generated by JS -->
        </tbody>
      </table>

      <div class="result-card" id="resultCard" style="display: none;">
        <div class="result-box">
          <div class="result-label">Total Weekly Hours</div>
          <div id="totalHoursValue" class="result-value">0.00</div>
        </div>
        <div class="result-box">
          <div class="result-label">Estimated Gross Pay</div>
          <div id="grossPayValue" class="result-value">$0.00</div>
        </div>
      </div>

    </div>

    <div class="explainer">

      <h2>How the Free Time Card Calculator Works</h2>
      <p>Tracking your work hours accurately is essential to ensuring you are compensated fairly for your labor. Whether you are an hourly employee, a freelancer billing clients, or a small business owner processing payroll, our free time card calculator simplifies the math. Instead of manually struggling with time conversions and overnight shifts, this tool instantly processes your daily inputs to determine your total weekly hours and estimates your gross pay based on your hourly rate.</p>

      <p>Calculating time can be confusing because the standard clock uses a base-60 system (60 minutes in an hour), while financial accounting and payroll systems rely on a base-10 decimal system. This calculator bridges that gap by seamlessly converting your recorded time punches into standardized decimal formats ready for payroll processing.</p>

      <h3>Understanding Decimal Hours</h3>
      <p>One of the most common mistakes people make when calculating their pay is multiplying their hourly rate by a literal time format. For example, if you worked 8 hours and 30 minutes at $15 per hour, you cannot simply multiply 15 by 8.30. Thirty minutes is half of an hour, meaning the correct decimal representation is 8.50. Multiplying 15 by 8.50 yields the correct pay of $127.50, whereas the incorrect math would shortchange you.</p>

      <p>The standard conversion formula divides the number of minutes by 60. Here is a quick reference for common time intervals converted into decimals:</p>
      <ul>
        <li>15 minutes = 0.25 hours</li>
        <li>30 minutes = 0.50 hours</li>
        <li>45 minutes = 0.75 hours</li>
        <li>60 minutes = 1.00 hour</li>
      </ul>
      <p>This calculator performs this conversion automatically in the background for every row, ensuring that your daily and weekly totals are presented in the accurate decimal format required for financial calculations.</p>

      <h3>Handling Breaks and Unpaid Time</h3>
      <p>Not all time spent at the workplace is strictly compensated. The Fair Labor Standards Act (FLSA) sets the baseline for how breaks should be handled in the United States. Short rest breaks (usually 5 to 20 minutes) are generally considered compensable work hours. This means they should be included in your start and end times, and you should not deduct them in the break column of this calculator.</p>

      <p>However, bona fide meal periods—typically lasting 30 minutes or more—are completely different. If you are entirely relieved from duty for the purpose of eating regular meals, this time is not considered work time and is unpaid. You should enter the duration of these unpaid meal breaks (in minutes) into the corresponding column. The calculator will automatically subtract this break time from your gross daily shift duration to determine your net compensable hours.</p>

      <h3>Calculating Overnight Shifts</h3>
      <p>Calculating shifts that cross midnight can be mathematically tricky if you are doing it by hand. If you start work at 10:00 PM and finish at 6:00 AM the following day, a simple subtraction formula fails because the end time appears chronologically earlier than the start time. This calculator features built-in overnight shift detection.</p>

      <p>Whenever you enter an end time that is earlier than the start time, the algorithm automatically assumes the shift crossed the midnight threshold. It seamlessly adds 24 hours to the end time on the backend, allowing it to correctly determine that a 10:00 PM to 6:00 AM shift equals 8 hours of total duration.</p>

      <h3>Gross Pay vs. Net Pay</h3>
      <p>It is important to understand that the financial result provided by this calculator represents your <strong>Gross Pay</strong>. Gross pay is the total amount of money you have earned based solely on your hours worked multiplied by your hourly rate. It does not account for any deductions.</p>

      <p>Your <strong>Net Pay</strong>—often referred to as your take-home pay—is the actual amount of money that will be deposited into your bank account on payday. To find your net pay, your employer must subtract mandatory taxes (such as federal income tax, state tax, Social Security, and Medicare), as well as voluntary deductions (like health insurance premiums, retirement plan contributions, or union dues). Because tax brackets and benefit costs vary wildly from person to person, generating an exact net pay calculation requires highly specialized tax software. Therefore, use the gross pay figure provided here as a baseline estimate of your earning potential before obligations are met.</p>

      <h3>Overtime Considerations</h3>
      <p>While this calculator provides an excellent foundation for tracking standard weekly hours, be aware that it does not automatically calculate complex overtime rates (such as time-and-a-half). In many jurisdictions, any time worked over 40 hours in a single 7-day workweek must be paid at a premium rate. Some states also require daily overtime for hours worked beyond 8 hours in a single day. If your total hours exceed your local overtime threshold, your actual gross pay may be higher than the estimate provided here. You would need to manually separate your regular hours from your overtime hours and multiply them by their respective rates.</p>

    </div>

    <div class="related-tools">

      <h3>Related Tools</h3>
      <p>Thinking about the future value of your hard-earned paychecks? Check out our <a href="/life-insurance-calculator">Life Insurance Calculator</a> to see how much coverage you might need to protect your family's financial security.</p>

    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How do you calculate total hours worked?</summary>
        <p>To calculate total hours worked, subtract your start time from your end time. If you took an unpaid break, subtract the duration of that break from the total. For example, working from 9:00 AM to 5:00 PM is 8 hours. Subtracting a 30-minute unpaid lunch break leaves 7 hours and 30 minutes, or 7.5 decimal hours.</p>
      </details>
      <details>
        <summary>Why does the calculator use decimal hours?</summary>
        <p>Payroll systems process wages using decimal hours rather than minutes because it makes multiplication easier. For instance, 30 minutes is half an hour, so it becomes 0.5 in decimal form. You cannot simply multiply your hourly rate by '8 hours and 15 minutes'; you must convert it to 8.25 decimal hours first to get an accurate gross pay.</p>
      </details>
      <details>
        <summary>Are breaks paid or unpaid?</summary>
        <p>Under US federal law, short breaks (usually lasting about 5 to 20 minutes) must be paid and included in your total work hours. However, bona fide meal periods (typically lasting 30 minutes or longer) do not need to be compensated if the employee is completely relieved from duty. Check your state's specific labor laws, as regulations can vary significantly.</p>
      </details>
      <details>
        <summary>Does this time card calculator handle overnight shifts?</summary>
        <p>Yes, our time card calculator is designed to seamlessly handle overnight shifts. If your entered end time is chronologically earlier than your start time (for example, starting at 10:00 PM and ending at 6:00 AM), the calculator automatically recognizes that the shift crossed midnight and adds 24 hours to the end time to calculate the correct duration.</p>
      </details>
      <details>
        <summary>What is the difference between gross pay and net pay?</summary>
        <p>This calculator estimates your gross pay, which is the total amount of money you earned before any deductions are taken out. Net pay, often called 'take-home pay,' is the amount you actually receive in your paycheck after federal, state, and local taxes, as well as benefits, retirement contributions, and other deductions have been subtracted.</p>
      </details>
    </section>
  </div>

  <script is:inline>

    const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];

    function initTable() {
      const tbody = document.querySelector('#timecardTable tbody');
      tbody.innerHTML = '';

      days.forEach(day => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td><strong>${day}</strong></td>
          <td><input type="time" id="start-${day}" class="time-input" aria-label="Start time for ${day}"></td>
          <td><input type="time" id="end-${day}" class="time-input" aria-label="End time for ${day}"></td>
          <td><input type="number" id="break-${day}" class="break-input" min="0" step="5" placeholder="e.g. 30" aria-label="Break minutes for ${day}"></td>
          <td><div class="day-total" id="total-${day}">0.00</div></td>
        `;
        tbody.appendChild(tr);
      });

      // Add event listeners to all new inputs
      document.querySelectorAll('.time-input, .break-input, #hourlyRate').forEach(input => {
        input.addEventListener('input', calculateTimecard);
      });
    }

    function parseTime(timeStr) {
      if (!timeStr) return null;
      const [hours, minutes] = timeStr.split(':').map(Number);
      return (hours * 60) + minutes; // returns total minutes from midnight
    }

    function calculateTimecard() {
      let totalWeeklyMinutes = 0;
      let hasData = false;

      days.forEach(day => {
        const startInput = document.getElementById(`start-${day}`).value;
        const endInput = document.getElementById(`end-${day}`).value;
        const breakInput = document.getElementById(`break-${day}`).value;
        const totalDisplay = document.getElementById(`total-${day}`);

        if (startInput && endInput) {
          hasData = true;
          let startMin = parseTime(startInput);
          let endMin = parseTime(endInput);

          // Handle overnight shifts
          if (endMin < startMin) {
            endMin += (24 * 60);
          }

          let shiftMinutes = endMin - startMin;
          const breakMinutes = Number(breakInput) || 0;

          let netMinutes = shiftMinutes - breakMinutes;
          if (netMinutes < 0) netMinutes = 0;

          totalWeeklyMinutes += netMinutes;

          // Display daily total in decimal hours
          totalDisplay.textContent = (netMinutes / 60).toFixed(2);
        } else {
          totalDisplay.textContent = "0.00";
        }
      });

      const resultCard = document.getElementById('resultCard');
      if (!hasData) {
        resultCard.style.display = 'none';
        return;
      }

      const totalHoursDecimal = totalWeeklyMinutes / 60;
      const hourlyRate = Number(document.getElementById('hourlyRate').value) || 0;
      const grossPay = totalHoursDecimal * hourlyRate;

      document.getElementById('totalHoursValue').textContent = totalHoursDecimal.toFixed(2);
      document.getElementById('grossPayValue').textContent = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD'
      }).format(grossPay);

      resultCard.style.display = 'grid';
    }

    function clearTimecard() {
      document.querySelectorAll('.time-input, .break-input').forEach(input => {
        input.value = '';
      });
      calculateTimecard();
    }

    // Initialize on load
    document.addEventListener('DOMContentLoaded', () => {
      initTable();
    });

  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .pay-rate-group { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .pay-rate-group label { font-weight: 600; white-space: nowrap; }
    .pay-rate-group input { max-width: 150px; }

    table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; }
    th { text-align: left; padding: 0.75rem; border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: 600; }
    td { padding: 0.75rem; border-bottom: 1px solid var(--border-color); vertical-align: middle; }

    input[type="time"], input[type="number"] { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.5rem; border-radius: 6px; width: 100%; font-size: 0.95rem; box-sizing: border-box; }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .day-total { font-weight: 600; color: var(--accent-color); text-align: right; }

    .controls { display: flex; justify-content: flex-end; margin-bottom: 1.5rem; }
    .clear-btn { background: transparent; color: var(--text-secondary); border: 1px solid var(--border-color); padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; font-size: 0.9rem; transition: all 0.2s; }
    .clear-btn:hover { background: var(--border-color); color: var(--text-primary); }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; display: grid; grid-template-columns: 1fr; gap: 1rem; text-align: center; }
    @media (min-width: 600px) {
      .result-card { grid-template-columns: 1fr 1fr; }
    }

    .result-box { padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .result-label { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; }
    .result-value { font-size: 2rem; font-weight: 800; color: var(--accent-color); }

    .explainer { margin: 3rem 0; line-height: 1.7; }
    .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; }
    .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 1rem; }
    .explainer p { margin-bottom: 1.2rem; }
    .explainer ul { margin: 1rem 0 1.5rem 2rem; }
    .explainer li { margin-bottom: 0.5rem; }

    .related-tools { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 3rem 0; }
    .related-tools h3 { margin-top: 0; margin-bottom: 1rem; }
    .related-tools a { color: var(--accent-color); text-decoration: none; font-weight: 600; }
    .related-tools a:hover { text-decoration: underline; }

    .faq-section { margin-top: 4rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; }
    .faq-section p { margin-top: 1rem; margin-bottom: 0; line-height: 1.6; color: var(--text-secondary); }

    /* Responsive Table */
    @media (max-width: 768px) {
      table, thead, tbody, th, td, tr { display: block; }
      thead tr { position: absolute; top: -9999px; left: -9999px; }
      tr { border: 1px solid var(--border-color); border-radius: 8px; margin-bottom: 1rem; padding: 0.5rem; background: var(--card-bg); }
      td { border: none; border-bottom: 1px solid var(--border-color); position: relative; padding-left: 35%; text-align: right; }
      td:last-child { border-bottom: 0; }
      td::before { position: absolute; top: 0.75rem; left: 0.5rem; width: 30%; padding-right: 10px; white-space: nowrap; text-align: left; font-weight: 600; color: var(--text-secondary); }
      td:nth-of-type(1)::before { content: "Day"; }
      td:nth-of-type(2)::before { content: "Start"; }
      td:nth-of-type(3)::before { content: "End"; }
      td:nth-of-type(4)::before { content: "Break (min)"; }
      td:nth-of-type(5)::before { content: "Total"; }
      .day-total { text-align: right; }
    }
  </style>
</SiteLayout>