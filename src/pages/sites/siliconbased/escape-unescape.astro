---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "String Escape & Unescape",
    "url": "https://siliconbased.dev/escape-unescape",
    "description": "Interactive tool to escape and unescape strings for JSON, HTML, XML, URL, JavaScript, CSV, and SQL formats. Runs locally in the browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    }
  }
];
---

<SiteLayout
  site="siliconbased"
  title="String Escape & Unescape | Free Online Tool"
  description="Escape or unescape strings for JSON, HTML, XML, URL, JavaScript, CSV, and SQL. Free, fast, and works entirely offline in your browser."
  canonical="https://siliconbased.dev/escape-unescape"
  schema={schemas}
>
  <style is:inline>
code, pre, .mono { font-family: "JetBrains Mono", monospace; }
.hero { text-align: center; padding: 32px 24px 16px; background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%); }
.hero h1 { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 900px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }
.tabs { display: flex; justify-content: center; gap: 12px; margin-bottom: 24px; }
.tab-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 10px 24px; border-radius: 12px; font-size: 1rem; font-weight: 600; cursor: pointer; font-family: "Inter", sans-serif; transition: all 0.2s; }
.tab-btn:hover { background: #2a2d40; color: #ccc; }
.tab-btn.active { background: #818cf8; color: #fff; border-color: #818cf8; box-shadow: 0 4px 12px rgba(129, 140, 248, 0.2); }
.format-selector { display: flex; justify-content: center; gap: 8px; margin-bottom: 32px; flex-wrap: wrap; }
.format-btn { background: #111318; border: 1px solid #1e2030; color: #888; padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 500; cursor: pointer; font-family: "Inter", sans-serif; transition: all 0.2s; }
.format-btn:hover { background: #1e2030; color: #ccc; border-color: #2a2d40; }
.format-btn.active { background: #2a2d40; color: #fff; border-color: #818cf8; }
.tool-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; margin-bottom: 40px; }
.tool-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; background: #13151d; border-bottom: 1px solid #1e2030; flex-wrap: wrap; gap: 12px; }
.tool-header h3 { font-size: 0.9rem; font-weight: 600; color: #ccc; display: flex; align-items: center; gap: 8px; }
.tool-body { padding: 24px; display: flex; flex-direction: column; gap: 20px; }
.textarea-wrapper { position: relative; display: flex; flex-direction: column; gap: 8px; }
.textarea-label { font-size: 0.85rem; font-weight: 600; color: #818cf8; display: flex; justify-content: space-between; }
.char-count { color: #666; font-weight: 400; font-family: "JetBrains Mono", monospace; font-size: 0.75rem; }
.input-area { width: 100%; min-height: 180px; background: #0a0b10; border: 1px solid #1e2030; border-radius: 12px; padding: 16px; color: #e0e0e0; font-family: "JetBrains Mono", monospace; font-size: 0.95rem; resize: vertical; outline: none; transition: border-color 0.2s; line-height: 1.5; white-space: pre-wrap; word-wrap: break-word; }
.input-area:focus { border-color: #818cf8; }
.input-area::placeholder { color: #444; }
.actions-row { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
.btn { background: #1e2030; border: 1px solid #2a2d40; color: #ccc; padding: 10px 20px; border-radius: 10px; font-size: 0.9rem; font-weight: 600; cursor: pointer; font-family: "Inter", sans-serif; transition: all 0.2s; display: flex; align-items: center; gap: 8px; }
.btn:hover { background: #2a2d40; color: #fff; }
.btn-primary { background: #818cf8; color: #fff; border-color: #818cf8; }
.btn-primary:hover { background: #6366f1; border-color: #6366f1; }
.btn.copied { background: #1a3a1a; color: #4ade80; border-color: #2d5a2d; }
.clear-btn { background: transparent; border: 1px solid #2a2d40; color: #888; padding: 6px 12px; border-radius: 6px; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; }
.clear-btn:hover { background: #1e2030; color: #ef4444; border-color: #ef4444; }
.error-msg { color: #ef4444; font-size: 0.85rem; margin-top: -12px; display: none; }
.error-msg.visible { display: block; }
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }
.seo-content code { background: #111318; padding: 2px 6px; border-radius: 4px; color: #818cf8; font-size: 0.85em; font-family: "JetBrains Mono", monospace; }
.footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #555; border-top: 1px solid #151520; margin-top: auto; }
.footer a { color: #818cf8; text-decoration: none; }
.footer a:hover { text-decoration: underline; }
@media (max-width: 768px) {
  .actions-row { flex-direction: column; align-items: stretch; }
  .btn { justify-content: center; }
  .tool-header { flex-direction: column; align-items: flex-start; }
}
</style>


  <script is:inline>

const tabEscape = document.getElementById('tabEscape');
const tabUnescape = document.getElementById('tabUnescape');
const formatSelector = document.getElementById('formatSelector');
const formatBtns = document.querySelectorAll('.format-btn');
const modeTitle = document.getElementById('modeTitle');
const inputLabel = document.getElementById('inputLabel');
const outputLabel = document.getElementById('outputLabel');
const processBtn = document.getElementById('processBtn');
const clearBtn = document.getElementById('clearBtn');
const inputText = document.getElementById('inputText');
const outputText = document.getElementById('outputText');
const inputCount = document.getElementById('inputCount');
const outputCount = document.getElementById('outputCount');
const copyBtn = document.getElementById('copyBtn');
const errorMsg = document.getElementById('errorMsg');

let currentMode = 'escape'; // 'escape' or 'unescape'
let currentFormat = 'json';

function updateCounts() {
  inputCount.textContent = `${inputText.value.length} chars`;
  outputCount.textContent = `${outputText.value.length} chars`;
}

function updateUI() {
  const formatName = currentFormat.toUpperCase() === 'JAVASCRIPT' ? 'JavaScript' : currentFormat.toUpperCase();
  if (currentMode === 'escape') {
    modeTitle.textContent = `Escape ${formatName} String`;
    inputLabel.textContent = 'Input Text';
    outputLabel.textContent = 'Escaped Output';
    processBtn.textContent = 'Escape';
  } else {
    modeTitle.textContent = `Unescape ${formatName} String`;
    inputLabel.textContent = 'Escaped Input';
    outputLabel.textContent = 'Unescaped Output';
    processBtn.textContent = 'Unescape';
  }
}

function showError(show, message = "Invalid input.") {
  if (show) {
    errorMsg.textContent = message;
    errorMsg.classList.add('visible');
    outputText.value = '';
    updateCounts();
  } else {
    errorMsg.classList.remove('visible');
  }
}

// Escaping logic
function escapeString(text, format) {
  if (!text) return '';
  switch (format) {
    case 'json':
      return JSON.stringify(text).slice(1, -1);
    case 'html':
      return text.replace(/&/g, '&amp;')
                 .replace(/</g, '&lt;')
                 .replace(/>/g, '&gt;')
                 .replace(/"/g, '&quot;')
                 .replace(/'/g, '&#39;');
    case 'xml':
      return text.replace(/&/g, '&amp;')
                 .replace(/</g, '&lt;')
                 .replace(/>/g, '&gt;')
                 .replace(/"/g, '&quot;')
                 .replace(/'/g, '&apos;');
    case 'url':
      return encodeURIComponent(text);
    case 'javascript':
      return text.replace(/\\/g, '\\\\')
                 .replace(/'/g, "\\'")
                 .replace(/"/g, '\\"')
                 .replace(/\n/g, '\\n')
                 .replace(/\r/g, '\\r')
                 .replace(/\t/g, '\\t');
    case 'csv':
      if (text.includes('"') || text.includes(',') || text.includes('\n') || text.includes('\r')) {
        return '"' + text.replace(/"/g, '""') + '"';
      }
      return text;
    case 'sql':
      return text.replace(/'/g, "''");
    default:
      return text;
  }
}

// Unescaping logic
function unescapeString(text, format) {
  if (!text) return '';
  switch (format) {
    case 'json':
      try {
        // If it looks like a full JSON object, just try to parse it
        if (text.trim().startsWith('{') || text.trim().startsWith('[')) {
             JSON.parse(text); // check validity
             return text; // It's an object/array, not an escaped string value
        }
        return JSON.parse('"' + text + '"');
      } catch (e) {
        throw new Error("Invalid JSON string format.");
      }
    case 'html':
      return text.replace(/&quot;/g, '"')
                 .replace(/&#39;/g, "'")
                 .replace(/&lt;/g, '<')
                 .replace(/&gt;/g, '>')
                 .replace(/&amp;/g, '&');
    case 'xml':
      return text.replace(/&quot;/g, '"')
                 .replace(/&apos;/g, "'")
                 .replace(/&lt;/g, '<')
                 .replace(/&gt;/g, '>')
                 .replace(/&amp;/g, '&');
    case 'url':
      try {
        return decodeURIComponent(text.replace(/\+/g, '%20'));
      } catch(e) {
        throw new Error("Invalid URL encoding.");
      }
    case 'javascript':
      // Basic unescaping for common characters
      return text.replace(/\\'/g, "'")
                 .replace(/\\"/g, '"')
                 .replace(/\\n/g, '\n')
                 .replace(/\\r/g, '\r')
                 .replace(/\\t/g, '\t')
                 .replace(/\\\\/g, '\\');
    case 'csv':
      if (text.startsWith('"') && text.endsWith('"')) {
        return text.slice(1, -1).replace(/""/g, '"');
      }
      return text;
    case 'sql':
      return text.replace(/''/g, "'");
    default:
      return text;
  }
}

function process() {
  showError(false);
  let text = inputText.value;
  if (!text) {
    outputText.value = '';
    updateCounts();
    return;
  }

  try {
    if (currentMode === 'escape') {
      outputText.value = escapeString(text, currentFormat);
    } else {
      outputText.value = unescapeString(text, currentFormat);
    }
  } catch (e) {
    showError(true, e.message || "Error processing input.");
  }
  updateCounts();
}

// Event Listeners
tabEscape.addEventListener('click', () => {
  if (currentMode === 'escape') return;
  currentMode = 'escape';
  tabEscape.classList.add('active');
  tabUnescape.classList.remove('active');
  updateUI();

  let temp = inputText.value;
  inputText.value = outputText.value;
  outputText.value = temp;

  process();
});

tabUnescape.addEventListener('click', () => {
  if (currentMode === 'unescape') return;
  currentMode = 'unescape';
  tabUnescape.classList.add('active');
  tabEscape.classList.remove('active');
  updateUI();

  let temp = inputText.value;
  inputText.value = outputText.value;
  outputText.value = temp;

  process();
});

formatSelector.addEventListener('click', (e) => {
  if (e.target.classList.contains('format-btn')) {
    formatBtns.forEach(btn => btn.classList.remove('active'));
    e.target.classList.add('active');
    currentFormat = e.target.dataset.format;
    updateUI();
    process();
  }
});

inputText.addEventListener('input', () => {
  process();
});

processBtn.addEventListener('click', process);

clearBtn.addEventListener('click', () => {
  inputText.value = '';
  outputText.value = '';
  showError(false);
  updateCounts();
  inputText.focus();
});

// Copy
copyBtn.addEventListener('click', () => {
  if (!outputText.value) return;
  navigator.clipboard.writeText(outputText.value).then(() => {
    const originalText = copyBtn.innerHTML;
    copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied!';
    copyBtn.classList.add('copied');
    setTimeout(() => {
      copyBtn.innerHTML = originalText;
      copyBtn.classList.remove('copied');
    }, 2000);
  });
});

// Init
updateUI();
updateCounts();

</script>

</SiteLayout>
