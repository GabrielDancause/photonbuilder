);
const data = await res.json();
console.log(`$&#123;data.name&#125;: $&#123;data.main.temp&#125;°C`);
console.log(`Feels like: $&#123;data.main.feels_like&#125;°C`);
console.log(`$&#123;data.weather[0].description&#125;`);</code></pre>
      </div>
    </details>
      <p class="api-link"><a href="https://openweathermap.org/api" target="_blank">Official Documentation →</a></p>
