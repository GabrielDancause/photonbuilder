  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const valueA = document.getElementById('value-a');
      const valueB = document.getElementById('value-b');
      const resultContainer = document.getElementById('result-container');
      const resultValue = document.getElementById('result-value');
      const errorMsg = document.getElementById('error-message');
      const calcSteps = document.getElementById('calculation-steps');

      const formatNumber = (num) => {
        return new Intl.NumberFormat('en-US', {
            maximumFractionDigits: 4,
            minimumFractionDigits: 0
        }).format(num);
      };

      const calculate = () => {
        const a = parseFloat(valueA.value);
        const b = parseFloat(valueB.value);

        // If either is empty or invalid, clear everything
        if (valueA.value === '' || valueB.value === '' || isNaN(a) || isNaN(b)) {
          resultContainer.style.display = 'none';
          errorMsg.style.display = 'none';
          return;
        }

        const sum = a + b;

        if (a === b) {
            resultContainer.style.display = 'block';
            errorMsg.style.display = 'none';
            resultValue.textContent = '0%';
            calcSteps.textContent = 'The values are identical, so there is 0% difference.';
            return;
        }

        if (sum === 0) {
            resultContainer.style.display = 'none';
            errorMsg.style.display = 'block';
            errorMsg.textContent = 'The average of the two numbers cannot be zero.';
            return;
        }

        // Calculation
        const difference = Math.abs(a - b);
        const average = Math.abs(sum / 2);
        const percentDifference = (difference / average) * 100;

        // Display results
        resultContainer.style.display = 'block';
        errorMsg.style.display = 'none';

        resultValue.textContent = formatNumber(percentDifference) + '%';

        calcSteps.innerHTML = `
            Difference: |${a} - ${b}| = ${formatNumber(difference)}<br>
            Average: (${a} + ${b}) / 2 = ${formatNumber(average)}<br>
            Result: (${formatNumber(difference)} / ${formatNumber(average)}) × 100 = <strong>${formatNumber(percentDifference)}%</strong>
        `;
      };

      valueA.addEventListener('input', calculate);
      valueB.addEventListener('input', calculate);
    });
  </script>

