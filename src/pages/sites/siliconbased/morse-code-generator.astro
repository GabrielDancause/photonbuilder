      <p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto">
        Convert text to morse code and back — with audio playback
      </p>
    </section>

    <!-- Main Translator -->
    <section class="max-w-6xl mx-auto px-4 mb-12">
      <div class="bg-card border border-border rounded-xl p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-accent">Translator</h2>
          <div class="flex gap-2">
            <button id="swapBtn" class="px-4 py-2 bg-accent text-white rounded-lg hover:bg-blue-600 transition-colors">
              ⇄ Swap
            </button>
            <button id="clearBtn" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors">
              Clear
            </button>
          </div>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Text Input -->
          <div>
            <div class="flex justify-between items-center mb-2">
              <label class="text-sm font-medium text-gray-300" id="textLabel">Plain Text</label>
              <button id="copyTextBtn" class="text-xs text-accent hover:text-blue-400 transition-colors">Copy</button>
            </div>
            <textarea 
              id="textInput" 
              placeholder="Type your message here..."
              class="w-full h-32 p-4 bg-bg border border-border rounded-lg text-white resize-none focus:border-accent focus:outline-none"
            ></textarea>
          </div>

          <!-- Morse Output -->
          <div>
            <div class="flex justify-between items-center mb-2">
              <label class="text-sm font-medium text-gray-300" id="morseLabel">Morse Code</label>
              <button id="copyMorseBtn" class="text-xs text-accent hover:text-blue-400 transition-colors">Copy</button>
            </div>
            <textarea 
              id="morseOutput" 
              placeholder="··· −−− ···"
              class="w-full h-32 p-4 bg-bg border border-border rounded-lg text-white font-mono resize-none focus:border-accent focus:outline-none"
            ></textarea>
          </div>
        </div>

        <!-- Audio Controls -->
        <div class="mt-6 p-4 bg-bg border border-border rounded-lg">
          <div class="flex flex-wrap items-center gap-4">
            <button id="playBtn" class="px-6 py-2 bg-green text-white rounded-lg hover:bg-green-600 transition-colors flex items-center gap-2">
              ▶️ Play Morse
