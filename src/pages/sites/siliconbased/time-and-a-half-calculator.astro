---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Time and a Half Calculator",
  description: "Calculate your exact overtime pay with our free time and a half calculator. Find out exactly how much you're leaving on the table if you miscalculate your hours.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
    {
        "@type": "Question",
        "name": "What is time and a half?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Time and a half is an overtime pay rate that is 1.5 times an employee's regular hourly wage. It is typically paid for any hours worked beyond the standard 40 hours in a single workweek."
        }
    },
    {
        "@type": "Question",
        "name": "How do I calculate time and a half?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "To calculate time and a half, multiply your regular hourly rate by 1.5. For example, if you earn $15 per hour, your time and a half rate would be $15 \u00d7 1.5 = $22.50 per hour."
        }
    },
    {
        "@type": "Question",
        "name": "Do salaried employees get time and a half?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Generally, salaried employees who meet specific exemption criteria under the Fair Labor Standards Act (FLSA) are not eligible for time and a half. However, salaried employees who do not meet these criteria (non-exempt) are entitled to overtime pay."
        }
    },
    {
        "@type": "Question",
        "name": "Is time and a half based on a day or a week?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Under federal law (FLSA), time and a half is based on a workweek and applies to hours worked over 40 in that week. However, some state laws may require overtime pay based on hours worked in a single day (e.g., over 8 hours)."
        }
    },
    {
        "@type": "Question",
        "name": "Are bonuses included in time and a half calculations?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Non-discretionary bonuses (such as performance bonuses or shift differentials) generally must be included in your regular rate of pay when calculating your time and a half overtime rate. Discretionary bonuses (like a holiday gift) are typically excluded."
        }
    }
]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.published
  }
];
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/time-and-a-half-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Time and a Half Calculator</h1>
      <p class="subtitle">Quickly calculate your overtime earnings and total pay</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-group">
          <label for="regular-rate">Regular Hourly Rate ($)</label>
          <input type="number" id="regular-rate" min="0" step="0.01" placeholder="e.g., 20.00" aria-label="Regular Hourly Rate" />
        </div>

        <div class="input-group">
          <label for="regular-hours">Regular Hours Worked</label>
          <input type="number" id="regular-hours" min="0" step="0.25" placeholder="e.g., 40" aria-label="Regular Hours Worked" />
        </div>

        <div class="input-group">
          <label for="overtime-hours">Overtime Hours Worked</label>
          <input type="number" id="overtime-hours" min="0" step="0.25" placeholder="e.g., 5" aria-label="Overtime Hours Worked" />
        </div>
      </div>

      <div id="error-message" class="error-message" style="display: none;"></div>

      <div class="results-grid">
        <div class="result-card secondary">
          <h3>Overtime Rate</h3>
          <div class="result-value" id="overtime-rate-result">$0.00</div>
          <div class="result-label">per hour</div>
        </div>
        <div class="result-card secondary">
          <h3>Regular Pay</h3>
          <div class="result-value" id="regular-pay-result">$0.00</div>
        </div>
        <div class="result-card secondary">
          <h3>Overtime Pay</h3>
          <div class="result-value" id="overtime-pay-result">$0.00</div>
        </div>
        <div class="result-card primary full-width">
          <h3>Total Gross Pay</h3>
          <div class="result-value large" id="total-pay-result">$0.00</div>
        </div>
      </div>
    </div>

    <div class="explainer">

      <h2>Understanding Time and a Half and Overtime Pay</h2>
      <p>If you work hourly and clock in more than 40 hours a week, you've likely encountered the concept of "time and a half." But what exactly does it mean, and how does it affect your paycheck? Time and a half is the standard overtime rate mandated by the Fair Labor Standards Act (FLSA) for most non-exempt hourly employees in the United States. It dictates that for every hour worked beyond the standard 40-hour workweek, an employee must be compensated at a rate of 1.5 times their regular hourly wage.</p>

      <p>Calculating time and a half manually can sometimes be tricky, especially if you have fluctuating hours or earn varying rates for different tasks. Our free time and a half calculator simplifies this process. By entering your regular hourly wage, the number of standard hours you've worked, and your overtime hours, you can instantly see your exact overtime rate, regular pay, overtime pay, and your total gross earnings. This ensures you are fully aware of what your paycheck should look like before payday arrives.</p>

      <h3>How is Time and a Half Calculated?</h3>
      <p>The math behind time and a half is straightforward. To find your overtime rate, you simply multiply your standard hourly rate by 1.5. For instance, if you earn $20 per hour, your time and a half rate would be $20 &times; 1.5, which equals $30 per hour. Every hour you work over 40 hours in a given workweek is then paid at this $30 rate.</p>

      <p>Let's look at a concrete example to illustrate how this impacts your total gross pay. Suppose you work 45 hours in a single week. The first 40 hours are paid at your regular rate of $20 per hour, totaling $800. The remaining 5 hours are classified as overtime and are paid at the time and a half rate of $30 per hour, totaling $150. Your total gross pay for that week would be the sum of your regular pay ($800) and your overtime pay ($150), which equals $950.</p>

      <p>It's important to understand the distinction between a workweek and a pay period. A workweek is a fixed and regularly recurring period of 168 hours—seven consecutive 24-hour periods. Overtime is strictly calculated based on the hours worked within that specific, single workweek. Even if you are paid bi-weekly or semi-monthly, overtime is not calculated over the entire pay period. If you work 50 hours in the first week of a two-week pay period and only 30 hours in the second week, you are still entitled to 10 hours of overtime pay for the first week, despite your total hours for the pay period being 80.</p>

      <h3>Who is Eligible for Time and a Half?</h3>
      <p>The FLSA sets the federal baseline for overtime pay, but it does not apply to everyone. Eligibility primarily depends on whether you are classified as an "exempt" or "non-exempt" employee. Non-exempt employees are entitled to overtime pay. This category typically includes most hourly workers, as well as some salaried workers whose income falls below a certain threshold defined by the Department of Labor.</p>

      <p>Exempt employees, on the other hand, are not entitled to overtime pay under the FLSA. To be classified as exempt, an employee must meet specific criteria regarding their job duties and salary. Common exemptions include executive, administrative, professional, and some computer-related roles. These employees must generally be paid on a salary basis at not less than a defined minimum rate. It is crucial to check with your human resources department or consult state labor laws to understand your specific classification and eligibility.</p>

      <p>In addition to federal laws, many states have their own overtime regulations, which may provide greater protections or different overtime thresholds than the FLSA. For example, some states require time and a half to be paid for any hours worked beyond eight hours in a single day, regardless of the total hours worked in the week. Other states may require double time (twice the regular hourly rate) for working on a seventh consecutive day or working beyond 12 hours in a single day. When state and federal laws conflict, employers are legally obligated to follow the rule that provides the greatest benefit to the employee.</p>

      <h3>Common Pitfalls When Calculating Overtime</h3>
      <p>While the basic formula is simple, calculating overtime can become complicated due to various factors. One common pitfall involves bonuses and commissions. Under the FLSA, non-discretionary bonuses (bonuses promised or expected, such as a production bonus) and commissions must be included in your regular rate of pay when calculating your overtime rate. Failing to include these can result in underpaid overtime.</p>

      <p>Another area of confusion is calculating overtime when working at multiple rates. If you perform two different jobs for the same employer at different hourly rates, calculating your regular rate for overtime purposes involves finding the weighted average of your earnings for the week. This means dividing your total straight-time earnings by your total hours worked. The overtime rate is then calculated based on this blended regular rate.</p>

      <p>Lastly, unapproved overtime is a frequent issue. The FLSA requires employers to pay for all hours worked, including overtime, regardless of whether the overtime was explicitly authorized in advance. If an employer knows or has reason to believe that work is being performed, the time must be counted as hours worked. This means if you stay late to finish a project, even without asking permission, your employer is generally legally required to pay you for that time, including any applicable time and a half overtime.</p>

    </div>

    <section class="related-tools">
      <h2>Related Tools</h2>
      <ul>
        <li><a href="/mortgage-refinance-calculator">Mortgage Refinance Calculator</a></li>
      </ul>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>What is time and a half?</summary>
        <p>Time and a half is an overtime pay rate that is 1.5 times an employee's regular hourly wage. It is typically paid for any hours worked beyond the standard 40 hours in a single workweek.</p>
      </details>
      <details>
        <summary>How do I calculate time and a half?</summary>
        <p>To calculate time and a half, multiply your regular hourly rate by 1.5. For example, if you earn $15 per hour, your time and a half rate would be $15 &times; 1.5 = $22.50 per hour.</p>
      </details>
      <details>
        <summary>Do salaried employees get time and a half?</summary>
        <p>Generally, salaried employees who meet specific exemption criteria under the Fair Labor Standards Act (FLSA) are not eligible for time and a half. However, salaried employees who do not meet these criteria (non-exempt) are entitled to overtime pay.</p>
      </details>
      <details>
        <summary>Is time and a half based on a day or a week?</summary>
        <p>Under federal law (FLSA), time and a half is based on a workweek and applies to hours worked over 40 in that week. However, some state laws may require overtime pay based on hours worked in a single day (e.g., over 8 hours).</p>
      </details>
      <details>
        <summary>Are bonuses included in time and a half calculations?</summary>
        <p>Non-discretionary bonuses (such as performance bonuses or shift differentials) generally must be included in your regular rate of pay when calculating your time and a half overtime rate. Discretionary bonuses (like a holiday gift) are typically excluded.</p>
      </details>

    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const regularRateInput = document.getElementById('regular-rate');
      const regularHoursInput = document.getElementById('regular-hours');
      const overtimeHoursInput = document.getElementById('overtime-hours');
      const errorMessage = document.getElementById('error-message');

      const overtimeRateResult = document.getElementById('overtime-rate-result');
      const regularPayResult = document.getElementById('regular-pay-result');
      const overtimePayResult = document.getElementById('overtime-pay-result');
      const totalPayResult = document.getElementById('total-pay-result');

      const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD'
        }).format(value);
      };

      const calculatePay = () => {
        const rate = parseFloat(regularRateInput.value);
        const regHours = parseFloat(regularHoursInput.value) || 0;
        const otHours = parseFloat(overtimeHoursInput.value) || 0;

        // Reset display if all inputs are empty
        if (regularRateInput.value === '' && regularHoursInput.value === '' && overtimeHoursInput.value === '') {
          errorMessage.style.display = 'none';
          overtimeRateResult.textContent = '$0.00';
          regularPayResult.textContent = '$0.00';
          overtimePayResult.textContent = '$0.00';
          totalPayResult.textContent = '$0.00';
          return;
        }

        // Validation
        if (isNaN(rate) || rate <= 0) {
          if (regularRateInput.value !== '') {
            errorMessage.textContent = 'Please enter a valid regular hourly rate greater than 0.';
            errorMessage.style.display = 'block';
          }
          return;
        }

        if (regHours < 0 || otHours < 0) {
            errorMessage.textContent = 'Hours cannot be negative.';
            errorMessage.style.display = 'block';
            return;
        }

        errorMessage.style.display = 'none';

        const otRate = rate * 1.5;
        const regPay = rate * regHours;
        const otPay = otRate * otHours;
        const totalPay = regPay + otPay;

        overtimeRateResult.textContent = formatCurrency(otRate);
        regularPayResult.textContent = formatCurrency(regPay);
        overtimePayResult.textContent = formatCurrency(otPay);
        totalPayResult.textContent = formatCurrency(totalPay);
      };

      regularRateInput.addEventListener('input', calculatePay);
      regularHoursInput.addEventListener('input', calculatePay);
      overtimeHoursInput.addEventListener('input', calculatePay);
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2rem;
      margin: 2rem 0;
    }

    .calc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .input-group label {
      font-weight: 600;
      color: var(--text-primary);
    }

    input, select {
      background: var(--bg-color);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1rem;
      border-radius: 8px;
      width: 100%;
      font-size: 1rem;
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--accent-color);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .error-message {
      background: #fee2e2;
      color: #991b1b;
      padding: 1rem;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      text-align: center;
      font-weight: 500;
    }

    .results-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
    }

    .result-card {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .result-card h3 {
      font-size: 1rem;
      color: var(--text-secondary);
      margin-bottom: 0.5rem;
      margin-top: 0;
    }

    .result-card.primary {
      background: color-mix(in srgb, var(--accent-color) 10%, transparent);
      border-color: var(--accent-color);
    }

    .result-card.full-width {
      grid-column: 1 / -1;
    }

    .result-value {
      font-size: 2rem;
      font-weight: 800;
      color: var(--text-primary);
    }

    .result-card.primary .result-value {
      color: var(--accent-color);
    }

    .result-value.large {
      font-size: 3rem;
    }

    .result-label {
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .explainer, .related-tools {
      margin: 3rem 0;
    }

    .explainer h2, .related-tools h2, .faq-section h2 {
      font-size: 1.8rem;
      margin-bottom: 1.5rem;
      margin-top: 2rem;
    }

    .explainer h3 {
      font-size: 1.4rem;
      margin-bottom: 1rem;
      margin-top: 1.5rem;
    }

    .explainer p {
      line-height: 1.6;
      margin-bottom: 1rem;
      color: var(--text-secondary);
    }

    .explainer ul {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
      color: var(--text-secondary);
    }

    .explainer li {
      margin-bottom: 0.5rem;
    }

    .related-tools ul {
      list-style: none;
      padding: 0;
    }

    .related-tools li {
      margin-bottom: 0.5rem;
    }

    .related-tools a {
      color: var(--accent-color);
      text-decoration: none;
      font-weight: 600;
    }

    .related-tools a:hover {
      text-decoration: underline;
    }

    .faq-section details {
      margin: 1rem 0;
      padding: 1rem;
      background: var(--card-bg);
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }

    .faq-section summary {
      font-weight: 600;
      cursor: pointer;
      font-size: 1.1rem;
      color: var(--text-primary);
    }

    .faq-section details p {
      margin-top: 1rem;
      margin-bottom: 0;
      line-height: 1.6;
      color: var(--text-secondary);
    }
  </style>
</SiteLayout>
