---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "SVG to CSS Background Converter — Pattern Generator",
      "url": "https://siliconbased.dev/svg-to-css-converter",
      "description": "Free SVG to CSS converter with 15 built-in patterns. Convert SVG code to CSS background-image data URIs, customize colors, size, spacing, and rotation with live preview.",
      "applicationCategory": "DesignApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I convert an SVG to a CSS background?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your SVG code into the converter, and it will encode the SVG as a data URI for use in the CSS background-image property. The tool URL-encodes the SVG markup and wraps it in a data:image/svg+xml format that all modern browsers support."
          }
        },
        {
          "@type": "Question",
          "name": "What is an SVG data URI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An SVG data URI is a way to embed SVG image data directly into CSS without needing an external file. The SVG markup is URL-encoded and placed inline as a background-image value, reducing HTTP requests and making the pattern self-contained in your stylesheet."
          }
        },
        {
          "@type": "Question",
          "name": "What patterns are available in the pattern library?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The tool includes 15 built-in patterns: dots, stripes, checkerboard, zigzag, waves, triangles, hexagons, circles, diamonds, crosses, grid, diagonal lines, herringbone, polka dots, and stars. Each pattern can be customized with different colors, sizes, spacing, and rotation."
          }
        },
        {
          "@type": "Question",
          "name": "Can I customize the colors and size of SVG patterns?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The converter lets you change the foreground and background colors, adjust the pattern element size, control spacing between elements, and rotate the entire pattern. All changes are reflected in the live preview instantly."
          }
        },
        {
          "@type": "Question",
          "name": "Are SVG CSS backgrounds better than PNG patterns?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SVG backgrounds are resolution-independent, so they look sharp on all screen sizes and DPIs including Retina displays. They also have much smaller file sizes than PNGs for geometric patterns and can be customized with CSS without needing image editing software."
          }
        },
        {
          "@type": "Question",
          "name": "Do SVG data URI backgrounds work in all browsers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, SVG data URIs in CSS background-image are supported in all modern browsers including Chrome, Firefox, Safari, and Edge. They have been widely supported since IE9, making them safe to use in production websites."
          }
        },
        {
          "@type": "Question",
          "name": "Is this SVG to CSS converter free?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this tool is completely free. It runs entirely in your browser with no sign-up required. All SVG encoding and CSS generation happens client-side — no data is sent to any server."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "SVG to CSS Background Converter — CSS Background Pattern Generator",
      "description": "Free SVG to CSS converter with 15 built-in patterns. Convert SVG to CSS background-image data URIs with live preview, customizable colors, size, spacing, and rotation.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>SVG to CSS Background Converter</h1>
  <p>Convert SVG code to CSS background patterns or choose from 15 built-in patterns. Customize colors, size, spacing, and rotation with live preview.</p>
</div>

<div class="main">

  <!-- Mode Tabs -->
  <div class="mode-tabs">
    <button class="mode-tab active" data-mode="library">Pattern Library</button>
    <button class="mode-tab" data-mode="custom">Paste SVG</button>
  </div>

  <!-- Pattern Library -->
  <div class="panel" id="libraryPanel">
    <div class="patterns-grid" id="patternsGrid"></div>
  </div>

  <!-- Custom SVG Input -->
  <div class="panel hidden" id="customPanel">
    <label class="field-label">Paste SVG Code</label>
    <textarea id="svgInput" class="svg-input" rows="8" placeholder="<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;20&quot; height=&quot;20&quot;>&#10;  <circle cx=&quot;10&quot; cy=&quot;10&quot; r=&quot;3&quot; fill=&quot;#888&quot;/>&#10;</svg>" spellcheck="false"></textarea>
  </div>

  <!-- Controls -->
  <div class="section-block">
    <div class="section-header">
      <h2>Customize</h2>
    </div>
    <div class="controls-grid">
      <div class="control-item">
        <label>Foreground</label>
        <div class="color-wrap">
          <input type="color" id="fgColor" value="#6366f1">
          <span class="color-hex" id="fgHex">#6366F1</span>
        </div>
      </div>
      <div class="control-item">
        <label>Background</label>
        <div class="color-wrap">
          <input type="color" id="bgColor" value="#0a1020">
          <span class="color-hex" id="bgHex">#0A1020</span>
        </div>
      </div>
      <div class="control-item">
        <label>Size <span class="val-display" id="sizeVal">20</span>px</label>
        <input type="range" id="sizeRange" min="4" max="100" value="20">
      </div>
      <div class="control-item">
        <label>Spacing <span class="val-display" id="spacingVal">0</span>px</label>
        <input type="range" id="spacingRange" min="0" max="50" value="0">
      </div>
      <div class="control-item">
        <label>Rotation <span class="val-display" id="rotationVal">0</span>&deg;</label>
        <input type="range" id="rotationRange" min="0" max="360" value="0" step="5">
      </div>
      <div class="control-item">
        <label>Opacity <span class="val-display" id="opacityVal">100</span>%</label>
        <input type="range" id="opacityRange" min="10" max="100" value="100">
      </div>
    </div>
  </div>

  <!-- Live Preview -->
  <div class="section-block">
    <div class="section-header">
      <h2>Preview</h2>
    </div>
    <div class="preview-box" id="previewBox"></div>
  </div>

  <!-- CSS Output -->
  <div class="section-block">
    <div class="section-header">
      <h2>CSS Output</h2>
    </div>
    <div class="export-output-wrap">
      <pre class="export-output" id="cssOutput"></pre>
      <button class="copy-btn" id="copyBtn">Copy CSS</button>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is an SVG to CSS Background Converter?</h2>
    <p>An SVG to CSS background converter takes SVG (Scalable Vector Graphics) code and transforms it into a CSS <code>background-image</code> property using data URIs. This allows you to embed vector patterns directly in your stylesheet without external image files. The result is a resolution-independent, infinitely tiling background pattern that looks crisp on any screen density.</p>

    <h2>Why Use SVG Backgrounds Instead of Images?</h2>
    <p>SVG backgrounds offer several advantages over raster image formats like PNG or JPEG for repeating patterns:</p>
    <ul>
      <li><strong>Resolution Independence:</strong> SVGs are vector-based, so they render perfectly at any zoom level or DPI, including Retina and 4K displays.</li>
      <li><strong>Tiny File Size:</strong> Geometric patterns as SVG data URIs are typically under 1KB, far smaller than equivalent PNGs.</li>
      <li><strong>No Extra HTTP Requests:</strong> Since the SVG is embedded directly in your CSS, there are no additional network requests to slow down page load.</li>
      <li><strong>Easy Customization:</strong> You can change colors, sizes, and other properties by modifying the SVG code — no image editor needed.</li>
    </ul>

    <h2>Built-in CSS Background Pattern Library</h2>
    <p>This tool includes 15 ready-to-use geometric patterns: dots, stripes, checkerboard, zigzag, waves, triangles, hexagons, circles, diamonds, crosses, grid, diagonal lines, herringbone, polka dots, and stars. Each pattern is generated as clean SVG markup and can be customized with your own colors, element sizes, spacing, and rotation before exporting as CSS.</p>

    <h2>How SVG Data URIs Work</h2>
    <p>A data URI encodes file data directly into a URL string. For SVG backgrounds, the SVG markup is URL-encoded and placed in the format: <code>url("data:image/svg+xml,...")</code>. The browser decodes this string and renders the SVG just as it would an external file. Combined with <code>background-repeat: repeat</code>, the SVG tiles seamlessly across the element.</p>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I convert an SVG to a CSS background?</h3>
      <p style="margin-bottom: 16px;">Paste your SVG code into the converter, and it will encode the SVG as a data URI for use in the CSS background-image property. The tool URL-encodes the SVG markup and wraps it in a data:image/svg+xml format that all modern browsers support.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is an SVG data URI?</h3>
      <p style="margin-bottom: 16px;">An SVG data URI is a way to embed SVG image data directly into CSS without needing an external file. The SVG markup is URL-encoded and placed inline as a background-image value, reducing HTTP requests and making the pattern self-contained in your stylesheet.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What patterns are available in the pattern library?</h3>
      <p style="margin-bottom: 16px;">The tool includes 15 built-in patterns: dots, stripes, checkerboard, zigzag, waves, triangles, hexagons, circles, diamonds, crosses, grid, diagonal lines, herringbone, polka dots, and stars. Each can be customized with different colors, sizes, spacing, and rotation.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I customize the colors and size of SVG patterns?</h3>
      <p style="margin-bottom: 16px;">Yes. The converter lets you change the foreground and background colors, adjust the pattern element size, control spacing between elements, and rotate the entire pattern. All changes are reflected in the live preview instantly.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Are SVG CSS backgrounds better than PNG patterns?</h3>
      <p style="margin-bottom: 16px;">SVG backgrounds are resolution-independent, so they look sharp on all screen sizes and DPIs including Retina displays. They also have much smaller file sizes than PNGs for geometric patterns and can be customized with CSS.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Do SVG data URI backgrounds work in all browsers?</h3>
      <p style="margin-bottom: 16px;">Yes, SVG data URIs in CSS background-image are supported in all modern browsers including Chrome, Firefox, Safari, and Edge. They have been widely supported since IE9.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is this SVG to CSS converter free?</h3>
      <p style="margin-bottom: 16px;">Yes, this tool is completely free. It runs entirely in your browser with no sign-up required. All SVG encoding and CSS generation happens client-side — no data is sent to any server.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/css-gradient-generator">CSS Gradient Generator</a> — Create beautiful CSS gradients with linear, radial, and conic modes.</li>
      <li><a href="/css-box-shadow-generator">CSS Box Shadow Generator</a> — Design layered box shadows with live preview.</li>
      <li><a href="/color-palette-generator">Color Palette Generator</a> — Create beautiful color schemes with harmony modes and contrast checking.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "SVG to CSS Background Converter — Pattern Tool",
  description: "Free SVG to CSS converter with 15 built-in patterns. Convert SVG to CSS background-image data URIs. Customize colors, size, spacing, rotation with live preview.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="SVG to CSS Background Converter — Pattern Tool"
  description="Free SVG to CSS converter with 15 built-in patterns. Convert SVG to CSS background-image data URIs. Customize colors, size, spacing, rotation with live preview."
  canonical="https://siliconbased.dev/svg-to-css-converter"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
var fgColor = document.getElementById('fgColor');
var bgColor = document.getElementById('bgColor');
var fgHex = document.getElementById('fgHex');
var bgHex = document.getElementById('bgHex');
var sizeRange = document.getElementById('sizeRange');
var spacingRange = document.getElementById('spacingRange');
var rotationRange = document.getElementById('rotationRange');
var opacityRange = document.getElementById('opacityRange');
var sizeVal = document.getElementById('sizeVal');
var spacingVal = document.getElementById('spacingVal');
var rotationVal = document.getElementById('rotationVal');
var opacityVal = document.getElementById('opacityVal');
var previewBox = document.getElementById('previewBox');
var cssOutput = document.getElementById('cssOutput');
var copyBtn = document.getElementById('copyBtn');
var svgInput = document.getElementById('svgInput');
var patternsGrid = document.getElementById('patternsGrid');
var libraryPanel = document.getElementById('libraryPanel');
var customPanel = document.getElementById('customPanel');

var currentMode = 'library';
var selectedPattern = 'dots';

// --- 15 Pattern generators ---
function generatePatternSVG(name, fg, size) {
  var s = size;
  switch (name) {
    case 'dots':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><circle cx="'+s/2+'" cy="'+s/2+'" r="'+s*0.15+'" fill="'+fg+'"/></svg>';
    case 'stripes':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><rect width="'+s/2+'" height="'+s+'" fill="'+fg+'"/></svg>';
    case 'checkerboard':
      var h = s/2;
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><rect width="'+h+'" height="'+h+'" fill="'+fg+'"/><rect x="'+h+'" y="'+h+'" width="'+h+'" height="'+h+'" fill="'+fg+'"/></svg>';
    case 'zigzag':
      var q = s/4;
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><polyline points="0,'+q+' '+s/2+','+3*q+' '+s+','+q+'" fill="none" stroke="'+fg+'" stroke-width="'+Math.max(1,s*0.06)+'"/></svg>';
    case 'waves':
      var cy1 = s*0.3, cy2 = s*0.7;
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><path d="M0,'+s/2+' Q'+s/4+','+cy1+' '+s/2+','+s/2+' T'+s+','+s/2+'" fill="none" stroke="'+fg+'" stroke-width="'+Math.max(1,s*0.06)+'"/></svg>';
    case 'triangles':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><polygon points="'+s/2+','+s*0.15+' '+s*0.85+','+s*0.85+' '+s*0.15+','+s*0.85+'" fill="'+fg+'"/></svg>';
    case 'hexagons': {
      var r = s * 0.4;
      var cx = s / 2, cy = s / 2;
      var pts = [];
      for (var i = 0; i < 6; i++) {
        var a = Math.PI / 3 * i - Math.PI / 6;
        pts.push((cx + r * Math.cos(a)).toFixed(1) + ',' + (cy + r * Math.sin(a)).toFixed(1));
      }
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><polygon points="'+pts.join(' ')+'" fill="none" stroke="'+fg+'" stroke-width="'+Math.max(1,s*0.05)+'"/></svg>';
    }
    case 'circles':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><circle cx="'+s/2+'" cy="'+s/2+'" r="'+s*0.35+'" fill="none" stroke="'+fg+'" stroke-width="'+Math.max(1,s*0.06)+'"/></svg>';
    case 'diamonds':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><polygon points="'+s/2+','+s*0.1+' '+s*0.9+','+s/2+' '+s/2+','+s*0.9+' '+s*0.1+','+s/2+'" fill="'+fg+'"/></svg>';
    case 'crosses': {
      var t = s * 0.15;
      var c = s / 2;
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><rect x="'+(c-t)+'" y="'+s*0.15+'" width="'+2*t+'" height="'+s*0.7+'" fill="'+fg+'"/><rect x="'+s*0.15+'" y="'+(c-t)+'" width="'+s*0.7+'" height="'+2*t+'" fill="'+fg+'"/></svg>';
    }
    case 'grid':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><path d="M'+s+' 0L'+s+' '+s+' 0 '+s+'" fill="none" stroke="'+fg+'" stroke-width="'+Math.max(1,s*0.04)+'"/></svg>';
    case 'diagonal-lines':
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><line x1="0" y1="'+s+'" x2="'+s+'" y2="0" stroke="'+fg+'" stroke-width="'+Math.max(1,s*0.06)+'"/></svg>';
    case 'herringbone': {
      var sw = Math.max(1, s * 0.06);
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><path d="M0,0 L'+s/2+','+s/2+' L0,'+s+' M'+s+',0 L'+s/2+','+s/2+' L'+s+','+s+'" fill="none" stroke="'+fg+'" stroke-width="'+sw+'"/></svg>';
    }
    case 'polka-dots': {
      var r2 = s * 0.18;
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><circle cx="'+s*0.25+'" cy="'+s*0.25+'" r="'+r2+'" fill="'+fg+'"/><circle cx="'+s*0.75+'" cy="'+s*0.75+'" r="'+r2+'" fill="'+fg+'"/></svg>';
    }
    case 'stars': {
      var cx2 = s/2, cy2b = s/2, outerR = s*0.4, innerR = s*0.18;
      var starPts = [];
      for (var j = 0; j < 10; j++) {
        var angle = Math.PI/2*3 + j * Math.PI / 5;
        var rr = j % 2 === 0 ? outerR : innerR;
        starPts.push((cx2 + rr * Math.cos(angle)).toFixed(1) + ',' + (cy2b + rr * Math.sin(angle)).toFixed(1));
      }
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><polygon points="'+starPts.join(' ')+'" fill="'+fg+'"/></svg>';
    }
    default:
      return '<svg xmlns="http://www.w3.org/2000/svg" width="'+s+'" height="'+s+'"><circle cx="'+s/2+'" cy="'+s/2+'" r="'+s*0.15+'" fill="'+fg+'"/></svg>';
  }
}

var patternNames = [
  'dots', 'stripes', 'checkerboard', 'zigzag', 'waves',
  'triangles', 'hexagons', 'circles', 'diamonds', 'crosses',
  'grid', 'diagonal-lines', 'herringbone', 'polka-dots', 'stars'
];

var patternLabels = {
  'dots': 'Dots', 'stripes': 'Stripes', 'checkerboard': 'Checkerboard',
  'zigzag': 'Zigzag', 'waves': 'Waves', 'triangles': 'Triangles',
  'hexagons': 'Hexagons', 'circles': 'Circles', 'diamonds': 'Diamonds',
  'crosses': 'Crosses', 'grid': 'Grid', 'diagonal-lines': 'Diagonal Lines',
  'herringbone': 'Herringbone', 'polka-dots': 'Polka Dots', 'stars': 'Stars'
};

function encodeSVG(svg) {
  return svg
    .replace(/"/g, "'")
    .replace(/%/g, '%25')
    .replace(/#/g, '%23')
    .replace(/\{/g, '%7B')
    .replace(/\}/g, '%7D')
    .replace(/</g, '%3C')
    .replace(/>/g, '%3E')
    .replace(/\s+/g, ' ')
    .trim();
}

function getCurrentSVG() {
  var fg = fgColor.value;
  var size = parseInt(sizeRange.value);
  var spacing = parseInt(spacingRange.value);
  var totalSize = size + spacing;

  if (currentMode === 'custom') {
    var raw = svgInput.value.trim();
    if (!raw) return null;
    // Try to update width/height in user SVG
    raw = raw.replace(/width=["'][^"']*["']/i, 'width="' + totalSize + '"');
    raw = raw.replace(/height=["'][^"']*["']/i, 'height="' + totalSize + '"');
    return raw;
  }

  var innerSVG = generatePatternSVG(selectedPattern, fg, size);
  if (spacing > 0) {
    // Re-wrap SVG with larger viewBox to add spacing
    var inner = innerSVG.replace(/<svg[^>]*>/, '').replace(/<\/svg>/, '');
    innerSVG = '<svg xmlns="http://www.w3.org/2000/svg" width="' + totalSize + '" height="' + totalSize + '">' + inner + '</svg>';
  }
  return innerSVG;
}

function buildCSS() {
  var svg = getCurrentSVG();
  if (!svg) return { css: '', dataUri: '' };

  var bg = bgColor.value;
  var rotation = parseInt(rotationRange.value);
  var opacity = parseInt(opacityRange.value) / 100;

  var encoded = encodeSVG(svg);
  var dataUri = 'url("data:image/svg+xml,' + encoded + '")';

  var lines = [];
  lines.push('background-color: ' + bg + ';');
  lines.push('background-image: ' + dataUri + ';');
  lines.push('background-repeat: repeat;');
  if (rotation > 0) {
    // Use a wrapper or pseudo-element note
    lines.push('/* Rotation requires a wrapper element or pseudo-element */');
    lines.push('/* transform: rotate(' + rotation + 'deg); */');
  }
  if (opacity < 1) {
    lines.push('opacity: ' + opacity + ';');
  }

  return { css: lines.join('\n'), dataUri: dataUri };
}

function render() {
  var fg = fgColor.value;
  var bg = bgColor.value;
  var size = parseInt(sizeRange.value);
  var spacing = parseInt(spacingRange.value);
  var rotation = parseInt(rotationRange.value);
  var opacity = parseInt(opacityRange.value);

  fgHex.textContent = fg.toUpperCase();
  bgHex.textContent = bg.toUpperCase();
  sizeVal.textContent = size;
  spacingVal.textContent = spacing;
  rotationVal.textContent = rotation;
  opacityVal.textContent = opacity;

  var result = buildCSS();

  // Preview
  var svg = getCurrentSVG();
  if (svg) {
    var encoded = encodeSVG(svg);
    previewBox.style.backgroundColor = bg;
    previewBox.style.backgroundImage = 'url("data:image/svg+xml,' + encoded + '")';
    previewBox.style.backgroundRepeat = 'repeat';
    previewBox.style.transform = rotation > 0 ? 'rotate(' + rotation + 'deg) scale(1.5)' : '';
    previewBox.style.opacity = opacity / 100;
  } else {
    previewBox.style.backgroundColor = bg;
    previewBox.style.backgroundImage = 'none';
    previewBox.style.transform = '';
    previewBox.style.opacity = '1';
  }

  // CSS output
  cssOutput.textContent = result.css || '/* Paste SVG code or select a pattern */';
}

// --- Pattern grid ---
function renderPatterns() {
  patternsGrid.innerHTML = '';
  patternNames.forEach(function(name) {
    var card = document.createElement('div');
    card.className = 'pattern-card' + (name === selectedPattern ? ' active' : '');
    var svg = generatePatternSVG(name, '#6366f1', 20);
    var encoded = encodeSVG(svg);
    card.innerHTML = '<div class="pattern-swatch" style="background-color:#0a1020;background-image:url(\'data:image/svg+xml,' + encoded + '\');background-repeat:repeat;"></div><div class="pattern-name">' + patternLabels[name] + '</div>';
    card.addEventListener('click', function() {
      selectedPattern = name;
      renderPatterns();
      render();
    });
    patternsGrid.appendChild(card);
  });
}

// --- Mode tabs ---
document.querySelectorAll('.mode-tab').forEach(function(tab) {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.mode-tab').forEach(function(t) { t.classList.remove('active'); });
    tab.classList.add('active');
    currentMode = tab.dataset.mode;
    libraryPanel.classList.toggle('hidden', currentMode !== 'library');
    customPanel.classList.toggle('hidden', currentMode !== 'custom');
    render();
  });
});

// --- Control listeners ---
fgColor.addEventListener('input', function() { render(); renderPatterns(); });
bgColor.addEventListener('input', function() { render(); });
sizeRange.addEventListener('input', render);
spacingRange.addEventListener('input', render);
rotationRange.addEventListener('input', render);
opacityRange.addEventListener('input', render);
svgInput.addEventListener('input', render);

// --- Copy ---
copyBtn.addEventListener('click', function() {
  var text = cssOutput.textContent;
  if (!text) return;
  navigator.clipboard.writeText(text).then(function() {
    copyBtn.textContent = 'Copied!';
    setTimeout(function() { copyBtn.textContent = 'Copy CSS'; }, 1500);
  });
});

// --- Init ---
renderPatterns();
render();
</script>

