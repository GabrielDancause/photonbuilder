// Tabs
const tabBtns = document.querySelectorAll('.tab-btn');
const tabPanels = document.querySelectorAll('.tab-panel');
tabBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    tabBtns.forEach(b => b.classList.remove('active'));
    tabPanels.forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
  });
});

// All sizes table
const allSizesBody = document.getElementById('allSizesBody');
const filterInput = document.getElementById('filterInput');
const sortSelect = document.getElementById('sortSelect');

function renderAllSizes() {
  const filter = filterInput.value.toLowerCase();
  const sort = sortSelect.value;

  let data = ALL_SIZES.filter(s =>
    s.platform.toLowerCase().includes(filter) ||
    s.type.toLowerCase().includes(filter) ||
    s.ratio.toLowerCase().includes(filter)
  );

  if (sort === 'width-asc') data.sort((a, b) => a.w - b.w);
  else if (sort === 'width-desc') data.sort((a, b) => b.w - a.w);
  else if (sort === 'height-asc') data.sort((a, b) => a.h - b.h);
  else if (sort === 'height-desc') data.sort((a, b) => b.h - a.h);
  else if (sort === 'ratio') data.sort((a, b) => (a.w / a.h) - (b.w / b.h));

  allSizesBody.innerHTML = data.map(s =>
    `<tr><td><span class="platform-badge ${s.platform.toLowerCase().replace(/[\s\/]/g, '')}">${s.platform}</span></td><td>${s.type}</td><td>${s.w}</td><td>${s.h}</td><td>${s.ratio}</td><td>${s.max}</td></tr>`
  ).join('');
}

filterInput.addEventListener('input', renderAllSizes);
sortSelect.addEventListener('change', renderAllSizes);
renderAllSizes();

// Resize checker
const widthInput = document.getElementById('widthInput');
const heightInput = document.getElementById('heightInput');
const checkBtn = document.getElementById('checkBtn');
const resizeResult = document.getElementById('resizeResult');

function checkFit() {
  const w = parseInt(widthInput.value) || 0;
  const h = parseInt(heightInput.value) || 0;
  if (w <= 0 || h <= 0) {
    resizeResult.innerHTML = '<div class="result-empty">Enter valid dimensions above.</div>';
    return;
  }

  const userRatio = w / h;
  const TOLERANCE = 0.05;

  const exact = [];
  const close = [];
  const scalable = [];

  ALL_SIZES.forEach(s => {
    const sRatio = s.w / s.h;
    if (w === s.w && h === s.h) {
      exact.push(s);
    } else if (Math.abs(userRatio - sRatio) < TOLERANCE) {
      close.push(s);
    } else if (w >= s.w && h >= s.h) {
      scalable.push(s);
    }
  });

  let html = `<div class="result-info">Your image: <strong>${w} × ${h}</strong> (${userRatio.toFixed(2)}:1)</div>`;

  if (exact.length) {
    html += '<div class="result-section"><div class="result-label exact">Exact Match</div>';
    exact.forEach(s => { html += `<div class="result-item"><span class="platform-badge ${s.platform.toLowerCase().replace(/[\s\/]/g, '')}">${s.platform}</span> ${s.type}</div>`; });
    html += '</div>';
  }

  if (close.length) {
    html += '<div class="result-section"><div class="result-label close">Same Aspect Ratio — Just Resize</div>';
    close.forEach(s => { html += `<div class="result-item"><span class="platform-badge ${s.platform.toLowerCase().replace(/[\s\/]/g, '')}">${s.platform}</span> ${s.type} <span class="dim-hint">${s.w}×${s.h}</span></div>`; });
    html += '</div>';
  }

  if (scalable.length) {
    html += '<div class="result-section"><div class="result-label scalable">Can Scale Down (Different Ratio)</div>';
    scalable.forEach(s => { html += `<div class="result-item"><span class="platform-badge ${s.platform.toLowerCase().replace(/[\s\/]/g, '')}">${s.platform}</span> ${s.type} <span class="dim-hint">${s.w}×${s.h}</span></div>`; });
    html += '</div>';
  }

  if (!exact.length && !close.length && !scalable.length) {
    html += '<div class="result-empty">No standard social media sizes match these dimensions. Try a more common size like 1080×1080 or 1080×1920.</div>';
  }

  resizeResult.innerHTML = html;
}

checkBtn.addEventListener('click', checkFit);
widthInput.addEventListener('keydown', e => { if (e.key === 'Enter') checkFit(); });
heightInput.addEventListener('keydown', e => { if (e.key === 'Enter') checkFit(); });
checkFit();
</script>

