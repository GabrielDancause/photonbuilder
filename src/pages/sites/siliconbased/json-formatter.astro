---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "JSON Formatter & Validator — Format, Validate & Minify JSON Online",
      "url": "https://siliconbased.dev/json-formatter",
      "description": "Free online JSON formatter, validator, and minifier. Paste JSON to instantly format with syntax highlighting, validate with error messages, minify, view as tree, and download — all in your browser.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does a JSON formatter do?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A JSON formatter takes raw or minified JSON data and reformats it with proper indentation, line breaks, and syntax highlighting so it's easy to read and debug. It can also validate the JSON structure and report errors with line numbers."
          }
        },
        {
          "@type": "Question",
          "name": "How do I validate JSON online?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your JSON into the input field on this page. The tool instantly parses it and reports whether it's valid. If there are syntax errors, it shows the exact error message and line number so you can quickly find and fix the problem."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between JSON minify and beautify?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Beautify (or pretty-print) adds indentation and line breaks to make JSON human-readable. Minify removes all unnecessary whitespace to produce the smallest possible output, which is ideal for network transmission and storage. Both operations preserve the data — only the formatting changes."
          }
        },
        {
          "@type": "Question",
          "name": "Is it safe to paste sensitive JSON data here?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All formatting and validation happens entirely in your browser using JavaScript. No data is sent to any server. Your JSON never leaves your device, making it safe to use with API responses, configuration files, and other sensitive data."
          }
        },
        {
          "@type": "Question",
          "name": "What is the maximum JSON size this tool supports?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This tool supports JSON input up to 1 MB in size. For most use cases — API responses, configuration files, database exports — this is more than sufficient. The tool shows real-time stats including the size of your JSON data."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "JSON Formatter & Validator — Format, Validate & Minify JSON Online",
      "description": "Free online JSON formatter and validator. Paste JSON to instantly beautify, minify, validate, and explore with tree view.",
      "datePublished": "2026-03-15T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>JSON Formatter & Validator</h1>
  <p>Format, validate, minify, and explore JSON instantly — with syntax highlighting, tree view, and error reporting. All in your browser.</p>
</div>

<div class="main">

  <!-- Input Section -->
  <div class="input-section">
    <div class="input-header">
      <div class="header-title">Paste JSON</div>
      <div class="header-actions">
        <button class="action-btn" id="sampleBtn">Sample</button>
        <button class="action-btn" id="clearBtn">Clear</button>
        <button class="action-btn" id="fileBtn">Upload File</button>
        <input type="file" id="fileInput" accept=".json,.txt" style="display:none;">
      </div>
    </div>
    <textarea id="jsonInput" class="json-input" spellcheck="false" placeholder="Paste your JSON here... (Ctrl+Enter to format)"></textarea>
    <div class="input-footer">
      <span class="hint">Ctrl+Enter to format</span>
      <span class="size-label" id="sizeLabel"></span>
    </div>
  </div>

  <!-- Validation Banner -->
  <div class="validation-banner" id="validationBanner" style="display:none;">
    <div class="validation-icon" id="validationIcon"></div>
    <div class="validation-text" id="validationText"></div>
  </div>

  <!-- Stats Bar -->
  <div class="stats-bar" id="statsBar" style="display:none;">
    <div class="stat"><span class="stat-label">Keys</span><span class="stat-value" id="statKeys">0</span></div>
    <div class="stat"><span class="stat-label">Depth</span><span class="stat-value" id="statDepth">0</span></div>
    <div class="stat"><span class="stat-label">Size</span><span class="stat-value" id="statSize">0 B</span></div>
    <div class="stat"><span class="stat-label">Arrays</span><span class="stat-value" id="statArrays">0</span></div>
    <div class="stat"><span class="stat-label">Objects</span><span class="stat-value" id="statObjects">0</span></div>
  </div>

  <!-- Action Bar -->
  <div class="action-bar" id="actionBar" style="display:none;">
    <button class="action-btn active" id="beautifyBtn">Beautify</button>
    <button class="action-btn" id="minifyBtn">Minify</button>
    <button class="action-btn" id="treeBtn">Tree View</button>
    <div style="flex:1;"></div>
    <button class="action-btn" id="copyBtn">Copy</button>
    <button class="action-btn" id="downloadBtn">Download</button>
  </div>

  <!-- Output Section -->
  <div class="output-section" id="outputSection" style="display:none;">
    <div class="output-wrap" id="outputWrap">
      <pre class="output-code" id="outputCode"></pre>
    </div>
    <div class="tree-wrap" id="treeWrap" style="display:none;">
      <div class="tree-view" id="treeView"></div>
    </div>
  </div>

  <!-- JSON Reference -->
  <div class="ref-section">
    <div class="input-header">
      <div class="header-title">JSON Quick Reference</div>
    </div>
    <div class="ref-grid">
      <div class="ref-card">
        <div class="ref-card-title">Data Types</div>
        <code>string &mdash; "hello"</code>
        <code>number &mdash; 42, 3.14</code>
        <code>boolean &mdash; true, false</code>
        <code>null &mdash; null</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Structures</div>
        <code>object &mdash; {"key": "value"}</code>
        <code>array &mdash; [1, 2, 3]</code>
        <code>nested &mdash; {"a": {"b": 1}}</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Escape Sequences</div>
        <code>\\" &mdash; double quote</code>
        <code>\\\\ &mdash; backslash</code>
        <code>\\n &mdash; newline</code>
        <code>\\t &mdash; tab</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Common Errors</div>
        <code>Trailing commas</code>
        <code>Single quotes</code>
        <code>Unquoted keys</code>
        <code>Comments (not allowed)</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Standards</div>
        <code>RFC 8259 (JSON)</code>
        <code>ECMA-404</code>
        <code>MIME: application/json</code>
        <code>UTF-8 encoding</code>
      </div>
      <div class="ref-card">
        <div class="ref-card-title">Common Uses</div>
        <code>REST API responses</code>
        <code>Configuration files</code>
        <code>Data interchange</code>
        <code>NoSQL databases</code>
      </div>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is JSON?</h2>
    <p>JSON (JavaScript Object Notation) is a lightweight, text-based data interchange format defined in <strong>RFC 8259</strong>. It is language-independent but uses conventions familiar to programmers of the C-family of languages. JSON is the dominant format for APIs, configuration files, and data storage in modern web development.</p>

    <h2>Why Format JSON?</h2>
    <p>Raw or minified JSON is difficult to read and debug. A JSON formatter adds proper indentation and line breaks, making the structure immediately visible. This is essential when inspecting API responses, debugging configuration issues, or reviewing data exports. Syntax highlighting further improves readability by color-coding keys, strings, numbers, and other value types.</p>

    <h2>JSON Validation</h2>
    <p>JSON has strict syntax rules: keys must be double-quoted strings, no trailing commas are allowed, and comments are not part of the specification. Common errors include using single quotes instead of double quotes, adding trailing commas after the last element, and using unquoted property names. A JSON validator catches these errors instantly and reports the exact location.</p>

    <h2>Beautify vs Minify</h2>
    <p><strong>Beautify</strong> (pretty-print) reformats JSON with consistent indentation (typically 2 spaces) and line breaks, making it easy to read and edit. <strong>Minify</strong> removes all unnecessary whitespace to produce the smallest possible output. Minified JSON is ideal for API transmission, storage, and production configuration files where readability is not needed.</p>

    <h2>JSON Syntax Rules</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Rule</th>
          <th>Valid Example</th>
          <th>Common Error</th>
        </tr>
      </thead>
      <tbody>
        <tr><td><strong>Double Quotes Only</strong></td><td><code>{"key": "value"}</code></td><td>Using single quotes <code>{'key': 'value'}</code></td></tr>
        <tr><td><strong>Keys Must Be Quoted</strong></td><td><code>{"name": "Gab"}</code></td><td>Missing quotes <code>{name: "Gab"}</code></td></tr>
        <tr><td><strong>No Trailing Commas</strong></td><td><code>[1, 2, 3]</code></td><td>Extra comma <code>[1, 2, 3,]</code></td></tr>
        <tr><td><strong>Specific Data Types</strong></td><td><code>"string"</code>, <code>123</code>, <code>true</code>, <code>null</code></td><td>Using <code>undefined</code> or functions</td></tr>
      </tbody>
    </table>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does a JSON formatter do?</h3>
      <p style="margin-bottom: 16px;">A JSON formatter takes raw or minified JSON data and reformats it with proper indentation, line breaks, and syntax highlighting so it's easy to read and debug. It can also validate the JSON structure and report errors with line numbers.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I validate JSON online?</h3>
      <p style="margin-bottom: 16px;">Paste your JSON into the input field on this page. The tool instantly parses it and reports whether it's valid. If there are syntax errors, it shows the exact error message and line number so you can quickly find and fix the problem.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between JSON minify and beautify?</h3>
      <p style="margin-bottom: 16px;">Beautify (or pretty-print) adds indentation and line breaks to make JSON human-readable. Minify removes all unnecessary whitespace to produce the smallest possible output, which is ideal for network transmission and storage. Both operations preserve the data — only the formatting changes.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is it safe to paste sensitive JSON data here?</h3>
      <p style="margin-bottom: 16px;">Yes. All formatting and validation happens entirely in your browser using JavaScript. No data is sent to any server. Your JSON never leaves your device, making it safe to use with API responses, configuration files, and other sensitive data.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the maximum JSON size this tool supports?</h3>
      <p style="margin-bottom: 16px;">This tool supports JSON input up to 1 MB in size. For most use cases — API responses, configuration files, database exports — this is more than sufficient. The tool shows real-time stats including the size of your JSON data.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/jsonpath-tester">JSONPath Tester</a> — Query and extract data from JSON using JSONPath expressions.</li>
      <li><a href="/jwt-decoder">JWT Decoder</a> — Decode and debug JSON Web Tokens online.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions with real-time highlighting.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "JSON Formatter & Validator — Format & Minify",
  description: "Free online JSON formatter, validator, and minifier. Paste JSON to instantly beautify with syntax highlighting, validate with error messages, minify, view as tree, and download. No data leaves your browser.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="siliconbased"
  title="JSON Formatter & Validator — Format & Minify"
  description="Free online JSON formatter, validator, and minifier. Paste JSON to instantly beautify with syntax highlighting, validate with error messages, minify, view as tree, and download. No data leaves your browser."
  canonical="https://siliconbased.dev/json-formatter"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
var MAX_SIZE = 1048576;
var jsonInput = document.getElementById('jsonInput');
var sampleBtn = document.getElementById('sampleBtn');
var clearBtn = document.getElementById('clearBtn');
var fileBtn = document.getElementById('fileBtn');
var fileInput = document.getElementById('fileInput');
var sizeLabel = document.getElementById('sizeLabel');
var validationBanner = document.getElementById('validationBanner');
var validationIcon = document.getElementById('validationIcon');
var validationText = document.getElementById('validationText');
var statsBar = document.getElementById('statsBar');
var statKeys = document.getElementById('statKeys');
var statDepth = document.getElementById('statDepth');
var statSize = document.getElementById('statSize');
var statArrays = document.getElementById('statArrays');
var statObjects = document.getElementById('statObjects');
var actionBar = document.getElementById('actionBar');
var beautifyBtn = document.getElementById('beautifyBtn');
var minifyBtn = document.getElementById('minifyBtn');
var treeBtn = document.getElementById('treeBtn');
var copyBtn = document.getElementById('copyBtn');
var downloadBtn = document.getElementById('downloadBtn');
var outputSection = document.getElementById('outputSection');
var outputWrap = document.getElementById('outputWrap');
var outputCode = document.getElementById('outputCode');
var treeWrap = document.getElementById('treeWrap');
var treeView = document.getElementById('treeView');

var currentMode = 'beautify';
var parsedJson = null;

function escapeHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / 1048576).toFixed(2) + ' MB';
}

function countStats(obj) {
  var keys = 0, arrays = 0, objects = 0, maxDepth = 0;
  function walk(val, depth) {
    if (depth > maxDepth) maxDepth = depth;
    if (val === null || typeof val !== 'object') return;
    if (Array.isArray(val)) {
      arrays++;
      for (var i = 0; i < val.length; i++) walk(val[i], depth + 1);
    } else {
      objects++;
      var k = Object.keys(val);
      keys += k.length;
      for (var i = 0; i < k.length; i++) walk(val[k[i]], depth + 1);
    }
  }
  walk(obj, 0);
  return { keys: keys, depth: maxDepth, arrays: arrays, objects: objects };
}

function syntaxHighlight(json) {
  json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function(match) {
    var cls = 'json-number';
    if (/^"/.test(match)) {
      if (/:$/.test(match)) {
        cls = 'json-key';
      } else {
        cls = 'json-string';
      }
    } else if (/true|false/.test(match)) {
      cls = 'json-boolean';
    } else if (/null/.test(match)) {
      cls = 'json-null';
    }
    return '<span class="' + cls + '">' + match + '</span>';
  });
}

function getErrorLine(input, error) {
  var match = error.message.match(/position\s+(\d+)/i);
  if (match) {
    var pos = parseInt(match[1]);
    var lines = input.substring(0, pos).split('\n');
    return lines.length;
  }
  var lineMatch = error.message.match(/line\s+(\d+)/i);
  if (lineMatch) return parseInt(lineMatch[1]);
  return null;
}

function buildTree(val, key, container, depth) {
  var node = document.createElement('div');
  node.className = 'tree-node';
  node.style.paddingLeft = (depth * 20) + 'px';

  if (val === null) {
    node.innerHTML = (key !== null ? '<span class="tree-key">' + escapeHtml(String(key)) + '</span>: ' : '') + '<span class="json-null">null</span>';
    container.appendChild(node);
    return;
  }

  if (typeof val !== 'object') {
    var valClass = typeof val === 'string' ? 'json-string' : (typeof val === 'boolean' ? 'json-boolean' : 'json-number');
    var display = typeof val === 'string' ? '"' + escapeHtml(val) + '"' : escapeHtml(String(val));
    node.innerHTML = (key !== null ? '<span class="tree-key">' + escapeHtml(String(key)) + '</span>: ' : '') + '<span class="' + valClass + '">' + display + '</span>';
    container.appendChild(node);
    return;
  }

  var isArr = Array.isArray(val);
  var childKeys = isArr ? val : Object.keys(val);
  var len = isArr ? val.length : childKeys.length;
  var toggle = document.createElement('span');
  toggle.className = 'tree-toggle';
  toggle.textContent = '\u25BC';
  node.appendChild(toggle);

  if (key !== null) {
    var keySpan = document.createElement('span');
    keySpan.className = 'tree-key';
    keySpan.textContent = String(key);
    node.appendChild(keySpan);
    node.appendChild(document.createTextNode(': '));
  }

  var summary = document.createElement('span');
  summary.className = 'tree-summary';
  summary.textContent = isArr ? 'Array(' + len + ')' : 'Object {' + len + ' keys}';
  node.appendChild(summary);
  container.appendChild(node);

  var children = document.createElement('div');
  children.className = 'tree-children';
  if (isArr) {
    for (var i = 0; i < val.length; i++) buildTree(val[i], i, children, depth + 1);
  } else {
    var objKeys = Object.keys(val);
    for (var i = 0; i < objKeys.length; i++) buildTree(val[objKeys[i]], objKeys[i], children, depth + 1);
  }
  container.appendChild(children);

  toggle.addEventListener('click', function() {
    var collapsed = children.style.display === 'none';
    children.style.display = collapsed ? '' : 'none';
    toggle.textContent = collapsed ? '\u25BC' : '\u25B6';
  });
}

function updateSizeLabel() {
  var bytes = new Blob([jsonInput.value]).size;
  sizeLabel.textContent = formatSize(bytes);
  sizeLabel.style.color = bytes > MAX_SIZE ? '#f87171' : '';
}

function processJson() {
  var input = jsonInput.value.trim();
  parsedJson = null;
  updateSizeLabel();

  if (!input) {
    validationBanner.style.display = 'none';
    statsBar.style.display = 'none';
    actionBar.style.display = 'none';
    outputSection.style.display = 'none';
    return;
  }

  var bytes = new Blob([input]).size;
  if (bytes > MAX_SIZE) {
    validationBanner.style.display = 'flex';
    validationBanner.className = 'validation-banner invalid';
    validationIcon.textContent = '\u2718';
    validationText.textContent = 'Input too large (' + formatSize(bytes) + '). Maximum supported size is 1 MB.';
    statsBar.style.display = 'none';
    actionBar.style.display = 'none';
    outputSection.style.display = 'none';
    return;
  }

  try {
    parsedJson = JSON.parse(input);
  } catch (e) {
    var line = getErrorLine(input, e);
    validationBanner.style.display = 'flex';
    validationBanner.className = 'validation-banner invalid';
    validationIcon.textContent = '\u2718';
    validationText.textContent = 'Invalid JSON' + (line ? ' (line ' + line + ')' : '') + ': ' + e.message;
    statsBar.style.display = 'none';
    actionBar.style.display = 'none';
    outputSection.style.display = 'none';
    return;
  }

  validationBanner.style.display = 'flex';
  validationBanner.className = 'validation-banner valid';
  validationIcon.textContent = '\u2714';
  validationText.textContent = 'Valid JSON';

  var stats = countStats(parsedJson);
  statKeys.textContent = stats.keys;
  statDepth.textContent = stats.depth;
  statSize.textContent = formatSize(bytes);
  statArrays.textContent = stats.arrays;
  statObjects.textContent = stats.objects;
  statsBar.style.display = 'flex';
  actionBar.style.display = 'flex';
  outputSection.style.display = 'block';

  renderOutput();
}

function renderOutput() {
  if (parsedJson === null) return;

  if (currentMode === 'tree') {
    outputWrap.style.display = 'none';
    treeWrap.style.display = 'block';
    treeView.innerHTML = '';
    buildTree(parsedJson, null, treeView, 0);
  } else {
    outputWrap.style.display = 'block';
    treeWrap.style.display = 'none';
    var formatted;
    if (currentMode === 'minify') {
      formatted = JSON.stringify(parsedJson);
    } else {
      formatted = JSON.stringify(parsedJson, null, 2);
    }
    outputCode.innerHTML = syntaxHighlight(formatted);
  }
}

function setMode(mode) {
  currentMode = mode;
  beautifyBtn.classList.toggle('active', mode === 'beautify');
  minifyBtn.classList.toggle('active', mode === 'minify');
  treeBtn.classList.toggle('active', mode === 'tree');
  renderOutput();
}

function init() {
  jsonInput.addEventListener('input', processJson);

  jsonInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
      e.preventDefault();
      processJson();
    }
  });

  sampleBtn.addEventListener('click', function() {
    jsonInput.value = JSON.stringify({
      "name": "Silicon Based",
      "version": "2.1.0",
      "description": "Developer tools and utilities",
      "author": {
        "name": "Jane Developer",
        "email": "jane@example.com",
        "url": "https://example.com"
      },
      "tags": ["json", "formatter", "validator", "developer-tools"],
      "config": {
        "maxDepth": 10,
        "prettyPrint": true,
        "encoding": "utf-8"
      },
      "endpoints": [
        { "method": "GET", "path": "/api/users", "auth": true },
        { "method": "POST", "path": "/api/users", "auth": true },
        { "method": "DELETE", "path": "/api/users/:id", "auth": true }
      ],
      "stats": {
        "uptime": 99.97,
        "requests": 1284350,
        "errors": 12,
        "cacheHitRate": 0.94
      },
      "active": true,
      "deprecated": null
    }, null, 2);
    processJson();
  });

  clearBtn.addEventListener('click', function() {
    jsonInput.value = '';
    processJson();
    jsonInput.focus();
  });

  fileBtn.addEventListener('click', function() { fileInput.click(); });

  fileInput.addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(ev) {
      jsonInput.value = ev.target.result;
      processJson();
    };
    reader.readAsText(file);
    fileInput.value = '';
  });

  beautifyBtn.addEventListener('click', function() { setMode('beautify'); });
  minifyBtn.addEventListener('click', function() { setMode('minify'); });
  treeBtn.addEventListener('click', function() { setMode('tree'); });

  copyBtn.addEventListener('click', function() {
    if (parsedJson === null) return;
    var text = currentMode === 'minify' ? JSON.stringify(parsedJson) : JSON.stringify(parsedJson, null, 2);
    navigator.clipboard.writeText(text).then(function() {
      copyBtn.textContent = '\u2713 Copied';
      setTimeout(function() { copyBtn.textContent = 'Copy'; }, 1500);
    });
  });

  downloadBtn.addEventListener('click', function() {
    if (parsedJson === null) return;
    var text = currentMode === 'minify' ? JSON.stringify(parsedJson) : JSON.stringify(parsedJson, null, 2);
    var blob = new Blob([text], { type: 'application/json' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'formatted.json';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });
}

init();
