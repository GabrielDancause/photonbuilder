---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const indexPath = path.join(process.cwd(), 'src/data/pseo/cron/_index.json');
  const index = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
  return index.map((item: any) => ({
    params: { slug: item.slug },
    props: { title: item.title, description: item.description },
  }));
}

const { slug } = Astro.params;
const { title, description } = Astro.props;

const contentPath = path.join(process.cwd(), 'src/data/pseo/cron/' + slug + '.html');
const htmlContent = fs.readFileSync(contentPath, 'utf-8');

const cssPath = path.join(process.cwd(), 'src/data/pseo/cron/' + slug + '.css');
let cssContent = '';
try { cssContent = fs.readFileSync(cssPath, 'utf-8'); } catch {}
---

<SiteLayout
  site="siliconbased"
  title={title}
  description={description}
  canonical={`https://siliconbased.dev/cron/${slug}`}
>
  <Fragment set:html={htmlContent} />
  {cssContent && <style is:inline set:html={cssContent} />}
</SiteLayout>
