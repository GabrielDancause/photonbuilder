    async function fetchWeatherDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Loading weather data...</div>';
      try {
        const res = await fetch('https://api.open-meteo.com/v1/forecast?latitude=51.5074&longitude=-0.1278&current=temperature_2m,weathercode,windspeed_10m&timezone=Europe%2FLondon');
        const data = await res.json();
        r.innerHTML = '<div class="demo-result"><h4>London Weather</h4><p><strong>Temperature:</strong> ' + data.current.temperature_2m + '°C</p><p><strong>Wind Speed:</strong> ' + data.current.windspeed_10m + ' km/h</p><p><small>Data from Open-Meteo (no API key needed)</small></p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching weather data.</div>'; }
    }

    async function fetchCryptoDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Loading crypto data...</div>';
      try {
        const res = await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum&vs_currencies=usd');
        const data = await res.json();
        r.innerHTML = '<div class="demo-result"><h4>Crypto Prices</h4><p><strong>Bitcoin:</strong> $' + data.bitcoin.usd.toLocaleString() + '</p><p><strong>Ethereum:</strong> $' + data.ethereum.usd.toLocaleString() + '</p><p><small>Data from CoinGecko</small></p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching crypto data.</div>'; }
    }

    async function fetchCountryDemo() {
      const name = document.getElementById('countryInput').value;
      const r = document.getElementById('demoResult');
      if (!name) { r.innerHTML = '<div class="error">Please enter a country name.</div>'; return; }
      r.innerHTML = '<div class="loading">Loading country data...</div>';
      try {
        const res = await fetch('https://restcountries.com/v3.1/name/' + encodeURIComponent(name));
        const data = await res.json();
        if (data.message || data.status === 404) { r.innerHTML = '<div class="error">Country not found.</div>'; return; }
        const c = data[0];
        r.innerHTML = '<div class="demo-result"><h4>' + c.name.common + '</h4><p><strong>Capital:</strong> ' + (c.capital?.[0] || 'N/A') + '</p><p><strong>Population:</strong> ' + c.population.toLocaleString() + '</p><p><strong>Region:</strong> ' + c.region + '</p><img src="' + c.flags.svg + '" alt="Flag" style="width:100px;margin-top:8px;border-radius:4px;"></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching country data.</div>'; }
    }

    async function fetchCatDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Loading cat...</div>';
      try {
        const res = await fetch('https://api.thecatapi.com/v1/images/search');
        const data = await res.json();
        r.innerHTML = '<div class="demo-result"><h4>Random Cat</h4><img src="' + data[0].url + '" alt="Random Cat" style="max-width:300px;border-radius:8px;"></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching cat image.</div>'; }
    }

    async function fetchDogDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Loading dog...</div>';
      try {
        const res = await fetch('https://api.thedogapi.com/v1/images/search');
        const data = await res.json();
        r.innerHTML = '<div class="demo-result"><h4>Random Dog</h4><img src="' + data[0].url + '" alt="Random Dog" style="max-width:300px;border-radius:8px;"></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching dog image.</div>'; }
    }

    async function fetchJsonDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Fetching post...</div>';
      try {
        const id = Math.floor(Math.random() * 100) + 1;
        const res = await fetch('https://jsonplaceholder.typicode.com/posts/' + id);
        const post = await res.json();
        r.innerHTML = '<div class="demo-result"><h4>Post #' + post.id + '</h4><p><strong>Title:</strong> ' + post.title + '</p><p>' + post.body + '</p><p><small>Data from JSONPlaceholder</small></p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching post.</div>'; }
    }

    async function fetchPokemonDemo() {
      const name = (document.getElementById('pokemonInput').value || 'pikachu').toLowerCase().trim();
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Loading Pokemon...</div>';
      try {
        const res = await fetch('https://pokeapi.co/api/v2/pokemon/' + encodeURIComponent(name));
        if (!res.ok) { r.innerHTML = '<div class="error">Pokemon not found.</div>'; return; }
        const p = await res.json();
        r.innerHTML = '<div class="demo-result"><h4>' + p.name.charAt(0).toUpperCase() + p.name.slice(1) + ' (#' + p.id + ')</h4><img src="' + p.sprites.front_default + '" alt="' + p.name + '" style="width:96px;image-rendering:pixelated;"><p><strong>Types:</strong> ' + p.types.map(t => t.type.name).join(', ') + '</p><p><strong>Height:</strong> ' + p.height/10 + 'm | <strong>Weight:</strong> ' + p.weight/10 + 'kg</p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching Pokemon data.</div>'; }
    }

    async function fetchNasaDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Loading NASA image...</div>';
      try {
        const res = await fetch('https://api.nasa.gov/planetary/apod?api_key=DEMO_KEY');
        const data = await res.json();
        const mediaHtml = data.media_type === 'video'
          ? '<iframe src="' + data.url + '" width="100%" height="300" frameborder="0" allowfullscreen style="border-radius:8px;"></iframe>'
          : '<img src="' + data.url + '" alt="' + data.title + '" style="max-width:100%;border-radius:8px;">';
        r.innerHTML = '<div class="demo-result"><h4>' + data.title + '</h4><p><strong>Date:</strong> ' + data.date + '</p>' + mediaHtml + '<p style="margin-top:8px;font-size:0.85rem;line-height:1.5;">' + data.explanation.slice(0, 300) + '...</p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error fetching NASA data.</div>'; }
    }

    async function fetchDictionaryDemo() {
      const word = (document.getElementById('wordInput').value || 'serendipity').trim();
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Looking up word...</div>';
      try {
        const res = await fetch('https://api.dictionaryapi.dev/api/v2/entries/en/' + encodeURIComponent(word));
        if (!res.ok) { r.innerHTML = '<div class="error">Word not found.</div>'; return; }
        const data = await res.json();
        const entry = data[0];
        const defs = entry.meanings.slice(0, 2).map(m => '<p><strong>' + m.partOfSpeech + ':</strong> ' + m.definitions[0].definition + '</p>').join('');
        r.innerHTML = '<div class="demo-result"><h4>' + entry.word + ' ' + (entry.phonetic || '') + '</h4>' + defs + '<p><small>Data from Free Dictionary API</small></p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error looking up word.</div>'; }
    }

    async function fetchRandomUserDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Generating user...</div>';
      try {
        const res = await fetch('https://randomuser.me/api/');
        const data = await res.json();
        const u = data.results[0];
        r.innerHTML = '<div class="demo-result"><div style="display:flex;align-items:center;gap:12px;"><img src="' + u.picture.medium + '" alt="User" style="border-radius:50%;width:72px;height:72px;"><div><h4>' + u.name.first + ' ' + u.name.last + '</h4><p>' + u.email + '</p></div></div><p><strong>Location:</strong> ' + u.location.city + ', ' + u.location.country + '</p><p><strong>Phone:</strong> ' + u.phone + '</p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error generating user.</div>'; }
    }

    async function fetchPicsumDemo() {
      const r = document.getElementById('demoResult');
      r.innerHTML = '<div class="loading">Loading photo...</div>';
      try {
        const id = Math.floor(Math.random() * 200) + 1;
        const infoRes = await fetch('https://picsum.photos/id/' + id + '/info');
        const info = await infoRes.json();
        r.innerHTML = '<div class="demo-result"><h4>Photo by ' + info.author + '</h4><img src="https://picsum.photos/id/' + id + '/400/300" alt="Random" style="max-width:100%;border-radius:8px;"><p><strong>Original size:</strong> ' + info.width + 'x' + info.height + '</p></div>';
      } catch (e) { r.innerHTML = '<div class="error">Error loading photo.</div>'; }
    }

    function fetchQrDemo() {
      const text = document.getElementById('qrInput').value || 'https://siliconbased.dev';
      const r = document.getElementById('demoResult');
      const url = 'https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=' + encodeURIComponent(text);
      r.innerHTML = '<div class="demo-result"><h4>QR Code</h4><img src="' + url + '" alt="QR Code" style="border-radius:8px;background:#fff;padding:8px;"><p><strong>Text:</strong> ' + text + '</p></div>';
    }
  </script>

