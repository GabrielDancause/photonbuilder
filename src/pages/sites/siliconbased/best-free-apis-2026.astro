import SiteLayout from "../../../layouts/SiteLayout.astro";
const schema = [
  {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are free APIs reliable for production use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Many free APIs are reliable for side projects and MVPs, but for mission-critical production use, you should evaluate their uptime guarantees, rate limits, and SLA. Often, transitioning to a paid tier is necessary as your application scales."
        }
      },
      {
        "@type": "Question",
        "name": "How do I handle API rate limits on free tiers?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To handle rate limits, implement caching to reduce redundant requests, use queues to pace your outbound calls, and implement exponential backoff strategies for retrying failed requests when limits are hit."
        }
      },
      {
        "@type": "Question",
        "name": "Do free APIs require authentication?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most high-quality free APIs require authentication via an API key or OAuth. This allows providers to track usage, enforce rate limits, and prevent abuse, even on their free tiers."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between REST and GraphQL APIs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "REST APIs expose multiple endpoints for different resources and use standard HTTP methods, while GraphQL exposes a single endpoint and allows clients to request exactly the data they need, reducing over-fetching."
        }
      },
      {
        "@type": "Question",
        "name": "Can I monetize an app built entirely on free APIs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, you can monetize apps built with free APIs, but you must carefully read the Terms of Service for each API. Some providers explicitly forbid commercial use of their free tiers or require attribution."
        }
      }
    ]
  }
];
