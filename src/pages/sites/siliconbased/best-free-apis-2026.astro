    let currentCategory = 'all';
    let currentSort = 'name';
    let searchTerm = '';
    let selectedForCompare = new Set();

    document.addEventListener('DOMContentLoaded', function() {
      setupEventListeners();
      setupFAQ();
    });

    function filterAndSort() {
      const cards = document.querySelectorAll('#apiGrid .api-card');
      const rows = document.querySelectorAll('#apiTableBody tr');
      let visibleCount = 0;
      const term = searchTerm.toLowerCase();

      // Build sorted order
      let indices = apiIndex.map((api, i) => i);
      indices.sort((a, b) => {
        const aa = apiIndex[a], bb = apiIndex[b];
        switch (currentSort) {
          case 'name': return aa.name.localeCompare(bb.name);
          case 'category': return aa.category.localeCompare(bb.category) || aa.name.localeCompare(bb.name);
          case 'rate-limit': return bb.rateScore - aa.rateScore || aa.name.localeCompare(bb.name);
          default: return 0;
        }
      });

      // Reorder DOM elements
      const grid = document.getElementById('apiGrid');
      const tbody = document.getElementById('apiTableBody');
      indices.forEach(i => {
        const api = apiIndex[i];
        const card = grid.querySelector('[data-name="' + api.name + '"]');
        const row = tbody.querySelector('[data-name="' + api.name + '"]');
        
        const matchesCat = currentCategory === 'all' || api.category === currentCategory;
        const matchesSearch = term === '' ||
          api.name.toLowerCase().includes(term) ||
          api.description.toLowerCase().includes(term) ||
          api.category.toLowerCase().includes(term) ||
          api.authType.toLowerCase().includes(term) ||
          api.freeTier.toLowerCase().includes(term);
        const visible = matchesCat && matchesSearch;

        if (card) {
          card.style.display = visible ? '' : 'none';
          grid.appendChild(card); // reorder
        }
        if (row) {
          row.style.display = visible ? '' : 'none';
          tbody.appendChild(row);
        }
        if (visible) visibleCount++;
      });

      document.getElementById('resultCount').textContent = visibleCount + ' of ' + apiIndex.length + ' APIs';
      updateCompareButton();
    }

    function copyCode(btn) {
      const code = btn.nextElementSibling.textContent;
      navigator.clipboard.writeText(code).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1500);
      });
    }

    function copyUrl(url, btn) {
      navigator.clipboard.writeText(url).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = 'Copied!';
        btn.style.color = '#48bb78';
        setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; }, 1500);
      });
    }

    function toggleCompare(name) {
      if (selectedForCompare.has(name)) {
        selectedForCompare.delete(name);
      } else if (selectedForCompare.size < 2) {
        selectedForCompare.add(name);
      } else {
        const first = selectedForCompare.values().next().value;
        selectedForCompare.delete(first);
        selectedForCompare.add(name);
      }
      // Update button states
      document.querySelectorAll('.btn-compare').forEach(btn => {
        const card = btn.closest('.api-card');
        if (!card) return;
        const n = card.dataset.name;
        if (selectedForCompare.has(n)) {
          btn.innerHTML = '&#10003;';
          btn.classList.add('btn-compare-active');
          card.classList.add('compare-selected');
        } else {
          btn.innerHTML = '+';
          btn.classList.remove('btn-compare-active');
          card.classList.remove('compare-selected');
        }
      });
      updateCompareButton();
    }

    function updateCompareButton() {
      const btn = document.getElementById('compareBtn');
      const count = document.getElementById('compareCount');
      count.textContent = selectedForCompare.size;
      btn.style.display = selectedForCompare.size > 0 ? 'inline-block' : 'none';
      btn.disabled = selectedForCompare.size < 2;
      btn.style.opacity = selectedForCompare.size < 2 ? '0.5' : '1';
    }

    function getRateDescription(score) {
      if (score >= 9) return 'Very Generous';
      if (score >= 7) return 'Good';
      if (score >= 5) return 'Moderate';
      return 'Limited';
    }

    function showCompare() {
      if (selectedForCompare.size < 2) return;
      const names = Array.from(selectedForCompare);
      const a = apiIndex.find(x => x.name === names[0]);
      const b = apiIndex.find(x => x.name === names[1]);
      if (!a || !b) return;
      
      // Get code from the cards
      const cardA = document.querySelector('[data-name="' + a.name + '"] code');
      const cardB = document.querySelector('[data-name="' + b.name + '"] code');
      const codeA = cardA ? cardA.textContent : '';
      const codeB = cardB ? cardB.textContent : '';
      function escH(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

      const modal = document.getElementById('compareModal');
      document.getElementById('compareBody').innerHTML =
        '<div class="compare-grid">' +
        '<div class="compare-label"></div><div class="compare-api-name">' + a.name + '</div><div class="compare-api-name">' + b.name + '</div>' +
        '<div class="compare-label">Category</div><div>' + a.category + '</div><div>' + b.category + '</div>' +
        '<div class="compare-label">Free Tier</div><div>' + a.freeTier + '</div><div>' + b.freeTier + '</div>' +
        '<div class="compare-label">Auth</div><div>' + a.authType + '</div><div>' + b.authType + '</div>' +
        '<div class="compare-label">Rate Score</div><div>' + a.rateScore + '/10</div><div>' + b.rateScore + '/10</div>' +
        '<div class="compare-label">Rate Feel</div><div>' + getRateDescription(a.rateScore) + '</div><div>' + getRateDescription(b.rateScore) + '</div>' +
        '<div class="compare-label">Live Demo</div><div>' + (a.tryItDemo ? 'Yes' : 'No') + '</div><div>' + (b.tryItDemo ? 'Yes' : 'No') + '</div>' +
        '<div class="compare-label">Code</div><div class="compare-code"><pre><code>' + escH(codeA) + '</code></pre></div><div class="compare-code"><pre><code>' + escH(codeB) + '</code></pre></div>' +
        '</div>';
      modal.style.display = 'flex';
    }

    function setupEventListeners() {
      document.getElementById('searchInput').addEventListener('input', function() {
        searchTerm = this.value;
        filterAndSort();
      });

      document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          currentCategory = this.dataset.category;
          filterAndSort();
        });
      });

      document.getElementById('sortSelect').addEventListener('change', function() {
        currentSort = this.value;
        filterAndSort();
      });

      document.getElementById('compareBtn').addEventListener('click', showCompare);
      document.getElementById('closeCompare').addEventListener('click', function() {
        document.getElementById('compareModal').style.display = 'none';
      });
      document.getElementById('compareModal').addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
      });

      document.getElementById('viewCards').addEventListener('click', () => {
        document.getElementById('apiGrid').style.display = '';
        document.getElementById('apiTable').style.display = 'none';
        document.getElementById('viewCards').classList.add('active');
        document.getElementById('viewTable').classList.remove('active');
      });
      document.getElementById('viewTable').addEventListener('click', () => {
        document.getElementById('apiGrid').style.display = 'none';
        document.getElementById('apiTable').style.display = 'block';
        document.getElementById('viewTable').classList.add('active');
        document.getElementById('viewCards').classList.remove('active');
      });
    }

    function setupFAQ() {
      document.querySelectorAll('.faq-question').forEach(question => {
        question.addEventListener('click', function() {
          const item = this.parentElement;
          const isOpen = item.classList.contains('open');
          document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
          if (!isOpen) item.classList.add('open');
        });
      });
    }

