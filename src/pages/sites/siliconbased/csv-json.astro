---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSV to JSON Converter",
    "url": "https://siliconbased.dev/csv-json",
    "description": "Interactive tool to convert CSV data to JSON arrays/objects and vice versa. Auto-detects delimiters and handles complex CSV structures including quotes and newlines.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    }
  }
];
---

<SiteLayout
  site="siliconbased"
  title="CSV to JSON Converter & JSON to CSV | Free Online Tool"
  description="Convert CSV to JSON or JSON to CSV instantly. Auto-detects delimiters, handles quoted fields and newlines. Free, offline-capable, runs completely in your browser."
  canonical="https://siliconbased.dev/csv-json"
  schema={schemas}
>
  <style is:inline>
code, pre, .mono { font-family: "JetBrains Mono", monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }
.tool-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 40px; align-items: stretch; }
.pane { display: flex; flex-direction: column; }
.input-header, .output-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.header-title { font-size: 0.85rem; font-weight: 600; color: #ccc; text-transform: uppercase; letter-spacing: 0.5px; }
.header-actions { display: flex; gap: 8px; flex-wrap: wrap; }
.action-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 6px 12px; border-radius: 8px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: "Inter", sans-serif; transition: all 0.15s; }
.action-btn:hover { background: #2a2d40; color: #ccc; }
.action-btn.active { background: #818cf8; color: #fff; border-color: #818cf8; }
textarea.data-area { flex: 1; min-height: 400px; background: #111318; border: 2px solid #1e2030; border-radius: 12px; padding: 16px; color: #e0e0e0; font-family: "JetBrains Mono", monospace; font-size: 0.88rem; resize: vertical; outline: none; transition: border-color 0.2s; line-height: 1.6; white-space: pre; }
textarea.data-area:focus { border-color: #818cf8; }
textarea.data-area.error-border { border-color: #f87171; }
.copy-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 6px 14px; border-radius: 8px; font-size: 0.75rem; font-weight: 500; cursor: pointer; font-family: "Inter", sans-serif; transition: all 0.15s; }
.copy-btn:hover { background: #2a2d40; color: #ccc; }
.copy-btn.copied { background: #1a3a1a; color: #4ade80; border-color: #2d5a2d; }
.error-msg { background: #f87171; color: #fff; padding: 12px 16px; font-size: 0.85rem; font-weight: 500; display: none; align-items: flex-start; gap: 10px; font-family: "JetBrains Mono", monospace; word-break: break-word; border-bottom: 1px solid #dc2626; border-radius: 12px 12px 0 0; }
.error-msg svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px; }
.textarea-wrapper { display: flex; flex-direction: column; flex: 1; position: relative; }
.textarea-wrapper textarea { border-top-left-radius: 0; border-top-right-radius: 0; }
.textarea-wrapper.no-error textarea { border-radius: 12px; }
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }
.seo-content code { background: #111318; padding: 2px 6px; border-radius: 4px; color: #818cf8; font-size: 0.85em; }
.footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #555; border-top: 1px solid #151520; margin-top: auto; }
.footer a { color: #818cf8; text-decoration: none; }
.footer a:hover { text-decoration: underline; }
@media (max-width: 800px) {
  .tool-grid { grid-template-columns: 1fr; }
  textarea.data-area { min-height: 300px; }
}
</style>


  <script is:inline>

// Expose functions for testing
const Converter = (function() {

  // --- CSV Parser ---
  function parseCSV(text) {
    if (!text || !text.trim()) return [];

    const lines = text.split(/\r?\n/);
    if (lines.length === 0) return [];

    // Auto-detect delimiter
    const firstLine = lines[0];
    let delimiter = ',';
    const commaCount = (firstLine.match(/,/g) || []).length;
    const tabCount = (firstLine.match(/\t/g) || []).length;
    const semiCount = (firstLine.match(/;/g) || []).length;

    if (tabCount > commaCount && tabCount > semiCount) {
      delimiter = '\t';
    } else if (semiCount > commaCount && semiCount > tabCount) {
      delimiter = ';';
    }

    const rows = [];
    let currentRow = [];
    let currentCell = '';
    let inQuotes = false;

    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      const nextChar = text[i + 1];

      if (char === '"') {
        if (inQuotes && nextChar === '"') {
          // Escaped quote
          currentCell += '"';
          i++; // skip next quote
        } else {
          // Toggle quote state
          inQuotes = !inQuotes;
        }
      } else if (char === delimiter && !inQuotes) {
        currentRow.push(currentCell);
        currentCell = '';
      } else if ((char === '\r' || char === '\n') && !inQuotes) {
        if (char === '\r' && nextChar === '\n') {
          i++; // Skip \n
        }
        currentRow.push(currentCell);
        rows.push(currentRow);
        currentRow = [];
        currentCell = '';
      } else {
        currentCell += char;
      }
    }

    // Push the last cell/row if not empty or ending with a newline
    if (currentCell !== '' || text[text.length - 1] === delimiter) {
      currentRow.push(currentCell);
    }
    if (currentRow.length > 0) {
      rows.push(currentRow);
    }

    // Clean up empty last row if it exists due to trailing newline
    if (rows.length > 0 && rows[rows.length - 1].length === 1 && rows[rows.length - 1][0] === '') {
      rows.pop();
    }

    return rows;
  }

  // --- JSON to CSV ---
  function jsonToCSV(jsonObj) {
    if (!Array.isArray(jsonObj)) {
      if (typeof jsonObj === 'object' && jsonObj !== null) {
        // If single object, wrap in array
        jsonObj = [jsonObj];
      } else {
        throw new Error('Input must be an array of objects or an array of arrays.');
      }
    }

    if (jsonObj.length === 0) return '';

    let csvRows = [];

    // Check if it's an array of arrays
    if (Array.isArray(jsonObj[0])) {
      for (const row of jsonObj) {
        csvRows.push(row.map(escapeCSVCell).join(','));
      }
      return csvRows.join('\n');
    }

    // Array of objects
    // Extract all unique headers
    const headers = [];
    for (const row of jsonObj) {
      if (typeof row === 'object' && row !== null && !Array.isArray(row)) {
        for (const key of Object.keys(row)) {
          if (!headers.includes(key)) {
            headers.push(key);
          }
        }
      }
    }

    if (headers.length === 0) return '';

    // Add header row
    csvRows.push(headers.map(escapeCSVCell).join(','));

    // Add data rows
    for (const row of jsonObj) {
      if (typeof row === 'object' && row !== null) {
        const values = headers.map(header => {
          let val = row[header];
          if (val === null || val === undefined) return '';
          if (typeof val === 'object') return JSON.stringify(val);
          return String(val);
        });
        csvRows.push(values.map(escapeCSVCell).join(','));
      }
    }

    return csvRows.join('\n');
  }

  function escapeCSVCell(cell) {
    if (cell == null) return '';
    const str = String(cell);
    if (str.includes(',') || str.includes('"') || str.includes('\n') || str.includes('\r')) {
      return '"' + str.replace(/"/g, '""') + '"';
    }
    return str;
  }

  // --- Converters ---
  function csvToJsonObjects(csvText) {
    const rows = parseCSV(csvText);
    if (rows.length < 2) return [];
    const headers = rows[0];
    const data = [];
    for (let i = 1; i < rows.length; i++) {
      const row = rows[i];
      const obj = {};
      for (let j = 0; j < headers.length; j++) {
        obj[headers[j]] = row[j] !== undefined ? row[j] : '';
      }
      data.push(obj);
    }
    return data;
  }

  function csvToJsonArray(csvText) {
    return parseCSV(csvText);
  }

  return {
    parseCSV,
    jsonToCSV,
    csvToJsonObjects,
    csvToJsonArray
  };
})();

// Export for Node.js testing
if (typeof module !== 'undefined' && module.exports) {
  module.exports = Converter;
}

// UI Logic
if (typeof window !== 'undefined' && typeof document !== 'undefined') {
  const dataInput = document.getElementById('dataInput');
  const dataOutput = document.getElementById('dataOutput');
  const inputErrorMsg = document.getElementById('inputErrorMsg');
  const inputErrorText = document.getElementById('inputErrorText');
  const outputErrorMsg = document.getElementById('outputErrorMsg');
  const outputErrorText = document.getElementById('outputErrorText');
  const inputWrapper = document.getElementById('inputWrapper');
  const outputWrapper = document.getElementById('outputWrapper');
  const inputTitle = document.getElementById('inputTitle');
  const outputTitle = document.getElementById('outputTitle');

  const btnModeAuto = document.getElementById('btnModeAuto');
  const btnModeArray = document.getElementById('btnModeArray');
  const btnModeObj = document.getElementById('btnModeObj');
  const btnModeCsv = document.getElementById('btnModeCsv');
  const btnSwap = document.getElementById('btnSwap');
  const clearBtn = document.getElementById('clearBtn');
  const copyInputBtn = document.getElementById('copyInputBtn');
  const copyOutputBtn = document.getElementById('copyOutputBtn');

  let currentMode = 'auto'; // auto, toArray, toObj, toCsv
  let debounceTimer;

  function init() {
    dataInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(processData, 300);
    });

    btnModeAuto.addEventListener('click', () => setMode('auto'));
    btnModeArray.addEventListener('click', () => setMode('toArray'));
    btnModeObj.addEventListener('click', () => setMode('toObj'));
    btnModeCsv.addEventListener('click', () => setMode('toCsv'));

    clearBtn.addEventListener('click', () => {
      dataInput.value = '';
      processData();
      dataInput.focus();
    });

    btnSwap.addEventListener('click', () => {
      const outputVal = dataOutput.value;
      if (outputVal) {
        dataInput.value = outputVal;
        setMode('auto');
        processData();
      }
    });

    copyInputBtn.addEventListener('click', () => copyToClipboard(dataInput.value, copyInputBtn));
    copyOutputBtn.addEventListener('click', () => copyToClipboard(dataOutput.value, copyOutputBtn));

    // Sample data
    dataInput.value = "id,name,role,email\n1,Alice,\"Engineer, Senior\",alice@example.com\n2,Bob,Designer,bob@example.com\n3,Charlie,Product Manager,\"charlie@example.com\"";
    processData();
  }

  function setMode(mode) {
    currentMode = mode;
    btnModeAuto.classList.toggle('active', mode === 'auto');
    btnModeArray.classList.toggle('active', mode === 'toArray');
    btnModeObj.classList.toggle('active', mode === 'toObj');
    btnModeCsv.classList.toggle('active', mode === 'toCsv');
    processData();
  }

  function copyToClipboard(text, btn) {
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      const originalText = btn.textContent;
      btn.textContent = '✓ Copied';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = originalText;
        btn.classList.remove('copied');
      }, 1500);
    });
  }

  function clearErrors() {
    inputWrapper.classList.add('no-error');
    outputWrapper.classList.add('no-error');
    dataInput.classList.remove('error-border');
    dataOutput.classList.remove('error-border');
    inputErrorMsg.style.display = 'none';
    outputErrorMsg.style.display = 'none';
  }

  function showOutputError(msg) {
    clearErrors();
    outputWrapper.classList.remove('no-error');
    dataOutput.classList.add('error-border');
    outputErrorMsg.style.display = 'flex';
    outputErrorText.textContent = msg;
    dataOutput.value = '';
  }

  function determineInputType(text) {
    text = text.trim();
    if (!text) return 'empty';
    if (text.startsWith('{') || text.startsWith('[')) {
      try {
        JSON.parse(text);
        return 'json';
      } catch (e) {
        // Might be malformed JSON, but let's assume JSON if it starts with brackets
        return 'json';
      }
    }
    return 'csv';
  }

  function processData() {
    clearErrors();
    const raw = dataInput.value.trim();
    if (!raw) {
      dataOutput.value = '';
      inputTitle.textContent = 'Input';
      outputTitle.textContent = 'Output';
      return;
    }

    const inputType = determineInputType(raw);
    let targetMode = currentMode;

    if (currentMode === 'auto') {
      targetMode = inputType === 'csv' ? 'toObj' : 'toCsv';
    }

    inputTitle.textContent = inputType === 'csv' ? 'Input (CSV)' : 'Input (JSON)';

    try {
      let result = '';
      if (targetMode === 'toCsv') {
        outputTitle.textContent = 'Output (CSV)';
        let parsedJson;
        try {
          parsedJson = JSON.parse(raw);
        } catch (e) {
          throw new Error('Invalid JSON input: ' + e.message);
        }
        result = Converter.jsonToCSV(parsedJson);
      } else if (targetMode === 'toObj') {
        outputTitle.textContent = 'Output (JSON Objects)';
        const jsonObj = Converter.csvToJsonObjects(raw);
        result = JSON.stringify(jsonObj, null, 2);
      } else if (targetMode === 'toArray') {
        outputTitle.textContent = 'Output (JSON Array)';
        const jsonObj = Converter.csvToJsonArray(raw);
        result = JSON.stringify(jsonObj, null, 2);
      }

      dataOutput.value = result;
    } catch (err) {
      showOutputError(err.message);
    }
  }

  init();
}

</script>

</SiteLayout>
