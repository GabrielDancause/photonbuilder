---
import SiteLayout from '../../../../layouts/SiteLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const contentPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/siliconbased_lists.html');
const htmlContent = fs.readFileSync(contentPath, 'utf-8');

const cssPath = path.join(process.cwd(), 'src/data/pseo/category-indexes/siliconbased_lists.css');
let cssContent = '';
try { cssContent = fs.readFileSync(cssPath, 'utf-8'); } catch {}
---

<SiteLayout
  site="siliconbased"
  title="Curated Lists for Developers | siliconbased.dev"
  description="Curated lists of the best developer tools, libraries, frameworks, and resources."
  canonical="https://{}/lists/"
>
  <Fragment set:html={htmlContent} />
  {cssContent && <style is:inline set:html={cssContent} />}
</SiteLayout>
