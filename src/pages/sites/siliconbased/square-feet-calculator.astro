        </div>
        <div>
          <label for="widthInput" style="display:block; margin-bottom:0.5rem; font-weight:bold;">Width (Feet)</label>
          <input type="number" id="widthInput" value="10" min="0" step="0.1">
          <div id="widthError" style="color: red; font-size: 0.8rem; display: none;">Please enter a valid width.</div>
        </div>
        <div>
          <label for="pricePerSqFt" style="display:block; margin-bottom:0.5rem; font-weight:bold;">Price per Sq Ft ($) (Optional)</label>
          <input type="number" id="pricePerSqFt" value="" placeholder="e.g., 2.50" min="0" step="0.01">
          <div id="priceError" style="color: red; font-size: 0.8rem; display: none;">Please enter a valid price.</div>
        </div>
      </div>

      <div class="result-card">
        <div style="font-size: 1.2rem; margin-bottom: 0.5rem;">Total Area</div>
        <div class="result-value" id="sqFtResult">0 sq ft</div>

        <div id="costContainer" style="display: none; margin-top: 1rem; font-size: 1.1rem; color: var(--text-primary);">
          Estimated Cost: <strong id="totalCostResult" style="color: var(--accent-color);">$0.00</strong>
