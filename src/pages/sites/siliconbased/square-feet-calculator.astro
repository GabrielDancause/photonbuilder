      <div style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
        <div>
          <label for="lengthInput" style="display:block; margin-bottom:0.5rem; font-weight:bold;">Length (Feet)</label>
