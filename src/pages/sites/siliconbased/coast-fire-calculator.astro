---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Coast FIRE Calculator | Your Timeline to Financial Independence",
  description: "Are you already financially independent without realizing it? Use our Coast FIRE calculator to find out if your current investments will grow to fund your retirement.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Coast FIRE Calculator: Your Timeline to Financial Independence",
      "description": "Are you already financially independent without realizing it? Use our Coast FIRE calculator to find out if your current investments will grow to fund your retirement.",
      "author": {
        "@type": "Organization",
        "name": "Silicon Based"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Silicon Based",
        "logo": {
          "@type": "ImageObject",
          "url": "https://siliconbased.dev/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://siliconbased.dev/coast-fire-calculator"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What exactly is Coast FIRE?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Coast FIRE is a milestone in the Financial Independence, Retire Early (FIRE) movement. You reach Coast FIRE when your current invested assets, assuming an average rate of return, will grow large enough to fund your retirement target without requiring another dime of contributions."
          }
        },
        {
          "@type": "Question",
          "name": "What return rate should I use in the calculator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "It is highly recommended to use a 'real' return rate, which is the expected market return minus expected inflation. Historically, the S&P 500 returns about 10% annually before inflation. Subtracting a 3% historical inflation rate gives you a 7% real return rate. If you want to be conservative, use 5% or 6%."
          }
        },
        {
          "@type": "Question",
          "name": "Does reaching Coast FIRE mean I can retire today?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Reaching Coast FIRE means you have secured your traditional retirement age. You still need to generate enough income to cover your living expenses from today until your target retirement age, but you no longer need to save for retirement, freeing up income to upgrade your lifestyle or take a lower-stress job."
          }
        },
        {
          "@type": "Question",
          "name": "What is the 4% rule (Safe Withdrawal Rate)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 4% rule comes from the Trinity Study, which found that an investor with a portfolio of 50% stocks and 50% bonds could withdraw 4% of the portfolio's initial value annually (adjusted for inflation) without running out of money over a 30-year retirement period. Our calculator uses this concept to determine your total FIRE target."
          }
        },
        {
          "@type": "Question",
          "name": "How is the Coast FIRE number calculated mathematically?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Coast FIRE number uses the Present Value formula: PV = FV / (1 + r)^t. We calculate your Future Value (Total FIRE Target) by dividing your annual spend by your withdrawal rate. We then discount that amount backward by your assumed annual return rate (r) over the number of years (t) between your current age and retirement age."
          }
        }
      ]
    }
  ]
};
---

<SiteLayout
  site="siliconbased"
  title={meta.title}
  description={meta.description}
  canonical="https://siliconbased.dev/coast-fire-calculator"
  schema={schema}
>
  <div class="page-content">
    <div class="hero">
      <h1>Coast FIRE Calculator</h1>
      <p class="subtitle">Find out when you can stop saving and let compound interest do the heavy lifting.</p>
    </div>

    <div class="calculator-container" id="calculator">
      <div class="grid-2">
        <div class="form-group">
          <label for="currentAge">Current Age</label>
          <input type="number" id="currentAge" value="30" min="18" max="80" step="1" />
          <div id="currentAgeError" class="error-msg">Please enter a valid age.</div>
        </div>

        <div class="form-group">
          <label for="retireAge">Target Retirement Age</label>
          <input type="number" id="retireAge" value="65" min="30" max="100" step="1" />
          <div id="retireAgeError" class="error-msg">Retirement age must be greater than current age.</div>
        </div>
      </div>

      <div class="grid-2">
        <div class="form-group">
          <label for="currentAssets">Current Invested Assets</label>
          <div class="input-wrapper">
            <span class="input-prefix">$</span>
            <input type="number" id="currentAssets" class="has-prefix" value="100000" min="0" step="1000" />
          </div>
          <div id="currentAssetsError" class="error-msg">Please enter a valid asset amount.</div>
        </div>

        <div class="form-group">
          <label for="annualSpend">Annual Retirement Spend</label>
          <div class="input-wrapper">
            <span class="input-prefix">$</span>
            <input type="number" id="annualSpend" class="has-prefix" value="60000" min="10000" step="1000" />
          </div>
          <div id="annualSpendError" class="error-msg">Please enter a valid spending amount.</div>
        </div>
      </div>

      <div class="grid-2">
        <div class="form-group">
          <label for="returnRate">Expected Annual Return (Real)</label>
          <div class="input-wrapper">
            <input type="number" id="returnRate" class="has-suffix" value="7" min="1" max="15" step="0.1" />
            <span class="input-suffix">%</span>
          </div>
          <div id="returnRateError" class="error-msg">Enter a realistic return rate (1-15%).</div>
        </div>

        <div class="form-group">
          <label for="withdrawalRate">Safe Withdrawal Rate</label>
          <div class="input-wrapper">
            <input type="number" id="withdrawalRate" class="has-suffix" value="4" min="2" max="10" step="0.1" />
            <span class="input-suffix">%</span>
          </div>
          <div id="withdrawalRateError" class="error-msg">Enter a valid withdrawal rate (e.g. 4%).</div>
        </div>
      </div>

      <div class="result-card">
        <div style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 0.5rem;">Your Coast FIRE Number</div>
        <div class="result-value" id="coastFireResult">$0</div>
        <div id="coastStatus" class="coast-status status-pending">Status pending</div>
      </div>

      <div class="grid-3">
        <div class="stat-box">
          <div class="stat-label">Total FIRE Target</div>
          <div class="stat-value" id="fireTarget">$0</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Years to Grow</div>
          <div class="stat-value" id="yearsToGrow">0 years</div>
        </div>
        <div class="stat-box">
          <div class="stat-label">Projected Future Value</div>
          <div class="stat-value" id="projectedAssets">$0</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Coast FIRE: The Psychology of Financial Freedom</h2>
      <p>The traditional Financial Independence, Retire Early (FIRE) movement often conjures images of extreme frugality—eating rice and beans while saving 70% of your income to escape the corporate grind in your 30s. While effective for some, that path is grueling and largely inaccessible to the average earner.</p>
      <p>Enter <strong>Coast FIRE</strong>. Coast FIRE is a financial milestone that shifts the focus from retiring tomorrow to securing your future today. Our Coast FIRE Calculator helps you determine the exact dollar amount you need invested right now so that, through the magic of compound interest, your portfolio will grow to your full retirement number by the time you reach traditional retirement age—without you ever contributing another dime.</p>

      <h3>The Mechanics of Coasting</h3>
      <p>To understand Coast FIRE, you first need to understand your standard FIRE Number. Your FIRE Number is the total portfolio value required to sustain your lifestyle indefinitely without working. This is typically calculated using the <strong>Safe Withdrawal Rate (SWR)</strong>, often set at 4% based on historical market data (the Trinity Study).</p>
      <p>If you anticipate needing $60,000 per year in retirement, and you plan to withdraw 4% annually, your Total FIRE Target is $1,500,000 ($60,000 / 0.04).</p>
      <p>Reaching $1.5 million takes decades of consistent investing. However, reaching the <em>Coast FIRE</em> number for that target can happen surprisingly fast, especially if you start young. If you are 30 years old with a target retirement age of 65, your money has 35 years to grow. Assuming an inflation-adjusted (real) return rate of 7%, you only need about <strong>$140,000</strong> invested today to reach $1.5 million by age 65.</p>
      <p>Once you hit that $140,000 mark, you have reached Coast FIRE.</p>

      <h3>Why Real Return Rate Matters</h3>
      <p>When projecting growth over decades, inflation is the silent killer. A million dollars in 30 years will not have the same purchasing power as a million dollars today. To account for this, our calculator relies on a <strong>Real Return Rate</strong>.</p>
      <ul>
        <li><strong>Nominal Return:</strong> The actual percentage the stock market grows in a year. Historically, the S&P 500 averages about 10% nominal return.</li>
        <li><strong>Inflation Rate:</strong> The rate at which money loses its purchasing power. Historically, this averages about 3% annually in the US.</li>
        <li><strong>Real Return:</strong> Nominal Return minus Inflation (10% - 3% = 7%).</li>
      </ul>
      <p>By using a 7% Real Return Rate, the numbers output by our calculator are represented in <em>today's dollars</em>. When the calculator says you will have $1.5 million in 35 years, it means you will have the equivalent purchasing power of $1.5 million today. If you want to build a more conservative plan, adjust the return rate down to 5% or 6%.</p>

      <h3>The Mathematical Formula</h3>
      <p>The logic running our calculator is based on the fundamental financial equation for Present Value (PV), which determines what a future sum of money is worth today given a specific rate of return.</p>
      <p><code>Coast FIRE Number = FIRE Target / (1 + Return Rate) ^ Years to Grow</code></p>
      <p>For example: $1,500,000 / (1 + 0.07) ^ 35 = $140,515. This elegant math illustrates why front-loading your retirement investments early in your career is infinitely more powerful than trying to play catch-up in your 50s.</p>

      <h3>What Changes When You Hit Coast FIRE?</h3>
      <p>Reaching Coast FIRE does not mean you can quit your job and move to a beach today. You still need to cover your current living expenses. However, hitting this milestone provides a massive psychological shift. Your retirement is functionally "paid for."</p>
      <p>Because you no longer need to allocate 15% to 20% of your income to retirement savings, that money is freed up. You can use it to upgrade your current lifestyle, pay off a mortgage faster, or travel. Alternatively, many use Coast FIRE as a green light to "downshift" their careers—leaving a high-stress, high-paying corporate job for a lower-paying job they actually enjoy, known as "Barista FIRE."</p>

      <h3>Physical Health Meets Financial Wealth</h3>
      <p>Building wealth takes time, and you want to ensure your body is capable of enjoying that wealth when you reach your target retirement age. As you age, maintaining muscle mass becomes one of the most critical factors for longevity and quality of life. While you let compound interest work on your portfolio, let compound fitness work on your body. Check out our <a href="/sites/siliconbased/protein-intake-calculator">Protein Intake Calculator</a> to ensure you are fueling your physical future as well as your financial one.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What exactly is Coast FIRE?</summary>
        <p>Coast FIRE is a milestone in the Financial Independence, Retire Early (FIRE) movement. You reach Coast FIRE when your current invested assets, assuming an average rate of return, will grow large enough to fund your retirement target without requiring another dime of contributions.</p>
      </details>
      <details>
        <summary>What return rate should I use in the calculator?</summary>
        <p>It is highly recommended to use a 'real' return rate, which is the expected market return minus expected inflation. Historically, the S&P 500 returns about 10% annually before inflation. Subtracting a 3% historical inflation rate gives you a 7% real return rate. If you want to be conservative, use 5% or 6%.</p>
      </details>
      <details>
        <summary>Does reaching Coast FIRE mean I can retire today?</summary>
        <p>No. Reaching Coast FIRE means you have secured your traditional retirement age. You still need to generate enough income to cover your living expenses from today until your target retirement age, but you no longer need to save for retirement, freeing up income to upgrade your lifestyle or take a lower-stress job.</p>
      </details>
      <details>
        <summary>What is the 4% rule (Safe Withdrawal Rate)?</summary>
        <p>The 4% rule comes from the Trinity Study, which found that an investor with a portfolio of 50% stocks and 50% bonds could withdraw 4% of the portfolio's initial value annually (adjusted for inflation) without running out of money over a 30-year retirement period. Our calculator uses this concept to determine your total FIRE target.</p>
      </details>
      <details>
        <summary>How is the Coast FIRE number calculated mathematically?</summary>
        <p>The Coast FIRE number uses the Present Value formula: PV = FV / (1 + r)^t. We calculate your Future Value (Total FIRE Target) by dividing your annual spend by your withdrawal rate. We then discount that amount backward by your assumed annual return rate (r) over the number of years (t) between your current age and retirement age.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    // Utility to format currency
    const formatCurrency = (amount) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(amount);
    };

    function calculateCoastFire() {
      // Get elements
      const els = {
        currentAge: document.getElementById('currentAge'),
        retireAge: document.getElementById('retireAge'),
        currentAssets: document.getElementById('currentAssets'),
        annualSpend: document.getElementById('annualSpend'),
        returnRate: document.getElementById('returnRate'),
        withdrawalRate: document.getElementById('withdrawalRate')
      };

      const errs = {
        currentAge: document.getElementById('currentAgeError'),
        retireAge: document.getElementById('retireAgeError'),
        currentAssets: document.getElementById('currentAssetsError'),
        annualSpend: document.getElementById('annualSpendError'),
        returnRate: document.getElementById('returnRateError'),
        withdrawalRate: document.getElementById('withdrawalRateError')
      };

      // Reset errors
      for (const key in els) {
        els[key].classList.remove('input-error');
        errs[key].style.display = 'none';
      }

      // Parse values
      const currentAge = parseInt(els.currentAge.value);
      const retireAge = parseInt(els.retireAge.value);
      const currentAssets = parseFloat(els.currentAssets.value);
      const annualSpend = parseFloat(els.annualSpend.value);
      const returnRate = parseFloat(els.returnRate.value) / 100;
      const withdrawalRate = parseFloat(els.withdrawalRate.value) / 100;

      let hasError = false;

      // Validation
      if (isNaN(currentAge) || currentAge < 18) { els.currentAge.classList.add('input-error'); errs.currentAge.style.display = 'block'; hasError = true; }
      if (isNaN(retireAge) || retireAge <= currentAge) { els.retireAge.classList.add('input-error'); errs.retireAge.style.display = 'block'; hasError = true; }
      if (isNaN(currentAssets) || currentAssets < 0) { els.currentAssets.classList.add('input-error'); errs.currentAssets.style.display = 'block'; hasError = true; }
      if (isNaN(annualSpend) || annualSpend <= 0) { els.annualSpend.classList.add('input-error'); errs.annualSpend.style.display = 'block'; hasError = true; }
      if (isNaN(returnRate) || returnRate <= 0) { els.returnRate.classList.add('input-error'); errs.returnRate.style.display = 'block'; hasError = true; }
      if (isNaN(withdrawalRate) || withdrawalRate <= 0) { els.withdrawalRate.classList.add('input-error'); errs.withdrawalRate.style.display = 'block'; hasError = true; }

      if (hasError) return;

      // Calculations
      const yearsToGrow = retireAge - currentAge;

      // 1. Calculate Total FIRE Number (e.g. 60k / 0.04 = 1.5M)
      const fireTarget = annualSpend / withdrawalRate;

      // 2. Calculate Coast FIRE Number (Present Value formula: PV = FV / (1 + r)^t)
      const coastFireNumber = fireTarget / Math.pow((1 + returnRate), yearsToGrow);

      // 3. Projected Future Value of current assets
      const projectedAssets = currentAssets * Math.pow((1 + returnRate), yearsToGrow);

      // Update UI
      document.getElementById('coastFireResult').textContent = formatCurrency(coastFireNumber);
      document.getElementById('fireTarget').textContent = formatCurrency(fireTarget);
      document.getElementById('yearsToGrow').textContent = yearsToGrow + ' years';
      document.getElementById('projectedAssets').textContent = formatCurrency(projectedAssets);

      const statusEl = document.getElementById('coastStatus');
      if (currentAssets >= coastFireNumber) {
        statusEl.className = 'coast-status status-success';
        const excess = formatCurrency(currentAssets - coastFireNumber);
        statusEl.textContent = `🎉 You've reached Coast FIRE! (Over by ${excess})`;
      } else {
        statusEl.className = 'coast-status status-pending';
        const shortfall = formatCurrency(coastFireNumber - currentAssets);
        statusEl.textContent = `⏳ Keep investing! You need ${shortfall} more to Coast.`;
      }
    }

    // Attach event listeners for real-time calculation
    const inputs = ['currentAge', 'retireAge', 'currentAssets', 'annualSpend', 'returnRate', 'withdrawalRate'];
    inputs.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('input', calculateCoastFire);
        el.addEventListener('change', calculateCoastFire);
      }
    });

    // Initial calculation
    calculateCoastFire();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .form-group { margin-bottom: 1.5rem; }
    .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
    .input-wrapper { position: relative; }
    .input-prefix { position: absolute; left: 1rem; top: 0.75rem; color: var(--text-secondary); }
    .input-suffix { position: absolute; right: 1rem; top: 0.75rem; color: var(--text-secondary); }
    input[type="number"] { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input.has-prefix { padding-left: 2rem; }
    input.has-suffix { padding-right: 2rem; }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    .input-error { border-color: #ef4444 !important; }
    .error-msg { color: #ef4444; font-size: 0.875rem; margin-top: 0.25rem; display: none; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .coast-status { font-size: 1.25rem; font-weight: 700; margin-top: 1rem; padding: 0.75rem; border-radius: 8px; }
    .status-success { background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }
    .status-pending { background: rgba(234, 179, 8, 0.1); color: #eab308; border: 1px solid rgba(234, 179, 8, 0.3); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-top: 1.5rem; }
    .stat-box { background: var(--bg-color); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border-color); text-align: center; }
    .stat-label { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem; }
    .stat-value { font-size: 1.25rem; font-weight: 700; color: var(--text-primary); }
    @media (max-width: 768px) { .grid-2, .grid-3 { grid-template-columns: 1fr; gap: 1rem; } }
  </style>
</SiteLayout>
