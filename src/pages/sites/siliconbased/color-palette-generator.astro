---

<SiteLayout
  site="siliconbased"
  title="Color Palette Generator — Create Color Schemes Online"
  description="Free color palette generator with harmony modes, contrast checker, color blindness simulation, and export to CSS/Tailwind. Generate beautiful color schemes instantly."
  canonical="https://siliconbased.dev/color-palette-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const paletteRow = document.getElementById('paletteRow');
const harmonyMode = document.getElementById('harmonyMode');
const generateBtn = document.getElementById('generateBtn');
const fgSelect = document.getElementById('fgSelect');
const bgSelect = document.getElementById('bgSelect');
const fgSwatch = document.getElementById('fgSwatch');
const bgSwatch = document.getElementById('bgSwatch');
const contrastRatio = document.getElementById('contrastRatio');
const contrastBadges = document.getElementById('contrastBadges');
const contrastPreview = document.getElementById('contrastPreview');
const exportOutput = document.getElementById('exportOutput');
const exportCopyBtn = document.getElementById('exportCopyBtn');
const exportCanvas = document.getElementById('exportCanvas');

let palette = [];
let locked = [false, false, false, false, false];
let currentExportFormat = 'css';

// --- Color math utilities ---
function randomHSL() {
  return { h: Math.random() * 360, s: 50 + Math.random() * 40, l: 35 + Math.random() * 35 };
}

function hslToHex(h, s, l) {
  s /= 100; l /= 100;
  const a = s * Math.min(l, 1 - l);
  const f = n => { const k = (n + h / 30) % 12; const c = l - a * Math.max(Math.min(k - 3, 9 - k, 1), -1); return Math.round(255 * c).toString(16).padStart(2, '0'); };
  return '#' + f(0) + f(8) + f(4);
}

function hexToRGB(hex) {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return { r, g, b };
}

function rgbToHSL(r, g, b) {
  r /= 255; g /= 255; b /= 255;
  const max = Math.max(r, g, b), min = Math.min(r, g, b);
  let h, s, l = (max + min) / 2;
  if (max === min) { h = s = 0; }
  else {
    const d = max - min;
    s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
    switch (max) {
      case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
      case g: h = ((b - r) / d + 2) / 6; break;
      case b: h = ((r - g) / d + 4) / 6; break;
    }
  }
  return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
}

function hexToHSL(hex) {
  const { r, g, b } = hexToRGB(hex);
  return rgbToHSL(r, g, b);
}

function textColor(hex) {
  const { r, g, b } = hexToRGB(hex);
  const lum = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
  return lum > 0.55 ? '#000000' : '#ffffff';
}

// --- Harmony generators ---
function generateHarmony(mode) {
  const base = randomHSL();
  switch (mode) {
    case 'complementary': return [
      base,
      { h: (base.h + 180) % 360, s: base.s, l: base.l },
      { h: base.h, s: base.s - 15, l: base.l + 15 },
      { h: (base.h + 180) % 360, s: base.s - 10, l: base.l - 10 },
      { h: (base.h + 15) % 360, s: base.s + 5, l: base.l + 10 }
    ];
    case 'analogous': return [
      { h: (base.h - 30 + 360) % 360, s: base.s, l: base.l + 5 },
      { h: (base.h - 15 + 360) % 360, s: base.s + 5, l: base.l },
      base,
      { h: (base.h + 15) % 360, s: base.s + 5, l: base.l },
      { h: (base.h + 30) % 360, s: base.s, l: base.l + 5 }
    ];
    case 'triadic': return [
      base,
      { h: (base.h + 120) % 360, s: base.s, l: base.l },
      { h: (base.h + 240) % 360, s: base.s, l: base.l },
      { h: base.h, s: base.s - 20, l: base.l + 20 },
      { h: (base.h + 120) % 360, s: base.s - 20, l: base.l + 20 }
    ];
    case 'split-complementary': return [
      base,
      { h: (base.h + 150) % 360, s: base.s, l: base.l },
      { h: (base.h + 210) % 360, s: base.s, l: base.l },
      { h: base.h, s: base.s - 15, l: base.l + 20 },
      { h: (base.h + 180) % 360, s: base.s - 10, l: base.l + 15 }
    ];
    case 'monochromatic': return [
      { h: base.h, s: base.s, l: 20 },
      { h: base.h, s: base.s + 10, l: 35 },
      { h: base.h, s: base.s, l: 50 },
      { h: base.h, s: base.s - 10, l: 65 },
      { h: base.h, s: base.s - 20, l: 80 }
    ];
    default: return [randomHSL(), randomHSL(), randomHSL(), randomHSL(), randomHSL()];
  }
}

function clampHSL(c) {
  return { h: ((c.h % 360) + 360) % 360, s: Math.max(0, Math.min(100, c.s)), l: Math.max(10, Math.min(90, c.l)) };
}

// --- Palette generation ---
function generate() {
  const mode = harmonyMode.value;
  const colors = generateHarmony(mode).map(clampHSL);
  for (let i = 0; i < 5; i++) {
    if (!locked[i]) {
      palette[i] = hslToHex(colors[i].h, colors[i].s, colors[i].l);
    }
  }
  render();
}

function render() {
  renderPalette();
  renderColorBlindness();
  renderContrastSelects();
  updateContrast();
  renderExport();
}

// --- Palette rendering ---
function renderPalette() {
  paletteRow.innerHTML = '';
  palette.forEach((hex, i) => {
    const col = document.createElement('div');
    col.className = 'palette-col';
    const tc = textColor(hex);
    const { r, g, b } = hexToRGB(hex);
    const { h, s, l } = hexToHSL(hex);
    col.innerHTML =
      '<div class="palette-swatch" style="background:' + hex + ';color:' + tc + ';">' +
        '<button class="lock-btn' + (locked[i] ? ' locked' : '') + '" data-i="' + i + '" title="' + (locked[i] ? 'Unlock' : 'Lock') + '">' +
          (locked[i] ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>'
            : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 019.9-1"/></svg>') +
        '</button>' +
        '<div class="swatch-hex">' + hex.toUpperCase() + '</div>' +
      '</div>' +
      '<div class="color-values">' +
        '<button class="value-btn" data-copy="' + hex.toUpperCase() + '">HEX: ' + hex.toUpperCase() + '</button>' +
        '<button class="value-btn" data-copy="rgb(' + r + ', ' + g + ', ' + b + ')">RGB: ' + r + ', ' + g + ', ' + b + '</button>' +
        '<button class="value-btn" data-copy="hsl(' + h + ', ' + s + '%, ' + l + '%)">HSL: ' + h + ', ' + s + '%, ' + l + '%</button>' +
      '</div>';
    paletteRow.appendChild(col);
  });

  // Lock events
  paletteRow.querySelectorAll('.lock-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const i = parseInt(btn.dataset.i);
      locked[i] = !locked[i];
      renderPalette();
    });
  });

  // Copy events
  paletteRow.querySelectorAll('.value-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(btn.dataset.copy).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1200);
      });
    });
  });
}

// --- Color Blindness Simulation ---
function simulateCB(hex, type) {
  const { r, g, b } = hexToRGB(hex);
  let lr = r / 255, lg = g / 255, lb = b / 255;
  // Linearize
  lr = lr <= 0.04045 ? lr / 12.92 : Math.pow((lr + 0.055) / 1.055, 2.4);
  lg = lg <= 0.04045 ? lg / 12.92 : Math.pow((lg + 0.055) / 1.055, 2.4);
  lb = lb <= 0.04045 ? lb / 12.92 : Math.pow((lb + 0.055) / 1.055, 2.4);

  // Brettel matrices for color blindness simulation
  let sr, sg, sb;
  if (type === 'deuteranopia') {
    sr = 0.625 * lr + 0.375 * lg + 0.0 * lb;
    sg = 0.7 * lr + 0.3 * lg + 0.0 * lb;
    sb = 0.0 * lr + 0.3 * lg + 0.7 * lb;
  } else if (type === 'protanopia') {
    sr = 0.56667 * lr + 0.43333 * lg + 0.0 * lb;
    sg = 0.55833 * lr + 0.44167 * lg + 0.0 * lb;
    sb = 0.0 * lr + 0.24167 * lg + 0.75833 * lb;
  } else { // tritanopia
    sr = 0.95 * lr + 0.05 * lg + 0.0 * lb;
    sg = 0.0 * lr + 0.43333 * lg + 0.56667 * lb;
    sb = 0.0 * lr + 0.475 * lg + 0.525 * lb;
  }

  // De-linearize
  const delinear = v => v <= 0.0031308 ? 12.92 * v : 1.055 * Math.pow(v, 1 / 2.4) - 0.055;
  const clamp = v => Math.max(0, Math.min(255, Math.round(delinear(v) * 255)));
  return '#' + clamp(sr).toString(16).padStart(2, '0') + clamp(sg).toString(16).padStart(2, '0') + clamp(sb).toString(16).padStart(2, '0');
}

function renderColorBlindness() {
  const types = [
    { id: 'cbNormal', fn: hex => hex },
    { id: 'cbDeuteranopia', fn: hex => simulateCB(hex, 'deuteranopia') },
    { id: 'cbProtanopia', fn: hex => simulateCB(hex, 'protanopia') },
    { id: 'cbTritanopia', fn: hex => simulateCB(hex, 'tritanopia') }
  ];
  types.forEach(t => {
    const strip = document.getElementById(t.id);
    strip.innerHTML = '';
    palette.forEach(hex => {
      const sim = t.fn(hex);
      const swatch = document.createElement('div');
      swatch.className = 'cb-swatch';
      swatch.style.background = sim;
      swatch.title = sim.toUpperCase();
      strip.appendChild(swatch);
    });
  });
}

// --- Contrast Checker ---
function renderContrastSelects() {
  [fgSelect, bgSelect].forEach((sel, si) => {
    const prev = sel.value;
    sel.innerHTML = '';
    palette.forEach((hex, i) => {
      const opt = document.createElement('option');
      opt.value = hex;
      opt.textContent = 'Color ' + (i + 1) + ' — ' + hex.toUpperCase();
      sel.appendChild(opt);
    });
    if (prev && palette.includes(prev)) { sel.value = prev; }
    else { sel.selectedIndex = si === 0 ? 0 : Math.min(1, palette.length - 1); }
  });
  fgSwatch.style.background = fgSelect.value;
  bgSwatch.style.background = bgSelect.value;
}

function relativeLuminance(hex) {
  const { r, g, b } = hexToRGB(hex);
  const srgb = [r, g, b].map(c => {
    c /= 255;
    return c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
  });
  return 0.2126 * srgb[0] + 0.7152 * srgb[1] + 0.0722 * srgb[2];
}

function contrastRatioCalc(hex1, hex2) {
  const l1 = relativeLuminance(hex1);
  const l2 = relativeLuminance(hex2);
  const lighter = Math.max(l1, l2);
  const darker = Math.min(l1, l2);
  return (lighter + 0.05) / (darker + 0.05);
}

function updateContrast() {
  const fg = fgSelect.value;
  const bg = bgSelect.value;
  fgSwatch.style.background = fg;
  bgSwatch.style.background = bg;

  const ratio = contrastRatioCalc(fg, bg);
  contrastRatio.textContent = ratio.toFixed(2) + ':1';

  const aaNormal = ratio >= 4.5;
  const aaLarge = ratio >= 3;
  const aaaNormal = ratio >= 7;
  const aaaLarge = ratio >= 4.5;

  contrastBadges.innerHTML =
    '<span class="badge ' + (aaNormal ? 'pass' : 'fail') + '">AA Normal: ' + (aaNormal ? 'Pass' : 'Fail') + '</span>' +
    '<span class="badge ' + (aaLarge ? 'pass' : 'fail') + '">AA Large: ' + (aaLarge ? 'Pass' : 'Fail') + '</span>' +
    '<span class="badge ' + (aaaNormal ? 'pass' : 'fail') + '">AAA Normal: ' + (aaaNormal ? 'Pass' : 'Fail') + '</span>' +
    '<span class="badge ' + (aaaLarge ? 'pass' : 'fail') + '">AAA Large: ' + (aaaLarge ? 'Pass' : 'Fail') + '</span>';

  contrastPreview.style.background = bg;
  contrastPreview.style.color = fg;
}

fgSelect.addEventListener('change', updateContrast);
bgSelect.addEventListener('change', updateContrast);

// --- Export ---
function renderExport() {
  if (currentExportFormat === 'image') {
    exportOutput.parentElement.querySelector('.copy-btn').style.display = 'none';
    exportOutput.textContent = 'Click "Download PNG" above to save your palette as an image.';
    return;
  }
  exportOutput.parentElement.querySelector('.copy-btn').style.display = '';

  if (currentExportFormat === 'css') {
    const lines = [':root {'];
    palette.forEach((hex, i) => { lines.push('  --color-' + (i + 1) + ': ' + hex + ';'); });
    lines.push('}');
    exportOutput.textContent = lines.join('\n');
  } else if (currentExportFormat === 'tailwind') {
    const lines = ['// tailwind.config.js', 'module.exports = {', '  theme: {', '    extend: {', '      colors: {', '        palette: {'];
    palette.forEach((hex, i) => { lines.push("          '" + (i + 1) + "00': '" + hex + "',"); });
    lines.push('        },', '      },', '    },', '  },', '};');
    exportOutput.textContent = lines.join('\n');
  }
}

function downloadPNG() {
  const w = 1200, h = 630, sw = w / 5;
  exportCanvas.width = w;
  exportCanvas.height = h;
  const ctx = exportCanvas.getContext('2d');
  palette.forEach((hex, i) => {
    ctx.fillStyle = hex;
    ctx.fillRect(i * sw, 0, sw, h);
    ctx.fillStyle = textColor(hex);
    ctx.font = 'bold 28px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(hex.toUpperCase(), i * sw + sw / 2, h / 2);
  });
  const link = document.createElement('a');
  link.download = 'palette.png';
  link.href = exportCanvas.toDataURL('image/png');
  link.click();
}

document.querySelectorAll('.export-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.export-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const fmt = tab.dataset.format;
    if (fmt === 'image') {
      downloadPNG();
    } else {
      currentExportFormat = fmt;
      renderExport();
    }
  });
});

exportCopyBtn.addEventListener('click', () => {
  const text = exportOutput.textContent;
  if (!text) return;
  navigator.clipboard.writeText(text).then(() => {
    exportCopyBtn.textContent = 'Copied!';
    setTimeout(() => { exportCopyBtn.textContent = 'Copy'; }, 1500);
  });
});

// --- Init ---
generateBtn.addEventListener('click', generate);
document.addEventListener('keydown', (e) => {
  if (e.code === 'Space' && !['INPUT', 'TEXTAREA', 'SELECT'].includes(document.activeElement.tagName)) {
    e.preventDefault();
    generate();
  }
});

// Initial palette
palette = ['#6366f1', '#ec4899', '#10b981', '#f59e0b', '#3b82f6'];
render();
