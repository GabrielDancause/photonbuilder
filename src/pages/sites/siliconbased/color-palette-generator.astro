---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Color Palette Generator — Create Beautiful Color Schemes",
      "url": "https://siliconbased.dev/color-palette-generator",
      "description": "Free online color palette generator with harmony modes, contrast checker, color blindness simulation, and export to CSS/Tailwind. Generate, lock, and customize 5-color palettes instantly.",
      "applicationCategory": "DesignApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a color palette generator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A color palette generator is a design tool that creates harmonious sets of colors for use in websites, apps, branding, and graphic design. It uses color theory rules like complementary, analogous, and triadic relationships to produce palettes that look great together."
          }
        },
        {
          "@type": "Question",
          "name": "How do color harmony modes work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Color harmony modes use mathematical relationships on the color wheel. Complementary uses colors opposite each other (180°), analogous uses adjacent colors (30° apart), triadic uses three evenly spaced colors (120° apart), split-complementary uses a color and two colors adjacent to its complement, and monochromatic uses variations of a single hue."
          }
        },
        {
          "@type": "Question",
          "name": "What is WCAG contrast compliance?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "WCAG (Web Content Accessibility Guidelines) defines minimum contrast ratios for text readability. AA requires 4.5:1 for normal text and 3:1 for large text. AAA requires 7:1 for normal text and 4.5:1 for large text. The contrast checker in this tool tests any two colors against these standards."
          }
        },
        {
          "@type": "Question",
          "name": "How does color blindness simulation work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Color blindness simulation applies mathematical color transforms to approximate how people with different types of color vision deficiency perceive colors. Deuteranopia (green-blind) and protanopia (red-blind) affect red-green perception, while tritanopia (blue-blind) affects blue-yellow perception. Testing your palette against these simulations helps ensure your design is accessible."
          }
        },
        {
          "@type": "Question",
          "name": "Can I export my color palette?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. You can export your palette as CSS custom properties (variables), a Tailwind CSS config object, or download it as a PNG image. Click any individual color swatch to copy its hex, RGB, or HSL value to your clipboard."
          }
        },
        {
          "@type": "Question",
          "name": "How do I lock colors in a palette?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Click the lock icon on any color swatch to lock it. When you regenerate the palette (press spacebar or click Generate), locked colors stay fixed while unlocked colors are randomized or regenerated based on the current harmony mode. This lets you keep colors you like while exploring variations."
          }
        },
        {
          "@type": "Question",
          "name": "Is this color picker tool free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this color palette generator is completely free. It runs entirely in your browser with no sign-up required. All color generation, contrast checking, and exports happen client-side — no data is sent to any server."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Color Palette Generator — Create Beautiful Color Schemes Online",
      "description": "Free online color palette generator with harmony modes, contrast checker, color blindness simulation, and export to CSS/Tailwind.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Color Palette Generator</h1>
  <p>Generate beautiful color schemes with harmony modes, contrast checking, and color blindness simulation. Press <kbd>Space</kbd> to generate.</p>
</div>

<div class="main">

  <!-- Controls -->
  <div class="controls-bar">
    <div class="harmony-select">
      <label>Harmony</label>
      <select id="harmonyMode">
        <option value="random">Random</option>
        <option value="complementary">Complementary</option>
        <option value="analogous">Analogous</option>
        <option value="triadic">Triadic</option>
        <option value="split-complementary">Split-Complementary</option>
        <option value="monochromatic">Monochromatic</option>
      </select>
    </div>
