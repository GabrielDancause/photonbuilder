          <td>50 req/hour</td>
          <td>API Key</td>
          <td>6/10</td>
          <td><a href="https://unsplash.com/documentation" target="_blank">Docs</a></td>
        </tr>
        <tr>
          <td><strong>Pexels API</strong></td>
          <td>200 req/hour</td>
          <td>API Key</td>
          <td>8/10</td>
          <td><a href="https://www.pexels.com/api/" target="_blank">Docs</a></td>
        </tr>
        <tr>
          <td><strong>Lorem Picsum</strong></td>
          <td>Unlimited</td>
          <td>None</td>
          <td>10/10</td>
          <td><a href="https://picsum.photos/" target="_blank">Docs</a></td>
        </tr>
        <tr>
          <td><strong>Cloudinary</strong></td>
          <td>25 monthly credits</td>
          <td>API Key</td>
          <td>7/10</td>
          <td><a href="https://cloudinary.com/documentation" target="_blank">Docs</a></td>
        </tr>
        <tr>
          <td><strong>Giphy API</strong></td>
          <td>100 req/hour</td>
          <td>API Key</td>
          <td>7/10</td>
          <td><a href="https://developers.giphy.com/docs/api" target="_blank">Docs</a></td>
        </tr>
        <tr>
          <td><strong>The Cat API</strong></td>
          <td>Unlimited</td>
          <td>None</td>
          <td>10/10</td>
          <td><a href="https://thecatapi.com/" target="_blank">Docs</a></td>
        </tr>
        <tr>
          <td><strong>Imgur API</strong></td>
          <td>12,500 req/day</td>
          <td>API Key</td>
          <td>8/10</td>
          <td><a href="https://apidocs.imgur.com/" target="_blank">Docs</a></td>
        </tr>
