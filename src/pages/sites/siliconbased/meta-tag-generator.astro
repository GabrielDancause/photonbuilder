---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    [
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Meta Tag Generator",
        "url": "https://siliconbased.dev/meta-tag-generator",
        "description": "Free Meta Tag Generator for SEO. Generate HTML meta tags, Open Graph tags, Twitter Card tags, and JSON-LD Article schema. Live preview of Google search results and social media shares.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "author": {
          "@type": "Organization",
          "name": "GAB Ventures",
          "url": "https://gab.ae"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "Meta Tag Generator — Generate SEO Meta Tags, Open Graph & Twitter Cards",
        "description": "Free Meta Tag Generator for SEO. Generate HTML meta tags, Open Graph tags, Twitter Card tags, and JSON-LD Article schema with live preview.",
        "author": {
          "@type": "Organization",
          "name": "GAB Ventures",
          "url": "https://gab.ae"
        }
      }
    ],
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are meta tags and why do they matter for SEO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Meta tags are HTML elements that provide metadata about a web page to search engines and social media platforms. They influence how your page appears in search results (title and description), how it looks when shared on social media (Open Graph and Twitter Cards), and help search engines understand your content. Well-optimized meta tags can significantly improve click-through rates from search results."
          }
        },
        {
          "@type": "Question",
          "name": "What is the ideal length for a meta title and meta description?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The ideal meta title length is 50-60 characters. Google typically displays the first 50-60 characters of a title tag. For meta descriptions, aim for 150-160 characters. Google generally truncates descriptions longer than 160 characters in search results. Our generator validates these limits in real time."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between Open Graph tags and Twitter Card tags?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Open Graph tags (og:title, og:description, og:image) were created by Facebook and are used by most social platforms including Facebook, LinkedIn, Discord, and Slack. Twitter Card tags (twitter:card, twitter:title, twitter:image) are specific to Twitter/X. Twitter will fall back to Open Graph tags if Twitter-specific tags are not present, but it's best practice to include both for maximum control."
          }
        },
        {
          "@type": "Question",
          "name": "What is JSON-LD and should I add it to my pages?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "JSON-LD (JavaScript Object Notation for Linked Data) is a structured data format recommended by Google. Adding JSON-LD Article schema helps search engines understand your content type, author, and publication details. This can lead to rich results in Google Search, such as enhanced snippets with author info and publish dates. Our generator creates Article schema automatically."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need a canonical URL tag on every page?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, it's best practice to include a canonical URL on every page, even if the page only has one URL. The canonical tag tells search engines which version of a URL is the preferred one, preventing duplicate content issues. This is especially important if your content is accessible via multiple URLs (with/without www, HTTP/HTTPS, with query parameters, etc.)."
          }
        }
      ]
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Meta Tag <span>Generator</span></h1>
  <p>Generate SEO meta tags, Open Graph, Twitter Cards, and JSON-LD schema.</p>
</div>

<div class="main">

  <div class="layout-grid">
    <div class="editor-side">
      <div class="builder-grid" style="margin-bottom: 24px;">
        <div class="input-group">
          <label for="titleInput">
            Page Title
            <span class="char-count" id="titleCount">0 / 60</span>
          </label>
          <input type="text" id="titleInput" placeholder="My Awesome Page Title" autocomplete="off" value="How to Build a REST API with Node.js in 2026">
        </div>

        <div class="input-group">
          <label for="descInput">
            Meta Description
            <span class="char-count" id="descCount">0 / 160</span>
          </label>
          <textarea id="descInput" placeholder="A compelling description of your page content." autocomplete="off">Learn how to build a production-ready REST API with Node.js, Express, and MongoDB. Step-by-step tutorial with authentication, validation, and deployment.</textarea>
        </div>

        <div class="input-group">
          <label for="urlInput">Canonical URL</label>
          <input type="url" id="urlInput" placeholder="https://example.com/page" autocomplete="off" value="https://example.com/blog/rest-api-nodejs">
        </div>

        <div class="input-group">
          <label for="imageInput">OG Image URL</label>
          <input type="url" id="imageInput" placeholder="https://example.com/image.jpg" autocomplete="off" value="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1200&h=630&fit=crop">
          <div class="input-hint">Recommended: 1200x630 pixels</div>
        </div>

        <div class="input-group">
          <label for="siteNameInput">Site Name</label>
          <input type="text" id="siteNameInput" placeholder="My Website" autocomplete="off" value="DevBlog">
        </div>

        <div class="input-group">
          <label for="authorInput">Author</label>
          <input type="text" id="authorInput" placeholder="John Doe" autocomplete="off" value="Jane Smith">
        </div>

        <div class="input-group">
          <label for="twitterInput">Twitter Handle</label>
          <input type="text" id="twitterInput" placeholder="@username" autocomplete="off" value="@devblog">
        </div>

        <div class="input-group">
          <label for="localeInput">Locale</label>
          <select id="localeInput">
            <option value="en_US" selected>English (US)</option>
            <option value="en_GB">English (UK)</option>
            <option value="fr_FR">French</option>
            <option value="de_DE">German</option>
            <option value="es_ES">Spanish</option>
            <option value="pt_BR">Portuguese (Brazil)</option>
            <option value="ja_JP">Japanese</option>
            <option value="zh_CN">Chinese (Simplified)</option>
          </select>
        </div>
      </div>

      <div class="code-card">
        <div class="card-header">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
            Generated Meta Tags
          </h3>
          <button class="btn-primary" id="copyCodeBtn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            Copy All
          </button>
        </div>
        <pre class="code-output" id="codeOutput"></pre>
      </div>
    </div>

    <div class="previews-container">

      <div class="preview-card">
        <div class="card-header">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            Google Search Preview
          </h3>
        </div>
        <div class="preview-body">
          <div class="google-preview">
            <div class="google-breadcrumb" id="googleUrl">example.com &rsaquo; blog &rsaquo; rest-api-nodejs</div>
            <div class="google-title" id="googleTitle">How to Build a REST API with Node.js in 2026</div>
            <div class="google-desc" id="googleDesc">Learn how to build a production-ready REST API...</div>
          </div>
        </div>
      </div>

      <div class="preview-card">
        <div class="card-header">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
            Twitter / X Card
          </h3>
        </div>
        <div class="preview-body">
          <div class="social-preview twitter-preview large" id="twitterPreview">
            <div class="social-img-container">
              <img src="" alt="" class="social-img" id="twImage">
            </div>
            <div class="social-content">
              <div class="twitter-domain" id="twDomain">example.com</div>
              <div class="twitter-title" id="twTitle">Title</div>
              <div class="twitter-desc" id="twDesc">Description</div>
            </div>
          </div>
        </div>
      </div>

      <div class="preview-card">
        <div class="card-header">
          <h3>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            Facebook Post
          </h3>
        </div>
        <div class="preview-body">
          <div class="social-preview facebook-preview">
            <div class="social-img-container">
              <img src="" alt="" class="social-img" id="fbImage">
            </div>
            <div class="social-content">
              <div class="facebook-domain" id="fbDomain">EXAMPLE.COM</div>
              <div class="facebook-title" id="fbTitle">Title</div>
              <div class="facebook-desc" id="fbDesc">Description</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="seo-content">
    <h2>What Are Meta Tags?</h2>
    <p>Meta tags are snippets of HTML code that provide structured metadata about a web page. They live in the <code>&lt;head&gt;</code> section of your HTML and are not visible to visitors, but they are critical for search engines, social media platforms, and browsers. Well-crafted meta tags directly influence how your page appears in Google search results and when shared on social media.</p>

    <h2>Essential Meta Tags for SEO</h2>
    <p>The most important meta tags for SEO are the <code>&lt;title&gt;</code> tag and the <code>meta description</code>. The title tag is the single most important on-page SEO element. It appears as the clickable headline in search results and in the browser tab. The meta description provides a summary that appears below the title in search results and can dramatically affect your click-through rate.</p>
    <ul>
      <li><strong>Title Tag:</strong> Keep it under 60 characters. Include your primary keyword near the beginning. Make it compelling and unique for each page.</li>
      <li><strong>Meta Description:</strong> Keep it under 160 characters. Include a call to action and your target keyword. Write it like ad copy that entices clicks.</li>
      <li><strong>Canonical URL:</strong> Prevents duplicate content issues by telling search engines which URL is the preferred version of a page.</li>
    </ul>

    <h2>Open Graph and Twitter Card Tags</h2>
    <p>Open Graph tags control how your content appears when shared on Facebook, LinkedIn, Discord, and Slack. Twitter Card tags do the same for Twitter/X. Without these tags, social platforms will try to guess your page's title, description, and image, often with poor results. Adding proper social meta tags ensures your content looks professional and clickable when shared.</p>

    <h2>JSON-LD Structured Data</h2>
    <p>JSON-LD (JavaScript Object Notation for Linked Data) is the recommended format for adding structured data to your pages. Google uses structured data to understand your content and can display rich results like article snippets with author information, publish dates, and breadcrumbs. Our generator creates Article schema that follows Google's structured data guidelines.</p>
  </div>

</div>

</div>`;

export const meta = {
  title: "Meta Tag Generator — SEO & Open Graph Tags",
  description: "Free Meta Tag Generator for SEO. Generate HTML meta tags, Open Graph tags, Twitter Card tags, and JSON-LD Article schema with live Google and social media preview.",
  category: "guide",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="Meta Tag Generator — SEO & Open Graph Tags"
  description="Free Meta Tag Generator for SEO. Generate HTML meta tags, Open Graph tags, Twitter Card tags, and JSON-LD Article schema with live Google and social media preview."
  canonical="https://siliconbased.dev/meta-tag-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const inputs = {
  title: document.getElementById('titleInput'),
  desc: document.getElementById('descInput'),
  url: document.getElementById('urlInput'),
  image: document.getElementById('imageInput'),
  siteName: document.getElementById('siteNameInput'),
  author: document.getElementById('authorInput'),
  twitter: document.getElementById('twitterInput'),
  locale: document.getElementById('localeInput')
};

const titleCount = document.getElementById('titleCount');
const descCount = document.getElementById('descCount');
const codeOutput = document.getElementById('codeOutput');
const copyCodeBtn = document.getElementById('copyCodeBtn');

const googleUrl = document.getElementById('googleUrl');
const googleTitle = document.getElementById('googleTitle');
const googleDesc = document.getElementById('googleDesc');

const twDomain = document.getElementById('twDomain');
const twTitle = document.getElementById('twTitle');
const twDesc = document.getElementById('twDesc');
const twImage = document.getElementById('twImage');

const fbDomain = document.getElementById('fbDomain');
const fbTitle = document.getElementById('fbTitle');
const fbDesc = document.getElementById('fbDesc');
const fbImage = document.getElementById('fbImage');

function getDomain(urlStr) {
  if (!urlStr) return '';
  try {
    let u = urlStr;
    if (!u.startsWith('http')) u = 'https://' + u;
    return new URL(u).hostname.replace('www.', '');
  } catch(e) {
    return urlStr;
  }
}

function getBreadcrumb(urlStr) {
  if (!urlStr) return 'example.com';
  try {
    let u = urlStr;
    if (!u.startsWith('http')) u = 'https://' + u;
    const url = new URL(u);
    const domain = url.hostname.replace('www.', '');
    const parts = url.pathname.split('/').filter(Boolean);
    if (parts.length === 0) return domain;
    return domain + ' \u203A ' + parts.join(' \u203A ');
  } catch(e) {
    return urlStr;
  }
}

function escapeHtml(unsafe) {
  return (unsafe || '').toString()
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

function updateCharCounts() {
  var tLen = inputs.title.value.length;
  var dLen = inputs.desc.value.length;
  titleCount.textContent = tLen + ' / 60';
  titleCount.className = 'char-count' + (tLen > 60 ? ' over' : '');
  descCount.textContent = dLen + ' / 160';
  descCount.className = 'char-count' + (dLen > 160 ? ' over' : '');
}

function updatePreviews() {
  var title = inputs.title.value.trim() || 'Page Title';
  var desc = inputs.desc.value.trim() || 'Page description goes here.';
  var url = inputs.url.value.trim();
  var image = inputs.image.value.trim();
  var domain = getDomain(url) || 'example.com';

  updateCharCounts();

  googleUrl.textContent = getBreadcrumb(url);
  googleTitle.textContent = title.length > 60 ? title.substring(0, 57) + '...' : title;
  googleDesc.textContent = desc.length > 160 ? desc.substring(0, 157) + '...' : desc;

  twDomain.textContent = domain;
  twTitle.textContent = title;
  twDesc.textContent = desc;
  twImage.src = image;

  fbDomain.textContent = domain.toUpperCase();
  fbTitle.textContent = title;
  fbDesc.textContent = desc;
  fbImage.src = image;

  generateCode();
}

function generateCode() {
  var title = inputs.title.value.trim();
  var desc = inputs.desc.value.trim();
  var url = inputs.url.value.trim();
  var image = inputs.image.value.trim();
  var siteName = inputs.siteName.value.trim();
  var author = inputs.author.value.trim();
  var twitter = inputs.twitter.value.trim();
  var locale = inputs.locale.value;

  var tags = [];

  tags.push('<!-- Basic Meta Tags -->');
  if (title) tags.push('<title>' + escapeHtml(title) + '</title>');
  tags.push('<meta charset="UTF-8">');
  tags.push('<meta name="viewport" content="width=device-width, initial-scale=1.0">');
  if (desc) tags.push('<meta name="description" content="' + escapeHtml(desc) + '">');
  if (author) tags.push('<meta name="author" content="' + escapeHtml(author) + '">');
  if (url) tags.push('<link rel="canonical" href="' + escapeHtml(url) + '">');

  tags.push('');
  tags.push('<!-- Open Graph / Facebook -->');
  tags.push('<meta property="og:type" content="article">');
  if (url) tags.push('<meta property="og:url" content="' + escapeHtml(url) + '">');
  if (title) tags.push('<meta property="og:title" content="' + escapeHtml(title) + '">');
  if (desc) tags.push('<meta property="og:description" content="' + escapeHtml(desc) + '">');
  if (image) tags.push('<meta property="og:image" content="' + escapeHtml(image) + '">');
  if (siteName) tags.push('<meta property="og:site_name" content="' + escapeHtml(siteName) + '">');
  tags.push('<meta property="og:locale" content="' + escapeHtml(locale) + '">');

  tags.push('');
  tags.push('<!-- Twitter Card -->');
  tags.push('<meta name="twitter:card" content="summary_large_image">');
  if (twitter) {
    var handle = twitter.startsWith('@') ? twitter : '@' + twitter;
    tags.push('<meta name="twitter:site" content="' + escapeHtml(handle) + '">');
    tags.push('<meta name="twitter:creator" content="' + escapeHtml(handle) + '">');
  }
  if (title) tags.push('<meta name="twitter:title" content="' + escapeHtml(title) + '">');
  if (desc) tags.push('<meta name="twitter:description" content="' + escapeHtml(desc) + '">');
  if (image) tags.push('<meta name="twitter:image" content="' + escapeHtml(image) + '">');

  tags.push('');
  tags.push('<!-- JSON-LD Structured Data -->');

  var jsonLd = { "@context": "https://schema.org", "@type": "Article" };
  if (title) jsonLd.headline = title;
  if (desc) jsonLd.description = desc;
  if (image) jsonLd.image = image;
  if (url) jsonLd.url = url;
  if (author) jsonLd.author = { "@type": "Person", "name": author };

  var scriptOpen = '<script type="application/ld+json">';
  var scriptClose = '</' + 'script>';
  tags.push(scriptOpen);
  tags.push(JSON.stringify(jsonLd, null, 2));
  tags.push(scriptClose);

  var rawCode = tags.join('\n');

  var displayCode = rawCode
    .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
    .replace(/(<!--.*?-->)/g, '<span style="color: #666;">$1</span>')
    .replace(/(&lt;\/?)([\w-]+)/g, '$1<span class="tag">$2</span>')
    .replace(/ ([\w-]+)=/g, ' <span class="attr">$1</span>=')
    .replace(/&quot;([^&]*)&quot;/g, '&quot;<span class="val">$1</span>&quot;');

  codeOutput.innerHTML = displayCode;
  codeOutput.dataset.raw = rawCode;
}

Object.values(inputs).forEach(function(input) {
  input.addEventListener('input', updatePreviews);
});

copyCodeBtn.addEventListener('click', function() {
  var code = codeOutput.dataset.raw;
  if (!code) return;

  navigator.clipboard.writeText(code).then(function() {
    var originalText = copyCodeBtn.innerHTML;
    copyCodeBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied!';
    copyCodeBtn.classList.add('copied');

    setTimeout(function() {
      copyCodeBtn.innerHTML = originalText;
      copyCodeBtn.classList.remove('copied');
    }, 2000);
  });
});

updatePreviews();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #0a0b10; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }

.hero { text-align: center; padding: 32px 24px 16px; background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%); }
.hero h1 { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #888; font-size: 0.95rem; }

.main { max-width: 1000px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

.layout-grid { display: grid; grid-template-columns: 1fr; gap: 32px; margin-bottom: 32px; }
@media (min-width: 900px) {
  .layout-grid { grid-template-columns: 380px 1fr; }
}

.builder-grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
.input-group { display: flex; flex-direction: column; gap: 8px; }
.input-group label { font-size: 0.85rem; font-weight: 600; color: #ccc; display: flex; align-items: center; justify-content: space-between; }
.input-group input, .input-group select, .input-group textarea { background: #111318; border: 1px solid #1e2030; border-radius: 10px; padding: 12px 16px; font-family: 'Inter', sans-serif; font-size: 0.95rem; color: #fff; outline: none; transition: all 0.2s; width: 100%; }
.input-group textarea { resize: vertical; min-height: 80px; }
.input-group input:focus, .input-group select:focus, .input-group textarea:focus { border-color: #818cf8; box-shadow: 0 0 0 2px rgba(129, 140, 248, 0.2); }
.input-group input::placeholder, .input-group textarea::placeholder { color: #555; }
.input-hint { font-size: 0.75rem; color: #666; }

.char-count { font-size: 0.75rem; font-weight: 400; color: #666; }
.char-count.over { color: #f87171; font-weight: 600; }

.code-card { background: #111318; border: 1px solid #1e2030; border-radius: 14px; overflow: hidden; margin-bottom: 32px; }
.card-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 18px; background: #13151d; border-bottom: 1px solid #1e2030; }
.card-header h3 { font-size: 0.85rem; font-weight: 600; color: #ccc; display: flex; align-items: center; gap: 8px; }
.btn-primary { background: #818cf8; color: #fff; border: none; padding: 8px 16px; border-radius: 8px; font-size: 0.8rem; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px; }
.btn-primary:hover { background: #6366f1; }
.btn-primary.copied { background: #4ade80; color: #1a3a1a; }
.code-output { background: #0a0b10; border-radius: 0 0 14px 14px; padding: 16px; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #e0e0e0; overflow-x: auto; white-space: pre-wrap; line-height: 1.5; margin: 0; }
.code-output .tag { color: #818cf8; }
.code-output .attr { color: #c084fc; }
.code-output .val { color: #4ade80; }

.previews-container { display: flex; flex-direction: column; gap: 24px; }
.preview-card { background: #111318; border: 1px solid #1e2030; border-radius: 14px; overflow: hidden; }
.preview-body { padding: 24px; background: #0a0b10; display: flex; justify-content: center; }

/* Google Search Preview */
.google-preview { max-width: 600px; width: 100%; font-family: Arial, sans-serif; padding: 16px; background: #fff; border-radius: 12px; }
.google-breadcrumb { font-size: 14px; color: #202124; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.google-title { font-size: 20px; color: #1a0dab; line-height: 1.3; margin-bottom: 4px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; cursor: pointer; }
.google-title:hover { text-decoration: underline; }
