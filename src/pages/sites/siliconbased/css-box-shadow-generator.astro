---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "CSS Box Shadow Generator — Create Beautiful Shadows",
      "url": "https://siliconbased.dev/css-box-shadow-generator",
      "description": "Free CSS box shadow generator with live preview. Adjust horizontal offset, vertical offset, blur, spread, color, and opacity. Add multiple shadow layers, toggle inset, and copy CSS code.",
      "applicationCategory": "DesignApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a CSS box-shadow generator?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A CSS box-shadow generator is a visual tool that lets you create box-shadow effects by adjusting offset, blur, spread, and color values. It outputs ready-to-use CSS code you can paste directly into your stylesheets."
          }
        },
        {
          "@type": "Question",
          "name": "What do the box-shadow values mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The box-shadow property takes values for horizontal offset, vertical offset, blur radius, spread radius, and color. Horizontal offset moves the shadow left or right, vertical offset moves it up or down, blur radius controls softness, and spread radius expands or shrinks the shadow size."
          }
        },
        {
          "@type": "Question",
          "name": "What is an inset box shadow?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An inset box shadow appears inside the element rather than outside it. Adding the 'inset' keyword to the box-shadow property creates an inner shadow effect, useful for pressed buttons, input fields, and recessed UI elements."
          }
        },
        {
          "@type": "Question",
          "name": "Can I add multiple box shadows to one element?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, you can add multiple box shadows to a single element by separating each shadow with a comma. Multiple shadows are layered on top of each other, with the first shadow on top. This technique is commonly used for realistic depth effects and material design elevation."
          }
        },
        {
          "@type": "Question",
          "name": "How do I create a glowing shadow effect?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To create a glow effect, set both horizontal and vertical offsets to 0, use a large blur radius, and choose a bright or neon color. You can increase the spread radius for a wider glow. Combining multiple colored shadows produces vibrant neon glow effects."
          }
        },
        {
          "@type": "Question",
          "name": "Is the box-shadow property supported in all browsers?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, the box-shadow property is supported in all modern browsers including Chrome, Firefox, Safari, and Edge. It has been widely supported since IE9, so vendor prefixes are no longer needed for standard use."
          }
        },
        {
          "@type": "Question",
          "name": "Is this box shadow generator free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, this CSS box shadow generator is completely free. It runs entirely in your browser with no sign-up required. All shadow generation happens client-side — no data is sent to any server."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "CSS Box Shadow Generator — Create Beautiful Shadows Online",
      "description": "Free CSS box shadow generator with live preview. Adjust offset, blur, spread, color, and opacity. Add multiple layers, toggle inset, use presets, and copy CSS.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>CSS Box Shadow Generator</h1>
  <p>Create beautiful CSS box shadows with live preview. Adjust offset, blur, spread, color, and opacity — then copy the CSS.</p>
</div>

<div class="main">

  <!-- Preview -->
  <div class="preview-section">
    <div class="preview-area" id="previewArea">
      <div class="preview-card" id="previewCard">
        <div class="preview-card-title">Preview Card</div>
        <div class="preview-card-text">Your box shadow is applied to this element. Adjust the controls below to see changes in real time.</div>
      </div>
    </div>
    <div class="bg-toggle">
      <label>Background</label>
      <button class="bg-btn active" data-bg="#f0f2f5">Light</button>
      <button class="bg-btn" data-bg="#1a1a2e">Dark</button>
      <button class="bg-btn" data-bg="#ffffff">White</button>
    </div>
  </div>

  <!-- Shadow Layers -->
  <div class="section-block">
    <div class="section-header">
      <h2>Shadow Layers</h2>
      <button class="add-layer-btn" id="addLayerBtn">+ Add Layer</button>
    </div>
    <div class="layers-list" id="layersList"></div>
  </div>

  <!-- CSS Output -->
  <div class="section-block">
    <div class="section-header">
      <h2>CSS Output</h2>
    </div>
    <div class="export-output-wrap">
      <pre class="export-output" id="exportOutput"></pre>
      <button class="copy-btn" id="exportCopyBtn">Copy</button>
    </div>
  </div>

  <!-- Presets -->
  <div class="section-block">
    <div class="section-header">
      <h2>Shadow Presets</h2>
      <p class="section-desc">Click any preset to load it into the editor.</p>
    </div>
    <div class="presets-grid" id="presetsGrid"></div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a CSS Box Shadow Generator?</h2>
    <p>A CSS box shadow generator is a visual design tool that helps you create shadow effects for HTML elements without writing box-shadow syntax by hand. You can adjust horizontal and vertical offsets, blur radius, spread radius, shadow color with opacity, and toggle inset mode — all with a live preview. The tool outputs standard CSS code that works in all modern browsers.</p>

    <h2>Understanding the Box-Shadow Property</h2>
    <p>The CSS <code>box-shadow</code> property adds one or more shadow effects to an element's frame. The syntax is:</p>
    <p><code>box-shadow: [inset] offset-x offset-y blur-radius spread-radius color;</code></p>
    <ul>
      <li><strong>Horizontal Offset (offset-x):</strong> Moves the shadow left (negative) or right (positive). A value of 0 centers the shadow horizontally.</li>
      <li><strong>Vertical Offset (offset-y):</strong> Moves the shadow up (negative) or down (positive). A value of 0 centers the shadow vertically.</li>
      <li><strong>Blur Radius:</strong> Controls how soft or sharp the shadow edge is. 0 creates a sharp shadow; higher values produce softer, more diffused shadows.</li>
      <li><strong>Spread Radius:</strong> Expands (positive) or shrinks (negative) the shadow relative to the element. Use positive spread for larger shadows and negative spread for tighter, more focused shadows.</li>
      <li><strong>Color:</strong> Sets the shadow color, often with transparency using rgba() or hsla(). Semi-transparent shadows look more natural and realistic.</li>
      <li><strong>Inset:</strong> Adding the <code>inset</code> keyword places the shadow inside the element, creating a recessed or pressed effect.</li>
    </ul>

    <h2>Multiple Box Shadows</h2>
    <p>You can apply multiple shadows to a single element by separating each shadow value with a comma. The first shadow in the list appears on top. Layering multiple shadows is a common technique for creating realistic depth, material design elevation levels, and complex lighting effects. This generator supports adding and removing multiple shadow layers independently.</p>

    <h2>Common Shadow Patterns</h2>
    <ul>
      <li><strong>Subtle:</strong> Small offsets with moderate blur and low opacity create gentle, natural-looking shadows perfect for cards and containers.</li>
      <li><strong>Material Design:</strong> Multiple layered shadows with increasing blur and offset mimic physical elevation, a core principle of Material Design.</li>
      <li><strong>Glow:</strong> Zero offset with high blur and a bright color creates a neon glow effect, popular for dark-themed UIs and gaming sites.</li>
      <li><strong>Sharp:</strong> Zero blur with a small offset creates a hard-edged retro shadow, great for bold, graphic design styles.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a CSS box-shadow generator?</h3>
      <p style="margin-bottom: 16px;">A CSS box-shadow generator is a visual tool that lets you create box-shadow effects by adjusting offset, blur, spread, and color values. It outputs ready-to-use CSS code you can paste directly into your stylesheets.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What do the box-shadow values mean?</h3>
      <p style="margin-bottom: 16px;">The box-shadow property takes values for horizontal offset, vertical offset, blur radius, spread radius, and color. Horizontal offset moves the shadow left or right, vertical offset moves it up or down, blur radius controls softness, and spread radius expands or shrinks the shadow size.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is an inset box shadow?</h3>
      <p style="margin-bottom: 16px;">An inset box shadow appears inside the element rather than outside it. Adding the 'inset' keyword to the box-shadow property creates an inner shadow effect, useful for pressed buttons, input fields, and recessed UI elements.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I add multiple box shadows to one element?</h3>
      <p style="margin-bottom: 16px;">Yes, you can add multiple box shadows by separating each shadow with a comma. Multiple shadows are layered on top of each other, with the first shadow on top. This technique is commonly used for realistic depth effects and material design elevation.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I create a glowing shadow effect?</h3>
      <p style="margin-bottom: 16px;">To create a glow effect, set both offsets to 0, use a large blur radius, and choose a bright or neon color. Increase the spread radius for a wider glow. Combining multiple colored shadows produces vibrant neon glow effects.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is the box-shadow property supported in all browsers?</h3>
      <p style="margin-bottom: 16px;">Yes, box-shadow is supported in all modern browsers including Chrome, Firefox, Safari, and Edge. It has been widely supported since IE9, so vendor prefixes are no longer needed.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is this box shadow generator free to use?</h3>
      <p style="margin-bottom: 16px;">Yes, this CSS box shadow generator is completely free. It runs entirely in your browser with no sign-up required. All shadow generation happens client-side — no data is sent to any server.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/css-gradient-generator">CSS Gradient Generator</a> — Create beautiful CSS gradients with linear, radial, and conic modes.</li>
      <li><a href="/color-palette-generator">Color Palette Generator</a> — Create beautiful color schemes with harmony modes and contrast checking.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "CSS Box Shadow Generator — Create Shadows Online",
  description: "Free CSS box shadow generator with live preview. Adjust horizontal offset, vertical offset, blur, spread, color, and opacity. Add multiple layers, toggle inset, use presets, and copy CSS.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="CSS Box Shadow Generator — Create Shadows Online"
  description="Free CSS box shadow generator with live preview. Adjust horizontal offset, vertical offset, blur, spread, color, and opacity. Add multiple layers, toggle inset, use presets, and copy CSS."
  canonical="https://siliconbased.dev/css-box-shadow-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
var layers = [
  { x: 0, y: 4, blur: 16, spread: 0, color: '#000000', opacity: 0.15, inset: false }
];

var presets = [
  { name: 'Subtle', layers: [{ x: 0, y: 1, blur: 3, spread: 0, color: '#000000', opacity: 0.12, inset: false }, { x: 0, y: 1, blur: 2, spread: 0, color: '#000000', opacity: 0.08, inset: false }] },
  { name: 'Medium', layers: [{ x: 0, y: 4, blur: 14, spread: -2, color: '#000000', opacity: 0.2, inset: false }] },
  { name: 'Heavy', layers: [{ x: 0, y: 10, blur: 40, spread: -4, color: '#000000', opacity: 0.3, inset: false }] },
  { name: 'Sharp', layers: [{ x: 4, y: 4, blur: 0, spread: 0, color: '#000000', opacity: 0.25, inset: false }] },
  { name: 'Glow', layers: [{ x: 0, y: 0, blur: 20, spread: 4, color: '#818cf8', opacity: 0.6, inset: false }] },
  { name: 'Neon', layers: [{ x: 0, y: 0, blur: 10, spread: 2, color: '#00ff88', opacity: 0.7, inset: false }, { x: 0, y: 0, blur: 30, spread: 8, color: '#00ff88', opacity: 0.3, inset: false }] },
  { name: 'Layered', layers: [{ x: 0, y: 1, blur: 2, spread: 0, color: '#000000', opacity: 0.07, inset: false }, { x: 0, y: 2, blur: 4, spread: 0, color: '#000000', opacity: 0.07, inset: false }, { x: 0, y: 4, blur: 8, spread: 0, color: '#000000', opacity: 0.07, inset: false }, { x: 0, y: 8, blur: 16, spread: 0, color: '#000000', opacity: 0.07, inset: false }] },
  { name: 'Material 1', layers: [{ x: 0, y: 1, blur: 3, spread: 0, color: '#000000', opacity: 0.12, inset: false }, { x: 0, y: 1, blur: 2, spread: 0, color: '#000000', opacity: 0.24, inset: false }] },
  { name: 'Material 3', layers: [{ x: 0, y: 3, blur: 6, spread: -1, color: '#000000', opacity: 0.16, inset: false }, { x: 0, y: 10, blur: 20, spread: 0, color: '#000000', opacity: 0.12, inset: false }] },
  { name: 'Material 5', layers: [{ x: 0, y: 6, blur: 10, spread: -2, color: '#000000', opacity: 0.2, inset: false }, { x: 0, y: 16, blur: 40, spread: 2, color: '#000000', opacity: 0.14, inset: false }] },
  { name: 'Inset Soft', layers: [{ x: 0, y: 2, blur: 6, spread: 0, color: '#000000', opacity: 0.2, inset: true }] },
  { name: 'Inset Deep', layers: [{ x: 0, y: 4, blur: 12, spread: 2, color: '#000000', opacity: 0.35, inset: true }] },
  { name: 'Bottom Only', layers: [{ x: 0, y: 8, blur: 12, spread: -6, color: '#000000', opacity: 0.25, inset: false }] },
  { name: 'Dreamy', layers: [{ x: 0, y: 8, blur: 32, spread: 0, color: '#818cf8', opacity: 0.35, inset: false }] },
  { name: 'Crisp Border', layers: [{ x: 0, y: 0, blur: 0, spread: 2, color: '#818cf8', opacity: 0.6, inset: false }] },
  { name: 'Retro Offset', layers: [{ x: 6, y: 6, blur: 0, spread: 0, color: '#333333', opacity: 1, inset: false }] }
];

var previewCard = document.getElementById('previewCard');
var previewArea = document.getElementById('previewArea');
var layersList = document.getElementById('layersList');
var addLayerBtn = document.getElementById('addLayerBtn');
var exportOutput = document.getElementById('exportOutput');
var exportCopyBtn = document.getElementById('exportCopyBtn');
var presetsGrid = document.getElementById('presetsGrid');

function hexToRgba(hex, opacity) {
  var r = parseInt(hex.slice(1, 3), 16);
  var g = parseInt(hex.slice(3, 5), 16);
  var b = parseInt(hex.slice(5, 7), 16);
  return 'rgba(' + r + ', ' + g + ', ' + b + ', ' + opacity + ')';
}

function buildShadowCSS() {
  return layers.map(function(l) {
    var parts = [];
    if (l.inset) parts.push('inset');
    parts.push(l.x + 'px');
    parts.push(l.y + 'px');
    parts.push(l.blur + 'px');
    parts.push(l.spread + 'px');
    parts.push(hexToRgba(l.color, l.opacity));
    return parts.join(' ');
  }).join(',\n    ');
}

function render() {
  updatePreview();
  renderLayers();
  renderExport();
  addLayerBtn.disabled = layers.length >= 6;
  addLayerBtn.style.opacity = layers.length >= 6 ? '0.4' : '';
}

function updatePreview() {
  previewCard.style.boxShadow = layers.map(function(l) {
    var parts = [];
    if (l.inset) parts.push('inset');
    parts.push(l.x + 'px');
    parts.push(l.y + 'px');
    parts.push(l.blur + 'px');
    parts.push(l.spread + 'px');
    parts.push(hexToRgba(l.color, l.opacity));
    return parts.join(' ');
  }).join(', ');
}

function renderLayers() {
  layersList.innerHTML = '';
  layers.forEach(function(layer, i) {
    var card = document.createElement('div');
    card.className = 'layer-card';
    card.innerHTML =
      '<div class="layer-header">' +
        '<span class="layer-title">Shadow ' + (i + 1) + '</span>' +
        '<div class="layer-actions">' +
          '<label class="inset-toggle"><input type="checkbox" class="inset-cb" data-i="' + i + '"' + (layer.inset ? ' checked' : '') + '> Inset</label>' +
          (layers.length > 1 ? '<button class="layer-remove" data-i="' + i + '" title="Remove layer">&times;</button>' : '') +
        '</div>' +
      '</div>' +
      '<div class="layer-controls">' +
        '<div class="ctrl-row">' +
          '<label>X Offset</label>' +
          '<input type="range" class="ctrl-range" data-i="' + i + '" data-prop="x" min="-50" max="50" value="' + layer.x + '">' +
          '<input type="number" class="ctrl-num" data-i="' + i + '" data-prop="x" min="-50" max="50" value="' + layer.x + '">' +
          '<span class="ctrl-unit">px</span>' +
        '</div>' +
        '<div class="ctrl-row">' +
          '<label>Y Offset</label>' +
          '<input type="range" class="ctrl-range" data-i="' + i + '" data-prop="y" min="-50" max="50" value="' + layer.y + '">' +
          '<input type="number" class="ctrl-num" data-i="' + i + '" data-prop="y" min="-50" max="50" value="' + layer.y + '">' +
          '<span class="ctrl-unit">px</span>' +
        '</div>' +
        '<div class="ctrl-row">' +
          '<label>Blur</label>' +
          '<input type="range" class="ctrl-range" data-i="' + i + '" data-prop="blur" min="0" max="100" value="' + layer.blur + '">' +
          '<input type="number" class="ctrl-num" data-i="' + i + '" data-prop="blur" min="0" max="100" value="' + layer.blur + '">' +
          '<span class="ctrl-unit">px</span>' +
        '</div>' +
        '<div class="ctrl-row">' +
          '<label>Spread</label>' +
          '<input type="range" class="ctrl-range" data-i="' + i + '" data-prop="spread" min="-50" max="50" value="' + layer.spread + '">' +
          '<input type="number" class="ctrl-num" data-i="' + i + '" data-prop="spread" min="-50" max="50" value="' + layer.spread + '">' +
          '<span class="ctrl-unit">px</span>' +
        '</div>' +
        '<div class="ctrl-row">' +
          '<label>Color</label>' +
          '<input type="color" class="ctrl-color" data-i="' + i + '" value="' + layer.color + '">' +
          '<span class="ctrl-hex">' + layer.color.toUpperCase() + '</span>' +
        '</div>' +
        '<div class="ctrl-row">' +
          '<label>Opacity</label>' +
          '<input type="range" class="ctrl-range" data-i="' + i + '" data-prop="opacity" min="0" max="100" value="' + Math.round(layer.opacity * 100) + '">' +
          '<input type="number" class="ctrl-num" data-i="' + i + '" data-prop="opacity" min="0" max="100" value="' + Math.round(layer.opacity * 100) + '">' +
          '<span class="ctrl-unit">%</span>' +
        '</div>' +
      '</div>';
    layersList.appendChild(card);
  });

  // Bind events
  layersList.querySelectorAll('.ctrl-range').forEach(function(el) {
    el.addEventListener('input', function() {
      var i = parseInt(el.dataset.i);
      var prop = el.dataset.prop;
      var val = parseFloat(el.value);
      if (prop === 'opacity') {
        layers[i].opacity = val / 100;
      } else {
        layers[i][prop] = val;
      }
      render();
    });
  });
  layersList.querySelectorAll('.ctrl-num').forEach(function(el) {
    el.addEventListener('input', function() {
      var i = parseInt(el.dataset.i);
      var prop = el.dataset.prop;
      var val = parseFloat(el.value) || 0;
      if (prop === 'opacity') {
        layers[i].opacity = Math.max(0, Math.min(100, val)) / 100;
      } else {
        layers[i][prop] = val;
      }
      render();
    });
  });
  layersList.querySelectorAll('.ctrl-color').forEach(function(el) {
    el.addEventListener('input', function() {
      layers[parseInt(el.dataset.i)].color = el.value;
      render();
    });
  });
  layersList.querySelectorAll('.inset-cb').forEach(function(el) {
    el.addEventListener('change', function() {
      layers[parseInt(el.dataset.i)].inset = el.checked;
      render();
    });
  });
  layersList.querySelectorAll('.layer-remove').forEach(function(el) {
    el.addEventListener('click', function() {
      layers.splice(parseInt(el.dataset.i), 1);
      render();
    });
  });
}

function renderExport() {
  var shadow = buildShadowCSS();
  exportOutput.textContent = 'box-shadow: ' + shadow + ';';
}

addLayerBtn.addEventListener('click', function() {
  if (layers.length >= 6) return;
  layers.push({ x: 0, y: 4, blur: 16, spread: 0, color: '#000000', opacity: 0.15, inset: false });
  render();
});

exportCopyBtn.addEventListener('click', function() {
  var text = exportOutput.textContent;
  if (!text) return;
  navigator.clipboard.writeText(text).then(function() {
    exportCopyBtn.textContent = 'Copied!';
    setTimeout(function() { exportCopyBtn.textContent = 'Copy'; }, 1500);
  });
});

// Background toggle
document.querySelectorAll('.bg-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.bg-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    previewArea.style.background = btn.dataset.bg;
  });
});

// Presets
function renderPresets() {
  presetsGrid.innerHTML = '';
  presets.forEach(function(preset) {
    var card = document.createElement('div');
    card.className = 'preset-card';
    var shadow = preset.layers.map(function(l) {
      var parts = [];
      if (l.inset) parts.push('inset');
      parts.push(l.x + 'px');
      parts.push(l.y + 'px');
      parts.push(l.blur + 'px');
      parts.push(l.spread + 'px');
      parts.push(hexToRgba(l.color, l.opacity));
      return parts.join(' ');
    }).join(', ');
    card.innerHTML =
      '<div class="preset-swatch"><div class="preset-demo" style="box-shadow:' + shadow + ';"></div></div>' +
      '<div class="preset-name">' + preset.name + '</div>';
    card.addEventListener('click', function() {
      layers = preset.layers.map(function(l) {
        return { x: l.x, y: l.y, blur: l.blur, spread: l.spread, color: l.color, opacity: l.opacity, inset: l.inset };
      });
      render();
    });
    presetsGrid.appendChild(card);
  });
}

renderPresets();
render();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #0f1729 0%, #060a12 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1000px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; }

/* Preview */
.preview-section { margin-bottom: 32px; }
.preview-area { width: 100%; min-height: 280px; border-radius: 16px; border: 2px solid #152040; background: #f0f2f5; display: flex; align-items: center; justify-content: center; padding: 40px; transition: background 0.3s; }
.preview-card { background: #ffffff; border-radius: 16px; padding: 32px; width: 100%; max-width: 360px; transition: box-shadow 0.15s; }
.preview-card-title { font-size: 1.1rem; font-weight: 700; color: #1a1a2e; margin-bottom: 8px; }
