<SiteLayout
  site="siliconbased"
  title="QR Code Generator — Free Online QR Maker"
  description="Free QR code generator. Create QR codes for URLs, text, email, phone, WiFi, and vCard contacts. Customize size, colors, and error correction. Download as PNG."
  canonical="https://siliconbased.dev/qr-code-generator"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
// ===== Minimal QR Code Encoder =====
// Implements QR code generation (versions 1-10, byte mode) with Reed-Solomon error correction.

const QR = (() => {
  // Error correction codewords and blocks for versions 1-10, levels L/M/Q/H
  const EC_TABLE = {
    L: [[7,1,19],[10,1,34],[15,1,55],[20,1,80],[26,1,108],[36,2,68],[40,2,78],[48,2,97],[60,2,116],[72,2,68]],
    M: [[10,1,16],[16,1,28],[26,1,44],[36,2,32],[48,2,43],[64,4,27],[72,4,31],[88,4,38],[110,4,36],[130,4,43]],
    Q: [[13,1,13],[22,1,22],[36,2,17],[52,2,24],[72,2,15],[96,4,19],[108,4,21],[132,4,25],[160,4,15],[192,4,18]],
    H: [[17,1,9],[28,1,16],[44,2,13],[64,4,9],[88,4,11],[112,4,15],[130,4,13],[156,4,14],[192,4,12],[224,4,11]]
  };

  const MODE_BYTE = 0b0100;

  // GF(256) arithmetic for Reed-Solomon
  const GF_EXP = new Uint8Array(512);
  const GF_LOG = new Uint8Array(256);
  (() => {
    let x = 1;
    for (let i = 0; i < 255; i++) {
      GF_EXP[i] = x;
      GF_LOG[x] = i;
      x <<= 1;
      if (x & 256) x ^= 0x11d;
    }
    for (let i = 255; i < 512; i++) GF_EXP[i] = GF_EXP[i - 255];
  })();

  function gfMul(a, b) {
    if (a === 0 || b === 0) return 0;
    return GF_EXP[GF_LOG[a] + GF_LOG[b]];
  }

  function rsGenPoly(nsym) {
    let g = [1];
    for (let i = 0; i < nsym; i++) {
      const ng = new Array(g.length + 1).fill(0);
      for (let j = 0; j < g.length; j++) {
        ng[j] ^= g[j];
        ng[j + 1] ^= gfMul(g[j], GF_EXP[i]);
      }
      g = ng;
    }
    return g;
  }

  function rsEncode(data, nsym) {
    const gen = rsGenPoly(nsym);
    const res = new Uint8Array(data.length + nsym);
    res.set(data);
    for (let i = 0; i < data.length; i++) {
      const coef = res[i];
      if (coef !== 0) {
        for (let j = 0; j < gen.length; j++) {
          res[i + j] ^= gfMul(gen[j], coef);
        }
      }
    }
    return res.slice(data.length);
  }

  function getVersion(dataLen, ecLevel) {
    for (let v = 0; v < 10; v++) {
      const [ecCW, blocks, dcPerBlock] = EC_TABLE[ecLevel][v];
      const totalDC = blocks * dcPerBlock;
      // Byte mode: 4 bits mode + char count bits + data + terminator
      const charCountBits = v < 9 ? 8 : 16;
      const availBits = totalDC * 8;
      const needed = 4 + charCountBits + dataLen * 8;
      if (needed <= availBits) return v + 1;
    }
    return -1;
  }

  function getCharCountBits(version) {
    return version <= 9 ? 8 : 16;
  }

  function encodeData(text, ecLevel) {
    const dataBytes = new TextEncoder().encode(text);
    const version = getVersion(dataBytes.length, ecLevel);
    if (version < 0) throw new Error('Data too long for QR versions 1-10');

    const [ecCW, numBlocks, dcPerBlock] = EC_TABLE[ecLevel][version - 1];
    const totalDC = numBlocks * dcPerBlock;
    const ecPerBlock = ecCW / numBlocks;
    const charCountBits = getCharCountBits(version);

    // Build bit stream
    let bits = '';
    // Mode indicator
    bits += '0100';
    // Character count
    bits += dataBytes.length.toString(2).padStart(charCountBits, '0');
    // Data
    for (const b of dataBytes) bits += b.toString(2).padStart(8, '0');
    // Terminator
    const capacity = totalDC * 8;
    const termLen = Math.min(4, capacity - bits.length);
    bits += '0'.repeat(termLen);
    // Pad to byte boundary
    while (bits.length % 8 !== 0) bits += '0';
    // Pad bytes
    const padBytes = [0xEC, 0x11];
    let padIdx = 0;
    while (bits.length < capacity) {
      bits += padBytes[padIdx % 2].toString(2).padStart(8, '0');
      padIdx++;
    }

    // Convert to bytes
    const dataCodewords = new Uint8Array(totalDC);
    for (let i = 0; i < totalDC; i++) {
      dataCodewords[i] = parseInt(bits.slice(i * 8, i * 8 + 8), 2);
    }

    // Split into blocks and compute EC
    const dataBlocks = [];
    const ecBlocks = [];
    let offset = 0;
    for (let b = 0; b < numBlocks; b++) {
      const block = dataCodewords.slice(offset, offset + dcPerBlock);
      dataBlocks.push(block);
      ecBlocks.push(rsEncode(block, ecPerBlock));
      offset += dcPerBlock;
    }

    // Interleave data codewords
    const result = [];
    const maxDC = Math.max(...dataBlocks.map(b => b.length));
    for (let i = 0; i < maxDC; i++) {
      for (const block of dataBlocks) {
        if (i < block.length) result.push(block[i]);
      }
    }
    // Interleave EC codewords
    for (let i = 0; i < ecPerBlock; i++) {
      for (const block of ecBlocks) {
        if (i < block.length) result.push(block[i]);
      }
    }

    return { codewords: result, version, ecLevel };
  }

  // QR matrix construction
  const ALIGNMENT_POSITIONS = [
    [], [], [6,18], [6,22], [6,26], [6,30], [6,34],
    [6,22,38], [6,24,42], [6,26,46], [6,28,50]
  ];

  function createMatrix(version) {
    const size = 17 + version * 4;
    const matrix = Array.from({length: size}, () => new Int8Array(size)); // 0=empty, 1=black, -1=white
    const reserved = Array.from({length: size}, () => new Uint8Array(size)); // 1=reserved
    return { matrix, reserved, size };
  }

  function setModule(m, row, col, val) {
    if (row >= 0 && row < m.size && col >= 0 && col < m.size) {
      m.matrix[row][col] = val ? 1 : -1;
      m.reserved[row][col] = 1;
    }
  }

  function addFinderPattern(m, row, col) {
    for (let r = -1; r <= 7; r++) {
      for (let c = -1; c <= 7; c++) {
        const y = row + r, x = col + c;
        if (y < 0 || y >= m.size || x < 0 || x >= m.size) continue;
        const isBlack = (r >= 0 && r <= 6 && (c === 0 || c === 6)) ||
                        (c >= 0 && c <= 6 && (r === 0 || r === 6)) ||
                        (r >= 2 && r <= 4 && c >= 2 && c <= 4);
        setModule(m, y, x, isBlack);
      }
    }
  }

  function addAlignmentPattern(m, row, col) {
    for (let r = -2; r <= 2; r++) {
      for (let c = -2; c <= 2; c++) {
        const isBlack = Math.abs(r) === 2 || Math.abs(c) === 2 || (r === 0 && c === 0);
        setModule(m, row + r, col + c, isBlack);
      }
    }
  }

  function addTimingPatterns(m) {
    for (let i = 8; i < m.size - 8; i++) {
      const val = i % 2 === 0;
      if (!m.reserved[6][i]) setModule(m, 6, i, val);
      if (!m.reserved[i][6]) setModule(m, i, 6, val);
    }
  }

  function addFormatInfo(m, ecLevel, maskPattern) {
    const ecBits = {L:1, M:0, Q:3, H:2}[ecLevel];
    let data = (ecBits << 3) | maskPattern;
    let rem = data;
    for (let i = 0; i < 10; i++) { rem <<= 1; if (rem & (1 << 10)) rem ^= 0x537; }
    const bits = ((data << 10) | rem) ^ 0x5412;

    // Place format bits
    const positions = [
      // Around top-left finder
      [[8,0],[8,1],[8,2],[8,3],[8,4],[8,5],[8,7],[8,8],[7,8],[5,8],[4,8],[3,8],[2,8],[1,8],[0,8]],
      // Around bottom-left and top-right
      [[m.size-1,8],[m.size-2,8],[m.size-3,8],[m.size-4,8],[m.size-5,8],[m.size-6,8],[m.size-7,8],[8,m.size-8],[8,m.size-7],[8,m.size-6],[8,m.size-5],[8,m.size-4],[8,m.size-3],[8,m.size-2],[8,m.size-1]]
    ];

    for (let i = 0; i < 15; i++) {
      const val = (bits >> i) & 1;
      const [r1, c1] = positions[0][i];
      const [r2, c2] = positions[1][i];
      m.matrix[r1][c1] = val ? 1 : -1;
      m.reserved[r1][c1] = 1;
      m.matrix[r2][c2] = val ? 1 : -1;
      m.reserved[r2][c2] = 1;
    }

    // Dark module
    setModule(m, m.size - 8, 8, true);
  }

  function reserveFormatArea(m) {
    // Reserve format info areas (will be filled later)
    for (let i = 0; i < 8; i++) {
      m.reserved[8][i] = 1;
      m.reserved[i][8] = 1;
      m.reserved[8][m.size - 1 - i] = 1;
      m.reserved[m.size - 1 - i][8] = 1;
    }
    m.reserved[8][8] = 1;
    m.reserved[8][7] = 1;
    m.reserved[7][8] = 1;
  }

  const MASK_FUNCTIONS = [
    (r, c) => (r + c) % 2 === 0,
    (r, c) => r % 2 === 0,
    (r, c) => c % 3 === 0,
    (r, c) => (r + c) % 3 === 0,
    (r, c) => (Math.floor(r / 2) + Math.floor(c / 3)) % 2 === 0,
    (r, c) => (r * c) % 2 + (r * c) % 3 === 0,
    (r, c) => ((r * c) % 2 + (r * c) % 3) % 2 === 0,
    (r, c) => ((r + c) % 2 + (r * c) % 3) % 2 === 0,
  ];

  function placeData(m, codewords) {
    let bitIdx = 0;
    const totalBits = codewords.length * 8;
    let col = m.size - 1;
    let goingUp = true;

    while (col >= 0) {
      if (col === 6) col--; // Skip timing column
      for (let row = 0; row < m.size; row++) {
        const actualRow = goingUp ? m.size - 1 - row : row;
        for (let c = 0; c < 2; c++) {
          const actualCol = col - c;
          if (actualCol < 0 || m.reserved[actualRow][actualCol]) continue;
          if (bitIdx < totalBits) {
            const byteIdx = Math.floor(bitIdx / 8);
            const bitPos = 7 - (bitIdx % 8);
            const val = (codewords[byteIdx] >> bitPos) & 1;
            m.matrix[actualRow][actualCol] = val ? 1 : -1;
          } else {
            m.matrix[actualRow][actualCol] = -1;
          }
          bitIdx++;
        }
      }
      col -= 2;
      goingUp = !goingUp;
    }
  }

  function applyMask(m, maskIdx) {
    const fn = MASK_FUNCTIONS[maskIdx];
    for (let r = 0; r < m.size; r++) {
      for (let c = 0; c < m.size; c++) {
        if (!m.reserved[r][c] || (m.matrix[r][c] !== 0 && !m.reserved[r][c])) {
          // Only mask data modules (not reserved)
        }
        if (!m.reserved[r][c]) continue; // skip unfilled
        // Actually, we want to mask non-reserved modules that have been filled by placeData
      }
    }
    // Let me redo: mask data regions only
    for (let r = 0; r < m.size; r++) {
      for (let c = 0; c < m.size; c++) {
        if (m.reserved[r][c]) continue;
        if (fn(r, c)) {
          m.matrix[r][c] = m.matrix[r][c] === 1 ? -1 : 1;
        }
      }
    }
  }

  function penaltyScore(m) {
    let score = 0;
    // Rule 1: runs of same color
    for (let r = 0; r < m.size; r++) {
      let count = 1;
      for (let c = 1; c < m.size; c++) {
        if (m.matrix[r][c] === m.matrix[r][c-1]) { count++; }
        else { if (count >= 5) score += count - 2; count = 1; }
      }
      if (count >= 5) score += count - 2;
    }
    for (let c = 0; c < m.size; c++) {
      let count = 1;
      for (let r = 1; r < m.size; r++) {
        if (m.matrix[r][c] === m.matrix[r-1][c]) { count++; }
        else { if (count >= 5) score += count - 2; count = 1; }
      }
      if (count >= 5) score += count - 2;
    }
    // Rule 2: 2x2 blocks
    for (let r = 0; r < m.size - 1; r++) {
      for (let c = 0; c < m.size - 1; c++) {
        const v = m.matrix[r][c];
        if (v === m.matrix[r][c+1] && v === m.matrix[r+1][c] && v === m.matrix[r+1][c+1]) score += 3;
      }
    }
    // Rule 4: proportion
    let dark = 0;
    for (let r = 0; r < m.size; r++) for (let c = 0; c < m.size; c++) if (m.matrix[r][c] === 1) dark++;
    const pct = dark / (m.size * m.size) * 100;
    score += Math.floor(Math.abs(pct - 50) / 5) * 10;
    return score;
  }

  function generate(text, ecLevel) {
    const { codewords, version } = encodeData(text, ecLevel);
    const size = 17 + version * 4;

    // Try all 8 masks, pick the best
    let bestMask = 0, bestScore = Infinity, bestMatrix = null;

    for (let mask = 0; mask < 8; mask++) {
      const m = createMatrix(version);

      // Add finder patterns
      addFinderPattern(m, 0, 0);
      addFinderPattern(m, 0, m.size - 7);
      addFinderPattern(m, m.size - 7, 0);

      // Alignment patterns
      const positions = ALIGNMENT_POSITIONS[version] || [];
      for (let i = 0; i < positions.length; i++) {
        for (let j = 0; j < positions.length; j++) {
          const r = positions[i], c = positions[j];
          // Skip if overlapping with finder patterns
          if ((r < 9 && c < 9) || (r < 9 && c > m.size - 10) || (r > m.size - 10 && c < 9)) continue;
          addAlignmentPattern(m, r, c);
        }
      }

      addTimingPatterns(m);
      reserveFormatArea(m);
      placeData(m, codewords);
      applyMask(m, mask);
      addFormatInfo(m, ecLevel, mask);

      const score = penaltyScore(m);
      if (score < bestScore) {
        bestScore = score;
        bestMask = mask;
        bestMatrix = m.matrix.map(row => Array.from(row));
      }
    }

    return { matrix: bestMatrix, version, size, modules: size };
  }

  return { generate, getVersion };
})();

// ===== UI Logic =====
let currentType = 'url';

// Tab switching
document.getElementById('typeTabs').addEventListener('click', (e) => {
  const btn = e.target.closest('.type-tab');
  if (!btn) return;
  currentType = btn.dataset.type;
  document.querySelectorAll('.type-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.input-form').forEach(f => f.classList.remove('active'));
  document.getElementById('form-' + currentType).classList.add('active');
});

// Size slider
const optSize = document.getElementById('optSize');
const optSizeVal = document.getElementById('optSizeVal');
optSize.addEventListener('input', () => { optSizeVal.textContent = optSize.value + 'px'; });

// Color sync
function syncColor(picker, text) {
  picker.addEventListener('input', () => { text.value = picker.value; });
  text.addEventListener('input', () => { if (/^#[0-9a-fA-F]{6}$/.test(text.value)) picker.value = text.value; });
}
syncColor(document.getElementById('optFg'), document.getElementById('optFgText'));
syncColor(document.getElementById('optBg'), document.getElementById('optBgText'));

function getEncodedData() {
  switch (currentType) {
    case 'url': return document.getElementById('inputUrl').value.trim();
    case 'text': return document.getElementById('inputText').value;
    case 'email': {
      const addr = document.getElementById('inputEmail').value.trim();
      const subj = document.getElementById('inputEmailSubject').value.trim();
      const body = document.getElementById('inputEmailBody').value.trim();
      if (!addr) return '';
      let uri = 'mailto:' + addr;
      const params = [];
      if (subj) params.push('subject=' + encodeURIComponent(subj));
      if (body) params.push('body=' + encodeURIComponent(body));
      if (params.length) uri += '?' + params.join('&');
      return uri;
    }
    case 'phone': {
      const ph = document.getElementById('inputPhone').value.trim();
      return ph ? 'tel:' + ph : '';
    }
    case 'wifi': {
      const ssid = document.getElementById('inputWifiSsid').value.trim();
      const pass = document.getElementById('inputWifiPass').value;
      const enc = document.getElementById('inputWifiEnc').value;
      const hidden = document.getElementById('inputWifiHidden').checked;
      if (!ssid) return '';
      let s = 'WIFI:T:' + enc + ';S:' + ssid + ';';
      if (enc !== 'nopass' && pass) s += 'P:' + pass + ';';
      if (hidden) s += 'H:true;';
      s += ';';
      return s;
    }
    case 'vcard': {
      const fn = document.getElementById('inputVcardFn').value.trim();
      const ln = document.getElementById('inputVcardLn').value.trim();
      if (!fn && !ln) return '';
      let v = 'BEGIN:VCARD\nVERSION:3.0\n';
      v += 'N:' + ln + ';' + fn + ';;;\n';
      v += 'FN:' + (fn + ' ' + ln).trim() + '\n';
      const ph = document.getElementById('inputVcardPhone').value.trim();
      if (ph) v += 'TEL:' + ph + '\n';
      const em = document.getElementById('inputVcardEmail').value.trim();
      if (em) v += 'EMAIL:' + em + '\n';
      const org = document.getElementById('inputVcardOrg').value.trim();
      if (org) v += 'ORG:' + org + '\n';
      const title = document.getElementById('inputVcardTitle').value.trim();
      if (title) v += 'TITLE:' + title + '\n';
      const url = document.getElementById('inputVcardUrl').value.trim();
      if (url) v += 'URL:' + url + '\n';
      v += 'END:VCARD';
      return v;
    }
    default: return '';
  }
}

function getTypeLabel() {
  return {url:'URL',text:'Text',email:'Email',phone:'Phone',wifi:'WiFi',vcard:'vCard'}[currentType] || 'Text';
}

function getEcLabel(ec) {
  return {L:'L — Low (7%)',M:'M — Medium (15%)',Q:'Q — Quartile (25%)',H:'H — High (30%)'}[ec] || ec;
}

// Generate
document.getElementById('generateBtn').addEventListener('click', () => {
  const data = getEncodedData();
  if (!data) { alert('Please enter data to encode.'); return; }

  const size = parseInt(optSize.value);
  const ec = document.getElementById('optEc').value;
  const fg = document.getElementById('optFg').value;
  const bg = document.getElementById('optBg').value;

  let qr;
  try {
    qr = QR.generate(data, ec);
  } catch (e) {
    alert('Error: ' + e.message);
    return;
  }

  // Draw on canvas
  const canvas = document.getElementById('qrCanvas');
  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext('2d');
  const moduleSize = size / (qr.modules + 8); // 4-module quiet zone on each side
  const quietZone = 4 * moduleSize;

  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, size, size);

  ctx.fillStyle = fg;
  for (let r = 0; r < qr.modules; r++) {
    for (let c = 0; c < qr.modules; c++) {
      if (qr.matrix[r][c] === 1) {
        ctx.fillRect(
          quietZone + c * moduleSize,
          quietZone + r * moduleSize,
          Math.ceil(moduleSize),
          Math.ceil(moduleSize)
        );
      }
    }
  }

  // Show output
  const outputSection = document.getElementById('outputSection');
  outputSection.style.display = '';

  // Info
  document.getElementById('infoType').textContent = getTypeLabel();
  document.getElementById('infoLength').textContent = new TextEncoder().encode(data).length + ' bytes';
  document.getElementById('infoEc').textContent = getEcLabel(ec);
  document.getElementById('infoVersion').textContent = qr.version + ' (' + qr.modules + '×' + qr.modules + ')';
  document.getElementById('infoModules').textContent = qr.modules * qr.modules + ' modules';

  // Estimated scan distance (rule of thumb: 10x the printed size)
  const printSizeCm = (size / 96 * 2.54).toFixed(1);
  const distCm = (printSizeCm * 10).toFixed(0);
  const distIn = (distCm / 2.54).toFixed(0);
  document.getElementById('infoDistance').textContent = '~' + distCm + ' cm (~' + distIn + ' in) at ' + printSizeCm + ' cm print size';

  document.getElementById('infoRaw').textContent = data.length > 300 ? data.slice(0, 300) + '...' : data;
});

// Download
document.getElementById('downloadBtn').addEventListener('click', () => {
  const canvas = document.getElementById('qrCanvas');
  const link = document.createElement('a');
  link.download = 'qrcode.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
});

// Auto-generate on load
document.getElementById('generateBtn').click();
</script>

