    /* Timer specific styles */
    .timer-container { text-align: center; padding: 3rem 2rem; margin-bottom: 3rem; }
    .timer-display { font-size: 6rem; font-weight: 800; font-family: monospace; color: var(--accent-color); margin-bottom: 2rem; line-height: 1; }
    .timer-controls { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
    .btn { padding: 0.75rem 1.5rem; font-size: 1.1rem; font-weight: 600; border: none; border-radius: 8px; cursor: pointer; transition: opacity 0.2s ease; }
    .btn:hover { opacity: 0.9; }
    .btn.primary { background: var(--accent-color); color: white; }
    .btn.secondary { background: var(--border-color); color: var(--text-primary); }
    .btn.danger { background: #ef4444; color: white; }

    .timer-done { color: #ef4444; animation: blink 1s infinite; }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const display = document.getElementById('timer-display');
      const startBtn = document.getElementById('start-btn');
      const pauseBtn = document.getElementById('pause-btn');
      const resetBtn = document.getElementById('reset-btn');

      const INITIAL_TIME = 7 * 60; // 7 minutes in seconds
      let remainingTime = INITIAL_TIME;
      let timerInterval = null;
      let endTime = null;

      function formatTime(seconds) {
        if (seconds < 0) seconds = 0;
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = Math.floor(seconds % 60).toString().padStart(2, '0');
        return `${m}:${s}`;
      }

      function updateDisplay() {
        display.textContent = formatTime(remainingTime);
        if (remainingTime <= 0) {
          display.classList.add('timer-done');
        } else {
          display.classList.remove('timer-done');
        }
      }

      function startTimer() {
        if (timerInterval) return;
        if (remainingTime <= 0) remainingTime = INITIAL_TIME;

        display.classList.remove('timer-done');
        endTime = Date.now() + (remainingTime * 1000);

        timerInterval = setInterval(() => {
          const now = Date.now();
          const delta = endTime - now;
          remainingTime = Math.ceil(delta / 1000);

          if (remainingTime <= 0) {
            remainingTime = 0;
            clearInterval(timerInterval);
            timerInterval = null;
          }

          updateDisplay();
        }, 100);
      }

      function pauseTimer() {
        if (timerInterval) {
          clearInterval(timerInterval);
          timerInterval = null;
        }
      }

      function resetTimer() {
        pauseTimer();
        remainingTime = INITIAL_TIME;
        display.classList.remove('timer-done');
        updateDisplay();
      }

      startBtn.addEventListener('click', startTimer);
      pauseBtn.addEventListener('click', pauseTimer);
      resetBtn.addEventListener('click', resetTimer);

      updateDisplay();
    });
  </script>

