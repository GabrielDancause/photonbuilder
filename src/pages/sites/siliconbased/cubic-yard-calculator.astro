---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Cubic Yard Calculator",
  description: "How much material do you really need? Calculate exact volume in cubic yards for dirt, concrete, mulch, and more.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a cubic yard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A cubic yard is a unit of volume primarily used in the US and Canada to measure materials like dirt, mulch, and concrete. It represents the volume of a cube with sides that are exactly 1 yard (3 feet or 36 inches) long."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate cubic yards?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To calculate cubic yards, multiply the length, width, and depth (thickness) together. If your measurements are in feet, the formula is: Length (ft) × Width (ft) × Depth (ft) / 27 = Cubic Yards. If your depth is in inches, first convert it to feet by dividing by 12."
          }
        },
        {
          "@type": "Question",
          "name": "How many cubic feet are in a cubic yard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There are exactly 27 cubic feet in one cubic yard. This is because a cubic yard is 3 feet long, 3 feet wide, and 3 feet deep (3 × 3 × 3 = 27)."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a cubic yard of dirt or soil weigh?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The weight of a cubic yard of dirt varies greatly based on moisture content and composition. On average, a cubic yard of dry topsoil weighs around 2,000 pounds (1 ton), but wet, compacted soil can weigh over 3,000 pounds."
          }
        },
        {
          "@type": "Question",
          "name": "How many bags of concrete make a cubic yard?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "It takes about forty-five 80-pound bags, or sixty 60-pound bags, of standard pre-mixed concrete to yield exactly one cubic yard."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      }
    }
  ]
};
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/cubic-yard-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Cubic Yard Calculator</h1>
      <p class="subtitle">Instantly calculate the volume of concrete, dirt, mulch, or gravel needed for your project.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-group">
          <label for="length-input">Length</label>
          <div class="input-row">
            <input type="number" id="length-input" placeholder="0" min="0" step="0.01" />
            <select id="length-unit">
              <option value="ft">Feet (ft)</option>
              <option value="in">Inches (in)</option>
              <option value="yd">Yards (yd)</option>
              <option value="m">Meters (m)</option>
            </select>
          </div>
        </div>

        <div class="input-group">
          <label for="width-input">Width</label>
          <div class="input-row">
            <input type="number" id="width-input" placeholder="0" min="0" step="0.01" />
            <select id="width-unit">
              <option value="ft">Feet (ft)</option>
              <option value="in">Inches (in)</option>
              <option value="yd">Yards (yd)</option>
              <option value="m">Meters (m)</option>
            </select>
          </div>
        </div>

        <div class="input-group" style="grid-column: 1 / -1;">
          <label for="depth-input">Depth / Thickness</label>
          <div class="input-row">
            <input type="number" id="depth-input" placeholder="0" min="0" step="0.01" />
            <select id="depth-unit">
              <option value="in" selected>Inches (in)</option>
              <option value="ft">Feet (ft)</option>
              <option value="yd">Yards (yd)</option>
              <option value="m">Meters (m)</option>
            </select>
          </div>
        </div>
      </div>

      <p class="error-msg" id="calc-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 1rem; display: none;">Please enter valid positive numbers for all dimensions.</p>

      <div class="result-card">
        <div class="calc-result-label">Required Volume</div>
        <div class="result-value">
          <span id="cubic-yards-val">0.00</span> <span style="font-size: 1.25rem; font-weight: 600; color: var(--text-secondary);">yd³</span>
        </div>
      </div>

      <div class="conversion-grid">
        <div class="conv-box">
          <div class="conv-label">Cubic Feet (ft³)</div>
          <div class="conv-val" id="cubic-feet-val">0.00</div>
        </div>
        <div class="conv-box">
          <div class="conv-label">Cubic Meters (m³)</div>
          <div class="conv-val" id="cubic-meters-val">0.00</div>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>How the Cubic Yard Calculator Works</h2>
      <p>
        Whether you are planning to pour a new concrete driveway, spread mulch in your garden, or fill raised beds with topsoil, knowing precisely how much material to order is critical. Overestimating means wasted money and leftover material, while underestimating leads to mid-project delays and emergency trips to the supply store.
      </p>
      <p>
        The Cubic Yard Calculator simplifies this process by taking your linear dimensions—length, width, and depth (or thickness)—and instantly converting them into accurate volumetric measurements.
      </p>

      <h3>Understanding Cubic Yards</h3>
      <p>
        A <strong>cubic yard (yd³)</strong> is a three-dimensional unit of volume. Imagine a physical block that is exactly 1 yard long, 1 yard wide, and 1 yard tall.
      </p>
      <p>
        Since 1 yard equals 3 feet, a cubic yard can also be visualized as a 3-foot by 3-foot by 3-foot cube. To find the volume in cubic feet, you simply multiply these dimensions:
        <br><code>3 ft &times; 3 ft &times; 3 ft = 27 cubic feet</code>.
      </p>
      <p>
        Therefore, exactly <strong>27 cubic feet make up a single cubic yard</strong>. Most bulk landscaping and construction materials in North America—including dirt, gravel, sand, mulch, and ready-mix concrete—are sold by the cubic yard.
      </p>

      <h3>The Standard Volume Formula</h3>
      <p>
        The mathematical formula for finding a cubic yard based on standard English measurements (feet and inches) is straightforward. To do it by hand, you first ensure all your measurements are in feet.
      </p>
      <ol>
        <li>Measure the <strong>Length</strong> in feet.</li>
        <li>Measure the <strong>Width</strong> in feet.</li>
        <li>Measure the <strong>Depth</strong> in inches. Convert this to feet by dividing by 12.</li>
        <li>Multiply these three numbers together to get the total Cubic Feet.</li>
        <li>Divide the total Cubic Feet by <strong>27</strong> to find the Cubic Yards.</li>
      </ol>
      <p>
        For example, if you are pouring a concrete slab that is 10 feet long, 10 feet wide, and 4 inches thick:
        <br><code>10 ft (L) &times; 10 ft (W) &times; (4/12) ft (D) = 33.33 cubic feet</code>.
        <br><code>33.33 / 27 = 1.23 cubic yards</code>.
      </p>

      <h3>Calculating for Common Materials</h3>
      <p>
        Different projects require slightly different planning strategies, even if the base math remains the same:
      </p>
      <ul>
        <li><strong>Concrete:</strong> When ordering ready-mix concrete, contractors typically recommend adding a 5% to 10% "waste margin" to your final calculation. This accounts for uneven subgrades, spillage, and settling forms.</li>
        <li><strong>Mulch:</strong> For garden beds, a depth of 2 to 3 inches is generally ideal to suppress weeds and retain moisture without smothering plant roots.</li>
        <li><strong>Topsoil & Dirt:</strong> When filling deep raised beds, expect the soil to settle by roughly 10-20% after the first few waterings. It is wise to order slightly more than the strict mathematical volume.</li>
        <li><strong>Gravel:</strong> For a stable gravel driveway or walking path, a compacted depth of at least 4 inches is recommended.</li>
      </ul>

      <h3>Using the Calculator Tool</h3>
      <p>
        Our calculator allows you to mix and match measurement units freely. You can enter length in feet, width in meters, and depth in inches, and the internal engine will automatically convert all inputs to a unified base standard before running the final calculation.
      </p>
      <p>
        The tool processes the data locally in your browser, providing instant, real-time results as you adjust any measurement or unit type. It also outputs the equivalent volume in cubic feet and cubic meters for convenience.
      </p>

      <div class="highlight-box">
        <strong>Working on a math or logic project?</strong> Check out our <a href="/factor-calculator">Factor Calculator</a> to quickly find prime factorizations and factor pairs for any integer.
      </div>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>What is a cubic yard?</summary>
        <p>A cubic yard is a unit of volume primarily used in the US and Canada to measure materials like dirt, mulch, and concrete. It represents the volume of a cube with sides that are exactly 1 yard (3 feet or 36 inches) long.</p>
      </details>

      <details>
        <summary>How do you calculate cubic yards?</summary>
        <p>To calculate cubic yards, multiply the length, width, and depth (thickness) together. If your measurements are in feet, the formula is: Length (ft) × Width (ft) × Depth (ft) / 27 = Cubic Yards. If your depth is in inches, first convert it to feet by dividing by 12.</p>
      </details>

      <details>
        <summary>How many cubic feet are in a cubic yard?</summary>
        <p>There are exactly 27 cubic feet in one cubic yard. This is because a cubic yard is 3 feet long, 3 feet wide, and 3 feet deep (3 × 3 × 3 = 27).</p>
      </details>

      <details>
        <summary>How much does a cubic yard of dirt or soil weigh?</summary>
        <p>The weight of a cubic yard of dirt varies greatly based on moisture content and composition. On average, a cubic yard of dry topsoil weighs around 2,000 pounds (1 ton), but wet, compacted soil can weigh over 3,000 pounds.</p>
      </details>

      <details>
        <summary>How many bags of concrete make a cubic yard?</summary>
        <p>It takes about forty-five 80-pound bags, or sixty 60-pound bags, of standard pre-mixed concrete to yield exactly one cubic yard.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = [
        document.getElementById('length-input'),
        document.getElementById('width-input'),
        document.getElementById('depth-input'),
        document.getElementById('length-unit'),
        document.getElementById('width-unit'),
        document.getElementById('depth-unit')
      ];

      const calcError = document.getElementById('calc-error');
      const cubicYardsVal = document.getElementById('cubic-yards-val');
      const cubicFeetVal = document.getElementById('cubic-feet-val');
      const cubicMetersVal = document.getElementById('cubic-meters-val');

      function toFeet(value, unit) {
        if (unit === 'ft') return value;
        if (unit === 'in') return value / 12;
        if (unit === 'yd') return value * 3;
        if (unit === 'm') return value * 3.28084;
        return 0;
      }

      function calculate() {
        const length = parseFloat(inputs[0].value);
        const width = parseFloat(inputs[1].value);
        const depth = parseFloat(inputs[2].value);

        if (isNaN(length) || isNaN(width) || isNaN(depth) || length < 0 || width < 0 || depth < 0) {
          calcError.style.display = 'block';
          cubicYardsVal.textContent = '0.00';
          cubicFeetVal.textContent = '0.00';
          cubicMetersVal.textContent = '0.00';
          return;
        }

        calcError.style.display = 'none';

        const lengthUnit = inputs[3].value;
        const widthUnit = inputs[4].value;
        const depthUnit = inputs[5].value;

        const lengthFt = toFeet(length, lengthUnit);
        const widthFt = toFeet(width, widthUnit);
        const depthFt = toFeet(depth, depthUnit);

        const cubicFeet = lengthFt * widthFt * depthFt;
        const cubicYards = cubicFeet / 27;
        const cubicMeters = cubicYards * 0.764554857984;

        cubicYardsVal.textContent = cubicYards.toFixed(2);

        // Format large numbers with commas
        const formatNum = (num) => new Intl.NumberFormat('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(num);

        cubicFeetVal.textContent = formatNum(cubicFeet);
        cubicMetersVal.textContent = formatNum(cubicMeters);
      }

      inputs.forEach(input => {
        input.addEventListener('input', calculate);
        input.addEventListener('change', calculate);
      });

      // Initialize with zero state
      calculate();
    });
  </script>

  <style is:inline>
    .calc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .input-row {
      display: flex;
      gap: 0.5rem;
    }
    .input-row input {
      flex: 2;
    }
    .input-row select {
      flex: 1;
      min-width: 100px;
    }
    .conversion-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1rem;
    }
    .conv-box {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
    }
    .conv-label {
      color: var(--text-secondary);
      font-size: 0.85rem;
      margin-bottom: 0.25rem;
    }
    .conv-val {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      color: var(--text-primary);
      font-weight: 600;
    }
    @media (max-width: 640px) {
      .calc-grid {
        grid-template-columns: 1fr;
      }
      .input-row {
        flex-direction: column;
      }
    }
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }
    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: center; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }
  </style>
</SiteLayout>
