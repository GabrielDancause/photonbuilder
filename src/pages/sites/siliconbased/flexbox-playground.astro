---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Flexbox Playground & Generator",
    "url": "https://siliconbased.dev/flexbox-playground",
    "description": "Interactive CSS Flexbox builder. Visually edit flex container and flex item properties, preview live layouts, and generate CSS code instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    }
  }
];
---

<SiteLayout
  site="siliconbased"
  title="Flexbox Playground & Generator | Free Online Tool"
  description="Interactive CSS Flexbox builder. Visually edit flex container and flex item properties, preview live layouts, and generate CSS code instantly. Free and works offline."
  canonical="https://siliconbased.dev/flexbox-playground"
  schema={schemas}
>
  <style is:inline>
code, pre, .mono { font-family: "JetBrains Mono", monospace; }
.hero { text-align: center; padding: 32px 24px 16px; background: linear-gradient(180deg, #0f1729 0%, #0a0b10 100%); }
.hero h1 { font-size: 2.2rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; display: grid; grid-template-columns: 320px 1fr; gap: 24px; align-items: start; }
@media (max-width: 900px) {
  .main { grid-template-columns: 1fr; }
}
.controls-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }
.tabs { display: flex; background: #13151d; border-bottom: 1px solid #1e2030; }
.tab-btn { flex: 1; background: transparent; border: none; color: #888; padding: 14px; font-size: 0.9rem; font-weight: 600; cursor: pointer; font-family: "Inter", sans-serif; transition: all 0.2s; border-bottom: 2px solid transparent; }
.tab-btn:hover { color: #ccc; background: #1a1c26; }
.tab-btn.active { color: #818cf8; border-bottom-color: #818cf8; background: #111318; }
.controls-body { padding: 20px; display: none; flex-direction: column; gap: 16px; }
.controls-body.active { display: flex; }
.control-group { display: flex; flex-direction: column; gap: 6px; }
.control-label { font-size: 0.8rem; font-weight: 600; color: #a0a8c0; text-transform: uppercase; letter-spacing: 0.5px; }
.control-select, .control-input { width: 100%; background: #0a0b10; border: 1px solid #2a2d40; color: #e0e0e0; font-family: "JetBrains Mono", monospace; font-size: 0.85rem; padding: 8px 12px; border-radius: 8px; outline: none; transition: border-color 0.2s; appearance: none; }
.control-select:focus, .control-input:focus { border-color: #818cf8; }
.control-select { cursor: pointer; background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23888%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E"); background-repeat: no-repeat; background-position: right 12px top 50%; background-size: 10px auto; padding-right: 32px; }
.info-text { font-size: 0.8rem; color: #666; font-style: italic; }
.item-actions { display: flex; gap: 8px; margin-top: 8px; }
.btn { flex: 1; background: #1e2030; border: 1px solid #2a2d40; color: #ccc; padding: 8px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; font-family: "Inter", sans-serif; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 6px; }
.btn:hover { background: #2a2d40; color: #fff; }
.btn-primary { background: #818cf8; color: #fff; border-color: #818cf8; }
.btn-primary:hover { background: #6366f1; border-color: #6366f1; }
.btn-danger { color: #ef4444; }
.btn-danger:hover { background: #ef4444; color: #fff; border-color: #ef4444; }
.preview-col { display: flex; flex-direction: column; gap: 24px; }
.preview-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }
.preview-header { padding: 12px 20px; background: #13151d; border-bottom: 1px solid #1e2030; display: flex; justify-content: space-between; align-items: center; }
.preview-header h3 { font-size: 0.9rem; font-weight: 600; color: #ccc; }
.preview-area { padding: 20px; background: #0a0b10; min-height: 400px; display: flex; overflow: auto; resize: vertical; border-bottom: 1px solid #1e2030; }
.flex-container { background: #1a1d27; border: 2px dashed #2a2d40; border-radius: 8px; width: 100%; min-height: 300px; display: flex; padding: 8px; transition: all 0.3s ease; }
.flex-item { background: linear-gradient(135deg, #4f46e5, #818cf8); border: 2px solid #818cf8; border-radius: 6px; color: #fff; font-weight: 700; font-family: "JetBrains Mono", monospace; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; min-width: 60px; min-height: 60px; cursor: pointer; user-select: none; transition: transform 0.1s, box-shadow 0.2s; margin: 0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
.flex-item:hover { transform: scale(1.05); z-index: 10; }
.flex-item.selected { border-color: #fff; box-shadow: 0 0 0 3px rgba(129, 140, 248, 0.5), 0 10px 15px -3px rgba(0, 0, 0, 0.1); background: linear-gradient(135deg, #c084fc, #818cf8); }
.code-card { background: #111318; border: 1px solid #1e2030; border-radius: 16px; overflow: hidden; }
.code-header { padding: 12px 20px; background: #13151d; border-bottom: 1px solid #1e2030; display: flex; justify-content: space-between; align-items: center; }
.code-header h3 { font-size: 0.9rem; font-weight: 600; color: #ccc; }
.code-area { padding: 16px; background: #0a0b10; }
.code-block { margin-bottom: 16px; }
.code-block:last-child { margin-bottom: 0; }
.code-label { font-size: 0.75rem; color: #818cf8; font-weight: 600; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
pre { color: #e0e0e0; font-size: 0.85rem; overflow-x: auto; line-height: 1.5; tab-size: 2; }
.token.property { color: #9cdcfe; }
.token.value { color: #ce9178; }
.token.selector { color: #d7ba7d; }
.token.punctuation { color: #808080; }
.token.tag { color: #569cd6; }
.btn.copied { background: #1a3a1a; color: #4ade80; border-color: #2d5a2d; }
.seo-section { grid-column: 1 / -1; margin-top: 32px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; max-width: 900px; margin-left: auto; margin-right: auto; }
.seo-section h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-section h2:first-child { margin-top: 0; }
.seo-section h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-section p { margin-bottom: 16px; }
.seo-section ul { margin-bottom: 16px; padding-left: 24px; }
.seo-section li { margin-bottom: 8px; }
.seo-section code { background: #111318; padding: 2px 6px; border-radius: 4px; color: #818cf8; font-size: 0.85em; font-family: "JetBrains Mono", monospace; }
.footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #555; border-top: 1px solid #151520; margin-top: auto; }
.footer a { color: #818cf8; text-decoration: none; }
.footer a:hover { text-decoration: underline; }
</style>


  <script is:inline>

const flexContainer = document.getElementById('flexContainer');
const codeArea = document.getElementById('codeArea');
const copyCodeBtn = document.getElementById('copyCodeBtn');

// Tabs
const tabContainer = document.getElementById('tabContainer');
const tabItem = document.getElementById('tabItem');
const controlsContainer = document.getElementById('controlsContainer');
const controlsItem = document.getElementById('controlsItem');

// Container Inputs
const cFlexDirection = document.getElementById('c-flex-direction');
const cJustifyContent = document.getElementById('c-justify-content');
const cAlignItems = document.getElementById('c-align-items');
const cFlexWrap = document.getElementById('c-flex-wrap');
const cAlignContent = document.getElementById('c-align-content');
const cGap = document.getElementById('c-gap');

const btnAddItem = document.getElementById('btnAddItem');
const btnRemoveItem = document.getElementById('btnRemoveItem');

// Item Inputs
const iOrder = document.getElementById('i-order');
const iFlexGrow = document.getElementById('i-flex-grow');
const iFlexShrink = document.getElementById('i-flex-shrink');
const iFlexBasis = document.getElementById('i-flex-basis');
const iAlignSelf = document.getElementById('i-align-self');
const btnResetItem = document.getElementById('btnResetItem');
const itemInfoText = document.getElementById('itemInfoText');
const itemPropsWrapper = document.getElementById('itemPropsWrapper');
const selectedItemBadge = document.getElementById('selectedItemBadge');

let itemsCount = 3;
let selectedItemIndex = null;
let itemProps = {}; // e.g. { 0: { order: 1, flexGrow: 1 } }

function switchTab(tab) {
  if (tab === 'container') {
    tabContainer.classList.add('active');
    tabItem.classList.remove('active');
    controlsContainer.classList.add('active');
    controlsItem.classList.remove('active');
  } else {
    tabItem.classList.add('active');
    tabContainer.classList.remove('active');
    controlsItem.classList.add('active');
    controlsContainer.classList.remove('active');
  }
}

tabContainer.addEventListener('click', () => switchTab('container'));
tabItem.addEventListener('click', () => switchTab('item'));

function renderItems() {
  flexContainer.innerHTML = '';
  for (let i = 0; i < itemsCount; i++) {
    const div = document.createElement('div');
    div.className = 'flex-item';
    if (i === selectedItemIndex) div.classList.add('selected');
    div.textContent = i + 1;

    // Apply specific item props
    if (itemProps[i]) {
      const p = itemProps[i];
      if (p.order !== undefined && p.order !== 0) div.style.order = p.order;
      if (p.flexGrow !== undefined && p.flexGrow !== 0) div.style.flexGrow = p.flexGrow;
      if (p.flexShrink !== undefined && p.flexShrink !== 1) div.style.flexShrink = p.flexShrink;
      if (p.flexBasis !== undefined && p.flexBasis !== 'auto') div.style.flexBasis = p.flexBasis;
      if (p.alignSelf !== undefined && p.alignSelf !== 'auto') div.style.alignSelf = p.alignSelf;
    }

    div.addEventListener('click', () => selectItem(i));
    flexContainer.appendChild(div);
  }
}

function selectItem(index) {
  selectedItemIndex = index;
  renderItems();

  if (selectedItemIndex !== null) {
    switchTab('item');
    itemInfoText.style.display = 'none';
    itemPropsWrapper.style.display = 'flex';
    selectedItemBadge.style.display = 'inline-block';
    selectedItemBadge.textContent = index + 1;

    // Populate inputs
    const p = itemProps[index] || {};
    iOrder.value = p.order !== undefined ? p.order : 0;
    iFlexGrow.value = p.flexGrow !== undefined ? p.flexGrow : 0;
    iFlexShrink.value = p.flexShrink !== undefined ? p.flexShrink : 1;
    iFlexBasis.value = p.flexBasis !== undefined ? p.flexBasis : 'auto';
    iAlignSelf.value = p.alignSelf !== undefined ? p.alignSelf : 'auto';
  } else {
    itemInfoText.style.display = 'block';
    itemPropsWrapper.style.display = 'none';
    selectedItemBadge.style.display = 'none';
  }
}

function updateContainer() {
  flexContainer.style.flexDirection = cFlexDirection.value;
  flexContainer.style.justifyContent = cJustifyContent.value;
  flexContainer.style.alignItems = cAlignItems.value;
  flexContainer.style.flexWrap = cFlexWrap.value;
  flexContainer.style.alignContent = cAlignContent.value;
  flexContainer.style.gap = cGap.value;
  updateCode();
}

function updateItem() {
  if (selectedItemIndex === null) return;

  if (!itemProps[selectedItemIndex]) {
    itemProps[selectedItemIndex] = {};
  }

  itemProps[selectedItemIndex] = {
    order: parseInt(iOrder.value) || 0,
    flexGrow: parseInt(iFlexGrow.value) || 0,
    flexShrink: parseInt(iFlexShrink.value),
    flexBasis: iFlexBasis.value || 'auto',
    alignSelf: iAlignSelf.value
  };

  renderItems();
  updateCode();
}

function updateCode() {
  let containerCss = `.container {
  <span class="token property">display</span>: <span class="token value">flex</span>;`;

  if (cFlexDirection.value !== 'row') {
    containerCss += `\n  <span class="token property">flex-direction</span>: <span class="token value">${cFlexDirection.value}</span>;`;
  }
  if (cJustifyContent.value !== 'flex-start') {
    containerCss += `\n  <span class="token property">justify-content</span>: <span class="token value">${cJustifyContent.value}</span>;`;
  }
  if (cAlignItems.value !== 'stretch') {
    containerCss += `\n  <span class="token property">align-items</span>: <span class="token value">${cAlignItems.value}</span>;`;
  }
  if (cFlexWrap.value !== 'nowrap') {
    containerCss += `\n  <span class="token property">flex-wrap</span>: <span class="token value">${cFlexWrap.value}</span>;`;
  }
  if (cAlignContent.value !== 'stretch') {
    containerCss += `\n  <span class="token property">align-content</span>: <span class="token value">${cAlignContent.value}</span>;`;
  }
  if (cGap.value && cGap.value !== '0' && cGap.value !== '0px') {
    containerCss += `\n  <span class="token property">gap</span>: <span class="token value">${cGap.value}</span>;`;
  }
  containerCss += `\n}`;

  let itemsCss = '';

  for (let i = 0; i < itemsCount; i++) {
    if (itemProps[i]) {
      const p = itemProps[i];
      let itemCss = '';
      if (p.order !== undefined && p.order !== 0) itemCss += `\n  <span class="token property">order</span>: <span class="token value">${p.order}</span>;`;
      if (p.flexGrow !== undefined && p.flexGrow !== 0) itemCss += `\n  <span class="token property">flex-grow</span>: <span class="token value">${p.flexGrow}</span>;`;
      if (p.flexShrink !== undefined && p.flexShrink !== 1) itemCss += `\n  <span class="token property">flex-shrink</span>: <span class="token value">${p.flexShrink}</span>;`;
      if (p.flexBasis !== undefined && p.flexBasis !== 'auto') itemCss += `\n  <span class="token property">flex-basis</span>: <span class="token value">${p.flexBasis}</span>;`;
      if (p.alignSelf !== undefined && p.alignSelf !== 'auto') itemCss += `\n  <span class="token property">align-self</span>: <span class="token value">${p.alignSelf}</span>;`;

      if (itemCss !== '') {
        itemsCss += `\n\n.item-${i + 1} {${itemCss}\n}`;
      }
    }
  }

  codeArea.innerHTML = `<pre><code><span class="token selector">${containerCss}</span>${itemsCss ? `<span class="token selector">${itemsCss}</span>` : ''}</code></pre>`;
}

function getRawCode() {
  const temp = document.createElement('div');
  temp.innerHTML = codeArea.innerHTML;
  return temp.textContent || temp.innerText || '';
}

// Event Listeners
const containerInputs = [cFlexDirection, cJustifyContent, cAlignItems, cFlexWrap, cAlignContent, cGap];
containerInputs.forEach(input => {
  input.addEventListener('change', updateContainer);
  if (input.tagName === 'INPUT') {
    input.addEventListener('input', updateContainer);
  }
});

const itemInputs = [iOrder, iFlexGrow, iFlexShrink, iFlexBasis, iAlignSelf];
itemInputs.forEach(input => {
  input.addEventListener('change', updateItem);
  if (input.tagName === 'INPUT') {
    input.addEventListener('input', updateItem);
  }
});

btnAddItem.addEventListener('click', () => {
  if (itemsCount < 12) {
    itemsCount++;
    renderItems();
    updateCode();
  }
});

btnRemoveItem.addEventListener('click', () => {
  if (itemsCount > 1) {
    // Clean up props if removing selected
    delete itemProps[itemsCount - 1];
    if (selectedItemIndex === itemsCount - 1) {
      selectItem(null);
    }
    itemsCount--;
    renderItems();
    updateCode();
  }
});

btnResetItem.addEventListener('click', () => {
  if (selectedItemIndex !== null) {
    delete itemProps[selectedItemIndex];
    selectItem(selectedItemIndex);
    updateCode();
  }
});

copyCodeBtn.addEventListener('click', () => {
  const code = getRawCode();
  if (!code) return;
  navigator.clipboard.writeText(code).then(() => {
    const originalText = copyCodeBtn.innerHTML;
    copyCodeBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied!';
    copyCodeBtn.classList.add('copied');
    setTimeout(() => {
      copyCodeBtn.innerHTML = originalText;
      copyCodeBtn.classList.remove('copied');
    }, 2000);
  });
});

// Initialize
renderItems();
updateContainer();


</script>

</SiteLayout>
