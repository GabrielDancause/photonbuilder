---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Regex Tester — Test Regular Expressions Online",
      "url": "https://siliconbased.dev/regex-tester",
      "description": "Free online regex tester with real-time match highlighting, group captures, replace mode, and a built-in cheat sheet. Test regular expressions instantly.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is a regex tester?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A regex tester is an online tool that lets you write a regular expression pattern and test it against a sample string in real time. It highlights matches, shows captured groups, and reports match positions — helping you build and debug patterns without writing code."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use a regular expression tester?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Type your regex pattern in the pattern input field, enter your test string in the text area, and toggle flags like global (g), case-insensitive (i), or multiline (m). Matches are highlighted instantly as you type — no submit button needed."
          }
        },
        {
          "@type": "Question",
          "name": "What regex flags are available?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The most common flags are: g (global — find all matches), i (case-insensitive), m (multiline — ^ and $ match line boundaries), s (dotAll — . matches newlines), and u (unicode — enables full Unicode matching). You can combine multiple flags."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between regex tester and regex101?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Both are online regex testing tools. This regex tester runs entirely in your browser with zero server calls, providing instant results with match highlighting, group captures, and a replace mode. It also includes a quick-reference panel and cheat sheet for learning regex syntax."
          }
        },
        {
          "@type": "Question",
          "name": "Can I use regex to find and replace text?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Switch to Replace mode, enter your replacement pattern (supporting backreferences like $1, $2 for captured groups), and see the transformed output instantly. This is useful for batch text transformations, data cleanup, and reformatting."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my regex not matching anything?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Common reasons include: forgetting the global (g) flag so only the first match is found, not escaping special characters like . or (, case sensitivity (toggle the i flag), or an incorrect pattern. Check the error message area for syntax issues and use the cheat sheet for reference."
          }
        },
        {
          "@type": "Question",
          "name": "Is my data safe when using an online regex checker?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This regex tester runs entirely in your browser using JavaScript. No data is sent to any server. Your patterns and test strings never leave your device, making it completely safe for testing with sensitive data."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Regex Tester — Test & Debug Regular Expressions Online",
      "description": "Free online regex tester with real-time match highlighting, group captures, replace mode, and a built-in cheat sheet.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Regex Tester</h1>
  <p>Test, debug, and learn regular expressions in real time. No data leaves your browser.</p>
</div>

<div class="main">

  <!-- Pattern Input -->
  <div class="pattern-bar">
    <span class="pattern-slash">/</span>
    <input type="text" id="regexInput" class="regex-input" placeholder="Enter regex pattern..." spellcheck="false" value="(\\\\w+)@(\\\\w+\\\\.\\\\w+)" />
    <span class="pattern-slash">/</span>
    <div class="flags-row">
      <button class="flag-btn active" data-flag="g" title="Global">g</button>
      <button class="flag-btn" data-flag="i" title="Case Insensitive">i</button>
      <button class="flag-btn" data-flag="m" title="Multiline">m</button>
      <button class="flag-btn" data-flag="s" title="DotAll">s</button>
      <button class="flag-btn" data-flag="u" title="Unicode">u</button>
    </div>
  </div>

  <!-- Error message -->
  <div class="regex-error" id="regexError"></div>

  <!-- Mode toggle -->
  <div class="mode-row">
    <button class="mode-btn active" id="btnMatch">Match</button>
    <button class="mode-btn" id="btnReplace">Replace</button>
  </div>

  <!-- Replace input (hidden by default) -->
  <div class="replace-bar" id="replaceBar" style="display:none;">
    <label class="replace-label">Replace with:</label>
    <input type="text" id="replaceInput" class="replace-input" placeholder="Replacement pattern (e.g. $1 or \\$&)" spellcheck="false" />
  </div>

  <div class="tool-grid">
    <!-- Test String -->
    <div class="pane">
      <div class="input-header">
        <div class="header-title">Test String</div>
        <div class="header-actions">
          <button class="action-btn" id="clearBtn">Clear</button>
        </div>
      </div>
      <div class="test-string-wrap">
        <div class="highlight-layer" id="highlightLayer"></div>
        <textarea id="testInput" class="test-input" spellcheck="false" placeholder="Enter text to test against..."></textarea>
      </div>
    </div>

    <!-- Results -->
    <div class="pane">
      <div class="output-header">
        <div class="header-title" id="matchStatus">Matches</div>
        <div class="header-actions">
          <button class="copy-btn" id="copyBtn">Copy</button>
        </div>
      </div>
      <div class="results-card" id="resultsCard">
        <div id="matchResults" class="match-results"></div>
      </div>
    </div>
  </div>

  <!-- Replace output -->
  <div class="replace-output-wrap" id="replaceOutputWrap" style="display:none;">
    <div class="input-header">
      <div class="header-title">Replace Output</div>
      <div class="header-actions">
        <button class="copy-btn" id="copyReplaceBtn">Copy</button>
      </div>
    </div>
    <pre class="replace-output" id="replaceOutput"></pre>
  </div>

  <!-- Quick Reference -->
  <div class="quick-ref">
    <div class="input-header">
      <div class="header-title">Quick Reference — Click to Insert</div>
    </div>
    <div class="ref-grid" id="quickRefGrid"></div>
  </div>

  <!-- Cheat Sheet -->
  <div class="cheat-sheet">
    <h2>Regex Cheat Sheet</h2>
    <div class="cheat-grid">
      <div class="cheat-section">
        <h3>Character Classes</h3>
        <table class="cheat-table"><tbody>
          <tr><td><code>.</code></td><td>Any character (except newline)</td></tr>
          <tr><td><code>\\\\d</code></td><td>Digit (0-9)</td></tr>
          <tr><td><code>\\\\D</code></td><td>Not a digit</td></tr>
          <tr><td><code>\\\\w</code></td><td>Word character (a-z, A-Z, 0-9, _)</td></tr>
          <tr><td><code>\\\\W</code></td><td>Not a word character</td></tr>
          <tr><td><code>\\\\s</code></td><td>Whitespace</td></tr>
          <tr><td><code>\\\\S</code></td><td>Not whitespace</td></tr>
          <tr><td><code>[abc]</code></td><td>Any of a, b, or c</td></tr>
          <tr><td><code>[^abc]</code></td><td>Not a, b, or c</td></tr>
          <tr><td><code>[a-z]</code></td><td>Character range a to z</td></tr>
        </tbody></table>
      </div>
      <div class="cheat-section">
        <h3>Quantifiers</h3>
        <table class="cheat-table"><tbody>
          <tr><td><code>*</code></td><td>0 or more</td></tr>
          <tr><td><code>+</code></td><td>1 or more</td></tr>
          <tr><td><code>?</code></td><td>0 or 1 (optional)</td></tr>
          <tr><td><code>{n}</code></td><td>Exactly n times</td></tr>
          <tr><td><code>{n,}</code></td><td>n or more times</td></tr>
          <tr><td><code>{n,m}</code></td><td>Between n and m times</td></tr>
          <tr><td><code>*?</code></td><td>Lazy (0 or more)</td></tr>
          <tr><td><code>+?</code></td><td>Lazy (1 or more)</td></tr>
        </tbody></table>
      </div>
      <div class="cheat-section">
        <h3>Anchors & Boundaries</h3>
        <table class="cheat-table"><tbody>
          <tr><td><code>^</code></td><td>Start of string / line</td></tr>
          <tr><td><code>$</code></td><td>End of string / line</td></tr>
          <tr><td><code>\\\\b</code></td><td>Word boundary</td></tr>
          <tr><td><code>\\\\B</code></td><td>Not a word boundary</td></tr>
        </tbody></table>
      </div>
      <div class="cheat-section">
        <h3>Groups & Lookaround</h3>
        <table class="cheat-table"><tbody>
          <tr><td><code>(abc)</code></td><td>Capturing group</td></tr>
          <tr><td><code>(?:abc)</code></td><td>Non-capturing group</td></tr>
          <tr><td><code>(?&lt;name&gt;abc)</code></td><td>Named group</td></tr>
          <tr><td><code>\\\\1</code></td><td>Backreference to group 1</td></tr>
          <tr><td><code>(?=abc)</code></td><td>Positive lookahead</td></tr>
          <tr><td><code>(?!abc)</code></td><td>Negative lookahead</td></tr>
          <tr><td><code>(?&lt;=abc)</code></td><td>Positive lookbehind</td></tr>
          <tr><td><code>(?&lt;!abc)</code></td><td>Negative lookbehind</td></tr>
          <tr><td><code>a|b</code></td><td>Alternation (a or b)</td></tr>
        </tbody></table>
      </div>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>What is a Regular Expression?</h2>
    <p>A regular expression (regex or regexp) is a sequence of characters that defines a search pattern. Originally developed for Unix text processing in the 1970s, regex is now supported in virtually every programming language and text editor. It's used for pattern matching, validation, search-and-replace, and text extraction.</p>

    <h2>Common Use Cases for Regex</h2>
    <ul>
      <li><strong>Form validation:</strong> Check if user input matches expected formats like emails, phone numbers, or zip codes.</li>
      <li><strong>Data extraction:</strong> Pull specific values like dates, URLs, or IDs from unstructured text or log files.</li>
      <li><strong>Search and replace:</strong> Transform text in bulk — rename variables, reformat dates, or clean up data.</li>
      <li><strong>Log analysis:</strong> Filter and parse server logs to find errors, IP addresses, or request patterns.</li>
      <li><strong>Web scraping:</strong> Extract content from HTML when a full parser is overkill.</li>
    </ul>

    <h2>Regex Flags Explained</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Flag</th>
          <th>Name</th>
          <th>Effect</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>g</code></td>
          <td>Global</td>
          <td>Find all matches, not just the first one</td>
        </tr>
        <tr>
          <td><code>i</code></td>
          <td>Case Insensitive</td>
          <td>Match uppercase and lowercase letters equally</td>
        </tr>
        <tr>
          <td><code>m</code></td>
          <td>Multiline</td>
          <td>Make <code>^</code> and <code>$</code> match start/end of each line</td>
        </tr>
        <tr>
          <td><code>s</code></td>
          <td>DotAll</td>
          <td>Make <code>.</code> match newline characters too</td>
        </tr>
        <tr>
          <td><code>u</code></td>
          <td>Unicode</td>
          <td>Enable full Unicode support for patterns</td>
        </tr>
      </tbody>
    </table>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is a regex tester?</h3>
      <p style="margin-bottom: 16px;">A regex tester is an online tool that lets you write a regular expression pattern and test it against a sample string in real time. It highlights matches, shows captured groups, and reports match positions — helping you build and debug patterns without writing code.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I use a regular expression tester?</h3>
      <p style="margin-bottom: 16px;">Type your regex pattern in the pattern input field, enter your test string in the text area, and toggle flags like global (g), case-insensitive (i), or multiline (m). Matches are highlighted instantly as you type — no submit button needed.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What regex flags are available?</h3>
      <p style="margin-bottom: 16px;">The most common flags are: g (global), i (case-insensitive), m (multiline), s (dotAll — makes . match newlines), and u (unicode). You can combine multiple flags to refine your search behavior.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between regex tester and regex101?</h3>
      <p style="margin-bottom: 16px;">Both are online regex testing tools. This regex tester runs entirely in your browser with zero server calls, providing instant results with match highlighting, group captures, and a replace mode. It also includes a quick-reference panel and cheat sheet for learning regex syntax.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can I use regex to find and replace text?</h3>
      <p style="margin-bottom: 16px;">Yes. Switch to Replace mode, enter your replacement pattern (supporting backreferences like $1, $2 for captured groups), and see the transformed output instantly. This is useful for batch text transformations, data cleanup, and reformatting.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Why is my regex not matching anything?</h3>
      <p style="margin-bottom: 16px;">Common reasons include: forgetting the global (g) flag so only the first match is found, not escaping special characters like . or (, case sensitivity (toggle the i flag), or an incorrect pattern. Check the error message for syntax issues and reference the cheat sheet.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is my data safe when using an online regex checker?</h3>
      <p style="margin-bottom: 16px;">This regex tester runs entirely in your browser using JavaScript. No data is sent to any server. Your patterns and test strings never leave your device, making it completely safe for testing with sensitive data.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/json-formatter">JSON Formatter & Validator</a> — Format, validate, and minify JSON online.</li>
      <li><a href="/base64">Base64 Encoder / Decoder</a> — Encode and decode Base64 strings.</li>
      <li><a href="/url-encoder-decoder">URL Encoder / Decoder</a> — Encode and decode URL components.</li>
      <li><a href="/hash-generator">Hash Generator</a> — Generate MD5, SHA-1, SHA-256, and other hashes.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "Regex Tester — Test Regular Expressions Online",
  description: "Free online regex tester with real-time match highlighting, capture groups, replace mode, and cheat sheet. Like regex101 but faster.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="Regex Tester — Test Regular Expressions Online"
  description="Free online regex tester with real-time match highlighting, capture groups, replace mode, and cheat sheet. Like regex101 but faster."
  canonical="https://siliconbased.dev/regex-tester"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const regexInput = document.getElementById('regexInput');
const testInput = document.getElementById('testInput');
const highlightLayer = document.getElementById('highlightLayer');
const matchResults = document.getElementById('matchResults');
const matchStatus = document.getElementById('matchStatus');
const regexError = document.getElementById('regexError');
const replaceInput = document.getElementById('replaceInput');
const replaceBar = document.getElementById('replaceBar');
const replaceOutputWrap = document.getElementById('replaceOutputWrap');
const replaceOutput = document.getElementById('replaceOutput');
const btnMatch = document.getElementById('btnMatch');
const btnReplace = document.getElementById('btnReplace');
const clearBtn = document.getElementById('clearBtn');
const copyBtn = document.getElementById('copyBtn');
const copyReplaceBtn = document.getElementById('copyReplaceBtn');
const quickRefGrid = document.getElementById('quickRefGrid');
const resultsCard = document.getElementById('resultsCard');

let currentMode = 'match';
const matchColors = ['#818cf840','#c084fc40','#4ade8040','#fbbf2440','#f8717140','#38bdf840'];

const quickPatterns = [
  { label: 'Email', pattern: '[\\w.-]+@[\\w.-]+\\.\\w{2,}' },
  { label: 'URL', pattern: 'https?://[\\w.-]+(?:\\.[\\w]{2,})(?:/[^\\s]*)?' },
  { label: 'Phone (US)', pattern: '\\(?\\d{3}\\)?[-.\\s]?\\d{3}[-.\\s]?\\d{4}' },
  { label: 'Date (YYYY-MM-DD)', pattern: '\\d{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12]\\d|3[01])' },
  { label: 'IPv4 Address', pattern: '\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b' },
  { label: 'Hex Color', pattern: '#(?:[0-9a-fA-F]{3}){1,2}\\b' },
  { label: 'HTML Tag', pattern: '<([a-z][a-z0-9]*)\\b[^>]*>(.*?)</\\1>' },
  { label: 'Integer', pattern: '-?\\d+' },
  { label: 'Floating Point', pattern: '-?\\d+\\.\\d+' },
  { label: 'Whitespace Trim', pattern: '^\\s+|\\s+$' },
  { label: 'Duplicate Words', pattern: '\\b(\\w+)\\s+\\1\\b' },
  { label: 'Username', pattern: '[a-zA-Z0-9_]{3,16}' },
];

function init() {
  // Build quick ref buttons
  quickPatterns.forEach(p => {
    const btn = document.createElement('button');
    btn.className = 'ref-btn';
    btn.innerHTML = '<span class="ref-label">' + p.label + '</span><code>' + escapeHtml(p.pattern) + '</code>';
    btn.addEventListener('click', () => {
      regexInput.value = p.pattern;
      runRegex();
      regexInput.focus();
    });
    quickRefGrid.appendChild(btn);
  });

  // Flag toggles
  document.querySelectorAll('.flag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('active');
      runRegex();
    });
  });

  // Mode toggles
  btnMatch.addEventListener('click', () => setMode('match'));
  btnReplace.addEventListener('click', () => setMode('replace'));

  // Live input
  regexInput.addEventListener('input', runRegex);
  testInput.addEventListener('input', runRegex);
  testInput.addEventListener('scroll', syncScroll);
  replaceInput.addEventListener('input', runRegex);

  clearBtn.addEventListener('click', () => {
    testInput.value = '';
    runRegex();
    testInput.focus();
  });

  copyBtn.addEventListener('click', () => {
    const text = matchResults.innerText;
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      copyBtn.textContent = '✓ Copied';
      setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
    });
  });

  copyReplaceBtn.addEventListener('click', () => {
    const text = replaceOutput.textContent;
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      copyReplaceBtn.textContent = '✓ Copied';
      setTimeout(() => { copyReplaceBtn.textContent = 'Copy'; }, 1500);
    });
  });

  // Demo data
  testInput.value = 'Contact us at hello@example.com or support@company.org\nVisit https://siliconbased.dev for dev tools\nCall 555-123-4567 or (800) 555-0199';
  runRegex();
}

function setMode(mode) {
  currentMode = mode;
  btnMatch.classList.toggle('active', mode === 'match');
  btnReplace.classList.toggle('active', mode === 'replace');
  replaceBar.style.display = mode === 'replace' ? 'flex' : 'none';
  replaceOutputWrap.style.display = mode === 'replace' ? 'block' : 'none';
  runRegex();
}

function getFlags() {
  let flags = '';
  document.querySelectorAll('.flag-btn.active').forEach(btn => {
    flags += btn.dataset.flag;
  });
  return flags;
}

function syncScroll() {
  highlightLayer.scrollTop = testInput.scrollTop;
  highlightLayer.scrollLeft = testInput.scrollLeft;
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function runRegex() {
  const pattern = regexInput.value;
  const text = testInput.value;
  const flags = getFlags();

  // Reset
  regexError.style.display = 'none';
  regexError.textContent = '';
  highlightLayer.innerHTML = '';
  matchResults.innerHTML = '';
  replaceOutput.textContent = '';

  if (!pattern) {
    highlightLayer.innerHTML = escapeHtml(text);
    matchStatus.textContent = 'Matches';
    matchStatus.style.color = '#ccc';
    return;
  }

  let regex;
  try {
    regex = new RegExp(pattern, flags);
  } catch (e) {
    regexError.textContent = e.message;
    regexError.style.display = 'block';
    highlightLayer.innerHTML = escapeHtml(text);
    matchStatus.textContent = 'Invalid Pattern';
    matchStatus.style.color = '#f87171';
    return;
  }

  if (!text) {
    matchStatus.textContent = 'Matches';
    matchStatus.style.color = '#ccc';
    return;
  }

  // Find all matches
  const matches = [];
  if (flags.includes('g')) {
    let m;
    let safety = 0;
    while ((m = regex.exec(text)) !== null && safety < 10000) {
      matches.push(m);
      if (m[0].length === 0) { regex.lastIndex++; }
      safety++;
    }
  } else {
    const m = regex.exec(text);
    if (m) matches.push(m);
  }

  // Highlight layer
  if (matches.length > 0) {
    let html = '';
    let lastIndex = 0;
    matches.forEach((m, i) => {
      const start = m.index;
      const end = start + m[0].length;
      const color = matchColors[i % matchColors.length];
      html += escapeHtml(text.slice(lastIndex, start));
      html += '<mark style="background:' + color + ';border-radius:2px;color:inherit;">' + escapeHtml(text.slice(start, end)) + '</mark>';
      lastIndex = end;
    });
    html += escapeHtml(text.slice(lastIndex));
    highlightLayer.innerHTML = html;
  } else {
    highlightLayer.innerHTML = escapeHtml(text);
  }

  // Match count
  matchStatus.textContent = matches.length + ' match' + (matches.length !== 1 ? 'es' : '');
  matchStatus.style.color = matches.length > 0 ? '#4ade80' : '#f87171';

  // Match details
  if (matches.length === 0) {
    matchResults.innerHTML = '<div class="no-match">No matches found</div>';
  } else {
    let html = '';
    matches.forEach((m, i) => {
      const color = matchColors[i % matchColors.length];
      html += '<div class="match-item">';
      html += '<div class="match-header" style="border-left:3px solid ' + color.replace('40','cc') + ';">';
      html += '<span class="match-label">Match ' + (i + 1) + '</span>';
      html += '<span class="match-index">Index ' + m.index + '</span>';
      html += '</div>';
      html += '<div class="match-value"><code>' + escapeHtml(m[0]) + '</code></div>';

      // Named groups
      if (m.groups) {
        const groupNames = Object.keys(m.groups);
        if (groupNames.length > 0) {
          groupNames.forEach(name => {
            html += '<div class="match-group"><span class="group-label">' + escapeHtml(name) + '</span><code>' + escapeHtml(m.groups[name] || '') + '</code></div>';
          });
        }
      }

      // Numbered groups
      for (let g = 1; g < m.length; g++) {
        html += '<div class="match-group"><span class="group-label">Group ' + g + '</span><code>' + escapeHtml(m[g] || '') + '</code></div>';
      }

      html += '</div>';
    });
    matchResults.innerHTML = html;
  }

  // Replace mode
  if (currentMode === 'replace') {
    try {
      const replaceVal = replaceInput.value;
      const result = text.replace(regex, replaceVal);
      replaceOutput.textContent = result;
    } catch (e) {
