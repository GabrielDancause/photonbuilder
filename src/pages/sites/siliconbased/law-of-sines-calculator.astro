---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Law of Sines Calculator",
  description: "Stuck on a tricky triangle problem? Discover the missing sides and angles instantly with our free Law of Sines Calculator—you might be surprised by the...",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Law of Sines formula?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Law of Sines formula is a / sin(A) = b / sin(B) = c / sin(C). It states that the ratio of a side to the sine of its opposite angle is constant for all three sides of a triangle."
        }
      },
      {
        "@type": "Question",
        "name": "When should I use the Law of Sines?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You should use the Law of Sines when you know two angles and one side (AAS or ASA), or two sides and a non-included angle (SSA) of a triangle."
        }
      },
      {
        "@type": "Question",
        "name": "What is the ambiguous case?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The ambiguous case occurs in the Side-Side-Angle (SSA) scenario. Depending on the given lengths and angle, there might be no possible triangle, exactly one triangle, or two completely different valid triangles."
        }
      },
      {
        "@type": "Question",
        "name": "Does this work for right-angled triangles?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the Law of Sines works for all triangles, including right triangles. However, for right triangles, standard SOH CAH TOA trigonometric ratios are usually faster to use."
        }
      },
      {
        "@type": "Question",
        "name": "Why am I getting a 'No Solution' error?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 'No Solution' error happens when the side opposite your given angle is too short to reach the base of the triangle. Geometrically, such a triangle is impossible to construct."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Law of Sines Calculator",
    "description": "Stuck on a tricky triangle problem? Discover the missing sides and angles instantly with our free Law of Sines Calculator—you might be surprised by the ambiguous case!",
    "datePublished": "2026-03-15",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased"
    }
  }
];
---
<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/law-of-sines-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Law of Sines Calculator</h1>
      <p class="subtitle">Solve any oblique triangle instantly by entering 3 known values.</p>
    </div>

    <div class="calculator-container">

      <p style="margin-bottom: 1rem; color: var(--text-secondary); text-align: center;">Enter exactly 3 values (must include at least 1 side). Angles are in degrees.</p>

      <div class="triangle-inputs">
        <div class="input-col">
          <h3>Sides</h3>
          <div class="form-group">
            <label for="side-a">Side a</label>
            <input type="number" id="side-a" step="any" min="0" />
          </div>
          <div class="form-group">
            <label for="side-b">Side b</label>
            <input type="number" id="side-b" step="any" min="0" />
          </div>
          <div class="form-group">
            <label for="side-c">Side c</label>
            <input type="number" id="side-c" step="any" min="0" />
          </div>
        </div>
        <div class="input-col">
          <h3>Angles (Degrees)</h3>
          <div class="form-group">
            <label for="angle-A">Angle A</label>
            <input type="number" id="angle-A" step="any" min="0" max="180" />
          </div>
          <div class="form-group">
            <label for="angle-B">Angle B</label>
            <input type="number" id="angle-B" step="any" min="0" max="180" />
          </div>
          <div class="form-group">
            <label for="angle-C">Angle C</label>
            <input type="number" id="angle-C" step="any" min="0" max="180" />
          </div>
        </div>
      </div>

      <div id="error-message" class="error-msg" style="display:none; color: #ef4444; margin: 1rem 0; text-align: center; font-weight: 600;"></div>

      <div id="results-container" style="display:none;">
        <div class="result-card">
          <div style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 1rem;">Calculation Results</div>
          <div class="grid-results" id="solution-1">
            <!-- Populated via JS -->
          </div>
        </div>

        <div id="solution-2-container" class="result-card" style="display:none; margin-top: 1rem;">
          <div style="font-size: 1.1rem; color: #f59e0b; margin-bottom: 1rem;">Alternative Solution (Ambiguous Case)</div>
          <div class="grid-results" id="solution-2">
            <!-- Populated via JS -->
          </div>
        </div>
      </div>
      <div style="text-align:center; margin-top:1rem;">
         <button id="clear-btn" type="button" style="background:var(--bg-color); color:var(--text-primary); border:1px solid var(--border-color);">Clear Inputs</button>
      </div>

    </div>

    <div class="explainer">

      <p>Trigonometry is a branch of mathematics that explores the relationships between the side lengths and angles of triangles. While right-angled triangles are relatively straightforward to solve using basic sine, cosine, and tangent ratios, non-right triangles (oblique triangles) require more advanced tools. One of the most powerful and fundamental theorems for solving these oblique triangles is the Law of Sines. This calculator is designed to instantly apply the Law of Sines to find missing sides and angles, but understanding the underlying methodology and geometry is crucial for mastering trigonometry.</p>

      <h3>Understanding the Law of Sines Formula</h3>
      <p>The Law of Sines establishes a simple yet profound relationship: the ratio of the length of a side of a triangle to the sine of the angle opposite that side is the same for all three sides of the triangle. If we denote the angles of a triangle as A, B, and C, and the lengths of the corresponding opposite sides as a, b, and c, the formula is expressed as:</p>
      <p><strong>a / sin(A) = b / sin(B) = c / sin(C)</strong></p>
      <p>This elegant equation means that if you know any two angles and one side (AAS or ASA), or two sides and an angle opposite one of them (SSA), you can calculate the remaining unknown values of the triangle. To use the formula, you simply isolate the unknown variable. For example, if you know angles A and B, and side a, you can find side b by rearranging the equation to: b = (a * sin(B)) / sin(A). Our calculator handles these algebraic manipulations automatically in real-time as you enter the known values.</p>

      <h3>When to Use the Law of Sines</h3>
      <p>In the study of geometry and trigonometry, triangle problems are typically classified by the known parts given to you. The Law of Sines is applicable in specific scenarios. The first scenario is AAS (Angle-Angle-Side), where you know two angles and a non-included side. Because the sum of angles in a triangle is always 180 degrees, finding the third angle is a simple subtraction, and you can immediately apply the Law of Sines to find the remaining sides.</p>
      <p>The second scenario is ASA (Angle-Side-Angle), where you know two angles and the included side. Similar to AAS, you first calculate the third angle, and then proceed with the Law of Sines. The third and most complex scenario is SSA (Side-Side-Angle), where you are given two sides and an angle not included between them. This specific scenario is unique because it doesn't always guarantee a single unique triangle, leading to what mathematicians call the ambiguous case.</p>

      <h3>The Ambiguous Case (SSA)</h3>
      <p>The ambiguous case is a notorious stumbling block for many geometry students. When you are given two sides (let's say a and b) and a non-included angle (Angle A), there are three possible outcomes: no solution exists, exactly one unique triangle exists, or two different valid triangles exist. How does this happen? It all comes down to the geometry of the situation and the value of the sine function.</p>
      <p>If the side opposite the given angle (side a) is shorter than the altitude of the triangle drawn from the other given side (h = b * sin(A)), the side cannot reach the base, meaning no triangle can be formed. If side a is exactly equal to the altitude, it forms a perfect right angle, resulting in exactly one right triangle. If side a is longer than the altitude but shorter than side b, the side can swing like a pendulum and intersect the base in two different locations, creating two distinctly different triangles—one acute and one obtuse. Finally, if side a is longer than side b, only one valid triangle can be formed. Our interactive calculator accounts for this by checking the validity of the inputs and warning you if an impossible triangle is entered.</p>

      <h3>Real-World Applications</h3>
      <p>While solving triangles might seem like a purely academic exercise, the Law of Sines has vital real-world applications across various fields. In surveying and cartography, for instance, terrain is often mapped using a technique called triangulation. Surveyors measure a baseline distance between two points and then measure the angles from those points to a distant, inaccessible landmark. Using the Law of Sines, they can accurately calculate the distance to the landmark without ever physically measuring it.</p>
      <p>Navigation is another critical area where these trigonometric principles are applied. Pilots and sailors use vector addition to calculate their true course, taking into account wind speed or water currents. These velocity vectors form triangles, and the Law of Sines is frequently used to determine the correct heading angle required to reach a destination. Similarly, in physics and engineering, the resolution of forces into components often relies on oblique triangle calculations.</p>

      <h3>Tips for Avoiding Common Mistakes</h3>
      <p>When working with trigonometric equations, errors often arise from simple oversights rather than complex misunderstandings. The most common mistake is having your calculator set to radians instead of degrees (or vice versa). Our web tool explicitly expects angles in degrees to align with standard high school geometry conventions. Another frequent error occurs during the ambiguous case when solving for an angle using the inverse sine function (arcsin). Calculators will only return the acute angle solution; you must manually subtract this value from 180 degrees to find the potential obtuse angle solution.</p>
      <p>Understanding these mathematical foundations transforms a simple tool into a powerful asset. Whether you are an engineer calculating load vectors, a student preparing for a geometry final, or someone who just finished checking their exact age with our <a href="/birthday-calculator">Birthday Calculator</a> and wanted a mental challenge, the Law of Sines is an indispensable part of your mathematical toolkit. By visualizing the relationships between sides and angles, you can decode the geometry of the physical world.</p>

    </div>

    <section class="faq-section">

      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is the Law of Sines formula?</summary>
        <p>The Law of Sines formula is a / sin(A) = b / sin(B) = c / sin(C). It states that the ratio of a side to the sine of its opposite angle is constant for all three sides of a triangle.</p>
      </details>
      <details>
        <summary>When should I use the Law of Sines?</summary>
        <p>You should use the Law of Sines when you know two angles and one side (AAS or ASA), or two sides and a non-included angle (SSA) of a triangle.</p>
      </details>
      <details>
        <summary>What is the ambiguous case?</summary>
        <p>The ambiguous case occurs in the Side-Side-Angle (SSA) scenario. Depending on the given lengths and angle, there might be no possible triangle, exactly one triangle, or two completely different valid triangles.</p>
      </details>
      <details>
        <summary>Does this work for right-angled triangles?</summary>
        <p>Yes, the Law of Sines works for all triangles, including right triangles. However, for right triangles, standard SOH CAH TOA trigonometric ratios are usually faster to use.</p>
      </details>
      <details>
        <summary>Why am I getting a 'No Solution' error?</summary>
        <p>A 'No Solution' error happens when the side opposite your given angle is too short to reach the base of the triangle. Geometrically, such a triangle is impossible to construct.</p>
      </details>

    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = {
        a: document.getElementById('side-a'),
        b: document.getElementById('side-b'),
        c: document.getElementById('side-c'),
        A: document.getElementById('angle-A'),
        B: document.getElementById('angle-B'),
        C: document.getElementById('angle-C')
      };

      const resultsContainer = document.getElementById('results-container');
      const errorMsg = document.getElementById('error-message');
      const solution1El = document.getElementById('solution-1');
      const solution2Container = document.getElementById('solution-2-container');
      const solution2El = document.getElementById('solution-2');
      const clearBtn = document.getElementById('clear-btn');

      const toRad = deg => deg * Math.PI / 180;
      const toDeg = rad => rad * 180 / Math.PI;

      function renderSolution(sol, container) {
        container.innerHTML = `
          <div class="small-card"><div class="card-label">Side a</div><div class="card-value">${sol.a.toFixed(4)}</div></div>
          <div class="small-card"><div class="card-label">Side b</div><div class="card-value">${sol.b.toFixed(4)}</div></div>
          <div class="small-card"><div class="card-label">Side c</div><div class="card-value">${sol.c.toFixed(4)}</div></div>
          <div class="small-card"><div class="card-label">Angle A</div><div class="card-value">${sol.A.toFixed(4)}&deg;</div></div>
          <div class="small-card"><div class="card-label">Angle B</div><div class="card-value">${sol.B.toFixed(4)}&deg;</div></div>
          <div class="small-card"><div class="card-label">Angle C</div><div class="card-value">${sol.C.toFixed(4)}&deg;</div></div>
        `;
      }

      function solveTriangle() {
        errorMsg.style.display = 'none';
        resultsContainer.style.display = 'none';
        solution2Container.style.display = 'none';

        let vals = {};
        let filledCount = 0;
        let sideCount = 0;

        for (const [key, el] of Object.entries(inputs)) {
          if (el.value.trim() !== '') {
            const num = parseFloat(el.value);
            if (isNaN(num) || num <= 0) {
              errorMsg.textContent = "All entered values must be positive numbers.";
              errorMsg.style.display = 'block';
              return;
            }
            vals[key] = num;
            filledCount++;
            if (['a', 'b', 'c'].includes(key)) sideCount++;
          }
        }

        if (filledCount < 3) return; // not enough data
        if (filledCount > 3) {
          errorMsg.textContent = "Please enter exactly 3 values.";
          errorMsg.style.display = 'block';
          return;
        }
        if (sideCount === 0) {
          errorMsg.textContent = "You must provide at least one side length to determine the scale of the triangle.";
          errorMsg.style.display = 'block';
          return;
        }

        // If 3 angles entered (wait, sideCount === 0 caught this)
        // Check if sum of provided angles is >= 180
        let angleSum = 0;
        if (vals.A) angleSum += vals.A;
        if (vals.B) angleSum += vals.B;
        if (vals.C) angleSum += vals.C;
        if (angleSum >= 180) {
           errorMsg.textContent = "The sum of the known angles must be less than 180 degrees.";
           errorMsg.style.display = 'block';
           return;
        }

        // Attempt to solve
        // We will loop and try to deduce missing values until all are found, or we hit SSA ambiguity
        let knowns = { ...vals };
        let solutions = [knowns];

        let pass = 0;
        while (pass < 5) {
          pass++;
          let newSolutions = [];
          let changedAny = false;

          for (let sol of solutions) {
            // Deduction 1: 3rd angle if 2 are known
            let angCount = (sol.A?1:0) + (sol.B?1:0) + (sol.C?1:0);
            if (angCount === 2) {
               if (!sol.A) sol.A = 180 - sol.B - sol.C;
               else if (!sol.B) sol.B = 180 - sol.A - sol.C;
               else if (!sol.C) sol.C = 180 - sol.A - sol.B;
               if (sol.A <= 0 || sol.B <= 0 || sol.C <= 0) {
                 continue; // invalid
               }
               changedAny = true;
            }

            // Deduction 2: Law of Sines ratio if possible
            let ratio = null;
            if (sol.a && sol.A) ratio = sol.a / Math.sin(toRad(sol.A));
            else if (sol.b && sol.B) ratio = sol.b / Math.sin(toRad(sol.B));
            else if (sol.c && sol.C) ratio = sol.c / Math.sin(toRad(sol.C));

            if (ratio) {
              // If we have a ratio, we can find missing sides if angle is known
              const pairs = [['b', 'B'], ['c', 'C'], ['a', 'A']];
              for (let [side, ang] of pairs) {
                if (sol[ang] && !sol[side]) {
                  sol[side] = ratio * Math.sin(toRad(sol[ang]));
                  changedAny = true;
                }
              }

              // Find missing angles if side is known
              let tempSols = [sol];
              for (let [side, ang] of pairs) {
                if (sol[side] && !sol[ang]) {
                  let sinAng = sol[side] / ratio;
                  if (sinAng > 1.0000001) {
                    // No solution
                    tempSols = [];
                    break;
                  } else if (sinAng > 1) {
                    sinAng = 1;
                  }

                  let newTemp = [];
                  for (let s of tempSols) {
                    let ang1 = toDeg(Math.asin(sinAng));
                    s[ang] = ang1;
                    changedAny = true;
                    newTemp.push({...s});

                    // Check ambiguous case
                    let ang2 = 180 - ang1;
                    // Validity check for obtuse angle: it must leave room for the remaining angles
                    let sumOtherAngles = 0;
                    if (s.A && ang !== 'A') sumOtherAngles += s.A;
                    if (s.B && ang !== 'B') sumOtherAngles += s.B;
                    if (s.C && ang !== 'C') sumOtherAngles += s.C;

                    if (ang2 > ang1 && ang2 > 0 && sumOtherAngles + ang2 < 180) {
                       let s2 = {...s};
                       s2[ang] = ang2;
                       newTemp.push(s2);
                    }
                  }
                  tempSols = newTemp;
                }
              }
              newSolutions.push(...tempSols);
            } else {
               // If no ratio, we might have 3 sides or SAS. But prompt says "Law of Sines", standard case.
               // Law of Cosines might be needed if SSS or SAS. We will just inform user.
               newSolutions.push(sol);
            }
          }

          if (newSolutions.length > 0) solutions = newSolutions;
          if (!changedAny) break;
        }

        // Filter complete valid solutions
        let valid = [];
        for (let s of solutions) {
           if (s.a && s.b && s.c && s.A && s.B && s.C) {
              let sum = s.A + s.B + s.C;
              if (Math.abs(sum - 180) < 0.1) valid.push(s);
           }
        }

        // Remove duplicates
        let unique = [];
        for (let v of valid) {
           if (!unique.some(u => Math.abs(u.a-v.a) < 0.001 && Math.abs(u.A-v.A) < 0.001)) {
             unique.push(v);
           }
        }

        if (unique.length === 0) {
          // Check if we didn't solve because we need law of cosines (SAS or SSS)
          if (sideCount === 3 || (sideCount === 2 && filledCount === 3)) {
             // Just to be sure, check if it was SSS or SAS
             let hasRatio = (vals.a && vals.A) || (vals.b && vals.B) || (vals.c && vals.C);
             if (!hasRatio) {
                errorMsg.textContent = "This combination (SSS or SAS) requires the Law of Cosines to solve first. Our Law of Sines calculator handles AAS, ASA, and SSA cases.";
                errorMsg.style.display = 'block';
                return;
             }
          }
          errorMsg.textContent = "No valid triangle exists for these inputs.";
          errorMsg.style.display = 'block';
        } else {
          resultsContainer.style.display = 'block';
          renderSolution(unique[0], solution1El);
          if (unique.length > 1) {
             solution2Container.style.display = 'block';
             renderSolution(unique[1], solution2El);
          }
        }
      }

      for (let el of Object.values(inputs)) {
         el.addEventListener('input', solveTriangle);
      }

      clearBtn.addEventListener('click', () => {
         for (let el of Object.values(inputs)) el.value = '';
         resultsContainer.style.display = 'none';
         errorMsg.style.display = 'none';
      });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .triangle-inputs { display: flex; gap: 2rem; justify-content: space-between; margin-bottom: 1.5rem; }
    .input-col { flex: 1; }
    .input-col h3 { font-size: 1.2rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }

    .form-group { margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between; }
    .form-group label { font-weight: 600; width: 30%; }
    .form-group input { width: 65%; }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    button { padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; text-align: center; }

    .grid-results { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .small-card { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem; text-align: center; }
    .card-label { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem; }
    .card-value { font-size: 1.2rem; font-weight: 700; color: var(--text-primary); }

    .explainer { margin: 3rem 0; line-height: 1.7; }
    .explainer h3 { margin: 2rem 0 1rem; font-size: 1.5rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }

    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; }

    @media (max-width: 600px) {
      .triangle-inputs { flex-direction: column; gap: 1rem; }
      .grid-results { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

</SiteLayout>
