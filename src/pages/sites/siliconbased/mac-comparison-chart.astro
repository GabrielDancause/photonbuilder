const USECASES = [
  {id:'student', label:'Students', icon:'🎓', recs:['macbook-air','macbook-neo'],
    text:'The <strong>MacBook Air</strong> ($1,099) is the best Mac for students — fast, fanless, all-day battery, and light enough for any backpack. On a tighter budget, the <strong>MacBook Neo</strong> ($899) handles notes, browsing, and schoolwork with ease.'},
