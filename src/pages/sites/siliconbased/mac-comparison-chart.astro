const FAQS = [
  {q:'What Macs does Apple currently sell in 2026?', a:'As of March 2026, Apple sells six Mac models: iMac (M4), Mac mini (M4/M4 Pro), Mac Studio (M4 Max/M3 Ultra), MacBook Neo (entry-level), MacBook Air (M4), and MacBook Pro (M4 Pro/M4 Max in 14″ and 16″ sizes). The Mac Pro was discontinued in March 2026.'},
  {q:'Which Mac is best for students?', a:'The MacBook Air M4 starting at $1,099 is the best Mac for most students — it offers excellent performance, all-day battery life, and a thin, light design. The MacBook Neo at $899 is a great budget alternative if you need basic computing for notes, browsing, and light coursework.'},
  {q:'Is the Mac Pro still available?', a:'No. Apple discontinued the Mac Pro in March 2026. The Mac Studio with M3 Ultra is now Apple\'s most powerful desktop Mac, offering up to 192 GB of unified memory and 80 GPU cores for professional 3D, ML, and video production workloads.'},
  {q:'What is the difference between M4, M4 Pro, M4 Max, and M3 Ultra?', a:'The M4 is Apple\'s base chip with 10 CPU and 10 GPU cores. The M4 Pro adds up to 14 CPU and 20 GPU cores with more memory bandwidth. The M4 Max doubles that to up to 16 CPU and 40 GPU cores with up to 128 GB unified memory. The M3 Ultra (used in Mac Studio) fuses two M3 Max dies for up to 32 CPU and 80 GPU cores with up to 192 GB unified memory.'},
  {q:'Should I buy a Mac mini or an iMac?', a:'Buy the Mac mini ($599) if you already have a monitor, keyboard, and mouse — it\'s Apple\'s most affordable Mac and offers M4 or M4 Pro chip options. Buy the iMac ($1,299) if you want an all-in-one with a beautiful 24″ 4.5K Retina display, built-in speakers, camera, and minimal desk clutter.'}
];

const SPEC_ROWS = [
  {label:'Starting Price', key:'basePrice', fmt:v=>'$'+v.toLocaleString()},
  {label:'Chip Options', key:'chips', fmt:v=>v.join(', ')},
  {label:'CPU Cores', key:'cpu', fmt:v=>Object.values(v).join(' · ')},
  {label:'GPU Cores', key:'gpu', fmt:v=>Object.values(v).join(' · ')},
  {label:'Unified Memory', key:'ram', fmt:v=>{const s=new Set();Object.values(v).forEach(a=>a.forEach(x=>s.add(x)));return[...s].join(', ')}},
  {label:'Storage Options', key:'storage', fmt:v=>{const s=new Set();Object.values(v).forEach(a=>a.forEach(x=>s.add(x)));return[...s].join(', ')}},
  {label:'Display', key:'display'},
  {label:'Ports', key:'ports'},
  {label:'Weight', key:'weight'},
  {label:'Battery', key:'battery'},
  {label:'Year Released', key:'year'}
];

const TYPE_ICONS = {laptop:'💻', desktop:'🖥️'};

/* ---------- Lineup Grid ---------- */
function renderLineup(){
  const g = document.getElementById('lineupGrid');
  g.innerHTML = MACS.map(m=>`
    <button class="lineup-card" data-id="${m.id}" aria-label="View ${m.name} specs">
      <div class="lc-icon">${TYPE_ICONS[m.type]}</div>
      <div class="lc-name">${m.name}</div>
      <div class="lc-chip">${m.chips.join(' / ')}</div>
      <div class="lc-price">From $${m.basePrice.toLocaleString()}</div>
      <div class="lc-tag">${m.tagline}</div>
    </button>
  `).join('');
  g.querySelectorAll('.lineup-card').forEach(c=>{
    c.addEventListener('click',()=>{
      const id = c.dataset.id;
      document.getElementById('pick1').value = id;
      document.getElementById('pick1').dispatchEvent(new Event('change'));
      document.getElementById('compareWrap').scrollIntoView({behavior:'smooth',block:'start'});
    });
  });
}

/* ---------- Comparison Table ---------- */
function populatePickers(){
  ['pick1','pick2','pick3'].forEach(sid=>{
    const sel = document.getElementById(sid);
    MACS.forEach(m=>{
      const o = document.createElement('option');
      o.value = m.id; o.textContent = m.name;
      sel.appendChild(o);
    });
    sel.addEventListener('change', renderComparison);
  });
}

function renderComparison(){
  const ids = ['pick1','pick2','pick3'].map(s=>document.getElementById(s).value).filter(Boolean);
  const wrap = document.getElementById('compareWrap');
  if(ids.length < 2){
    wrap.innerHTML = '<p class="placeholder-msg">Select at least two Macs above to see the comparison table.</p>';
    return;
  }
  const macs = ids.map(id=>MACS.find(m=>m.id===id)).filter(Boolean);
  const unique = [...new Set(macs.map(m=>m.id))];
  if(unique.length < 2){
    wrap.innerHTML = '<p class="placeholder-msg">Please select different Macs to compare.</p>';
    return;
  }

  let html = '<table class="compare-table"><thead><tr><th>Spec</th>';
  macs.forEach(m=>{ html += '<th>'+m.name+'</th>'; });
  html += '</tr></thead><tbody>';

  SPEC_ROWS.forEach(row=>{
    const vals = macs.map(m=>{
      const v = m[row.key];
      return row.fmt ? row.fmt(v) : String(v);
    });
    const allSame = vals.every(v=>v===vals[0]);
    html += '<tr'+(allSame?'':' class="diff-row"')+'><td class="spec-label">'+row.label+'</td>';
    vals.forEach(v=>{ html += '<td>'+v+'</td>'; });
    html += '</tr>';
  });

  html += '</tbody></table>';
  wrap.innerHTML = html;
}

/* ---------- Use Case Guide ---------- */
function renderUseCases(){
  const grid = document.getElementById('usecaseGrid');
  grid.innerHTML = USECASES.map(u=>`
    <button class="uc-card" data-uc="${u.id}">
      <span class="uc-icon">${u.icon}</span>
      <span class="uc-label">${u.label}</span>
    </button>
  `).join('');
  grid.querySelectorAll('.uc-card').forEach(btn=>{
    btn.addEventListener('click',()=>{
      grid.querySelectorAll('.uc-card').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      const uc = USECASES.find(u=>u.id===btn.dataset.uc);
      const res = document.getElementById('usecaseResult');
      res.innerHTML = '<div class="uc-rec">'+uc.text+'</div>';
      /* highlight lineup cards */
      document.querySelectorAll('.lineup-card').forEach(c=>{
        c.classList.toggle('uc-highlight', uc.recs.includes(c.dataset.id));
      });
    });
  });
}

/* ---------- Price Configurator ---------- */
function initConfigurator(){
  const mSel = document.getElementById('cfgModel');
  const cSel = document.getElementById('cfgChip');
  const rSel = document.getElementById('cfgRam');
  const sSel = document.getElementById('cfgStorage');
  const priceEl = document.getElementById('cfgPrice');

  mSel.innerHTML = '<option value="">Choose a Mac…</option>' + MACS.map(m=>'<option value="'+m.id+'">'+m.name+'</option>').join('');

  function getM(){ return MACS.find(m=>m.id===mSel.value); }

  function fillChips(){
    const m = getM();
    cSel.innerHTML = '<option value="">Choose chip…</option>';
    rSel.innerHTML = '<option value="">Choose memory…</option>';
    sSel.innerHTML = '<option value="">Choose storage…</option>';
    priceEl.textContent = 'Select options to see price';
    if(!m) return;
    m.chips.forEach(c=>{ cSel.innerHTML += '<option value="'+c+'">'+c+'</option>'; });
  }

  function fillRam(){
    const m = getM(); const chip = cSel.value;
    rSel.innerHTML = '<option value="">Choose memory…</option>';
    sSel.innerHTML = '<option value="">Choose storage…</option>';
    priceEl.textContent = 'Select options to see price';
    if(!m||!chip) return;
    (m.ram[chip]||[]).forEach(r=>{ rSel.innerHTML += '<option value="'+r+'">'+r+'</option>'; });
  }

  function fillStorage(){
    const m = getM(); const chip = cSel.value;
    sSel.innerHTML = '<option value="">Choose storage…</option>';
    priceEl.textContent = 'Select options to see price';
    if(!m||!chip) return;
    (m.storage[chip]||[]).forEach(s=>{ sSel.innerHTML += '<option value="'+s+'">'+s+'</option>'; });
  }

  function calcPrice(){
    const m = getM();
    if(!m||!cSel.value||!rSel.value||!sSel.value){ priceEl.textContent='Select all options to see price'; return; }
    const key = cSel.value+'-'+rSel.value+'-'+sSel.value;
    const p = m.pricing[key];
    if(p !== undefined){
      priceEl.innerHTML = '<span class="cfg-model-name">'+m.name+' — '+cSel.value+'</span><span class="cfg-total">$'+p.toLocaleString()+'</span>';
    } else {
      priceEl.textContent = 'Configuration not available';
    }
  }

  mSel.addEventListener('change',fillChips);
  cSel.addEventListener('change',()=>{ fillRam(); fillStorage(); });
  rSel.addEventListener('change',()=>{ fillStorage(); calcPrice(); });
  sSel.addEventListener('change', calcPrice);
}

/* ---------- FAQ ---------- */
function renderFAQ(){
  const list = document.getElementById('faqList');
  list.innerHTML = FAQS.map((f,i)=>`
    <details class="faq-item"${i===0?' open':''}>
      <summary>${f.q}</summary>
      <div class="faq-answer">${f.a}</div>
    </details>
  `).join('');
}

/* ---------- Init ---------- */
renderLineup();
populatePickers();
renderUseCases();
initConfigurator();
renderFAQ();

})();
</script>

