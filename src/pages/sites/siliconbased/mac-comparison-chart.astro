---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Mac Comparison Chart 2026",
      "url": "https://siliconbased.dev/mac-comparison-chart",
      "description": "Compare every Apple Mac side by side — specs, prices, and recommendations for 2026.",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "author": { "@type": "Organization", "name": "GAB Ventures", "url": "https://gab.ae" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What Macs does Apple currently sell in 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "As of March 2026, Apple sells six Mac models: iMac (M4), Mac mini (M4/M4 Pro), Mac Studio (M4 Max/M3 Ultra), MacBook Neo (entry-level), MacBook Air (M4), and MacBook Pro (M4 Pro/M4 Max in 14\" and 16\" sizes). The Mac Pro was discontinued in March 2026."
          }
        },
        {
          "@type": "Question",
          "name": "Which Mac is best for students?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The MacBook Air M4 starting at $1,099 is the best Mac for most students — it offers excellent performance, all-day battery life, and a thin, light design. The MacBook Neo at $899 is a great budget alternative if you need basic computing for notes, browsing, and light coursework."
          }
        },
        {
          "@type": "Question",
          "name": "Is the Mac Pro still available?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Apple discontinued the Mac Pro in March 2026. The Mac Studio with M3 Ultra is now Apple's most powerful desktop Mac, offering up to 192 GB of unified memory and 80 GPU cores for professional 3D, ML, and video production workloads."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between M4, M4 Pro, M4 Max, and M3 Ultra?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The M4 is Apple's base chip with 10 CPU and 10 GPU cores. The M4 Pro adds up to 14 CPU and 20 GPU cores with more memory bandwidth. The M4 Max doubles that to up to 16 CPU and 40 GPU cores with up to 128 GB unified memory. The M3 Ultra (used in Mac Studio) fuses two M3 Max dies for up to 32 CPU and 80 GPU cores with up to 192 GB unified memory."
          }
        },
        {
          "@type": "Question",
          "name": "Should I buy a Mac mini or an iMac?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Buy the Mac mini ($599) if you already have a monitor, keyboard, and mouse — it's Apple's most affordable Mac and offers M4 or M4 Pro chip options. Buy the iMac ($1,299) if you want an all-in-one with a beautiful 24\" 4.5K Retina display, built-in speakers, camera, and minimal desk clutter."
          }
        }
      ]
    }
  ]
};

const htmlBody = `
<div class="page-content">

  <div class="disco-banner">
    <span class="disco-icon">⚠️</span>
    <div>
      <strong>Mac Pro Discontinued — March 2026</strong>
      <p>Apple has officially discontinued the Mac Pro. The Mac Studio with M3 Ultra is now Apple's most powerful desktop. Existing Mac Pro units may still be available from third-party retailers while supplies last.</p>
    </div>
  </div>

  <div class="hero">
    <h1>Mac Comparison Chart 2026</h1>
    <p class="hero-sub">Compare every Apple Mac side by side. Pick 2–3 Macs, compare specs, and find the right one for you.</p>
  </div>

  <!-- SECTION: Mac Lineup Grid -->
  <section class="section">
    <h2>The 2026 Mac Lineup</h2>
    <p class="section-sub">Click any Mac to view full specs below.</p>
    <div class="lineup-grid" id="lineupGrid"></div>
  </section>

  <!-- SECTION: Comparison Picker -->
  <section class="section">
    <h2>Compare Macs Side by Side</h2>
    <p class="section-sub">Select 2 or 3 Macs to compare their specs.</p>
    <div class="picker-row" id="pickerRow">
      <div class="picker-slot">
        <label>Mac 1</label>
        <select id="pick1" class="picker-select"><option value="">Choose a Mac…</option></select>
      </div>
      <div class="picker-slot">
        <label>Mac 2</label>
        <select id="pick2" class="picker-select"><option value="">Choose a Mac…</option></select>
      </div>
      <div class="picker-slot">
        <label>Mac 3 <span class="opt-label">(optional)</span></label>
        <select id="pick3" class="picker-select"><option value="">Choose a Mac…</option></select>
      </div>
    </div>
    <div class="compare-table-wrap" id="compareWrap">
      <p class="placeholder-msg">Select at least two Macs above to see the comparison table.</p>
    </div>
  </section>

  <!-- SECTION: Use Case Guide -->
  <section class="section">
    <h2>Which Mac Should You Buy?</h2>
    <p class="section-sub">Click a use case to see our recommendation.</p>
    <div class="usecase-grid" id="usecaseGrid"></div>
    <div class="usecase-result" id="usecaseResult"></div>
  </section>

  <!-- SECTION: Price Configurator -->
  <section class="section">
    <h2>Price Configurator</h2>
    <p class="section-sub">Select a Mac, chip, memory, and storage to see the configured price.</p>
    <div class="config-row">
      <div class="config-group">
        <label>Model</label>
        <select id="cfgModel" class="picker-select"></select>
      </div>
      <div class="config-group">
        <label>Chip</label>
        <select id="cfgChip" class="picker-select"></select>
      </div>
      <div class="config-group">
        <label>Memory</label>
        <select id="cfgRam" class="picker-select"></select>
      </div>
      <div class="config-group">
        <label>Storage</label>
        <select id="cfgStorage" class="picker-select"></select>
      </div>
    </div>
    <div class="config-price" id="cfgPrice">Select a model to begin</div>
  </section>

  <!-- SECTION: FAQ -->
  <section class="section">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list" id="faqList"></div>
  </section>

</div>
`;

export const meta = {
  title: "Mac Comparison Chart 2026: Every Apple Mac Compared",
  description: "Compare every 2026 Apple Mac side by side — iMac, Mac mini, Mac Studio, MacBook Air, MacBook Pro, and MacBook Neo. Specs, prices, and buying recommendations.",
  category: "tool",
  published: "2026-03-29",
};
