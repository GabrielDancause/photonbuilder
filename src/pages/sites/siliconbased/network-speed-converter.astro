---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Network Speed Unit Converter — Convert Mbps, Gbps, MB/s & More",
      "url": "https://siliconbased.dev/network-speed-converter",
      "description": "Free network speed unit converter. Convert between bps, Kbps, Mbps, Gbps, Tbps, B/s, KB/s, MB/s, GB/s instantly. Calculate download times and compare internet speeds.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the difference between Mbps and MB/s?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Mbps (megabits per second) measures network speed in bits, while MB/s (megabytes per second) measures data transfer in bytes. Since 1 byte equals 8 bits, you divide Mbps by 8 to get MB/s. For example, a 100 Mbps connection transfers data at 12.5 MB/s."
          }
        },
        {
          "@type": "Question",
          "name": "How long does it take to download a 1 GB file?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Download time depends on your connection speed. At 10 Mbps it takes about 13 minutes and 20 seconds, at 100 Mbps about 1 minute and 20 seconds, at 1 Gbps about 8 seconds, and at 10 Gbps under 1 second. Real-world speeds may vary due to network overhead and congestion."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my download speed slower than my internet plan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ISPs advertise speeds in megabits per second (Mbps), but browsers and download managers show megabytes per second (MB/s). A 100 Mbps plan downloads at about 12.5 MB/s maximum. Additionally, network overhead, Wi-Fi interference, server limits, and congestion can reduce actual throughput below the advertised rate."
          }
        },
        {
          "@type": "Question",
          "name": "What internet speed do I need for streaming 4K video?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Streaming 4K video typically requires at least 25 Mbps for a single stream. Netflix recommends 15 Mbps minimum for 4K, while YouTube suggests 20 Mbps. If multiple devices are streaming simultaneously, you should multiply accordingly — a household with 3 simultaneous 4K streams needs at least 75 Mbps."
          }
        },
        {
          "@type": "Question",
          "name": "Is my data safe when using this converter?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. All calculations happen entirely in your browser using JavaScript. No data is sent to any server. Your inputs never leave your device."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Network Speed Unit Converter — Convert Mbps, Gbps, MB/s & More",
      "description": "Free network speed unit converter with instant conversion, download time calculator, and internet speed reference table.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>Network Speed Converter</h1>
  <p>Convert between network speed and data transfer units instantly. Calculate download times and compare internet speeds — all in your browser.</p>
</div>

<div class="main">

  <!-- Speed Converter -->
  <div class="converter-section">
    <div class="input-header">
      <div class="header-title">Speed Unit Converter</div>
    </div>
    <div class="converter-input-row">
      <input type="number" id="speedValue" class="speed-input" placeholder="Enter value..." value="100" min="0" step="any" />
      <select id="speedUnit" class="speed-select">
        <option value="bps">bps (bits/s)</option>
        <option value="Kbps">Kbps (kilobits/s)</option>
        <option value="Mbps" selected>Mbps (megabits/s)</option>
        <option value="Gbps">Gbps (gigabits/s)</option>
        <option value="Tbps">Tbps (terabits/s)</option>
        <option value="Bs">B/s (bytes/s)</option>
        <option value="KBs">KB/s (kilobytes/s)</option>
        <option value="MBs">MB/s (megabytes/s)</option>
        <option value="GBs">GB/s (gigabytes/s)</option>
      </select>
    </div>
    <div class="results-grid" id="resultsGrid"></div>
  </div>

  <!-- Download Time Calculator -->
  <div class="download-section">
    <div class="input-header">
      <div class="header-title">Download Time Calculator</div>
    </div>
    <p class="section-desc">Enter a file size and connection speed to calculate how long the download will take.</p>
    <div class="download-input-row">
      <div class="dl-field">
        <label class="dl-label">File Size</label>
        <div class="dl-input-pair">
          <input type="number" id="fileSize" class="speed-input" placeholder="Size..." value="4.7" min="0" step="any" />
          <select id="fileSizeUnit" class="speed-select">
            <option value="B">Bytes</option>
            <option value="KB">KB</option>
            <option value="MB">MB</option>
            <option value="GB" selected>GB</option>
            <option value="TB">TB</option>
          </select>
        </div>
      </div>
      <div class="dl-field">
        <label class="dl-label">Connection Speed</label>
        <div class="dl-input-pair">
          <input type="number" id="dlSpeed" class="speed-input" placeholder="Speed..." value="100" min="0" step="any" />
          <select id="dlSpeedUnit" class="speed-select">
            <option value="bps">bps</option>
            <option value="Kbps">Kbps</option>
            <option value="Mbps" selected>Mbps</option>
            <option value="Gbps">Gbps</option>
            <option value="Tbps">Tbps</option>
            <option value="Bs">B/s</option>
            <option value="KBs">KB/s</option>
            <option value="MBs">MB/s</option>
            <option value="GBs">GB/s</option>
          </select>
        </div>
      </div>
    </div>
    <div class="dl-result" id="dlResult"></div>
  </div>

  <!-- How Long to Download Table -->
  <div class="time-table-section">
    <div class="input-header">
      <div class="header-title">How Long to Download?</div>
    </div>
    <p class="section-desc">Enter a file size to see download times at common connection speeds.</p>
    <div class="converter-input-row">
      <input type="number" id="tableFileSize" class="speed-input" placeholder="File size..." value="1" min="0" step="any" />
      <select id="tableFileSizeUnit" class="speed-select">
        <option value="B">Bytes</option>
        <option value="KB">KB</option>
        <option value="MB">MB</option>
        <option value="GB" selected>GB</option>
        <option value="TB">TB</option>
      </select>
    </div>
    <div class="ref-table-wrap">
      <table class="ref-table">
        <thead>
          <tr>
            <th>Connection</th>
            <th>Speed</th>
            <th>Download Time</th>
          </tr>
        </thead>
        <tbody id="timeTableBody"></tbody>
      </table>
    </div>
  </div>

  <!-- Common Internet Speeds Reference -->
  <div class="ref-section">
    <div class="input-header">
      <div class="header-title">Common Internet Speeds Reference</div>
    </div>
    <div class="ref-table-wrap">
      <table class="ref-table">
        <thead>
          <tr>
            <th>Connection Type</th>
            <th>Speed</th>
            <th>MB/s</th>
            <th>Typical Use</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Dial-up</td><td>56 Kbps</td><td>0.007</td><td>Basic email, text-only web pages</td></tr>
          <tr><td>Early DSL</td><td>1 Mbps</td><td>0.125</td><td>Web browsing, email with attachments</td></tr>
          <tr><td>Basic DSL/Cable</td><td>5 Mbps</td><td>0.625</td><td>SD video streaming, casual browsing</td></tr>
          <tr><td>Standard Broadband</td><td>25 Mbps</td><td>3.125</td><td>HD streaming, video calls, light gaming</td></tr>
          <tr><td>Fast Broadband</td><td>100 Mbps</td><td>12.5</td><td>4K streaming, multiplayer gaming, working from home</td></tr>
          <tr><td>Gigabit Cable</td><td>500 Mbps</td><td>62.5</td><td>Multiple 4K streams, large file transfers, smart homes</td></tr>
          <tr><td>Gigabit Fiber</td><td>1 Gbps</td><td>125</td><td>Near-instant downloads, heavy cloud computing</td></tr>
          <tr><td>Multi-Gig Fiber</td><td>2.5 Gbps</td><td>312.5</td><td>Prosumer NAS, 8K streaming, high-speed backups</td></tr>
          <tr><td>5G mmWave (peak)</td><td>5 Gbps</td><td>625</td><td>Ultra-low latency applications, edge computing</td></tr>
          <tr><td>10G Fiber</td><td>10 Gbps</td><td>1,250</td><td>Data centers, enterprise backbone, research networks</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- SEO Content + FAQ -->
  <div class="seo-content">
    <h2>Understanding Network Speed Units</h2>
    <p>Network speeds are measured in bits per second, while file sizes are measured in bytes. This fundamental difference causes confusion — your ISP advertises speeds in <strong>megabits per second (Mbps)</strong>, but your download manager shows <strong>megabytes per second (MB/s)</strong>. Since there are 8 bits in a byte, you divide the Mbps number by 8 to get MB/s. A 100 Mbps connection delivers a maximum of 12.5 MB/s.</p>

    <h2>Bits vs Bytes: The Key Difference</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Unit (bits)</th>
          <th>Value</th>
          <th>Equivalent (bytes)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>1 bps</td><td>1 bit/s</td><td>0.125 B/s</td></tr>
        <tr><td>1 Kbps</td><td>1,000 bits/s</td><td>125 B/s</td></tr>
        <tr><td>1 Mbps</td><td>1,000,000 bits/s</td><td>125 KB/s</td></tr>
        <tr><td>1 Gbps</td><td>1,000,000,000 bits/s</td><td>125 MB/s</td></tr>
        <tr><td>1 Tbps</td><td>1,000,000,000,000 bits/s</td><td>125 GB/s</td></tr>
      </tbody>
    </table>
    <p>Network speeds use SI (decimal) prefixes: 1 Kbps = 1,000 bps, 1 Mbps = 1,000 Kbps. This is different from file sizes where some systems use binary prefixes (1 KiB = 1,024 bytes). This converter uses SI/decimal prefixes throughout for consistency with how ISPs and networking standards report speeds.</p>

    <h2>How to Calculate Download Time</h2>
    <p>To calculate download time: convert your file size to bits (multiply bytes by 8), then divide by your connection speed in bits per second. For example, downloading a 1 GB file (8,000,000,000 bits) at 100 Mbps (100,000,000 bits/s) takes 80 seconds — about 1 minute and 20 seconds. Real-world speeds are typically 60-80% of the advertised rate due to protocol overhead, Wi-Fi loss, and server-side limits.</p>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between Mbps and MB/s?</h3>
      <p style="margin-bottom: 16px;">Mbps (megabits per second) measures network speed in bits, while MB/s (megabytes per second) measures data transfer in bytes. Since 1 byte equals 8 bits, you divide Mbps by 8 to get MB/s. For example, a 100 Mbps connection transfers data at 12.5 MB/s.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How long does it take to download a 1 GB file?</h3>
      <p style="margin-bottom: 16px;">Download time depends on your connection speed. At 10 Mbps it takes about 13 minutes and 20 seconds, at 100 Mbps about 1 minute and 20 seconds, at 1 Gbps about 8 seconds, and at 10 Gbps under 1 second. Real-world speeds may vary due to network overhead and congestion.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Why is my download speed slower than my internet plan?</h3>
      <p style="margin-bottom: 16px;">ISPs advertise speeds in megabits per second (Mbps), but browsers and download managers show megabytes per second (MB/s). A 100 Mbps plan downloads at about 12.5 MB/s maximum. Additionally, network overhead, Wi-Fi interference, server limits, and congestion can reduce actual throughput below the advertised rate.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What internet speed do I need for streaming 4K video?</h3>
      <p style="margin-bottom: 16px;">Streaming 4K video typically requires at least 25 Mbps for a single stream. Netflix recommends 15 Mbps minimum for 4K, while YouTube suggests 20 Mbps. If multiple devices are streaming simultaneously, you should multiply accordingly — a household with 3 simultaneous 4K streams needs at least 75 Mbps.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Is my data safe when using this converter?</h3>
      <p style="margin-bottom: 16px;">Yes. All calculations happen entirely in your browser using JavaScript. No data is sent to any server. Your inputs never leave your device.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/byte-converter">Byte Converter</a> — Convert between bytes, KB, MB, GB, TB with binary and decimal units.</li>
      <li><a href="/unix-timestamp-converter">Unix Timestamp Converter</a> — Convert Unix timestamps to human-readable dates and back.</li>
      <li><a href="/number-base-converter">Number Base Converter</a> — Convert numbers between decimal, binary, hexadecimal, and octal.</li>
    </ul>
  </div>

</div>
</div>`;

export const meta = {
  title: "Network Speed Converter — Convert Mbps, Gbps, MB/s Online",
  description: "Free network speed unit converter. Convert between bps, Kbps, Mbps, Gbps, Tbps, B/s, KB/s, MB/s, GB/s instantly. Download time calculator and internet speed reference table.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="Network Speed Converter — Convert Mbps, Gbps, MB/s Online"
  description="Free network speed unit converter. Convert between bps, Kbps, Mbps, Gbps, Tbps, B/s, KB/s, MB/s, GB/s instantly. Download time calculator and internet speed reference table."
  canonical="https://siliconbased.dev/network-speed-converter"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
// Unit definitions: factor to convert TO bps
var UNITS = {
  bps:  { factor: 1, label: 'bps (bits/s)' },
  Kbps: { factor: 1e3, label: 'Kbps (kilobits/s)' },
  Mbps: { factor: 1e6, label: 'Mbps (megabits/s)' },
  Gbps: { factor: 1e9, label: 'Gbps (gigabits/s)' },
  Tbps: { factor: 1e12, label: 'Tbps (terabits/s)' },
  Bs:   { factor: 8, label: 'B/s (bytes/s)' },
  KBs:  { factor: 8e3, label: 'KB/s (kilobytes/s)' },
  MBs:  { factor: 8e6, label: 'MB/s (megabytes/s)' },
  GBs:  { factor: 8e9, label: 'GB/s (gigabytes/s)' }
};

// File size units: factor to convert TO bytes
var FILE_UNITS = {
  B:  1,
  KB: 1e3,
  MB: 1e6,
  GB: 1e9,
  TB: 1e12
};

// Common speeds for the "how long to download" table
var COMMON_SPEEDS = [
  { name: 'Dial-up', mbps: 0.056 },
  { name: 'DSL (1 Mbps)', mbps: 1 },
  { name: 'Broadband (5 Mbps)', mbps: 5 },
  { name: 'Broadband (25 Mbps)', mbps: 25 },
  { name: 'Fast (50 Mbps)', mbps: 50 },
  { name: 'Fast (100 Mbps)', mbps: 100 },
  { name: 'Cable (500 Mbps)', mbps: 500 },
  { name: 'Fiber (1 Gbps)', mbps: 1000 },
  { name: 'Multi-Gig (2.5 Gbps)', mbps: 2500 },
  { name: '10G Fiber', mbps: 10000 }
];

var speedValue = document.getElementById('speedValue');
var speedUnit = document.getElementById('speedUnit');
var resultsGrid = document.getElementById('resultsGrid');
var fileSize = document.getElementById('fileSize');
var fileSizeUnit = document.getElementById('fileSizeUnit');
var dlSpeed = document.getElementById('dlSpeed');
var dlSpeedUnit = document.getElementById('dlSpeedUnit');
var dlResult = document.getElementById('dlResult');
var tableFileSize = document.getElementById('tableFileSize');
var tableFileSizeUnit = document.getElementById('tableFileSizeUnit');
var timeTableBody = document.getElementById('timeTableBody');

function toBps(value, unit) {
  return value * UNITS[unit].factor;
}

function fromBps(bps, unit) {
  return bps / UNITS[unit].factor;
}

function formatNumber(n) {
  if (n === 0) return '0';
  if (n >= 1e15) return n.toExponential(3);
  if (Math.abs(n) >= 1) {
    if (n >= 1e9) return n.toLocaleString(undefined, { maximumFractionDigits: 2 });
    if (n >= 1e6) return n.toLocaleString(undefined, { maximumFractionDigits: 3 });
    if (n >= 1000) return n.toLocaleString(undefined, { maximumFractionDigits: 4 });
    if (n >= 1) return n.toLocaleString(undefined, { maximumFractionDigits: 6 });
  }
  if (n < 0.0001) return n.toExponential(3);
  return n.toLocaleString(undefined, { maximumFractionDigits: 8 });
}

function formatTime(seconds) {
  if (!isFinite(seconds) || seconds < 0) return '\u2014';
  if (seconds < 0.001) return '< 1 ms';
  if (seconds < 1) return (seconds * 1000).toFixed(1) + ' ms';
  if (seconds < 60) return seconds.toFixed(1) + ' sec';

  var days = Math.floor(seconds / 86400);
  var hrs = Math.floor((seconds % 86400) / 3600);
  var mins = Math.floor((seconds % 3600) / 60);
  var secs = Math.floor(seconds % 60);

  if (days > 365) {
    var years = (days / 365.25).toFixed(1);
    return years + ' years';
  }
  if (days > 0) {
    var parts = [days + 'd'];
    if (hrs > 0) parts.push(hrs + 'h');
    if (mins > 0) parts.push(mins + 'm');
    return parts.join(' ');
  }
  if (hrs > 0) {
    var parts = [hrs + 'h'];
    if (mins > 0) parts.push(mins + 'm');
    if (secs > 0) parts.push(secs + 's');
    return parts.join(' ');
  }
  return mins + 'm ' + secs + 's';
}

function convertSpeed() {
  var val = parseFloat(speedValue.value);
  if (isNaN(val) || val < 0) {
    resultsGrid.innerHTML = '<div class="result-empty">Enter a positive number to see conversions.</div>';
    return;
  }

  var bps = toBps(val, speedUnit.value);
  var html = '';
  var keys = Object.keys(UNITS);
  for (var i = 0; i < keys.length; i++) {
    var key = keys[i];
    var converted = fromBps(bps, key);
    var isActive = key === speedUnit.value ? ' result-active' : '';
    html += '<div class="result-card' + isActive + '">'
      + '<div class="result-value">' + formatNumber(converted) + '</div>'
      + '<div class="result-unit">' + UNITS[key].label + '</div>'
      + '</div>';
  }
  resultsGrid.innerHTML = html;
}

function calcDownloadTime() {
  var size = parseFloat(fileSize.value);
  var speed = parseFloat(dlSpeed.value);

  if (isNaN(size) || isNaN(speed) || size < 0 || speed <= 0) {
    dlResult.innerHTML = '<div class="dl-result-box">Enter valid values to see the download time.</div>';
    return;
  }

  var sizeBytes = size * FILE_UNITS[fileSizeUnit.value];
  var sizeBits = sizeBytes * 8;
  var speedBps = toBps(speed, dlSpeedUnit.value);
  var seconds = sizeBits / speedBps;

  dlResult.innerHTML = '<div class="dl-result-box">'
    + '<div class="dl-result-time">' + formatTime(seconds) + '</div>'
    + '<div class="dl-result-detail">'
    + formatNumber(size) + ' ' + fileSizeUnit.value + ' at ' + formatNumber(speed) + ' ' + dlSpeedUnit.value
    + ' = ' + formatNumber(seconds) + ' seconds'
    + '</div>'
    + '</div>';
}

function buildTimeTable() {
  var size = parseFloat(tableFileSize.value);
  if (isNaN(size) || size < 0) {
    timeTableBody.innerHTML = '<tr><td colspan="3" style="color:#888;text-align:center;padding:20px;">Enter a file size above.</td></tr>';
    return;
  }

  var sizeBytes = size * FILE_UNITS[tableFileSizeUnit.value];
  var sizeBits = sizeBytes * 8;
  var html = '';

  for (var i = 0; i < COMMON_SPEEDS.length; i++) {
    var s = COMMON_SPEEDS[i];
    var bps = s.mbps * 1e6;
    var seconds = sizeBits / bps;
    var speedLabel = s.mbps >= 1000 ? (s.mbps / 1000) + ' Gbps' : s.mbps + ' Mbps';
    if (s.mbps < 1) speedLabel = (s.mbps * 1000) + ' Kbps';
    html += '<tr><td>' + s.name + '</td><td>' + speedLabel + '</td><td class="time-value">' + formatTime(seconds) + '</td></tr>';
  }

  timeTableBody.innerHTML = html;
}

function init() {
  speedValue.addEventListener('input', convertSpeed);
  speedUnit.addEventListener('change', convertSpeed);

  fileSize.addEventListener('input', calcDownloadTime);
  fileSizeUnit.addEventListener('change', calcDownloadTime);
  dlSpeed.addEventListener('input', calcDownloadTime);
  dlSpeedUnit.addEventListener('change', calcDownloadTime);

  tableFileSize.addEventListener('input', buildTimeTable);
  tableFileSizeUnit.addEventListener('change', buildTimeTable);

  convertSpeed();
  calcDownloadTime();
  buildTimeTable();
}

init();
</script>

  <style is:inline>

.page-content { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #e0e0e0; min-height: 100vh; display: flex; flex-direction: column; }
code, pre, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #0f1729 0%, #060a12 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero p { color: #888; font-size: 0.95rem; }
.main { max-width: 1100px; margin: 0 auto; padding: 24px 20px 80px; flex: 1; width: 100%; position: relative; }

.section-desc { color: #888; font-size: 0.88rem; margin: -8px 0 16px; }

/* Input header */
.input-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.header-title { font-size: 0.85rem; font-weight: 600; color: #ccc; text-transform: uppercase; letter-spacing: 0.5px; }
.header-actions { display: flex; gap: 8px; }

/* Converter section */
.converter-section { margin-bottom: 40px; }
.converter-input-row { display: flex; gap: 12px; margin-bottom: 20px; }
.speed-input { flex: 1; background: #0a1020; border: 2px solid #152040; border-radius: 10px; padding: 12px 16px; color: #e0e0e0; font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; outline: none; transition: border-color 0.2s; }
.speed-input:focus { border-color: #818cf8; }
.speed-select { background: #0a1020; border: 2px solid #152040; border-radius: 10px; padding: 12px 16px; color: #e0e0e0; font-family: 'Inter', sans-serif; font-size: 0.85rem; outline: none; cursor: pointer; transition: border-color 0.2s; min-width: 180px; }
.speed-select:focus { border-color: #818cf8; }

/* Results grid */
.results-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.result-card { background: #0a1020; border: 2px solid #152040; border-radius: 12px; padding: 16px 18px; transition: border-color 0.2s; }
.result-card:hover { border-color: #2a3060; }
.result-card.result-active { border-color: #818cf8; background: #0e1430; }
.result-value { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700; color: #e0e0e0; margin-bottom: 4px; word-break: break-all; }
.result-active .result-value { color: #818cf8; }
.result-unit { font-size: 0.75rem; color: #666; font-weight: 500; text-transform: uppercase; letter-spacing: 0.3px; }
.result-empty { color: #555; font-size: 0.9rem; padding: 24px; text-align: center; }

/* Download time calculator */
.download-section { margin-bottom: 40px; }
.download-input-row { display: flex; gap: 24px; margin-bottom: 16px; }
.dl-field { flex: 1; }
.dl-label { display: block; font-size: 0.78rem; color: #888; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 8px; }
.dl-input-pair { display: flex; gap: 10px; }
.dl-result-box { background: #0a1020; border: 2px solid #152040; border-radius: 12px; padding: 20px 24px; text-align: center; }
.dl-result-time { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 800; color: #4ade80; margin-bottom: 6px; }
.dl-result-detail { font-size: 0.82rem; color: #666; font-family: 'JetBrains Mono', monospace; }

/* Time table section */
.time-table-section { margin-bottom: 40px; }
.time-value { color: #4ade80; font-family: 'JetBrains Mono', monospace; font-weight: 600; }

/* Reference section */
.ref-section { margin-bottom: 40px; }
.ref-table-wrap { overflow-x: auto; }
.ref-table { width: 100%; border-collapse: collapse; }
.ref-table th { text-align: left; padding: 10px 14px; border-bottom: 2px solid #2a2d4e; color: #ccc; font-weight: 600; font-size: 0.78rem; background: #0a1020; text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; }
.ref-table td { padding: 10px 14px; border-bottom: 1px solid #152040; font-size: 0.85rem; color: #aaa; }
.ref-table td:nth-child(2) { color: #818cf8; font-family: 'JetBrains Mono', monospace; font-weight: 600; }
.ref-table td:nth-child(3) { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #888; }
.ref-table tr:hover td { background: #0a1020; }

/* SEO Content */
.seo-content { margin-top: 48px; border-top: 1px solid #1e2030; padding-top: 48px; color: #b0b8d0; font-size: 0.95rem; line-height: 1.6; }
.seo-content h2 { color: #fff; font-size: 1.4rem; font-weight: 700; margin: 32px 0 16px; }
.seo-content h2:first-child { margin-top: 0; }
.seo-content h3 { color: #e0e0e0; font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; }
.seo-content p { margin-bottom: 16px; }
.seo-content ul { margin-bottom: 16px; padding-left: 24px; }
.seo-content li { margin-bottom: 8px; }
.seo-content a { color: #818cf8; text-decoration: none; }
.seo-content a:hover { text-decoration: underline; }
.seo-content code { background: #0a1020; padding: 2px 6px; border-radius: 4px; color: #818cf8; font-size: 0.85em; }
.seo-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; font-size: 0.9rem; }
.seo-table th { text-align: left; padding: 10px 14px; border-bottom: 2px solid #2a2d4e; color: #ccc; font-weight: 600; background: #0a1020; }
.seo-table td { padding: 10px 14px; border-bottom: 1px solid #152040; color: #aaa; }
.seo-table tr:hover td { background: #0a1020; }

/* Responsive */
@media (max-width: 800px) {
  .results-grid { grid-template-columns: repeat(2, 1fr); }
  .download-input-row { flex-direction: column; gap: 16px; }
  .converter-input-row { flex-direction: column; }
  .speed-select { min-width: unset; }
}
@media (max-width: 500px) {
  .results-grid { grid-template-columns: 1fr; }
  .dl-input-pair { flex-direction: column; }
}

</style>
</SiteLayout>
