    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .content-section p { line-height: 1.7; margin-bottom: 1.5rem; color: var(--text-primary); }
    .content-section h2 { font-size: 1.8rem; margin: 2.5rem 0 1rem; color: var(--text-primary); }
    .content-section h3 { font-size: 1.4rem; margin: 2rem 0 0.8rem; color: var(--text-primary); }
    .content-section ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .content-section li { margin-bottom: 0.8rem; line-height: 1.6; }
