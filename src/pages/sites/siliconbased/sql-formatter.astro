---

<SiteLayout
  site="siliconbased"
  title="SQL Formatter & Beautifier — Pretty Print SQL Online"
  description="Free online SQL formatter and beautifier. Format, minify, and pretty print SQL with syntax highlighting and keyword uppercasing."
  canonical="https://siliconbased.dev/sql-formatter"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const sqlInput = document.getElementById('sqlInput');
const sqlOutput = document.getElementById('sqlOutput');
const lineNumbers = document.getElementById('lineNumbers');
const outputStatus = document.getElementById('outputStatus');

const btnFormat = document.getElementById('btnFormat');
const btnMinify = document.getElementById('btnMinify');
const copyBtn = document.getElementById('copyBtn');
const clearBtn = document.getElementById('clearBtn');
const sampleBtn = document.getElementById('sampleBtn');

const optUppercase = document.getElementById('optUppercase');
const optIndent = document.getElementById('optIndent');
const optLineBreakLogical = document.getElementById('optLineBreakLogical');
const optTrailingSemicolon = document.getElementById('optTrailingSemicolon');

let currentMode = 'format';
let debounceTimer;
let currentFormattedSql = '';

const SQL_KEYWORDS = new Set([
  'SELECT','FROM','WHERE','AND','OR','NOT','IN','EXISTS','BETWEEN','LIKE','IS','NULL',
  'INSERT','INTO','VALUES','UPDATE','SET','DELETE','CREATE','TABLE','ALTER','DROP',
  'ADD','COLUMN','INDEX','VIEW','DATABASE','SCHEMA','PRIMARY','KEY','FOREIGN','REFERENCES',
  'JOIN','INNER','LEFT','RIGHT','FULL','OUTER','CROSS','ON','USING',
  'GROUP','BY','ORDER','ASC','DESC','HAVING','LIMIT','OFFSET','FETCH','NEXT','ROWS','ONLY',
  'UNION','ALL','INTERSECT','EXCEPT','DISTINCT','AS','CASE','WHEN','THEN','ELSE','END',
  'WITH','RECURSIVE','IF','BEGIN','COMMIT','ROLLBACK','TRANSACTION','GRANT','REVOKE',
  'COUNT','SUM','AVG','MIN','MAX','COALESCE','NULLIF','CAST','CONVERT',
  'VARCHAR','INT','INTEGER','BIGINT','SMALLINT','DECIMAL','NUMERIC','FLOAT','DOUBLE',
  'BOOLEAN','DATE','TIME','TIMESTAMP','TEXT','BLOB','CHAR','DEFAULT','CONSTRAINT',
  'UNIQUE','CHECK','AUTO_INCREMENT','SERIAL','CASCADE','RESTRICT','NO','ACTION',
  'TOP','PERCENT','OVER','PARTITION','ROW_NUMBER','RANK','DENSE_RANK','NTILE',
  'LAG','LEAD','FIRST_VALUE','LAST_VALUE','WINDOW','RANGE','UNBOUNDED','PRECEDING',
  'FOLLOWING','CURRENT','ROW','REPLACE','TRUNCATE','EXPLAIN','ANALYZE',
  'TEMPORARY','TEMP','MATERIALIZED','LATERAL','NATURAL','SOME','ANY','ILIKE',
  'SIMILAR','TO','ESCAPE','COLLATE','RETURNING','CONFLICT','DO','NOTHING',
  'EXCLUDE','INCLUDE','GENERATED','ALWAYS','IDENTITY','OVERRIDING','SYSTEM','VALUE',
  'TRUE','FALSE','UNKNOWN','LIKE','EXISTS','CONCAT','SUBSTRING','ROUND','EXTRACT',
  'DATE_TRUNC','UPPER','LOWER','TRIM','LENGTH','YEAR','MONTH','DAY','HOUR','MINUTE',
  'SECOND','NOW','CURRENT_TIMESTAMP','CURRENT_DATE','CURRENT_TIME','INTERVAL',
  'ZONE','INET','UUID','GEN_RANDOM_UUID','JSONB','JSON','ARRAY','LATERAL',
  'RETURNS','LANGUAGE','FUNCTION','PROCEDURE','TRIGGER','BEFORE','AFTER','FOR',
  'EACH','EXECUTE','DECLARE','CURSOR','OPEN','CLOSE','LOOP','WHILE','REPEAT',
  'UNTIL','SIGNAL','RESIGNAL','HANDLER','CONDITION','CONTINUE','EXIT',
  'ENABLE','DISABLE','VALIDATE','NOVALIDATE','DEFERRABLE','INITIALLY',
  'DEFERRED','IMMEDIATE','RENAME'
]);

/* ── Tokenizer ── */
function tokenize(sql) {
  const tokens = [];
  let i = 0;
  const len = sql.length;
  while (i < len) {
    // whitespace
    if (/\s/.test(sql[i])) {
      let ws = '';
      while (i < len && /\s/.test(sql[i])) { ws += sql[i]; i++; }
      tokens.push({ type: 'ws', value: ws });
      continue;
    }
    // single-line comment
    if (sql[i] === '-' && sql[i+1] === '-') {
      let c = '';
      while (i < len && sql[i] !== '\n') { c += sql[i]; i++; }
      tokens.push({ type: 'comment', value: c });
      continue;
    }
    // block comment
    if (sql[i] === '/' && sql[i+1] === '*') {
      let c = '/*'; i += 2;
      while (i < len && !(sql[i] === '*' && sql[i+1] === '/')) { c += sql[i]; i++; }
      if (i < len) { c += '*/'; i += 2; }
      tokens.push({ type: 'comment', value: c });
      continue;
    }
    // single-quoted string
    if (sql[i] === "'") {
      let s = "'"; i++;
      while (i < len) {
        if (sql[i] === "'" && sql[i+1] === "'") { s += "''"; i += 2; }
        else if (sql[i] === "'") { s += "'"; i++; break; }
        else { s += sql[i]; i++; }
      }
      tokens.push({ type: 'string', value: s });
      continue;
    }
    // double-quoted identifier
    if (sql[i] === '"') {
      let s = '"'; i++;
      while (i < len && sql[i] !== '"') { s += sql[i]; i++; }
      if (i < len) { s += '"'; i++; }
      tokens.push({ type: 'ident', value: s });
      continue;
    }
    // backtick identifier
    if (sql[i] === '`') {
      let s = '`'; i++;
      while (i < len && sql[i] !== '`') { s += sql[i]; i++; }
      if (i < len) { s += '`'; i++; }
      tokens.push({ type: 'ident', value: s });
      continue;
    }
    // number
    if (/\d/.test(sql[i]) || (sql[i] === '.' && i+1 < len && /\d/.test(sql[i+1]))) {
      let n = '';
      while (i < len && /[\d.eE]/.test(sql[i])) { n += sql[i]; i++; }
      tokens.push({ type: 'number', value: n });
      continue;
    }
    if (sql[i] === '(') { tokens.push({ type: 'lparen', value: '(' }); i++; continue; }
    if (sql[i] === ')') { tokens.push({ type: 'rparen', value: ')' }); i++; continue; }
    if (sql[i] === ';') { tokens.push({ type: 'semi', value: ';' }); i++; continue; }
    if (sql[i] === ',') { tokens.push({ type: 'comma', value: ',' }); i++; continue; }
    if (sql[i] === '.') { tokens.push({ type: 'dot', value: '.' }); i++; continue; }
    if ('<>=!'.includes(sql[i])) {
      let op = sql[i]; i++;
      if (i < len && '>='.includes(sql[i])) { op += sql[i]; i++; }
      tokens.push({ type: 'op', value: op });
      continue;
    }
    if ('*+-/%&|^~'.includes(sql[i])) { tokens.push({ type: 'op', value: sql[i] }); i++; continue; }
    if (/[a-zA-Z_@#]/.test(sql[i])) {
      let w = '';
      while (i < len && /[a-zA-Z0-9_@#$]/.test(sql[i])) { w += sql[i]; i++; }
      const up = w.toUpperCase();
      tokens.push({ type: SQL_KEYWORDS.has(up) ? 'keyword' : 'ident', value: w });
      continue;
    }
    tokens.push({ type: 'other', value: sql[i] }); i++;
  }
  return tokens;
}

/* ── Formatter ── */
function formatSQL(sql) {
  const uppercase = optUppercase.checked;
  const indentVal = optIndent.value;
  const lineBreakLogical = optLineBreakLogical.checked;
  const trailingSemicolon = optTrailingSemicolon.checked;
  const ind = indentVal === 'tab' ? '\t' : ' '.repeat(parseInt(indentVal, 10));

  const raw = tokenize(sql);
  const tokens = raw.filter(t => t.type !== 'ws');
  if (!tokens.length) return '';

  let out = '';
  let depth = 0;
  let fresh = true; // at start of line
  let selDepth = -1;
  let parenStack = [];

  function peek(idx) {
    return idx < tokens.length && tokens[idx].type === 'keyword' ? tokens[idx].value.toUpperCase() : null;
  }

  function combo(idx) {
    const a = peek(idx);
    if (!a) return null;
    const b = peek(idx + 1);
    const c = peek(idx + 2);
    if (b && c) {
      const t = a + ' ' + b + ' ' + c;
      if (['FULL OUTER JOIN','LEFT OUTER JOIN','RIGHT OUTER JOIN','ORDER BY ASC','ORDER BY DESC','GROUP BY ALL'].includes(t)) return { kw: t, skip: 2 };
    }
    if (b) {
      const t = a + ' ' + b;
      if (['GROUP BY','ORDER BY','INSERT INTO','DELETE FROM','INNER JOIN','LEFT JOIN','RIGHT JOIN','FULL JOIN','CROSS JOIN','NATURAL JOIN','UNION ALL','CREATE TABLE','ALTER TABLE','DROP TABLE','FETCH NEXT','ROWS ONLY','NOT IN','NOT EXISTS','NOT NULL','NOT BETWEEN','NOT LIKE','IS NOT','IS NULL','PRIMARY KEY','FOREIGN KEY','IF EXISTS','IF NOT','ON DELETE','ON UPDATE'].includes(t)) return { kw: t, skip: 1 };
    }
    return { kw: a, skip: 0 };
  }

  const newlineBefore = new Set([
    'SELECT','FROM','WHERE','GROUP BY','ORDER BY','HAVING','LIMIT','OFFSET',
    'INSERT INTO','UPDATE','SET','DELETE FROM','VALUES',
    'INNER JOIN','LEFT JOIN','RIGHT JOIN','FULL JOIN','FULL OUTER JOIN',
    'CROSS JOIN','LEFT OUTER JOIN','RIGHT OUTER JOIN','NATURAL JOIN','JOIN',
    'UNION ALL','UNION','INTERSECT','EXCEPT',
    'WITH','CREATE TABLE','ALTER TABLE','DROP TABLE','FETCH NEXT'
  ]);

  const deIndentBefore = new Set([
    'FROM','WHERE','GROUP BY','ORDER BY','HAVING','LIMIT','OFFSET',
    'SET','VALUES','FETCH NEXT','UNION ALL','UNION','INTERSECT','EXCEPT'
  ]);

  function nl() { out = out.replace(/[ \t]+$/, ''); out += '\n' + ind.repeat(depth); fresh = true; }
  function sp() { if (!fresh && out.length && !out.endsWith(' ') && !out.endsWith('\n')) out += ' '; }

  let i = 0;
  while (i < tokens.length) {
    const t = tokens[i];

    if (t.type === 'keyword') {
      const c = combo(i);
      const kw = c.kw;
      const skip = c.skip;
      const display = uppercase ? kw : kw.toLowerCase();

      if (newlineBefore.has(kw)) {
        if (deIndentBefore.has(kw) && selDepth >= 0 && depth > selDepth) {
          depth = selDepth; selDepth = -1;
        }
        if (!(kw === 'SELECT' && i === 0)) nl();
        else if (!fresh) nl();
        out += display; fresh = false;
        if (kw === 'SELECT' || kw === 'SET' || kw === 'VALUES') { selDepth = depth; depth++; }
        i += 1 + skip; continue;
      }

      if (kw === 'AND' || kw === 'OR') {
        if (lineBreakLogical && parenStack.length === 0) { nl(); out += display; }
        else { sp(); out += display; }
        fresh = false; i++; continue;
      }

      if (kw === 'CASE') { sp(); out += display; depth++; fresh = false; i += 1 + skip; continue; }
      if (kw === 'WHEN' || kw === 'ELSE') { nl(); out += display; fresh = false; i += 1 + skip; continue; }
      if (kw === 'THEN') { sp(); out += display; fresh = false; i += 1 + skip; continue; }
      if (kw === 'END') { depth = Math.max(0, depth - 1); nl(); out += display; fresh = false; i += 1 + skip; continue; }
      if (kw === 'ON') { sp(); out += display; fresh = false; i += 1 + skip; continue; }

      sp(); out += display; fresh = false; i += 1 + skip; continue;
    }

    if (t.type === 'lparen') {
      sp(); out += '('; parenStack.push(depth); depth++;
      if (peek(i + 1) === 'SELECT') nl();
      fresh = false; i++; continue;
    }
    if (t.type === 'rparen') {
      if (parenStack.length) depth = parenStack.pop(); else depth = Math.max(0, depth - 1);
      if (selDepth >= depth) selDepth = -1;
      nl(); out += ')'; fresh = false; i++; continue;
    }
    if (t.type === 'comma') {
      out += ',';
      if (selDepth >= 0 && parenStack.length === 0) nl(); else out += ' ';
      fresh = false; i++; continue;
    }
    if (t.type === 'semi') {
      out = out.replace(/[ \t]+$/, ''); out += ';';
      if (i + 1 < tokens.length) { out += '\n'; depth = 0; selDepth = -1; parenStack = []; nl(); }
      fresh = false; i++; continue;
    }
    if (t.type === 'comment') { sp(); out += t.value; nl(); i++; continue; }

    sp(); out += t.value; fresh = false; i++;
  }

  out = out.trim();
  if (trailingSemicolon && out.length && !out.endsWith(';')) out += ';';
  if (!trailingSemicolon && out.endsWith(';')) out = out.slice(0, -1).trimEnd();
  return out;
}

/* ── Minify ── */
function minifySQL(sql) {
  const tokens = tokenize(sql);
  let out = '';
  for (const t of tokens) {
    if (t.type === 'ws') { if (out.length && !out.endsWith(' ')) out += ' '; }
    else if (t.type === 'comment') { /* strip */ }
    else out += t.value;
  }
  return out.replace(/ +/g, ' ').trim();
}

/* ── Syntax highlight ── */
function highlightSQL(sql) {
  const tokens = tokenize(sql);
  let html = '';
  for (const t of tokens) {
    const e = t.value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    switch (t.type) {
      case 'keyword': html += '<span class="hl-keyword">' + e + '</span>'; break;
      case 'string':  html += '<span class="hl-string">' + e + '</span>'; break;
      case 'number':  html += '<span class="hl-number">' + e + '</span>'; break;
      case 'comment': html += '<span class="hl-comment">' + e + '</span>'; break;
      default:        html += e;
    }
  }
  return html;
}

/* ── Process ── */
function processSQL() {
  const raw = sqlInput.value.trim();
  if (!raw) {
    sqlOutput.innerHTML = '';
    lineNumbers.innerHTML = '1';
    outputStatus.textContent = 'Output';
    outputStatus.style.color = '#ccc';
    currentFormattedSql = '';
    return;
  }
  const out = currentMode === 'format' ? formatSQL(raw) : minifySQL(raw);
  currentFormattedSql = out;
  outputStatus.textContent = currentMode === 'format' ? 'Formatted' : 'Minified';
  outputStatus.style.color = '#4ade80';

  const lines = out.split('\n');
  let lh = '';
  for (let n = 1; n <= lines.length; n++) lh += n + '<br>';
  lineNumbers.innerHTML = lh;
  sqlOutput.innerHTML = highlightSQL(out);
}

function setMode(mode) {
  currentMode = mode;
  btnFormat.classList.toggle('active', mode === 'format');
  btnMinify.classList.toggle('active', mode === 'minify');
  processSQL();
}

/* ── Samples ── */
const SAMPLES = [
  "SELECT u.id, u.name, u.email, o.order_id, o.total_amount, p.product_name FROM users u INNER JOIN orders o ON u.id = o.user_id LEFT JOIN order_items oi ON o.order_id = oi.order_id LEFT JOIN products p ON oi.product_id = p.id WHERE u.active = 1 AND o.created_at >= '2024-01-01' AND o.total_amount > 100.00 GROUP BY u.id, u.name, u.email, o.order_id, o.total_amount, p.product_name HAVING COUNT(oi.id) > 2 ORDER BY o.total_amount DESC LIMIT 50;",
  "WITH monthly_sales AS (SELECT DATE_TRUNC('month', order_date) AS month, salesperson_id, SUM(amount) AS total_sales FROM orders WHERE order_date >= '2024-01-01' GROUP BY DATE_TRUNC('month', order_date), salesperson_id), ranked AS (SELECT month, salesperson_id, total_sales, RANK() OVER (PARTITION BY month ORDER BY total_sales DESC) AS sales_rank FROM monthly_sales) SELECT r.month, s.name, r.total_sales, r.sales_rank FROM ranked r INNER JOIN salespeople s ON r.salesperson_id = s.id WHERE r.sales_rank <= 5 ORDER BY r.month, r.sales_rank;",
  "SELECT e.employee_id, e.first_name, e.last_name, d.department_name, CASE WHEN e.salary > 100000 THEN 'Senior' WHEN e.salary > 60000 THEN 'Mid-Level' ELSE 'Junior' END AS level, e.salary, (SELECT AVG(salary) FROM employees WHERE department_id = e.department_id) AS dept_avg_salary FROM employees e INNER JOIN departments d ON e.department_id = d.department_id WHERE e.hire_date BETWEEN '2020-01-01' AND '2024-12-31' AND e.department_id IN (SELECT department_id FROM departments WHERE location_id = 1700) ORDER BY d.department_name, e.salary DESC;",
  "INSERT INTO audit_log (user_id, action, table_name, record_id, old_values, new_values, created_at) VALUES (42, 'UPDATE', 'products', 1001, '{\"price\": 29.99}', '{\"price\": 34.99}', NOW());",
  "CREATE TABLE IF NOT EXISTS user_sessions (session_id UUID PRIMARY KEY DEFAULT gen_random_uuid(), user_id INTEGER NOT NULL REFERENCES users(id) ON DELETE CASCADE, ip_address INET NOT NULL, user_agent TEXT, created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP, expires_at TIMESTAMP WITH TIME ZONE NOT NULL, is_active BOOLEAN DEFAULT TRUE, CONSTRAINT valid_expiry CHECK (expires_at > created_at));"
];
let sampleIdx = 0;

function init() {
  sqlInput.addEventListener('input', () => { clearTimeout(debounceTimer); debounceTimer = setTimeout(processSQL, 300); });
  btnFormat.addEventListener('click', () => setMode('format'));
  btnMinify.addEventListener('click', () => setMode('minify'));
  clearBtn.addEventListener('click', () => { sqlInput.value = ''; processSQL(); sqlInput.focus(); });
  sampleBtn.addEventListener('click', () => { sqlInput.value = SAMPLES[sampleIdx % SAMPLES.length]; sampleIdx++; processSQL(); });
  copyBtn.addEventListener('click', () => {
    if (!currentFormattedSql) return;
    navigator.clipboard.writeText(currentFormattedSql).then(() => {
      copyBtn.textContent = '\u2713 Copied';
      copyBtn.classList.add('copied');
      setTimeout(() => { copyBtn.textContent = 'Copy'; copyBtn.classList.remove('copied'); }, 1500);
    });
  });
  optUppercase.addEventListener('change', processSQL);
  optIndent.addEventListener('change', processSQL);
  optLineBreakLogical.addEventListener('change', processSQL);
  optTrailingSemicolon.addEventListener('change', processSQL);

  sqlInput.value = SAMPLES[0];
  sampleIdx = 1;
  processSQL();
}

init();
</script>

