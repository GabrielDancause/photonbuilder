/* Copy button */
.copy-btn { background: #1e2030; border: 1px solid #2a2d40; color: #888; padding: 4px 12px; border-radius: 6px; font-size: 0.72rem; font-weight: 500; cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.15s; white-space: nowrap; flex-shrink: 0; }
.copy-btn:hover { background: #2a2d40; color: #ccc; }
