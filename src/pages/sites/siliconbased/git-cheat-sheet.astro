  description="Comprehensive git cheat sheet with interactive examples. Search and copy git commands for setup, staging, committing, branching, merging, remote, stashing, undoing changes, history, tags, and submodules."
  canonical="https://siliconbased.dev/git-cheat-sheet"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
var COMMANDS = {
  setup: [
    { cmd: 'git config --global user.name "[name]"', desc: 'Set your name for all repositories', flags: ['--global: apply to all repos', '--local: apply to current repo only'], example: 'git config --global user.name "Jane Doe"' },
    { cmd: 'git config --global user.email "[email]"', desc: 'Set your email for all repositories', flags: ['--global: apply to all repos'], example: 'git config --global user.email "jane@example.com"' },
    { cmd: 'git config --list', desc: 'Show all configuration settings', flags: ['--global: show global config', '--local: show repo config', '--show-origin: show config file paths'], example: 'git config --list --show-origin' },
    { cmd: 'git init', desc: 'Initialize a new git repository in the current directory', flags: ['--bare: create a bare repo (no working directory)', '-b <name>: set initial branch name'], example: 'git init -b main' },
    { cmd: 'git clone <url>', desc: 'Clone a remote repository to your local machine', flags: ['--depth <n>: shallow clone with n commits', '--branch <name>: clone a specific branch', '--recurse-submodules: clone with submodules'], example: 'git clone --depth 1 https://github.com/user/repo.git' },
    { cmd: 'git config core.editor "[editor]"', desc: 'Set the default text editor for git', flags: [], example: 'git config --global core.editor "code --wait"' },
  ],
  staging: [
    { cmd: 'git status', desc: 'Show the working tree status \u2014 modified, staged, and untracked files', flags: ['-s: short format output', '-b: show branch info in short format', '--ignored: show ignored files'], example: 'git status -sb' },
    { cmd: 'git add <file>', desc: 'Stage a file for the next commit', flags: ['-A: stage all changes (new, modified, deleted)', '-p: interactively stage hunks', '--dry-run: show what would be staged'], example: 'git add src/app.js' },
    { cmd: 'git add .', desc: 'Stage all changes in the current directory and subdirectories', flags: [], example: 'git add .' },
    { cmd: 'git reset <file>', desc: 'Unstage a file while keeping your changes', flags: [], example: 'git reset src/app.js' },
    { cmd: 'git diff', desc: 'Show unstaged changes between working directory and staging area', flags: ['--staged: show staged changes', '--stat: show diffstat summary', '--name-only: show changed file names only'], example: 'git diff --staged' },
    { cmd: 'git rm <file>', desc: 'Remove a file from working directory and stage the deletion', flags: ['--cached: remove from staging only, keep file on disk', '-r: remove directories recursively'], example: 'git rm --cached secrets.env' },
    { cmd: 'git mv <old> <new>', desc: 'Rename or move a file and stage the change', flags: [], example: 'git mv old-name.js new-name.js' },
  ],
  committing: [
    { cmd: 'git commit -m "<message>"', desc: 'Commit staged changes with a message', flags: ['-a: auto-stage tracked modified files', '--amend: modify the last commit', '--no-edit: amend without changing message', '-S: GPG-sign the commit'], example: 'git commit -m "feat: add user authentication"' },
    { cmd: 'git commit -am "<message>"', desc: 'Stage all tracked changes and commit in one step', flags: [], example: 'git commit -am "fix: resolve login redirect"' },
    { cmd: 'git commit --amend', desc: 'Modify the most recent commit (message or content)', flags: ['--no-edit: keep existing message', '-m "<msg>": replace message'], example: 'git commit --amend -m "updated commit message"' },
    { cmd: 'git commit --allow-empty -m "<msg>"', desc: 'Create a commit with no file changes (useful for CI triggers)', flags: [], example: 'git commit --allow-empty -m "trigger deploy"' },
    { cmd: 'git cherry-pick <commit>', desc: 'Apply a specific commit from another branch to the current branch', flags: ['--no-commit: apply changes without committing', '-x: append source commit hash to message'], example: 'git cherry-pick abc1234' },
  ],
  branching: [
    { cmd: 'git branch', desc: 'List all local branches', flags: ['-a: list local and remote branches', '-r: list remote branches only', '-v: show last commit on each branch', '--merged: list merged branches'], example: 'git branch -av' },
    { cmd: 'git branch <name>', desc: 'Create a new branch (does not switch to it)', flags: ['-d: delete a merged branch', '-D: force delete a branch', '-m <new>: rename current branch'], example: 'git branch feature/user-auth' },
    { cmd: 'git checkout <branch>', desc: 'Switch to an existing branch', flags: ['-b <name>: create and switch to a new branch', '--track: set up tracking for remote branch'], example: 'git checkout -b feature/user-auth' },
    { cmd: 'git switch <branch>', desc: 'Switch to an existing branch (modern alternative to checkout)', flags: ['-c <name>: create and switch', '-C <name>: create/reset and switch'], example: 'git switch -c feature/new-api' },
    { cmd: 'git branch -d <branch>', desc: 'Delete a branch that has been fully merged', flags: ['-D: force delete even if not merged'], example: 'git branch -d feature/old-feature' },
    { cmd: 'git branch -m <new-name>', desc: 'Rename the current branch', flags: [], example: 'git branch -m feature/better-name' },
  ],
  merging: [
    { cmd: 'git merge <branch>', desc: 'Merge a branch into the current branch', flags: ['--no-ff: force a merge commit even for fast-forward', '--squash: squash all commits into one', '--abort: abort a merge in progress'], example: 'git merge --no-ff feature/user-auth' },
    { cmd: 'git rebase <branch>', desc: 'Reapply commits on top of another branch', flags: ['--onto <new>: rebase onto a different base', '--abort: abort rebase in progress', '--continue: continue after resolving conflicts'], example: 'git rebase main' },
    { cmd: 'git merge --squash <branch>', desc: 'Combine all branch commits into a single staged changeset', flags: [], example: 'git merge --squash feature/user-auth && git commit -m "feat: user auth"' },
    { cmd: 'git merge --abort', desc: 'Abort a merge that has conflicts and return to pre-merge state', flags: [], example: 'git merge --abort' },
    { cmd: 'git rebase --abort', desc: 'Abort a rebase in progress and return to the original state', flags: [], example: 'git rebase --abort' },
    { cmd: 'git rebase --continue', desc: 'Continue rebase after resolving conflicts', flags: [], example: 'git rebase --continue' },
  ],
  remote: [
    { cmd: 'git remote -v', desc: 'List all remote connections with URLs', flags: [], example: 'git remote -v' },
    { cmd: 'git remote add <name> <url>', desc: 'Add a new remote repository', flags: [], example: 'git remote add origin https://github.com/user/repo.git' },
    { cmd: 'git fetch <remote>', desc: 'Download objects and refs from a remote without merging', flags: ['--all: fetch from all remotes', '--prune: remove stale remote-tracking branches', '--tags: fetch all tags'], example: 'git fetch origin --prune' },
    { cmd: 'git pull', desc: 'Fetch and merge changes from the remote tracking branch', flags: ['--rebase: rebase instead of merge', '--no-rebase: force merge even if config says rebase', '--ff-only: only fast-forward, fail otherwise'], example: 'git pull --rebase origin main' },
    { cmd: 'git push', desc: 'Upload local commits to the remote repository', flags: ['-u: set upstream tracking branch', '--force: overwrite remote history (dangerous)', '--tags: push all tags', '--delete <branch>: delete remote branch'], example: 'git push -u origin feature/user-auth' },
    { cmd: 'git push origin --delete <branch>', desc: 'Delete a branch from the remote repository', flags: [], example: 'git push origin --delete feature/old-branch' },
    { cmd: 'git remote rename <old> <new>', desc: 'Rename a remote connection', flags: [], example: 'git remote rename origin upstream' },
    { cmd: 'git remote remove <name>', desc: 'Remove a remote connection', flags: [], example: 'git remote remove upstream' },
  ],
  stashing: [
    { cmd: 'git stash', desc: 'Temporarily save all uncommitted changes', flags: ['-u: include untracked files', '-a: include untracked and ignored files', '-m "<msg>": add a description'], example: 'git stash -u -m "work in progress: login form"' },
    { cmd: 'git stash list', desc: 'List all stashed changesets', flags: [], example: 'git stash list' },
    { cmd: 'git stash pop', desc: 'Apply the most recent stash and remove it from the stash list', flags: ['stash@{n}: apply a specific stash'], example: 'git stash pop stash@{2}' },
    { cmd: 'git stash apply', desc: 'Apply a stash without removing it from the stash list', flags: ['stash@{n}: apply a specific stash'], example: 'git stash apply stash@{0}' },
    { cmd: 'git stash drop', desc: 'Remove a specific stash entry', flags: ['stash@{n}: drop a specific stash'], example: 'git stash drop stash@{1}' },
    { cmd: 'git stash clear', desc: 'Remove all stash entries', flags: [], example: 'git stash clear' },
    { cmd: 'git stash show', desc: 'Show a summary of stash changes', flags: ['-p: show full diff'], example: 'git stash show -p stash@{0}' },
  ],
  undoing: [
    { cmd: 'git reset --soft HEAD~1', desc: 'Undo last commit, keep changes staged', flags: [], example: 'git reset --soft HEAD~1' },
    { cmd: 'git reset --mixed HEAD~1', desc: 'Undo last commit, keep changes unstaged (default)', flags: [], example: 'git reset HEAD~1' },
    { cmd: 'git reset --hard HEAD~1', desc: 'Undo last commit and discard all changes permanently', flags: [], example: 'git reset --hard HEAD~1' },
    { cmd: 'git revert <commit>', desc: 'Create a new commit that undoes a previous commit', flags: ['--no-commit: apply the revert without committing', '-m 1: revert a merge commit (keep first parent)'], example: 'git revert abc1234' },
    { cmd: 'git checkout -- <file>', desc: 'Discard changes in working directory for a specific file', flags: [], example: 'git checkout -- src/app.js' },
    { cmd: 'git restore <file>', desc: 'Discard working directory changes (modern alternative)', flags: ['--staged: unstage a file', '--source <commit>: restore from a specific commit'], example: 'git restore --staged src/app.js' },
    { cmd: 'git clean -fd', desc: 'Remove untracked files and directories', flags: ['-n: dry run (show what would be removed)', '-f: force', '-d: include directories', '-x: include ignored files'], example: 'git clean -fdn' },
    { cmd: 'git reflog', desc: 'Show a log of all reference updates \u2014 useful for recovering lost commits', flags: ['--expire=<time>: prune entries older than time'], example: 'git reflog' },
  ],
  history: [
    { cmd: 'git log', desc: 'Show commit history for the current branch', flags: ['--oneline: one line per commit', '--graph: show branch graph', '--all: show all branches', '-n <num>: limit number of commits', '--author="<name>": filter by author'], example: 'git log --oneline --graph --all -20' },
    { cmd: 'git log --oneline --graph', desc: 'Show a compact, visual branch history', flags: ['--all: include all branches', '--decorate: show branch/tag names'], example: 'git log --oneline --graph --all --decorate' },
    { cmd: 'git log -p <file>', desc: 'Show the change history for a specific file with diffs', flags: ['--follow: track file renames'], example: 'git log -p --follow src/app.js' },
    { cmd: 'git blame <file>', desc: 'Show who last modified each line of a file', flags: ['-L <start>,<end>: limit to line range', '-w: ignore whitespace changes'], example: 'git blame -L 10,20 src/app.js' },
    { cmd: 'git show <commit>', desc: 'Show details and diff of a specific commit', flags: ['--stat: show diffstat only', '--name-only: show changed file names only'], example: 'git show abc1234' },
    { cmd: 'git diff <branch1>..<branch2>', desc: 'Compare two branches', flags: ['--stat: show summary', '--name-only: file names only'], example: 'git diff main..feature/auth --stat' },
    { cmd: 'git shortlog -sn', desc: 'Show commit count per author, sorted', flags: ['--all: include all branches', '--no-merges: exclude merge commits'], example: 'git shortlog -sn --all --no-merges' },
  ],
  tags: [
    { cmd: 'git tag', desc: 'List all tags', flags: ['-l "<pattern>": list tags matching a pattern', '-n: show tag messages'], example: 'git tag -l "v1.*"' },
    { cmd: 'git tag <name>', desc: 'Create a lightweight tag at the current commit', flags: [], example: 'git tag v1.0.0' },
    { cmd: 'git tag -a <name> -m "<msg>"', desc: 'Create an annotated tag with a message', flags: ['-s: GPG-sign the tag'], example: 'git tag -a v1.0.0 -m "Release version 1.0.0"' },
    { cmd: 'git tag -d <name>', desc: 'Delete a local tag', flags: [], example: 'git tag -d v1.0.0' },
    { cmd: 'git push origin <tag>', desc: 'Push a specific tag to the remote', flags: ['--tags: push all tags'], example: 'git push origin v1.0.0' },
    { cmd: 'git push origin --delete <tag>', desc: 'Delete a tag from the remote', flags: [], example: 'git push origin --delete v1.0.0' },
  ],
  submodules: [
    { cmd: 'git submodule add <url> <path>', desc: 'Add a submodule to the repository', flags: ['-b <branch>: track a specific branch'], example: 'git submodule add https://github.com/lib/utils.git lib/utils' },
    { cmd: 'git submodule init', desc: 'Initialize submodule configuration from .gitmodules', flags: [], example: 'git submodule init' },
    { cmd: 'git submodule update', desc: 'Fetch and checkout the correct submodule commits', flags: ['--init: initialize if needed', '--recursive: update nested submodules', '--remote: update to latest remote commit'], example: 'git submodule update --init --recursive' },
    { cmd: 'git submodule status', desc: 'Show the status of all submodules', flags: ['--recursive: include nested submodules'], example: 'git submodule status' },
    { cmd: 'git submodule deinit <path>', desc: 'Unregister a submodule', flags: ['-f: force removal'], example: 'git submodule deinit lib/utils' },
    { cmd: 'git clone --recurse-submodules <url>', desc: 'Clone a repository including all submodules', flags: [], example: 'git clone --recurse-submodules https://github.com/user/repo.git' },
  ]
};

function escapeHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderCard(item) {
  var flagsHtml = '';
  if (item.flags && item.flags.length > 0) {
    flagsHtml = '<div class="cmd-flags"><div class="flags-label">Common flags:</div>' +
      item.flags.map(function(f) { return '<div class="flag-item"><code>' + escapeHtml(f) + '</code></div>'; }).join('') +
      '</div>';
  }
  return '<div class="cmd-card" data-search="' + escapeHtml((item.cmd + ' ' + item.desc + ' ' + item.example + ' ' + item.flags.join(' ')).toLowerCase()) + '">' +
    '<div class="cmd-top">' +
      '<code class="cmd-syntax">' + escapeHtml(item.cmd) + '</code>' +
      '<button class="copy-btn" data-copy="' + escapeHtml(item.cmd) + '">Copy</button>' +
    '</div>' +
    '<div class="cmd-desc">' + escapeHtml(item.desc) + '</div>' +
    flagsHtml +
    '<div class="cmd-example">' +
      '<div class="example-label">Example:</div>' +
      '<div class="example-line">' +
        '<code class="example-code">' + escapeHtml(item.example) + '</code>' +
        '<button class="copy-btn copy-sm" data-copy="' + escapeHtml(item.example) + '">Copy</button>' +
      '</div>' +
    '</div>' +
  '</div>';
}

function renderAll() {
  Object.keys(COMMANDS).forEach(function(section) {
    var grid = document.getElementById('grid-' + section);
    if (!grid) return;
    grid.innerHTML = COMMANDS[section].map(renderCard).join('');
    var countEl = document.querySelector('[data-section-count="' + section + '"]');
    if (countEl) countEl.textContent = COMMANDS[section].length + ' commands';
  });
}

function filterCommands(query) {
  query = query.toLowerCase().trim();
  var totalVisible = 0;
  Object.keys(COMMANDS).forEach(function(section) {
    var grid = document.getElementById('grid-' + section);
    var sectionBlock = document.getElementById('section-' + section);
    if (!grid || !sectionBlock) return;
    var cards = grid.querySelectorAll('.cmd-card');
    var sectionVisible = 0;
    cards.forEach(function(card) {
      var searchText = card.getAttribute('data-search');
      var match = !query || searchText.indexOf(query) !== -1;
      card.style.display = match ? '' : 'none';
      if (match) sectionVisible++;
    });
    sectionBlock.style.display = sectionVisible > 0 ? '' : 'none';
    totalVisible += sectionVisible;
    var countEl = document.querySelector('[data-section-count="' + section + '"]');
    if (countEl) countEl.textContent = (query ? sectionVisible + ' / ' : '') + COMMANDS[section].length + ' commands';
  });
  // Hide workflow diagram when searching
  var workflowSection = document.getElementById('section-workflow');
  if (workflowSection) workflowSection.style.display = query ? 'none' : '';
  var searchCount = document.getElementById('searchCount');
  if (query) {
    searchCount.textContent = totalVisible + ' result' + (totalVisible !== 1 ? 's' : '');
  } else {
    searchCount.textContent = '';
  }
}

// Toggle sections
document.querySelectorAll('.section-toggle').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var section = btn.getAttribute('data-section');
    var body = document.getElementById('body-' + section);
    var icon = btn.querySelector('.toggle-icon');
    var expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    body.style.display = expanded ? 'none' : '';
    icon.innerHTML = expanded ? '&#9654;' : '&#9660;';
  });
});

// Copy buttons (event delegation)
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.copy-btn');
  if (!btn) return;
  var text = btn.getAttribute('data-copy');
  if (!text) return;
  navigator.clipboard.writeText(text).then(function() {
    btn.textContent = '\u2713 Copied';
    setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
  });
});

// Search
var searchInput = document.getElementById('searchInput');
searchInput.addEventListener('input', function() {
  filterCommands(searchInput.value);
});

// Keyboard shortcut: focus search with /
document.addEventListener('keydown', function(e) {
  if (e.key === '/' && document.activeElement !== searchInput && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
    e.preventDefault();
    searchInput.focus();
  }
});

renderAll();
</script>

