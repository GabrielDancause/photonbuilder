---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "JSONPath Tester — Query & Extract JSON Data Online",
      "url": "https://siliconbased.dev/json-path-tester",
      "description": "Free online JSONPath tester and evaluator. Write JSONPath expressions, see matched results instantly, and click any value to auto-generate its path.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is JSONPath?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "JSONPath is a query language for JSON, similar to XPath for XML. It lets you navigate and extract specific values from complex JSON structures using expressions like $.store.book[0].title or $..price to find data without manually traversing nested objects."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use a JSONPath tester?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your JSON into the input panel, type a JSONPath expression (e.g., $.users[*].name), and the tester instantly shows all matching values in the results panel. You can also click any value in the JSON tree to auto-generate its JSONPath."
          }
        },
        {
          "@type": "Question",
          "name": "What does the $ symbol mean in JSONPath?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The $ symbol represents the root element of the JSON document. Every JSONPath expression starts with $. For example, $.name accesses the 'name' property at the root level, while $.store.book accesses the 'book' array inside the 'store' object."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between dot notation and bracket notation in JSONPath?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dot notation ($.store.book) is a shorthand for accessing properties by name. Bracket notation ($['store']['book']) achieves the same result but is required when property names contain special characters, spaces, or start with a number."
          }
        },
        {
          "@type": "Question",
          "name": "How do I filter JSON arrays with JSONPath?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use filter expressions with the ?() syntax. For example, $.books[?(@.price<10)] returns all books with a price less than 10. The @ symbol refers to the current element being evaluated. You can use comparison operators like <, >, ==, !=, and logical operators."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "JSONPath Tester — Query & Extract JSON Data Online",
      "description": "Free online JSONPath tester and evaluator. Write JSONPath expressions, see matched results instantly, and click any value to auto-generate its path.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>JSONPath Tester</h1>
  <p>Write JSONPath expressions and instantly see matched values from your JSON data.</p>
</div>

<div class="main">

  <!-- Query Bar -->
  <div class="query-bar">
    <label class="query-label" for="pathInput">JSONPath Expression</label>
    <div class="query-row">
      <input type="text" id="pathInput" class="path-input" value="$" placeholder="e.g. $.store.book[*].author" spellcheck="false" />
      <button class="action-btn sample-btn" id="sampleBtn">Load Sample</button>
    </div>
  </div>

  <div class="tool-grid">
    <!-- JSON Input Pane -->
    <div class="pane">
      <div class="input-header">
        <div class="header-title">JSON Input</div>
        <div class="header-actions">
          <button class="action-btn active" id="treeViewBtn">Tree</button>
          <button class="action-btn" id="editViewBtn">Edit</button>
          <button class="action-btn" id="clearBtn">Clear</button>
        </div>
      </div>
      <div class="tree-card" id="treeCard">
        <div class="result-body">
          <div class="line-numbers" id="inputLineNumbers">1</div>
          <pre class="output-pre" id="jsonTree"></pre>
        </div>
      </div>
      <textarea id="jsonInput" class="json-input" placeholder="Paste your JSON here..." spellcheck="false" style="display:none;"></textarea>
    </div>

    <!-- Results Pane -->
    <div class="pane">
      <div class="output-header">
        <div class="header-title" id="resultStatus">Results</div>
        <div class="header-actions">
          <button class="copy-btn" id="copyBtn">Copy Results</button>
        </div>
      </div>
      <div class="output-card" id="outputCard">
        <div class="error-msg" id="errorMsg">
          <div style="display:flex; align-items:flex-start; gap:10px; flex:1;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <span id="errorText">Error</span>
          </div>
        </div>
        <div class="result-body">
          <div class="line-numbers" id="lineNumbers">1</div>
          <pre class="output-pre" id="resultOutput"></pre>
        </div>
      </div>
    </div>
  </div>

  <!-- Cheat Sheet -->
  <div class="cheat-sheet">
    <h2>JSONPath Cheat Sheet</h2>
    <div class="cheat-grid">
      <div class="cheat-item" data-expr="$">
        <code>$</code>
        <span>Root element</span>
      </div>
      <div class="cheat-item" data-expr="$.store">
        <code>.property</code>
        <span>Child property</span>
      </div>
      <div class="cheat-item" data-expr="$.store.book[*]">
        <code>[*]</code>
        <span>All elements in array</span>
      </div>
      <div class="cheat-item" data-expr="$..price">
        <code>..property</code>
        <span>Recursive descent (find anywhere)</span>
      </div>
      <div class="cheat-item" data-expr="$.store.book[0]">
        <code>[n]</code>
        <span>Array element by index</span>
      </div>
      <div class="cheat-item" data-expr="$.store.book[0:2]">
        <code>[start:end]</code>
        <span>Array slice</span>
      </div>
      <div class="cheat-item" data-expr="$.store.book[?(@.price<10)]">
        <code>[?(@.price&lt;10)]</code>
        <span>Filter expression</span>
      </div>
      <div class="cheat-item" data-expr="$.store.book[-1]">
        <code>[-1]</code>
        <span>Last element</span>
      </div>
    </div>
    <div class="cheat-queries" id="sampleQueries" style="display:none;">
      <h3>Try These Queries</h3>
      <div class="query-chips">
        <button class="query-chip" data-expr="$">$ &mdash; entire document</button>
        <button class="query-chip" data-expr="$.store.book[*].author">$.store.book[*].author</button>
        <button class="query-chip" data-expr="$..author">$..author &mdash; all authors</button>
        <button class="query-chip" data-expr="$.store.*">$.store.* &mdash; all store items</button>
        <button class="query-chip" data-expr="$..book[2]">$..book[2] &mdash; third book</button>
        <button class="query-chip" data-expr="$..book[-1]">$..book[-1] &mdash; last book</button>
        <button class="query-chip" data-expr="$..book[0:2]">$..book[0:2] &mdash; first two</button>
        <button class="query-chip" data-expr="$..book[?(@.isbn)]">$..book[?(@.isbn)] &mdash; has ISBN</button>
        <button class="query-chip" data-expr="$..book[?(@.price<10)]">$..book[?(@.price&lt;10)]</button>
        <button class="query-chip" data-expr="$..*">$..* &mdash; all values</button>
      </div>
    </div>
  </div>

  <div class="seo-content">
    <h2>What is JSONPath?</h2>
    <p>JSONPath is a query language for JSON data, originally proposed by Stefan G&ouml;ssner in 2007. It works like XPath does for XML &mdash; you write expressions that navigate and extract specific pieces of data from a JSON document. JSONPath is widely used in API testing tools like Postman, data pipelines, and configuration systems to pull values out of complex nested structures without writing custom parsing code.</p>

    <h2>JSONPath Syntax Reference</h2>
    <p>JSONPath expressions always start with <code>$</code>, which represents the root of the JSON document. From there, you use operators to drill down into the data:</p>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Operator</th>
          <th>Description</th>
          <th>Example</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>$</code></td>
          <td>Root object/element</td>
          <td><code>$</code> &mdash; returns the entire document</td>
        </tr>
        <tr>
          <td><code>.property</code></td>
          <td>Dot-notated child</td>
          <td><code>$.store.book</code></td>
        </tr>
        <tr>
          <td><code>['property']</code></td>
          <td>Bracket-notated child</td>
          <td><code>$['store']['book']</code></td>
        </tr>
        <tr>
          <td><code>[n]</code></td>
          <td>Array index (0-based)</td>
          <td><code>$.book[0]</code> &mdash; first book</td>
        </tr>
        <tr>
          <td><code>[*]</code></td>
          <td>Wildcard (all elements)</td>
          <td><code>$.book[*].title</code></td>
        </tr>
        <tr>
          <td><code>..</code></td>
          <td>Recursive descent</td>
          <td><code>$..price</code> &mdash; all prices at any depth</td>
        </tr>
        <tr>
          <td><code>[start:end]</code></td>
          <td>Array slice</td>
          <td><code>$.book[0:3]</code> &mdash; first three elements</td>
        </tr>
        <tr>
          <td><code>[?()]</code></td>
          <td>Filter expression</td>
          <td><code>$.book[?(@.price<10)]</code></td>
        </tr>
      </tbody>
    </table>

    <h2>Common Use Cases for JSONPath</h2>
    <ul>
      <li><strong>API response parsing:</strong> Extract specific fields from large JSON responses returned by REST APIs.</li>
      <li><strong>Configuration files:</strong> Query deeply nested YAML/JSON config files for specific settings.</li>
      <li><strong>Data transformation:</strong> Pull values from JSON payloads for ETL pipelines and data processing workflows.</li>
      <li><strong>Testing &amp; validation:</strong> Assert specific values in API responses using tools like Postman, REST Assured, or Karate.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is JSONPath?</h3>
      <p style="margin-bottom: 16px;">JSONPath is a query language for JSON, similar to XPath for XML. It lets you navigate and extract specific values from complex JSON structures using expressions like $.store.book[0].title or $..price to find data without manually traversing nested objects.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I use a JSONPath tester?</h3>
      <p style="margin-bottom: 16px;">Paste your JSON into the input panel, type a JSONPath expression (e.g., $.users[*].name), and the tester instantly shows all matching values in the results panel. You can also click any value in the JSON tree to auto-generate its JSONPath.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What does the $ symbol mean in JSONPath?</h3>
      <p style="margin-bottom: 16px;">The $ symbol represents the root element of the JSON document. Every JSONPath expression starts with $. For example, $.name accesses the 'name' property at the root level, while $.store.book accesses the 'book' array inside the 'store' object.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between dot notation and bracket notation in JSONPath?</h3>
      <p style="margin-bottom: 16px;">Dot notation ($.store.book) is a shorthand for accessing properties by name. Bracket notation ($['store']['book']) achieves the same result but is required when property names contain special characters, spaces, or start with a number.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I filter JSON arrays with JSONPath?</h3>
      <p style="margin-bottom: 16px;">Use filter expressions with the ?() syntax. For example, $.books[?(@.price&lt;10)] returns all books with a price less than 10. The @ symbol refers to the current element being evaluated. You can use comparison operators like &lt;, &gt;, ==, !=, and logical operators.</p>
    </div>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/json-formatter" style="color:#818cf8;">JSON Formatter &amp; Validator</a> &mdash; Format, validate, minify and fix JSON online.</li>
      <li><a href="/regex-tester" style="color:#818cf8;">Regex Tester</a> &mdash; Test regular expressions with real-time match highlighting.</li>
    </ul>
  </div>

</div>

</div>`

export const meta = {
  title: "JSONPath Tester — Query & Extract JSON Data Online",
  description: "Free online JSONPath tester and json path finder. Write JSONPath expressions, see matched results instantly, and click values to auto-generate paths.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="JSONPath Tester — Query & Extract JSON Data Online"
  description="Free online JSONPath tester and json path finder. Write JSONPath expressions, see matched results instantly, and click values to auto-generate paths."
  canonical="https://siliconbased.dev/json-path-tester"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const jsonInput = document.getElementById('jsonInput');
const jsonTree = document.getElementById('jsonTree');
const inputLineNumbers = document.getElementById('inputLineNumbers');
const resultOutput = document.getElementById('resultOutput');
const lineNumbers = document.getElementById('lineNumbers');
const errorMsg = document.getElementById('errorMsg');
const errorText = document.getElementById('errorText');
const outputCard = document.getElementById('outputCard');
const resultStatus = document.getElementById('resultStatus');
const pathInput = document.getElementById('pathInput');
const copyBtn = document.getElementById('copyBtn');
const clearBtn = document.getElementById('clearBtn');
const sampleBtn = document.getElementById('sampleBtn');
const treeCard = document.getElementById('treeCard');
const sampleQueries = document.getElementById('sampleQueries');
const treeViewBtn = document.getElementById('treeViewBtn');
const editViewBtn = document.getElementById('editViewBtn');

let debounceTimer;
let currentResults = '';
let parsedData = null;
let viewMode = 'tree';

const SAMPLE_JSON = {
  "store": {
    "book": [
      { "category": "reference", "author": "Nigel Rees", "title": "Sayings of the Century", "price": 8.95 },
      { "category": "fiction", "author": "Evelyn Waugh", "title": "Sword of Honour", "price": 12.99 },
      { "category": "fiction", "author": "Herman Melville", "title": "Moby Dick", "isbn": "0-553-21311-3", "price": 8.99 },
      { "category": "fiction", "author": "J. R. R. Tolkien", "title": "The Lord of the Rings", "isbn": "0-395-19395-8", "price": 22.99 }
    ],
    "bicycle": {
      "color": "red",
      "price": 19.95
    }
  }
};

function init() {
  jsonInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(evaluate, 200);
  });

  pathInput.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(evaluate, 200);
  });

  clearBtn.addEventListener('click', () => {
    jsonInput.value = '';
    pathInput.value = '$';
    parsedData = null;
    clearOutput();
    clearTree();
    setViewMode('edit');
    jsonInput.focus();
  });

  sampleBtn.addEventListener('click', loadSample);

  treeViewBtn.addEventListener('click', () => setViewMode('tree'));
  editViewBtn.addEventListener('click', () => setViewMode('edit'));

  copyBtn.addEventListener('click', () => {
    if (!currentResults) return;
    navigator.clipboard.writeText(currentResults).then(() => {
      copyBtn.textContent = '\u2713 Copied';
      copyBtn.classList.add('copied');
      setTimeout(() => {
        copyBtn.textContent = 'Copy Results';
        copyBtn.classList.remove('copied');
      }, 1500);
    });
  });

  // Cheat sheet items
  document.querySelectorAll('.cheat-item[data-expr]').forEach(el => {
    el.style.cursor = 'pointer';
    el.addEventListener('click', () => {
      if (!parsedData) loadSample();
      pathInput.value = el.dataset.expr;
      evaluate();
    });
  });

  // Sample query chips
  document.querySelectorAll('.query-chip[data-expr]').forEach(el => {
    el.addEventListener('click', () => {
      pathInput.value = el.dataset.expr;
      evaluate();
    });
  });

  // Load sample on first visit
  loadSample();
}

function setViewMode(mode) {
  viewMode = mode;
  treeViewBtn.classList.toggle('active', mode === 'tree');
  editViewBtn.classList.toggle('active', mode === 'edit');
  if (mode === 'edit') {
    treeCard.style.display = 'none';
    jsonInput.style.display = '';
    jsonInput.focus();
  } else {
    jsonInput.style.display = 'none';
    if (parsedData) {
      renderTree(parsedData);
    } else {
      // Try to parse current input
      try {
        const d = JSON.parse(jsonInput.value.trim());
        parsedData = d;
        renderTree(d);
      } catch(e) {
        // Can't show tree for invalid JSON, stay in edit
        setViewMode('edit');
        return;
      }
    }
  }
}

function loadSample() {
  jsonInput.value = JSON.stringify(SAMPLE_JSON, null, 2);
  pathInput.value = '$.store.book[*].author';
  sampleQueries.style.display = 'block';
  evaluate();
  setViewMode('tree');
}

function evaluate() {
  const raw = jsonInput.value.trim();
  if (!raw) {
    clearOutput();
    clearTree();
    return;
  }

  try {
    parsedData = JSON.parse(raw);
  } catch (err) {
    showError('Invalid JSON: ' + err.message);
    clearTree();
    return;
  }

  // Render tree if in tree view
  if (viewMode === 'tree') renderTree(parsedData);

  const expr = pathInput.value.trim();
  if (!expr) {
    clearOutput();
    return;
  }

  try {
    const results = jsonPath(parsedData, expr);
    if (results === false || results === null || results === undefined) {
      showError('No matches found for: ' + expr);
      return;
    }
    showResults(results);
  } catch (err) {
    showError('Invalid JSONPath: ' + err.message);
  }
}

function clearOutput() {
  resultOutput.innerHTML = '';
  lineNumbers.innerHTML = '1';
  errorMsg.style.display = 'none';
  outputCard.classList.remove('error-state');
  resultStatus.textContent = 'Results';
  resultStatus.style.color = '#ccc';
  currentResults = '';
}

function clearTree() {
  jsonTree.innerHTML = '';
  inputLineNumbers.innerHTML = '1';
  treeCard.style.display = 'none';
}

function renderTree(obj) {
  treeCard.style.display = 'flex';
  jsonTree.innerHTML = '';
  jsonTree.appendChild(buildTreeDOM(obj, '$', true, 0));
  const text = jsonTree.textContent || '';
  const count = text.split('\n').length || 1;
  let html = '';
  for (let i = 1; i <= count; i++) html += i + '<br>';
  inputLineNumbers.innerHTML = html;
}

function buildTreeDOM(obj, path, isLast, indent) {
  const container = document.createElement('span');
  const indentStr = ' '.repeat(indent);

  if (obj === null) {
    const el = document.createElement('span');
    el.className = 'hl-null tree-val';
    el.textContent = 'null' + (isLast ? '' : ',');
    el.dataset.path = path;
    el.title = path;
    el.onclick = (e) => { e.stopPropagation(); pathInput.value = path; evaluate(); };
    container.appendChild(el);
    return container;
  }

  if (typeof obj !== 'object') {
    const el = document.createElement('span');
    el.classList.add('tree-val');
    if (typeof obj === 'string') {
      el.className = 'hl-str tree-val';
      el.textContent = '"' + obj.replace(/"/g, '\\"') + '"' + (isLast ? '' : ',');
    } else if (typeof obj === 'boolean') {
      el.className = 'hl-bool tree-val';
      el.textContent = obj + (isLast ? '' : ',');
    } else {
      el.className = 'hl-num tree-val';
      el.textContent = obj + (isLast ? '' : ',');
    }
    el.dataset.path = path;
    el.title = 'Click to query: ' + path;
    el.onclick = (e) => { e.stopPropagation(); pathInput.value = path; evaluate(); };
    container.appendChild(el);
    return container;
  }

  const isArray = Array.isArray(obj);
  const keys = Object.keys(obj);

  if (keys.length === 0) {
    container.textContent = isArray ? '[]' + (isLast ? '' : ',') : '{}' + (isLast ? '' : ',');
    return container;
  }

  const open = isArray ? '[' : '{';
  const close = isArray ? ']' : '}';

  container.appendChild(document.createTextNode(open + '\n'));

  keys.forEach((key, i) => {
    const childIsLast = i === keys.length - 1;
    const childPath = isArray ? path + '[' + key + ']' : path + '.' + key;
    const childIndent = ' '.repeat(indent + 2);

    const line = document.createElement('span');
    line.appendChild(document.createTextNode(childIndent));

    if (!isArray) {
      const keyNode = document.createElement('span');
      keyNode.className = 'hl-key tree-val';
      keyNode.textContent = '"' + key + '": ';
      keyNode.dataset.path = childPath;
      keyNode.title = 'Click to query: ' + childPath;
      keyNode.onclick = (e) => { e.stopPropagation(); pathInput.value = childPath; evaluate(); };
      line.appendChild(keyNode);
    }

    line.appendChild(buildTreeDOM(obj[key], childPath, childIsLast, indent + 2));
    line.appendChild(document.createTextNode('\n'));
    container.appendChild(line);
  });

  container.appendChild(document.createTextNode(indentStr + close + (isLast ? '' : ',')));
  return container;
}

function showResults(results) {
  errorMsg.style.display = 'none';
  outputCard.classList.remove('error-state');
  resultStatus.textContent = '\u2713 ' + results.length + ' match' + (results.length !== 1 ? 'es' : '');
  resultStatus.style.color = '#4ade80';

  const formatted = JSON.stringify(results, null, 2);
  currentResults = formatted;

  resultOutput.innerHTML = syntaxHighlight(formatted);
  const count = formatted.split('\n').length || 1;
  let html = '';
  for (let i = 1; i <= count; i++) html += i + '<br>';
  lineNumbers.innerHTML = html;
}

function showError(msg) {
  errorMsg.style.display = 'flex';
  errorText.textContent = msg;
  outputCard.classList.add('error-state');
  resultStatus.textContent = 'Error';
  resultStatus.style.color = '#f87171';
  resultOutput.innerHTML = '';
  lineNumbers.innerHTML = '1';
  currentResults = '';
}

function syntaxHighlight(json) {
  json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
    let cls = 'hl-num';
    if (/^"/.test(match)) {
      cls = /:$/.test(match) ? 'hl-key' : 'hl-str';
    } else if (/true|false/.test(match)) {
      cls = 'hl-bool';
    } else if (/null/.test(match)) {
      cls = 'hl-null';
    }
    return '<span class="' + cls + '">' + match + '</span>';
  });
}

// ── Minimal JSONPath implementation ──
function jsonPath(obj, expr) {
  if (!obj || !expr) return false;

  const walk = function(obj, parts) {
    if (parts.length === 0) return [obj];

    const part = parts[0];
    const rest = parts.slice(1);
    let results = [];

    if (part === '$') {
      return walk(obj, rest);
    }

    if (part === '..') {
      // Recursive descent - next part is the property to find
      if (rest.length === 0) return [obj];
      const target = rest[0];
      const afterTarget = rest.slice(1);

      const recurse = function(current) {
        if (current === null || typeof current !== 'object') return;

        // Handle wildcard after ..
        if (target === '*') {
          if (Array.isArray(current)) {
            current.forEach(v => {
              results = results.concat(walk(v, afterTarget));
            });
          } else {
            Object.values(current).forEach(v => {
              results = results.concat(walk(v, afterTarget));
            });
          }
        }
        // Handle filter after ..
        else if (target.match(/^\[.*\]$/)) {
          // Array or filter operation
          const inner = target.slice(1, -1);
          if (Array.isArray(current)) {
            const matched = applyBracket(current, inner);
            matched.forEach(v => {
              results = results.concat(walk(v, afterTarget));
            });
          }
        }
        // Named property
        else if (current.hasOwnProperty && current.hasOwnProperty(target)) {
          results = results.concat(walk(current[target], afterTarget));
        }

        // Continue recursing
        if (Array.isArray(current)) {
          current.forEach(recurse);
        } else if (typeof current === 'object' && current !== null) {
          Object.values(current).forEach(recurse);
        }
      };
      recurse(obj);
      return results;
    }

    if (obj === null || typeof obj !== 'object') return [];

    // Wildcard
    if (part === '*') {
      const values = Array.isArray(obj) ? obj : Object.values(obj);
      values.forEach(v => {
        results = results.concat(walk(v, rest));
      });
      return results;
    }

    // Bracket expression: [n], [start:end], [*], [?(@...)]
    const bracketMatch = part.match(/^\[(.+)\]$/);
    if (bracketMatch) {
      const inner = bracketMatch[1];
      const matched = applyBracket(obj, inner);
      matched.forEach(v => {
        results = results.concat(walk(v, rest));
      });
      return results;
    }

    // Plain property or index
    if (Array.isArray(obj)) {
      const idx = parseInt(part, 10);
      if (!isNaN(idx)) {
        const realIdx = idx < 0 ? obj.length + idx : idx;
        if (realIdx >= 0 && realIdx < obj.length) {
          return walk(obj[realIdx], rest);
        }
      }
      return [];
    }

    if (obj.hasOwnProperty && obj.hasOwnProperty(part)) {
      return walk(obj[part], rest);
    }

    return [];
  };

  const applyBracket = function(arr, inner) {
    if (!Array.isArray(arr)) return [];

    // Wildcard
    if (inner === '*') return arr.slice();

    // Filter: ?(@.price<10)
    const filterMatch = inner.match(/^\?\(@\.(.+?)\s*(==|!=|<|>|<=|>=)\s*(.+)\)$/);
    if (filterMatch) {
      const prop = filterMatch[1];
      const op = filterMatch[2];
      let val = filterMatch[3].trim();
      // Parse value
      if (val === 'true') val = true;
      else if (val === 'false') val = false;
      else if (val === 'null') val = null;
      else if (val.match(/^["'].*["']$/)) val = val.slice(1, -1);
      else if (!isNaN(Number(val))) val = Number(val);

      return arr.filter(item => {
        if (item === null || typeof item !== 'object') return false;
        const v = item[prop];
        if (v === undefined) return false;
        switch(op) {
          case '==': return v == val;
          case '!=': return v != val;
          case '<': return v < val;
          case '>': return v > val;
          case '<=': return v <= val;
          case '>=': return v >= val;
        }
        return false;
      });
    }

    // Existence filter: ?(@.isbn)
    const existsMatch = inner.match(/^\?\(@\.(.+)\)$/);
    if (existsMatch) {
      const prop = existsMatch[1];
      return arr.filter(item => item !== null && typeof item === 'object' && item.hasOwnProperty(prop));
    }

    // Slice: start:end
    const sliceMatch = inner.match(/^(-?\d*):(-?\d*)$/);
    if (sliceMatch) {
      const start = sliceMatch[1] === '' ? 0 : parseInt(sliceMatch[1], 10);
      const end = sliceMatch[2] === '' ? arr.length : parseInt(sliceMatch[2], 10);
      return arr.slice(start, end);
    }

    // Single index
    const idx = parseInt(inner, 10);
    if (!isNaN(idx)) {
      const realIdx = idx < 0 ? arr.length + idx : idx;
      if (realIdx >= 0 && realIdx < arr.length) return [arr[realIdx]];
    }

    return [];
  };

  // Preprocess expression: handle bracket expressions inline
  // Convert [?(...)] and [n:m] and [*] into tokens
  const tokens = [];
  let i = 0;
  const e = expr;
  while (i < e.length) {
    if (e[i] === '[') {
      const end = e.indexOf(']', i);
      if (end === -1) break;
      tokens.push(e.substring(i, end + 1));
      i = end + 1;
      if (e[i] === '.') i++; // skip trailing dot
    } else if (e[i] === '.') {
      if (e[i+1] === '.') {
        tokens.push('..');
        i += 2;
      } else {
        i++;
      }
    } else {
      let end = i;
      while (end < e.length && e[end] !== '.' && e[end] !== '[') end++;
      tokens.push(e.substring(i, end));
      i = end;
    }
  }

  const result = walk(obj, tokens);
  if (!result || result.length === 0) return false;
  return result;
}

