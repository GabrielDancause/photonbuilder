---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "JSONPath Tester & Query Tool",
      "url": "https://siliconbased.dev/json-path-tester",
      "description": "Test JSONPath expressions against your JSON data in real time. Supports wildcards, recursive descent, array slicing, and filter expressions.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "GAB Ventures",
        "url": "https://gab.ae"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is JSONPath?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "JSONPath is a query language for JSON, similar to XPath for XML. It allows you to navigate and extract specific values from a JSON document using path expressions like $.store.book[0].title or $..author to find all authors recursively."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use a JSONPath tester online?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paste your JSON data into the input field, type a JSONPath expression like $.store.book[*].title in the query box, and the tool instantly highlights and displays the matched values. You can also click nodes in the tree view to auto-generate the path."
          }
        },
        {
          "@type": "Question",
          "name": "What JSONPath syntax is supported?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Common JSONPath syntax includes: $ (root), .key (child), ..key (recursive descent), [*] (wildcard), [0] (array index), [0:3] (array slice), and [?(@.price<10)] (filter expressions). These cover the vast majority of real-world querying needs."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between JSONPath and jq?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "JSONPath and jq both query JSON data but have different syntax. JSONPath uses dot notation like $.store.book[0], while jq uses pipe-based syntax like .store.book[0]. JSONPath is commonly used in REST APIs and testing tools, while jq is a command-line tool popular in shell scripts."
          }
        },
        {
          "@type": "Question",
          "name": "Can JSONPath filter JSON arrays?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. JSONPath supports filter expressions with the syntax [?(@.field operator value)]. For example, $.store.book[?(@.price<10)] returns all books cheaper than 10, and $.users[?(@.active==true)] returns only active users."
          }
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "JSONPath Tester: Query & Extract JSON Data Online",
      "description": "Test JSONPath expressions against your JSON data in real time. Supports wildcards, recursive descent, array slicing, and filter expressions.",
      "datePublished": "2026-03-21T00:00:00Z",
      "publisher": {
        "@type": "Organization",
        "name": "siliconbased.dev",
        "url": "https://siliconbased.dev"
      }
    }
  ]
};

const htmlBody = `<div class="page-content">
<div class="hero">
  <h1>JSONPath Tester</h1>
  <p>Query and extract data from JSON using JSONPath expressions — live results as you type.</p>
</div>

<div class="main">

  <!-- Query Bar -->
  <div class="query-bar">
    <div class="query-label">JSONPath</div>
    <input type="text" id="pathInput" class="path-input" value="$.store.book[*].title" placeholder="Enter JSONPath expression, e.g. $.store.book[*]" spellcheck="false" />
    <button class="action-btn" id="examplesToggle">Examples</button>
  </div>

  <!-- Example Queries Dropdown -->
  <div class="examples-panel" id="examplesPanel">
    <div class="examples-grid">
      <button class="example-btn" data-path="$.store.book[*].title">$.store.book[*].title<span>All book titles</span></button>
      <button class="example-btn" data-path="$..author">$..author<span>All authors (recursive)</span></button>
      <button class="example-btn" data-path="$.store.book[0]">$.store.book[0]<span>First book</span></button>
      <button class="example-btn" data-path="$.store.book[-1]">$.store.book[-1]<span>Last book</span></button>
      <button class="example-btn" data-path="$.store.book[0:2]">$.store.book[0:2]<span>First two books</span></button>
      <button class="example-btn" data-path="$.store.book[?(@.price<10)]">$.store.book[?(@.price&lt;10)]<span>Books under $10</span></button>
      <button class="example-btn" data-path="$.store.book[?(@.isbn)]">$.store.book[?(@.isbn)]<span>Books with ISBN</span></button>
      <button class="example-btn" data-path="$.store.*">$.store.*<span>All items in store</span></button>
      <button class="example-btn" data-path="$..price">$..price<span>All prices</span></button>
      <button class="example-btn" data-path="$.store.book.length">$.store.book.length<span>Book count</span></button>
    </div>
  </div>

  <div class="tool-grid">
    <!-- Input Pane -->
    <div class="pane">
      <div class="input-header">
        <div class="header-title">JSON Input</div>
        <div class="header-actions">
          <button class="action-btn" id="formatBtn">Format</button>
          <button class="action-btn" id="sampleBtn">Load Sample</button>
          <button class="action-btn" id="clearBtn">Clear</button>
        </div>
      </div>
      <textarea id="jsonInput" class="json-input" placeholder="Paste your JSON here..." spellcheck="false"></textarea>
      <div class="error-bar" id="errorBar"></div>
    </div>

    <!-- Results Pane -->
    <div class="pane">
      <div class="output-header">
        <div class="header-title" id="resultStatus">Results</div>
        <div class="header-actions">
          <button class="copy-btn" id="copyBtn">Copy Results</button>
        </div>
      </div>
      <div class="output-card" id="outputCard">
        <div class="result-body">
          <pre class="output-pre" id="resultOutput"><span class="placeholder-text">Enter a JSONPath expression above to see matched values here.</span></pre>
        </div>
      </div>
    </div>
  </div>

  <!-- Tree View -->
  <div class="tree-section">
    <div class="input-header">
      <div class="header-title">Tree View <span class="tree-hint">Click any node to copy its JSONPath</span></div>
    </div>
    <div class="tree-card" id="treeCard">
      <div class="tree-body" id="treeBody">
        <span class="placeholder-text">Paste valid JSON above to see the tree view.</span>
      </div>
    </div>
  </div>

  <!-- Quick Reference -->
  <div class="ref-section">
    <h2>JSONPath Quick Reference</h2>
    <div class="ref-grid">
      <div class="ref-card">
        <div class="ref-expr">$</div>
        <div class="ref-desc">Root object</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">.key</div>
        <div class="ref-desc">Child property</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">..key</div>
        <div class="ref-desc">Recursive descent — find all</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">[*]</div>
        <div class="ref-desc">Wildcard — all elements</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">[0]</div>
        <div class="ref-desc">Array index (0-based)</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">[-1]</div>
        <div class="ref-desc">Last array element</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">[0:3]</div>
        <div class="ref-desc">Array slice (start:end)</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">[0:5:2]</div>
        <div class="ref-desc">Slice with step</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">[?(@.price&lt;10)]</div>
        <div class="ref-desc">Filter expression</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">[?(@.isbn)]</div>
        <div class="ref-desc">Existence check</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">.length</div>
        <div class="ref-desc">Array / string length</div>
      </div>
      <div class="ref-card">
        <div class="ref-expr">.*</div>
        <div class="ref-desc">All children of current node</div>
      </div>
    </div>
  </div>

  <div class="seo-content">
    <h2>What is JSONPath?</h2>
    <p>JSONPath is a query language for JSON data, originally proposed by Stefan Goessner as the JSON equivalent of XPath for XML. It lets you navigate deeply nested JSON structures and extract exactly the values you need using concise path expressions. JSONPath is widely supported in API testing tools like Postman, REST-assured, and Karate, as well as in programming languages through libraries like Jayway JSONPath (Java), jsonpath-ng (Python), and jsonpath-plus (JavaScript).</p>

    <h2>JSONPath vs XPath vs jq</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Feature</th>
          <th>JSONPath</th>
          <th>XPath</th>
          <th>jq</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Data format</strong></td>
          <td>JSON</td>
          <td>XML</td>
          <td>JSON</td>
        </tr>
        <tr>
          <td><strong>Root</strong></td>
          <td><code>$</code></td>
          <td><code>/</code></td>
          <td><code>.</code></td>
        </tr>
        <tr>
          <td><strong>Child access</strong></td>
          <td><code>.key</code> or <code>['key']</code></td>
          <td><code>/key</code></td>
          <td><code>.key</code></td>
        </tr>
        <tr>
          <td><strong>Recursive</strong></td>
          <td><code>..key</code></td>
          <td><code>//key</code></td>
          <td><code>.. | .key?</code></td>
        </tr>
        <tr>
          <td><strong>Filters</strong></td>
          <td><code>[?(@.x>1)]</code></td>
          <td><code>[x>1]</code></td>
          <td><code>select(.x>1)</code></td>
        </tr>
      </tbody>
    </table>

    <h2>Common JSONPath Use Cases</h2>
    <ul>
      <li><strong>API response extraction:</strong> Pull specific fields from large REST API responses for testing or transformation.</li>
      <li><strong>Configuration lookup:</strong> Navigate deep config files to find specific settings without writing custom parsing code.</li>
      <li><strong>Data transformation:</strong> Select subsets of JSON data for ETL pipelines, reporting, or feeding into other tools.</li>
      <li><strong>Automated testing:</strong> Assert specific values in API responses using JSONPath in test frameworks like Postman, REST-assured, or Cypress.</li>
      <li><strong>Log analysis:</strong> Extract structured data from JSON-formatted application logs for debugging and monitoring.</li>
    </ul>

    <h2>JSONPath Syntax Guide</h2>
    <h3>Basic Navigation</h3>
    <p>Every JSONPath expression starts with <code>$</code> representing the root. Use dot notation (<code>$.store.name</code>) or bracket notation (<code>$['store']['name']</code>) to traverse objects. For arrays, use zero-based indices: <code>$.items[0]</code> gets the first element, <code>$.items[-1]</code> gets the last.</p>

    <h3>Wildcards and Recursive Descent</h3>
    <p>The wildcard <code>[*]</code> selects all elements in an array or all values of an object. The recursive descent operator <code>..</code> searches the entire tree: <code>$..name</code> finds every <code>name</code> property at any depth. Combine them for powerful queries like <code>$..*</code> to list every value in the document.</p>

    <h3>Filter Expressions</h3>
    <p>Filter expressions use <code>[?()]</code> syntax with <code>@</code> representing the current element. Supported operators include <code>==</code>, <code>!=</code>, <code>&lt;</code>, <code>&gt;</code>, <code>&lt;=</code>, <code>&gt;=</code>. You can check existence (<code>[?(@.isbn)]</code>) or compare values (<code>[?(@.price&lt;10)]</code>). String comparisons should use quotes: <code>[?(@.color=='red')]</code>.</p>

    <h2>Related Tools</h2>
    <ul>
      <li><a href="/json-formatter">JSON Formatter & Validator</a> — Format, validate, minify, and fix JSON data.</li>
      <li><a href="/regex-tester">Regex Tester</a> — Test and debug regular expressions with real-time matching.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>
    <div style="margin-top: 24px;">
      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is JSONPath?</h3>
      <p style="margin-bottom: 16px;">JSONPath is a query language for JSON, similar to XPath for XML. It allows you to navigate and extract specific values from a JSON document using path expressions like $.store.book[0].title or $..author to find all authors recursively.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">How do I use a JSONPath tester online?</h3>
      <p style="margin-bottom: 16px;">Paste your JSON data into the input field, type a JSONPath expression like $.store.book[*].title in the query box, and the tool instantly highlights and displays the matched values. You can also click nodes in the tree view to auto-generate the path.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What JSONPath syntax is supported?</h3>
      <p style="margin-bottom: 16px;">Common JSONPath syntax includes: $ (root), .key (child), ..key (recursive descent), [*] (wildcard), [0] (array index), [0:3] (array slice), and [?(@.price&lt;10)] (filter expressions). These cover the vast majority of real-world querying needs.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">What is the difference between JSONPath and jq?</h3>
      <p style="margin-bottom: 16px;">JSONPath and jq both query JSON data but have different syntax. JSONPath uses dot notation like $.store.book[0], while jq uses pipe-based syntax like .store.book[0]. JSONPath is commonly used in REST APIs and testing tools, while jq is a command-line tool popular in shell scripts.</p>

      <h3 style="margin: 16px 0 8px; font-size: 1.1rem; color: #e0e0e0;">Can JSONPath filter JSON arrays?</h3>
      <p style="margin-bottom: 16px;">Yes. JSONPath supports filter expressions with the syntax [?(@.field operator value)]. For example, $.store.book[?(@.price&lt;10)] returns all books cheaper than 10, and $.users[?(@.active==true)] returns only active users.</p>
    </div>
  </div>

</div>

</div>`;

export const meta = {
  title: "JSONPath Tester — Query, Extract & Test JSON Paths Online",
  description: "Test JSONPath expressions against JSON data in real time. Supports wildcards, recursive descent, filters, array slicing, and click-to-copy path from tree view.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="siliconbased"
  title="JSONPath Tester — Query, Extract & Test JSON Paths Online"
  description="Test JSONPath expressions against JSON data in real time. Supports wildcards, recursive descent, filters, array slicing, and click-to-copy path from tree view."
  canonical="https://siliconbased.dev/json-path-tester"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const jsonInput = document.getElementById('jsonInput');
const pathInput = document.getElementById('pathInput');
const resultOutput = document.getElementById('resultOutput');
const resultStatus = document.getElementById('resultStatus');
const errorBar = document.getElementById('errorBar');
const treeBody = document.getElementById('treeBody');
const copyBtn = document.getElementById('copyBtn');
const clearBtn = document.getElementById('clearBtn');
const formatBtn = document.getElementById('formatBtn');
const sampleBtn = document.getElementById('sampleBtn');
const examplesToggle = document.getElementById('examplesToggle');
const examplesPanel = document.getElementById('examplesPanel');

const SAMPLE_JSON = {
  "store": {
    "book": [
      { "category": "reference", "author": "Nigel Rees", "title": "Sayings of the Century", "price": 8.95 },
      { "category": "fiction", "author": "Evelyn Waugh", "title": "Sword of Honour", "price": 12.99 },
      { "category": "fiction", "author": "Herman Melville", "title": "Moby Dick", "isbn": "0-553-21311-3", "price": 8.99 },
      { "category": "fiction", "author": "J. R. R. Tolkien", "title": "The Lord of the Rings", "isbn": "0-395-19395-8", "price": 22.99 }
    ],
    "bicycle": {
      "color": "red",
      "price": 19.95
    }
  }
};

let debounceTimer;
let currentResults = '';

// ─── JSONPath Engine ───────────────────────────────────────────
function jsonpath(obj, expr) {
  if (typeof expr !== 'string' || !expr.startsWith('$')) return [];
  const results = [];
  const tokens = tokenize(expr.substring(1));
  resolve(obj, tokens, 0, results);
  return results;
}

function tokenize(expr) {
  const tokens = [];
  let i = 0;
  while (i < expr.length) {
    if (expr[i] === '.') {
      if (expr[i + 1] === '.') {
        tokens.push({ type: 'recursive' });
        i += 2;
      } else {
        i++;
        if (expr[i] === '*') {
          tokens.push({ type: 'wildcard' });
          i++;
        } else {
          let key = '';
          while (i < expr.length && expr[i] !== '.' && expr[i] !== '[') {
            key += expr[i++];
          }
          if (key === 'length') {
            tokens.push({ type: 'length' });
          } else if (key) {
            tokens.push({ type: 'child', key: key });
          }
        }
      }
    } else if (expr[i] === '[') {
      i++;
      let inner = '';
      let depth = 1;
      while (i < expr.length && depth > 0) {
        if (expr[i] === '[') depth++;
        else if (expr[i] === ']') { depth--; if (depth === 0) break; }
        inner += expr[i++];
      }
      i++; // skip ]
      inner = inner.trim();
      if (inner === '*') {
        tokens.push({ type: 'wildcard' });
      } else if (inner.startsWith('?')) {
        tokens.push({ type: 'filter', expr: inner.substring(1).trim() });
      } else if (inner.includes(':')) {
        const parts = inner.split(':').map(s => s.trim());
        tokens.push({ type: 'slice', start: parts[0], end: parts[1], step: parts[2] || '' });
      } else if (inner.startsWith("'") || inner.startsWith('"')) {
        tokens.push({ type: 'child', key: inner.slice(1, -1) });
      } else {
        const idx = parseInt(inner, 10);
        if (!isNaN(idx)) {
          tokens.push({ type: 'index', index: idx });
        } else {
          tokens.push({ type: 'child', key: inner });
        }
      }
    } else {
      i++;
    }
  }
  return tokens;
}

function resolve(obj, tokens, ti, results) {
  if (ti >= tokens.length) {
    results.push(obj);
    return;
  }
  if (obj === null || obj === undefined) return;
  const token = tokens[ti];

  if (token.type === 'child') {
    if (typeof obj === 'object' && obj !== null && token.key in obj) {
      resolve(obj[token.key], tokens, ti + 1, results);
    }
  } else if (token.type === 'index') {
    if (Array.isArray(obj)) {
      const idx = token.index < 0 ? obj.length + token.index : token.index;
      if (idx >= 0 && idx < obj.length) {
        resolve(obj[idx], tokens, ti + 1, results);
      }
    }
  } else if (token.type === 'wildcard') {
    if (typeof obj === 'object' && obj !== null) {
      const keys = Array.isArray(obj) ? obj.map((_, i) => i) : Object.keys(obj);
      for (const k of keys) {
        resolve(obj[k], tokens, ti + 1, results);
      }
    }
  } else if (token.type === 'recursive') {
    if (ti + 1 < tokens.length) {
      const next = tokens[ti + 1];
      if (next.type === 'wildcard') {
        resolveRecursiveWild(obj, tokens, ti + 2, results);
      } else {
        resolveRecursive(obj, tokens, ti + 1, results);
      }
    } else {
      descendAll(obj, results);
    }
  } else if (token.type === 'slice') {
    if (Array.isArray(obj)) {
      const len = obj.length;
      let start = token.start === '' ? 0 : parseInt(token.start, 10);
      let end = token.end === '' ? len : parseInt(token.end, 10);
      let step = token.step === '' ? 1 : parseInt(token.step, 10);
      if (start < 0) start = Math.max(0, len + start);
      if (end < 0) end = Math.max(0, len + end);
      if (end > len) end = len;
      if (step < 1) step = 1;
      for (let i = start; i < end; i += step) {
        resolve(obj[i], tokens, ti + 1, results);
      }
    }
  } else if (token.type === 'filter') {
    if (Array.isArray(obj)) {
      for (const item of obj) {
        if (evalFilter(item, token.expr)) {
          resolve(item, tokens, ti + 1, results);
        }
      }
    }
  } else if (token.type === 'length') {
    if (Array.isArray(obj)) {
      results.push(obj.length);
    } else if (typeof obj === 'string') {
      results.push(obj.length);
    }
  }
}

function resolveRecursive(obj, tokens, ti, results) {
  resolve(obj, tokens, ti, results);
  if (typeof obj === 'object' && obj !== null) {
    const keys = Array.isArray(obj) ? obj.map((_, i) => i) : Object.keys(obj);
    for (const k of keys) {
      resolveRecursive(obj[k], tokens, ti, results);
    }
  }
}

function resolveRecursiveWild(obj, tokens, ti, results) {
  if (typeof obj === 'object' && obj !== null) {
    const keys = Array.isArray(obj) ? obj.map((_, i) => i) : Object.keys(obj);
    for (const k of keys) {
      resolve(obj[k], tokens, ti, results);
      resolveRecursiveWild(obj[k], tokens, ti, results);
    }
  }
}

function descendAll(obj, results) {
  if (typeof obj === 'object' && obj !== null) {
    const keys = Array.isArray(obj) ? obj.map((_, i) => i) : Object.keys(obj);
    for (const k of keys) {
      results.push(obj[k]);
      descendAll(obj[k], results);
    }
  }
}

function evalFilter(item, expr) {
  let inner = expr.trim();
  if (inner.startsWith('(') && inner.endsWith(')')) {
    inner = inner.slice(1, -1).trim();
  }
  if (!inner.startsWith('@')) return false;

  const opsRe = /^@\.([a-zA-Z0-9_]+)\s*(==|!=|<=|>=|<|>)\s*(.+)$/;
  const match = inner.match(opsRe);
  if (!match) {
    const fieldMatch = inner.match(/^@\.([a-zA-Z0-9_]+)$/);
    if (fieldMatch && typeof item === 'object' && item !== null) {
      return fieldMatch[1] in item;
    }
    return false;
  }

  const field = match[1];
  const op = match[2];
  let value = match[3].trim();

  if (typeof item !== 'object' || item === null || !(field in item)) return false;
  const fieldVal = item[field];

  let cmpVal;
  if ((value.startsWith("'") && value.endsWith("'")) || (value.startsWith('"') && value.endsWith('"'))) {
    cmpVal = value.slice(1, -1);
  } else if (value === 'true') {
    cmpVal = true;
  } else if (value === 'false') {
    cmpVal = false;
  } else if (value === 'null') {
    cmpVal = null;
  } else {
    cmpVal = parseFloat(value);
    if (isNaN(cmpVal)) cmpVal = value;
  }

  switch (op) {
    case '==': return fieldVal == cmpVal;
    case '!=': return fieldVal != cmpVal;
    case '<': return fieldVal < cmpVal;
    case '>': return fieldVal > cmpVal;
    case '<=': return fieldVal <= cmpVal;
    case '>=': return fieldVal >= cmpVal;
    default: return false;
  }
}

// ─── UI Logic ──────────────────────────────────────────────────

function init() {
  jsonInput.value = JSON.stringify(SAMPLE_JSON, null, 2);

  jsonInput.addEventListener('input', debounceRun);
  pathInput.addEventListener('input', debounceRun);

  clearBtn.addEventListener('click', () => {
    jsonInput.value = '';
    errorBar.style.display = 'none';
    resultOutput.innerHTML = '<span class="placeholder-text">Enter JSON and a JSONPath expression to see results.</span>';
    resultStatus.textContent = 'Results';
    resultStatus.style.color = '#ccc';
    treeBody.innerHTML = '<span class="placeholder-text">Paste valid JSON above to see the tree view.</span>';
    currentResults = '';
  });

  formatBtn.addEventListener('click', () => {
    try {
      const parsed = JSON.parse(jsonInput.value);
      jsonInput.value = JSON.stringify(parsed, null, 2);
      errorBar.style.display = 'none';
    } catch (e) { /* ignore */ }
  });

  sampleBtn.addEventListener('click', () => {
    jsonInput.value = JSON.stringify(SAMPLE_JSON, null, 2);
    runQuery();
  });

  copyBtn.addEventListener('click', () => {
    if (!currentResults) return;
    navigator.clipboard.writeText(currentResults).then(() => {
      copyBtn.textContent = '\u2713 Copied';
      copyBtn.classList.add('copied');
      setTimeout(() => {
        copyBtn.textContent = 'Copy Results';
        copyBtn.classList.remove('copied');
      }, 1500);
    });
  });

  examplesToggle.addEventListener('click', () => {
    examplesPanel.classList.toggle('open');
    examplesToggle.classList.toggle('active');
  });

  document.querySelectorAll('.example-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      pathInput.value = btn.dataset.path;
      examplesPanel.classList.remove('open');
      examplesToggle.classList.remove('active');
      runQuery();
    });
  });

  runQuery();
}

function debounceRun() {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(runQuery, 200);
}

function runQuery() {
  const raw = jsonInput.value.trim();
  if (!raw) {
    errorBar.style.display = 'none';
    resultOutput.innerHTML = '<span class="placeholder-text">Enter JSON and a JSONPath expression to see results.</span>';
    resultStatus.textContent = 'Results';
    resultStatus.style.color = '#ccc';
    treeBody.innerHTML = '<span class="placeholder-text">Paste valid JSON above to see the tree view.</span>';
    currentResults = '';
    return;
  }

  let parsed;
  try {
    parsed = JSON.parse(raw);
    errorBar.style.display = 'none';
    jsonInput.classList.remove('error-border');
  } catch (e) {
    errorBar.style.display = 'block';
    errorBar.textContent = 'Invalid JSON: ' + e.message;
    jsonInput.classList.add('error-border');
    resultOutput.innerHTML = '<span class="placeholder-text">Fix the JSON errors to run queries.</span>';
    resultStatus.textContent = 'Results';
    resultStatus.style.color = '#ccc';
    treeBody.innerHTML = '<span class="placeholder-text">Fix the JSON errors to see the tree view.</span>';
    currentResults = '';
    return;
  }

  buildTree(parsed);

  const expr = pathInput.value.trim();
  if (!expr) {
    resultOutput.innerHTML = '<span class="placeholder-text">Enter a JSONPath expression above to see matched values here.</span>';
    resultStatus.textContent = 'Results';
    resultStatus.style.color = '#ccc';
    currentResults = '';
    return;
  }

  try {
    const matches = jsonpath(parsed, expr);
    if (matches.length === 0) {
      resultOutput.innerHTML = '<span class="no-match">No matches found for this expression.</span>';
      resultStatus.textContent = '0 matches';
      resultStatus.style.color = '#f87171';
      currentResults = '';
    } else {
      const formatted = JSON.stringify(matches.length === 1 ? matches[0] : matches, null, 2);
      currentResults = formatted;
      resultOutput.innerHTML = syntaxHighlight(formatted);
      resultStatus.textContent = matches.length + ' match' + (matches.length === 1 ? '' : 'es');
      resultStatus.style.color = '#4ade80';
    }
  } catch (e) {
    resultOutput.innerHTML = '<span class="no-match">Invalid JSONPath expression.</span>';
    resultStatus.textContent = 'Error';
    resultStatus.style.color = '#f87171';
    currentResults = '';
  }
}

function syntaxHighlight(json) {
  const escaped = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return escaped.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
    let cls = 'hl-num';
    if (/^"/.test(match)) {
      cls = /:$/.test(match) ? 'hl-key' : 'hl-str';
    } else if (/true|false/.test(match)) {
      cls = 'hl-bool';
    } else if (/null/.test(match)) {
      cls = 'hl-null';
    }
    return '<span class="' + cls + '">' + match + '</span>';
  });
}

// ─── Tree View ─────────────────────────────────────────────────

function buildTree(obj) {
  treeBody.innerHTML = '';
  const root = createTreeNode('$', obj, '$', true);
  treeBody.appendChild(root);
}

function createTreeNode(key, value, path, isRoot) {
  const node = document.createElement('div');
  node.className = 'tree-node';

  const row = document.createElement('div');
  row.className = 'tree-row';

  if (typeof value === 'object' && value !== null) {
    const isArr = Array.isArray(value);
    const keys = Object.keys(value);
    const toggle = document.createElement('span');
    toggle.className = 'tree-toggle open';
    toggle.textContent = '\u25BE';
    row.appendChild(toggle);

    const keyEl = document.createElement('span');
    keyEl.className = 'tree-key';
    keyEl.textContent = isRoot ? '$' : key;
    row.appendChild(keyEl);

    const badge = document.createElement('span');
    badge.className = 'tree-badge';
    badge.textContent = isArr ? '[' + keys.length + ']' : '{' + keys.length + '}';
    row.appendChild(badge);

    row.addEventListener('click', (e) => {
      e.stopPropagation();
      copyPathToClipboard(path, row);
    });

    node.appendChild(row);

    const children = document.createElement('div');
    children.className = 'tree-children';
    keys.forEach((k) => {
      const childPath = isArr ? path + '[' + k + ']' : path + '.' + k;
      children.appendChild(createTreeNode(k, value[k], childPath, false));
    });
    node.appendChild(children);

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = toggle.classList.toggle('open');
      children.style.display = open ? 'block' : 'none';
      toggle.textContent = open ? '\u25BE' : '\u25B8';
    });
  } else {
    const spacer = document.createElement('span');
    spacer.className = 'tree-spacer';
    row.appendChild(spacer);

    const keyEl = document.createElement('span');
    keyEl.className = 'tree-key';
    keyEl.textContent = key;
    row.appendChild(keyEl);

    const sep = document.createElement('span');
    sep.className = 'tree-sep';
    sep.textContent = ': ';
    row.appendChild(sep);

    const valEl = document.createElement('span');
    if (value === null) {
      valEl.className = 'hl-null';
      valEl.textContent = 'null';
    } else if (typeof value === 'string') {
      valEl.className = 'hl-str';
      valEl.textContent = '"' + value + '"';
    } else if (typeof value === 'boolean') {
      valEl.className = 'hl-bool';
      valEl.textContent = String(value);
    } else {
      valEl.className = 'hl-num';
      valEl.textContent = String(value);
    }
    row.appendChild(valEl);

    row.addEventListener('click', (e) => {
      e.stopPropagation();
      copyPathToClipboard(path, row);
    });

    node.appendChild(row);
  }

  return node;
}

function copyPathToClipboard(path, rowEl) {
  pathInput.value = path;
  navigator.clipboard.writeText(path).then(() => {
    rowEl.classList.add('copied-flash');
    setTimeout(() => rowEl.classList.remove('copied-flash'), 800);
  });
  runQuery();
}

init();
</script>

