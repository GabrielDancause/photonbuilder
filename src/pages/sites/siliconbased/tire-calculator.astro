---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Tire Size Calculator & Speedometer Comparison",
  description: "Comparing tire sizes? Uncover exact differences in diameter, circumference, and speedometer readings before you buy a new set of wheels.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.published,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I read my tire size?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tire size is printed on the sidewall in a format like 225/65R17. The first number (225) is the width in millimeters. The second number (65) is the aspect ratio (the sidewall height is 65% of the width). The 'R' means Radial construction. The last number (17) is the wheel/rim diameter in inches."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I put bigger tires on my car?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bigger tires (larger overall diameter) will cause your speedometer to read slower than your actual speed. They also act as a taller gear, which can decrease acceleration. Additionally, you must ensure the larger tires have enough clearance in the wheel wells to avoid rubbing when turning or going over bumps."
        }
      },
      {
        "@type": "Question",
        "name": "What is aspect ratio on a tire?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The aspect ratio is the percentage of the tire's width that determines the height of the sidewall. For example, a 65 aspect ratio on a 225mm wide tire means the sidewall is 65% of 225mm (about 146mm) tall. Lower numbers indicate lower profile tires."
        }
      },
      {
        "@type": "Question",
        "name": "How much difference in tire size is acceptable?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A general rule of thumb is to stay within a 3% difference in overall diameter compared to the original factory tires. Exceeding this 3% margin can cause significant issues with brake performance, transmission shifting, ABS calibration, and speedometer accuracy."
        }
      },
      {
        "@type": "Question",
        "name": "Why is my speedometer wrong with new tires?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Speedometers are calibrated from the factory based on the revolutions per mile of the stock tire size. If your new tires have a larger or smaller circumference, they will rotate a different number of times over a mile. The vehicle's computer still expects the old number of rotations, leading to an inaccurate reading."
        }
      }
    ]
  }
];
---
<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/tire-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Tire Size Calculator</h1>
      <p class="subtitle">Compare two tire sizes to see the difference in diameter, circumference, and speedometer readings.</p>
    </div>

    <div class="calculator-container">
      <div class="tire-grid">
        <div class="tire-input-section">
          <h3>Tire 1 (Current)</h3>
          <div class="input-row">
            <div class="input-group">
              <label for="width1">Width (mm)</label>
              <input type="number" id="width1" value="225" min="100" max="400" step="5" />
            </div>
            <div class="input-divider">/</div>
            <div class="input-group">
              <label for="aspect1">Aspect Ratio</label>
              <input type="number" id="aspect1" value="65" min="20" max="90" step="5" />
            </div>
            <div class="input-divider">R</div>
            <div class="input-group">
              <label for="rim1">Rim (in)</label>
              <input type="number" id="rim1" value="17" min="10" max="30" step="1" />
            </div>
          </div>
          <div id="error1" class="error-message" style="display: none; color: #ef4444; font-size: 0.875rem; margin-top: 0.5rem;">Please enter valid dimensions.</div>
        </div>

        <div class="tire-input-section">
          <h3>Tire 2 (New)</h3>
          <div class="input-row">
            <div class="input-group">
              <label for="width2">Width (mm)</label>
              <input type="number" id="width2" value="245" min="100" max="400" step="5" />
            </div>
            <div class="input-divider">/</div>
            <div class="input-group">
              <label for="aspect2">Aspect Ratio</label>
              <input type="number" id="aspect2" value="60" min="20" max="90" step="5" />
            </div>
            <div class="input-divider">R</div>
            <div class="input-group">
              <label for="rim2">Rim (in)</label>
              <input type="number" id="rim2" value="18" min="10" max="30" step="1" />
            </div>
          </div>
          <div id="error2" class="error-message" style="display: none; color: #ef4444; font-size: 0.875rem; margin-top: 0.5rem;">Please enter valid dimensions.</div>
        </div>
      </div>

      <div id="results" class="result-card" style="display: none;">
        <h3>Comparison Results</h3>
        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Dimension</th>
                <th>Tire 1</th>
                <th>Tire 2</th>
                <th>Difference</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Diameter (in)</td>
                <td id="dia1">-</td>
                <td id="dia2">-</td>
                <td id="diaDiff">-</td>
              </tr>
              <tr>
                <td>Circumference (in)</td>
                <td id="circ1">-</td>
                <td id="circ2">-</td>
                <td id="circDiff">-</td>
              </tr>
              <tr>
                <td>Sidewall (in)</td>
                <td id="wall1">-</td>
                <td id="wall2">-</td>
                <td id="wallDiff">-</td>
              </tr>
              <tr>
                <td>Revs per Mile</td>
                <td id="rev1">-</td>
                <td id="rev2">-</td>
                <td id="revDiff">-</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="speedometer-box">
          <h4>Speedometer Reading</h4>
          <p>When your speedometer reads <strong>60 mph</strong>, your actual speed will be: <span id="actualSpeed" class="highlight-speed">-</span></p>
        </div>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding Tire Sizes and the Math Behind the Calculator</h2>

      <p>Upgrading or changing your vehicle's tires is a common practice among car enthusiasts and everyday drivers alike. Whether you are looking for improved performance, a better stance, or need a replacement set that differs slightly from your original equipment, understanding tire sizing is paramount. A change in tire dimensions does not just affect the physical appearance of the wheel; it has significant implications for your vehicle's speedometer accuracy, gearing, suspension clearance, and overall safety. The Tire Size Calculator is an essential tool designed to help you decode these alphanumeric dimensions and visualize exactly how a new tire compares to your current setup.</p>

      <h3>Decoding the Alphanumeric Tire Code</h3>
      <p>The sequence of numbers and letters on the sidewall of a tire (e.g., 225/65R17) might seem like a complex code, but it follows a standard, logical format used globally. Breaking down this code is the first step in understanding tire sizing:</p>
      <ul>
        <li><strong>Width (e.g., 225):</strong> The first number in the sequence represents the nominal section width of the tire in millimeters. This is the measurement from sidewall to sidewall when the tire is mounted on a standardized rim and fully inflated. A wider tire generally provides more grip and a larger contact patch with the road.</li>
        <li><strong>Aspect Ratio (e.g., 65):</strong> The second number, following the slash, is the aspect ratio. This is a crucial, often misunderstood figure, as it is a percentage rather than a direct measurement. It represents the height of the tire's sidewall as a percentage of its width. For instance, an aspect ratio of 65 means the sidewall height is 65% of the tire's width (which is 225mm). Lower aspect ratios typically indicate a lower-profile tire, often found on sports cars, offering stiffer sidewalls and better handling, albeit sometimes at the expense of ride comfort.</li>
        <li><strong>Construction Type (e.g., R):</strong> The letter usually following the aspect ratio indicates the tire's internal construction. 'R' stands for Radial, which is the industry standard for virtually all modern passenger vehicles. Other letters like 'D' (Diagonal/Bias Ply) or 'B' (Belted) exist but are rare in contemporary consumer applications.</li>
        <li><strong>Rim Diameter (e.g., 17):</strong> The final number indicates the diameter of the wheel (rim) the tire is designed to fit, measured in inches. This is a critical measurement; you cannot mount a tire designed for a 17-inch rim on an 18-inch wheel.</li>
      </ul>

      <h3>The Mathematics of Tire Dimensions</h3>
      <p>To accurately compare two different tires, we must convert these mixed metric and imperial measurements into a standardized unit, typically inches, to calculate the overall diameter and circumference. The calculations involved, while straightforward, can be tedious to perform manually. This is where our calculator shines, executing the following mathematical steps instantly:</p>
      <p><strong>Step 1: Calculating Sidewall Height.</strong> First, we find the sidewall height by multiplying the tire's width (in millimeters) by its aspect ratio (as a decimal). For example, a 225/65 tire has a sidewall height of 225 * 0.65 = 146.25 millimeters. To convert this to inches, we divide by 25.4 (since there are 25.4 mm in an inch), resulting in a sidewall height of approximately 5.76 inches.</p>
      <p><strong>Step 2: Calculating Overall Diameter.</strong> The overall diameter of the tire is composed of the rim diameter plus two sidewall heights (the top and the bottom). The formula is: Overall Diameter = Rim Diameter + (2 * Sidewall Height). Using our previous figures for a 17-inch rim: 17 + (2 * 5.76) = 28.52 inches.</p>
      <p><strong>Step 3: Calculating Circumference.</strong> Once we have the diameter, finding the circumference (the distance the tire travels in one full rotation) requires basic geometry. We multiply the diameter by Pi (π, approximately 3.14159). For our example: 28.52 * 3.14159 = 89.60 inches. This figure is crucial for understanding how the tire interacts with the road over a given distance.</p>
      <p><strong>Step 4: Revolutions Per Mile.</strong> Finally, to understand gearing and speedometer calibration, we calculate the revolutions per mile. There are 63,360 inches in a mile. By dividing 63,360 by the tire's circumference, we determine how many times the tire rotates over a one-mile distance. In our example: 63,360 / 89.60 = 707.14 revolutions per mile.</p>

      <h3>The Impact of Tire Size Changes on Your Vehicle</h3>
      <p>Altering your tire size beyond the manufacturer's recommendations can have a domino effect on various vehicle systems. The most immediate and noticeable impact is on your speedometer and odometer. These instruments are calibrated at the factory based on the revolutions per mile of the stock tire size. When you install a larger diameter tire, it travels further per revolution than the computer expects. Consequently, your speedometer will read slower than your actual speed, which can lead to inadvertent speeding tickets. Conversely, a smaller tire will make your speedometer read faster than you are actually traveling.</p>
      <p>Beyond instrumentation, a significant change in tire diameter acts as a gearing change for your vehicle. A larger tire effectively tallies your gearing, which can reduce acceleration and low-end torque but may lower cruising RPMs on the highway. A smaller tire lowers gearing, potentially improving acceleration but increasing RPMs at cruising speeds, which can negatively impact fuel economy and increase engine wear.</p>
      <p>Furthermore, physical clearance is a paramount concern. A tire that is too wide or too tall may rub against suspension components, the inner wheel well, or the fenders, especially during tight turns or when the suspension is fully compressed over bumps. This rubbing can cause severe damage to the tire and the vehicle. Always verify that a new tire size will physically fit within your vehicle's wheel wells without interference before making a purchase.</p>

      <h3>Conclusion</h3>
      <p>While upgrading tires can enhance the look and performance of your vehicle, it is not a decision that should be made blindly. Using a Tire Size Calculator takes the guesswork out of the equation, providing you with precise data on how a new setup will alter critical dimensions and affect your vehicle's systems. By understanding the alphanumeric code, the underlying mathematics, and the potential impacts on speedometers and gearing, you can make informed, confident decisions when selecting your next set of tires.</p>

    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>

      <details>
        <summary>How do I read my tire size?</summary>
        <p>The tire size is printed on the sidewall in a format like 225/65R17. The first number (225) is the width in millimeters. The second number (65) is the aspect ratio (the sidewall height is 65% of the width). The 'R' means Radial construction. The last number (17) is the wheel/rim diameter in inches.</p>
      </details>
      <details>
        <summary>What happens if I put bigger tires on my car?</summary>
        <p>Bigger tires (larger overall diameter) will cause your speedometer to read slower than your actual speed. They also act as a taller gear, which can decrease acceleration. Additionally, you must ensure the larger tires have enough clearance in the wheel wells to avoid rubbing when turning or going over bumps.</p>
      </details>
      <details>
        <summary>What is aspect ratio on a tire?</summary>
        <p>The aspect ratio is the percentage of the tire's width that determines the height of the sidewall. For example, a 65 aspect ratio on a 225mm wide tire means the sidewall is 65% of 225mm (about 146mm) tall. Lower numbers indicate lower profile tires.</p>
      </details>
      <details>
        <summary>How much difference in tire size is acceptable?</summary>
        <p>A general rule of thumb is to stay within a 3% difference in overall diameter compared to the original factory tires. Exceeding this 3% margin can cause significant issues with brake performance, transmission shifting, ABS calibration, and speedometer accuracy.</p>
      </details>
      <details>
        <summary>Why is my speedometer wrong with new tires?</summary>
        <p>Speedometers are calibrated from the factory based on the revolutions per mile of the stock tire size. If your new tires have a larger or smaller circumference, they will rotate a different number of times over a mile. The vehicle's computer still expects the old number of rotations, leading to an inaccurate reading.</p>
      </details>

    </section>

    <div class="related-tools" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color);">
      <h2>Related Tools</h2>
      <p>Need to calculate grades? Use our <a href="/grading-calculator">Grading Calculator</a>.</p>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = {
        w1: document.getElementById('width1'),
        a1: document.getElementById('aspect1'),
        r1: document.getElementById('rim1'),
        w2: document.getElementById('width2'),
        a2: document.getElementById('aspect2'),
        r2: document.getElementById('rim2')
      };

      const error1 = document.getElementById('error1');
      const error2 = document.getElementById('error2');
      const resultsDiv = document.getElementById('results');

      const elements = {
        dia1: document.getElementById('dia1'),
        dia2: document.getElementById('dia2'),
        diaDiff: document.getElementById('diaDiff'),
        circ1: document.getElementById('circ1'),
        circ2: document.getElementById('circ2'),
        circDiff: document.getElementById('circDiff'),
        wall1: document.getElementById('wall1'),
        wall2: document.getElementById('wall2'),
        wallDiff: document.getElementById('wallDiff'),
        rev1: document.getElementById('rev1'),
        rev2: document.getElementById('rev2'),
        revDiff: document.getElementById('revDiff'),
        actualSpeed: document.getElementById('actualSpeed')
      };

      function calculateTire(w, a, r) {
        // Sidewall height in inches = (Width(mm) * AspectRatio(%)) / 25.4
        const sidewall = (w * (a / 100)) / 25.4;
        const diameter = r + (sidewall * 2);
        const circumference = diameter * Math.PI;
        const revsPerMile = 63360 / circumference;

        return { sidewall, diameter, circumference, revsPerMile };
      }

      function formatNum(num) {
        return num.toFixed(2);
      }

      function getDiffStr(val1, val2, isPercent = false) {
        const diff = val2 - val1;
        const sign = diff >= 0 ? '+' : '';
        if (isPercent) {
          const pct = (diff / val1) * 100;
          return `${sign}${pct.toFixed(1)}%`;
        }
        return `${sign}${diff.toFixed(2)}`;
      }

      function validateInput() {
        let valid1 = true;
        let valid2 = true;

        const w1 = parseFloat(inputs.w1.value);
        const a1 = parseFloat(inputs.a1.value);
        const r1 = parseFloat(inputs.r1.value);

        const w2 = parseFloat(inputs.w2.value);
        const a2 = parseFloat(inputs.a2.value);
        const r2 = parseFloat(inputs.r2.value);

        if (isNaN(w1) || isNaN(a1) || isNaN(r1) || w1 < 100 || a1 < 20 || r1 < 10) {
          valid1 = false;
        }
        if (isNaN(w2) || isNaN(a2) || isNaN(r2) || w2 < 100 || a2 < 20 || r2 < 10) {
          valid2 = false;
        }

        error1.style.display = valid1 ? 'none' : 'block';
        error2.style.display = valid2 ? 'none' : 'block';

        if (valid1 && valid2) {
          calculateCompare(w1, a1, r1, w2, a2, r2);
          resultsDiv.style.display = 'block';
        } else {
          resultsDiv.style.display = 'none';
        }
      }

      function calculateCompare(w1, a1, r1, w2, a2, r2) {
        const t1 = calculateTire(w1, a1, r1);
        const t2 = calculateTire(w2, a2, r2);

        elements.dia1.textContent = formatNum(t1.diameter);
        elements.dia2.textContent = formatNum(t2.diameter);
        elements.diaDiff.textContent = getDiffStr(t1.diameter, t2.diameter, true);

        elements.circ1.textContent = formatNum(t1.circumference);
        elements.circ2.textContent = formatNum(t2.circumference);
        elements.circDiff.textContent = getDiffStr(t1.circumference, t2.circumference, true);

        elements.wall1.textContent = formatNum(t1.sidewall);
        elements.wall2.textContent = formatNum(t2.sidewall);
        elements.wallDiff.textContent = getDiffStr(t1.sidewall, t2.sidewall, true);

        elements.rev1.textContent = Math.round(t1.revsPerMile);
        elements.rev2.textContent = Math.round(t2.revsPerMile);

        const revDiff = t2.revsPerMile - t1.revsPerMile;
        const revDiffPct = (revDiff / t1.revsPerMile) * 100;
        elements.revDiff.textContent = `${revDiff >= 0 ? '+' : ''}${revDiffPct.toFixed(1)}%`;

        // Speedometer reading (assume calibrated to tire 1, reading 60mph)
        // Actual speed = 60 * (T2 Circumference / T1 Circumference)
        const speedRatio = t2.circumference / t1.circumference;
        const actualSpeedAt60 = 60 * speedRatio;
        elements.actualSpeed.textContent = `${actualSpeedAt60.toFixed(1)} mph`;
      }

      // Initial calculation
      validateInput();

      // Add event listeners
      Object.values(inputs).forEach(input => {
        input.addEventListener('input', validateInput);
      });
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .tire-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
    @media (max-width: 768px) { .tire-grid { grid-template-columns: 1fr; } }

    .tire-input-section h3 { margin-bottom: 1rem; color: var(--accent-color); font-size: 1.2rem; }
    .input-row { display: flex; align-items: flex-end; gap: 0.5rem; }
    .input-group { flex: 1; }
    .input-group label { display: block; margin-bottom: 0.25rem; font-weight: 600; font-size: 0.85rem; color: var(--text-secondary); }
    .input-divider { font-size: 1.5rem; font-weight: bold; padding-bottom: 0.5rem; color: var(--text-secondary); }

    input { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 0.5rem; border-radius: 8px; width: 100%; font-size: 1rem; text-align: center; }
    input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .result-card { background: color-mix(in srgb, var(--accent-color) 5%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; margin-top: 2rem; }
    .result-card h3 { text-align: center; margin-bottom: 1.5rem; }

    .comparison-table-wrapper { overflow-x: auto; margin-bottom: 1.5rem; }
    .comparison-table { width: 100%; border-collapse: collapse; text-align: right; }
    .comparison-table th, .comparison-table td { padding: 0.75rem; border-bottom: 1px solid var(--border-color); }
    .comparison-table th { text-align: right; font-weight: 600; color: var(--text-secondary); }
    .comparison-table th:first-child, .comparison-table td:first-child { text-align: left; font-weight: 600; }

    .speedometer-box { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; text-align: center; }
    .speedometer-box h4 { margin-bottom: 0.5rem; color: var(--text-secondary); }
    .highlight-speed { font-size: 1.5rem; font-weight: 800; color: var(--accent-color); display: inline-block; margin-left: 0.5rem; }

    .explainer { margin: 3rem 0; line-height: 1.7; }
    .explainer h2, .explainer h3 { margin-top: 2rem; margin-bottom: 1rem; }
    .explainer p { margin-bottom: 1rem; }
    .explainer ul { margin-bottom: 1rem; padding-left: 1.5rem; }
    .explainer li { margin-bottom: 0.5rem; }

    .faq-section { margin: 3rem 0; }
    .faq-section h2 { margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; list-style-position: inside; }
    .faq-section details p { margin-top: 1rem; color: var(--text-secondary); line-height: 1.6; }

    .related-tools a { color: var(--accent-color); text-decoration: none; font-weight: 600; }
    .related-tools a:hover { text-decoration: underline; }
  </style>
</SiteLayout>
