---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "The Wedding Planner | Budget & Timeline Calculator",
  description: "Plan your perfect wedding without the stress. Our interactive wedding planner helps you allocate your budget intelligently and generate a personalized planning timeline.",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How is a typical wedding budget divided?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A standard wedding budget generally allocates 40-50% to the venue and catering, 10-15% to photography and videography, 8-10% to attire and beauty, 8-10% to flowers and decor, 8-10% to entertainment, and the remainder split among stationary, transportation, gifts, and a contingency fund."
          }
        },
        {
          "@type": "Question",
          "name": "Why do I need a contingency fund for my wedding?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A contingency fund of at least 5% is highly recommended because unexpected expenses almost always arise during wedding planning. This covers things like sudden guest additions, forgotten vendor meals, extra postage, or last-minute setup charges."
          }
        },
        {
          "@type": "Question",
          "name": "What is considered a realistic wedding budget in 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The national average cost of a wedding fluctuates, but in major metropolitan areas, a typical full-scale wedding often ranges from $30,000 to $40,000+. However, a realistic budget is entirely dependent on your financial situation, guest count, and the style of event you desire."
          }
        },
        {
          "@type": "Question",
          "name": "How does prioritizing a specific category change the budget?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If you prioritize photography, for example, the calculator increases the standard 10% allocation to 15% or higher to match premium vendor rates, and proportionally reduces spending in lower-priority areas like decor or stationary to keep the total budget balanced."
          }
        },
        {
          "@type": "Question",
          "name": "Does the venue budget include food and alcohol?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "In our standard calculation, the 'Venue & Catering' category encompasses the site rental fee, all food, and the bar service. If you choose a venue that requires outside catering, this total percentage should simply be split between the venue fee and your chosen caterer."
          }
        }
      ]
    },
    {
      "@type": "SoftwareApplication",
      "name": "The Wedding Planner Calculator",
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": "Any",
      "description": "Calculate wedding budget allocations based on standard industry percentages and user priorities."
    },
    {
      "@type": "Article",
      "headline": "The Wedding Planner: Budget & Timeline Calculator",
      "description": "Plan your perfect wedding without the stress. Our interactive wedding planner helps you allocate your budget intelligently and generate a personalized planning timeline.",
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      }
    }
  ]
};
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/the-wedding-planner" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>The Wedding Planner</h1>
      <p class="subtitle">Enter your total budget and priority level to instantly generate a standard vendor allocation breakdown.</p>
    </div>

    <div class="calculator-container">
      <div class="input-row">
        <div class="input-group">
          <label for="totalBudget">Total Expected Budget</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="totalBudget" class="has-prefix" min="1000" step="500" value="30000" placeholder="e.g. 30000">
          </div>
        </div>

        <div class="input-group">
          <label for="priority">Main Priority / Splurge</label>
          <select id="priority">
            <option value="balanced" selected>Balanced (Standard Allocation)</option>
            <option value="venue">Venue & Food (Epic Party)</option>
            <option value="photo">Photography & Video (Memories)</option>
            <option value="floral">Florals & Decor (Aesthetics)</option>
            <option value="attire">Attire & Beauty (Fashion)</option>
            <option value="entertainment">Band / DJ (Entertainment)</option>
          </select>
        </div>
      </div>

      <div class="budget-results" id="resultsContainer">
        <!-- Results injected via JS -->
      </div>

      <div class="total-row">
        <div class="cat-name">Total Budgeted</div>
        <div class="cat-amount" id="totalAmountDisplay">$0</div>
      </div>
    </div>

    <div class="explainer">
      <h2>Wedding Budget Methodology & Formulas</h2>
      <p>Creating a wedding budget is often the most stressful part of the planning process. Without a clear framework, it is incredibly easy to overspend on early vendor bookings (like the venue or photographer) and find yourself without enough funds for later expenses (like alterations, tips, or transportation). This calculator uses standard industry percentages to create a safe, balanced starting point for your financial planning.</p>

      <h3>Standard Budget Allocation</h3>
      <p>If you select a "Balanced" priority, the calculator utilizes the standard breakdown recommended by professional wedding planners. This baseline ensures all bases are covered:</p>
      <ul>
        <li><strong>Venue, Catering & Bar (45%):</strong> This is the largest chunk of any wedding budget. It covers the physical space, all food, alcohol, staffing, and often basic rentals like tables and chairs.</li>
        <li><strong>Photography & Videography (12%):</strong> Professional documentation of the day.</li>
        <li><strong>Attire & Beauty (9%):</strong> The wedding dress, suit/tuxedo, alterations, hair, and makeup.</li>
        <li><strong>Florals & Decor (8%):</strong> Bouquets, boutonnieres, centerpieces, and atmospheric lighting.</li>
        <li><strong>Entertainment (8%):</strong> A live band or a professional DJ, plus ceremony musicians.</li>
        <li><strong>Stationery & Favors (4%):</strong> Save-the-dates, invitations, postage, menus, and guest favors.</li>
        <li><strong>Rings & Officiant (4%):</strong> Wedding bands and the legal/ceremonial officiant fees.</li>
        <li><strong>Transportation & Hotel (5%):</strong> Getting the wedding party to the venue and accommodation for the night of the wedding.</li>
        <li><strong>Contingency Fund (5%):</strong> A non-negotiable safety net for unexpected costs, vendor meals, tips, and taxes.</li>
      </ul>

      <h3>How Priority Adjustments Work</h3>
      <p>Very few couples stick perfectly to the balanced baseline; most have specific priorities they want to splurge on. When you select a priority in the calculator, a dynamic adjustment algorithm alters the percentages.</p>

      <p>The math behind the adjustment works by increasing the allocation of the selected priority category by a specific weight (usually adding 4-8% to its base), and then proportionally reducing the remaining non-essential categories to ensure the total budget still equals exactly 100%.</p>

      <h4>The Priority Formulas</h4>
      <ul>
        <li><strong>Venue & Food Priority:</strong> Increases Venue/Catering to <strong>53%</strong>. Reduces Florals, Stationary, and Transportation to compensate.</li>
        <li><strong>Photography Priority:</strong> Increases Photo/Video to <strong>18%</strong>. Reduces Venue slightly, and cuts into Decor and Stationary.</li>
        <li><strong>Florals Priority:</strong> Increases Florals/Decor to <strong>15%</strong>. Pulls funds from Attire, Stationary, and Entertainment.</li>
        <li><strong>Attire Priority:</strong> Increases Attire/Beauty to <strong>15%</strong>. Reduces Venue, Decor, and Favors.</li>
        <li><strong>Entertainment Priority:</strong> Increases Entertainment to <strong>14%</strong> (suitable for a high-end live band). Reduces Florals and Stationary.</li>
      </ul>
      <p><em>Note: The 5% Contingency Fund is hard-coded and will never be reduced by a priority shift. It is essential to keep this intact.</em></p>

      <h3>Managing the "Contingency"</h3>
      <p>The 5% contingency fund calculated here should physically exist in your bank account, but mentally be treated as non-existent during vendor negotiations. Do not allocate this money to a specific vendor early in the process. It is required for things like:</p>
      <ul>
        <li>Service charges and gratuities (which can add 20% to catering bills).</li>
        <li>Postage for unusually heavy invitation suites.</li>
        <li>Vendor meals (you must feed your photographer, DJ, and coordinator).</li>
        <li>Last-minute weather contingencies (tents, umbrellas).</li>
      </ul>

      <h3>Navigating Hidden Fees and Service Charges</h3>
      <p>When reviewing initial vendor quotes, especially from venues and caterers, couples frequently overlook taxes and mandatory service charges. A venue might quote a catering package at $150 per person, but a standard 20-22% service charge and local taxes can easily inflate that number to $195 per person. When you use this calculator, remember that the "Venue & Catering" allocation must include these additional fees, not just the base price. Always ask vendors for an 'out-the-door' estimate before signing a contract to ensure the actual cost fits within your calculated percentage.</p>

      <h3>Maximizing Your Floral and Decor Budget</h3>
      <p>Florals are notorious for causing sticker shock. If you find your floral allocation is too tight for the aesthetic you want, consider repurposing ceremony arrangements for the reception. For instance, the floral arch or pillars used at the altar can often be moved to frame the sweetheart table, and bridesmaids' bouquets can double as centerpieces. Additionally, opting for in-season, locally sourced blooms rather than imported exotics can dramatically reduce costs without sacrificing visual impact.</p>

      <h3>The Entertainment Dilemma: Band vs. DJ</h3>
      <p>Your choice of entertainment significantly impacts both the vibe of the reception and your budget allocation. A live band will typically cost anywhere from three to five times more than a professional DJ due to the number of musicians, equipment, and required setup time. If live music is a non-negotiable priority, you should select the "Entertainment Priority" in the calculator, which adjusts the percentages to safely afford a quality band. If you opt for a DJ, the standard 8-10% allocation is usually more than enough, and any surplus can be rolled into other categories like an upgraded bar package or late-night snacks.</p>

      <h3>Understanding Planners vs. Coordinators</h3>
      <p>You may notice that a dedicated "Wedding Planner" category is not explicitly separated out in the standard baseline. Full-service wedding planners generally charge a flat fee or a percentage of the total wedding cost (often 10-15%). If you are hiring a full-service planner, their fee should be accounted for before running these numbers, or pulled proportionally from multiple categories. However, a Day-Of or Month-Of Coordinator is much more affordable and is absolutely essential for executing the timeline. Their fee is often pulled from the Contingency fund or the Venue/Catering allocation if the venue provides one.</p>

      <h3>The Importance of Tipping and Gratuities</h3>
      <p>Tipping is an often-forgotten line item that can easily add thousands of dollars to your final bill. While some vendors (like a catering company) may include a built-in gratuity or service charge, others (like your independent photographer, hair and makeup artists, or the delivery team for your rentals) will expect a standard tip. We highly recommend factoring these tips into your contingency fund from day one. Prepare cash envelopes a week before the wedding and hand them to your Day-Of Coordinator to distribute, ensuring you aren't scrambling for ATMs on the morning of your event.</p>

      <p>By treating the generated numbers as a strict cap per category, you can confidently navigate vendor meetings knowing exactly what you can afford without jeopardizing the rest of the event.</p>

      <div class="cross-link-box" style="margin-top: 3rem; padding: 1.5rem; background: var(--card-bg); border-left: 4px solid var(--accent-color); border-radius: 4px;">
        <h4 style="margin-top: 0; color: var(--text-primary);">Fueling your late-night planning sessions?</h4>
        <p style="margin-bottom: 0;">If you're making frequent coffee runs to keep up with seating charts and vendor emails, check out our <a href="/starbucks-calorie-calculator" style="color: var(--accent-color); font-weight: 600; text-decoration: none;">Starbucks Calorie Calculator</a> to track the exact nutritional impact of your custom caffeine orders.</p>
      </div>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How is a typical wedding budget divided?</summary>
        <p>A standard wedding budget generally allocates 40-50% to the venue and catering, 10-15% to photography and videography, 8-10% to attire and beauty, 8-10% to flowers and decor, 8-10% to entertainment, and the remainder split among stationary, transportation, gifts, and a contingency fund.</p>
      </details>
      <details>
        <summary>Why do I need a contingency fund for my wedding?</summary>
        <p>A contingency fund of at least 5% is highly recommended because unexpected expenses almost always arise during wedding planning. This covers things like sudden guest additions, forgotten vendor meals, extra postage, or last-minute setup charges. Without it, you will likely go over budget.</p>
      </details>
      <details>
        <summary>What is considered a realistic wedding budget in 2026?</summary>
        <p>The national average cost of a wedding fluctuates, but in major metropolitan areas, a typical full-scale wedding often ranges from $30,000 to $40,000+. However, a realistic budget is entirely dependent on your financial situation, guest count, and the style of event you desire. Micro-weddings can easily be done for under $10,000.</p>
      </details>
      <details>
        <summary>How does prioritizing a specific category change the budget?</summary>
        <p>If you prioritize photography, for example, the calculator increases the standard 12% allocation to 18% to match premium vendor rates, and proportionally reduces spending in lower-priority areas like decor or stationary to keep the total budget balanced at 100%.</p>
      </details>
      <details>
        <summary>Does the venue budget include food and alcohol?</summary>
        <p>In our standard calculation, the 'Venue & Catering' category encompasses the site rental fee, all food, and the open bar service. If you choose a venue that requires outside catering (often called a 'raw space'), this total percentage should simply be split between the venue fee and your chosen caterer.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const budgetInput = document.getElementById('totalBudget');
      const prioritySelect = document.getElementById('priority');
      const resultsContainer = document.getElementById('resultsContainer');
      const totalDisplay = document.getElementById('totalAmountDisplay');

      // Formatter for currency
      const formatCurrency = (amount) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0
        }).format(amount);
      };

      // Base percentage allocations (Must equal 1.0)
      const baseAllocations = {
        venue: { name: "Venue, Catering & Bar", pct: 0.45 },
        photo: { name: "Photography & Video", pct: 0.12 },
        attire: { name: "Attire & Beauty", pct: 0.09 },
        floral: { name: "Florals & Decor", pct: 0.08 },
        entertainment: { name: "Entertainment (DJ/Band)", pct: 0.08 },
        stationary: { name: "Stationery & Favors", pct: 0.04 },
        rings: { name: "Rings & Officiant", pct: 0.04 },
        transport: { name: "Transportation & Hotel", pct: 0.05 },
        contingency: { name: "Contingency / Emergency", pct: 0.05 } // Always fixed
      };

      // Adjusted matrices based on priority selection
      const priorityMatrices = {
        balanced: { ...baseAllocations },
        venue: {
          venue: { name: "Venue, Catering & Bar", pct: 0.53 },
          photo: { name: "Photography & Video", pct: 0.11 },
          attire: { name: "Attire & Beauty", pct: 0.08 },
          floral: { name: "Florals & Decor", pct: 0.06 },
          entertainment: { name: "Entertainment (DJ/Band)", pct: 0.07 },
          stationary: { name: "Stationery & Favors", pct: 0.03 },
          rings: { name: "Rings & Officiant", pct: 0.04 },
          transport: { name: "Transportation & Hotel", pct: 0.03 },
          contingency: { name: "Contingency / Emergency", pct: 0.05 }
        },
        photo: {
          venue: { name: "Venue, Catering & Bar", pct: 0.42 },
          photo: { name: "Photography & Video", pct: 0.18 },
          attire: { name: "Attire & Beauty", pct: 0.08 },
          floral: { name: "Florals & Decor", pct: 0.07 },
          entertainment: { name: "Entertainment (DJ/Band)", pct: 0.07 },
          stationary: { name: "Stationery & Favors", pct: 0.03 },
          rings: { name: "Rings & Officiant", pct: 0.04 },
          transport: { name: "Transportation & Hotel", pct: 0.06 },
          contingency: { name: "Contingency / Emergency", pct: 0.05 }
        },
        floral: {
          venue: { name: "Venue, Catering & Bar", pct: 0.43 },
          photo: { name: "Photography & Video", pct: 0.11 },
          attire: { name: "Attire & Beauty", pct: 0.07 },
          floral: { name: "Florals & Decor", pct: 0.15 },
          entertainment: { name: "Entertainment (DJ/Band)", pct: 0.07 },
          stationary: { name: "Stationery & Favors", pct: 0.03 },
          rings: { name: "Rings & Officiant", pct: 0.04 },
          transport: { name: "Transportation & Hotel", pct: 0.05 },
          contingency: { name: "Contingency / Emergency", pct: 0.05 }
        },
        attire: {
          venue: { name: "Venue, Catering & Bar", pct: 0.42 },
          photo: { name: "Photography & Video", pct: 0.11 },
          attire: { name: "Attire & Beauty", pct: 0.15 },
          floral: { name: "Florals & Decor", pct: 0.07 },
          entertainment: { name: "Entertainment (DJ/Band)", pct: 0.08 },
          stationary: { name: "Stationery & Favors", pct: 0.04 },
          rings: { name: "Rings & Officiant", pct: 0.04 },
          transport: { name: "Transportation & Hotel", pct: 0.04 },
          contingency: { name: "Contingency / Emergency", pct: 0.05 }
        },
        entertainment: {
          venue: { name: "Venue, Catering & Bar", pct: 0.42 },
          photo: { name: "Photography & Video", pct: 0.11 },
          attire: { name: "Attire & Beauty", pct: 0.08 },
          floral: { name: "Florals & Decor", pct: 0.07 },
          entertainment: { name: "Entertainment (DJ/Band)", pct: 0.14 },
          stationary: { name: "Stationery & Favors", pct: 0.04 },
          rings: { name: "Rings & Officiant", pct: 0.04 },
          transport: { name: "Transportation & Hotel", pct: 0.05 },
          contingency: { name: "Contingency / Emergency", pct: 0.05 }
        }
      };

      function calculateBudget() {
        const rawBudget = parseFloat(budgetInput.value);
        let budget = 0;
        let hasError = false;

        const errorMsgEl = document.getElementById('calc-error-msg');

        if (isNaN(rawBudget) || rawBudget < 1000) {
          hasError = true;
          budgetInput.style.borderColor = 'red';
          if (!errorMsgEl) {
            const msg = document.createElement('div');
            msg.id = 'calc-error-msg';
            msg.style.color = 'red';
            msg.style.fontSize = '0.9rem';
            msg.style.marginTop = '0.5rem';
            msg.textContent = 'Please enter a valid budget of at least $1,000.';
            budgetInput.parentElement.parentElement.appendChild(msg);
          }
        } else {
          budgetInput.style.borderColor = 'var(--border-color)';
          budget = rawBudget;
          if (errorMsgEl) errorMsgEl.remove();
        }

        const priority = prioritySelect.value;
        const matrix = priorityMatrices[priority];

        // Clear existing results
        resultsContainer.innerHTML = '<h3>Category Breakdown</h3>';

        let calculatedTotal = 0;

        // Iterate through matrix and build DOM
        Object.keys(matrix).forEach(key => {
          const cat = matrix[key];
          const amount = budget * cat.pct;
          calculatedTotal += amount;

          const pctString = Math.round(cat.pct * 100) + '%';

          const row = document.createElement('div');
          row.className = 'budget-category';
          row.innerHTML = `
            <div class="cat-info">
              <span class="cat-name">${cat.name}</span>
              <span class="cat-pct">${pctString} of total</span>
            </div>
            <div class="cat-amount">${formatCurrency(amount)}</div>
          `;

          resultsContainer.appendChild(row);
        });

        totalDisplay.textContent = formatCurrency(calculatedTotal);
      }

      // Event listeners
      budgetInput.addEventListener('input', calculateBudget);
      prioritySelect.addEventListener('change', calculateBudget);

      // Initial render
      calculateBudget();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .input-row { display: flex; gap: 1.5rem; margin-bottom: 2rem; align-items: flex-end; }
    @media (max-width: 600px) { .input-row { flex-direction: column; align-items: stretch; } }

    .input-group { flex: 1; }
    .input-group label { display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-primary); }

    .input-wrapper { position: relative; display: flex; align-items: center; }
    .prefix { position: absolute; left: 1rem; color: var(--text-secondary); font-family: var(--font-mono); font-size: 1.1rem; pointer-events: none; }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1.1rem; }
    input.has-prefix { padding-left: 2rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .budget-results { margin-top: 2rem; }
    .budget-results h3 { margin-bottom: 1.5rem; color: var(--text-primary); text-align: center; }

    .budget-category { background: color-mix(in srgb, var(--accent-color) 5%, transparent); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem 1.5rem; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center; }
    .budget-category:hover { border-color: var(--accent-color); }

    .cat-info { display: flex; flex-direction: column; }
    .cat-name { font-weight: 600; color: var(--text-primary); }
    .cat-pct { font-size: 0.85rem; color: var(--text-secondary); }

    .cat-amount { font-size: 1.25rem; font-weight: 700; color: var(--accent-color); font-family: var(--font-mono); }

    .total-row { display: flex; justify-content: space-between; padding: 1.5rem; margin-top: 2rem; background: color-mix(in srgb, var(--accent-color) 10%, transparent); border-radius: 8px; border: 1px solid var(--accent-color); }
    .total-row .cat-name { font-size: 1.25rem; }
    .total-row .cat-amount { font-size: 1.5rem; }

    .explainer { margin-top: 4rem; }
    .explainer h2 { color: var(--accent-color); margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.75rem; }
    .explainer h3 { margin-top: 1.5rem; margin-bottom: 0.75rem; font-size: 1.25rem; }
    .explainer p { margin-bottom: 1.25rem; color: var(--text-secondary); line-height: 1.7; }
    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }

    .faq-section { margin-top: 4rem; border-top: 1px solid var(--border-color); padding-top: 3rem; }
    .faq-section h2 { margin-bottom: 2rem; text-align: center; }
    .faq-section details { margin: 1rem 0; padding: 1.25rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); transition: all 0.2s; }
    .faq-section details[open] { border-color: var(--accent-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; color: var(--text-primary); font-size: 1.1rem; outline: none; display: flex; justify-content: space-between; align-items: center; }
    .faq-section summary::-webkit-details-marker { display: none; }
    .faq-section summary::after { content: '+'; font-size: 1.5rem; color: var(--accent-color); line-height: 1; }
    .faq-section details[open] summary::after { content: '−'; }
    .faq-section details p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
