      }

      .days-container { display: flex; flex-direction: column; gap: 1rem; }
      .day-row { display: flex; flex-direction: column; gap: 0.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color); }
      .day-row:last-child { border-bottom: none; padding-bottom: 0; }
      .day-label { font-weight: 600; color: var(--text-primary); font-size: 1.1rem; }
      .time-inputs { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 1rem; align-items: end; }

      @media (max-width: 600px) {
        .time-inputs { grid-template-columns: 1fr 1fr; }
        .day-total { grid-column: 1 / -1; text-align: right; }
      }

      .input-group { display: flex; flex-direction: column; gap: 0.25rem; }
      .input-group label { font-size: 0.85rem; color: var(--text-secondary); font-weight: 500; }
      .input-group.full { margin-bottom: 1rem; }

      input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.5rem 0.75rem; border-radius: 6px; width: 100%; font-size: 0.95rem; }
      input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

