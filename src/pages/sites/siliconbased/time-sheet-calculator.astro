            <div class="day-label">Friday</div>
            <div class="time-inputs">
              <div class="input-group">
                <label>Start</label>
                <input type="time" id="fri-start" value="09:00">
              </div>
              <div class="input-group">
                <label>End</label>
                <input type="time" id="fri-end" value="17:00">
              </div>
              <div class="input-group">
                <label>Break (mins)</label>
                <input type="number" id="fri-break" value="30" min="0">
              </div>
              <div class="day-total" id="fri-total">0.00 hrs</div>
            </div>
          </div>
          <!-- Saturday -->
          <div class="day-row">
            <div class="day-label">Saturday</div>
            <div class="time-inputs">
              <div class="input-group">
                <label>Start</label>
                <input type="time" id="sat-start">
              </div>
              <div class="input-group">
                <label>End</label>
                <input type="time" id="sat-end">
              </div>
              <div class="input-group">
                <label>Break (mins)</label>
                <input type="number" id="sat-break" value="0" min="0">
              </div>
              <div class="day-total" id="sat-total">0.00 hrs</div>
            </div>
          </div>
