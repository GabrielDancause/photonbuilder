    .ts-table td.day-total { font-weight: bold; font-family: monospace; font-size: 1.1rem; }

    .ts-actions { text-align: right; margin-bottom: 2rem; }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }
    #clear-btn { background: transparent; color: var(--text-primary); border: 1px solid var(--border-color); }
    #clear-btn:hover { background: var(--border-color); }

    .ts-results { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-top: 1rem; }
    .result-box { background: var(--bg-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; }
    .total-pay-box { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border-color: var(--accent-color); }

    .result-label { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.5rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .result-value { font-size: 2rem; font-weight: 800; color: var(--text-primary); font-family: monospace; }
    .total-pay-box .result-value { color: var(--accent-color); font-size: 2.5rem; }

    .error-msg { color: #ef4444; background: color-mix(in srgb, #ef4444 10%, transparent); border: 1px solid #ef4444; padding: 1rem; border-radius: 8px; margin-top: 1rem; font-weight: 600; text-align: center; }

    .explainer { line-height: 1.8; margin-bottom: 3rem; }
    .explainer h2, .explainer h3 { margin-top: 2rem; margin-bottom: 1rem; font-weight: 700; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer a { color: var(--accent-color); text-decoration: none; }
    .explainer a:hover { text-decoration: underline; }

    .faq-section h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; list-style-position: inside; }
    .faq-section p { margin-top: 1rem; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
