      .result-row.final { font-size: 1.5rem; color: var(--accent-color); margin-top: 0.5rem; }
      .result-row.final span:last-child { color: var(--accent-color); font-size: 1.8rem; }

      hr { border: none; border-top: 1px solid var(--border-color); margin: 1rem 0; }
      .error-msg { color: #ef4444; font-size: 0.9rem; margin-top: 1rem; text-align: center; min-height: 1.2rem; }

      .explainer { margin-top: 3rem; }
      .explainer h2, .explainer h3 { color: var(--text-primary); margin-top: 2rem; margin-bottom: 1rem; }
      .explainer p { margin-bottom: 1rem; line-height: 1.6; }
      .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; }
