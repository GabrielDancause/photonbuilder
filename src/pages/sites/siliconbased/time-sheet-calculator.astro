            </div>
          </div>
        </div>

        <div class="settings-and-results">
          <div class="settings-box">
            <h3>Pay Settings</h3>
            <div class="input-group full">
              <label for="hourly-rate">Hourly Rate ($)</label>
              <input type="number" id="hourly-rate" value="20.00" min="0" step="0.01">
            </div>
            <div class="input-group full">
              <label for="overtime-rate">Overtime Multiplier</label>
              <select id="overtime-rate">
                <option value="1.5">1.5x (Time and a half)</option>
                <option value="2.0">2.0x (Double time)</option>
                <option value="1.0">1.0x (No overtime)</option>
              </select>
            </div>
            <div class="input-group full">
              <label for="overtime-threshold">Overtime Threshold (Hours)</label>
              <input type="number" id="overtime-threshold" value="40" min="0" step="1">
            </div>
          </div>

          <div class="results-box">
            <h3>Weekly Summary</h3>
            <div class="result-row">
              <span>Regular Hours:</span>
              <span id="res-reg-hours">0.00</span>
            </div>
            <div class="result-row">
              <span>Overtime Hours:</span>
              <span id="res-ot-hours">0.00</span>
            </div>
            <div class="result-row highlight">
              <span>Total Hours:</span>
              <span id="res-total-hours">0.00</span>
            </div>

            <hr>

            <div class="result-row">
              <span>Regular Pay:</span>
              <span id="res-reg-pay">$0.00</span>
            </div>
            <div class="result-row">
              <span>Overtime Pay:</span>
              <span id="res-ot-pay">$0.00</span>
            </div>
            <div class="result-row highlight final">
              <span>Gross Pay:</span>
              <span id="res-total-pay">$0.00</span>
            </div>
            <p class="error-msg" id="calc-error"></p>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const days = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun'];
        const rateInput = document.getElementById('hourly-rate');
        const otMultiplierSelect = document.getElementById('overtime-rate');
        const otThresholdInput = document.getElementById('overtime-threshold');
        const errorMsg = document.getElementById('calc-error');

        function parseTime(timeStr) {
          if (!timeStr) return null;
          const [hours, minutes] = timeStr.split(':').map(Number);
          return hours + (minutes / 60);
        }

        function calculate() {
          let totalWeeklyHours = 0;
          errorMsg.textContent = '';
          let hasError = false;

          days.forEach(day => {
            const startInput = document.getElementById(`${day}-start`).value;
            const endInput = document.getElementById(`${day}-end`).value;
            const breakInput = parseFloat(document.getElementById(`${day}-break`).value) || 0;
            const totalEl = document.getElementById(`${day}-total`);

            if (startInput && endInput) {
              const start = parseTime(startInput);
              let end = parseTime(endInput);

              if (end < start) {
                // Crosses midnight
                end += 24;
              }

              let dailyHours = (end - start) - (breakInput / 60);

              if (dailyHours < 0) {
                dailyHours = 0;
                hasError = true;
                errorMsg.textContent = 'Break duration exceeds hours worked on some days.';
              }

              totalEl.textContent = `${dailyHours.toFixed(2)} hrs`;
              totalWeeklyHours += dailyHours;
            } else {
              totalEl.textContent = '0.00 hrs';
            }
          });

          const rate = parseFloat(rateInput.value) || 0;
          const otMultiplier = parseFloat(otMultiplierSelect.value) || 1.5;
          const otThreshold = parseFloat(otThresholdInput.value) || 40;

          let regularHours = totalWeeklyHours;
          let overtimeHours = 0;

          if (totalWeeklyHours > otThreshold) {
            regularHours = otThreshold;
            overtimeHours = totalWeeklyHours - otThreshold;
          }

          const regularPay = regularHours * rate;
          const overtimePay = overtimeHours * (rate * otMultiplier);
          const totalPay = regularPay + overtimePay;

          document.getElementById('res-reg-hours').textContent = regularHours.toFixed(2);
          document.getElementById('res-ot-hours').textContent = overtimeHours.toFixed(2);
          document.getElementById('res-total-hours').textContent = totalWeeklyHours.toFixed(2);

          document.getElementById('res-reg-pay').textContent = '$' + regularPay.toFixed(2);
          document.getElementById('res-ot-pay').textContent = '$' + overtimePay.toFixed(2);
          document.getElementById('res-total-pay').textContent = '$' + totalPay.toFixed(2);
        }

        // Add event listeners to all inputs
        const inputs = document.querySelectorAll('.calculator-container input, .calculator-container select');
        inputs.forEach(input => {
          input.addEventListener('input', calculate);
        });

        // Initial calculation
        calculate();
      });
    </script>

    <style is:inline>
      .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
      .hero { text-align: center; padding: 3rem 0 2rem; }
      .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; color: var(--accent-color); }
      .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

