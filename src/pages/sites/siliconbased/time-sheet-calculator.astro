---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Time Sheet Calculator | Calculate Hours & Gross Pay",
  description: "Stop guessing your paycheck. Our free time sheet calculator figures out your exact hours and gross pay—including overtime. Are you leaving money on the table?",
  category: "tool",
  published: "2026-03-15",
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I calculate my hours for a time sheet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "To calculate your hours, take your end time and subtract your start time. Convert the result to a decimal (e.g., 30 minutes becomes 0.5 hours), then subtract any unpaid breaks."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate pay from a time sheet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Multiply your total weekly decimal hours by your hourly rate. If you worked overtime (typically over 40 hours in a week), multiply those extra hours by your overtime rate (usually 1.5 times your regular rate) and add it to your regular pay."
          }
        },
        {
          "@type": "Question",
          "name": "What are the rules for unpaid breaks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Under the Fair Labor Standards Act (FLSA), short breaks (usually 20 minutes or less) must be paid. Bona fide meal periods (typically 30 minutes or more) where you are completely relieved from duty are generally unpaid."
          }
        },
        {
          "@type": "Question",
          "name": "How do I convert minutes to decimal hours?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Divide the number of minutes by 60. For example, 15 minutes is 0.25 hours (15/60), 30 minutes is 0.5 hours (30/60), and 45 minutes is 0.75 hours (45/60)."
          }
        },
        {
          "@type": "Question",
          "name": "Should time sheets be rounded?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, employers can round time under the FLSA, usually to the nearest 5, 10, or 15 minutes, provided the rounding doesn't consistently favor the employer. However, exact tracking is often preferred to avoid wage disputes."
          }
        }
      ]
    },
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": meta.published,
      "author": {
        "@type": "Organization",
        "name": "SiliconBased"
      }
    }
  ]
};
---

<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/time-sheet-calculator" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Free Time Sheet Calculator</h1>
      <p class="subtitle">Calculate your weekly work hours, break deductions, and gross pay instantly.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="days-container">
          <!-- Monday -->
          <div class="day-row">
            <div class="day-label">Monday</div>
            <div class="time-inputs">
              <div class="input-group">
                <label>Start</label>
                <input type="time" id="mon-start" value="09:00">
              </div>
              <div class="input-group">
                <label>End</label>
                <input type="time" id="mon-end" value="17:00">
              </div>
              <div class="input-group">
                <label>Break (mins)</label>
                <input type="number" id="mon-break" value="30" min="0">
              </div>
              <div class="day-total" id="mon-total">0.00 hrs</div>
            </div>
          </div>
          <!-- Tuesday -->
          <div class="day-row">
            <div class="day-label">Tuesday</div>
            <div class="time-inputs">
              <div class="input-group">
                <label>Start</label>
                <input type="time" id="tue-start" value="09:00">
              </div>
              <div class="input-group">
                <label>End</label>
                <input type="time" id="tue-end" value="17:00">
              </div>
              <div class="input-group">
                <label>Break (mins)</label>
                <input type="number" id="tue-break" value="30" min="0">
              </div>
              <div class="day-total" id="tue-total">0.00 hrs</div>
            </div>
          </div>
          <!-- Wednesday -->
          <div class="day-row">
            <div class="day-label">Wednesday</div>
            <div class="time-inputs">
              <div class="input-group">
                <label>Start</label>
                <input type="time" id="wed-start" value="09:00">
              </div>
              <div class="input-group">
                <label>End</label>
                <input type="time" id="wed-end" value="17:00">
              </div>
              <div class="input-group">
                <label>Break (mins)</label>
                <input type="number" id="wed-break" value="30" min="0">
              </div>
              <div class="day-total" id="wed-total">0.00 hrs</div>
            </div>
          </div>
          <!-- Thursday -->
          <div class="day-row">
            <div class="day-label">Thursday</div>
            <div class="time-inputs">
              <div class="input-group">
                <label>Start</label>
                <input type="time" id="thu-start" value="09:00">
              </div>
              <div class="input-group">
                <label>End</label>
                <input type="time" id="thu-end" value="17:00">
              </div>
              <div class="input-group">
                <label>Break (mins)</label>
                <input type="number" id="thu-break" value="30" min="0">
              </div>
              <div class="day-total" id="thu-total">0.00 hrs</div>
            </div>
          </div>
          <!-- Friday -->
