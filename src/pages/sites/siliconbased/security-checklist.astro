    .intro-card { background: color-mix(in srgb, var(--accent-color) 5%, var(--card-bg)); }
    h2 { font-size: 1.8rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--text-primary); }
    h3 { font-size: 1.3rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-primary); }
    p { margin-bottom: 1rem; line-height: 1.6; color: var(--text-secondary); }
    ul { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--text-secondary); }
    li { margin-bottom: 0.5rem; line-height: 1.5; }
    strong { color: var(--text-primary); font-weight: 600; }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
