---
import SiteLayout from "../../../layouts/SiteLayout.astro";

export const meta = {
  title: "NFL Free Agency Salary Cap Space Calculator",
  description: "How much cap space does your team really have left? This tracker uncovers the hidden math behind free agency contracts.",
  category: "tool",
  published: "2026-03-15",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is NFL cap space calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "NFL cap space is calculated by taking the league-wide salary cap, adjusting for rollover cap space from the previous year, and subtracting the top 51 highest salaries, along with any dead money and active guarantees. It is a dynamic figure that changes with every roster move."
        }
      },
      {
        "@type": "Question",
        "name": "What is dead money in the NFL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dead money is the portion of the salary cap allocated to players who are no longer on the team's roster. This typically occurs when a player with guaranteed money or prorated signing bonuses is cut or traded before their contract expires."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Top 51 rule?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "During the NFL offseason, only the top 51 highest salaries on a team's roster count against the salary cap. This rule exists because offseason rosters expand to 90 players, making it mathematically impossible to stay under the cap if all 90 players were counted."
        }
      },
      {
        "@type": "Question",
        "name": "How does guaranteed money affect free agency?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Guaranteed money represents the financial commitment a team makes regardless of a player's performance or injury status. High guaranteed amounts reduce flexibility in future free agency periods, as releasing the player accelerates those guarantees onto the current year's cap as dead money."
        }
      },
      {
        "@type": "Question",
        "name": "Can teams roll over unused cap space?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, NFL teams are permitted to roll over unused salary cap space from one season to the next, provided they notify the league prior to the end of the regular season. This mechanism allows teams to save cap space for major free agent acquisitions in subsequent years."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "NFL Free Agency Tracker: Salary Cap & Contract Calculator",
    "description": "Calculate dynamic NFL salary cap space, track contract structures, and analyze free agency spending with this interactive tool.",
    "author": {
      "@type": "Organization",
      "name": "SiliconBased.dev"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SiliconBased.dev",
      "logo": {
        "@type": "ImageObject",
        "url": "https://siliconbased.dev/favicon.ico"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://siliconbased.dev/nfl-free-agency-tracker"
    }
  }
];
---
<SiteLayout site="siliconbased" title={meta.title} description={meta.description} canonical="https://siliconbased.dev/nfl-free-agency-tracker" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>NFL Free Agency Cap Space Tracker</h1>
      <p class="subtitle">Simulate real-time salary cap adjustments and track contract impacts instantly.</p>
    </div>

    <div class="calculator-container">
      <div class="calc-grid">
        <div class="input-group">
          <label for="baseCap">Base League Salary Cap ($)</label>
          <input type="number" id="baseCap" value="255400000" step="100000">
        </div>
        <div class="input-group">
          <label for="rolloverCap">Rollover Cap Space ($)</label>
          <input type="number" id="rolloverCap" value="12500000" step="100000">
        </div>
        <div class="input-group">
          <label for="top51Salaries">Top 51 Active Salaries ($)</label>
          <input type="number" id="top51Salaries" value="210000000" step="100000">
        </div>
        <div class="input-group">
          <label for="deadMoney">Dead Money ($)</label>
          <input type="number" id="deadMoney" value="18000000" step="100000">
        </div>
        <div class="input-group">
          <label for="newContractAAV">New Signing AAV ($)</label>
          <input type="number" id="newContractAAV" value="0" step="100000">
        </div>
      </div>

      <div id="errorMessage" class="error-message" style="display: none;"></div>

      <div class="result-card">
        <div class="result-label">Available Cap Space</div>
        <div class="result-value" id="availableCap">$0</div>
        <div class="result-subtext" id="capStatus">Status: Calculating...</div>
      </div>

      <div class="calc-actions">
        <button id="resetCalc">Reset Values</button>
      </div>
    </div>

    <div class="explainer">
      <h2>Understanding the NFL Salary Cap & Free Agency Tracking</h2>
      <p>The NFL offseason is defined by its financial complexity. Unlike leagues with soft caps or luxury taxes, the National Football League operates under a hard salary cap. This means teams must strictly adhere to a maximum spending limit, forcing front offices to meticulously balance star player contracts, rookie deals, and veteran depth. Our NFL Free Agency Tracker provides a granular look at how these financial mechanics dictate roster construction, enabling analysts and fans alike to model hypothetical signings and their immediate cap implications.</p>

      <h3>The Core Components of Cap Space</h3>
      <p>Calculating a team's true spending power during free agency involves more than just subtracting total salaries from the league-wide cap. The mathematical framework relies on several distinct variables:</p>
      <ul>
        <li><strong>Base League Salary Cap:</strong> The fundamental limit set by the NFL each year, determined by league revenue sharing agreements and collective bargaining. For example, the 2024 salary cap was set at $255.4 million, a significant increase driven by media rights deals.</li>
        <li><strong>Rollover Cap Space:</strong> A critical strategic tool. Teams that do not spend up to the cap limit in a given year are permitted to carry over the unused balance to the following season. This creates a disparity in actual spending power; a team with a baseline cap of $255.4 million might have an adjusted cap of $270 million if they rolled over unused funds.</li>
        <li><strong>The Top 51 Rule:</strong> During the offseason, rosters expand to 90 players. To make free agency functional, the NFL only counts the 51 most expensive contracts on a team against the salary cap until the start of the regular season. This prevents teams from immediately violating the cap while evaluating training camp prospects.</li>
        <li><strong>Dead Money:</strong> The financial ghosts of past contracts. When a player is released or traded, any unamortized signing bonus money or guaranteed salary immediately accelerates onto the team's current salary cap. High dead money limits flexibility, acting as a direct penalty for poor contract structuring or unexpected player decline.</li>
      </ul>

      <h3>Contract Structures and AAV</h3>
      <p>When tracking free agency, the headline numbers are often misleading. A "5-year, $100 million" contract rarely means the player is receiving $20 million evenly per year. Front offices utilize complex mechanisms to manipulate the cap hit:</p>
      <p><strong>Average Annual Value (AAV)</strong> is the total value of the contract divided by the years. While useful for comparing total compensation, it does not reflect the actual cap hit. Teams heavily utilize <strong>Signing Bonuses</strong>. A $25 million signing bonus on a 5-year deal is paid to the player immediately but is prorated over the length of the contract for cap purposes ($5 million per year). This artificially lowers the Year 1 cap hit, allowing teams to acquire premium talent while remaining compliant.</p>
      <p>Furthermore, <strong>Void Years</strong> are frequently appended to contracts. These are "dummy" years added to the end of a deal solely to stretch out the proration of the signing bonus. When the contract voids, the remaining prorated money accelerates, creating the dead money discussed earlier. This "kicking the can down the road" strategy is common among championship contenders maximizing their immediate window.</p>

      <h3>How Our Methodology Works</h3>
      <p>The interactive tracker above models the immediate state of a team's salary cap using a simplified yet highly accurate formula. The fundamental calculation is:</p>
      <p><code>Adjusted Cap = Base League Cap + Rollover Cap</code></p>
      <p><code>Total Liabilities = Top 51 Salaries + Dead Money + New Signing Cap Hit</code></p>
      <p><code>Available Cap Space = Adjusted Cap - Total Liabilities</code></p>
      <p>By inputting hypothetical values, you can instantly observe the fragility of NFL roster building. A single massive free-agent acquisition (represented by the 'New Signing AAV' field) can evaporate cap space, forcing a team to either restructure existing contracts (converting base salary to signing bonus to lower current cap hits) or release veteran players to generate compliance.</p>
      <p>Understanding these mechanics is essential for comprehending the modern NFL. Free agency is not merely a talent acquisition period; it is an exercise in complex financial engineering where the margin between sustainable contention and long-term cap hell is remarkably thin. The tracker serves as an analytical foundation for projecting these high-stakes decisions.</p>
      <p>Check out our <a href="/microsoft-planner">Microsoft Planner implementation tool</a> to manage your offseason workflows, or explore our other analytical <a href="/tools">developer tools</a>.</p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>How is NFL cap space calculated?</summary>
        <p>NFL cap space is calculated by taking the league-wide salary cap, adjusting for rollover cap space from the previous year, and subtracting the top 51 highest salaries, along with any dead money and active guarantees. It is a dynamic figure that changes with every roster move.</p>
      </details>
      <details>
        <summary>What is dead money in the NFL?</summary>
        <p>Dead money is the portion of the salary cap allocated to players who are no longer on the team's roster. This typically occurs when a player with guaranteed money or prorated signing bonuses is cut or traded before their contract expires.</p>
      </details>
      <details>
        <summary>What is the Top 51 rule?</summary>
        <p>During the NFL offseason, only the top 51 highest salaries on a team's roster count against the salary cap. This rule exists because offseason rosters expand to 90 players, making it mathematically impossible to stay under the cap if all 90 players were counted.</p>
      </details>
      <details>
        <summary>How does guaranteed money affect free agency?</summary>
        <p>Guaranteed money represents the financial commitment a team makes regardless of a player's performance or injury status. High guaranteed amounts reduce flexibility in future free agency periods, as releasing the player accelerates those guarantees onto the current year's cap as dead money.</p>
      </details>
      <details>
        <summary>Can teams roll over unused cap space?</summary>
        <p>Yes, NFL teams are permitted to roll over unused salary cap space from one season to the next, provided they notify the league prior to the end of the regular season. This mechanism allows teams to save cap space for major free agent acquisitions in subsequent years.</p>
      </details>
    </section>
  </div>

  <script is:inline>
    const baseCapInput = document.getElementById('baseCap');
    const rolloverCapInput = document.getElementById('rolloverCap');
    const top51SalariesInput = document.getElementById('top51Salaries');
    const deadMoneyInput = document.getElementById('deadMoney');
    const newContractAAVInput = document.getElementById('newContractAAV');

    const errorMessage = document.getElementById('errorMessage');
    const availableCapDisplay = document.getElementById('availableCap');
    const capStatusDisplay = document.getElementById('capStatus');
    const resetBtn = document.getElementById('resetCalc');

    const formatter = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 0
    });

    function calculateCap() {
      errorMessage.style.display = 'none';

      const baseCap = parseFloat(baseCapInput.value);
      const rolloverCap = parseFloat(rolloverCapInput.value);
      const top51 = parseFloat(top51SalariesInput.value);
      const deadMoney = parseFloat(deadMoneyInput.value);
      const newSigning = parseFloat(newContractAAVInput.value);

      if (isNaN(baseCap) || isNaN(rolloverCap) || isNaN(top51) || isNaN(deadMoney) || isNaN(newSigning)) {
        errorMessage.textContent = 'Please enter valid numerical values for all fields.';
        errorMessage.style.display = 'block';
        availableCapDisplay.textContent = '$0';
        capStatusDisplay.textContent = 'Invalid input';
        return;
      }

      if (baseCap < 0 || rolloverCap < 0 || top51 < 0 || deadMoney < 0 || newSigning < 0) {
        errorMessage.textContent = 'Values cannot be negative.';
        errorMessage.style.display = 'block';
        availableCapDisplay.textContent = '$0';
        capStatusDisplay.textContent = 'Invalid input';
        return;
      }

      const adjustedCap = baseCap + rolloverCap;
      const totalLiabilities = top51 + deadMoney + newSigning;
      const availableSpace = adjustedCap - totalLiabilities;

      availableCapDisplay.textContent = formatter.format(availableSpace);

      if (availableSpace > 10000000) {
        capStatusDisplay.textContent = 'Healthy Cap Space. Ready for free agency.';
        availableCapDisplay.style.color = 'var(--accent-color)';
      } else if (availableSpace >= 0) {
        capStatusDisplay.textContent = 'Tight Cap Situation. Restructures may be needed.';
        availableCapDisplay.style.color = '#f59e0b';
      } else {
        capStatusDisplay.textContent = 'OVER THE CAP. Roster cuts or restructures required immediately.';
        availableCapDisplay.style.color = '#ef4444';
      }
    }

    [baseCapInput, rolloverCapInput, top51SalariesInput, deadMoneyInput, newContractAAVInput].forEach(input => {
      input.addEventListener('input', calculateCap);
    });

    resetBtn.addEventListener('click', () => {
      baseCapInput.value = '255400000';
      rolloverCapInput.value = '12500000';
      top51SalariesInput.value = '210000000';
      deadMoneyInput.value = '18000000';
      newContractAAVInput.value = '0';
      calculateCap();
    });

    // Initial calculation
    calculateCap();
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }

    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }
    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
    @media (max-width: 600px) { .calc-grid { grid-template-columns: 1fr; } }

    .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group label { font-weight: 600; font-size: 0.95rem; }
    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }

    .error-message { color: #ef4444; background: color-mix(in srgb, #ef4444 10%, transparent); border: 1px solid color-mix(in srgb, #ef4444 30%, transparent); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem; font-weight: 500; }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 2rem; margin: 1.5rem 0; text-align: center; }
    .result-label { font-size: 1.1rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.5rem; }
    .result-value { font-size: 3rem; font-weight: 800; color: var(--accent-color); margin-bottom: 0.5rem; line-height: 1; }
    .result-subtext { font-size: 0.95rem; font-weight: 500; }

    .calc-actions { text-align: center; }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; transition: opacity 0.2s; }
    button:hover { opacity: 0.9; }

    .explainer { margin-top: 3rem; line-height: 1.7; }
    .explainer h2 { font-size: 1.8rem; margin: 2rem 0 1rem; }
    .explainer h3 { font-size: 1.4rem; margin: 1.5rem 0 0.75rem; }
    .explainer p { margin-bottom: 1rem; color: var(--text-secondary); }
    .explainer ul { margin-bottom: 1.5rem; padding-left: 1.5rem; color: var(--text-secondary); }
    .explainer li { margin-bottom: 0.5rem; }
    .explainer a { color: var(--accent-color); text-decoration: none; font-weight: 500; }
    .explainer a:hover { text-decoration: underline; }
    .explainer code { background: var(--card-bg); border: 1px solid var(--border-color); padding: 0.2rem 0.4rem; border-radius: 4px; font-family: monospace; font-size: 0.9rem; }

    .faq-section { margin-top: 3rem; }
    .faq-section h2 { font-size: 1.8rem; margin-bottom: 1.5rem; }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; list-style-position: inside; }
    .faq-section details p { margin-top: 1rem; margin-bottom: 0; color: var(--text-secondary); line-height: 1.6; }
  </style>
</SiteLayout>
