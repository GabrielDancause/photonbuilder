<SiteLayout
  site="siliconbased"
  title="Online Markdown Editor — Live Preview & Export"
  description="Free online markdown editor with live preview, formatting toolbar, syntax highlighting, dark/light theme toggle, and export to HTML or .md file. No data leaves your browser."
  canonical="https://siliconbased.dev/markdown-editor"
  schema={schema}
>
  <Fragment set:html={htmlBody} />

  <script is:inline>
const editorArea = document.getElementById('editorArea');
const previewArea = document.getElementById('previewArea');
const wordCountEl = document.getElementById('wordCount');
const charCountEl = document.getElementById('charCount');
const themeToggle = document.getElementById('themeToggle');
const copyHtmlBtn = document.getElementById('copyHtmlBtn');
const downloadMdBtn = document.getElementById('downloadMdBtn');
const sampleBtn = document.getElementById('sampleBtn');
const clearBtn = document.getElementById('clearBtn');

const sampleMarkdown = `# Welcome to the Markdown Editor

This is a **live preview** markdown editor. Start typing on the left and see the rendered output here.

## Features

- **Bold**, *italic*, and ~~strikethrough~~ text
- [Links](https://example.com) and ![images](https://via.placeholder.com/150x50)
- Ordered and unordered lists
- Code blocks with syntax highlighting

## Code Example

\`\`\`javascript
function greet(name) {
  return \`Hello, \${name}!\`;
}

console.log(greet("World"));
\`\`\`

You can also use \`inline code\` in your text.

## Blockquote

> The best way to predict the future is to invent it.
> — Alan Kay

## Table

| Feature | Status |
|---------|--------|
| Live Preview | Yes |
| Toolbar | Yes |
| Export HTML | Yes |
| Download .md | Yes |
| Dark/Light Theme | Yes |

## Lists

### Unordered
- First item
- Second item
- Third item

### Ordered
1. Step one
2. Step two
3. Step three

---

*Start editing to see the magic happen!*`;

let isDark = true;

function init() {
  editorArea.addEventListener('input', onInput);

  // Toolbar buttons
  document.querySelectorAll('.tb-btn[data-action]').forEach(btn => {
    btn.addEventListener('click', () => handleToolbar(btn.dataset.action));
  });

  themeToggle.addEventListener('click', toggleTheme);
  copyHtmlBtn.addEventListener('click', copyHtml);
  downloadMdBtn.addEventListener('click', downloadMd);

  sampleBtn.addEventListener('click', () => {
    editorArea.value = sampleMarkdown;
    onInput();
    editorArea.focus();
  });

  clearBtn.addEventListener('click', () => {
    editorArea.value = '';
    onInput();
    editorArea.focus();
  });

  // Keyboard shortcuts
  editorArea.addEventListener('keydown', (e) => {
    if (e.ctrlKey || e.metaKey) {
      if (e.key === 'b') { e.preventDefault(); handleToolbar('bold'); }
      if (e.key === 'i') { e.preventDefault(); handleToolbar('italic'); }
    }
    // Tab support
    if (e.key === 'Tab') {
      e.preventDefault();
      const start = editorArea.selectionStart;
      const end = editorArea.selectionEnd;
      editorArea.value = editorArea.value.substring(0, start) + '  ' + editorArea.value.substring(end);
      editorArea.selectionStart = editorArea.selectionEnd = start + 2;
      onInput();
    }
  });

  // Load sample
  editorArea.value = sampleMarkdown;
  onInput();
}

function onInput() {
  renderPreview();
  updateStats();
}

function updateStats() {
  const text = editorArea.value;
  const chars = text.length;
  const words = text.trim() ? text.trim().split(/\s+/).length : 0;
  wordCountEl.textContent = words + ' word' + (words !== 1 ? 's' : '');
  charCountEl.textContent = chars + ' character' + (chars !== 1 ? 's' : '');
}

function handleToolbar(action) {
  const start = editorArea.selectionStart;
  const end = editorArea.selectionEnd;
  const text = editorArea.value;
  const selected = text.substring(start, end);
  let insert = '';
  let cursorOffset = 0;

  switch (action) {
    case 'bold':
      insert = '**' + (selected || 'bold text') + '**';
      cursorOffset = selected ? insert.length : 2;
      break;
    case 'italic':
      insert = '*' + (selected || 'italic text') + '*';
      cursorOffset = selected ? insert.length : 1;
      break;
    case 'strikethrough':
      insert = '~~' + (selected || 'text') + '~~';
      cursorOffset = selected ? insert.length : 2;
      break;
    case 'h1':
      insert = '# ' + (selected || 'Heading 1');
      cursorOffset = insert.length;
      break;
    case 'h2':
      insert = '## ' + (selected || 'Heading 2');
      cursorOffset = insert.length;
      break;
    case 'h3':
      insert = '### ' + (selected || 'Heading 3');
      cursorOffset = insert.length;
      break;
    case 'link':
      insert = '[' + (selected || 'link text') + '](url)';
      cursorOffset = selected ? insert.length - 4 : 1;
      break;
    case 'image':
      insert = '![' + (selected || 'alt text') + '](image-url)';
      cursorOffset = selected ? insert.length - 10 : 2;
      break;
    case 'code':
      insert = '`' + (selected || 'code') + '`';
      cursorOffset = selected ? insert.length : 1;
      break;
    case 'codeblock':
      insert = '```\n' + (selected || 'code here') + '\n```';
      cursorOffset = selected ? insert.length : 4;
      break;
    case 'blockquote':
      insert = '> ' + (selected || 'quote');
      cursorOffset = insert.length;
      break;
    case 'ul':
      insert = '- ' + (selected || 'list item');
      cursorOffset = insert.length;
      break;
    case 'ol':
      insert = '1. ' + (selected || 'list item');
      cursorOffset = insert.length;
      break;
    case 'hr':
      insert = '\n---\n';
      cursorOffset = insert.length;
      break;
    case 'table':
      insert = '| Header 1 | Header 2 | Header 3 |\n|----------|----------|----------|\n| Cell 1   | Cell 2   | Cell 3   |\n| Cell 4   | Cell 5   | Cell 6   |';
      cursorOffset = insert.length;
      break;
  }

  editorArea.value = text.substring(0, start) + insert + text.substring(end);
  editorArea.selectionStart = editorArea.selectionEnd = start + cursorOffset;
  editorArea.focus();
  onInput();
}

/* ── Markdown → HTML Parser ── */
function renderPreview() {
  const md = editorArea.value;
  previewArea.innerHTML = markdownToHtml(md);
}

function markdownToHtml(md) {
  let html = md;

  // Fenced code blocks — preserve before other transforms
  const codeBlocks = [];
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, function(_, lang, code) {
    const escaped = escapeHtml(code.replace(/\n$/, ''));
    const block = lang
      ? '<pre class="code-block"><code class="language-' + lang + '">' + escaped + '</code></pre>'
      : '<pre class="code-block"><code>' + escaped + '</code></pre>';
    codeBlocks.push(block);
    return '\x00CODEBLOCK' + (codeBlocks.length - 1) + '\x00';
  });

  // Inline code — preserve before other inline transforms
  const inlineCodes = [];
  html = html.replace(/`([^`]+)`/g, function(_, code) {
    inlineCodes.push('<code>' + escapeHtml(code) + '</code>');
    return '\x00INLINE' + (inlineCodes.length - 1) + '\x00';
  });

  // Blockquotes
  html = html.replace(/^((?:>.*\n?)+)/gm, function(block) {
    const inner = block.replace(/^>\s?/gm, '').trim();
    return '<blockquote>' + inner + '</blockquote>\n';
  });

  // Tables (GFM)
  html = html.replace(/^(\|.+\|)\n(\|[\s:|-]+\|)\n((?:\|.+\|\n?)*)/gm, function(_, headerRow, _sep, bodyRows) {
    const headers = headerRow.split('|').filter(c => c.trim()).map(c => '<th>' + c.trim() + '</th>').join('');
    let body = '';
    if (bodyRows.trim()) {
      bodyRows.trim().split('\n').forEach(row => {
        const cells = row.split('|').filter(c => c.trim()).map(c => '<td>' + c.trim() + '</td>').join('');
        body += '<tr>' + cells + '</tr>';
      });
    }
    return '<table><thead><tr>' + headers + '</tr></thead><tbody>' + body + '</tbody></table>\n';
  });

  // Headings
  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');

  // HR
  html = html.replace(/^---$/gm, '<hr>');

  // Unordered lists
  html = html.replace(/^((?:[-*+]\s+.+\n?)+)/gm, function(block) {
    const items = block.trim().split('\n').map(l => '<li>' + l.replace(/^[-*+]\s+/, '') + '</li>').join('');
    return '<ul>' + items + '</ul>\n';
  });

  // Ordered lists
  html = html.replace(/^((?:\d+\.\s+.+\n?)+)/gm, function(block) {
    const items = block.trim().split('\n').map(l => '<li>' + l.replace(/^\d+\.\s+/, '') + '</li>').join('');
    return '<ol>' + items + '</ol>\n';
  });

  // Images
  html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" />');

  // Links
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');

  // Bold + italic combined
  html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');

  // Bold
  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

  // Italic
  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

  // Strikethrough
  html = html.replace(/~~(.+?)~~/g, '<del>$1</del>');

  // Paragraphs
  html = html.replace(/^(?!<[a-z/]|$|\x00)(.+)$/gm, '<p>$1</p>');

  // Restore code blocks and inline code
  html = html.replace(/\x00CODEBLOCK(\d+)\x00/g, (_, i) => codeBlocks[i]);
  html = html.replace(/\x00INLINE(\d+)\x00/g, (_, i) => inlineCodes[i]);

  // Clean up empty paragraphs
  html = html.replace(/<p>\s*<\/p>/g, '');

  return html.trim();
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function toggleTheme() {
  isDark = !isDark;
  const page = document.querySelector('.page-content');
  page.classList.toggle('light-theme', !isDark);
  themeToggle.innerHTML = isDark ? '&#9790; Theme' : '&#9788; Theme';
}

function copyHtml() {
  const html = previewArea.innerHTML;
  if (!html) return;
  navigator.clipboard.writeText(html).then(() => {
    copyHtmlBtn.textContent = '✓ Copied';
    setTimeout(() => { copyHtmlBtn.textContent = 'Copy HTML'; }, 1500);
  });
}

function downloadMd() {
  const text = editorArea.value;
  if (!text) return;
  const blob = new Blob([text], { type: 'text/markdown' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'document.md';
  a.click();
  URL.revokeObjectURL(url);
}

init();
</script>

