      <li><strong>Privacy-first:</strong> Everything runs in your browser — no data is ever sent to a server.</li>
    </ul>

    <h2>Supported Markdown Syntax</h2>
    <table class="seo-table">
      <thead>
        <tr>
          <th>Syntax</th>
          <th>Output</th>
          <th>Notes</th>
        </tr>
      </thead>
