<script is:inline>
  const searchInput = document.getElementById('searchInput');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const rows = document.querySelectorAll('.oil-row');
  const headers = document.querySelectorAll('th[data-sort]');
  const tableBody = document.getElementById('tableBody');

  let currentFilter = 'all';
  let searchQuery = '';

  // Filter logic
  function applyFilters() {
    rows.forEach(row => {
      const category = row.getAttribute('data-category');
      const text = row.innerText.toLowerCase();

      const matchesFilter = currentFilter === 'all' || category.includes(currentFilter);
      const matchesSearch = text.includes(searchQuery);

      if (matchesFilter && matchesSearch) {
        row.classList.remove('hidden');
      } else {
        row.classList.add('hidden');
      }
    });
  }

  // Event listeners for filters
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter');
      applyFilters();
    });
  });

  // Event listener for search
  searchInput.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase();
    applyFilters();
  });

  // Sort logic
  headers.forEach(header => {
    header.addEventListener('click', () => {
      const sortType = header.getAttribute('data-sort');
      const isAsc = !header.classList.contains('asc');

      headers.forEach(h => { h.classList.remove('asc', 'desc'); });
      header.classList.add(isAsc ? 'asc' : 'desc');

      const rowsArray = Array.from(rows);

      rowsArray.sort((a, b) => {
        let aVal, bVal;

        if (sortType === 'name') {
          aVal = a.children[0].innerText.trim();
          bVal = b.children[0].innerText.trim();
        } else if (sortType === 'temp') {
          aVal = parseInt(a.getAttribute('data-temp'));
          bVal = parseInt(b.getAttribute('data-temp'));
        } else if (sortType === 'zone') {
          aVal = parseInt(a.getAttribute('data-temp'));
          bVal = parseInt(b.getAttribute('data-temp'));
        } else if (sortType === 'price') {
          aVal = parseInt(a.getAttribute('data-price'));
          bVal = parseInt(b.getAttribute('data-price'));
        }

        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });

      rowsArray.forEach(row => tableBody.appendChild(row));
    });
  });

  // Oil Selector
  const methodBtns = document.querySelectorAll('.method-btn');
  const selectorResult = document.getElementById('selectorResult');
  const recTitle = document.getElementById('recTitle');
  const recDesc = document.getElementById('recDesc');
  const recOils = document.getElementById('recOils');

  const recommendations = {
    'deep-fry': {
      title: 'Best Oils for Deep Frying',
      desc: 'Deep frying typically happens at 350-375°F. You need an oil with a high smoke point (450°F+), neutral flavor, and good heat stability for repeated use.',
      oils: ['Refined Avocado Oil', 'Peanut Oil', 'Sunflower Oil', 'Canola Oil', 'Vegetable Oil']
    },
    'stir-fry': {
      title: 'Best Oils for Stir Frying',
      desc: 'Stir frying uses very high heat for short periods. Choose oils that can handle 400°F+ and complement Asian flavors.',
      oils: ['Refined Avocado Oil', 'Peanut Oil', 'Rice Bran Oil', 'Light Sesame Oil', 'Grapeseed Oil']
    },
    'saute': {
      title: 'Best Oils for Sauteing',
      desc: 'Sauteing uses medium to medium-high heat (300-400°F). You have many great options depending on the flavor profile you want.',
      oils: ['Extra Virgin Olive Oil', 'Ghee', 'Butter', 'Avocado Oil', 'Coconut Oil (Refined)']
    },
    'baking': {
      title: 'Best Oils for Baking',
      desc: 'Baking typically ranges from 325-425°F. Choose neutral oils for delicate baked goods or flavorful fats for rich recipes.',
      oils: ['Butter', 'Coconut Oil', 'Canola Oil', 'Light Olive Oil', 'Vegetable Oil']
    },
    'roasting': {
      title: 'Best Oils for Roasting',
      desc: 'Roasting vegetables and meats at 400-450°F requires heat-stable oils that add flavor or stay neutral.',
      oils: ['Avocado Oil', 'Ghee', 'Light Olive Oil', 'Duck Fat', 'Tallow']
    },
    'dressing': {
      title: 'Best Oils for Dressings & Finishing',
      desc: 'No heat needed! Choose oils with the most flavor and nutritional benefit. These specialty oils shine when used raw.',
      oils: ['Extra Virgin Olive Oil', 'Walnut Oil', 'Toasted Sesame Oil', 'Flaxseed Oil', 'Pumpkin Seed Oil']
    }
  };

  methodBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      methodBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const method = btn.getAttribute('data-method');
      const rec = recommendations[method];

      recTitle.textContent = rec.title;
      recDesc.textContent = rec.desc;
      recOils.innerHTML = rec.oils.map(oil => '<span class="rec-oil">' + oil + '</span>').join('');
      selectorResult.classList.add('visible');
    });
  });
</script>

