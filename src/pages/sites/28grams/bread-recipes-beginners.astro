  background: #150d12;
  border-bottom: 1px solid var(--border-color);
}
.chart-header h2 { font-size: 1rem; font-weight: 700; color: #fff; }

/* Table Container */
.table-container {
  width: 100%;
  overflow-x: auto;
}
.compare-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 800px;
}
.compare-table th {
