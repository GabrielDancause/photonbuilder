---
import SiteLayout from "../../../layouts/SiteLayout.astro";
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Guide to Oil Smoke Points",
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does refining an oil change its smoke point?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, refining removes impurities that burn easily, significantly raising the smoke point."
        }
      },
      {
        "@type": "Question",
        "name": "What happens when oil smokes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It degrades, losing nutritional value and developing bitter, burnt flavors."
        }
      },
      {
        "@type": "Question",
        "name": "What is the highest smoke point oil?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Refined avocado oil and safflower oil have some of the highest smoke points, exceeding 500\u00b0F."
        }
      }
    ]
  }
};

export const meta = {
  title: "Interactive Guide to Oil Smoke Points",
  description: "Interactive smoke point chart for 20+ cooking oils — sort by temperature, filter by best use (frying, sauteing, dressings), and find the right oil for any method.",
  category: "guide",
  published: "2026-03-15",
};
---
<SiteLayout site="28grams" title="Interactive Guide to Oil Smoke Points" description="Interactive smoke point chart — sortable by oil, temp, best use." canonical="https://28grams.vip/guide-oil-smoke-points" schema={schema}>
  <div class="page-content">
    <div class="hero"><h1>Guide to Oil Smoke Points</h1><p>Understanding cooking temperatures.</p></div>

    <h2>Why Smoke Points Matter</h2>
    <p>Heating an oil past its smoke point not only ruins the flavor of your food but also destroys beneficial nutrients and creates harmful free radicals.</p>
    <h2>General Smoke Point Chart</h2>
    <ul>
      <li><strong>Avocado Oil (Refined):</strong> ~520°F (High Heat)</li>
      <li><strong>Safflower Oil (Refined):</strong> ~510°F (High Heat)</li>
      <li><strong>Canola Oil:</strong> ~400°F (Medium-High Heat)</li>
      <li><strong>Extra Virgin Olive Oil:</strong> ~350°F - 410°F (Medium Heat)</li>
      <li><strong>Butter:</strong> ~302°F (Low to Medium Heat)</li>
    </ul>
    <h2>Choosing the Right Oil</h2>
    <p>Match the oil's smoke point to your cooking method. Use high smoke point oils for searing and frying, and save delicate, low smoke point oils for dressings and finishing.</p>
    <div class="card">
      <h3>Related Guides</h3>
      <p>Return to the <a href="/cooking-oils-compared">Main Cooking Oils Guide</a> or read about <a href="/high-heat-cooking-oils">High Heat Oils</a> and <a href="/sesame-oil-guide">Sesame Oil</a>.</p>
    </div>

  </div>
  <script is:inline></script>
  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); }
    .card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
  </style>
</SiteLayout>
