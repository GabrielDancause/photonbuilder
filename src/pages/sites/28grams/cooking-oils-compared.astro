    {
      "@type": "Question",
      "name": "What is the best oil for high heat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Avocado oil and refined olive oil are excellent for high heat."
      }
    },
    {
      "@type": "Question",
      "name": "Is coconut oil healthy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Coconut oil is high in saturated fat and should be used in moderation."
      }
    },
    {
      "@type": "Question",
      "name": "What is smoke point?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The temperature at which oil starts to burn and smoke."
      }
    },
    {
      "@type": "Question",
      "name": "Can I fry with extra virgin olive oil?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, but its lower smoke point makes it less ideal than refined oils for deep frying."
      }
    },
    {
      "@type": "Question",
      "name": "What oil is best for baking?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Neutral oils like canola or melted butter are typically best for baking."
      }
    }
  ]
};

export const meta = {
  title: "Every Cooking Oil Compared",
  description: "Side-by-side comparison of every cooking oil — smoke points, flavor profiles, fat composition, nutrition data, best uses, and cost per serving in one sortable chart.",
  category: "study",
  published: "2026-03-15",
};
