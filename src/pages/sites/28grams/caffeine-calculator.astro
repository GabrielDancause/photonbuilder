        </div>
        <div class="card-body">
          <div class="faq-list" id="faqList"></div>
        </div>
      </div>

      <!-- Related -->
      <div class="converter-card">
        <div class="card-header">
          <h2>Related Tools</h2>
        </div>
        <div class="card-body">
          <div class="related-grid">
            <a href="/recipe-calorie-calculator" class="related-card">
              <h3>Recipe Calorie Calculator</h3>
              <p>Calculate calories, macros, and full nutrition for any recipe with a complete ingredient database.</p>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script type="text/javascript">
  (function(){
    // ========== BEVERAGE DATABASE ==========
    const beverages = [
      // Coffee
      { name: 'Drip Coffee', cat: 'coffee', caffPerOz: 11.88, defaultOz: 8, unit: 'oz' },
      { name: 'Espresso', cat: 'coffee', caffPerOz: 63.6, defaultOz: 1, unit: 'shot' },
      { name: 'Latte', cat: 'coffee', caffPerOz: 9.53, defaultOz: 16, unit: 'oz' },
      { name: 'Cold Brew', cat: 'coffee', caffPerOz: 12.5, defaultOz: 16, unit: 'oz' },
      { name: 'Americano', cat: 'coffee', caffPerOz: 9.53, defaultOz: 12, unit: 'oz' },
      { name: 'Cappuccino', cat: 'coffee', caffPerOz: 9.53, defaultOz: 8, unit: 'oz' },
      { name: 'Instant Coffee', cat: 'coffee', caffPerOz: 7.13, defaultOz: 8, unit: 'oz' },
      { name: 'Decaf Coffee', cat: 'coffee', caffPerOz: 0.88, defaultOz: 8, unit: 'oz' },
      // Tea
      { name: 'Black Tea', cat: 'tea', caffPerOz: 5.88, defaultOz: 8, unit: 'oz' },
      { name: 'Green Tea', cat: 'tea', caffPerOz: 3.5, defaultOz: 8, unit: 'oz' },
      { name: 'Matcha', cat: 'tea', caffPerOz: 8.88, defaultOz: 8, unit: 'oz' },
      { name: 'White Tea', cat: 'tea', caffPerOz: 3.75, defaultOz: 8, unit: 'oz' },
      { name: 'Oolong Tea', cat: 'tea', caffPerOz: 4.5, defaultOz: 8, unit: 'oz' },
      { name: 'Chai Tea Latte', cat: 'tea', caffPerOz: 3.17, defaultOz: 12, unit: 'oz' },
      { name: 'Herbal Tea', cat: 'tea', caffPerOz: 0, defaultOz: 8, unit: 'oz' },
      // Energy Drinks
      { name: 'Red Bull', cat: 'energy', caffPerOz: 9.46, defaultOz: 8.4, unit: 'oz' },
      { name: 'Monster Energy', cat: 'energy', caffPerOz: 10, defaultOz: 16, unit: 'oz' },
      { name: 'Bang Energy', cat: 'energy', caffPerOz: 18.75, defaultOz: 16, unit: 'oz' },
      { name: 'Celsius', cat: 'energy', caffPerOz: 16.67, defaultOz: 12, unit: 'oz' },
      { name: 'Reign', cat: 'energy', caffPerOz: 18.75, defaultOz: 16, unit: 'oz' },
      { name: '5-Hour Energy', cat: 'energy', caffPerOz: 103, defaultOz: 1.93, unit: 'oz' },
      { name: 'Rockstar', cat: 'energy', caffPerOz: 10, defaultOz: 16, unit: 'oz' },
      // Soda
      { name: 'Coca-Cola', cat: 'soda', caffPerOz: 2.83, defaultOz: 12, unit: 'oz' },
      { name: 'Diet Coke', cat: 'soda', caffPerOz: 3.83, defaultOz: 12, unit: 'oz' },
      { name: 'Dr Pepper', cat: 'soda', caffPerOz: 3.42, defaultOz: 12, unit: 'oz' },
      { name: 'Mountain Dew', cat: 'soda', caffPerOz: 4.5, defaultOz: 12, unit: 'oz' },
      { name: 'Pepsi', cat: 'soda', caffPerOz: 3.17, defaultOz: 12, unit: 'oz' },
      { name: 'Sprite', cat: 'soda', caffPerOz: 0, defaultOz: 12, unit: 'oz' },
      // Chocolate
      { name: 'Dark Chocolate (70-85%)', cat: 'chocolate', caffPerOz: 22.7, defaultOz: 1, unit: 'g_oz' },
      { name: 'Milk Chocolate', cat: 'chocolate', caffPerOz: 5.7, defaultOz: 1.5, unit: 'g_oz' },
      { name: 'Hot Chocolate', cat: 'chocolate', caffPerOz: 0.63, defaultOz: 8, unit: 'oz' },
      { name: 'Chocolate Milk', cat: 'chocolate', caffPerOz: 0.31, defaultOz: 8, unit: 'oz' },
    ];

    const DAILY_LIMIT = 400;
    const HALF_LIFE = 5.7;
    let selectedBev = null;
    let trackedItems = [];

    const catBtns = document.getElementById('catBtns');
    const bevGrid = document.getElementById('bevGrid');
    const servingRow = document.getElementById('servingRow');
    const servingSizeInput = document.getElementById('servingSize');
    const servingUnitSelect = document.getElementById('servingUnit');
    const bevQtyInput = document.getElementById('bevQty');
    const addBevBtn = document.getElementById('addBevBtn');
    const caffResult = document.getElementById('caffResult');
    const caffPerServing = document.getElementById('caffPerServing');
    const caffPct = document.getElementById('caffPct');
    const dailyTotal = document.getElementById('dailyTotal');
    const progressFill = document.getElementById('progressFill');
    const progressLabel = document.getElementById('progressLabel');
    const trackedList = document.getElementById('trackedList');
    const clearAllBtn = document.getElementById('clearAllBtn');

    // ========== RENDER BEVERAGE GRID ==========
    function renderBevGrid(filter) {
      const filtered = filter === 'all' ? beverages : beverages.filter(b => b.cat === filter);
      bevGrid.innerHTML = filtered.map((b, i) => {
        const idx = beverages.indexOf(b);
        const totalCaff = Math.round(b.caffPerOz * b.defaultOz);
        return `<button class="bev-btn" data-idx="${idx}">
          <span class="bev-name">${b.name}</span>
          <span class="bev-info">${totalCaff}mg / ${b.defaultOz}${b.unit === 'shot' ? ' shot' : b.unit === 'g_oz' ? 'oz' : 'oz'}</span>
        </button>`;
      }).join('');
    }

    // ========== CATEGORY BUTTONS ==========
    catBtns.addEventListener('click', (e) => {
      const btn = e.target.closest('.cat-btn');
      if (!btn) return;
      catBtns.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderBevGrid(btn.dataset.cat);
      selectedBev = null;
      servingRow.style.display = 'none';
      caffResult.classList.remove('show');
    });

    // ========== SELECT BEVERAGE ==========
    bevGrid.addEventListener('click', (e) => {
      const btn = e.target.closest('.bev-btn');
      if (!btn) return;
      bevGrid.querySelectorAll('.bev-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      const idx = parseInt(btn.dataset.idx);
      selectedBev = beverages[idx];
      servingRow.style.display = 'flex';
      servingSizeInput.value = selectedBev.defaultOz;
      if (selectedBev.unit === 'shot') {
        servingUnitSelect.value = 'shot';
      } else if (selectedBev.unit === 'g_oz') {
        servingUnitSelect.value = 'oz';
      } else {
        servingUnitSelect.value = 'oz';
      }
      bevQtyInput.value = 1;
      addBevBtn.disabled = false;
      updateCaffPreview();
    });

    // ========== CAFFEINE PREVIEW ==========
    function getOzMultiplier(unit) {
      if (unit === 'ml') return 1 / 29.5735;
      if (unit === 'shot') return 1;
      if (unit === 'g') return 1 / 28.35;
      return 1;
    }

    function calcCaffeine() {
      if (!selectedBev) return 0;
      const size = parseFloat(servingSizeInput.value) || 0;
      const unit = servingUnitSelect.value;
      const qty = parseInt(bevQtyInput.value) || 1;
      let oz = size * getOzMultiplier(unit);
      if (unit === 'shot') oz = size; // shots: use caffPerOz * shot count
      return Math.round(selectedBev.caffPerOz * oz * qty);
    }

    function updateCaffPreview() {
      const mg = calcCaffeine();
      caffPerServing.textContent = mg + 'mg';
      caffPct.textContent = Math.round((mg / DAILY_LIMIT) * 100) + '%';
      caffResult.classList.add('show');
    }

    servingSizeInput.addEventListener('input', updateCaffPreview);
    servingUnitSelect.addEventListener('change', updateCaffPreview);
    bevQtyInput.addEventListener('input', updateCaffPreview);

    // ========== ADD TO TRACKER ==========
    addBevBtn.addEventListener('click', () => {
      if (!selectedBev) return;
      const mg = calcCaffeine();
      const size = parseFloat(servingSizeInput.value) || 0;
      const unit = servingUnitSelect.value;
      const qty = parseInt(bevQtyInput.value) || 1;
      const unitLabel = unit === 'shot' ? 'shot' : unit === 'ml' ? 'ml' : unit === 'g' ? 'g' : 'oz';
      trackedItems.push({
        name: selectedBev.name,
        size: size,
        unit: unitLabel,
        qty: qty,
        caffeine: mg,
        id: Date.now()
      });
      updateTracker();
    });

    // ========== UPDATE TRACKER ==========
    function updateTracker() {
      const total = trackedItems.reduce((s, i) => s + i.caffeine, 0);
      dailyTotal.textContent = total + 'mg';
      const pct = Math.min(Math.round((total / DAILY_LIMIT) * 100), 100);
      const actualPct = Math.round((total / DAILY_LIMIT) * 100);
      progressFill.style.width = Math.min(actualPct, 100) + '%';
      progressFill.className = 'progress-bar-fill' + (total > DAILY_LIMIT ? ' over' : '');
      progressLabel.textContent = actualPct + '% of 400mg';

      if (trackedItems.length === 0) {
        trackedList.innerHTML = '<div class="empty-state">No beverages added yet. Select a drink above to start tracking.</div>';
        return;
      }

      trackedList.innerHTML = trackedItems.map(item => `
        <div class="tracked-row" data-id="${item.id}">
          <span class="tr-name">${item.name}${item.qty > 1 ? ' x' + item.qty : ''}</span>
          <span class="tr-size">${item.size}${item.unit}</span>
          <span class="tr-caff">${item.caffeine}mg</span>
          <button class="remove-btn" data-id="${item.id}">&#x2715;</button>
        </div>
      `).join('');
    }

    trackedList.addEventListener('click', (e) => {
      const btn = e.target.closest('.remove-btn');
      if (!btn) return;
      const id = parseInt(btn.dataset.id);
      trackedItems = trackedItems.filter(i => i.id !== id);
      updateTracker();
    });

    clearAllBtn.addEventListener('click', () => {
      trackedItems = [];
      updateTracker();
    });

    // ========== HALF-LIFE CALCULATOR ==========
    const hlAmount = document.getElementById('hlAmount');
    const hlTime = document.getElementById('hlTime');
    const hlBedtime = document.getElementById('hlBedtime');
    const hlCalcBtn = document.getElementById('hlCalcBtn');
    const hlResult = document.getElementById('hlResult');
    const hlTimeline = document.getElementById('hlTimeline');
    const hlBedNote = document.getElementById('hlBedNote');

    function parseTime(str) {
      const [h, m] = str.split(':').map(Number);
      return h * 60 + m;
    }

    function formatTime(mins) {
      let m = ((mins % 1440) + 1440) % 1440;
      const h = Math.floor(m / 60);
      const mm = m % 60;
      const ampm = h >= 12 ? 'PM' : 'AM';
      const hh = h === 0 ? 12 : h > 12 ? h - 12 : h;
      return hh + ':' + String(mm).padStart(2, '0') + ' ' + ampm;
    }

    function calcRemaining(initialMg, hoursElapsed) {
      return initialMg * Math.pow(0.5, hoursElapsed / HALF_LIFE);
    }

    hlCalcBtn.addEventListener('click', () => {
      const amount = parseFloat(hlAmount.value);
      if (!amount || amount <= 0) return;

      const consumedMin = parseTime(hlTime.value);
      const bedMin = parseTime(hlBedtime.value);
      let bedDiff = bedMin - consumedMin;
      if (bedDiff <= 0) bedDiff += 1440;

      const steps = [];
      for (let h = 0; h <= Math.ceil(bedDiff / 60); h++) {
        const mins = consumedMin + h * 60;
        const remaining = calcRemaining(amount, h);
        steps.push({ time: mins, mg: remaining, hours: h });
      }
      // Add exact bedtime
      const bedHours = bedDiff / 60;
      const bedRemaining = calcRemaining(amount, bedHours);
      steps.push({ time: bedMin, mg: bedRemaining, hours: bedHours, isBed: true });
      // Deduplicate close times
      const unique = [];
      steps.forEach(s => {
        if (!unique.some(u => Math.abs(u.time % 1440 - s.time % 1440) < 5 && !s.isBed)) {
          unique.push(s);
        }
      });

      hlTimeline.innerHTML = unique.map(s => {
        const pct = (s.mg / amount) * 100;
        const label = s.isBed ? '🛏 ' + formatTime(s.time) : formatTime(s.time);
        return `<div class="hl-row">
          <span class="hl-time">${label}</span>
          <div class="hl-bar-bg"><div class="hl-bar-fill" style="width:${pct}%"></div></div>
          <span class="hl-mg">${Math.round(s.mg)}mg</span>
        </div>`;
      }).join('');

      const bedNote = Math.round(bedRemaining) > 100
        ? `At bedtime (${formatTime(bedMin)}), you'll still have <strong>${Math.round(bedRemaining)}mg</strong> of caffeine in your system — this may affect sleep quality.`
        : Math.round(bedRemaining) > 0
        ? `At bedtime (${formatTime(bedMin)}), you'll have <strong>${Math.round(bedRemaining)}mg</strong> remaining — likely manageable for most people.`
        : `By bedtime (${formatTime(bedMin)}), caffeine will be virtually cleared from your system.`;
      hlBedNote.innerHTML = bedNote;

      hlResult.classList.add('show');
    });

    // ========== COMPARISON TABLE ==========
    const compBody = document.getElementById('compBody');
    const compTable = document.getElementById('compTable');
    let sortCol = 'caffeine';
    let sortDir = -1;

    const catLabels = { coffee: 'Coffee', tea: 'Tea', energy: 'Energy', soda: 'Soda', chocolate: 'Chocolate' };
    const catClasses = { coffee: 'cat-coffee', tea: 'cat-tea', energy: 'cat-energy', soda: 'cat-soda', chocolate: 'cat-chocolate' };

    function renderCompTable() {
      const rows = beverages.map(b => ({
        name: b.name,
        category: b.cat,
        serving: b.defaultOz,
        caffeine: Math.round(b.caffPerOz * b.defaultOz),
        perOz: b.caffPerOz
      }));

      rows.sort((a, b) => {
        let av = a[sortCol], bv = b[sortCol];
        if (typeof av === 'string') av = av.toLowerCase();
        if (typeof bv === 'string') bv = bv.toLowerCase();
        if (av < bv) return -1 * sortDir;
        if (av > bv) return 1 * sortDir;
        return 0;
      });

      compBody.innerHTML = rows.map(r => `
        <tr>
          <td>${r.name}</td>
          <td><span class="cat-tag ${catClasses[r.category]}">${catLabels[r.category]}</span></td>
          <td class="size-val">${r.serving}oz</td>
          <td class="mg-val">${r.caffeine}mg</td>
          <td class="size-val">${r.perOz.toFixed(1)}mg</td>
        </tr>
      `).join('');
    }

    compTable.querySelector('thead').addEventListener('click', (e) => {
      const th = e.target.closest('th');
      if (!th) return;
      const col = th.dataset.col;
      if (sortCol === col) {
        sortDir *= -1;
      } else {
        sortCol = col;
        sortDir = col === 'name' || col === 'category' ? 1 : -1;
      }
      compTable.querySelectorAll('th').forEach(t => {
        t.classList.remove('sorted');
        t.textContent = t.textContent.replace(/ [▴▾]/, '');
      });
      th.classList.add('sorted');
      th.textContent = th.textContent + (sortDir === 1 ? ' ▴' : ' ▾');
      renderCompTable();
    });

    // ========== FAQ ==========
    const faqData = [
      { q: 'How much caffeine is safe per day?', a: 'The FDA recommends a maximum of 400mg of caffeine per day for healthy adults. That\'s roughly four 8oz cups of drip coffee, or about ten cans of cola. Pregnant women are advised to limit intake to 200mg per day. Individual tolerance varies based on genetics, body weight, and how regularly you consume caffeine.' },
      { q: 'How long does caffeine stay in your system?', a: 'Caffeine has an average half-life of about 5.7 hours in healthy adults, meaning half the caffeine is eliminated every 5.7 hours. After consuming 200mg of caffeine at noon, you\'d still have about 100mg in your system around 5:45 PM. It takes approximately 5–6 half-lives (28–34 hours) to fully clear caffeine from your body.' },
      { q: 'Which drink has the most caffeine?', a: 'Per serving, Bang Energy (300mg per 16oz) and cold brew concentrate have the most caffeine among common beverages. Per fluid ounce, espresso leads at about 63mg per ounce, but it\'s typically consumed in small 1oz shots. Drip coffee averages about 12mg per ounce, while tea ranges from 3–8mg per ounce depending on type.' },
      { q: 'Does caffeine content change with serving size?', a: 'Yes. Caffeine content scales linearly with serving size for most beverages. A 16oz drip coffee has roughly double the caffeine of an 8oz cup. Espresso-based drinks like lattes depend on the number of shots rather than total drink volume — a 12oz latte and a 16oz latte with the same number of shots have the same caffeine content.' },
      { q: 'How does caffeine affect sleep?', a: 'Caffeine blocks adenosine receptors in the brain, which suppresses sleepiness. Because of its 5.7-hour half-life, drinking a large coffee at 3 PM means roughly half the caffeine is still active at 8:45 PM. Sleep experts recommend cutting off caffeine at least 6–8 hours before bedtime to minimize its impact on sleep quality and duration.' },
      { q: 'Is caffeine in tea different from caffeine in coffee?', a: 'The caffeine molecule is chemically identical in all sources. However, tea contains L-theanine, an amino acid that modulates caffeine\'s effects — producing a calmer, more sustained alertness compared to coffee. Tea also has less caffeine per serving: a cup of green tea has about 28mg versus 95mg for drip coffee.' },
    ];

    const faqList = document.getElementById('faqList');
    faqList.innerHTML = faqData.map((f, i) => `
      <div class="faq-item">
        <div class="faq-q" data-idx="${i}">
          <span>${f.q}</span>
          <span class="arrow">&#x25BE;</span>
        </div>
        <div class="faq-a"><div class="faq-a-inner">${f.a}</div></div>
      </div>
    `).join('');

    faqList.addEventListener('click', (e) => {
      const q = e.target.closest('.faq-q');
      if (!q) return;
      q.parentElement.classList.toggle('open');
    });

    // ========== INIT ==========
    renderBevGrid('all');
    renderCompTable();
  })();
  </script>
</SiteLayout>
