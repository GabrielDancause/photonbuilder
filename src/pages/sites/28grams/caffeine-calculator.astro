---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Caffeine Calculator",
  "url": "https://28grams.vip/caffeine-calculator",
  "description": "Calculate your daily caffeine intake from coffee, tea, energy drinks, soda, and chocolate. Track your total caffeine with a progress bar, compare beverages, and see how long caffeine stays in your system.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "GAB Ventures",
    "url": "https://gab.ae"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much caffeine is safe per day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The FDA recommends a maximum of 400mg of caffeine per day for healthy adults. That's roughly four 8oz cups of drip coffee, or about ten cans of cola. Pregnant women are advised to limit intake to 200mg per day. Individual tolerance varies based on genetics, body weight, and how regularly you consume caffeine."
      }
    },
    {
      "@type": "Question",
      "name": "How long does caffeine stay in your system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Caffeine has an average half-life of about 5.7 hours in healthy adults, meaning half the caffeine is eliminated every 5.7 hours. After consuming 200mg of caffeine at noon, you'd still have about 100mg in your system around 5:45 PM. It takes approximately 5–6 half-lives (28–34 hours) to fully clear caffeine from your body."
      }
    },
    {
      "@type": "Question",
      "name": "Which drink has the most caffeine?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Per serving, Bang Energy (300mg per 16oz) and cold brew concentrate have the most caffeine among common beverages. Per fluid ounce, espresso leads at about 63mg per ounce, but it's typically consumed in small 1oz shots. Drip coffee averages about 12mg per ounce, while tea ranges from 3–8mg per ounce depending on type."
      }
    },
    {
      "@type": "Question",
      "name": "Does caffeine content change with serving size?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Caffeine content scales linearly with serving size for most beverages. A 16oz drip coffee has roughly double the caffeine of an 8oz cup. Espresso-based drinks like lattes depend on the number of shots rather than total drink volume — a 12oz latte and a 16oz latte with the same number of shots have the same caffeine content."
      }
    },
    {
      "@type": "Question",
      "name": "How does caffeine affect sleep?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Caffeine blocks adenosine receptors in the brain, which suppresses sleepiness. Because of its 5.7-hour half-life, drinking a large coffee at 3 PM means roughly half the caffeine is still active at 8:45 PM. Sleep experts recommend cutting off caffeine at least 6–8 hours before bedtime to minimize its impact on sleep quality and duration."
      }
    },
    {
      "@type": "Question",
      "name": "Is caffeine in tea different from caffeine in coffee?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The caffeine molecule is chemically identical in all sources. However, tea contains L-theanine, an amino acid that modulates caffeine's effects — producing a calmer, more sustained alertness compared to coffee. Tea also has less caffeine per serving: a cup of green tea has about 28mg versus 95mg for drip coffee."
      }
    }
  ]
};

export const meta = {
  title: "Caffeine Calculator — Track Daily Intake",
  description: "Calculate your caffeine intake from coffee, tea, energy drinks, soda, and chocolate. Track daily total vs. the 400mg limit, compare caffeine content, and see how long caffeine stays in your system.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
