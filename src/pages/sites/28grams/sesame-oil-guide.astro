      {
        "@type": "Question",
        "name": "What is toasted sesame oil?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Made from toasted seeds, it has a strong, nutty flavor used mainly for finishing."
        }
      },
      {
        "@type": "Question",
        "name": "Can I fry in sesame oil?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Light sesame oil can be used for cooking, but toasted should not be exposed to high heat."
        }
      },
      {
        "@type": "Question",
        "name": "Does it need refrigeration?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It is recommended to refrigerate toasted sesame oil to prevent it from going rancid."
        }
      }
    ]
  }
};

export const meta = {
  title: "Sesame Oil Guide",
