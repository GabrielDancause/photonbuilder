  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the smoke point of avocado oil?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Refined avocado oil can reach up to 520\u00b0F."
        }
      },
      {
        "@type": "Question",
        "name": "Is avocado oil healthy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, it is high in monounsaturated fats."
        }
      },
      {
        "@type": "Question",
        "name": "Why is it so expensive?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The extraction process from avocado pulp is more costly than seed oils."
        }
      }
    ]
