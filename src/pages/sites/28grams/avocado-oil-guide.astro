};

export const meta = {
  title: "Avocado Oil Guide — Complete Guide",
  description: "Complete avocado oil guide — the real smoke point (not what labels claim), refined vs unrefined differences, nutrition facts, and whether it is worth the premium price.",
  category: "guide",
  published: "2026-03-15",
