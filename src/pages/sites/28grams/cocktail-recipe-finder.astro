      { name: "Caipirinha", spirit: "rum", flavors: ["sour","sweet"], difficulty: "easy", glass: "Rocks glass", garnish: "Lime wedge", ingredients: [["2 oz","Cachaça"],["1","Lime, cut into wedges"],["2 tsp","Sugar"]], instructions: "Muddle lime wedges with sugar in the glass. Fill with crushed ice, add cachaça. Stir well." },
      { name: "Gimlet", spirit: "gin", flavors: ["sour","sweet","herbal"], difficulty: "easy", glass: "Coupe", garnish: "Lime wheel", ingredients: [["2.5 oz","Gin"],["0.75 oz","Lime juice"],["0.75 oz","Simple syrup"]], instructions: "Shake all ingredients with ice. Strain into a chilled coupe." },
      { name: "Mint Julep", spirit: "whiskey", flavors: ["sweet","herbal"], difficulty: "easy", glass: "Julep cup", garnish: "Mint bouquet", ingredients: [["2.5 oz","Bourbon"],["0.5 oz","Simple syrup"],["8 leaves","Fresh mint"]], instructions: "Gently muddle mint with syrup in the cup. Pack with crushed ice, add bourbon. Stir until cup frosts." },
      { name: "Sazerac", spirit: "whiskey", flavors: ["bitter","herbal"], difficulty: "medium", glass: "Rocks glass", garnish: "Lemon peel", ingredients: [["2 oz","Rye whiskey"],["0.25 oz","Simple syrup"],["3 dashes","Peychaud's bitters"],["1 rinse","Absinthe"]], instructions: "Rinse a chilled rocks glass with absinthe. In a mixing glass, stir rye, syrup, and bitters with ice. Strain into the prepared glass. Express lemon peel." },
