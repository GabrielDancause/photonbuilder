      { name: "Bramble", spirit: "gin", flavors: ["sweet","fruity","sour"], difficulty: "medium", glass: "Rocks glass", garnish: "Blackberry, lemon slice", ingredients: [["2 oz","Gin"],["1 oz","Lemon juice"],["0.5 oz","Simple syrup"],["0.5 oz","Crème de mûre"]], instructions: "Shake gin, lemon, and syrup with ice. Strain over crushed ice. Drizzle crème de mûre over the top." },
      { name: "Penicillin", spirit: "whiskey", flavors: ["sour","sweet","herbal"], difficulty: "medium", glass: "Rocks glass", garnish: "Candied ginger", ingredients: [["2 oz","Blended scotch"],["0.75 oz","Lemon juice"],["0.75 oz","Honey-ginger syrup"],["0.25 oz","Islay scotch (float)"]], instructions: "Shake scotch, lemon, and honey-ginger syrup with ice. Strain over rocks. Float Islay scotch on top." },
