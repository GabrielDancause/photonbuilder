---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Cocktail Recipe Finder — 50+ Classic & Popular Cocktails",
      "description": "Interactive cocktail recipe browser with 50+ classic and popular cocktails. Filter by spirit, flavor profile, difficulty, or ingredients you have on hand.",
      "url": "https://28grams.vip/cocktail-recipe-finder",
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are the essential spirits for a home bar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A well-stocked home bar starts with six base spirits: vodka, gin, white rum, bourbon or rye whiskey, tequila (blanco), and brandy or cognac. With these six bottles plus some basic mixers (simple syrup, citrus juice, bitters, and vermouth), you can make the vast majority of classic cocktails."
          }
        },
        {
          "@type": "Question",
          "name": "What's the difference between shaking and stirring a cocktail?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Shake cocktails that contain citrus juice, cream, egg, or fruit — shaking aerates and emulsifies these ingredients for a frothy texture. Stir cocktails that are all spirits (like a Martini or Manhattan) — stirring chills and dilutes without adding air bubbles, keeping the drink silky and clear."
          }
        },
        {
          "@type": "Question",
          "name": "How do I use the 'What Can I Make?' feature?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Click the 'What Can I Make?' tab, then check off all the ingredients you currently have at home. The tool will instantly show you every cocktail you can make with those ingredients, sorted by how many ingredients match. It also shows 'almost' matches where you're just one ingredient short."
          }
        },
        {
          "@type": "Question",
          "name": "What does cocktail difficulty rating mean?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Easy cocktails require simple mixing or stirring with common ingredients — perfect for beginners. Medium cocktails may involve shaking, muddling, or layering techniques. Hard cocktails require advanced techniques like flaming, egg white dry-shaking, fat-washing, or precise timing with specialized equipment."
          }
        },
        {
          "@type": "Question",
          "name": "Can I substitute ingredients in cocktail recipes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Many substitutions work well: swap lime for lemon in sours, use maple syrup instead of simple syrup for depth, replace bourbon with rye for a spicier profile, or use mezcal instead of tequila for smokiness. However, avoid substituting the base spirit entirely — a Margarita without tequila is a different drink."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Cocktail Recipe Finder | 50+ Classic & Popular Cocktails",
  description: "Browse 50+ cocktail recipes. Filter by spirit, flavor, difficulty, or check off ingredients you have to find what you can make. Instructions, measurements, and garnish tips.",
  category: "tool",
  published: "2024-08-15",
};
---

<SiteLayout
  site="28grams"
  title="Cocktail Recipe Finder | 50+ Classic & Popular Cocktails"
  description="Browse 50+ cocktail recipes. Filter by spirit, flavor, difficulty, or check off ingredients you have to find what you can make. Instructions, measurements, and garnish tips."
  canonical="https://28grams.vip/cocktail-recipe-finder"
  schema={schema}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', sans-serif; background: #0a060a; color: #e0d0d8; min-height: 100vh; }
code, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #C2185B, #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1100px; margin: 0 auto; padding: 32px 20px 40px; }

/* Mode Tabs */
.mode-tabs { display: flex; justify-content: center; gap: 8px; margin-bottom: 24px; }
.mode-tab {
  background: #120c10;
  border: 2px solid #2a1820;
  color: #c8b8c0;
  padding: 12px 24px;
  border-radius: 12px;
  font-size: 0.9rem;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
}
.mode-tab:hover { border-color: #C2185B; color: #fff; }
.mode-tab.active { background: #C2185B; border-color: #C2185B; color: #fff; }

/* Filters */
.filter-section { margin-bottom: 24px; }
.filter-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin-bottom: 8px; }
.filter-label {
  font-size: 0.75rem; color: #666; text-transform: uppercase; letter-spacing: 0.5px;
  font-weight: 600; text-align: center; margin-bottom: 6px;
}
.filter-btn {
  background: #120c10; border: 1px solid #2a1820; color: #c8b8c0;
  padding: 8px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600;
  cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s;
}
.filter-btn:hover { border-color: #C2185B; color: #fff; }
.filter-btn.active { background: #C2185B; border-color: #C2185B; color: #fff; }

/* Search */
.search-wrap { position: relative; width: 100%; max-width: 400px; margin: 0 auto 24px; }
.search-input {
  width: 100%; background: #1a1015; border: 1px solid #2a1820; border-radius: 8px;
  padding: 10px 14px 10px 36px; color: #fff; font-family: 'Inter', sans-serif;
  font-size: 0.9rem; outline: none;
}
.search-input:focus { border-color: #C2185B; }
.search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #888; font-size: 0.9rem; }

/* Results header */
.results-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16px; padding: 0 4px;
}
.result-count { font-size: 0.85rem; color: #888; }
.sort-select {
  background: #1a1015; border: 1px solid #2a1820; border-radius: 8px;
  padding: 6px 12px; color: #fff; font-family: 'Inter', sans-serif;
  font-size: 0.8rem; outline: none; cursor: pointer;
}

/* Cocktail Grid */
.cocktail-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
.cocktail-card {
  background: #120c10; border: 2px solid #2a1820; border-radius: 16px;
  overflow: hidden; transition: border-color 0.2s; cursor: pointer;
}
.cocktail-card:hover { border-color: #C2185B; }
.card-top { padding: 16px 20px 12px; }
.card-name { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
.card-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px; }
.card-tag {
  display: inline-block; font-size: 0.65rem; font-weight: 700; padding: 2px 8px;
  border-radius: 4px; text-transform: uppercase; letter-spacing: 0.3px;
}
.tag-spirit { background: #1a2a3a; color: #60a5fa; }
.tag-flavor { background: #2a1a2a; color: #c084fc; }
.tag-difficulty-easy { background: #1a3a1a; color: #4ade80; }
.tag-difficulty-medium { background: #3a2a1a; color: #fbbf24; }
.tag-difficulty-hard { background: #3a1a1a; color: #f87171; }
.card-glass { font-size: 0.8rem; color: #888; }
.card-glass span { color: #c8b8c0; }

/* Expanded card */
.card-details { display: none; border-top: 1px solid #2a1820; padding: 16px 20px; }
.cocktail-card.expanded .card-details { display: block; }
.detail-section { margin-bottom: 12px; }
.detail-label { font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; margin-bottom: 6px; }
.ingredient-list { list-style: none; }
.ingredient-list li { font-size: 0.85rem; color: #c8b8c0; padding: 3px 0; }
.ingredient-list li .amount { color: #f97316; font-weight: 600; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; }
.instructions-text { font-size: 0.85rem; color: #c8b8c0; line-height: 1.6; }
.garnish-text { font-size: 0.85rem; color: #fbbf24; }

/* What Can I Make panel */
.wcim-panel { display: none; }
.wcim-panel.visible { display: block; }
.browse-panel.hidden { display: none; }
.ingredient-checklist {
  background: #120c10; border: 2px solid #2a1820; border-radius: 16px;
  padding: 20px; margin-bottom: 24px;
}
.checklist-group { margin-bottom: 16px; }
.checklist-group-title {
  font-size: 0.75rem; color: #C2185B; text-transform: uppercase; letter-spacing: 0.5px;
  font-weight: 700; margin-bottom: 8px; padding-bottom: 4px; border-bottom: 1px solid #2a1820;
}
.checklist-items { display: flex; flex-wrap: wrap; gap: 6px; }
.check-item {
  background: #1a1015; border: 1px solid #2a1820; color: #c8b8c0;
  padding: 6px 12px; border-radius: 8px; font-size: 0.8rem; font-weight: 600;
  cursor: pointer; font-family: 'Inter', sans-serif; transition: all 0.2s; user-select: none;
}
.check-item:hover { border-color: #C2185B; color: #fff; }
.check-item.checked { background: #2a1030; border-color: #C2185B; color: #fff; }
.check-item.checked::before { content: '✓ '; color: #4ade80; }
.wcim-actions { display: flex; gap: 8px; justify-content: center; margin-bottom: 20px; }
.wcim-btn {
  background: #C2185B; border: none; color: #fff; padding: 10px 20px; border-radius: 8px;
  font-size: 0.85rem; font-weight: 700; cursor: pointer; font-family: 'Inter', sans-serif;
}
.wcim-btn.secondary { background: #2a1820; }
.match-label { font-size: 0.75rem; color: #4ade80; font-weight: 700; margin-left: 8px; }
.match-label.partial { color: #fbbf24; }
.missing-note { font-size: 0.75rem; color: #f87171; margin-top: 4px; }

/* Empty state */
.empty-state { text-align: center; padding: 60px 20px; color: #666; }
.empty-state .icon { font-size: 3rem; margin-bottom: 12px; }
.empty-state p { font-size: 0.95rem; }

/* FAQ */
.faq-section { margin-top: 48px; }
.faq-section h2 { font-size: 1.3rem; font-weight: 800; color: #fff; text-align: center; margin-bottom: 20px; }
.faq-item {
  background: #120c10; border: 1px solid #2a1820; border-radius: 12px;
  padding: 16px 20px; margin-bottom: 8px;
}
.faq-q { font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
.faq-a { font-size: 0.85rem; color: #aaa; line-height: 1.6; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.6rem; }
  .cocktail-grid { grid-template-columns: 1fr; }
  .mode-tabs { flex-direction: column; align-items: center; }
}
  </style>

  <div style="max-width:1100px;margin:0 auto;padding:16px 20px 0;">
    <div style="background:rgba(194,24,91,0.08);border:1px solid rgba(194,24,91,0.2);border-radius:12px;padding:1rem 1.5rem;font-size:0.88rem;color:#888;line-height:1.6;">
      🍹 <strong style="color:#C2185B;">A cocktail at a bar now costs $16 on average.</strong> With prices up 12% this year, making drinks at home saves $10+ per cocktail. Find recipes below using what's already in your cabinet. <a href="https://gab.ae/news/grocery-prices-rising-raspberries-oil-costs-2026" style="color:#C2185B;">Why going out costs more →</a>
