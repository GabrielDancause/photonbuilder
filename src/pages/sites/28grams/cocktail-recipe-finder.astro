      { name: "Daiquiri", spirit: "rum", flavors: ["sour","sweet"], difficulty: "easy", glass: "Coupe", garnish: "Lime wheel", ingredients: [["2 oz","White rum"],["1 oz","Lime juice"],["0.75 oz","Simple syrup"]], instructions: "Shake all ingredients with ice until well-chilled. Fine strain into a coupe glass." },
      { name: "Whiskey Sour", spirit: "whiskey", flavors: ["sour","sweet"], difficulty: "medium", glass: "Rocks glass", garnish: "Cherry, orange slice", ingredients: [["2 oz","Bourbon"],["0.75 oz","Lemon juice"],["0.75 oz","Simple syrup"],["0.5 oz","Egg white (optional)"]], instructions: "Dry shake all ingredients without ice (if using egg white). Add ice and shake again. Strain into a rocks glass over ice." },
      { name: "Negroni", spirit: "gin", flavors: ["bitter","herbal"], difficulty: "easy", glass: "Rocks glass", garnish: "Orange peel", ingredients: [["1 oz","Gin"],["1 oz","Campari"],["1 oz","Sweet vermouth"]], instructions: "Stir all ingredients with ice. Strain into a rocks glass over a large ice cube. Express orange peel." },
      { name: "Manhattan", spirit: "whiskey", flavors: ["bitter","sweet","herbal"], difficulty: "easy", glass: "Coupe", garnish: "Brandied cherry", ingredients: [["2 oz","Rye whiskey"],["1 oz","Sweet vermouth"],["2 dashes","Angostura bitters"]], instructions: "Stir all ingredients with ice for 30 seconds. Strain into a chilled coupe." },
