      </div>

      <div class="cocktail-grid" id="cocktailGrid"></div>
      <div class="empty-state" id="emptyState" style="display:none;">
        <div class="icon">🍹</div>
        <p>No cocktails match your filters. Try broadening your search.</p>
      </div>
    </div>

    <!-- What Can I Make Panel -->
    <div class="wcim-panel" id="wcimPanel">
