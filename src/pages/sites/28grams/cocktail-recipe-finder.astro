      { name: "Pisco Sour", spirit: "brandy", flavors: ["sour","sweet","fruity"], difficulty: "medium", glass: "Coupe", garnish: "Angostura bitters drops", ingredients: [["2 oz","Pisco"],["1 oz","Lime juice"],["0.75 oz","Simple syrup"],["1","Egg white"]], instructions: "Dry shake all ingredients without ice. Add ice and shake again vigorously. Strain into a coupe. Dot bitters on the foam." },
