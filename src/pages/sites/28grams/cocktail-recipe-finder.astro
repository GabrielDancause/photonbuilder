      { name: "Last Word", spirit: "gin", flavors: ["herbal","sweet","sour"], difficulty: "easy", glass: "Coupe", garnish: "Cherry", ingredients: [["0.75 oz","Gin"],["0.75 oz","Green Chartreuse"],["0.75 oz","Maraschino liqueur"],["0.75 oz","Lime juice"]], instructions: "Shake all ingredients with ice. Strain into a coupe." },
      { name: "Corpse Reviver #2", spirit: "gin", flavors: ["sour","herbal","bitter"], difficulty: "medium", glass: "Coupe", garnish: "Orange peel", ingredients: [["0.75 oz","Gin"],["0.75 oz","Cointreau"],["0.75 oz","Lillet Blanc"],["0.75 oz","Lemon juice"],["1 rinse","Absinthe"]], instructions: "Rinse coupe with absinthe. Shake remaining ingredients with ice. Strain into the prepared glass." },
      { name: "White Russian", spirit: "vodka", flavors: ["sweet"], difficulty: "easy", glass: "Rocks glass", garnish: "None", ingredients: [["2 oz","Vodka"],["1 oz","Coffee liqueur"],["1 oz","Heavy cream"]], instructions: "Pour vodka and coffee liqueur over ice in a rocks glass. Float cream on top. Stir gently if desired." },
      { name: "Long Island Iced Tea", spirit: "vodka", flavors: ["sour","sweet"], difficulty: "medium", glass: "Highball", garnish: "Lemon wedge", ingredients: [["0.5 oz","Vodka"],["0.5 oz","Gin"],["0.5 oz","White rum"],["0.5 oz","Tequila"],["0.5 oz","Triple sec"],["0.75 oz","Lemon juice"],["0.5 oz","Simple syrup"],["2 oz","Cola"]], instructions: "Shake all spirits, lemon, and syrup with ice. Strain into an ice-filled highball. Top with cola." },
      { name: "Clover Club", spirit: "gin", flavors: ["fruity","sour","sweet"], difficulty: "medium", glass: "Coupe", garnish: "Raspberries", ingredients: [["2 oz","Gin"],["0.75 oz","Lemon juice"],["0.5 oz","Raspberry syrup"],["1","Egg white"]], instructions: "Dry shake all ingredients. Add ice, shake again. Fine strain into a coupe." },
      { name: "Zombie", spirit: "rum", flavors: ["fruity","sweet","sour"], difficulty: "hard", glass: "Tiki mug", garnish: "Mint sprig, cherry", ingredients: [["1.5 oz","Gold rum"],["1.5 oz","Dark rum"],["1 oz","151 rum (float)"],["1 oz","Lime juice"],["0.5 oz","Falernum"],["0.5 oz","Grenadine"],["1 oz","Pineapple juice"]], instructions: "Shake all ingredients except 151 rum with ice. Strain into a tiki mug with crushed ice. Float 151 on top." },
      { name: "Aviation", spirit: "gin", flavors: ["sour","sweet","fruity"], difficulty: "medium", glass: "Coupe", garnish: "Cherry", ingredients: [["2 oz","Gin"],["0.75 oz","Lemon juice"],["0.5 oz","Maraschino liqueur"],["0.25 oz","Crème de violette"]], instructions: "Shake all ingredients with ice. Strain into a coupe." },
      { name: "Rum Punch", spirit: "rum", flavors: ["sweet","fruity"], difficulty: "easy", glass: "Highball", garnish: "Orange slice, nutmeg", ingredients: [["2 oz","Dark rum"],["1 oz","Orange juice"],["1 oz","Pineapple juice"],["0.5 oz","Lime juice"],["0.5 oz","Grenadine"]], instructions: "Shake all ingredients with ice. Strain over ice in a highball glass. Grate nutmeg on top." },
      { name: "Vieux Carré", spirit: "whiskey", flavors: ["bitter","herbal","sweet"], difficulty: "medium", glass: "Rocks glass", garnish: "Lemon peel", ingredients: [["1 oz","Rye whiskey"],["1 oz","Cognac"],["1 oz","Sweet vermouth"],["1 tsp","Bénédictine"],["2 dashes","Peychaud's bitters"],["2 dashes","Angostura bitters"]], instructions: "Stir all ingredients with ice. Strain over a large ice cube in a rocks glass." },
      { name: "Daiquiri (Hemingway)", spirit: "rum", flavors: ["sour","fruity"], difficulty: "medium", glass: "Coupe", garnish: "Grapefruit twist", ingredients: [["2 oz","White rum"],["0.75 oz","Lime juice"],["0.5 oz","Grapefruit juice"],["0.5 oz","Maraschino liqueur"]], instructions: "Shake all ingredients with ice. Fine strain into a chilled coupe." },
      { name: "Brandy Alexander", spirit: "brandy", flavors: ["sweet"], difficulty: "easy", glass: "Coupe", garnish: "Nutmeg", ingredients: [["1.5 oz","Cognac"],["1 oz","Crème de cacao"],["1 oz","Heavy cream"]], instructions: "Shake all ingredients with ice. Strain into a chilled coupe. Grate fresh nutmeg on top." },
      { name: "Jungle Bird", spirit: "rum", flavors: ["bitter","fruity","sweet"], difficulty: "easy", glass: "Rocks glass", garnish: "Pineapple wedge", ingredients: [["1.5 oz","Dark rum"],["0.75 oz","Campari"],["1.5 oz","Pineapple juice"],["0.5 oz","Lime juice"],["0.5 oz","Simple syrup"]], instructions: "Shake all ingredients with ice. Strain over fresh ice in a rocks glass." },
      { name: "Paper Plane", spirit: "whiskey", flavors: ["bitter","sour","sweet"], difficulty: "easy", glass: "Coupe", garnish: "None", ingredients: [["0.75 oz","Bourbon"],["0.75 oz","Aperol"],["0.75 oz","Amaro Nonino"],["0.75 oz","Lemon juice"]], instructions: "Shake all ingredients with ice. Strain into a coupe." },
      { name: "Gin Fizz", spirit: "gin", flavors: ["sour","sweet"], difficulty: "medium", glass: "Highball", garnish: "Lemon wheel", ingredients: [["2 oz","Gin"],["1 oz","Lemon juice"],["0.75 oz","Simple syrup"],["1","Egg white"],["2 oz","Club soda"]], instructions: "Dry shake gin, lemon, syrup, and egg white. Add ice, shake again. Strain into a highball (no ice). Top with soda." },
      { name: "Rusty Nail", spirit: "whiskey", flavors: ["sweet","herbal"], difficulty: "easy", glass: "Rocks glass", garnish: "Lemon twist", ingredients: [["2 oz","Scotch whisky"],["0.75 oz","Drambuie"]], instructions: "Stir both ingredients with ice. Strain into a rocks glass over a large ice cube." },
      { name: "Cuba Libre", spirit: "rum", flavors: ["sweet","sour"], difficulty: "easy", glass: "Highball", garnish: "Lime wedge", ingredients: [["2 oz","White rum"],["0.5 oz","Lime juice"],["4 oz","Cola"]], instructions: "Build in a highball with ice. Add rum and lime juice, top with cola. Stir gently." },
      { name: "Ramos Gin Fizz", spirit: "gin", flavors: ["sweet","sour","fruity"], difficulty: "hard", glass: "Collins glass", garnish: "None", ingredients: [["2 oz","Gin"],["0.5 oz","Lemon juice"],["0.5 oz","Lime juice"],["1 oz","Simple syrup"],["1 oz","Heavy cream"],["1","Egg white"],["3 drops","Orange flower water"],["2 oz","Club soda"]], instructions: "Dry shake everything except soda for 2 minutes. Add ice, shake 1 more minute. Strain into a Collins glass. Let rest, then slowly pour soda to lift the foam." },
      { name: "Gold Rush", spirit: "whiskey", flavors: ["sour","sweet"], difficulty: "easy", glass: "Rocks glass", garnish: "Lemon twist", ingredients: [["2 oz","Bourbon"],["0.75 oz","Lemon juice"],["0.75 oz","Honey syrup"]], instructions: "Shake all ingredients with ice. Strain into a rocks glass over ice." },
      { name: "Hurricane", spirit: "rum", flavors: ["sweet","fruity","sour"], difficulty: "easy", glass: "Hurricane glass", garnish: "Orange slice, cherry", ingredients: [["2 oz","Dark rum"],["2 oz","White rum"],["1 oz","Orange juice"],["1 oz","Passion fruit juice"],["0.5 oz","Lime juice"],["0.5 oz","Grenadine"]], instructions: "Shake all ingredients with ice. Strain into a hurricane glass filled with ice." },
      { name: "Mezcal Mule", spirit: "tequila", flavors: ["sour","sweet","herbal"], difficulty: "easy", glass: "Copper mug", garnish: "Lime wheel", ingredients: [["2 oz","Mezcal"],["0.75 oz","Lime juice"],["4 oz","Ginger beer"]], instructions: "Build in a copper mug with ice. Add mezcal and lime juice, top with ginger beer." },
      { name: "Between the Sheets", spirit: "brandy", flavors: ["sour","sweet"], difficulty: "medium", glass: "Coupe", garnish: "Lemon twist", ingredients: [["1 oz","Cognac"],["1 oz","White rum"],["1 oz","Triple sec"],["0.5 oz","Lemon juice"]], instructions: "Shake all ingredients with ice. Strain into a chilled coupe." },
      { name: "Boulevardier (Mezcal)", spirit: "tequila", flavors: ["bitter","sweet","herbal"], difficulty: "easy", glass: "Rocks glass", garnish: "Orange peel", ingredients: [["1.5 oz","Mezcal"],["1 oz","Campari"],["1 oz","Sweet vermouth"]], instructions: "Stir all ingredients with ice. Strain over a large ice cube. Express orange peel." }
    ];

    const ingredientGroups = {
      "Spirits": ["Vodka","Gin","White rum","Dark rum","Aged rum","Gold rum","151 rum","Cachaça","Bourbon","Rye whiskey","Scotch whisky","Blended scotch","Islay scotch","Tequila blanco","Mezcal","Cognac","Pisco"],
      "Liqueurs": ["Triple sec","Cointreau","Coffee liqueur","Campari","Aperol","Sweet vermouth","Dry vermouth","Lillet Blanc","Amaretto","Green Chartreuse","Maraschino liqueur","Crème de mûre","Crème de violette","Crème de cacao","Orange curaçao","Falernum","Drambuie","Bénédictine","Amaro Nonino","Absinthe"],
      "Citrus & Juice": ["Lime juice","Lemon juice","Orange juice","Grapefruit juice","Pineapple juice","Cranberry juice","Passion fruit juice","Tomato juice"],
      "Sweeteners & Syrups": ["Simple syrup","Honey syrup","Honey-ginger syrup","Grenadine","Orgeat syrup","Raspberry syrup","Sugar","Orange flower water"],
      "Mixers & Other": ["Club soda","Tonic water","Ginger beer","Cola","Champagne","Prosecco","Fresh espresso","Heavy cream","Coconut cream","Egg white","Fresh mint","Angostura bitters","Peychaud's bitters","Orange bitters","Hot sauce","Worcestershire","Salt, pepper, celery salt"]
    };

    function getAllIngredients(c) {
      return c.ingredients.map(i => i[1]);
    }

    function normalize(s) {
      return s.toLowerCase().replace(/[^a-z0-9]/g, '');
    }

    let activeSpirit = 'all', activeFlavor = 'all', activeDifficulty = 'all', searchQuery = '';

    function renderCard(c, extraHtml) {
      const diffClass = 'tag-difficulty-' + c.difficulty;
      const flavorTags = c.flavors.map(f => `<span class="card-tag tag-flavor">${f}</span>`).join('');
      const ingHtml = c.ingredients.map(i => `<li><span class="amount">${i[0]}</span> ${i[1]}</li>`).join('');
      return `<div class="cocktail-card" data-name="${c.name}">
        <div class="card-top">
          <div class="card-name">${c.name}${extraHtml || ''}</div>
          <div class="card-meta">
            <span class="card-tag tag-spirit">${c.spirit}</span>
            ${flavorTags}
            <span class="card-tag ${diffClass}">${c.difficulty}</span>
          </div>
          <div class="card-glass">Glass: <span>${c.glass}</span></div>
        </div>
        <div class="card-details">
          <div class="detail-section">
            <div class="detail-label">Ingredients</div>
            <ul class="ingredient-list">${ingHtml}</ul>
          </div>
          <div class="detail-section">
            <div class="detail-label">Instructions</div>
            <div class="instructions-text">${c.instructions}</div>
          </div>
          <div class="detail-section">
            <div class="detail-label">Garnish</div>
            <div class="garnish-text">${c.garnish}</div>
          </div>
        </div>
      </div>`;
    }

    function filterCocktails() {
      return cocktails.filter(c => {
        if (activeSpirit !== 'all' && c.spirit !== activeSpirit) return false;
        if (activeFlavor !== 'all' && !c.flavors.includes(activeFlavor)) return false;
        if (activeDifficulty !== 'all' && c.difficulty !== activeDifficulty) return false;
        if (searchQuery && !normalize(c.name).includes(normalize(searchQuery))) return false;
        return true;
      });
    }

    function sortCocktails(list) {
      const sortBy = document.getElementById('sortSelect').value;
      return [...list].sort((a, b) => {
        if (sortBy === 'name') return a.name.localeCompare(b.name);
        if (sortBy === 'difficulty') {
          const order = { easy: 0, medium: 1, hard: 2 };
          return order[a.difficulty] - order[b.difficulty];
        }
        if (sortBy === 'ingredients') return a.ingredients.length - b.ingredients.length;
        return 0;
      });
    }

    function renderBrowse() {
      const filtered = sortCocktails(filterCocktails());
      const grid = document.getElementById('cocktailGrid');
      const empty = document.getElementById('emptyState');
      const count = document.getElementById('resultCount');
      count.textContent = filtered.length + ' cocktail' + (filtered.length !== 1 ? 's' : '');
      if (filtered.length === 0) {
        grid.innerHTML = '';
        empty.style.display = 'block';
      } else {
        empty.style.display = 'none';
        grid.innerHTML = filtered.map(c => renderCard(c)).join('');
      }
      attachCardListeners(grid);
    }

    function attachCardListeners(container) {
      container.querySelectorAll('.cocktail-card').forEach(card => {
        card.addEventListener('click', () => card.classList.toggle('expanded'));
      });
    }

    // Filter buttons
    function setupFilters(containerId, attr, setter) {
      document.getElementById(containerId).addEventListener('click', e => {
        const btn = e.target.closest('.filter-btn');
        if (!btn) return;
        document.getElementById(containerId).querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        setter(btn.getAttribute('data-' + attr));
        renderBrowse();
      });
    }
    setupFilters('spiritFilters', 'spirit', v => activeSpirit = v);
    setupFilters('flavorFilters', 'flavor', v => activeFlavor = v);
    setupFilters('difficultyFilters', 'difficulty', v => activeDifficulty = v);

    document.getElementById('searchInput').addEventListener('input', e => {
      searchQuery = e.target.value;
      renderBrowse();
    });
    document.getElementById('sortSelect').addEventListener('change', renderBrowse);

    // Mode tabs
    document.querySelectorAll('.mode-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const mode = tab.getAttribute('data-mode');
        document.getElementById('browsePanel').classList.toggle('hidden', mode !== 'browse');
        document.getElementById('wcimPanel').classList.toggle('visible', mode === 'wcim');
      });
    });

    // What Can I Make
    const checkedIngredients = new Set();

    function renderChecklist() {
      const container = document.getElementById('ingredientChecklist');
      let html = '';
      for (const [group, items] of Object.entries(ingredientGroups)) {
        html += `<div class="checklist-group"><div class="checklist-group-title">${group}</div><div class="checklist-items">`;
        items.forEach(item => {
          html += `<button class="check-item" data-ing="${item}">${item}</button>`;
        });
        html += '</div></div>';
      }
      container.innerHTML = html;
      container.addEventListener('click', e => {
        const btn = e.target.closest('.check-item');
        if (!btn) return;
        const ing = btn.getAttribute('data-ing');
        if (checkedIngredients.has(ing)) {
          checkedIngredients.delete(ing);
          btn.classList.remove('checked');
        } else {
          checkedIngredients.add(ing);
          btn.classList.add('checked');
        }
      });
    }

    function findMatches() {
      if (checkedIngredients.size === 0) {
        document.getElementById('wcimGrid').innerHTML = '';
        document.getElementById('wcimEmpty').style.display = 'block';
        document.getElementById('wcimCount').textContent = '';
        return;
      }
      const normalizedHave = new Set([...checkedIngredients].map(normalize));
      const results = cocktails.map(c => {
        const ings = getAllIngredients(c);
        const total = ings.length;
        let matched = 0;
        const missing = [];
        ings.forEach(ing => {
          if (normalizedHave.has(normalize(ing))) matched++;
          else missing.push(ing);
        });
        return { cocktail: c, matched, total, missing, pct: matched / total };
      }).filter(r => r.missing.length <= 1 && r.matched > 0)
        .sort((a, b) => {
          if (a.missing.length !== b.missing.length) return a.missing.length - b.missing.length;
          return b.pct - a.pct;
        });

      const grid = document.getElementById('wcimGrid');
      const empty = document.getElementById('wcimEmpty');
      const count = document.getElementById('wcimCount');

      const full = results.filter(r => r.missing.length === 0);
      const partial = results.filter(r => r.missing.length === 1);
      count.textContent = full.length + ' perfect match' + (full.length !== 1 ? 'es' : '') + ', ' + partial.length + ' almost';

      if (results.length === 0) {
        grid.innerHTML = '';
        empty.style.display = 'block';
        empty.querySelector('p').textContent = 'No matches found. Try adding more ingredients.';
      } else {
        empty.style.display = 'none';
        grid.innerHTML = results.map(r => {
          const label = r.missing.length === 0
            ? '<span class="match-label">✓ Perfect match</span>'
            : `<span class="match-label partial">Missing 1</span>`;
          const missingNote = r.missing.length > 0
            ? `<div class="missing-note">Need: ${r.missing.join(', ')}</div>` : '';
          return renderCard(r.cocktail, label) .replace('</div></div></div>', missingNote + '</div></div></div>');
        }).join('');
      }
      attachCardListeners(grid);
    }

    document.getElementById('findMatchesBtn').addEventListener('click', findMatches);
    document.getElementById('clearChecksBtn').addEventListener('click', () => {
      checkedIngredients.clear();
      document.querySelectorAll('.check-item').forEach(b => b.classList.remove('checked'));
      document.getElementById('wcimGrid').innerHTML = '';
      document.getElementById('wcimEmpty').style.display = 'block';
      document.getElementById('wcimEmpty').querySelector('p').textContent = 'Check off ingredients above, then hit "Find Matches" to see what you can make.';
      document.getElementById('wcimCount').textContent = '';
    });

    renderChecklist();
    renderBrowse();
  </script>
</SiteLayout>
