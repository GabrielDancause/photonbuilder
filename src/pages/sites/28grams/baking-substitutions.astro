  // Build calculator dropdowns
  const calcOrig = document.getElementById('calcOriginal');
  const calcSub = document.getElementById('calcSub');
  const calcAmt = document.getElementById('calcAmount');
  const calcUnit = document.getElementById('calcUnit');
  const calcVal = document.getElementById('calcResultVal');
  const calcLbl = document.getElementById('calcResultLbl');
  const calcNote = document.getElementById('calcResultNote');

  // Flat list of all original→sub pairs
  const pairs = [];
  DATA.forEach(ing => {
    ing.subs.forEach(s => {
      pairs.push({ original: ing.name, sub: s.name, ratio: s.ratio, note: s.note, bestFor: s.bestFor });
    });
  });

  // Populate original dropdown
  const origNames = [...new Set(pairs.map(p => p.original))];
  origNames.forEach(n => {
    const o = document.createElement('option');
    o.value = n; o.textContent = n;
    calcOrig.appendChild(o);
  });

  function updateSubDropdown() {
    const orig = calcOrig.value;
    calcSub.innerHTML = '';
    const subs = pairs.filter(p => p.original === orig);
    subs.forEach(s => {
      const o = document.createElement('option');
      o.value = s.sub; o.textContent = s.sub;
      calcSub.appendChild(o);
    });
    updateCalcResult();
  }

  function parseRatio(ratioStr) {
    // Try to extract a simple numeric ratio
    // Patterns: "1:1", "¾ cup per 1 cup", "¼ cup (60g) per egg"
    const fractions = { '¼': 0.25, '½': 0.5, '¾': 0.75, '⅓': 0.333, '⅔': 0.667, '⅛': 0.125, '⅜': 0.375, '⅝': 0.625, '⅞': 0.875 };

    if (ratioStr.includes('1:1')) return { factor: 1, display: null };

    // "¾ cup per 1 cup" pattern
    for (const [frac, val] of Object.entries(fractions)) {
      if (ratioStr.includes(frac + ' cup per 1 cup') || ratioStr.includes(frac + ' cup per cup')) {
        return { factor: val, display: null };
      }
    }

    // Return raw string if can't parse
    return { factor: null, display: ratioStr };
  }

  function updateCalcResult() {
    const orig = calcOrig.value;
    const sub = calcSub.value;
    const amount = parseFloat(calcAmt.value) || 0;
    const unit = calcUnit.options[calcUnit.selectedIndex].text;

    const pair = pairs.find(p => p.original === orig && p.sub === sub);
    if (!pair) { calcVal.textContent = '—'; calcLbl.textContent = 'Select ingredients'; calcNote.textContent = ''; return; }

    const parsed = parseRatio(pair.ratio);
    if (parsed.factor !== null) {
      const result = (amount * parsed.factor);
      const formatted = result % 1 === 0 ? result.toString() : result.toFixed(2);
      calcVal.textContent = `${formatted} ${unit.toLowerCase()}`;
      calcLbl.textContent = `${amount} ${unit.toLowerCase()} ${orig} → ${formatted} ${unit.toLowerCase()} ${sub}`;
    } else {
      calcVal.textContent = pair.ratio;
      calcLbl.textContent = `For ${amount} ${unit.toLowerCase()} of ${orig}:`;
    }
    calcNote.textContent = pair.note;
  }

  calcOrig.addEventListener('change', updateSubDropdown);
  calcSub.addEventListener('change', updateCalcResult);
  calcAmt.addEventListener('input', updateCalcResult);
  calcUnit.addEventListener('change', updateCalcResult);
  updateSubDropdown();

  // Render ingredient cards
  const listEl = document.getElementById('ingredientsList');
  const searchInput = document.getElementById('searchInput');
  let activeFilter = 'all';

  function renderCards() {
    const query = searchInput.value.toLowerCase().trim();
    listEl.innerHTML = '';
    let count = 0;

    DATA.forEach(ing => {
      // Filter subs by dietary tag
      const filteredSubs = activeFilter === 'all'
        ? ing.subs
        : ing.subs.filter(s => s.tags.includes(activeFilter));

      if (filteredSubs.length === 0) return;

      // Search filter
      const matchesName = ing.name.toLowerCase().includes(query);
      const matchesSub = filteredSubs.some(s => s.name.toLowerCase().includes(query));
      if (query && !matchesName && !matchesSub) return;

      count++;
      const card = document.createElement('div');
      card.className = 'ingredient-card' + (query || DATA.indexOf(ing) === 0 ? ' open' : '');
      card.innerHTML = `
        <div class="ing-header">
          <div class="ing-title"><span class="icon">${ing.icon}</span> ${ing.name}</div>
          <div style="display:flex;align-items:center;gap:10px;">
            <span class="ing-count">${filteredSubs.length} substitute${filteredSubs.length > 1 ? 's' : ''}</span>
            <span class="ing-toggle">+</span>
          </div>
        </div>
        <div class="ing-body">
          <div class="subs-list">
            ${filteredSubs.map(s => `
              <div class="sub-row">
                <div class="sub-top">
                  <span class="sub-name">${s.name}</span>
                  <div class="sub-tags">
                    ${s.tags.map(t => {
                      const labels = { vegan: 'Vegan', gf: 'GF', df: 'Dairy-Free', keto: 'Keto' };
                      return `<span class="tag tag-${t}">${labels[t]}</span>`;
                    }).join('')}
                  </div>
                </div>
                <div class="sub-ratio">${s.ratio}</div>
                <div class="sub-best"><strong>Best for:</strong> ${s.bestFor}</div>
                <div class="sub-note">${s.note}</div>
              </div>
            `).join('')}
          </div>
        </div>
      `;

      card.querySelector('.ing-header').addEventListener('click', () => {
        card.classList.toggle('open');
      });

      listEl.appendChild(card);
    });

    if (count === 0) {
      listEl.innerHTML = '<div class="no-results">No ingredients match your search. Try a different term.</div>';
    }
  }

  searchInput.addEventListener('input', renderCards);

  // Filter chips
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeFilter = chip.dataset.filter;
      renderCards();
    });
  });

  // FAQ toggles
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement.classList.toggle('open');
    });
  });

  // Initial render
  renderCards();
  </script>
