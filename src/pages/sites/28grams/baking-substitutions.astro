---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Baking Substitutions Chart — 40+ Ingredient Swaps",
      "description": "Complete baking substitution guide with 40+ ingredient swaps. Find egg substitutes, dairy-free alternatives, gluten-free flours, and more with ratios and usage notes.",
      "url": "https://28grams.vip/baking-substitutions",
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best egg substitute for baking?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The best egg substitute depends on the recipe. For binding, use 1 tablespoon ground flaxseed mixed with 3 tablespoons water (a 'flax egg'). For moisture and lift in cakes, use ¼ cup unsweetened applesauce or mashed banana per egg. For light and fluffy recipes, 3 tablespoons aquafaba (chickpea liquid) whips like egg whites."
          }
        },
        {
          "@type": "Question",
          "name": "Can I substitute oil for butter in baking?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, you can generally replace butter with oil using a 3:4 ratio — use ¾ cup oil for every 1 cup of butter. This works well in cakes, muffins, and quick breads. However, recipes that rely on creaming butter with sugar (like cookies) may have a different texture since oil doesn't trap air the same way."
          }
        },
        {
          "@type": "Question",
          "name": "What can I use instead of all-purpose flour for gluten-free baking?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 1:1 gluten-free flour blend (like Bob's Red Mill or King Arthur) is the easiest swap. For individual flours, try almond flour (adds moisture, works great in cookies and cakes) or oat flour (good for muffins and pancakes). You may need to add xanthan gum (½ tsp per cup of flour) for structure if your blend doesn't include it."
          }
        },
        {
          "@type": "Question",
          "name": "How do I substitute honey for sugar in baking?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use ¾ cup honey for every 1 cup sugar, reduce another liquid in the recipe by 3 tablespoons, add ¼ teaspoon baking soda per cup of honey (to neutralize acidity), and lower the oven temperature by 25°F since honey caramelizes faster. The baked good will be denser and moister."
          }
        },
        {
          "@type": "Question",
          "name": "Can I use baking soda instead of baking powder?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, but you need to adjust. Use ¼ teaspoon baking soda plus ½ teaspoon cream of tartar to replace 1 teaspoon of baking powder. Baking soda needs an acid to activate (like buttermilk, yogurt, or lemon juice), while baking powder already contains its own acid."
          }
        },
        {
          "@type": "Question",
          "name": "What's a good substitute for buttermilk?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The easiest substitute is 1 cup milk plus 1 tablespoon lemon juice or white vinegar — let it sit for 5-10 minutes until it curdles. You can also use plain yogurt or sour cream thinned with a little milk. For dairy-free, use 1 cup plant milk with 1 tablespoon lemon juice."
          }
        },
        {
          "@type": "Question",
          "name": "Does substituting ingredients affect baking times?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Substitutions can affect baking times. Liquid sweeteners like honey cause faster browning, so reduce oven temperature by 25°F. Gluten-free batters may bake slightly longer. Denser substitutes like applesauce can increase baking time. Always check doneness a few minutes early and use visual cues (golden edges, clean toothpick) rather than relying solely on the timer."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Baking Substitutions Chart | 40+ Ingredient Swaps Guide",
  description: "Complete baking substitute chart for eggs, dairy, flour, sugar, and more. Filter by dietary need — vegan, gluten-free, dairy-free. Ratios, notes, and best-use tips.",
  category: "guide",
  published: "2024-06-10",
};
---

<SiteLayout
  site="28grams"
  title="Baking Substitutions Chart | 40+ Ingredient Swaps Guide"
  description="Complete baking substitute chart for eggs, dairy, flour, sugar, and more. Filter by dietary need — vegan, gluten-free, dairy-free. Ratios, notes, and best-use tips."
  canonical="https://28grams.vip/baking-substitutions"
  schema={schema}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', sans-serif; background: #0a060a; color: #e0d0d8; min-height: 100vh; }
code, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #C2185B, #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1100px; margin: 0 auto; padding: 32px 20px 40px; }

/* Quick Lookup */
.lookup-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
  text-align: center;
}
.lookup-card h3 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 12px; }
.lookup-select {
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 8px;
  padding: 10px 16px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  min-width: 260px;
  outline: none;
  cursor: pointer;
}
.lookup-select:focus { border-color: #C2185B; }

/* Filters */
.filter-section { margin-bottom: 24px; }
.filter-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
  margin-bottom: 8px;
}
.filter-label {
  font-size: 0.75rem;
  color: #666;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 6px;
}
.filter-btn {
  background: #120c10;
  border: 1px solid #2a1820;
  color: #c8b8c0;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
}
.filter-btn:hover { border-color: #C2185B; color: #fff; }
.filter-btn.active { background: #C2185B; border-color: #C2185B; color: #fff; }

/* Chart Card */
.chart-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.chart-header {
  display: flex;
