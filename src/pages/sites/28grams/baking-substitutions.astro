  top: 0;
  cursor: pointer;
  user-select: none;
}
.sub-table th:hover { color: #ccc; }
.sub-table td {
  padding: 12px 16px;
  font-size: 0.88rem;
  color: #c8b8c0;
  border-bottom: 1px solid #1a1015;
}
.sub-table tr:hover td { background: #1a1015; }
.sub-table tr.hidden { display: none; }
.sub-table td:first-child { font-weight: 600; color: #fff; }
.ratio-cell { color: #f97316; font-weight: 600; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; }
.notes-cell { font-size: 0.8rem; color: #aaa; }
.best-cell { font-size: 0.8rem; }
.cat-icon { margin-right: 6px; font-size: 1.1em; }
.diet-tags { display: flex; gap: 4px; flex-wrap: wrap; }
.diet-tag {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}
.tag-vegan { background: #1a3a1a; color: #4ade80; }
.tag-gf { background: #3a2a1a; color: #fbbf24; }
.tag-df { background: #1a2a3a; color: #60a5fa; }
.tag-ls { background: #2a1a2a; color: #c084fc; }
.tag-ef { background: #2a2a1a; color: #a3e635; }

/* Sort Icons */
.sort-icon {
  display: inline-block;
  width: 0;
  height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-bottom: 4px solid #888;
  margin-left: 4px;
  vertical-align: middle;
  transition: transform 0.2s;
}
th.asc .sort-icon { transform: rotate(0deg); border-bottom-color: #C2185B; }
th.desc .sort-icon { transform: rotate(180deg); border-bottom-color: #C2185B; }

/* Tips Card */
.tips-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 32px;
}
.tips-card h3 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 16px; }
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.tip-item {
  background: #1a1015;
  border-radius: 12px;
  padding: 16px;
  border: 1px solid #2a1820;
}
.tip-item h4 { font-size: 0.9rem; color: #ccc; margin-bottom: 8px; }
.tip-item p { font-size: 0.82rem; color: #888; line-height: 1.6; }

/* SEO content */
.content { max-width: 800px; margin: 0 auto; padding: 0 20px; }
.content h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 40px 0 14px; }
.content h2:first-child { margin-top: 0; }
.content h3 { font-size: 1.1rem; font-weight: 700; color: #ddd; margin: 24px 0 10px; }
.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }
.content ul, .content ol { padding-left: 20px; margin-bottom: 14px; }
.content li { font-size: 0.88rem; color: #777; line-height: 1.8; margin-bottom: 4px; }
.content strong { color: #ccc; }

/* FAQ */
.faq-list { margin-bottom: 40px; }
.faq-item { border-bottom: 1px solid #1a1015; padding: 16px 0; }
.faq-item:last-child { border-bottom: none; }
.faq-q { font-size: 0.95rem; font-weight: 700; color: #ddd; margin-bottom: 8px; }
.faq-a { font-size: 0.88rem; color: #777; line-height: 1.8; }

/* Related */
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
  margin-top: 12px;
}
.related-link {
  display: block;
  background: #120c10;
  border: 1px solid #2a1820;
  border-radius: 12px;
  padding: 16px;
  text-decoration: none;
  transition: all 0.2s;
}
.related-link:hover { border-color: #C2185B; transform: translateY(-2px); }
.related-link h4 { font-size: 0.85rem; color: #fff; font-weight: 700; margin-bottom: 4px; }
.related-link p { font-size: 0.75rem; color: #666; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
  .chart-header { flex-direction: column; gap: 12px; align-items: flex-start; }
  .search-wrap { max-width: 100%; }
  .lookup-select { min-width: 100%; }
}
  </style>

