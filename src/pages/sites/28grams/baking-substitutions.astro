<script is:inline>
  const searchInput = document.getElementById('searchInput');
  const catBtns = document.querySelectorAll('#catFilters .filter-btn');
  const dietBtns = document.querySelectorAll('#dietFilters .filter-btn');
  const rows = document.querySelectorAll('.sub-row');
  const headers = document.querySelectorAll('th[data-sort]');
  const tableBody = document.getElementById('tableBody');
  const resultCount = document.getElementById('resultCount');
  const lookupSelect = document.getElementById('lookupSelect');

  let currentCat = 'all';
  let activeDiets = new Set();
  let searchQuery = '';

  function applyFilters() {
    let visible = 0;
    rows.forEach(row => {
      const cat = row.getAttribute('data-category');
      const diets = row.getAttribute('data-diet');
      const text = row.innerText.toLowerCase();
      const original = row.getAttribute('data-original');

      const matchesCat = currentCat === 'all' || cat === currentCat;
      const matchesSearch = text.includes(searchQuery);
      const matchesDiet = activeDiets.size === 0 || [...activeDiets].every(d => diets.includes(d));
      const matchesLookup = !lookupSelect.value || original === lookupSelect.value;

      if (matchesCat && matchesSearch && matchesDiet && matchesLookup) {
        row.classList.remove('hidden');
        visible++;
      } else {
        row.classList.add('hidden');
      }
    });
    resultCount.textContent = '(' + visible + ' results)';
  }

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentCat = btn.getAttribute('data-filter');
      applyFilters();
    });
  });

  dietBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const diet = btn.getAttribute('data-diet');
      if (btn.classList.contains('active')) {
        btn.classList.remove('active');
        activeDiets.delete(diet);
      } else {
        btn.classList.add('active');
        activeDiets.add(diet);
      }
      applyFilters();
    });
  });

  searchInput.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase();
    lookupSelect.value = '';
    applyFilters();
  });

  lookupSelect.addEventListener('change', () => {
    searchInput.value = '';
    searchQuery = '';
    catBtns.forEach(b => b.classList.remove('active'));
    catBtns[0].classList.add('active');
    currentCat = 'all';
    applyFilters();
  });

  headers.forEach(header => {
    header.addEventListener('click', () => {
      const sortType = header.getAttribute('data-sort');
      const isAsc = !header.classList.contains('asc');

      headers.forEach(h => { h.classList.remove('asc', 'desc'); });
      header.classList.add(isAsc ? 'asc' : 'desc');

      const rowsArray = Array.from(rows);

      rowsArray.sort((a, b) => {
        let aVal, bVal;
        if (sortType === 'original') {
          aVal = a.children[0].innerText.replace(/[^a-zA-Z ]/g, '').trim();
          bVal = b.children[0].innerText.replace(/[^a-zA-Z ]/g, '').trim();
        } else if (sortType === 'substitute') {
          aVal = a.children[1].innerText.trim();
          bVal = b.children[1].innerText.trim();
        } else if (sortType === 'ratio') {
          aVal = a.children[2].innerText.trim();
          bVal = b.children[2].innerText.trim();
        } else if (sortType === 'best') {
          aVal = a.children[4].innerText.trim();
          bVal = b.children[4].innerText.trim();
        }
        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });

      rowsArray.forEach(row => tableBody.appendChild(row));
    });
  });

  applyFilters();
</script>

