  overflow-x: auto;
}
.sub-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 850px;
}
.sub-table th {
  text-align: left;
  font-size: 0.75rem;
  color: #888;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 12px 16px;
  background: #1a1015;
