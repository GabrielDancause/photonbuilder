---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Ingredient Substitution Finder",
      "description": "Search 80+ ingredient substitutions with ratios, flavor and texture impact, dietary tags, and explanations of why each swap works.",
      "url": "https://28grams.vip/ingredient-substitution-finder",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I find a substitute for an ingredient I'm missing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Type the ingredient name into the search bar above. The tool searches 80+ common cooking and baking ingredients and shows you every viable substitution with the exact ratio to use, how it affects flavor and texture, and whether it meets dietary needs like vegan, gluten-free, or dairy-free."
          }
        },
        {
          "@type": "Question",
          "name": "Do ingredient substitutions change the taste of my recipe?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most substitutions have some flavor impact, which is why each entry in our database includes a flavor impact rating. Neutral-flavor swaps (like canola oil for vegetable oil) won't change taste at all, while stronger swaps (like coconut oil for butter) add a noticeable flavor. Check the flavor impact column to choose the best option for your recipe."
          }
        },
        {
          "@type": "Question",
          "name": "Can I substitute multiple ingredients in the same recipe?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can, but proceed with caution. Substituting one ingredient usually works well. Two substitutions may alter the recipe noticeably. Three or more can significantly change the outcome. If making multiple swaps, test with a small batch first and prioritize substitutions rated as having low flavor and texture impact."
          }
        },
        {
          "@type": "Question",
          "name": "What's the difference between a substitution for baking vs cooking?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Baking is more chemistry-dependent — leavening agents, fats, and eggs serve specific structural roles, so ratios matter more. In cooking (sauces, soups, stir-fries), substitutions are more forgiving since you're primarily matching flavor and texture rather than chemical reactions. Our tool notes when a substitution is better suited for one context over the other."
          }
        },
        {
          "@type": "Question",
          "name": "Are these substitution ratios exact or approximate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ratios are based on standard culinary guidelines and tested recommendations, but every recipe is different. Use them as a reliable starting point, then adjust to taste. Factors like altitude, humidity, oven calibration, and other ingredients in your recipe can all influence the final result."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Ingredient Substitution Finder | 80+ Swaps & Ratios",
  description: "Search 80+ ingredient substitutions instantly. Find swap ratios, flavor and texture impact, dietary tags (vegan, GF, dairy-free), and why each substitution works.",
  category: "tool",
  published: "2024-07-15",
};
