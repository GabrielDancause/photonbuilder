const mainSearch = document.getElementById('mainSearch');
const resultsBody = document.getElementById('resultsBody');
const resultCount = document.getElementById('resultCount');
const dietBtns = document.querySelectorAll('#dietFilters .filter-btn');

let activeDiets = new Set();

function getImpactClass(level) {
  if (level === 'low') return 'impact-low';
  if (level === 'medium') return 'impact-medium';
  return 'impact-high';
}

function getDietTags(diet) {
  const tagMap = {
    'vegan': '<span class="diet-tag tag-vegan">V</span>',
    'dairy-free': '<span class="diet-tag tag-df">DF</span>',
    'gluten-free': '<span class="diet-tag tag-gf">GF</span>',
    'egg-free': '<span class="diet-tag tag-ef">EF</span>',
  };
  return diet.map(d => tagMap[d] || '').join('');
}

function renderResults() {
  const query = mainSearch.value.trim().toLowerCase();

  if (!query && activeDiets.size === 0) {
    resultsBody.innerHTML = '<div class="results-prompt">Start typing an ingredient above to see substitutions.</div>';
    resultCount.textContent = '';
    return;
  }

  let filtered = DB;

  if (query) {
    filtered = filtered.filter(item =>
      item.ingredient.toLowerCase().includes(query) ||
      item.sub.toLowerCase().includes(query) ||
      item.notes.toLowerCase().includes(query)
    );
  }

  if (activeDiets.size > 0) {
    filtered = filtered.filter(item =>
      [...activeDiets].every(d => item.diet.includes(d))
    );
  }

  if (filtered.length === 0) {
    resultsBody.innerHTML = '<div class="results-empty"><span class="empty-icon">🔎</span>No substitutions found. Try a different ingredient or remove dietary filters.</div>';
    resultCount.textContent = '(0 results)';
    return;
  }

  // Group by ingredient
  const groups = {};
  filtered.forEach(item => {
    if (!groups[item.ingredient]) groups[item.ingredient] = [];
    groups[item.ingredient].push(item);
  });

  let html = '';
  let total = 0;
  for (const [ingredient, subs] of Object.entries(groups)) {
    total += subs.length;
    html += `<div class="ingredient-group">
      <div class="group-header" onclick="this.nextElementSibling.classList.toggle('collapsed')">
        <span class="group-title">${ingredient}</span>
        <span class="group-count">${subs.length} sub${subs.length !== 1 ? 's' : ''}</span>
      </div>
      <div class="group-body">`;
    subs.forEach(s => {
      html += `<div class="sub-card">
        <div class="sub-top">
          <span class="sub-name">${s.sub}</span>
          <span class="sub-ratio">${s.ratio}</span>
        </div>
        <div class="sub-impacts">
          <span class="impact"><span class="impact-label">Flavor: </span><span class="impact-value ${getImpactClass(s.flavor)}">${s.flavor}</span></span>
          <span class="impact"><span class="impact-label">Texture: </span><span class="impact-value ${getImpactClass(s.texture)}">${s.texture}</span></span>
        </div>
        <div class="sub-notes">${s.notes}</div>
        <div class="sub-why"><strong>Why it works:</strong> ${s.why}</div>
        <div class="diet-tags">${getDietTags(s.diet)}</div>
      </div>`;
    });
    html += '</div></div>';
  }

  resultsBody.innerHTML = html;
  resultCount.textContent = `(${total} result${total !== 1 ? 's' : ''})`;
}

mainSearch.addEventListener('input', renderResults);

dietBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    const diet = btn.getAttribute('data-diet');
    if (activeDiets.has(diet)) {
      activeDiets.delete(diet);
      btn.classList.remove('active');
    } else {
      activeDiets.add(diet);
      btn.classList.add('active');
    }
    renderResults();
  });
});
</script>


