  { ingredient: "Milk", sub: "Almond Milk", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Mild, slightly nutty. Thinner than whole milk but works in most recipes.", why: "Almond milk is neutral enough to not alter flavors and has enough body to replace milk's moisture role in batters and sauces." },
  { ingredient: "Milk", sub: "Soy Milk", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Highest protein of plant milks. Behaves most like dairy milk in baking.", why: "Soy milk's protein content is comparable to cow's milk, which means it browns, thickens, and creates structure similarly in baked goods." },
  { ingredient: "Milk", sub: "Coconut Milk (canned, full-fat)", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: ["vegan","dairy-free"], notes: "Rich, coconut flavor. Great for curries, tropical baked goods, and rich sauces.", why: "Full-fat coconut milk has a higher fat content than dairy milk, adding richness. The coconut flavor works best in recipes where it complements other ingredients." },
  { ingredient: "Milk", sub: "Water + Butter", ratio: "1 cup = 1 cup water + 1 Tbsp butter", flavor: "low", texture: "low", diet: [], notes: "Emergency sub when you have no milk at all. Adds fat back that water lacks.", why: "Milk is mostly water plus fat and protein. Adding butter to water approximates the fat content, though you lose milk's proteins and sugars." },

  // === HEAVY CREAM ===
  { ingredient: "Heavy Cream", sub: "Coconut Cream", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: ["vegan","dairy-free"], notes: "Rich and thick. Coconut flavor present. Whips when chilled overnight.", why: "Coconut cream's high fat content (around 24%) closely matches heavy cream's, allowing it to whip and enrich dishes similarly." },
  { ingredient: "Heavy Cream", sub: "Cashew Cream (blended soaked cashews)", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Neutral, creamy. Soak cashews 4+ hours, blend with water until smooth.", why: "Blended cashews create a smooth, high-fat emulsion that mimics cream's richness without any dairy proteins." },
  { ingredient: "Heavy Cream", sub: "Milk + Butter", ratio: "1 cup = ¾ cup milk + ¼ cup melted butter", flavor: "low", texture: "medium", diet: [], notes: "Good for sauces and baking. Won't whip. Approximates fat content.", why: "Heavy cream is ~36% fat. Combining whole milk (~3.5% fat) with butter brings the fat content closer, though the emulsion isn't stable enough to whip." },
  { ingredient: "Heavy Cream", sub: "Evaporated Milk", ratio: "1 cup = 1 cup", flavor: "low", texture: "medium", diet: [], notes: "Slightly caramelized flavor. Good in sauces and soups. Won't whip.", why: "Evaporated milk is milk with 60% of water removed, concentrating the fat and protein. It's thicker than milk but thinner than cream." },
  { ingredient: "Heavy Cream", sub: "Silken Tofu (blended) + Soy Milk", ratio: "1 cup = ½ cup tofu + ½ cup soy milk blended", flavor: "low", texture: "medium", diet: ["vegan","dairy-free"], notes: "Blend until perfectly smooth. Good in sauces and baking. Neutral flavor.", why: "Silken tofu provides body and protein while soy milk adds liquid and additional protein, creating a cream-like consistency." },

  // === BUTTERMILK ===
  { ingredient: "Buttermilk", sub: "Milk + Lemon Juice", ratio: "1 cup = 1 cup milk + 1 Tbsp lemon juice", flavor: "low", texture: "low", diet: [], notes: "Let sit 5-10 min until curdled. Easiest emergency buttermilk sub.", why: "The acid in lemon juice denatures milk proteins (casein), causing them to curdle and thicken — replicating buttermilk's acidity and texture." },
  { ingredient: "Buttermilk", sub: "Milk + White Vinegar", ratio: "1 cup = 1 cup milk + 1 Tbsp vinegar", flavor: "low", texture: "low", diet: [], notes: "Works identically to the lemon juice method. Let sit 5-10 minutes.", why: "Vinegar's acetic acid curdles milk proteins the same way lemon juice does, creating the tangy, thick liquid needed for proper leavening." },
  { ingredient: "Buttermilk", sub: "Plain Yogurt (thinned)", ratio: "1 cup = ¾ cup yogurt + ¼ cup milk", flavor: "low", texture: "low", diet: [], notes: "Already has the right acidity. Thin to pourable consistency.", why: "Yogurt is naturally acidic from lactic acid fermentation — the same acid present in real buttermilk — so it interacts with leavening agents identically." },
  { ingredient: "Buttermilk", sub: "Plant Milk + Lemon Juice", ratio: "1 cup = 1 cup plant milk + 1 Tbsp lemon juice", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Soy milk curdles best. Oat and almond work too. Let sit 5 min.", why: "Plant milk proteins (especially soy) curdle with acid similarly to dairy, providing both the acidity and thickness recipes need from buttermilk." },

  // === SOUR CREAM ===
  { ingredient: "Sour Cream", sub: "Plain Greek Yogurt", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: [], notes: "Nearly identical tang and thickness. Slightly less fat. Best 1:1 swap.", why: "Both are cultured dairy products with similar acidity, protein content, and fat levels. Greek yogurt is just slightly tangier and thicker." },
  { ingredient: "Sour Cream", sub: "Cottage Cheese (blended)", ratio: "1 cup = 1 cup blended smooth", flavor: "low", texture: "low", diet: [], notes: "Blend until completely smooth. Higher protein, lower fat option.", why: "Blended cottage cheese matches sour cream's consistency and mild tang. The curds disappear when blended, leaving a smooth, creamy texture." },
  { ingredient: "Sour Cream", sub: "Coconut Cream + Lemon Juice", ratio: "1 cup = 1 cup coconut cream + 1 tsp lemon", flavor: "medium", texture: "low", diet: ["vegan","dairy-free"], notes: "Chill coconut cream overnight. Mild coconut flavor. Good in baking.", why: "Chilled coconut cream thickens to sour cream consistency, and lemon juice adds the acidity that recipes depend on for proper leavening and flavor balance." },
  { ingredient: "Sour Cream", sub: "Cashew Sour Cream", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Blend soaked cashews with lemon juice, vinegar, and water. Rich and tangy.", why: "Cashew fats create a smooth, rich base, while lemon juice and vinegar replicate the lactic acid tang that defines sour cream." },

  // === CREAM CHEESE ===
  { ingredient: "Cream Cheese", sub: "Mascarpone", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: [], notes: "Slightly sweeter and richer. Works in both sweet and savory applications.", why: "Mascarpone is a fresh cream cheese with higher fat content. The texture and melting properties are very similar." },
  { ingredient: "Cream Cheese", sub: "Ricotta (blended smooth)", ratio: "1 cup = 1 cup", flavor: "low", texture: "medium", diet: [], notes: "Lighter, less tangy. Blend until very smooth for best results.", why: "Ricotta has a similar fresh-cheese character but with less fat and tang. Blending removes the grainy texture." },
  { ingredient: "Cream Cheese", sub: "Cashew Cream Cheese", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Blend soaked cashews with lemon, nutritional yeast, and salt. Chill to firm.", why: "Soaked cashews blend into a rich, spreadable base. Lemon juice and nutritional yeast add the tang and savory depth of dairy cream cheese." },

  // === YOGURT ===
  { ingredient: "Yogurt", sub: "Sour Cream", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: [], notes: "Richer and thicker. Works in both baking and sauces.", why: "Sour cream has similar acidity and culture profile to yogurt. Higher fat content adds richness." },
  { ingredient: "Yogurt", sub: "Coconut Yogurt", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: ["vegan","dairy-free"], notes: "Mild coconut flavor. Thickness varies by brand. Check sugar content.", why: "Coconut yogurt is cultured like dairy yogurt, providing similar probiotics and acidity for recipes that rely on yogurt's tang." },
  { ingredient: "Yogurt", sub: "Mashed Banana", ratio: "1 cup = 1 cup", flavor: "high", texture: "medium", diet: ["vegan","dairy-free"], notes: "Adds sweetness and banana flavor. Good in smoothies, pancakes, and muffins.", why: "Banana's creamy texture and natural moisture replicate yogurt's body, though flavor changes are significant." },

  // === ALL-PURPOSE FLOUR ===
  { ingredient: "All-Purpose Flour", sub: "1:1 Gluten-Free Flour Blend", ratio: "1 cup = 1 cup", flavor: "low", texture: "medium", diet: ["gluten-free"], notes: "Easiest GF swap. Check if blend includes xanthan gum; if not, add ½ tsp per cup.", why: "GF blends combine rice flour, tapioca starch, and potato starch to approximate wheat flour's protein and starch balance. Xanthan gum replaces gluten's elasticity." },
  { ingredient: "All-Purpose Flour", sub: "Almond Flour", ratio: "1 cup = 1 cup (add extra egg or binding)", flavor: "medium", texture: "high", diet: ["gluten-free"], notes: "Nutty, moist, dense. No gluten structure. Add binding agent. Great in cookies and cakes.", why: "Almond flour is pure ground almonds — high fat, no gluten. It produces moist, tender results but needs eggs or xanthan gum for structure." },
  { ingredient: "All-Purpose Flour", sub: "Oat Flour", ratio: "1 cup = 1 cup", flavor: "low", texture: "medium", diet: ["gluten-free"], notes: "Mild, slightly sweet. Make your own by blending rolled oats. Use certified GF oats.", why: "Oat flour has some protein for structure (though not gluten), and its starch content helps with binding. Results are slightly denser and moister." },
  { ingredient: "All-Purpose Flour", sub: "Whole Wheat Flour", ratio: "1 cup = 1 cup (or ¾ cup for lighter results)", flavor: "medium", texture: "medium", diet: [], notes: "Nuttier, denser. More fiber and protein. May need more liquid.", why: "Whole wheat includes the bran and germ, which absorb more water and cut gluten strands, producing a denser, more flavorful result." },
  { ingredient: "All-Purpose Flour", sub: "Coconut Flour", ratio: "1 cup = ¼ to ⅓ cup coconut flour + extra eggs/liquid", flavor: "medium", texture: "high", diet: ["gluten-free"], notes: "Extremely absorbent. Requires significantly more liquid and eggs. Dense results.", why: "Coconut flour absorbs 4-6x more liquid than wheat flour due to its high fiber content. Recipes must be reformulated, not simply swapped." },

  // === CAKE FLOUR ===
  { ingredient: "Cake Flour", sub: "All-Purpose Flour + Cornstarch", ratio: "1 cup = ⅞ cup AP flour + 2 Tbsp cornstarch", flavor: "low", texture: "low", diet: [], notes: "Sift together twice. Produces a lighter, softer crumb.", why: "Cake flour has ~8% protein vs AP's ~11%. Replacing some AP flour with cornstarch (zero protein) lowers the overall protein, reducing gluten formation for tender cakes." },

  // === BREAD FLOUR ===
  { ingredient: "Bread Flour", sub: "All-Purpose Flour + Vital Wheat Gluten", ratio: "1 cup = 1 cup AP flour + 1 tsp vital wheat gluten", flavor: "low", texture: "low", diet: [], notes: "Increases protein content for chewier results. Good for pizza and bread.", why: "Bread flour has ~13% protein. Adding vital wheat gluten to AP flour (~11%) brings the protein content closer, creating more gluten for chewy structure." },
  { ingredient: "Bread Flour", sub: "All-Purpose Flour (straight swap)", ratio: "1 cup = 1 cup", flavor: "low", texture: "medium", diet: [], notes: "Works in most bread recipes. Slightly less chewy, slightly less rise.", why: "AP flour's lower protein means less gluten development, which produces a softer crumb. For rustic breads and rolls, the difference is minimal." },

  // === SELF-RISING FLOUR ===
  { ingredient: "Self-Rising Flour", sub: "All-Purpose Flour + Baking Powder + Salt", ratio: "1 cup = 1 cup AP + 1½ tsp BP + ¼ tsp salt", flavor: "low", texture: "low", diet: [], notes: "Whisk well to distribute leavening evenly. Exact match for store-bought.", why: "Self-rising flour is simply AP flour pre-mixed with baking powder and salt. Making your own gives you fresh leavening, which is often more potent." },

  // === WHITE SUGAR ===
  { ingredient: "White Sugar", sub: "Coconut Sugar", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: [], notes: "Caramel-like flavor. Slightly less sweet. Lower glycemic index.", why: "Coconut sugar contains sucrose like white sugar but also has trace minerals and inulin fiber. It caramelizes similarly but produces a deeper color." },
  { ingredient: "White Sugar", sub: "Honey", ratio: "1 cup = ¾ cup honey (reduce other liquid by 3 Tbsp)", flavor: "medium", texture: "medium", diet: [], notes: "Sweeter than sugar. Reduce oven temp 25°F. Add ¼ tsp baking soda per cup of honey.", why: "Honey is ~25% sweeter than sugar by weight and contains water (~17%), so you need less and must compensate for the extra liquid. Its acidity requires baking soda to neutralize." },
  { ingredient: "White Sugar", sub: "Maple Syrup", ratio: "1 cup = ¾ cup maple syrup (reduce liquid by 3 Tbsp)", flavor: "high", texture: "medium", diet: [], notes: "Distinct maple flavor. Use in recipes where the flavor is welcome.", why: "Maple syrup is a liquid sweetener with ~33% water. Like honey, you reduce other liquids and may need to lower oven temperature." },
  { ingredient: "White Sugar", sub: "Stevia/Monk Fruit Blend", ratio: "Per package (typically 1 cup = 1 cup blend)", flavor: "medium", texture: "high", diet: [], notes: "Zero-calorie. May have aftertaste. Sugar provides structure, so texture changes in baking.", why: "These natural sweeteners are intensely sweet with no calories, but sugar does more than sweeten — it aids browning, creates structure, and retains moisture. Baking results vary significantly." },

  // === BROWN SUGAR ===
  { ingredient: "Brown Sugar", sub: "White Sugar + Molasses", ratio: "1 cup = 1 cup white sugar + 1 Tbsp molasses", flavor: "low", texture: "low", diet: [], notes: "Exact match for light brown sugar. Use 2 Tbsp molasses for dark brown sugar.", why: "Brown sugar is literally white sugar with molasses added. This recreates the exact same product, including the moisture molasses contributes." },
  { ingredient: "Brown Sugar", sub: "Coconut Sugar", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: [], notes: "Similar caramel notes. Natural 1:1 swap. Slightly different moisture level.", why: "Coconut sugar's natural caramel flavor profile is similar to brown sugar's molasses notes, making it one of the most seamless substitutions." },
  { ingredient: "Brown Sugar", sub: "Maple Sugar", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: [], notes: "Maple flavor replaces molasses flavor. Drier than brown sugar.", why: "Maple sugar is dehydrated maple syrup, giving it a dry granular form similar to brown sugar but with a distinct maple character." },

  // === POWDERED SUGAR ===
  { ingredient: "Powdered Sugar", sub: "Blended Granulated Sugar", ratio: "1 cup = 1 cup granulated sugar blended to powder", flavor: "low", texture: "low", diet: [], notes: "Blend for 30-60 sec until powdery. Add 1 tsp cornstarch per cup to prevent clumping.", why: "Powdered sugar is just finely ground granulated sugar with cornstarch. A blender or food processor achieves the same particle size." },

  // === CORN SYRUP ===
  { ingredient: "Corn Syrup", sub: "Honey", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: [], notes: "Sweeter with distinct flavor. Works in pecan pie, caramels, and candy.", why: "Both are invert sugars that resist crystallization — the primary reason corn syrup is used in candy-making. Honey performs the same anti-crystallization role." },
  { ingredient: "Corn Syrup", sub: "Maple Syrup", ratio: "1 cup = 1 cup", flavor: "high", texture: "low", diet: [], notes: "Strong maple flavor. Good in pies and desserts where maple is welcome.", why: "Maple syrup has similar viscosity and sugar concentration, and its glucose content provides comparable crystallization resistance." },
  { ingredient: "Corn Syrup", sub: "Golden Syrup", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: [], notes: "Buttery, caramel-like flavor. Popular in British baking. Works well in candy.", why: "Golden syrup is a refined sugar syrup with similar anti-crystallization properties to corn syrup, plus a richer flavor." },

  // === HONEY ===
  { ingredient: "Honey", sub: "Maple Syrup", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: ["vegan"], notes: "Maple flavor instead of floral. Works in dressings, baking, and marinades.", why: "Both are liquid sweeteners with similar sugar concentrations and viscosity. Maple is slightly thinner but behaves nearly identically in recipes." },
  { ingredient: "Honey", sub: "Agave Nectar", ratio: "1 cup = ⅔ cup", flavor: "low", texture: "low", diet: ["vegan"], notes: "Sweeter than honey, so use less. Neutral flavor. Dissolves easily.", why: "Agave is higher in fructose than honey, making it sweeter per volume. Its neutral flavor and liquid form make it a clean swap." },
  { ingredient: "Honey", sub: "Brown Rice Syrup", ratio: "1 cup = 1¼ cup", flavor: "low", texture: "medium", diet: ["vegan"], notes: "Less sweet than honey. Mild butterscotch flavor. Stickier consistency.", why: "Brown rice syrup is about 50% as sweet as honey, so more is needed. Its maltose content provides a gentler sweetness and chewier texture." },

  // === BAKING POWDER ===
  { ingredient: "Baking Powder", sub: "Baking Soda + Cream of Tartar", ratio: "1 tsp = ¼ tsp soda + ½ tsp cream of tartar", flavor: "low", texture: "low", diet: ["gluten-free"], notes: "Make fresh — cream of tartar loses potency. Mix just before using.", why: "Baking powder is baking soda plus an acid (cream of tartar) plus cornstarch. Combining them yourself creates the same CO₂-producing reaction." },
  { ingredient: "Baking Powder", sub: "Baking Soda + Acidic Ingredient", ratio: "1 tsp BP = ¼ tsp soda (ensure recipe has acid)", flavor: "low", texture: "low", diet: ["gluten-free"], notes: "Only works if recipe contains yogurt, buttermilk, lemon juice, vinegar, or similar acid.", why: "Baking soda needs an acid to produce CO₂. If your recipe already has an acidic ingredient, it can serve as the activating acid." },
  { ingredient: "Baking Powder", sub: "Self-Rising Flour (replace AP flour in recipe)", ratio: "Omit BP, use self-rising flour instead of AP", flavor: "low", texture: "low", diet: [], notes: "Self-rising flour already contains baking powder and salt. Adjust salt separately.", why: "Self-rising flour is pre-mixed with baking powder, so using it eliminates the need for separate leavening." },

  // === BAKING SODA ===
  { ingredient: "Baking Soda", sub: "Baking Powder (use 3x amount)", ratio: "1 tsp soda = 3 tsp (1 Tbsp) baking powder", flavor: "low", texture: "low", diet: ["gluten-free"], notes: "Baking powder is weaker. Large amounts may add metallic taste. Reduce other acids in recipe.", why: "Baking powder is ~⅓ baking soda by weight. Using 3x the amount provides the same leavening power, though the extra acid and starch in BP may slightly affect flavor." },

  // === VEGETABLE OIL ===
  { ingredient: "Vegetable Oil", sub: "Canola Oil", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Nearly identical. Neutral flavor, same smoke point. Perfect 1:1 swap.", why: "Canola and vegetable oil have virtually the same fat composition, smoke point, and neutral flavor. They're interchangeable in all applications." },
  { ingredient: "Vegetable Oil", sub: "Melted Coconut Oil", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: ["vegan","dairy-free"], notes: "Use refined for neutral flavor. Solidifies below 76°F, which may affect cold dishes.", why: "Coconut oil has a similar fat content but is solid at cool temperatures. Refined coconut oil eliminates the coconut flavor." },
  { ingredient: "Vegetable Oil", sub: "Melted Butter", ratio: "1 cup = 1 cup (or slightly more)", flavor: "medium", texture: "low", diet: [], notes: "Adds buttery richness. Butter is ~80% fat, oil is 100%, so you may need slightly more.", why: "Butter's water content (~20%) means slightly less fat per volume than oil. The difference is small enough for most recipes." },
  { ingredient: "Vegetable Oil", sub: "Avocado Oil", ratio: "1 cup = 1 cup", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Neutral flavor, high smoke point. More expensive but nutritionally superior.", why: "Avocado oil has a neutral taste and one of the highest smoke points of any cooking oil, making it a premium but perfect substitute." },
  { ingredient: "Vegetable Oil", sub: "Applesauce (for baking)", ratio: "1 cup = ½ cup applesauce", flavor: "medium", texture: "high", diet: ["vegan","dairy-free"], notes: "Reduces fat by half. Adds moisture and sweetness. Best in cakes, muffins.", why: "Applesauce provides moisture and pectin for structure, partially replacing the role of fat. Works best when you replace only half the oil." },

  // === SHORTENING ===
  { ingredient: "Shortening", sub: "Butter", ratio: "1 cup = 1 cup + 2 Tbsp", flavor: "medium", texture: "low", diet: [], notes: "Butter adds flavor shortening lacks. Extra 2 Tbsp compensates for water content.", why: "Shortening is 100% fat while butter is ~80% fat + 20% water. The extra butter compensates for this difference. Butter also adds flavor." },
  { ingredient: "Shortening", sub: "Coconut Oil (solid)", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: ["vegan","dairy-free"], notes: "Use refined for neutral flavor. Solid at room temp like shortening.", why: "Solid coconut oil has a similar melting point and fat content to shortening, making it work well in pie crusts and biscuits." },
  { ingredient: "Shortening", sub: "Lard", ratio: "1 cup = 1 cup", flavor: "medium", texture: "low", diet: [], notes: "Traditional choice for flaky pie crusts. Mild savory flavor.", why: "Lard is a solid animal fat with excellent plasticity — it creates even flakier pastry than shortening because of its larger fat crystals." },

  // === UNSWEETENED CHOCOLATE ===
  { ingredient: "Unsweetened Chocolate", sub: "Cocoa Powder + Fat", ratio: "1 oz = 3 Tbsp cocoa + 1 Tbsp oil/butter", flavor: "low", texture: "low", diet: [], notes: "Works in brownies, cakes, and sauces. Mix cocoa with fat until smooth.", why: "Unsweetened chocolate is cocoa solids + cocoa butter. Cocoa powder is the solids alone, so adding fat replaces the cocoa butter component." },

  // === SEMISWEET CHOCOLATE ===
  { ingredient: "Semisweet Chocolate", sub: "Cocoa Powder + Sugar + Fat", ratio: "1 oz = 1 Tbsp cocoa + 2 tsp sugar + 2 tsp butter", flavor: "low", texture: "medium", diet: [], notes: "Approximation for sauces and batters. Won't work for molding or coating.", why: "Semisweet chocolate is cocoa solids, cocoa butter, and sugar. Combining these individually approximates the flavor, though the texture won't temper." },
  { ingredient: "Semisweet Chocolate", sub: "Dark Chocolate (60-70%)", ratio: "1 oz = 1 oz", flavor: "low", texture: "low", diet: [], notes: "Slightly more bitter. Reduce sugar in recipe by 1 tsp per oz if desired.", why: "Dark chocolate has the same components as semisweet but in different proportions — more cocoa, less sugar. The difference is subtle in most recipes." },

  // === COCOA POWDER ===
  { ingredient: "Cocoa Powder", sub: "Carob Powder", ratio: "1 Tbsp = 1 Tbsp", flavor: "high", texture: "low", diet: ["vegan","dairy-free"], notes: "Naturally sweet, no caffeine. Doesn't taste like chocolate but similar color.", why: "Carob comes from a different plant entirely but has a similar dark color and mildly sweet flavor. It's a closer visual match than a flavor match." },
  { ingredient: "Cocoa Powder", sub: "Cacao Powder", ratio: "1 Tbsp = 1 Tbsp", flavor: "low", texture: "low", diet: ["vegan","dairy-free"], notes: "Raw, less processed version. More bitter and intense flavor. More nutrients.", why: "Cacao is the raw form of cocoa — same bean, less processing. It has a more intense, slightly acidic flavor and retains more antioxidants." },

  // === VANILLA EXTRACT ===
  { ingredient: "Vanilla Extract", sub: "Vanilla Bean Paste", ratio: "1 tsp = 1 tsp", flavor: "low", texture: "low", diet: [], notes: "Richer flavor with visible bean specks. More expensive. Excellent in custards.", why: "Vanilla paste contains the same vanillin compounds as extract, plus actual bean specks for visual appeal and slightly deeper flavor." },
  { ingredient: "Vanilla Extract", sub: "Almond Extract", ratio: "1 tsp = ½ tsp", flavor: "high", texture: "low", diet: [], notes: "Much stronger — use half. Distinct almond flavor. Good in cakes and cookies.", why: "Almond extract has a complementary but different flavor profile. Using less prevents it from overwhelming the recipe." },
  { ingredient: "Vanilla Extract", sub: "Maple Syrup", ratio: "1 tsp = 1 tsp", flavor: "medium", texture: "low", diet: ["vegan"], notes: "Adds warmth and depth. Not the same flavor but adds similar complexity.", why: "Both vanilla and maple add warm, sweet complexity. While chemically different, they fill a similar role of rounding out flavors." },

  // === CORNSTARCH ===
  { ingredient: "Cornstarch", sub: "All-Purpose Flour", ratio: "1 Tbsp cornstarch = 2 Tbsp flour", flavor: "low", texture: "medium", diet: [], notes: "Use double the amount. Creates cloudier result. Cook longer to remove raw flour taste.", why: "Flour has roughly half the thickening power of cornstarch because it contains protein alongside starch. The protein makes sauces opaque rather than glossy." },
  { ingredient: "Cornstarch", sub: "Arrowroot Powder", ratio: "1 Tbsp = 1 Tbsp", flavor: "low", texture: "low", diet: ["gluten-free"], notes: "Glossy, clear finish. Breaks down with prolonged heat. Best added at end.", why: "Arrowroot starch thickens at a similar rate to cornstarch and produces an even clearer, glossier result. It's more delicate, so don't boil vigorously." },
  { ingredient: "Cornstarch", sub: "Tapioca Starch", ratio: "1 Tbsp = 2 Tbsp tapioca starch", flavor: "low", texture: "medium", diet: ["gluten-free"], notes: "Slightly chewy, glossy texture. Good in pie fillings and fruit sauces.", why: "Tapioca is a weaker thickener than cornstarch but creates a pleasant, slightly chewy texture. It holds up well to freezing and thawing." },
  { ingredient: "Cornstarch", sub: "Potato Starch", ratio: "1 Tbsp = 1 Tbsp", flavor: "low", texture: "low", diet: ["gluten-free"], notes: "Similar thickening power. Breaks down with prolonged heat. Add at end of cooking.", why: "Potato starch has comparable thickening power to cornstarch and produces a similarly clear result, but it loses viscosity if overheated." },

  // === SOY SAUCE ===
  { ingredient: "Soy Sauce", sub: "Coconut Aminos", ratio: "1 Tbsp = 1 Tbsp", flavor: "medium", texture: "low", diet: ["gluten-free"], notes: "Sweeter, less salty. Soy-free and gluten-free. May need a pinch of salt.", why: "Coconut aminos are fermented coconut sap with a similar umami profile to soy sauce but with less sodium and a sweeter finish." },
  { ingredient: "Soy Sauce", sub: "Tamari", ratio: "1 Tbsp = 1 Tbsp", flavor: "low", texture: "low", diet: ["gluten-free"], notes: "Richer, less salty than regular soy sauce. Most tamari is gluten-free (check label).", why: "Tamari is a Japanese soy sauce made with little or no wheat. It has a deeper, smoother umami flavor with less harsh saltiness." },
  { ingredient: "Soy Sauce", sub: "Worcestershire Sauce", ratio: "1 Tbsp = 1 Tbsp", flavor: "high", texture: "low", diet: [], notes: "Tangy, complex flavor. Contains anchovies. Good in marinades and meats.", why: "Worcestershire provides umami from fermented anchovies and tamarind, offering similar savory depth but with a tangier, more complex profile." },

  // === FISH SAUCE ===
  { ingredient: "Fish Sauce", sub: "Soy Sauce + Lime Juice", ratio: "1 Tbsp = 1 Tbsp soy sauce + ½ tsp lime juice", flavor: "medium", texture: "low", diet: ["vegan"], notes: "Misses fish sauce's funky depth but captures the salty umami. Add a pinch of sugar.", why: "Soy sauce provides umami and salt, while lime adds the brightness that balances fish sauce's depth. Not identical but fills the same flavor role." },
  { ingredient: "Fish Sauce", sub: "Mushroom Sauce (vegetarian fish sauce)", ratio: "1 Tbsp = 1 Tbsp", flavor: "low", texture: "low", diet: ["vegan"], notes: "Made from mushrooms and soy. Closest vegan match for funky umami depth.", why: "Fermented mushroom sauces develop glutamates through similar processes to fish sauce, creating a deep umami that soy sauce alone can't match." },

  // === RICE VINEGAR ===
  { ingredient: "Rice Vinegar", sub: "Apple Cider Vinegar (diluted)", ratio: "1 Tbsp = 1 Tbsp ACV + ½ tsp sugar + ½ tsp water", flavor: "medium", texture: "low", diet: ["vegan","gluten-free"], notes: "Milder than straight ACV. The sugar and water match rice vinegar's gentleness.", why: "Rice vinegar is milder (~4% acidity) than most vinegars. Diluting ACV and sweetening it approximates this gentle, slightly sweet acidity." },
