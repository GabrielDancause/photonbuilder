---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Grocery List Organizer — Smart Shopping List by Aisle",
      "description": "Free grocery list organizer that auto-categorizes items by store aisle. Add items manually or paste recipe ingredients. Combine duplicates, sort by aisle, check off as you shop. Save multiple lists in your browser.",
      "url": "https://28grams.vip/grocery-list-organizer",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does the grocery list organizer categorize items?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The organizer uses a built-in database of common grocery items mapped to store aisles. When you add an item, it automatically assigns it to the correct category — produce, dairy, meat, bakery, frozen, canned goods, snacks, beverages, or household. You can also manually change the category if needed."
          }
        },
        {
          "@type": "Question",
          "name": "Can I import ingredients from a recipe?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Paste your recipe ingredient list into the bulk import box and the organizer will parse each line as a separate item, automatically detecting quantities and categorizing each ingredient by aisle. This makes it easy to build a shopping list from any recipe."
          }
        },
        {
          "@type": "Question",
          "name": "Does the grocery list save my data?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All your grocery lists are saved in your browser's localStorage, so they persist between sessions without needing an account. Your data stays on your device and is never sent to a server. You can create and save multiple named lists."
          }
        },
        {
          "@type": "Question",
          "name": "How does duplicate item combining work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "When you add an item that already exists in your list, the organizer detects the duplicate and combines quantities. For example, if you have '2 cups milk' and add '1 cup milk', it will merge them into '3 cups milk' in the dairy aisle. This prevents redundant entries and ensures accurate shopping."
          }
        },
        {
          "@type": "Question",
          "name": "What is the best way to organize a grocery list by aisle?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sorting your grocery list by store aisle is the most efficient way to shop. Group items into produce, dairy, meat, bakery, frozen, canned goods, snacks, beverages, and household. This minimizes backtracking in the store. Our organizer does this automatically so you can walk through the store in one pass."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Grocery List Organizer | Sort by Aisle & Category",
  description: "Free smart grocery list organizer. Auto-categorize items by store aisle, paste recipe ingredients, combine duplicates, check off as you shop. Save multiple lists in your browser.",
  category: "tool",
  published: "2024-06-10",
};
