    meat: ['bacon','beef','brisket','chicken','chicken breast','chicken thigh','chorizo','clam','clams','cod','crab','deli','fish','ground beef','ground turkey','ham','hot dog','hot dogs','jerky','lamb','lobster','mahi','meat','meatball','mussel','oyster','pepperoni','pork','prawn','rib','ribs','roast','salmon','salami','sardine','sausage','scallop','shrimp','sirloin','steak','tenderloin','tilapia','trout','tuna','turkey','veal','venison'],
    bakery: ['bagel','bagels','baguette','bread','brioche','bun','buns','ciabatta','cornbread','crescent','croissant','dinner roll','english muffin','flatbread','focaccia','hamburger bun','kaiser','loaf','muffin','naan','pita','pretzel','roll','rolls','rye','sourdough','tortilla','tortillas','wrap','wraps'],
    frozen: ['frozen','ice cream','gelato','popsicle','sorbet','frozen pizza','frozen vegetables','frozen fruit','frozen dinner','frozen meal','frozen fries','frozen waffles','frozen burrito','frozen pie','tv dinner','lean cuisine','hot pocket','tater tot','fish stick','ice pop','sherbet','frozen corn','frozen peas','frozen berries','edamame'],
    canned: ['baking powder','baking soda','bouillon','broth','brown rice','brown sugar','can of','canned','canola oil','cardamom','chickpea','chickpeas','chili powder','cinnamon','cloves','cocoa','coconut milk','cooking spray','cornmeal','cornstarch','couscous','cumin','curry','dry beans','elbow','extract','farro','flour','garlic powder','gelatin','grain','granulated','honey','jam','jelly','ketchup','lentil','lentils','linguine','maple syrup','marinara','mayonnaise','molasses','mustard','noodle','noodles','nutmeg','oat','oatmeal','oats','olive oil','onion powder','oregano','orzo','paprika','pasta','peanut butter','penne','powdered sugar','quinoa','ramen','ranch','red pepper flakes','rice','rigatoni','salsa','salt','sauce','sesame oil','soy sauce','spaghetti','spice','sriracha','stock','sugar','syrup','taco seasoning','tahini','thyme','tomato paste','tomato sauce','turmeric','vanilla','vegetable oil','vinegar','white rice','worcestershire','yeast'],
    snacks: ['candy','cereal','chip','chips','cookie','cookies','cracker','crackers','dried fruit','fruit snack','goldfish','granola','granola bar','gummy','jerky','nut','nuts','popcorn','pretzels','protein bar','raisin','raisins','rice cake','snack','trail mix','almond','almonds','cashew','cashews','mixed nuts','peanut','peanuts','pecan','pecans','pistachio','pistachios','sunflower seeds','walnut','walnuts'],
    beverages: ['ale','beer','chai','club soda','coconut water','coffee','coke','diet coke','energy drink','gatorade','ginger ale','iced tea','juice','kombucha','lager','lemonade','mineral water','orange juice','pepsi','seltzer','smoothie','soda','sparkling water','sprite','tea','tonic','water','wine','la croix','cold brew','espresso','creamer'],
    household: ['air freshener','aluminum foil','bag','bags','battery','bleach','broom','cleaner','cling wrap','clorox','detergent','dish soap','disinfectant','dryer sheet','fabric softener','foil','garbage bag','glass cleaner','hand soap','laundry','light bulb','lysol','napkin','napkins','paper plate','paper towel','paper towels','parchment','parchment paper','plastic bag','plastic wrap','sandwich bag','scrub','soap','sponge','straw','straws','tissue','tissues','toilet paper','toothpaste','toothbrush','trash bag','trash bags','wax paper','wipe','wipes','ziploc']
  };

  const UNITS = ['oz','ounce','ounces','lb','lbs','pound','pounds','cup','cups','tsp','tbsp','tablespoon','tablespoons','teaspoon','teaspoons','quart','quarts','gallon','gallons','pint','pints','ml','liter','liters','g','gram','grams','kg','can','cans','bag','bags','box','boxes','bunch','bunches','head','heads','clove','cloves','slice','slices','piece','pieces','dozen','stick','sticks','package','packages','pkg','jar','jars','bottle','bottles','container','large','medium','small','whole'];

  const STORAGE_KEY = '28g_grocery_lists';

  // ── State ──
  let lists = {};
  let currentListId = null;

  // ── DOM ──
  const listSelect = document.getElementById('listSelect');
  const newListBtn = document.getElementById('newListBtn');
  const renameListBtn = document.getElementById('renameListBtn');
  const deleteListBtn = document.getElementById('deleteListBtn');
  const itemInput = document.getElementById('itemInput');
  const categorySelect = document.getElementById('categorySelect');
  const addItemBtn = document.getElementById('addItemBtn');
  const bulkToggle = document.getElementById('bulkToggle');
  const bulkArea = document.getElementById('bulkArea');
  const bulkTextarea = document.getElementById('bulkTextarea');
  const bulkImportBtn = document.getElementById('bulkImportBtn');
  const bulkClearBtn = document.getElementById('bulkClearBtn');
  const uncheckAllBtn = document.getElementById('uncheckAllBtn');
  const removeCheckedBtn = document.getElementById('removeCheckedBtn');
  const clearAllBtn = document.getElementById('clearAllBtn');
  const groceryListEl = document.getElementById('groceryList');
  const itemCountEl = document.getElementById('itemCount');

  // ── LocalStorage ──
  function loadData() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        const data = JSON.parse(raw);
        lists = data.lists || {};
        currentListId = data.currentListId || null;
      }
    } catch (e) { /* ignore */ }
    if (Object.keys(lists).length === 0) {
      const id = genId();
      lists[id] = { name: 'My Grocery List', items: [] };
      currentListId = id;
    }
    if (!currentListId || !lists[currentListId]) {
      currentListId = Object.keys(lists)[0];
    }
  }

  function saveData() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ lists, currentListId }));
  }

  function genId() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
  }

  // ── Categorization ──
  function detectAisle(text) {
    const lower = text.toLowerCase();
    let bestMatch = 'canned';
    let bestLen = 0;
    for (const [aisle, keywords] of Object.entries(AISLE_KEYWORDS)) {
      for (const kw of keywords) {
        if (lower.includes(kw) && kw.length > bestLen) {
          bestMatch = aisle;
          bestLen = kw.length;
        }
      }
    }
    return bestMatch;
  }

  // ── Parsing ──
  function parseItem(text) {
    text = text.trim();
    if (!text) return null;
    let qty = '';
    let name = text;

    // Try to extract leading quantity: "2 cups milk", "1/2 lb chicken", "3 large eggs"
    const qtyMatch = text.match(/^([\d]+[\d\/\.\s]*(?:\s*(?:and\s+)?[\d\/\.]+)?)\s*(.*)/i);
    if (qtyMatch) {
      const numPart = qtyMatch[1].trim();
      let rest = qtyMatch[2];
      // Check if next word is a unit
      const unitMatch = rest.match(new RegExp('^(' + UNITS.join('|') + ')\\b\\s*(.*)', 'i'));
      if (unitMatch) {
        qty = numPart + ' ' + unitMatch[1];
        name = unitMatch[2] || rest;
      } else {
        qty = numPart;
        name = rest || text;
      }
    }

    // Clean up name
    name = name.replace(/^(of\s+)/i, '').replace(/,\s*$/, '').trim();
    if (!name) { name = text; qty = ''; }

    return { qty, name };
  }

  function normalizeItemName(name) {
    return name.toLowerCase().replace(/[^a-z0-9 ]/g, '').replace(/\s+/g, ' ').trim();
  }

  // ── Quantity combining ──
  function addQuantities(q1, q2) {
    if (!q1) return q2;
    if (!q2) return q1;

    // Try to extract numeric + unit from both
    const parse = (q) => {
      const m = q.match(/^([\d\/\.\s]+)\s*(.*)/);
      if (m) {
        let num = m[1].trim();
        // Handle fractions
        if (num.includes('/')) {
          const parts = num.split('/');
          num = parseFloat(parts[0]) / parseFloat(parts[1]);
        } else {
          num = parseFloat(num);
        }
        return { num: isNaN(num) ? null : num, unit: m[2].trim().toLowerCase() };
      }
      return { num: null, unit: q.trim().toLowerCase() };
    };

    const p1 = parse(q1);
    const p2 = parse(q2);

    if (p1.num !== null && p2.num !== null && p1.unit === p2.unit) {
      const total = p1.num + p2.num;
      const display = Number.isInteger(total) ? total.toString() : total.toFixed(1).replace(/\.0$/, '');
      return display + (p1.unit ? ' ' + p1.unit : '');
    }

    return q1 + ' + ' + q2;
  }

  // ── Core: add item ──
  function addItem(rawText, forcedCategory) {
    const parsed = parseItem(rawText);
    if (!parsed) return;

    const list = lists[currentListId];
    const normalized = normalizeItemName(parsed.name);
    const aisle = forcedCategory && forcedCategory !== 'auto' ? forcedCategory : detectAisle(rawText);

    // Check for duplicate
    const existing = list.items.find(item => normalizeItemName(item.name) === normalized && item.aisle === aisle);
    if (existing) {
      existing.qty = addQuantities(existing.qty, parsed.qty);
    } else {
      list.items.push({
        id: genId(),
        name: parsed.name,
        qty: parsed.qty,
        aisle,
        checked: false
      });
    }

    saveData();
    render();
  }

  // ── Rendering ──
  function render() {
    renderListSelect();
    renderGroceryList();
    updateItemCount();
  }

  function renderListSelect() {
    listSelect.innerHTML = '';
    for (const [id, list] of Object.entries(lists)) {
      const opt = document.createElement('option');
      opt.value = id;
      opt.textContent = list.name;
      if (id === currentListId) opt.selected = true;
      listSelect.appendChild(opt);
    }
  }

  function renderGroceryList() {
    const list = lists[currentListId];
    if (!list || list.items.length === 0) {
      groceryListEl.innerHTML = '<div class="empty-state"><div class="empty-icon">🛒</div><p>Your grocery list is empty. Add items above to get started.</p></div>';
      return;
    }

    // Group by aisle
    const groups = {};
    for (const item of list.items) {
      if (!groups[item.aisle]) groups[item.aisle] = [];
      groups[item.aisle].push(item);
    }

    // Sort aisles by order
    const sortedAisles = Object.keys(groups).sort((a, b) => {
      return (AISLES[a] ? AISLES[a].order : 99) - (AISLES[b] ? AISLES[b].order : 99);
    });

    let html = '';
    for (const aisle of sortedAisles) {
      const info = AISLES[aisle] || { label: aisle, icon: '📦', order: 99 };
      const items = groups[aisle];
      const checkedCount = items.filter(i => i.checked).length;
      html += '<div class="aisle-section">';
      html += '<div class="aisle-header" data-aisle="' + aisle + '">';
      html += '<span class="aisle-title">' + info.icon + ' ' + info.label + '</span>';
      html += '<span class="aisle-count">' + checkedCount + '/' + items.length + '</span>';
      html += '</div>';
      html += '<div class="aisle-items">';
      for (const item of items) {
        html += '<div class="grocery-item' + (item.checked ? ' checked' : '') + '" data-id="' + item.id + '">';
        html += '<div class="item-check' + (item.checked ? ' checked' : '') + '" data-id="' + item.id + '">&#10003;</div>';
        html += '<span class="item-name">' + escHtml(item.name) + '</span>';
        if (item.qty) html += '<span class="item-qty">' + escHtml(item.qty) + '</span>';
        html += '<button class="item-delete" data-id="' + item.id + '" title="Remove">&times;</button>';
        html += '</div>';
      }
      html += '</div></div>';
    }
    groceryListEl.innerHTML = html;

    // Attach events
    groceryListEl.querySelectorAll('.item-check').forEach(el => {
      el.addEventListener('click', () => toggleCheck(el.getAttribute('data-id')));
    });
    groceryListEl.querySelectorAll('.item-delete').forEach(el => {
      el.addEventListener('click', () => deleteItem(el.getAttribute('data-id')));
    });
    groceryListEl.querySelectorAll('.aisle-header').forEach(el => {
      el.addEventListener('click', () => {
        el.parentElement.classList.toggle('collapsed');
      });
    });
  }

  function updateItemCount() {
    const list = lists[currentListId];
    if (!list) return;
    const total = list.items.length;
    const checked = list.items.filter(i => i.checked).length;
    itemCountEl.textContent = total + ' item' + (total !== 1 ? 's' : '') + (checked > 0 ? ' (' + checked + ' checked)' : '');
  }

  function escHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ── Actions ──
  function toggleCheck(id) {
    const list = lists[currentListId];
    const item = list.items.find(i => i.id === id);
    if (item) { item.checked = !item.checked; saveData(); render(); }
  }

  function deleteItem(id) {
    const list = lists[currentListId];
    list.items = list.items.filter(i => i.id !== id);
    saveData();
    render();
  }

  // ── Event Listeners ──
  addItemBtn.addEventListener('click', () => {
    const text = itemInput.value.trim();
    if (!text) return;
    addItem(text, categorySelect.value);
    itemInput.value = '';
    categorySelect.value = 'auto';
  });

  itemInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      addItemBtn.click();
    }
  });

  bulkToggle.addEventListener('click', () => {
    bulkArea.classList.toggle('show');
  });

  bulkImportBtn.addEventListener('click', () => {
    const lines = bulkTextarea.value.split('\n').map(l => l.trim()).filter(Boolean);
    for (const line of lines) {
      // Remove leading bullets, dashes, numbers
      const cleaned = line.replace(/^[\-\*\u2022\d\.]+\s*/, '');
      if (cleaned) addItem(cleaned, 'auto');
    }
    bulkTextarea.value = '';
    bulkArea.classList.remove('show');
  });

  bulkClearBtn.addEventListener('click', () => {
    bulkTextarea.value = '';
  });

  uncheckAllBtn.addEventListener('click', () => {
    const list = lists[currentListId];
    list.items.forEach(i => i.checked = false);
    saveData();
    render();
  });

  removeCheckedBtn.addEventListener('click', () => {
    const list = lists[currentListId];
    list.items = list.items.filter(i => !i.checked);
    saveData();
    render();
  });

  clearAllBtn.addEventListener('click', () => {
    if (!confirm('Clear all items from this list?')) return;
    lists[currentListId].items = [];
    saveData();
    render();
  });

  listSelect.addEventListener('change', () => {
    currentListId = listSelect.value;
    saveData();
    render();
  });

  newListBtn.addEventListener('click', () => {
    const name = prompt('New list name:', 'Shopping List');
    if (!name) return;
    const id = genId();
    lists[id] = { name, items: [] };
    currentListId = id;
    saveData();
    render();
  });

  renameListBtn.addEventListener('click', () => {
    const current = lists[currentListId];
    const name = prompt('Rename list:', current.name);
    if (!name) return;
    current.name = name;
    saveData();
    render();
  });

  deleteListBtn.addEventListener('click', () => {
    if (Object.keys(lists).length <= 1) {
      alert('You must have at least one list.');
      return;
    }
    if (!confirm('Delete "' + lists[currentListId].name + '"?')) return;
    delete lists[currentListId];
    currentListId = Object.keys(lists)[0];
    saveData();
    render();
  });

  // ── Init ──
  loadData();
  render();
</script>

</SiteLayout>