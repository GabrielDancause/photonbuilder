  { name: "Cheesecake", category: "Desserts", cookTime: "35 mins", pressure: "High", release: "Natural (10 mins)", serves: "8", difficulty: "Hard" },
  { name: "Chocolate Lava Cake", category: "Desserts", cookTime: "9 mins", pressure: "High", release: "Quick", serves: "4", difficulty: "Medium" },
  { name: "Rice Pudding", category: "Desserts", cookTime: "15 mins", pressure: "High", release: "Natural (10 mins)", serves: "6", difficulty: "Easy" }
