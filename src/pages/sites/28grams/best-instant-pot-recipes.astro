---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "25 Best Instant Pot Recipes",
    "description": "Discover the 25 best Instant Pot recipes categorized by soups, grains, proteins, beans, yogurt, and desserts. Includes button guide and slow cooker conversion chart.",
    "url": "https://28grams.vip/best-instant-pot-recipes",
    "author": {
      "@type": "Organization",
      "name": "28grams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the difference between Quick Release and Natural Release?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Quick Release means manually turning the valve to release steam immediately after cooking, which stops the cooking process quickly. Natural Release means leaving the valve alone and letting the pressure drop on its own over 10-20 minutes, allowing food to finish cooking gently and retain moisture."
        }
      },
      {
        "@type": "Question",
        "name": "Can I put frozen meat in the Instant Pot?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, you can safely cook frozen meat in the Instant Pot because it heats up quickly enough to pass through the danger zone. You will need to increase the cooking time by about 50% compared to fresh meat."
        }
      },
      {
        "@type": "Question",
        "name": "Why is my Instant Pot saying 'BURN'?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The BURN notice usually means there isn't enough thin liquid in the pot, or food (especially tomatoes or thick sauces) has stuck to the bottom. To fix it, carefully release pressure, scrape the bottom of the inner pot, and add more water or broth."
        }
      },
      {
        "@type": "Question",
        "name": "How much liquid do I need in an Instant Pot?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You generally need at least 1 cup of thin liquid (like water or broth) for an 6-quart Instant Pot, and 1.5 to 2 cups for an 8-quart model, to create enough steam to build pressure."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need to adjust cooking times for high altitude?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. At higher altitudes, water boils at a lower temperature. A general rule is to increase the cooking time by 5% for every 1,000 feet above 2,000 feet elevation."
        }
      }
    ]
  }
];

const recipes = [
  // Soups/Stews
  { name: "Chicken Noodle Soup", category: "Soups/Stews", cookTime: "7 mins", pressure: "High", release: "Natural (10 mins)", serves: "6", difficulty: "Easy" },
  { name: "Beef Stew", category: "Soups/Stews", cookTime: "35 mins", pressure: "High", release: "Natural (10 mins)", serves: "6", difficulty: "Medium" },
  { name: "Butternut Squash Soup", category: "Soups/Stews", cookTime: "8 mins", pressure: "High", release: "Quick", serves: "4", difficulty: "Easy" },
  { name: "French Onion Soup", category: "Soups/Stews", cookTime: "15 mins", pressure: "High", release: "Quick", serves: "4", difficulty: "Medium" },
  { name: "Minestrone", category: "Soups/Stews", cookTime: "5 mins", pressure: "High", release: "Natural (5 mins)", serves: "6", difficulty: "Easy" },
  // Grains/Rice
  { name: "White Rice", category: "Grains/Rice", cookTime: "3 mins", pressure: "High", release: "Natural (10 mins)", serves: "4", difficulty: "Easy" },
  { name: "Brown Rice", category: "Grains/Rice", cookTime: "22 mins", pressure: "High", release: "Natural (10 mins)", serves: "4", difficulty: "Easy" },
  { name: "Quinoa", category: "Grains/Rice", cookTime: "1 min", pressure: "High", release: "Natural (10 mins)", serves: "4", difficulty: "Easy" },
  { name: "Steel Cut Oats", category: "Grains/Rice", cookTime: "4 mins", pressure: "High", release: "Natural (10 mins)", serves: "4", difficulty: "Easy" },
  { name: "Mushroom Risotto", category: "Grains/Rice", cookTime: "6 mins", pressure: "High", release: "Quick", serves: "4", difficulty: "Medium" },
  // Proteins
  { name: "Pulled Pork", category: "Proteins", cookTime: "45 mins", pressure: "High", release: "Natural (15 mins)", serves: "8", difficulty: "Medium" },
  { name: "Whole Chicken", category: "Proteins", cookTime: "25 mins", pressure: "High", release: "Natural (15 mins)", serves: "4-6", difficulty: "Medium" },
  { name: "Short Ribs", category: "Proteins", cookTime: "45 mins", pressure: "High", release: "Natural (15 mins)", serves: "4", difficulty: "Hard" },
  { name: "Hard Boiled Eggs", category: "Proteins", cookTime: "5 mins", pressure: "High", release: "Natural (5 mins)", serves: "6", difficulty: "Easy" },
  { name: "Salmon Fillets", category: "Proteins", cookTime: "3 mins", pressure: "High", release: "Quick", serves: "2", difficulty: "Easy" },
  // Beans from scratch
  { name: "Black Beans", category: "Beans", cookTime: "30 mins", pressure: "High", release: "Natural (15 mins)", serves: "6", difficulty: "Easy" },
  { name: "Chickpeas", category: "Beans", cookTime: "40 mins", pressure: "High", release: "Natural (20 mins)", serves: "6", difficulty: "Easy" },
  { name: "Pinto Beans", category: "Beans", cookTime: "25 mins", pressure: "High", release: "Natural (15 mins)", serves: "6", difficulty: "Easy" },
  { name: "Lentils", category: "Beans", cookTime: "15 mins", pressure: "High", release: "Natural (10 mins)", serves: "6", difficulty: "Easy" },
  { name: "Kidney Beans", category: "Beans", cookTime: "35 mins", pressure: "High", release: "Natural (15 mins)", serves: "6", difficulty: "Easy" },
  // Yogurt
  { name: "Plain Yogurt", category: "Yogurt", cookTime: "8-12 hrs", pressure: "None (Yogurt Mode)", release: "N/A", serves: "8", difficulty: "Medium" },
  { name: "Greek Yogurt", category: "Yogurt", cookTime: "8-12 hrs", pressure: "None (Yogurt Mode)", release: "N/A", serves: "6", difficulty: "Medium" },
