---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Coffee Brewing Methods Compared",
    "description": "A comprehensive guide comparing 12 coffee brewing methods including French press, pour over, espresso, cold brew, and more. Find the perfect method for your taste.",
    "url": "https://28grams.vip/coffee-brewing-methods",
    "author": {
      "@type": "Organization",
      "name": "28grams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the best coffee brewing method for beginners?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The French Press and drip coffee makers are generally considered the best methods for beginners. They require minimal equipment and technique while producing a consistent, full-bodied cup."
        }
      },
      {
        "@type": "Question",
        "name": "Which brewing method produces the strongest coffee?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Espresso produces the most concentrated and strongest coffee per ounce. However, Turkish coffee is also extremely strong and thick, as the fine grounds are left in the brew."
        }
      },
      {
        "@type": "Question",
        "name": "Is pour over better than a drip coffee maker?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pour over allows for more control over the brewing variables like water temperature and pouring speed, often resulting in a cleaner and more flavorful cup. Drip machines prioritize convenience."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between cold brew and iced coffee?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cold brew is made by steeping coarse coffee grounds in cold water for 12-24 hours, resulting in a smooth, low-acid brew. Iced coffee is typically hot-brewed coffee that is chilled or poured over ice."
        }
      },
      {
        "@type": "Question",
        "name": "Why do I need a specific grind size for different methods?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Grind size determines the surface area of the coffee exposed to water, which affects the extraction rate. Methods with short brew times (like espresso) need a fine grind, while longer methods (like French press) need a coarse grind to prevent over-extraction and bitterness."
        }
      }
    ]
  }
];

const methods = [
  { name: "French Press", grindSize: "Coarse", waterTemp: "200°F", brewTime: "4 mins", body: "Heavy/Full", costToStart: "Low", skillLevel: "Beginner" },
  { name: "Pour Over (V60, Chemex)", grindSize: "Medium-Fine", waterTemp: "195-205°F", brewTime: "3-4 mins", body: "Light/Clean", costToStart: "Low-Medium", skillLevel: "Intermediate" },
  { name: "AeroPress", grindSize: "Medium-Fine", waterTemp: "175-205°F", brewTime: "1-2 mins", body: "Medium/Smooth", costToStart: "Low", skillLevel: "Beginner-Intermediate" },
  { name: "Espresso", grindSize: "Fine", waterTemp: "195-205°F", brewTime: "25-30 secs", body: "Syrupy/Intense", costToStart: "High", skillLevel: "Expert" },
  { name: "Moka Pot", grindSize: "Medium-Fine", waterTemp: "Boiling", brewTime: "5 mins", body: "Heavy/Strong", costToStart: "Low", skillLevel: "Intermediate" },
  { name: "Cold Brew", grindSize: "Extra Coarse", waterTemp: "Cold/Room Temp", brewTime: "12-24 hrs", body: "Smooth/Low Acid", costToStart: "Low", skillLevel: "Beginner" },
  { name: "Drip", grindSize: "Medium", waterTemp: "195-205°F", brewTime: "5-10 mins", body: "Medium", costToStart: "Low-Medium", skillLevel: "Beginner" },
  { name: "Siphon", grindSize: "Medium", waterTemp: "200°F", brewTime: "3-5 mins", body: "Clean/Complex", costToStart: "Medium-High", skillLevel: "Advanced" },
  { name: "Turkish", grindSize: "Extra Fine", waterTemp: "Almost Boiling", brewTime: "3-4 mins", body: "Thick/Unfiltered", costToStart: "Low", skillLevel: "Intermediate" },
  { name: "Percolator", grindSize: "Coarse", waterTemp: "Boiling", brewTime: "5-8 mins", body: "Heavy/Often Bitter", costToStart: "Low", skillLevel: "Beginner" },
  { name: "Instant", grindSize: "N/A", waterTemp: "Any", brewTime: "Instant", body: "Light/Varies", costToStart: "Low", skillLevel: "Beginner" },
  { name: "Nespresso", grindSize: "Pre-packaged", waterTemp: "Pre-set", brewTime: "30-60 secs", body: "Medium/Consistent", costToStart: "Medium", skillLevel: "Beginner" }
];
---
<SiteLayout
  site="28grams"
  canonical="https://28grams.vip/coffee-brewing-methods"
  schema={schema}
>
  <style>
.page-wrapper {
  --card-bg: #120c10;
  --border-color: #2a1820;
  --accent-color: #C2185B;
  --text-secondary: #888;
  font-family: 'Inter', sans-serif;
  background: #0a060a;
  color: #e0d0d8;
  min-height: 100vh;
}
.page-wrapper * {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
.mono { font-family: 'JetBrains Mono', monospace; }

.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, var(--accent-color), #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1000px; margin: 0 auto; padding: 32px 20px 40px; }

.chart-card {
  background: var(--card-bg);
  border: 2px solid var(--border-color);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid var(--border-color);
}
.chart-header h2 { font-size: 1rem; font-weight: 700; color: #fff; }

.table-container {
  width: 100%;
  overflow-x: auto;
}

.compare-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 800px;
}
.compare-table th {
  text-align: left;
  font-size: 0.75rem;
  color: var(--text-secondary);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 12px 16px;
  background: #1a1015;
  border-bottom: 2px solid var(--border-color);
  position: sticky;
  top: 0;
}
.compare-table td {
  padding: 12px 16px;
  font-size: 0.9rem;
  color: #c8b8c0;
  border-bottom: 1px solid #1a1015;
}
.compare-table tr:hover td { background: #1a1015; }
.compare-table td:first-child { font-weight: 600; color: #fff; }

.recipe-name { font-weight: bold; color: #fff; }

.content { max-width: 800px; margin: 0 auto; padding: 0 20px; }
.content h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 40px 0 14px; }
.content h2:first-child { margin-top: 0; }
.content h3 { font-size: 1.1rem; font-weight: 700; color: #ddd; margin: 24px 0 10px; }
.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }
.content ul, .content ol { padding-left: 20px; margin-bottom: 14px; }
.content li { font-size: 0.88rem; color: #777; line-height: 1.8; margin-bottom: 4px; }
.content strong { color: #ccc; }

.faq-list { margin-top: 24px; }
.faq-item { margin-bottom: 24px; }
.faq-q { font-weight: 700; color: #fff; margin-bottom: 8px; font-size: 1.05rem; }
.faq-a { color: #777; font-size: 0.95rem; line-height: 1.6; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
}
  </style>

  <div class="page-wrapper">
    <div class="hero">
      <h1>Coffee Brewing <span>Methods</span> ☕</h1>
      <p>Discover the perfect cup. Compare 12 different coffee brewing methods by grind size, brew time, cost, skill level, and flavor profile to find your ideal match.</p>
    </div>

    <div class="main">

      <div class="chart-card">
        <div class="chart-header">
          <h2>12 Coffee Brewing Methods</h2>
        </div>
        <div class="table-container">
          <table class="compare-table">
            <thead>
              <tr>
                <th>Method</th>
                <th>Grind Size</th>
                <th>Water Temp</th>
                <th>Brew Time</th>
                <th>Body/Strength</th>
                <th>Cost to Start</th>
                <th>Skill Level</th>
              </tr>
            </thead>
            <tbody>
              {methods.map((method) => (
                <tr>
                  <td class="recipe-name">{method.name}</td>
                  <td>{method.grindSize}</td>
                  <td class="mono">{method.waterTemp}</td>
                  <td class="mono">{method.brewTime}</td>
                  <td>{method.body}</td>
                  <td>{method.costToStart}</td>
                  <td>{method.skillLevel}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <div class="content">
      <h2>Immersion Methods</h2>
      <ul>
        <li><strong>French Press:</strong> Grounds are steeped in hot water, then separated by pressing down a metal filter. Produces a robust, full-bodied cup with natural oils intact.</li>
        <li><strong>Cold Brew:</strong> Coarsely ground coffee steeped in cold or room-temperature water for 12-24 hours. The result is a highly caffeinated, exceptionally smooth, and low-acidity concentrate.</li>
        <li><strong>AeroPress:</strong> A versatile brewer that combines immersion and pressure. Water and grounds steep briefly before being pushed through a paper or metal filter, resulting in a clean yet full-bodied cup.</li>
      </ul>

      <h2>Pour Over & Drip Methods</h2>
      <ul>
        <li><strong>Pour Over (V60, Chemex):</strong> Hot water is manually poured over grounds in a filter. This method highlights the coffee's delicate flavors and bright acidity, producing a clean, tea-like body.</li>
        <li><strong>Drip Coffee Maker:</strong> The classic automated machine. Water is heated and dripped evenly over a basket of coffee grounds. Convenient and consistent for brewing multiple cups at once.</li>
      </ul>

      <h2>Pressure Methods</h2>
      <ul>
        <li><strong>Espresso:</strong> Highly pressurized near-boiling water is forced through tightly packed, finely ground coffee. Yields a concentrated, syrupy shot with a rich crema.</li>
        <li><strong>Moka Pot:</strong> A stovetop brewer where boiling water creates steam pressure, pushing water up through coffee grounds. Produces a strong, espresso-like coffee with a heavy body.</li>
      </ul>

      <h2>Specialty Methods</h2>
      <ul>
        <li><strong>Siphon (Vacuum Pot):</strong> Uses a combination of immersion, vacuum pressure, and a heat source. Visually stunning and produces a remarkably clean, crisp, and vibrant cup.</li>
        <li><strong>Turkish:</strong> Extra-fine grounds are boiled with water (and often sugar) in a small pot called a cezve. Served unfiltered, resulting in a thick, potent, and highly caffeinated beverage.</li>
        <li><strong>Percolator:</strong> Continuously cycles boiling water through grounds until the desired strength is reached. Known for producing a very strong, hot cup, though it can easily over-extract and become bitter.</li>
      </ul>

      <h2>Convenience Methods</h2>
      <ul>
        <li><strong>Instant Coffee:</strong> Brewed coffee that has been freeze-dried or spray-dried into soluble crystals. Just add hot water. The most convenient but generally lacks complexity.</li>
        <li><strong>Nespresso:</strong> A proprietary pod-based system that forces water through pre-packaged capsules. Highly convenient and consistent, producing a shot with a signature foamy top.</li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {schema[1].mainEntity.map((faq: any) => (
          <div class="faq-item">
            <div class="faq-q">{faq.name}</div>
            <div class="faq-a">{faq.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</SiteLayout>
