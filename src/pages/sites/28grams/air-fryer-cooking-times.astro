---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Air Fryer Cooking Times Chart",
      "description": "Comprehensive air fryer cooking times reference chart. Sortable and filterable table with 60+ foods organized by category.",
      "url": "https://28grams.vip/air-fryer-cooking-times",
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Do I need to preheat my air fryer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "While not strictly necessary for all foods, preheating your air fryer for 3-5 minutes can help achieve a crispier exterior, especially for meats and frozen foods. If you don't preheat, you may need to add 1-3 minutes to the cooking time."
          }
        },
        {
          "@type": "Question",
          "name": "Should I use oil in my air fryer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, but very little. Tossing fresh foods (like vegetables or chicken wings) in 1-2 teaspoons of oil helps them crisp up and prevents sticking. Frozen foods generally do not need extra oil as they already contain some."
          }
        },
        {
          "@type": "Question",
          "name": "Why do I need to shake or flip the food?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Air fryers cook by circulating hot air. Shaking the basket or flipping the food halfway through ensures that the air reaches all sides evenly, resulting in a uniform, crispy texture."
          }
        },
        {
          "@type": "Question",
          "name": "Can I put aluminum foil or parchment paper in an air fryer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, you can use aluminum foil or special perforated air fryer parchment paper. Ensure it doesn't block all the airflow and always place food on top to weigh it down so it doesn't fly up into the heating element."
          }
        },
        {
          "@type": "Question",
          "name": "How do I convert oven times to air fryer times?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A general rule of thumb is to reduce the suggested oven temperature by 25°F and cut the cooking time by about 20% to 25%. Always check the food early to prevent overcooking."
          }
        },
        {
          "@type": "Question",
          "name": "Why is my air fryer smoking?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Smoking usually happens when cooking high-fat foods (like bacon or burgers) and the grease drips onto the hot base. Adding a tablespoon of water or a piece of bread to the bottom of the drawer can help absorb the grease and stop the smoke."
          }
        },
        {
          "@type": "Question",
          "name": "Can I cook raw meat in an air fryer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Absolutely! You can cook raw chicken, beef, pork, and seafood in an air fryer. Just ensure you cook it to the proper internal temperature using a meat thermometer."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Air Fryer Cooking Times Chart | The Ultimate Cheat Sheet",
  description: "Comprehensive air fryer cooking times reference chart for 60+ foods. Includes temps, times, and tips for chicken, beef, pork, seafood, vegetables, and frozen foods.",
  category: "guide",
  published: "2024-05-15",
};
