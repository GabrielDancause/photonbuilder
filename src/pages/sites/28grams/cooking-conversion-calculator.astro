---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Cooking Conversion Calculator",
  "url": "https://28grams.vip/cooking-conversion-calculator",
  "description": "All-in-one cooking measurement converter with 40+ ingredient densities, temperature converter with Gas Mark, and recipe scaler. Convert cups, tablespoons, grams, ounces, liters and more.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "GAB Ventures",
    "url": "https://gab.ae"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the ingredient-specific conversion work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When you convert between volume (cups, tablespoons) and weight (grams, ounces), the result depends on the ingredient's density. For example, 1 cup of all-purpose flour weighs 125g while 1 cup of honey weighs 340g. Our calculator includes density data for 40+ common cooking ingredients so you get accurate conversions every time."
      }
    },
    {
      "@type": "Question",
      "name": "How do I use the recipe scaler?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Enter the original number of servings your recipe makes, then enter how many servings you want. Add each ingredient with its amount and unit. The calculator automatically multiplies every ingredient by the correct ratio. For example, scaling from 4 servings to 6 multiplies everything by 1.5×."
      }
    },
    {
      "@type": "Question",
      "name": "What is a Gas Mark and how does it relate to Fahrenheit and Celsius?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gas Mark is a temperature scale used on gas ovens, primarily in the UK and some Commonwealth countries. Gas Mark 1 equals 275°F (135°C), and each mark increases by about 25°F (14°C). Common baking temperatures: Gas Mark 4 = 350°F (177°C), Gas Mark 5 = 375°F (191°C), Gas Mark 6 = 400°F (204°C)."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between US and metric cups?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A US cup equals 236.588 ml, while a metric cup (used in Australia and some other countries) equals 250 ml. This calculator uses US cups by default, as they are the standard in most English-language recipes. The difference of about 13ml can matter in precise baking, so always check which cup standard your recipe uses."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate are volume-to-weight conversions for dry ingredients?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Volume-to-weight conversions for dry ingredients like flour and sugar can vary by 10-15% depending on how you measure. Scooping flour directly from the bag compacts it, giving a heavier cup (up to 150g) versus the spoon-and-level method (125g). Our values use the spoon-and-level method, which is the standard referenced by most cookbook authors. For best accuracy, use a kitchen scale."
      }
    }
  ]
};

export const meta = {
  title: "Cooking Conversion Calculator — Ingredients, Temperature & Recipe Scaler | 28grams",
  description: "All-in-one cooking conversion calculator with 40+ ingredient densities, temperature converter (°F/°C/Gas Mark), and recipe scaler. Convert cups, grams, ounces, tablespoons, liters and more.",
  category: "tool",
  published: "2026-03-21",
};
---

<SiteLayout
  site="28grams"
  title="Cooking Conversion Calculator — Ingredients, Temperature & Recipe Scaler | 28grams"
  description="All-in-one cooking conversion calculator with 40+ ingredient densities, temperature converter (°F/°C/Gas Mark), and recipe scaler. Convert cups, grams, ounces, tablespoons, liters and more."
  canonical="https://28grams.vip/cooking-conversion-calculator"
  schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', sans-serif; background: var(--bg, #0a0b10); color: var(--text, #e0d0d8); min-height: 100vh; }
code, .mono { font-family: 'JetBrains Mono', monospace; }

:root {
  --bg: #0a0b10;
  --bg-card: #111318;
  --bg-card-header: #151820;
  --border: #1e2030;
  --accent: #C2185B;
  --accent-glow: rgba(194, 24, 91, 0.15);
  --text: #e0d0d8;
  --text-muted: #8892b0;
  --text-dim: #666;
  --text-white: #fff;
  --mono: 'JetBrains Mono', monospace;
}

.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: var(--text-white); margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, var(--accent), #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: var(--text-muted); font-size: 0.95rem; max-width: 600px; margin: 0 auto; }
.main { max-width: 900px; margin: 0 auto; padding: 32px 20px 40px; }

.converter-card {
  background: var(--bg-card);
  border: 2px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 24px;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: var(--bg-card-header);
  border-bottom: 1px solid var(--border);
}
.card-header h2 { font-size: 0.95rem; font-weight: 700; color: #ccc; }
.card-body { padding: 24px 20px; display: flex; flex-direction: column; gap: 16px; }

.conv-row {
  display: flex;
  gap: 12px;
  align-items: flex-end;
  flex-wrap: wrap;
}
.conv-field { display: flex; flex-direction: column; gap: 4px; }
.conv-field label { font-size: 0.7rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.conv-field.amount-field { width: 110px; }
.conv-field.unit-field { flex: 1; min-width: 140px; }
.conv-field.ingredient-field { flex: 1; min-width: 180px; }

.conv-field input, .conv-field select {
  background: var(--bg);
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 10px 12px;
  color: var(--text-white);
  font-family: 'Inter', sans-serif;
  font-size: 0.88rem;
  outline: none;
}
.conv-field input:focus, .conv-field select:focus { border-color: var(--accent); }
.conv-field select {
  appearance: none;
  cursor: pointer;
  background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg width="10" height="6" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M1 1.5L6 6.5L11 1.5" stroke="%23888888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/%3E%3C/svg%3E');
  background-repeat: no-repeat;
  background-position: right 10px center;
  padding-right: 28px;
}

.swap-btn {
  background: var(--accent-glow);
  border: 2px solid var(--accent);
  color: var(--accent);
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 1rem;
  cursor: pointer;
  transition: background 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
}
.swap-btn:hover { background: rgba(194, 24, 91, 0.3); }

.result-display {
  background: var(--bg);
  border: 2px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  text-align: center;
}
.result-display .result-value {
  font-family: var(--mono);
  font-size: 2rem;
  font-weight: 800;
  color: var(--accent);
}
.result-display .result-label {
  font-size: 0.82rem;
  color: var(--text-dim);
  margin-top: 4px;
}
.ingredient-note {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-align: center;
  font-style: italic;
}

/* Reference tables */
.ref-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
}
.ref-table {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.ref-table h3 {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--accent);
  padding: 12px 14px;
  background: var(--bg-card-header);
  border-bottom: 1px solid var(--border);
}
.ref-table table { width: 100%; border-collapse: collapse; }
.ref-table th {
  font-size: 0.68rem;
  font-weight: 600;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 8px 14px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}
.ref-table td {
  font-size: 0.82rem;
  color: #ccc;
  padding: 8px 14px;
  border-bottom: 1px solid #0d0e14;
  font-family: var(--mono);
}
.ref-table tr:last-child td { border-bottom: none; }
.ref-table tr:hover td { background: var(--bg-card); }

/* Temp converter */
.temp-row {
  display: flex;
  gap: 12px;
  align-items: flex-end;
  flex-wrap: wrap;
}
.temp-field { display: flex; flex-direction: column; gap: 4px; flex: 1; min-width: 110px; }
.temp-field label { font-size: 0.7rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.temp-field input {
  background: var(--bg);
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 10px 12px;
  color: var(--text-white);
  font-family: var(--mono);
  font-size: 0.95rem;
  outline: none;
}
.temp-field input:focus { border-color: var(--accent); }
.temp-equal { color: #444; font-size: 1.2rem; font-weight: 700; padding-bottom: 8px; }

.oven-temps {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
}
.oven-chip {
  background: var(--bg-card-header);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 12px;
  font-size: 0.75rem;
  font-family: var(--mono);
  color: #999;
  cursor: pointer;
  transition: all 0.15s;
}
.oven-chip:hover { border-color: var(--accent); color: var(--text-white); }
.oven-chip .temp-f { color: var(--accent); font-weight: 600; }
.oven-chip .temp-c { color: var(--text-muted); }
.oven-chip .temp-g { color: #7c8db5; }

/* Recipe scaler */
.scaler-header {
  display: flex;
  gap: 12px;
  align-items: flex-end;
  flex-wrap: wrap;
  margin-bottom: 8px;
}
.scaler-field { display: flex; flex-direction: column; gap: 4px; }
.scaler-field label { font-size: 0.7rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
.scaler-field input {
  background: var(--bg);
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 10px 12px;
  color: var(--text-white);
  font-family: var(--mono);
  font-size: 0.88rem;
  outline: none;
  width: 100px;
}
.scaler-field input:focus { border-color: var(--accent); }
.scaler-ratio {
  font-family: var(--mono);
  font-size: 0.85rem;
  color: var(--accent);
  font-weight: 700;
  padding-bottom: 10px;
}

.ingredient-list { display: flex; flex-direction: column; gap: 8px; }
.ing-row {
  display: flex;
  gap: 8px;
  align-items: center;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 10px 12px;
}
.ing-row input[type="number"] {
  background: transparent;
  border: none;
  color: var(--text-white);
  font-family: var(--mono);
  font-size: 0.88rem;
  width: 70px;
  outline: none;
}
.ing-row input[type="text"] {
  background: transparent;
  border: none;
  color: #ccc;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  flex: 1;
  outline: none;
  min-width: 80px;
}
.ing-row .scaled-val {
  font-family: var(--mono);
  font-size: 0.85rem;
  color: var(--accent);
  font-weight: 700;
  min-width: 70px;
  text-align: right;
}
.ing-row .arrow { color: var(--text-dim); font-size: 0.8rem; }
.ing-remove {
  background: none;
  border: none;
  color: #555;
  cursor: pointer;
  font-size: 1rem;
  padding: 0 4px;
  transition: color 0.15s;
}
.ing-remove:hover { color: var(--accent); }
.add-ing-btn {
  background: var(--accent-glow);
  border: 2px dashed var(--border);
  color: var(--text-muted);
  padding: 10px;
  border-radius: 10px;
  font-size: 0.82rem;
  cursor: pointer;
  transition: all 0.15s;
  text-align: center;
}
.add-ing-btn:hover { border-color: var(--accent); color: var(--text-white); }

/* FAQ */
.faq-section { margin-top: 0; }
.faq-item {
  border-bottom: 1px solid var(--border);
  padding: 16px 0;
}
.faq-item:last-child { border-bottom: none; }
.faq-q {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text-white);
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}
.faq-q::after {
  content: '+';
  font-size: 1.2rem;
  color: var(--accent);
  transition: transform 0.2s;
  flex-shrink: 0;
}
.faq-item.open .faq-q::after { content: '−'; }
.faq-a {
  font-size: 0.84rem;
  color: var(--text-muted);
  line-height: 1.65;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s, padding 0.3s;
  padding-top: 0;
}
.faq-item.open .faq-a { max-height: 300px; padding-top: 10px; }

/* Related tools */
.related-tools {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 12px;
}
.related-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 16px;
  background: var(--bg-card-header);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: #ccc;
  text-decoration: none;
  font-size: 0.82rem;
  font-weight: 600;
  transition: all 0.15s;
}
.related-link:hover { border-color: var(--accent); color: var(--text-white); }
.related-link span { font-size: 1rem; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.6rem; }
  .conv-row { flex-direction: column; }
  .conv-field.amount-field { width: 100%; }
  .swap-btn { align-self: center; transform: rotate(90deg); }
  .result-display .result-value { font-size: 1.5rem; }
  .ref-grid { grid-template-columns: 1fr; }
  .temp-row { flex-direction: column; }
  .temp-equal { text-align: center; padding: 0; }
  .scaler-header { flex-direction: column; }
  .scaler-field input { width: 100%; }
}
  </style>

