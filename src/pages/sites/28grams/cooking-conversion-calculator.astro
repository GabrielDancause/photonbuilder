  </div>

  <script type="module">
  // Density data: grams per cup (US cup = 236.588 ml) — 40+ ingredients
  const ingredients = {
    water: { name: 'Water', gPerCup: 236.59 },
    // Flours
    allpurpose_flour: { name: 'All-Purpose Flour', gPerCup: 125 },
    bread_flour: { name: 'Bread Flour', gPerCup: 130 },
    cake_flour: { name: 'Cake Flour', gPerCup: 114 },
    whole_wheat_flour: { name: 'Whole Wheat Flour', gPerCup: 128 },
    almond_flour: { name: 'Almond Flour', gPerCup: 96 },
    coconut_flour: { name: 'Coconut Flour', gPerCup: 80 },
    rye_flour: { name: 'Rye Flour', gPerCup: 102 },
    semolina_flour: { name: 'Semolina Flour', gPerCup: 167 },
    // Sugars & Sweeteners
    granulated_sugar: { name: 'Granulated Sugar', gPerCup: 200 },
    powdered_sugar: { name: 'Powdered Sugar', gPerCup: 120 },
    brown_sugar_packed: { name: 'Brown Sugar (packed)', gPerCup: 220 },
    honey: { name: 'Honey', gPerCup: 340 },
    maple_syrup: { name: 'Maple Syrup', gPerCup: 322 },
    corn_syrup: { name: 'Corn Syrup', gPerCup: 328 },
    molasses: { name: 'Molasses', gPerCup: 337 },
    agave_nectar: { name: 'Agave Nectar', gPerCup: 336 },
    // Dairy & Fats
    butter: { name: 'Butter', gPerCup: 227 },
    vegetable_oil: { name: 'Vegetable Oil', gPerCup: 218 },
    olive_oil: { name: 'Olive Oil', gPerCup: 216 },
    coconut_oil: { name: 'Coconut Oil (melted)', gPerCup: 218 },
    milk: { name: 'Milk (whole)', gPerCup: 244 },
    heavy_cream: { name: 'Heavy Cream', gPerCup: 238 },
    sour_cream: { name: 'Sour Cream', gPerCup: 230 },
    cream_cheese: { name: 'Cream Cheese', gPerCup: 232 },
    yogurt: { name: 'Yogurt', gPerCup: 245 },
    buttermilk: { name: 'Buttermilk', gPerCup: 245 },
    // Grains & Starches
    rolled_oats: { name: 'Rolled Oats', gPerCup: 90 },
    rice_uncooked: { name: 'Rice (uncooked)', gPerCup: 185 },
    cornstarch: { name: 'Cornstarch', gPerCup: 128 },
    cornmeal: { name: 'Cornmeal', gPerCup: 150 },
    breadcrumbs: { name: 'Breadcrumbs (dry)', gPerCup: 108 },
    panko: { name: 'Panko Breadcrumbs', gPerCup: 60 },
    // Nuts & Seeds
    almonds_sliced: { name: 'Almonds (sliced)', gPerCup: 92 },
    walnuts_chopped: { name: 'Walnuts (chopped)', gPerCup: 120 },
    peanut_butter: { name: 'Peanut Butter', gPerCup: 258 },
    shredded_coconut: { name: 'Shredded Coconut', gPerCup: 85 },
    chia_seeds: { name: 'Chia Seeds', gPerCup: 160 },
    flax_seeds: { name: 'Flax Seeds', gPerCup: 150 },
    // Leaveners & Spices
    baking_powder: { name: 'Baking Powder', gPerCup: 230 },
    baking_soda: { name: 'Baking Soda', gPerCup: 220 },
    salt_table: { name: 'Table Salt', gPerCup: 288 },
    salt_kosher: { name: 'Kosher Salt (Morton)', gPerCup: 241 },
    cinnamon_ground: { name: 'Ground Cinnamon', gPerCup: 125 },
    cocoa_powder: { name: 'Cocoa Powder', gPerCup: 86 },
    // Other
    chocolate_chips: { name: 'Chocolate Chips', gPerCup: 170 },
    raisins: { name: 'Raisins', gPerCup: 165 },
    applesauce: { name: 'Applesauce', gPerCup: 244 },
    pumpkin_puree: { name: 'Pumpkin Puree', gPerCup: 245 }
  };

  // Volume units in ml
  const volumeUnits = {
    cup: { name: 'cup', ml: 236.588 },
    tbsp: { name: 'tbsp', ml: 14.787 },
    tsp: { name: 'tsp', ml: 4.929 },
    floz: { name: 'fl oz', ml: 29.574 },
    ml: { name: 'ml', ml: 1 },
    l: { name: 'L', ml: 1000 },
    pint: { name: 'pint', ml: 473.176 },
    quart: { name: 'quart', ml: 946.353 },
    gallon: { name: 'gallon', ml: 3785.41 }
  };

  // Weight units in grams
  const weightUnits = {
    g: { name: 'g', g: 1 },
    oz: { name: 'oz', g: 28.3495 },
    lb: { name: 'lb', g: 453.592 },
    kg: { name: 'kg', g: 1000 }
  };

  function isVolume(unit) { return unit in volumeUnits; }
  function isWeight(unit) { return unit in weightUnits; }

  function convert(amount, fromUnit, toUnit, ingredientKey) {
    const fromVol = isVolume(fromUnit);
    const toVol = isVolume(toUnit);
    const fromWt = isWeight(fromUnit);
    const toWt = isWeight(toUnit);
    const ing = ingredients[ingredientKey];

    if (fromVol && toVol) {
      return amount * volumeUnits[fromUnit].ml / volumeUnits[toUnit].ml;
    }
    if (fromWt && toWt) {
      return amount * weightUnits[fromUnit].g / weightUnits[toUnit].g;
    }
    if (fromVol && toWt) {
      const ml = amount * volumeUnits[fromUnit].ml;
      const cups = ml / 236.588;
      const g = cups * ing.gPerCup;
      return g / weightUnits[toUnit].g;
    }
    if (fromWt && toVol) {
      const g = amount * weightUnits[fromUnit].g;
      const cups = g / ing.gPerCup;
      const ml = cups * 236.588;
      return ml / volumeUnits[toUnit].ml;
    }
    return 0;
  }

  function getUnitLabel(unit) {
    if (volumeUnits[unit]) return volumeUnits[unit].name;
    if (weightUnits[unit]) return weightUnits[unit].name;
    return unit;
  }

  function formatNum(n) {
    if (n === 0) return '0';
    if (Math.abs(n) >= 100) return n.toFixed(1);
    if (Math.abs(n) >= 10) return n.toFixed(2);
    if (Math.abs(n) >= 1) return n.toFixed(3);
    return n.toFixed(4);
  }

  // --- Unit Converter ---
  const amountEl = document.getElementById('amount');
  const fromEl = document.getElementById('fromUnit');
  const toEl = document.getElementById('toUnit');
  const ingEl = document.getElementById('ingredient');
  const ingRow = document.getElementById('ingredientRow');
  const resultVal = document.getElementById('resultValue');
  const resultLbl = document.getElementById('resultLabel');
  const convType = document.getElementById('convType');
  const ingNote = document.getElementById('ingredientNote');
  const swapBtn = document.getElementById('swapBtn');

  function needsIngredient() {
    const f = fromEl.value, t = toEl.value;
    return (isVolume(f) && isWeight(t)) || (isWeight(f) && isVolume(t));
  }

  function updateConverter() {
    const amount = parseFloat(amountEl.value) || 0;
    const from = fromEl.value;
    const to = toEl.value;
    const ing = ingEl.value;
    const crossType = needsIngredient();

    ingRow.style.display = crossType ? '' : 'none';

    const fromIsVol = isVolume(from);
    const toIsVol = isVolume(to);
    if (fromIsVol && toIsVol) convType.textContent = 'volume → volume';
    else if (!fromIsVol && !toIsVol) convType.textContent = 'weight → weight';
    else convType.textContent = 'volume ↔ weight';

    const result = convert(amount, from, to, ing);
    const formatted = formatNum(result);
    const toLabel = getUnitLabel(to);
    const fromLabel = getUnitLabel(from);

    resultVal.textContent = `${formatted} ${toLabel}`;
    resultLbl.textContent = `${amount} ${fromLabel} = ${formatted} ${toLabel}`;

    if (crossType) {
      ingNote.textContent = `Using density for ${ingredients[ing].name} (${ingredients[ing].gPerCup}g per cup)`;
    } else {
      ingNote.textContent = '';
    }
  }

  amountEl.addEventListener('input', updateConverter);
  fromEl.addEventListener('change', updateConverter);
  toEl.addEventListener('change', updateConverter);
  ingEl.addEventListener('change', updateConverter);

  swapBtn.addEventListener('click', () => {
    const temp = fromEl.value;
    fromEl.value = toEl.value;
    toEl.value = temp;
    updateConverter();
  });

  // --- Temperature Converter (F / C / Gas Mark) ---
  const tempF = document.getElementById('tempF');
  const tempC = document.getElementById('tempC');
  const tempGas = document.getElementById('tempGas');
  let tempLock = false;

  function fToC(f) { return Math.round((f - 32) * 5 / 9); }
  function cToF(c) { return Math.round(c * 9 / 5 + 32); }
  function fToGas(f) {
    if (f < 250) return 0;
    const mark = (f - 250) / 25;
    return Math.round(mark * 2) / 2;
  }
  function gasToF(g) { return Math.round(g * 25 + 250); }

  tempF.addEventListener('input', () => {
    if (tempLock) return;
    tempLock = true;
    const f = parseFloat(tempF.value);
    if (!isNaN(f)) {
      tempC.value = fToC(f);
      tempGas.value = fToGas(f);
    }
    tempLock = false;
  });

  tempC.addEventListener('input', () => {
    if (tempLock) return;
    tempLock = true;
    const c = parseFloat(tempC.value);
    if (!isNaN(c)) {
      const f = cToF(c);
      tempF.value = f;
      tempGas.value = fToGas(f);
    }
    tempLock = false;
  });

  tempGas.addEventListener('input', () => {
    if (tempLock) return;
    tempLock = true;
    const g = parseFloat(tempGas.value);
    if (!isNaN(g)) {
      const f = gasToF(g);
      tempF.value = f;
      tempC.value = fToC(f);
    }
    tempLock = false;
  });

  document.querySelectorAll('.oven-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const f = parseInt(chip.dataset.f);
      tempF.value = f;
      tempC.value = fToC(f);
      tempGas.value = fToGas(f);
    });
  });

  // --- Recipe Scaler ---
  const origServings = document.getElementById('origServings');
  const desiredServings = document.getElementById('desiredServings');
  const ingredientList = document.getElementById('ingredientList');
  const addIngBtn = document.getElementById('addIngBtn');
  const scaleRatioEl = document.getElementById('scaleRatio');

  function getScaleRatio() {
    const orig = parseFloat(origServings.value) || 1;
    const desired = parseFloat(desiredServings.value) || 1;
    return desired / orig;
  }

  function updateScaler() {
    const ratio = getScaleRatio();
    scaleRatioEl.textContent = `${ratio % 1 === 0 ? ratio : ratio.toFixed(2)}×`;

    ingredientList.querySelectorAll('.ing-row').forEach(row => {
      const qty = parseFloat(row.querySelector('.ing-qty').value) || 0;
      const scaled = qty * ratio;
      const display = scaled % 1 === 0 ? scaled.toString() : scaled.toFixed(2);
      row.querySelector('.scaled-val').textContent = display;
    });
  }

  function addIngredientRow(qty = '', unit = '', name = '') {
    const row = document.createElement('div');
    row.className = 'ing-row';
    row.innerHTML = `
      <input type="number" class="ing-qty" value="${qty}" min="0" step="any" placeholder="Qty" />
      <input type="text" class="ing-unit" value="${unit}" placeholder="unit" style="max-width:70px;" />
      <input type="text" class="ing-name" value="${name}" placeholder="ingredient name" />
      <span class="arrow">→</span>
      <span class="scaled-val">${qty}</span>
      <button class="ing-remove" title="Remove">×</button>
    `;
    ingredientList.appendChild(row);
    bindRowEvents(row);
    updateScaler();
  }

  function bindRowEvents(row) {
    row.querySelector('.ing-qty').addEventListener('input', updateScaler);
    row.querySelector('.ing-remove').addEventListener('click', () => {
      row.remove();
      updateScaler();
    });
  }

  ingredientList.querySelectorAll('.ing-row').forEach(bindRowEvents);
  origServings.addEventListener('input', updateScaler);
  desiredServings.addEventListener('input', updateScaler);
  addIngBtn.addEventListener('click', () => addIngredientRow());

  // --- FAQ Toggles ---
  document.querySelectorAll('.faq-q').forEach(q => {
    q.addEventListener('click', () => {
      q.parentElement.classList.toggle('open');
    });
  });

  // Initial calculations
  updateConverter();
  updateScaler();
  </script>
